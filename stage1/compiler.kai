# stage 1: kaikai compiler, written in kaikai-minimal.
#
# This file is compiled by stage 0 (the C bootstrap) into `kaic1`. kaic1
# then compiles kaikai source to portable C. The module starts with
# shared utilities, then grows a lexer, parser, checker, and emitter in
# successive milestones. See docs/stage1-design.md.

# ====================================================================
# char classification helpers
# ====================================================================

fn ch_is_digit(c: Char) : Bool = c >= '0' and c <= '9'
fn ch_is_lower(c: Char) : Bool = c >= 'a' and c <= 'z'
fn ch_is_upper(c: Char) : Bool = c >= 'A' and c <= 'Z'
fn ch_is_alpha(c: Char) : Bool = ch_is_lower(c) or ch_is_upper(c) or c == '_'
fn ch_is_alnum(c: Char) : Bool = ch_is_alpha(c) or ch_is_digit(c)
fn ch_is_space(c: Char) : Bool = c == ' ' or c == '\t' or c == '\r'

# ====================================================================
# token kinds + tokens
# ====================================================================

type TokKind
  = TkEof
  | TkNewline
  # keywords (alphabetical)
  | TkAnd | TkAs | TkAssert | TkElse | TkFalse | TkFn | TkIf | TkImport
  | TkLet | TkMatch | TkNot | TkOr | TkPub | TkTest | TkTrue | TkType
  # literals
  | TkInt | TkReal | TkChar | TkString
  # identifiers
  | TkIdent | TkUnderscore
  # punctuation
  | TkLparen | TkRparen | TkLbracket | TkRbracket | TkLbrace | TkRbrace
  | TkComma | TkColon | TkSemi | TkDot | TkDotDot | TkEllipsis
  # operators
  | TkEq | TkArrow | TkFatArrow | TkPipe | TkPipeApply
  | TkPlus | TkMinus | TkStar | TkSlash | TkPercent
  | TkEqEq | TkNeq | TkLt | TkGt | TkLe | TkGe
  | TkBang
  # error token carries a human-readable message
  | TkError(String)

type Token = { kind: TokKind, line: Int, col: Int, start: Int, length: Int }

# Convenience constructor — fewer characters at call sites.
fn tok(kind: TokKind, line: Int, col: Int, start: Int, end: Int) : Token {
  Token { kind: kind, line: line, col: col, start: start, length: end - start }
}

# Mnemonic for token kinds (for --tokens dump). Keep in sync with TokKind.
fn tk_name(k: TokKind) : String {
  match k {
    TkEof -> "EOF"
    TkNewline -> "NEWLINE"
    TkAnd -> "and" TkAs -> "as" TkAssert -> "assert" TkElse -> "else"
    TkFalse -> "false" TkFn -> "fn" TkIf -> "if" TkImport -> "import"
    TkLet -> "let" TkMatch -> "match" TkNot -> "not" TkOr -> "or"
    TkPub -> "pub" TkTest -> "test" TkTrue -> "true" TkType -> "type"
    TkInt -> "INT" TkReal -> "REAL" TkChar -> "CHAR" TkString -> "STRING"
    TkIdent -> "IDENT" TkUnderscore -> "_"
    TkLparen -> "(" TkRparen -> ")" TkLbracket -> "[" TkRbracket -> "]"
    TkLbrace -> "{" TkRbrace -> "}"
    TkComma -> "," TkColon -> ":" TkSemi -> ";"
    TkDot -> "." TkDotDot -> ".." TkEllipsis -> "..."
    TkEq -> "=" TkArrow -> "->" TkFatArrow -> "=>"
    TkPipe -> "|" TkPipeApply -> "|>"
    TkPlus -> "+" TkMinus -> "-" TkStar -> "*" TkSlash -> "/"
    TkPercent -> "%"
    TkEqEq -> "==" TkNeq -> "!=" TkLt -> "<" TkGt -> ">"
    TkLe -> "<=" TkGe -> ">=" TkBang -> "!"
    TkError(_) -> "ERROR"
  }
}

# ====================================================================
# lexer state + helpers
# ====================================================================

type Lexer = { src: String, pos: Int, line: Int, col: Int }

fn lex_new(src: String) : Lexer = Lexer { src: src, pos: 0, line: 1, col: 1 }

fn lex_at_end(l: Lexer) : Bool = l.pos >= string_length(l.src)

fn lex_peek_at(l: Lexer, off: Int) : Option[Char] =
  char_at(l.src, l.pos + off)

fn lex_peek(l: Lexer) : Option[Char] = lex_peek_at(l, 0)

fn lex_advance(l: Lexer) : Lexer {
  match char_at(l.src, l.pos) {
    None -> l
    Some(c) -> {
      if c == '\n' {
        Lexer { src: l.src, pos: l.pos + 1, line: l.line + 1, col: 1 }
      } else {
        Lexer { src: l.src, pos: l.pos + 1, line: l.line, col: l.col + 1 }
      }
    }
  }
}

# Pair of lexer state + emitted token. Used everywhere the scanner
# returns both a new position and a produced token.
type LexStep = Step(Lexer, Token)

# Returns true if the next char matches `want` (and does not consume it).
fn lex_peek_is(l: Lexer, want: Char) : Bool {
  match lex_peek(l) {
    None -> false
    Some(c) -> c == want
  }
}

fn lex_peek2_is(l: Lexer, want: Char) : Bool {
  match lex_peek_at(l, 1) {
    None -> false
    Some(c) -> c == want
  }
}

fn lex_peek3_is(l: Lexer, want: Char) : Bool {
  match lex_peek_at(l, 2) {
    None -> false
    Some(c) -> c == want
  }
}

# ====================================================================
# whitespace and comments
# ====================================================================

fn lex_skip_comment(l: Lexer) : Lexer {
  # `#` already consumed. Stop at newline or EOF; the newline itself is a
  # token and stays for the main loop to emit.
  match lex_peek(l) {
    None -> l
    Some(c) -> if c == '\n' { l } else { lex_skip_comment(lex_advance(l)) }
  }
}

fn lex_skip_ws(l: Lexer) : Lexer {
  match lex_peek(l) {
    None -> l
    Some(c) -> {
      if ch_is_space(c) { lex_skip_ws(lex_advance(l)) }
      else if c == '#' { lex_skip_ws(lex_skip_comment(lex_advance(l))) }
      else { l }
    }
  }
}

# ====================================================================
# identifiers and keywords
# ====================================================================

fn lex_scan_ident_rest(l: Lexer) : Lexer {
  match lex_peek(l) {
    None -> l
    Some(c) -> if ch_is_alnum(c) { lex_scan_ident_rest(lex_advance(l)) } else { l }
  }
}

fn keyword_kind(text: String) : TokKind {
  if text == "and" { TkAnd }
  else if text == "as" { TkAs }
  else if text == "assert" { TkAssert }
  else if text == "else" { TkElse }
  else if text == "false" { TkFalse }
  else if text == "fn" { TkFn }
  else if text == "if" { TkIf }
  else if text == "import" { TkImport }
  else if text == "let" { TkLet }
  else if text == "match" { TkMatch }
  else if text == "not" { TkNot }
  else if text == "or" { TkOr }
  else if text == "pub" { TkPub }
  else if text == "test" { TkTest }
  else if text == "true" { TkTrue }
  else if text == "type" { TkType }
  else { TkIdent }
}

fn lex_ident(l: Lexer) : LexStep {
  let start = l.pos
  let sl = l.line
  let sc = l.col
  let l2 = lex_scan_ident_rest(l)
  let text = string_slice(l.src, start, l2.pos - start)
  let kind =
    if string_length(text) == 1 and text == "_" {
      TkUnderscore
    } else {
      keyword_kind(text)
    }
  Step(l2, tok(kind, sl, sc, start, l2.pos))
}

# ====================================================================
# numbers
# ====================================================================

fn lex_scan_digits(l: Lexer) : Lexer {
  match lex_peek(l) {
    None -> l
    Some(c) -> {
      if ch_is_digit(c) or c == '_' { lex_scan_digits(lex_advance(l)) }
      else { l }
    }
  }
}

fn lex_number(l: Lexer) : LexStep {
  let start = l.pos
  let sl = l.line
  let sc = l.col
  let l1 = lex_scan_digits(l)
  # Fractional part: only when `.` is followed by a digit. `x..y` (range)
  # and `x.field` (access) must be left alone.
  let after_frac_kind =
    if lex_peek_is(l1, '.') {
      match lex_peek_at(l1, 1) {
        Some(d) -> if ch_is_digit(d) { Some(true) } else { Some(false) }
        None -> Some(false)
      }
    } else {
      Some(false)
    }
  let l2 =
    match after_frac_kind {
      Some(true) -> lex_scan_digits(lex_advance(lex_advance(l1)))
      _ -> l1
    }
  let is_real1 = match after_frac_kind { Some(true) -> true _ -> false }
  # Exponent part: `e` or `E`, optional sign, digits.
  let has_exp =
    match lex_peek(l2) {
      Some(c) -> c == 'e' or c == 'E'
      None -> false
    }
  if has_exp {
    let l3 = lex_advance(l2)
    let l4 =
      match lex_peek(l3) {
        Some(c) -> if c == '+' or c == '-' { lex_advance(l3) } else { l3 }
        None -> l3
      }
    match lex_peek(l4) {
      Some(d) -> {
        if ch_is_digit(d) {
          let l5 = lex_scan_digits(l4)
          Step(l5, tok(TkReal, sl, sc, start, l5.pos))
        } else {
          Step(l4, tok(TkError("malformed number: expected digits after exponent"),
                       sl, sc, start, l4.pos))
        }
      }
      None -> {
        Step(l4, tok(TkError("malformed number: expected digits after exponent"),
                     sl, sc, start, l4.pos))
      }
    }
  } else {
    let kind = if is_real1 { TkReal } else { TkInt }
    Step(l2, tok(kind, sl, sc, start, l2.pos))
  }
}

# ====================================================================
# strings
# ====================================================================

# Walk a string literal consuming chars until the closing `"` (or `"""`).
# Handles backslash escapes and `#{...}` interpolation (nested braces).
# Return the lexer positioned past the closing quote, plus the kind of
# token to emit (TkString or TkError(msg)).

type StrResult = StrOk(Lexer) | StrErr(Lexer, String)

# Skip past a nested {...} block inside interpolation, counting braces.
fn lex_skip_interp(l: Lexer, depth: Int) : StrResult {
  if depth == 0 { StrOk(l) }
  else {
    match lex_peek(l) {
      None -> StrErr(l, "unterminated interpolation in string")
      Some(c) -> {
        if c == '{' { lex_skip_interp(lex_advance(l), depth + 1) }
        else if c == '}' { lex_skip_interp(lex_advance(l), depth - 1) }
        else if c == '"' {
          # Skip a nested string literal inside the interpolation.
          match lex_skip_inner_string(lex_advance(l)) {
            StrOk(l2) -> lex_skip_interp(l2, depth)
            StrErr(l2, msg) -> StrErr(l2, msg)
          }
        } else {
          lex_skip_interp(lex_advance(l), depth)
        }
      }
    }
  }
}

fn lex_skip_inner_string(l: Lexer) : StrResult {
  match lex_peek(l) {
    None -> StrErr(l, "unterminated string inside interpolation")
    Some(c) -> {
      if c == '"' { StrOk(lex_advance(l)) }
      else if c == '\\' {
        let l1 = lex_advance(l)
        match lex_peek(l1) {
          None -> StrErr(l1, "unterminated string inside interpolation")
          Some(_) -> lex_skip_inner_string(lex_advance(l1))
        }
      } else {
        lex_skip_inner_string(lex_advance(l))
      }
    }
  }
}

fn lex_string_body(l: Lexer, triple: Bool) : StrResult {
  match lex_peek(l) {
    None -> StrErr(l, "unterminated string")
    Some(c) -> {
      if c == '\\' {
        let l1 = lex_advance(l)
        match lex_peek(l1) {
          None -> StrErr(l1, "unterminated string")
          Some(_) -> lex_string_body(lex_advance(l1), triple)
        }
      } else if c == '#' and lex_peek2_is(l, '{') {
        let l1 = lex_advance(lex_advance(l))
        match lex_skip_interp(l1, 1) {
          StrOk(l2) -> lex_string_body(l2, triple)
          StrErr(l2, msg) -> StrErr(l2, msg)
        }
      } else if triple {
        if c == '"' and lex_peek2_is(l, '"') and lex_peek3_is(l, '"') {
          StrOk(lex_advance(lex_advance(lex_advance(l))))
        } else {
          lex_string_body(lex_advance(l), triple)
        }
      } else {
        if c == '\n' {
          StrErr(l, "unterminated string (newline in single-line string)")
        } else if c == '"' {
          StrOk(lex_advance(l))
        } else {
          lex_string_body(lex_advance(l), triple)
        }
      }
    }
  }
}

fn lex_string(l: Lexer) : LexStep {
  let start = l.pos
  let sl = l.line
  let sc = l.col
  let l1 = lex_advance(l)                  # consume opening "
  let triple = lex_peek_is(l1, '"') and lex_peek2_is(l1, '"')
  let l2 = if triple { lex_advance(lex_advance(l1)) } else { l1 }
  match lex_string_body(l2, triple) {
    StrOk(l3) -> Step(l3, tok(TkString, sl, sc, start, l3.pos))
    StrErr(l3, msg) -> Step(l3, tok(TkError(msg), sl, sc, start, l3.pos))
  }
}

# ====================================================================
# char literals
# ====================================================================

fn lex_char_skip_u_escape(l: Lexer) : Lexer {
  # We're past `\u`; consume `{HHHH}`.
  match lex_peek(l) {
    None -> l
    Some(c) -> {
      if c == '}' { lex_advance(l) }
      else { lex_char_skip_u_escape(lex_advance(l)) }
    }
  }
}

# Issue #744: skip UTF-8 continuation bytes (value in [128, 191]) after
# a multi-byte lead byte, so 'á' scans as one codepoint.
fn lex_skip_utf8_continuation(l: Lexer) : Lexer {
  match lex_peek(l) {
    None -> l
    Some(c) -> {
      let b = char_to_int(c)
      if b >= 128 and b < 192 { lex_skip_utf8_continuation(lex_advance(l)) }
      else { l }
    }
  }
}

fn lex_char(l: Lexer) : LexStep {
  let start = l.pos
  let sl = l.line
  let sc = l.col
  let l1 = lex_advance(l)                 # consume opening '
  match lex_peek(l1) {
    None -> Step(l1, tok(TkError("unterminated char literal"),
                         sl, sc, start, l1.pos))
    Some(c) -> {
      let l2 =
        if c == '\\' {
          let la = lex_advance(l1)
          match lex_peek(la) {
            None -> la
            Some(e) -> {
              if e == 'u' and lex_peek2_is(la, '{') {
                lex_char_skip_u_escape(lex_advance(lex_advance(la)))
              } else {
                lex_advance(la)
              }
            }
          }
        } else {
          # Lead byte of a (possibly multi-byte) UTF-8 codepoint; consume
          # it plus any continuation bytes (issue #744).
          lex_skip_utf8_continuation(lex_advance(l1))
        }
      if lex_peek_is(l2, '\'') {
        Step(lex_advance(l2), tok(TkChar, sl, sc, start, l2.pos + 1))
      } else {
        Step(l2, tok(TkError("unterminated char literal"),
                     sl, sc, start, l2.pos))
      }
    }
  }
}

# ====================================================================
# punctuation and operators
# ====================================================================

fn lex_punct(l: Lexer) : LexStep {
  let start = l.pos
  let sl = l.line
  let sc = l.col
  match lex_peek(l) {
    None -> Step(l, tok(TkEof, sl, sc, start, start))
    Some(c) -> {
      let l1 = lex_advance(l)
      if c == '(' { Step(l1, tok(TkLparen, sl, sc, start, l1.pos)) }
      else if c == ')' { Step(l1, tok(TkRparen, sl, sc, start, l1.pos)) }
      else if c == '[' { Step(l1, tok(TkLbracket, sl, sc, start, l1.pos)) }
      else if c == ']' { Step(l1, tok(TkRbracket, sl, sc, start, l1.pos)) }
      else if c == '{' { Step(l1, tok(TkLbrace, sl, sc, start, l1.pos)) }
      else if c == '}' { Step(l1, tok(TkRbrace, sl, sc, start, l1.pos)) }
      else if c == ',' { Step(l1, tok(TkComma, sl, sc, start, l1.pos)) }
      else if c == ':' { Step(l1, tok(TkColon, sl, sc, start, l1.pos)) }
      else if c == ';' { Step(l1, tok(TkSemi, sl, sc, start, l1.pos)) }
      else if c == '+' { Step(l1, tok(TkPlus, sl, sc, start, l1.pos)) }
      else if c == '*' { Step(l1, tok(TkStar, sl, sc, start, l1.pos)) }
      else if c == '%' { Step(l1, tok(TkPercent, sl, sc, start, l1.pos)) }
      else if c == '-' {
        if lex_peek_is(l1, '>') {
          let l2 = lex_advance(l1)
          Step(l2, tok(TkArrow, sl, sc, start, l2.pos))
        } else {
          Step(l1, tok(TkMinus, sl, sc, start, l1.pos))
        }
      }
      else if c == '/' {
        if lex_peek_is(l1, '/') {
          # Issue #315 — `//` integer division operator is removed.
          let l2 = lex_advance(l1)
          Step(l2, tok(TkError("`//` operator is removed (issue #315) — use `/` instead (Int / Int truncates)"),
                       sl, sc, start, l2.pos))
        } else {
          Step(l1, tok(TkSlash, sl, sc, start, l1.pos))
        }
      }
      else if c == '=' {
        if lex_peek_is(l1, '=') {
          let l2 = lex_advance(l1)
          Step(l2, tok(TkEqEq, sl, sc, start, l2.pos))
        } else if lex_peek_is(l1, '>') {
          let l2 = lex_advance(l1)
          Step(l2, tok(TkFatArrow, sl, sc, start, l2.pos))
        } else {
          Step(l1, tok(TkEq, sl, sc, start, l1.pos))
        }
      }
      else if c == '<' {
        if lex_peek_is(l1, '=') {
          let l2 = lex_advance(l1)
          Step(l2, tok(TkLe, sl, sc, start, l2.pos))
        } else {
          Step(l1, tok(TkLt, sl, sc, start, l1.pos))
        }
      }
      else if c == '>' {
        if lex_peek_is(l1, '=') {
          let l2 = lex_advance(l1)
          Step(l2, tok(TkGe, sl, sc, start, l2.pos))
        } else {
          Step(l1, tok(TkGt, sl, sc, start, l1.pos))
        }
      }
      else if c == '!' {
        if lex_peek_is(l1, '=') {
          let l2 = lex_advance(l1)
          Step(l2, tok(TkNeq, sl, sc, start, l2.pos))
        } else {
          Step(l1, tok(TkBang, sl, sc, start, l1.pos))
        }
      }
      else if c == '|' {
        if lex_peek_is(l1, '>') {
          let l2 = lex_advance(l1)
          Step(l2, tok(TkPipeApply, sl, sc, start, l2.pos))
        } else {
          Step(l1, tok(TkPipe, sl, sc, start, l1.pos))
        }
      }
      else if c == '.' {
        if lex_peek_is(l1, '.') and lex_peek2_is(l1, '.') {
          let l2 = lex_advance(lex_advance(l1))
          Step(l2, tok(TkEllipsis, sl, sc, start, l2.pos))
        } else if lex_peek_is(l1, '.') {
          let l2 = lex_advance(l1)
          Step(l2, tok(TkDotDot, sl, sc, start, l2.pos))
        } else {
          Step(l1, tok(TkDot, sl, sc, start, l1.pos))
        }
      }
      else {
        let msg = string_concat("unexpected character '", string_concat("#{c}", "'"))
        Step(l1, tok(TkError(msg), sl, sc, start, l1.pos))
      }
    }
  }
}

# ====================================================================
# dispatch: one token
# ====================================================================

fn lex_next(l: Lexer) : LexStep {
  let l0 = lex_skip_ws(l)
  let sl = l0.line
  let sc = l0.col
  match lex_peek(l0) {
    None -> Step(l0, tok(TkEof, sl, sc, l0.pos, l0.pos))
    Some(c) -> {
      if c == '\n' {
        let l1 = lex_advance(l0)
        Step(l1, tok(TkNewline, sl, sc, l0.pos, l1.pos))
      }
      else if ch_is_alpha(c) { lex_ident(l0) }
      else if ch_is_digit(c) { lex_number(l0) }
      else if c == '"' { lex_string(l0) }
      else if c == '\'' { lex_char(l0) }
      else { lex_punct(l0) }
    }
  }
}

# Build the full token list. Accumulate in reverse for O(1) prepend, then
# list_reverse once at the end.
fn lex_loop(l: Lexer, acc: [Token]) : [Token] {
  match lex_next(l) {
    Step(l1, t) -> {
      let acc1 = [t, ...acc]
      match t.kind {
        TkEof -> list_reverse(acc1)
        _ -> lex_loop(l1, acc1)
      }
    }
  }
}

fn tokenize(src: String) : [Token] {
  lex_loop(lex_new(src), [])
}

# ====================================================================
# token dump (for --tokens)
# ====================================================================

fn tok_text(src: String, t: Token) : String = string_slice(src, t.start, t.length)

fn tok_line_str(t: Token) : String = int_to_string(t.line)
fn tok_col_str(t: Token)  : String = int_to_string(t.col)

fn dump_token(src: String, t: Token) : Unit {
  match t.kind {
    TkNewline -> print("#{tok_line_str(t)}:#{tok_col_str(t)}  NEWLINE")
    TkError(msg) -> eprint("#{tok_line_str(t)}:#{tok_col_str(t)}  ERROR  #{msg}")
    _ -> {
      let text = tok_text(src, t)
      print("#{tok_line_str(t)}:#{tok_col_str(t)}  #{tk_name(t.kind)}  \"#{text}\"")
    }
  }
}

fn dump_tokens(src: String, tokens: [Token]) : Unit {
  tokens |> each((t) => dump_token(src, t))
}

# ====================================================================
# error scanning
# ====================================================================

fn report_one_error(path: String, t: Token, msg: String) : Unit {
  eprint("#{path}:#{tok_line_str(t)}:#{tok_col_str(t)}: error: #{msg}")
}

fn report_errors_loop(path: String, ts: [Token], count: Int) : Int {
  match ts {
    [] -> count
    [t, ...rest] -> match t.kind {
      TkError(msg) -> {
        report_one_error(path, t, msg)
        report_errors_loop(path, rest, count + 1)
      }
      _ -> report_errors_loop(path, rest, count)
    }
  }
}

# Returns 0 on success, 1 if any TkError tokens appeared (all reported to stderr).
fn report_errors(path: String, src: String, tokens: [Token]) : Int {
  if report_errors_loop(path, tokens, 0) > 0 { 1 } else { 0 }
}

# ====================================================================
# AST types
# ====================================================================

# Expressions carry their source position on the wrapper, so variants
# stay compact. Pattern matching on expressions therefore destructures
# the record to reach `.kind`, then matches the sum.

type Expr = { kind: ExprKind, line: Int, col: Int }

type ExprKind
  = EInt(Int)
  | EReal(Real)
  | EBool(Bool)
  | EChar(Char)
  | EStr(String, Bool)                      # raw source span (includes quotes), is_triple
  | EUnit
  | EVar(String)
  | EUnder                                  # `_` (pattern context only, but lexer produces it anywhere)
  | EPlaceholder                            # `.` placeholder (stage 1 extension; stage 0 rejects)
  | ECall(Expr, [Expr])
  | EField(Expr, String)
  | EIndex(Expr, Expr)
  | EBinop(String, Expr, Expr)
  | EUnop(String, Expr)                     # "-" or "not"
  | EIf(Expr, Expr, Option[Expr])
  | EMatch(Expr, [Arm])
  | ELambda([Param], Expr)
  | ERecordLit(String, [FieldInit])
  | EList([ListElem])
  | ERange(Expr, Expr, Option[Expr])
  | EBlock([Stmt], Option[Expr])
  | EPipe(Expr, Expr)

type ListElem = ElPlain(Expr) | ElSpread(Expr)

type Arm = Arm(Pattern, Option[Expr], Expr)

type FieldInit = FI(String, Expr)

type Param = { pname: String, ptype: Option[TypeExpr], pline: Int, pcol: Int }

type Stmt
  = SLet(Pattern, Option[TypeExpr], Expr)
  | SAssert(Expr, Option[Expr])
  | SExprStmt(Expr)

type Pattern = { pkind: PatKind, line: Int, col: Int }

type PatKind
  = PWild
  | PLit(Expr)                              # literal pattern (stores an Expr of literal shape)
  | PBind(String)
  | PList([Pattern], Option[String])         # fixed sub-patterns, optional rest binder name
  | PVariant(String, [Pattern])
  | PVariantRecord(String, [PField])
  | PRecord([PField])

type PField = PField(String, Pattern, Bool) # field name, sub-pattern, is_shorthand

type TypeExpr = { tkind: TyKind, line: Int, col: Int }

type TyKind
  = TyName(String, [TypeExpr])              # Name or Name[T1, T2, ...]
  | TyList(TypeExpr)
  | TyFn([TypeExpr], TypeExpr)

type Decl
  = DFn(Bool, String, [Param], Option[TypeExpr], Expr, Int, Int)
  | DType(Bool, String, [String], TypeBody, Int, Int)
  | DTest(String, Expr, Int, Int)
  | DImport(ImportKind, Int, Int)

type TypeBody = TBAlias(TypeExpr) | TBRecord([FieldDecl]) | TBSum([Variant])
type FieldDecl = FD(String, TypeExpr)
type Variant = Var(String, [TypeExpr])

type ImportKind
  = IkPath(String)
  | IkAlias(String, String)
  | IkSelective(String, [String])

# ---- small constructors ----
fn mk_expr(k: ExprKind, line: Int, col: Int) : Expr = Expr { kind: k, line: line, col: col }
fn mk_pat(k: PatKind, line: Int, col: Int) : Pattern = Pattern { pkind: k, line: line, col: col }
fn mk_ty(k: TyKind, line: Int, col: Int) : TypeExpr = TypeExpr { tkind: k, line: line, col: col }

# ====================================================================
# parser state
# ====================================================================
#
# The Parser is immutable; each helper returns a new one with `rest`
# advanced and `had_error` possibly flipped. We don't carry a token
# index — `rest` is the unconsumed suffix of the token list, so
# p_advance is O(1) (takes tail). Peek-ahead uses list destructuring
# up to depth 3, which covers every lookahead stage 0 does.

type Parser = { file: String, src: String, rest: [Token], had_error: Bool }

# A result = a new parser plus an optional payload. `None` means the
# parser failed (had_error is set on `p`). This mirrors stage 0's
# error-then-stop style.

type PExpr   = { p: Parser, r: Option[Expr] }
type PStmt   = { p: Parser, r: Option[Stmt] }
type PPat    = { p: Parser, r: Option[Pattern] }
type PTy     = { p: Parser, r: Option[TypeExpr] }
type PDecl   = { p: Parser, r: Option[Decl] }
type PArm    = { p: Parser, r: Option[Arm] }
type PParam  = { p: Parser, r: Option[Param] }
type PFI     = { p: Parser, r: Option[FieldInit] }
type PVar    = { p: Parser, r: Option[Variant] }
type PFD     = { p: Parser, r: Option[FieldDecl] }
type PPF     = { p: Parser, r: Option[PField] }
type PEL     = { p: Parser, r: Option[ListElem] }

fn parser_new(file: String, src: String, toks: [Token]) : Parser =
  Parser { file: file, src: src, rest: toks, had_error: false }

fn p_mark_err(p: Parser) : Parser =
  Parser { file: p.file, src: p.src, rest: p.rest, had_error: true }

fn p_advance(p: Parser) : Parser {
  match p.rest {
    [_, ...rest1] -> Parser { file: p.file, src: p.src, rest: rest1, had_error: p.had_error }
    [] -> p
  }
}

# A sentinel EOF token used when peeking past the list end. In practice
# the tokenizer always appends a TkEof, so we rarely hit this.
fn eof_tok() : Token = Token { kind: TkEof, line: 0, col: 0, start: 0, length: 0 }

fn p_peek(p: Parser) : Token {
  match p.rest {
    [t, ...rs] -> t
    [] -> eof_tok()
  }
}

fn p_peek1(p: Parser) : Token {
  match p.rest {
    [_, t, ...rs] -> t
    _ -> eof_tok()
  }
}

fn p_peek2(p: Parser) : Token {
  match p.rest {
    [_, _, t, ...rs] -> t
    _ -> eof_tok()
  }
}

# Token-kind comparison by structural case (TkError is the only payload-
# carrying variant, and we never compare it for equality in the parser).
fn tk_is(a: TokKind, b: TokKind) : Bool {
  match a {
    TkEof        -> match b { TkEof -> true _ -> false }
    TkNewline    -> match b { TkNewline -> true _ -> false }
    TkAnd        -> match b { TkAnd -> true _ -> false }
    TkAs         -> match b { TkAs -> true _ -> false }
    TkAssert     -> match b { TkAssert -> true _ -> false }
    TkElse       -> match b { TkElse -> true _ -> false }
    TkFalse      -> match b { TkFalse -> true _ -> false }
    TkFn         -> match b { TkFn -> true _ -> false }
    TkIf         -> match b { TkIf -> true _ -> false }
    TkImport     -> match b { TkImport -> true _ -> false }
    TkLet        -> match b { TkLet -> true _ -> false }
    TkMatch      -> match b { TkMatch -> true _ -> false }
    TkNot        -> match b { TkNot -> true _ -> false }
    TkOr         -> match b { TkOr -> true _ -> false }
    TkPub        -> match b { TkPub -> true _ -> false }
    TkTest       -> match b { TkTest -> true _ -> false }
    TkTrue       -> match b { TkTrue -> true _ -> false }
    TkType       -> match b { TkType -> true _ -> false }
    TkInt        -> match b { TkInt -> true _ -> false }
    TkReal       -> match b { TkReal -> true _ -> false }
    TkChar       -> match b { TkChar -> true _ -> false }
    TkString     -> match b { TkString -> true _ -> false }
    TkIdent      -> match b { TkIdent -> true _ -> false }
    TkUnderscore -> match b { TkUnderscore -> true _ -> false }
    TkLparen     -> match b { TkLparen -> true _ -> false }
    TkRparen     -> match b { TkRparen -> true _ -> false }
    TkLbracket   -> match b { TkLbracket -> true _ -> false }
    TkRbracket   -> match b { TkRbracket -> true _ -> false }
    TkLbrace     -> match b { TkLbrace -> true _ -> false }
    TkRbrace     -> match b { TkRbrace -> true _ -> false }
    TkComma      -> match b { TkComma -> true _ -> false }
    TkColon      -> match b { TkColon -> true _ -> false }
    TkSemi       -> match b { TkSemi -> true _ -> false }
    TkDot        -> match b { TkDot -> true _ -> false }
    TkDotDot     -> match b { TkDotDot -> true _ -> false }
    TkEllipsis   -> match b { TkEllipsis -> true _ -> false }
    TkEq         -> match b { TkEq -> true _ -> false }
    TkArrow      -> match b { TkArrow -> true _ -> false }
    TkFatArrow   -> match b { TkFatArrow -> true _ -> false }
    TkPipe       -> match b { TkPipe -> true _ -> false }
    TkPipeApply  -> match b { TkPipeApply -> true _ -> false }
    TkPlus       -> match b { TkPlus -> true _ -> false }
    TkMinus      -> match b { TkMinus -> true _ -> false }
    TkStar       -> match b { TkStar -> true _ -> false }
    TkSlash      -> match b { TkSlash -> true _ -> false }
    TkPercent    -> match b { TkPercent -> true _ -> false }
    TkEqEq       -> match b { TkEqEq -> true _ -> false }
    TkNeq        -> match b { TkNeq -> true _ -> false }
    TkLt         -> match b { TkLt -> true _ -> false }
    TkGt         -> match b { TkGt -> true _ -> false }
    TkLe         -> match b { TkLe -> true _ -> false }
    TkGe         -> match b { TkGe -> true _ -> false }
    TkBang       -> match b { TkBang -> true _ -> false }
    TkError(_)   -> false
  }
}

fn p_at(p: Parser, k: TokKind) : Bool = tk_is(p_peek(p).kind, k)

fn p_try_consume(p: Parser, k: TokKind) : Option[Parser] {
  if p_at(p, k) { Some(p_advance(p)) } else { None }
}

fn p_skip_newlines(p: Parser) : Parser {
  if p_at(p, TkNewline) { p_skip_newlines(p_advance(p)) } else { p }
}

fn p_skip_newlines_and_semis(p: Parser) : Parser {
  if p_at(p, TkNewline) or p_at(p, TkSemi) { p_skip_newlines_and_semis(p_advance(p)) }
  else { p }
}

fn p_error(p: Parser, t: Token, msg: String) : Parser {
  if p.had_error { p }
  else {
    eprint("#{p.file}:#{int_to_string(t.line)}:#{int_to_string(t.col)}: error: #{msg}")
    p_mark_err(p)
  }
}

fn p_error_here(p: Parser, msg: String) : Parser = p_error(p, p_peek(p), msg)

fn p_expect(p: Parser, k: TokKind, msg: String) : PExpr {
  # PExpr is a misnomer — we just reuse the record structure. We return
  # an Expr-less PExpr; callers that need the consumed token use
  # p_expect_tok instead. This variant is a convenience for "advance
  # past a required delimiter".
  if p_at(p, k) { PExpr { p: p_advance(p), r: Some(mk_expr(EUnit, 0, 0)) } }
  else { PExpr { p: p_error_here(p, msg), r: None } }
}

# Same, but returns the consumed token in the Option payload slot (as an
# EStr carrying the raw span — caller decodes).
fn p_expect_tok(p: Parser, k: TokKind, msg: String) : Token {
  if p_at(p, k) { p_peek(p) }
  else { eof_tok() }
}

fn is_upper_ident(src: String, t: Token) : Bool {
  match char_at(src, t.start) {
    Some(c) -> c >= 'A' and c <= 'Z'
    None -> false
  }
}

fn tok_source(src: String, t: Token) : String = string_slice(src, t.start, t.length)

# ====================================================================
# literal decoders
# ====================================================================

fn decode_int_loop(s: String, i: Int, n: Int, acc: Int, neg: Bool) : Int {
  if i >= n { if neg { 0 - acc } else { acc } }
  else {
    match char_at(s, i) {
      None -> if neg { 0 - acc } else { acc }
      Some(c) -> {
        if c == '_' { decode_int_loop(s, i + 1, n, acc, neg) }
        else if ch_is_digit(c) {
          let d = char_to_int(c) - char_to_int('0')
          decode_int_loop(s, i + 1, n, acc * 10 + d, neg)
        } else {
          if neg { 0 - acc } else { acc }
        }
      }
    }
  }
}

fn decode_int(span: String) : Int {
  let n = string_length(span)
  if n == 0 { 0 }
  else {
    match char_at(span, 0) {
      Some(c) -> if c == '-' { decode_int_loop(span, 1, n, 0, true) }
                 else { decode_int_loop(span, 0, n, 0, false) }
      None -> 0
    }
  }
}

fn strip_underscores_loop(s: String, i: Int, n: Int, acc: String) : String {
  if i >= n { acc }
  else {
    match char_at(s, i) {
      None -> acc
      Some(c) -> {
        if c == '_' { strip_underscores_loop(s, i + 1, n, acc) }
        else { strip_underscores_loop(s, i + 1, n, string_concat(acc, "#{c}")) }
      }
    }
  }
}

fn decode_real(span: String) : Real {
  let clean = strip_underscores_loop(span, 0, string_length(span), "")
  match string_to_real(clean) {
    Some(r) -> r
    None -> 0.0
  }
}

fn decode_char_escape(c: Char) : Char {
  if c == 'n' { '\n' }
  else if c == 't' { '\t' }
  else if c == 'r' { '\r' }
  else if c == '\\' { '\\' }
  else if c == '\'' { '\'' }
  else if c == '"' { '"' }
  else if c == '0' { int_to_char(0) }
  else { c }
}

fn decode_hex_loop(s: String, i: Int, n: Int, acc: Int) : Int {
  if i >= n { acc }
  else {
    match char_at(s, i) {
      None -> acc
      Some(c) -> {
        if c == '}' { acc }
        else {
          let v =
            if ch_is_digit(c) { char_to_int(c) - char_to_int('0') }
            else if c >= 'a' and c <= 'f' { char_to_int(c) - char_to_int('a') + 10 }
            else if c >= 'A' and c <= 'F' { char_to_int(c) - char_to_int('A') + 10 }
            else { 0 }
          decode_hex_loop(s, i + 1, n, acc * 16 + v)
        }
      }
    }
  }
}

# span is the raw char literal including surrounding quotes: 'a', '\n', '\u{2603}'
fn decode_char(span: String) : Char {
  let n = string_length(span)
  if n < 2 { int_to_char(0) }
  else {
    match char_at(span, 1) {
      None -> int_to_char(0)
      Some(c1) -> {
        if c1 == '\\' {
          match char_at(span, 2) {
            None -> int_to_char(0)
            Some(c2) -> {
              if c2 == 'u' {
                int_to_char(decode_hex_loop(span, 4, n - 1, 0))
              } else {
                decode_char_escape(c2)
              }
            }
          }
        } else {
          # Issue #744: decode the full UTF-8 codepoint starting at byte
          # 1, not just the lead byte (`c1`), so 'á'/'▸' lex to their
          # scalar value. ASCII decodes to itself.
          int_to_char(string_cp_at(span, 1))
        }
      }
    }
  }
}

# ====================================================================
# precedence climbing: forward declarations
# ====================================================================
#
# These are implemented below. Listed here as a reading aid.
#  parse_expr   -> parse_pipe
#  parse_pipe   -> parse_or ("|>" parse_or)*
#  parse_or     -> parse_and ("or" parse_and)*
#  parse_and    -> parse_cmp ("and" parse_cmp)*
#  parse_cmp    -> parse_add (cmpop parse_add)?        (no chains)
#  parse_add    -> parse_mul ([+-] parse_mul)*
#  parse_mul    -> parse_unary ([*/%//] parse_unary)*
#  parse_unary  -> ("-" | "not")? parse_postfix
#  parse_postfix-> parse_primary (call | field | index)*
#  parse_primary-> literal | ident | "(" expr ")" | if | match | block | record | list | lambda

fn op_of_tok(k: TokKind) : String {
  match k {
    TkPlus -> "+" TkMinus -> "-" TkStar -> "*" TkSlash -> "/"
    TkPercent -> "%"
    TkEqEq -> "==" TkNeq -> "!=" TkLt -> "<" TkGt -> ">" TkLe -> "<=" TkGe -> ">="
    TkAnd -> "and" TkOr -> "or"
    _ -> "?"
  }
}

# ====================================================================
# expression parsing
# ====================================================================

fn ok_e(p: Parser, e: Expr) : PExpr = PExpr { p: p, r: Some(e) }
fn err_e(p: Parser) : PExpr = PExpr { p: p, r: None }
fn ok_s(p: Parser, s: Stmt) : PStmt = PStmt { p: p, r: Some(s) }
fn err_s(p: Parser) : PStmt = PStmt { p: p, r: None }
fn ok_p(p: Parser, x: Pattern) : PPat = PPat { p: p, r: Some(x) }
fn err_p(p: Parser) : PPat = PPat { p: p, r: None }
fn ok_t(p: Parser, x: TypeExpr) : PTy = PTy { p: p, r: Some(x) }
fn err_t(p: Parser) : PTy = PTy { p: p, r: None }
fn ok_d(p: Parser, x: Decl) : PDecl = PDecl { p: p, r: Some(x) }
fn err_d(p: Parser) : PDecl = PDecl { p: p, r: None }
fn ok_a(p: Parser, x: Arm) : PArm = PArm { p: p, r: Some(x) }
fn err_a(p: Parser) : PArm = PArm { p: p, r: None }
fn ok_pm(p: Parser, x: Param) : PParam = PParam { p: p, r: Some(x) }
fn err_pm(p: Parser) : PParam = PParam { p: p, r: None }
fn ok_fi(p: Parser, x: FieldInit) : PFI = PFI { p: p, r: Some(x) }
fn err_fi(p: Parser) : PFI = PFI { p: p, r: None }
fn ok_v(p: Parser, x: Variant) : PVar = PVar { p: p, r: Some(x) }
fn err_v(p: Parser) : PVar = PVar { p: p, r: None }
fn ok_fd(p: Parser, x: FieldDecl) : PFD = PFD { p: p, r: Some(x) }
fn err_fd(p: Parser) : PFD = PFD { p: p, r: None }
fn ok_pf(p: Parser, x: PField) : PPF = PPF { p: p, r: Some(x) }
fn err_pf(p: Parser) : PPF = PPF { p: p, r: None }
fn ok_el(p: Parser, x: ListElem) : PEL = PEL { p: p, r: Some(x) }
fn err_el(p: Parser) : PEL = PEL { p: p, r: None }

fn parse_expr(p: Parser) : PExpr = parse_pipe(p)

fn parse_pipe(p: Parser) : PExpr {
  let r = parse_or(p)
  match r.r {
    None -> r
    Some(lhs) -> parse_pipe_rest(r.p, lhs)
  }
}

fn parse_pipe_rest(p: Parser, lhs: Expr) : PExpr {
  if p_at(p, TkPipeApply) {
    let t = p_peek(p)
    let p1 = p_skip_newlines(p_advance(p))
    let r = parse_or(p1)
    match r.r {
      None -> err_e(r.p)
      Some(rhs) -> parse_pipe_rest(r.p, mk_expr(EPipe(lhs, rhs), t.line, t.col))
    }
  } else {
    ok_e(p, lhs)
  }
}

fn parse_or(p: Parser) : PExpr {
  let r = parse_and(p)
  match r.r {
    None -> r
    Some(lhs) -> parse_or_rest(r.p, lhs)
  }
}

fn parse_or_rest(p: Parser, lhs: Expr) : PExpr {
  if p_at(p, TkOr) {
    let t = p_peek(p)
    let r = parse_and(p_skip_newlines(p_advance(p)))
    match r.r {
      None -> err_e(r.p)
      Some(rhs) -> parse_or_rest(r.p, mk_expr(EBinop("or", lhs, rhs), t.line, t.col))
    }
  } else {
    ok_e(p, lhs)
  }
}

fn parse_and(p: Parser) : PExpr {
  let r = parse_cmp(p)
  match r.r {
    None -> r
    Some(lhs) -> parse_and_rest(r.p, lhs)
  }
}

fn parse_and_rest(p: Parser, lhs: Expr) : PExpr {
  if p_at(p, TkAnd) {
    let t = p_peek(p)
    let r = parse_cmp(p_skip_newlines(p_advance(p)))
    match r.r {
      None -> err_e(r.p)
      Some(rhs) -> parse_and_rest(r.p, mk_expr(EBinop("and", lhs, rhs), t.line, t.col))
    }
  } else {
    ok_e(p, lhs)
  }
}

fn is_cmp_tok(k: TokKind) : Bool {
  tk_is(k, TkEqEq) or tk_is(k, TkNeq) or tk_is(k, TkLt) or tk_is(k, TkGt) or tk_is(k, TkLe) or tk_is(k, TkGe)
}

fn parse_cmp(p: Parser) : PExpr {
  let r = parse_add(p)
  match r.r {
    None -> r
    Some(lhs) -> {
      let t = p_peek(r.p)
      if is_cmp_tok(t.kind) {
        let op = op_of_tok(t.kind)
        let r2 = parse_add(p_skip_newlines(p_advance(r.p)))
        match r2.r {
          None -> err_e(r2.p)
          Some(rhs) -> ok_e(r2.p, mk_expr(EBinop(op, lhs, rhs), t.line, t.col))
        }
      } else { ok_e(r.p, lhs) }
    }
  }
}

fn parse_add(p: Parser) : PExpr {
  let r = parse_mul(p)
  match r.r {
    None -> r
    Some(lhs) -> parse_add_rest(r.p, lhs)
  }
}

fn parse_add_rest(p: Parser, lhs: Expr) : PExpr {
  let t = p_peek(p)
  if tk_is(t.kind, TkPlus) or tk_is(t.kind, TkMinus) {
    let op = op_of_tok(t.kind)
    let r = parse_mul(p_skip_newlines(p_advance(p)))
    match r.r {
      None -> err_e(r.p)
      Some(rhs) -> parse_add_rest(r.p, mk_expr(EBinop(op, lhs, rhs), t.line, t.col))
    }
  } else { ok_e(p, lhs) }
}

fn parse_mul(p: Parser) : PExpr {
  let r = parse_unary(p)
  match r.r {
    None -> r
    Some(lhs) -> parse_mul_rest(r.p, lhs)
  }
}

fn parse_mul_rest(p: Parser, lhs: Expr) : PExpr {
  let t = p_peek(p)
  if tk_is(t.kind, TkStar) or tk_is(t.kind, TkSlash) or tk_is(t.kind, TkPercent) {
    let op = op_of_tok(t.kind)
    let r = parse_unary(p_skip_newlines(p_advance(p)))
    match r.r {
      None -> err_e(r.p)
      Some(rhs) -> parse_mul_rest(r.p, mk_expr(EBinop(op, lhs, rhs), t.line, t.col))
    }
  } else { ok_e(p, lhs) }
}

fn parse_unary(p: Parser) : PExpr {
  let t = p_peek(p)
  if tk_is(t.kind, TkMinus) {
    let r = parse_unary(p_advance(p))
    match r.r {
      None -> err_e(r.p)
      Some(e) -> ok_e(r.p, mk_expr(EUnop("-", e), t.line, t.col))
    }
  } else if tk_is(t.kind, TkNot) {
    let r = parse_unary(p_advance(p))
    match r.r {
      None -> err_e(r.p)
      Some(e) -> ok_e(r.p, mk_expr(EUnop("not", e), t.line, t.col))
    }
  } else {
    parse_postfix(p)
  }
}

fn parse_postfix(p: Parser) : PExpr {
  let r = parse_primary(p)
  match r.r {
    None -> r
    Some(e) -> parse_postfix_rest(r.p, e)
  }
}

fn parse_postfix_rest(p: Parser, lhs: Expr) : PExpr {
  let t = p_peek(p)
  if tk_is(t.kind, TkLparen) {
    let args_r = parse_call_args(p_advance(p))
    match args_r.r {
      None -> err_e(args_r.p)
      Some(xs) -> parse_postfix_rest(args_r.p, mk_expr(ECall(lhs, xs), t.line, t.col))
    }
  } else if tk_is(t.kind, TkDot) {
    let p1 = p_advance(p)
    let id = p_peek(p1)
    if tk_is(id.kind, TkIdent) {
      let name = tok_source(p.src, id)
      parse_postfix_rest(p_advance(p1), mk_expr(EField(lhs, name), t.line, t.col))
    } else {
      err_e(p_error_here(p1, "expected field name after `.`"))
    }
  } else if tk_is(t.kind, TkLbracket) {
    let p1 = p_advance(p)
    let r = parse_expr(p1)
    match r.r {
      None -> err_e(r.p)
      Some(idx) -> {
        let closed = p_expect(r.p, TkRbracket, "expected `]` after index")
        match closed.r {
          None -> err_e(closed.p)
          Some(_) -> parse_postfix_rest(closed.p, mk_expr(EIndex(lhs, idx), t.line, t.col))
        }
      }
    }
  } else {
    ok_e(p, lhs)
  }
}

# Parse the argument list of a call. Position is AT the token after the
# opening `(`. Returns with `(` already consumed by caller, `)` to be
# consumed here. Newlines between args are allowed.
type PArgs = { p: Parser, r: Option[[Expr]] }

fn ok_args(p: Parser, xs: [Expr]) : PArgs = PArgs { p: p, r: Some(xs) }
fn err_args(p: Parser) : PArgs = PArgs { p: p, r: None }

fn parse_call_args(p: Parser) : PArgs {
  let p0 = p_skip_newlines(p)
  if p_at(p0, TkRparen) { ok_args(p_advance(p0), []) }
  else { parse_call_args_loop(p0, []) }
}

fn parse_call_args_loop(p: Parser, acc: [Expr]) : PArgs {
  let r = parse_expr(p_skip_newlines(p))
  match r.r {
    None -> err_args(r.p)
    Some(e) -> {
      let p1 = p_skip_newlines(r.p)
      if p_at(p1, TkComma) { parse_call_args_loop(p_skip_newlines(p_advance(p1)), [e, ...acc]) }
      else if p_at(p1, TkRparen) {
        ok_args(p_advance(p1), list_reverse([e, ...acc]))
      }
      else { err_args(p_error_here(p1, "expected `,` or `)` in call arguments")) }
    }
  }
}

# ====================================================================
# primary expressions — placeholders for later implementations
# ====================================================================

fn parse_primary(p: Parser) : PExpr {
  let t = p_peek(p)
  match t.kind {
    TkInt -> {
      let span = tok_source(p.src, t)
      ok_e(p_advance(p), mk_expr(EInt(decode_int(span)), t.line, t.col))
    }
    TkReal -> {
      let span = tok_source(p.src, t)
      ok_e(p_advance(p), mk_expr(EReal(decode_real(span)), t.line, t.col))
    }
    TkTrue  -> ok_e(p_advance(p), mk_expr(EBool(true),  t.line, t.col))
    TkFalse -> ok_e(p_advance(p), mk_expr(EBool(false), t.line, t.col))
    TkChar  -> {
      let span = tok_source(p.src, t)
      ok_e(p_advance(p), mk_expr(EChar(decode_char(span)), t.line, t.col))
    }
    TkString -> {
      let span = tok_source(p.src, t)
      let is_triple =
        string_length(span) >= 6 and
        match char_at(span, 0) { Some(c) -> c == '"' _ -> false } and
        match char_at(span, 1) { Some(c) -> c == '"' _ -> false } and
        match char_at(span, 2) { Some(c) -> c == '"' _ -> false }
      ok_e(p_advance(p), mk_expr(EStr(span, is_triple), t.line, t.col))
    }
    TkUnderscore -> ok_e(p_advance(p), mk_expr(EUnder, t.line, t.col))
    TkDot -> ok_e(p_advance(p), mk_expr(EPlaceholder, t.line, t.col))
    TkIdent -> parse_ident_primary(p, t)
    TkLparen -> parse_paren_or_lambda(p, t)
    TkLbracket -> parse_list_or_range(p, t)
    TkLbrace -> parse_block(p, t)
    TkIf -> parse_if(p, t)
    TkMatch -> parse_match(p, t)
    _ -> err_e(p_error_here(p, "expected expression"))
  }
}

fn parse_ident_primary(p: Parser, t: Token) : PExpr {
  let name = tok_source(p.src, t)
  let p1 = p_advance(p)
  # Lambda: `name => body`
  if p_at(p1, TkFatArrow) {
    let p2 = p_advance(p1)
    let r = parse_expr(p2)
    match r.r {
      None -> err_e(r.p)
      Some(body) -> {
        let param = Param { pname: name, ptype: None, pline: t.line, pcol: t.col }
        ok_e(r.p, mk_expr(ELambda([param], body), t.line, t.col))
      }
    }
  }
  # Record literal: `Name { ... }` — but only when the name is Uppercase.
  else if is_upper_ident(p.src, t) and p_at(p1, TkLbrace) {
    parse_record_lit(p1, name, t)
  }
  # Plain variable reference.
  else {
    ok_e(p1, mk_expr(EVar(name), t.line, t.col))
  }
}

fn parse_record_lit(p: Parser, type_name: String, tname: Token) : PExpr {
  # `{` is next. Consume it.
  let p1 = p_skip_newlines(p_advance(p))
  if p_at(p1, TkRbrace) {
    ok_e(p_advance(p1), mk_expr(ERecordLit(type_name, []), tname.line, tname.col))
  } else {
    parse_record_fields_loop(p1, [], type_name, tname)
  }
}

fn parse_record_fields_loop(p: Parser, acc: [FieldInit], type_name: String, tname: Token) : PExpr {
  let p0 = p_skip_newlines(p)
  let tk = p_peek(p0)
  if not tk_is(tk.kind, TkIdent) {
    err_e(p_error(p0, tk, "expected field name in record literal"))
  } else {
    let fname = tok_source(p0.src, tk)
    let p1 = p_advance(p0)
    if not p_at(p1, TkColon) {
      err_e(p_error_here(p1, "expected `:` after field name"))
    } else {
      let p2 = p_skip_newlines(p_advance(p1))
      let r = parse_expr(p2)
      match r.r {
        None -> err_e(r.p)
        Some(val) -> {
          let acc1 = [FI(fname, val), ...acc]
          let p3 = p_skip_newlines(r.p)
          if p_at(p3, TkComma) {
            parse_record_fields_loop(p_skip_newlines(p_advance(p3)), acc1, type_name, tname)
          } else if p_at(p3, TkRbrace) {
            ok_e(p_advance(p3), mk_expr(ERecordLit(type_name, list_reverse(acc1)), tname.line, tname.col))
          } else {
            err_e(p_error_here(p3, "expected `,` or `}` in record literal"))
          }
        }
      }
    }
  }
}

fn parse_paren_or_lambda(p: Parser, t: Token) : PExpr {
  # We need to distinguish:
  #   (expr)                  — grouping
  #   ()                       — unit
  #   () => expr               — zero-arg lambda
  #   (a, b, ...) => expr      — multi-arg lambda
  #   (a) => expr              — single-arg lambda (parenthesised)
  # Strategy: speculatively parse a lambda-param list. If followed by
  # `=>`, it's a lambda. Otherwise it was a parenthesised expression
  # and we re-parse from the original position.
  let p1 = p_skip_newlines(p_advance(p))
  # Empty parens: unit, or zero-arg lambda.
  if p_at(p1, TkRparen) {
    let p2 = p_advance(p1)
    if p_at(p2, TkFatArrow) {
      let p3 = p_advance(p2)
      let r = parse_expr(p3)
      match r.r {
        None -> err_e(r.p)
        Some(body) -> ok_e(r.p, mk_expr(ELambda([], body), t.line, t.col))
      }
    } else {
      ok_e(p2, mk_expr(EUnit, t.line, t.col))
    }
  } else {
    # Try lambda: tentatively scan for an ident list ending with `)` `=>`.
    match try_parse_lambda_params(p1) {
      Some(res) -> {
        let r = parse_expr(res.p)
        match r.r {
          None -> err_e(r.p)
          Some(body) -> ok_e(r.p, mk_expr(ELambda(res.params, body), t.line, t.col))
        }
      }
      None -> {
        # Fall back to `( expr )`.
        let r = parse_expr(p1)
        match r.r {
          None -> err_e(r.p)
          Some(e) -> {
            let p2 = p_skip_newlines(r.p)
            if p_at(p2, TkRparen) { ok_e(p_advance(p2), e) }
            else { err_e(p_error_here(p2, "expected `)` after expression")) }
          }
        }
      }
    }
  }
}

# A lambda parameter list is a comma-separated sequence of identifiers
# (optionally with `: Type` annotations) followed by `)` then `=>`.
# This scan is non-destructive: it returns the parser advanced past the
# `=>` on success, None on failure.
type LamParams = { p: Parser, params: [Param] }

fn try_parse_lambda_params(p: Parser) : Option[LamParams] {
  try_parse_lambda_params_loop(p, [])
}

fn try_parse_lambda_params_loop(p: Parser, acc: [Param]) : Option[LamParams] {
  let t = p_peek(p)
  if not tk_is(t.kind, TkIdent) { None }
  else {
    let name = tok_source(p.src, t)
    let p1 = p_advance(p)
    # Optional `: Type`
    let p2_opt =
      if p_at(p1, TkColon) {
        let r = parse_type(p_advance(p1))
        match r.r {
          None -> None
          Some(_) -> Some(r.p)
        }
      } else {
        Some(p1)
      }
    match p2_opt {
      None -> None
      Some(p2) -> {
        let param = Param { pname: name, ptype: None, pline: t.line, pcol: t.col }
        let acc1 = [param, ...acc]
        if p_at(p2, TkComma) {
          try_parse_lambda_params_loop(p_skip_newlines(p_advance(p2)), acc1)
        } else if p_at(p2, TkRparen) {
          let p3 = p_advance(p2)
          if p_at(p3, TkFatArrow) {
            Some(LamParams { p: p_advance(p3), params: list_reverse(acc1) })
          } else { None }
        } else { None }
      }
    }
  }
}

# ====================================================================
# list / range
# ====================================================================

fn parse_list_or_range(p: Parser, t: Token) : PExpr {
  let p1 = p_skip_newlines(p_advance(p))
  if p_at(p1, TkRbracket) {
    ok_e(p_advance(p1), mk_expr(EList([]), t.line, t.col))
  } else {
    # Parse first element (could start with `...`).
    parse_first_list_elem(p1, t)
  }
}

fn parse_first_list_elem(p: Parser, t: Token) : PExpr {
  if p_at(p, TkEllipsis) {
    let r = parse_expr(p_advance(p))
    match r.r {
      None -> err_e(r.p)
      Some(e) -> parse_list_rest(r.p, [ElSpread(e)], t)
    }
  } else {
    let r = parse_expr(p)
    match r.r {
      None -> err_e(r.p)
      Some(first) -> {
        # Range: `[ a .. b ]` or `[ a .. b .. step ]`.
        let p1 = p_skip_newlines(r.p)
        if p_at(p1, TkDotDot) {
          let r2 = parse_expr(p_skip_newlines(p_advance(p1)))
          match r2.r {
            None -> err_e(r2.p)
            Some(to) -> {
              let p2 = p_skip_newlines(r2.p)
              if p_at(p2, TkDotDot) {
                let r3 = parse_expr(p_skip_newlines(p_advance(p2)))
                match r3.r {
                  None -> err_e(r3.p)
                  Some(step) -> {
                    let p3 = p_skip_newlines(r3.p)
                    if p_at(p3, TkRbracket) {
                      ok_e(p_advance(p3), mk_expr(ERange(first, to, Some(step)), t.line, t.col))
                    } else { err_e(p_error_here(p3, "expected `]` at end of range")) }
                  }
                }
              } else if p_at(p2, TkRbracket) {
                ok_e(p_advance(p2), mk_expr(ERange(first, to, None), t.line, t.col))
              } else { err_e(p_error_here(p2, "expected `]` at end of range")) }
            }
          }
        } else {
          parse_list_rest(p1, [ElPlain(first)], t)
        }
      }
    }
  }
}

fn parse_list_rest(p: Parser, acc: [ListElem], t: Token) : PExpr {
  let p0 = p_skip_newlines(p)
  if p_at(p0, TkRbracket) {
    ok_e(p_advance(p0), mk_expr(EList(list_reverse(acc)), t.line, t.col))
  } else if p_at(p0, TkComma) {
    let p1 = p_skip_newlines(p_advance(p0))
    if p_at(p1, TkEllipsis) {
      let r = parse_expr(p_advance(p1))
      match r.r {
        None -> err_e(r.p)
        Some(e) -> parse_list_rest(r.p, [ElSpread(e), ...acc], t)
      }
    } else {
      let r = parse_expr(p1)
      match r.r {
        None -> err_e(r.p)
        Some(e) -> parse_list_rest(r.p, [ElPlain(e), ...acc], t)
      }
    }
  } else {
    err_e(p_error_here(p0, "expected `,` or `]` in list"))
  }
}

# ====================================================================
# block, if, match
# ====================================================================

fn parse_block(p: Parser, t: Token) : PExpr {
  # `{` is at current position.
  let p1 = p_skip_newlines_and_semis(p_advance(p))
  parse_block_body(p1, [], t)
}

fn parse_block_body(p: Parser, stmts: [Stmt], t: Token) : PExpr {
  let p0 = p_skip_newlines_and_semis(p)
  if p_at(p0, TkRbrace) {
    ok_e(p_advance(p0), mk_expr(EBlock(list_reverse(stmts), None), t.line, t.col))
  } else {
    let r = parse_stmt(p0)
    match r.r {
      None -> err_e(r.p)
      Some(s) -> {
        let p1 = p_skip_newlines_and_semis(r.p)
        if p_at(p1, TkRbrace) {
          # If the last stmt was an expression statement, it becomes the
          # block's final expression.
          match s {
            SExprStmt(e) -> ok_e(p_advance(p1), mk_expr(EBlock(list_reverse(stmts), Some(e)), t.line, t.col))
            _ -> ok_e(p_advance(p1), mk_expr(EBlock(list_reverse([s, ...stmts]), None), t.line, t.col))
          }
        } else {
          parse_block_body(p1, [s, ...stmts], t)
        }
      }
    }
  }
}

fn parse_stmt(p: Parser) : PStmt {
  let t = p_peek(p)
  if tk_is(t.kind, TkLet) {
    parse_let(p, t)
  } else if tk_is(t.kind, TkAssert) {
    parse_assert(p, t)
  } else {
    let r = parse_expr(p)
    match r.r {
      None -> err_s(r.p)
      Some(e) -> ok_s(r.p, SExprStmt(e))
    }
  }
}

fn parse_let(p: Parser, t: Token) : PStmt {
  let p1 = p_advance(p)
  let rp = parse_pattern(p1)
  match rp.r {
    None -> err_s(rp.p)
    Some(pat) -> {
      # Optional `: Type` annotation.
      let pa = p_skip_newlines(rp.p)
      let ty_opt_r =
        if p_at(pa, TkColon) {
          let rt = parse_type(p_advance(pa))
          match rt.r {
            None -> PTy { p: rt.p, r: None }
            Some(ty) -> PTy { p: rt.p, r: Some(ty) }
          }
        } else {
          PTy { p: pa, r: None }
        }
      if ty_opt_r.p.had_error and not pa.had_error { err_s(ty_opt_r.p) }
      else {
        let p_eq = p_skip_newlines(ty_opt_r.p)
        if not p_at(p_eq, TkEq) {
          err_s(p_error_here(p_eq, "expected `=` in let binding"))
        } else {
          let p_rhs = p_skip_newlines(p_advance(p_eq))
          let re = parse_expr(p_rhs)
          match re.r {
            None -> err_s(re.p)
            Some(rhs) -> ok_s(re.p, SLet(pat, ty_opt_r.r, rhs))
          }
        }
      }
    }
  }
}

fn parse_assert(p: Parser, t: Token) : PStmt {
  let p1 = p_advance(p)
  let re = parse_expr(p1)
  match re.r {
    None -> err_s(re.p)
    Some(cond) -> {
      if p_at(re.p, TkComma) {
        let p2 = p_skip_newlines(p_advance(re.p))
        let rm = parse_expr(p2)
        match rm.r {
          None -> err_s(rm.p)
          Some(msg) -> ok_s(rm.p, SAssert(cond, Some(msg)))
        }
      } else {
        ok_s(re.p, SAssert(cond, None))
      }
    }
  }
}

fn parse_if(p: Parser, t: Token) : PExpr {
  let p1 = p_advance(p)
  let rc = parse_expr(p1)
  match rc.r {
    None -> err_e(rc.p)
    Some(cond) -> {
      # Then-block
      let p2 = p_skip_newlines(rc.p)
      if not p_at(p2, TkLbrace) {
        err_e(p_error_here(p2, "expected `{` after `if` condition"))
      } else {
        let tb = p_peek(p2)
        let rt = parse_block(p2, tb)
        match rt.r {
          None -> err_e(rt.p)
          Some(then_e) -> {
            let p3 = p_skip_newlines(rt.p)
            if p_at(p3, TkElse) {
              let p4 = p_skip_newlines(p_advance(p3))
              if p_at(p4, TkIf) {
                let te = p_peek(p4)
                let re = parse_if(p4, te)
                match re.r {
                  None -> err_e(re.p)
                  Some(else_e) -> ok_e(re.p, mk_expr(EIf(cond, then_e, Some(else_e)), t.line, t.col))
                }
              } else if p_at(p4, TkLbrace) {
                let teb = p_peek(p4)
                let re = parse_block(p4, teb)
                match re.r {
                  None -> err_e(re.p)
                  Some(else_e) -> ok_e(re.p, mk_expr(EIf(cond, then_e, Some(else_e)), t.line, t.col))
                }
              } else {
                err_e(p_error_here(p4, "expected `if` or `{` after `else`"))
              }
            } else {
              ok_e(rc.p, mk_expr(EIf(cond, then_e, None), t.line, t.col))
              # Note: we return with p3's state (unchanged) since there is no else.
            }
          }
        }
      }
    }
  }
}

fn parse_match(p: Parser, t: Token) : PExpr {
  let p1 = p_advance(p)
  let rs = parse_expr(p1)
  match rs.r {
    None -> err_e(rs.p)
    Some(scrut) -> {
      let p2 = p_skip_newlines(rs.p)
      if not p_at(p2, TkLbrace) {
        err_e(p_error_here(p2, "expected `{` after `match` expression"))
      } else {
        parse_match_arms(p_skip_newlines(p_advance(p2)), [], scrut, t)
      }
    }
  }
}

fn parse_match_arms(p: Parser, acc: [Arm], scrut: Expr, t: Token) : PExpr {
  let p0 = p_skip_newlines_and_semis(p)
  if p_at(p0, TkRbrace) {
    ok_e(p_advance(p0), mk_expr(EMatch(scrut, list_reverse(acc)), t.line, t.col))
  } else {
    let ra = parse_arm(p0)
    match ra.r {
      None -> err_e(ra.p)
      Some(arm) -> parse_match_arms(ra.p, [arm, ...acc], scrut, t)
    }
  }
}

fn parse_arm(p: Parser) : PArm {
  let rp = parse_pattern(p)
  match rp.r {
    None -> err_a(rp.p)
    Some(pat) -> {
      let p1 = p_skip_newlines(rp.p)
      # Optional guard: `if expr`.
      let guard_opt_r =
        if p_at(p1, TkIf) {
          let rg = parse_expr(p_advance(p1))
          match rg.r {
            None -> PExpr { p: rg.p, r: None }
            Some(g) -> PExpr { p: rg.p, r: Some(g) }
          }
        } else {
          PExpr { p: p1, r: None }
        }
      match guard_opt_r.r {
        None -> if guard_opt_r.p.had_error { err_a(guard_opt_r.p) } else {
          parse_arm_body(guard_opt_r.p, pat, None)
        }
        Some(_) -> parse_arm_body(guard_opt_r.p, pat, guard_opt_r.r)
      }
    }
  }
}

fn parse_arm_body(p: Parser, pat: Pattern, guard: Option[Expr]) : PArm {
  let p1 = p_skip_newlines(p)
  if not p_at(p1, TkArrow) {
    err_a(p_error_here(p1, "expected `->` in match arm"))
  } else {
    let p2 = p_skip_newlines(p_advance(p1))
    let rb = parse_expr(p2)
    match rb.r {
      None -> err_a(rb.p)
      Some(body) -> ok_a(rb.p, Arm(pat, guard, body))
    }
  }
}

# ====================================================================
# patterns
# ====================================================================

fn parse_pattern(p: Parser) : PPat {
  let t = p_peek(p)
  if tk_is(t.kind, TkUnderscore) {
    ok_p(p_advance(p), mk_pat(PWild, t.line, t.col))
  } else if tk_is(t.kind, TkInt) {
    let span = tok_source(p.src, t)
    let lit = mk_expr(EInt(decode_int(span)), t.line, t.col)
    ok_p(p_advance(p), mk_pat(PLit(lit), t.line, t.col))
  } else if tk_is(t.kind, TkReal) {
    let span = tok_source(p.src, t)
    let lit = mk_expr(EReal(decode_real(span)), t.line, t.col)
    ok_p(p_advance(p), mk_pat(PLit(lit), t.line, t.col))
  } else if tk_is(t.kind, TkTrue) {
    ok_p(p_advance(p), mk_pat(PLit(mk_expr(EBool(true), t.line, t.col)), t.line, t.col))
  } else if tk_is(t.kind, TkFalse) {
    ok_p(p_advance(p), mk_pat(PLit(mk_expr(EBool(false), t.line, t.col)), t.line, t.col))
  } else if tk_is(t.kind, TkChar) {
    let span = tok_source(p.src, t)
    ok_p(p_advance(p), mk_pat(PLit(mk_expr(EChar(decode_char(span)), t.line, t.col)), t.line, t.col))
  } else if tk_is(t.kind, TkString) {
    let span = tok_source(p.src, t)
    ok_p(p_advance(p), mk_pat(PLit(mk_expr(EStr(span, false), t.line, t.col)), t.line, t.col))
  } else if tk_is(t.kind, TkMinus) {
    let nxt = p_peek1(p)
    if tk_is(nxt.kind, TkInt) {
      let span = tok_source(p.src, nxt)
      let v = 0 - decode_int(span)
      let p1 = p_advance(p_advance(p))
      ok_p(p1, mk_pat(PLit(mk_expr(EInt(v), t.line, t.col)), t.line, t.col))
    } else {
      err_p(p_error_here(p, "expected literal after `-` in pattern"))
    }
  } else if tk_is(t.kind, TkLbracket) {
    parse_list_pattern(p, t)
  } else if tk_is(t.kind, TkIdent) {
    parse_ident_pattern(p, t)
  } else {
    err_p(p_error_here(p, "expected pattern"))
  }
}

fn parse_list_pattern(p: Parser, t: Token) : PPat {
  let p1 = p_skip_newlines(p_advance(p))
  if p_at(p1, TkRbracket) {
    ok_p(p_advance(p1), mk_pat(PList([], None), t.line, t.col))
  } else {
    parse_list_pattern_loop(p1, [], None, t)
  }
}

fn parse_list_pattern_loop(p: Parser, acc: [Pattern], rest: Option[String], t: Token) : PPat {
  if p_at(p, TkEllipsis) {
    # Spread binder. Issue #328: `...` may stand alone (preferred form
    # `[h, ...]`) or be followed by `_` (uniform-with-`_` form
    # `[h, ..._]`); both discard the tail with no binding. The named
    # form `[h, ...rest]` keeps the existing semantics. Bare/`_` spread
    # uses a synthesized sentinel name (`__list_rest_<line>_<col>__`)
    # that round-trips as `Some(name)` through the rest of the pipeline,
    # preserving the spread-vs-no-spread distinction the typer needs
    # for exhaustiveness while leaving the binding unread.
    let p1 = p_advance(p)
    let id = p_peek(p1)
    if tk_is(id.kind, TkIdent) {
      let name = tok_source(p1.src, id)
      let p2 = p_skip_newlines(p_advance(p1))
      if p_at(p2, TkRbracket) {
        ok_p(p_advance(p2), mk_pat(PList(list_reverse(acc), Some(name)), t.line, t.col))
      } else {
        err_p(p_error_here(p2, "expected `]` after spread pattern"))
      }
    } else if tk_is(id.kind, TkUnderscore) {
      let sentinel = concat_all(["__list_rest_", int_to_string(id.line), "_",
                                  int_to_string(id.col), "__"])
      let p2 = p_skip_newlines(p_advance(p1))
      if p_at(p2, TkRbracket) {
        ok_p(p_advance(p2), mk_pat(PList(list_reverse(acc), Some(sentinel)), t.line, t.col))
      } else {
        err_p(p_error_here(p2, "expected `]` after spread pattern"))
      }
    } else if tk_is(id.kind, TkRbracket) {
      let sentinel = concat_all(["__list_rest_", int_to_string(id.line), "_",
                                  int_to_string(id.col), "__"])
      ok_p(p_advance(p1), mk_pat(PList(list_reverse(acc), Some(sentinel)), t.line, t.col))
    } else {
      err_p(p_error_here(p1, "expected identifier, `_`, or `]` after `...` in list pattern"))
    }
  } else {
    let r = parse_pattern(p)
    match r.r {
      None -> err_p(r.p)
      Some(pat) -> {
        let p1 = p_skip_newlines(r.p)
        if p_at(p1, TkComma) {
          parse_list_pattern_loop(p_skip_newlines(p_advance(p1)), [pat, ...acc], None, t)
        } else if p_at(p1, TkRbracket) {
          ok_p(p_advance(p1), mk_pat(PList(list_reverse([pat, ...acc]), None), t.line, t.col))
        } else {
          err_p(p_error_here(p1, "expected `,` or `]` in list pattern"))
        }
      }
    }
  }
}

fn parse_ident_pattern(p: Parser, t: Token) : PPat {
  let name = tok_source(p.src, t)
  let p1 = p_advance(p)
  if is_upper_ident(p.src, t) and p_at(p1, TkLparen) {
    # Variant with positional sub-patterns.
    let p2 = p_skip_newlines(p_advance(p1))
    if p_at(p2, TkRparen) {
      ok_p(p_advance(p2), mk_pat(PVariant(name, []), t.line, t.col))
    } else {
      parse_variant_sub_patterns(p2, [], name, t)
    }
  } else if is_upper_ident(p.src, t) and p_at(p1, TkLbrace) {
    # Variant-record pattern: parse as record, wrap in PVariantRecord.
    let p2 = p_skip_newlines(p_advance(p1))
    parse_record_pattern_fields(p2, [], Some(name), t)
  } else if is_upper_ident(p.src, t) {
    # Bare uppercase ident: 0-arg variant.
    ok_p(p1, mk_pat(PVariant(name, []), t.line, t.col))
  } else {
    ok_p(p1, mk_pat(PBind(name), t.line, t.col))
  }
}

fn parse_variant_sub_patterns(p: Parser, acc: [Pattern], name: String, t: Token) : PPat {
  let r = parse_pattern(p)
  match r.r {
    None -> err_p(r.p)
    Some(sub) -> {
      let p1 = p_skip_newlines(r.p)
      if p_at(p1, TkComma) {
        parse_variant_sub_patterns(p_skip_newlines(p_advance(p1)), [sub, ...acc], name, t)
      } else if p_at(p1, TkRparen) {
        ok_p(p_advance(p1), mk_pat(PVariant(name, list_reverse([sub, ...acc])), t.line, t.col))
      } else {
        err_p(p_error_here(p1, "expected `,` or `)` in variant pattern"))
      }
    }
  }
}

fn parse_record_pattern_fields(p: Parser, acc: [PField], ctor: Option[String], t: Token) : PPat {
  let p0 = p_skip_newlines(p)
  if p_at(p0, TkRbrace) {
    let p1 = p_advance(p0)
    match ctor {
      None -> ok_p(p1, mk_pat(PRecord(list_reverse(acc)), t.line, t.col))
      Some(name) -> ok_p(p1, mk_pat(PVariantRecord(name, list_reverse(acc)), t.line, t.col))
    }
  } else {
    let fn_t = p_peek(p0)
    if not tk_is(fn_t.kind, TkIdent) {
      err_p(p_error(p0, fn_t, "expected field name in record pattern"))
    } else {
      let fname = tok_source(p0.src, fn_t)
      let p1 = p_advance(p0)
      let sub_r =
        if p_at(p1, TkColon) {
          let r = parse_pattern(p_advance(p1))
          match r.r {
            None -> PPat { p: r.p, r: None }
            Some(sp) -> PPat { p: r.p, r: Some(sp) }
          }
        } else {
          PPat { p: p1, r: Some(mk_pat(PBind(fname), fn_t.line, fn_t.col)) }
        }
      match sub_r.r {
        None -> err_p(sub_r.p)
        Some(sub) -> {
          let is_short = not p_at(p1, TkColon)
          let pf = PField(fname, sub, is_short)
          let p2 = p_skip_newlines(sub_r.p)
          if p_at(p2, TkComma) {
            parse_record_pattern_fields(p_skip_newlines(p_advance(p2)), [pf, ...acc], ctor, t)
          } else if p_at(p2, TkRbrace) {
            parse_record_pattern_fields(p2, [pf, ...acc], ctor, t)
          } else {
            err_p(p_error_here(p2, "expected `,` or `}` in record pattern"))
          }
        }
      }
    }
  }
}

# ====================================================================
# type expressions
# ====================================================================

fn parse_type(p: Parser) : PTy {
  let t = p_peek(p)
  if tk_is(t.kind, TkLbracket) {
    let p1 = p_advance(p)
    let r = parse_type(p1)
    match r.r {
      None -> err_t(r.p)
      Some(inner) -> {
        if p_at(r.p, TkRbracket) {
          ok_t(p_advance(r.p), mk_ty(TyList(inner), t.line, t.col))
        } else {
          err_t(p_error_here(r.p, "expected `]` in list type"))
        }
      }
    }
  } else if tk_is(t.kind, TkLparen) {
    parse_fn_type(p, t)
  } else if tk_is(t.kind, TkIdent) {
    parse_named_type(p, t)
  } else {
    err_t(p_error_here(p, "expected type"))
  }
}

fn parse_named_type(p: Parser, t: Token) : PTy {
  let name = tok_source(p.src, t)
  let p1 = p_advance(p)
  if p_at(p1, TkLbracket) {
    # Generic type: Name[T1, T2, ...]
    let p2 = p_skip_newlines(p_advance(p1))
    parse_type_args_loop(p2, [], name, t)
  } else {
    ok_t(p1, mk_ty(TyName(name, []), t.line, t.col))
  }
}

fn parse_type_args_loop(p: Parser, acc: [TypeExpr], name: String, t: Token) : PTy {
  let r = parse_type(p)
  match r.r {
    None -> err_t(r.p)
    Some(arg) -> {
      let p1 = p_skip_newlines(r.p)
      if p_at(p1, TkComma) {
        parse_type_args_loop(p_skip_newlines(p_advance(p1)), [arg, ...acc], name, t)
      } else if p_at(p1, TkRbracket) {
        ok_t(p_advance(p1), mk_ty(TyName(name, list_reverse([arg, ...acc])), t.line, t.col))
      } else {
        err_t(p_error_here(p1, "expected `,` or `]` after type arguments"))
      }
    }
  }
}

fn parse_fn_type(p: Parser, t: Token) : PTy {
  let p1 = p_skip_newlines(p_advance(p))
  if p_at(p1, TkRparen) {
    let p2 = p_advance(p1)
    if not p_at(p2, TkArrow) {
      err_t(p_error_here(p2, "expected `->` in function type"))
    } else {
      let r = parse_type(p_advance(p2))
      match r.r {
        None -> err_t(r.p)
        Some(ret) -> ok_t(r.p, mk_ty(TyFn([], ret), t.line, t.col))
      }
    }
  } else {
    parse_fn_type_args(p1, [], t)
  }
}

fn parse_fn_type_args(p: Parser, acc: [TypeExpr], t: Token) : PTy {
  let r = parse_type(p)
  match r.r {
    None -> err_t(r.p)
    Some(arg) -> {
      let p1 = p_skip_newlines(r.p)
      if p_at(p1, TkComma) {
        parse_fn_type_args(p_skip_newlines(p_advance(p1)), [arg, ...acc], t)
      } else if p_at(p1, TkRparen) {
        let p2 = p_advance(p1)
        if not p_at(p2, TkArrow) {
          err_t(p_error_here(p2, "expected `->` in function type"))
        } else {
          let rr = parse_type(p_advance(p2))
          match rr.r {
            None -> err_t(rr.p)
            Some(ret) -> ok_t(rr.p, mk_ty(TyFn(list_reverse([arg, ...acc]), ret), t.line, t.col))
          }
        }
      } else {
        err_t(p_error_here(p1, "expected `,` or `)` in function type args"))
      }
    }
  }
}

# ====================================================================
# declarations
# ====================================================================

fn parse_decl(p: Parser) : PDecl {
  let p0 = p_skip_newlines(p)
  let t = p_peek(p0)
  let is_pub_r =
    if tk_is(t.kind, TkPub) { PTy { p: p_advance(p0), r: Some(mk_ty(TyName("", []), 0, 0)) } }
    else { PTy { p: p0, r: None } }
  let is_pub =
    match is_pub_r.r { Some(_) -> true None -> false }
  let p1 = is_pub_r.p
  let hd = p_peek(p1)
  if tk_is(hd.kind, TkFn) {
    parse_fn_decl(p_advance(p1), is_pub, hd)
  } else if tk_is(hd.kind, TkType) {
    parse_type_decl(p_advance(p1), is_pub, hd)
  } else if tk_is(hd.kind, TkTest) {
    if is_pub { err_d(p_error(p1, hd, "`pub` is not allowed on a test")) }
    else { parse_test_decl(p_advance(p1), hd) }
  } else if tk_is(hd.kind, TkImport) {
    if is_pub { err_d(p_error(p1, hd, "`pub` is not allowed on an import")) }
    else { parse_import_decl(p_advance(p1), hd) }
  } else {
    err_d(p_error(p1, hd, "expected `fn`, `type`, `test`, or `import`"))
  }
}

fn parse_fn_decl(p: Parser, is_pub: Bool, t: Token) : PDecl {
  let id = p_peek(p)
  if not tk_is(id.kind, TkIdent) {
    err_d(p_error(p, id, "expected function name"))
  } else {
    let name = tok_source(p.src, id)
    let p1 = p_advance(p)
    if not p_at(p1, TkLparen) {
      err_d(p_error_here(p1, "expected `(` after function name"))
    } else {
      let p2 = p_skip_newlines(p_advance(p1))
      let params_r = parse_fn_params(p2, [])
      match params_r.r {
        None -> err_d(params_r.p)
        Some(params) -> {
          let p3 = p_skip_newlines(params_r.p)
          # Optional `: ReturnType`
          let ret_r =
            if p_at(p3, TkColon) {
              let rt = parse_type(p_advance(p3))
              match rt.r {
                None -> PTy { p: rt.p, r: None }
                Some(ty) -> PTy { p: rt.p, r: Some(ty) }
              }
            } else {
              PTy { p: p3, r: None }
            }
          if ret_r.p.had_error and not p3.had_error { err_d(ret_r.p) }
          else {
            # m12.8.x phase 4: stage 1 ignores effect rows by design;
            # enforcement lives in stage 2. After the return type, an
            # optional `/ Eff (+ Eff)*` row is consumed and discarded
            # so the compiler's own source (which declares rows on
            # its print/eprint helpers) keeps round-tripping through
            # the stage-1 → stage-2 bootstrap unchanged.
            let p4 = skip_effect_row(p_skip_newlines(ret_r.p))
            # Body: `= expr` or `{ block }`.
            if p_at(p4, TkEq) {
              let p5 = p_skip_newlines(p_advance(p4))
              let rb = parse_expr(p5)
              match rb.r {
                None -> err_d(rb.p)
                Some(body) -> ok_d(rb.p, DFn(is_pub, name, params, ret_r.r, body, t.line, t.col))
              }
            } else if p_at(p4, TkLbrace) {
              let tb = p_peek(p4)
              let rb = parse_block(p4, tb)
              match rb.r {
                None -> err_d(rb.p)
                Some(body) -> ok_d(rb.p, DFn(is_pub, name, params, ret_r.r, body, t.line, t.col))
              }
            } else {
              err_d(p_error_here(p4, "expected `=` or `{` to start function body"))
            }
          }
        }
      }
    }
  }
}

# m12.8.x phase 4: optional effect-row consumer for fn signatures.
# Stage 1 is kaikai-minimal — no effect system semantically — but its
# parser must accept and discard `/ Eff (+ Eff)*` so the stage-2
# compiler.kai source (which carries `/ Console` annotations on its
# print/eprint helpers) round-trips through the bootstrap unchanged.
# Walks tokens until the next `=` or `{` (the legitimate function-
# body openers); also stops at TkEof or `}` defensively. The
# discarded slice is not parsed — names appearing inside the row are
# arbitrary and ignored at this layer.
fn skip_effect_row(p: Parser) : Parser {
  if not p_at(p, TkSlash) { p }
  else { skip_effect_row_loop(p_advance(p)) }
}

fn skip_effect_row_loop(p: Parser) : Parser {
  let t = p_peek(p)
  if tk_is(t.kind, TkEq) or tk_is(t.kind, TkLbrace) or tk_is(t.kind, TkRbrace) or tk_is(t.kind, TkEof) { p }
  else { skip_effect_row_loop(p_advance(p)) }
}

type PParams = { p: Parser, r: Option[[Param]] }

fn parse_fn_params(p: Parser, acc: [Param]) : PParams {
  if p_at(p, TkRparen) { PParams { p: p_advance(p), r: Some(list_reverse(acc)) } }
  else {
    let t = p_peek(p)
    if not tk_is(t.kind, TkIdent) {
      PParams { p: p_error(p, t, "expected parameter name"), r: None }
    } else {
      let name = tok_source(p.src, t)
      let p1 = p_advance(p)
      if not p_at(p1, TkColon) {
        PParams { p: p_error_here(p1, "expected `:` after parameter name"), r: None }
      } else {
        let rt = parse_type(p_advance(p1))
        match rt.r {
          None -> PParams { p: rt.p, r: None }
          Some(ty) -> {
            let param = Param { pname: name, ptype: Some(ty), pline: t.line, pcol: t.col }
            let p2 = p_skip_newlines(rt.p)
            if p_at(p2, TkComma) {
              parse_fn_params(p_skip_newlines(p_advance(p2)), [param, ...acc])
            } else if p_at(p2, TkRparen) {
              PParams { p: p_advance(p2), r: Some(list_reverse([param, ...acc])) }
            } else {
              PParams { p: p_error_here(p2, "expected `,` or `)` in parameter list"), r: None }
            }
          }
        }
      }
    }
  }
}

fn parse_type_decl(p: Parser, is_pub: Bool, t: Token) : PDecl {
  let id = p_peek(p)
  if not tk_is(id.kind, TkIdent) or not is_upper_ident(p.src, id) {
    err_d(p_error(p, id, "expected an uppercase type name after `type`"))
  } else {
    let name = tok_source(p.src, id)
    let p1 = p_advance(p)
    let p1n = p_skip_newlines(p1)
    # Optional type params `[a, b, c]`.
    let tparams_r =
      if p_at(p1n, TkLbracket) {
        parse_type_params_loop(p_skip_newlines(p_advance(p1n)), [])
      } else {
        PTParams { p: p1n, r: Some([]) }
      }
    match tparams_r.r {
      None -> err_d(tparams_r.p)
      Some(tparams) -> {
        let p2 = p_skip_newlines(tparams_r.p)
        if not p_at(p2, TkEq) {
          err_d(p_error_here(p2, "expected `=` in type declaration"))
        } else {
          let p3 = p_skip_newlines(p_advance(p2))
          parse_type_body(p3, is_pub, name, tparams, t)
        }
      }
    }
  }
}

type PTParams = { p: Parser, r: Option[[String]] }

fn parse_type_params_loop(p: Parser, acc: [String]) : PTParams {
  let t = p_peek(p)
  if not tk_is(t.kind, TkIdent) {
    PTParams { p: p_error(p, t, "expected type parameter name"), r: None }
  } else {
    let name = tok_source(p.src, t)
    let p1 = p_skip_newlines(p_advance(p))
    if p_at(p1, TkComma) {
      parse_type_params_loop(p_skip_newlines(p_advance(p1)), [name, ...acc])
    } else if p_at(p1, TkRbracket) {
      PTParams { p: p_advance(p1), r: Some(list_reverse([name, ...acc])) }
    } else {
      PTParams { p: p_error_here(p1, "expected `,` or `]` after type parameter"), r: None }
    }
  }
}

fn parse_type_body(p: Parser, is_pub: Bool, name: String, tparams: [String], t: Token) : PDecl {
  if p_at(p, TkLbrace) {
    let p1 = p_skip_newlines(p_advance(p))
    parse_record_body(p1, [], is_pub, name, tparams, t)
  } else {
    # Sum or alias: check for an uppercase ident followed by `(` OR
    # followed eventually by `|` to decide. Simpler approach: try to
    # parse as sum; if the first variant is followed by `|`, continue
    # as sum; otherwise, fall back to alias. But stage 1 mirrors stage
    # 0: use the same heuristic — if the first token is Uppercase and
    # the next is `(` OR further along we see `|`, treat as sum.
    let hd = p_peek(p)
    if tk_is(hd.kind, TkIdent) and is_upper_ident(p.src, hd) {
      # Decide by lookahead.
      let is_sum = looks_like_sum(p)
      if is_sum {
        parse_sum_body(p, [], is_pub, name, tparams, t)
      } else {
        let rt = parse_type(p)
        match rt.r {
          None -> err_d(rt.p)
          Some(aliased) -> ok_d(rt.p, DType(is_pub, name, tparams, TBAlias(aliased), t.line, t.col))
        }
      }
    } else {
      let rt = parse_type(p)
      match rt.r {
        None -> err_d(rt.p)
        Some(aliased) -> ok_d(rt.p, DType(is_pub, name, tparams, TBAlias(aliased), t.line, t.col))
      }
    }
  }
}

# Mirror of stage 0's looks_like_sum heuristic: scan ahead for `|` or
# for `Uppercase(` indicating a variant with payload.
fn looks_like_sum(p: Parser) : Bool {
  let hd = p_peek(p)
  let nxt = p_peek1(p)
  if is_upper_ident(p.src, hd) and tk_is(nxt.kind, TkLparen) { true }
  else { looks_like_sum_scan(p.rest, 0) }
}

fn looks_like_sum_scan(toks: [Token], depth: Int) : Bool {
  match toks {
    [] -> false
    [t, ...rs] -> {
      match t.kind {
        TkEof -> false
        TkLparen -> looks_like_sum_scan(rs, depth + 1)
        TkLbracket -> looks_like_sum_scan(rs, depth + 1)
        TkLbrace -> looks_like_sum_scan(rs, depth + 1)
        TkRparen -> looks_like_sum_scan(rs, depth - 1)
        TkRbracket -> looks_like_sum_scan(rs, depth - 1)
        TkRbrace -> looks_like_sum_scan(rs, depth - 1)
        TkPipe -> if depth == 0 { true } else { looks_like_sum_scan(rs, depth) }
        TkNewline -> if depth == 0 { looks_like_sum_after_nl(rs) }
                     else { looks_like_sum_scan(rs, depth) }
        _ -> looks_like_sum_scan(rs, depth)
      }
    }
  }
}

fn looks_like_sum_after_nl(toks: [Token]) : Bool {
  match toks {
    [] -> false
    [t, ...rs] -> {
      match t.kind {
        TkNewline -> looks_like_sum_after_nl(rs)
        TkPipe -> true
        _ -> false
      }
    }
  }
}

fn parse_record_body(p: Parser, acc: [FieldDecl], is_pub: Bool, name: String, tparams: [String], t: Token) : PDecl {
  let p0 = p_skip_newlines(p)
  if p_at(p0, TkRbrace) {
    ok_d(p_advance(p0), DType(is_pub, name, tparams, TBRecord(list_reverse(acc)), t.line, t.col))
  } else {
    let ft = p_peek(p0)
    if not tk_is(ft.kind, TkIdent) {
      err_d(p_error(p0, ft, "expected field name in record type"))
    } else {
      let fname = tok_source(p0.src, ft)
      let p1 = p_advance(p0)
      if not p_at(p1, TkColon) {
        err_d(p_error_here(p1, "expected `:` after field name"))
      } else {
        let rt = parse_type(p_advance(p1))
        match rt.r {
          None -> err_d(rt.p)
          Some(ty) -> {
            let fd = FD(fname, ty)
            let p2 = p_skip_newlines(rt.p)
            if p_at(p2, TkComma) {
              parse_record_body(p_skip_newlines(p_advance(p2)), [fd, ...acc], is_pub, name, tparams, t)
            } else if p_at(p2, TkRbrace) {
              ok_d(p_advance(p2), DType(is_pub, name, tparams, TBRecord(list_reverse([fd, ...acc])), t.line, t.col))
            } else {
              err_d(p_error_here(p2, "expected `,` or `}` in record type"))
            }
          }
        }
      }
    }
  }
}

fn parse_sum_body(p: Parser, acc: [Variant], is_pub: Bool, name: String, tparams: [String], t: Token) : PDecl {
  let p0 = p_skip_newlines(p)
  let vt = p_peek(p0)
  if not tk_is(vt.kind, TkIdent) or not is_upper_ident(p0.src, vt) {
    err_d(p_error(p0, vt, "expected variant constructor name"))
  } else {
    let vname = tok_source(p0.src, vt)
    let p1 = p_advance(p0)
    let args_r =
      if p_at(p1, TkLparen) {
        parse_variant_args(p_skip_newlines(p_advance(p1)), [])
      } else {
        PVariantArgs { p: p1, r: Some([]) }
      }
    match args_r.r {
      None -> err_d(args_r.p)
      Some(vargs) -> {
        let vnode = Var(vname, vargs)
        let p2 = p_skip_newlines(args_r.p)
        if p_at(p2, TkPipe) {
          parse_sum_body(p_skip_newlines(p_advance(p2)), [vnode, ...acc], is_pub, name, tparams, t)
        } else {
          ok_d(p2, DType(is_pub, name, tparams, TBSum(list_reverse([vnode, ...acc])), t.line, t.col))
        }
      }
    }
  }
}

type PVariantArgs = { p: Parser, r: Option[[TypeExpr]] }

fn parse_variant_args(p: Parser, acc: [TypeExpr]) : PVariantArgs {
  if p_at(p, TkRparen) { PVariantArgs { p: p_advance(p), r: Some(list_reverse(acc)) } }
  else {
    let r = parse_type(p)
    match r.r {
      None -> PVariantArgs { p: r.p, r: None }
      Some(ty) -> {
        let p1 = p_skip_newlines(r.p)
        if p_at(p1, TkComma) {
          parse_variant_args(p_skip_newlines(p_advance(p1)), [ty, ...acc])
        } else if p_at(p1, TkRparen) {
          PVariantArgs { p: p_advance(p1), r: Some(list_reverse([ty, ...acc])) }
        } else {
          PVariantArgs { p: p_error_here(p1, "expected `,` or `)` in variant payload"), r: None }
        }
      }
    }
  }
}

fn parse_test_decl(p: Parser, t: Token) : PDecl {
  let desc_t = p_peek(p)
  if not tk_is(desc_t.kind, TkString) {
    err_d(p_error(p, desc_t, "expected string description after `test`"))
  } else {
    let desc_span = tok_source(p.src, desc_t)
    let p1 = p_skip_newlines(p_advance(p))
    if not p_at(p1, TkLbrace) {
      err_d(p_error_here(p1, "expected `{` for test body"))
    } else {
      let tb = p_peek(p1)
      let rb = parse_block(p1, tb)
      match rb.r {
        None -> err_d(rb.p)
        Some(body) -> ok_d(rb.p, DTest(desc_span, body, t.line, t.col))
      }
    }
  }
}

fn parse_import_decl(p: Parser, t: Token) : PDecl {
  # For stage 1 MVP, imports are structurally parsed but not resolved.
  # Accept: `import a.b.c`, `import a.b.c as X`, `import a.b.c.{f, g}`.
  let first = p_peek(p)
  if not tk_is(first.kind, TkIdent) {
    err_d(p_error(p, first, "expected module name after `import`"))
  } else {
    parse_import_path(p_advance(p), tok_source(p.src, first), t)
  }
}

fn parse_import_path(p: Parser, acc_path: String, t: Token) : PDecl {
  if p_at(p, TkDot) {
    let p1 = p_advance(p)
    let nxt = p_peek(p1)
    if tk_is(nxt.kind, TkIdent) {
      let seg = tok_source(p1.src, nxt)
      parse_import_path(p_advance(p1), string_concat(string_concat(acc_path, "."), seg), t)
    } else if tk_is(nxt.kind, TkLbrace) {
      # Selective: `.{a, b}`
      parse_import_selectives(p_skip_newlines(p_advance(p1)), [], acc_path, t)
    } else {
      err_d(p_error_here(p1, "expected identifier or `{` after `.`"))
    }
  } else if p_at(p, TkAs) {
    let p1 = p_advance(p)
    let nxt = p_peek(p1)
    if not tk_is(nxt.kind, TkIdent) {
      err_d(p_error(p1, nxt, "expected alias name after `as`"))
    } else {
      let alias = tok_source(p1.src, nxt)
      ok_d(p_advance(p1), DImport(IkAlias(acc_path, alias), t.line, t.col))
    }
  } else {
    ok_d(p, DImport(IkPath(acc_path), t.line, t.col))
  }
}

fn parse_import_selectives(p: Parser, acc: [String], path: String, t: Token) : PDecl {
  let p0 = p_skip_newlines(p)
  let nxt = p_peek(p0)
  if not tk_is(nxt.kind, TkIdent) {
    err_d(p_error(p0, nxt, "expected identifier in selective import"))
  } else {
    let name = tok_source(p0.src, nxt)
    let p1 = p_skip_newlines(p_advance(p0))
    if p_at(p1, TkComma) {
      parse_import_selectives(p_skip_newlines(p_advance(p1)), [name, ...acc], path, t)
    } else if p_at(p1, TkRbrace) {
      ok_d(p_advance(p1), DImport(IkSelective(path, list_reverse([name, ...acc])), t.line, t.col))
    } else {
      err_d(p_error_here(p1, "expected `,` or `}` in selective import"))
    }
  }
}

# ====================================================================
# program
# ====================================================================

fn parse_program_loop(p: Parser, acc: [Decl]) : PParser {
  let p0 = p_skip_newlines(p)
  if p_at(p0, TkEof) { PParser { p: p0, decls: Some(list_reverse(acc)) } }
  else {
    let r = parse_decl(p0)
    match r.r {
      None -> PParser { p: r.p, decls: None }
      Some(d) -> parse_program_loop(r.p, [d, ...acc])
    }
  }
}

type PParser = { p: Parser, decls: Option[[Decl]] }

fn parse_program(file: String, src: String, toks: [Token]) : PParser {
  parse_program_loop(parser_new(file, src, toks), [])
}

# ====================================================================
# AST dumper (for --ast)
# ====================================================================
#
# The format is indented nesting, one node per line. It does not try
# to match stage 0's kai_dump_ast byte-for-byte; the value here is to
# help visually inspect stage 1's parser while the emitter is being
# written.

fn indent_of(depth: Int) : String {
  if depth == 0 { "" } else { string_concat("  ", indent_of(depth - 1)) }
}

fn emit_line(depth: Int, s: String) : Unit = print("#{indent_of(depth)}#{s}")

fn dump_expr(e: Expr, depth: Int) : Unit {
  match e.kind {
    EInt(n) -> emit_line(depth, "int #{int_to_string(n)} @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
    EReal(r) -> emit_line(depth, "real #{real_to_string(r)} @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
    EBool(b) -> {
      let s = if b { "true" } else { "false" }
      emit_line(depth, "bool #{s} @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
    }
    EChar(c) -> emit_line(depth, "char '#{c}' @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
    EStr(s, _) -> emit_line(depth, "string #{s} @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
    EUnit -> emit_line(depth, "unit @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
    EVar(name) -> emit_line(depth, "ident #{name} @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
    EUnder -> emit_line(depth, "_ @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
    EPlaceholder -> emit_line(depth, ". @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
    ECall(callee, xs) -> {
      emit_line(depth, "call @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      dump_expr(callee, depth + 1)
      xs |> each((a) => dump_expr(a, depth + 1))
    }
    EField(base, name) -> {
      emit_line(depth, "field .#{name} @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      dump_expr(base, depth + 1)
    }
    EIndex(base, idx) -> {
      emit_line(depth, "index @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      dump_expr(base, depth + 1)
      dump_expr(idx, depth + 1)
    }
    EBinop(op, a, b) -> {
      emit_line(depth, "binop #{op} @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      dump_expr(a, depth + 1)
      dump_expr(b, depth + 1)
    }
    EUnop(op, x) -> {
      emit_line(depth, "unop #{op} @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      dump_expr(x, depth + 1)
    }
    EIf(c, a, opt_b) -> {
      emit_line(depth, "if @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      dump_expr(c, depth + 1)
      dump_expr(a, depth + 1)
      match opt_b { Some(b) -> dump_expr(b, depth + 1) None -> () }
    }
    EMatch(scrut, arms) -> {
      emit_line(depth, "match @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      dump_expr(scrut, depth + 1)
      arms |> each((a) => dump_arm(a, depth + 1))
    }
    ELambda(params, body) -> {
      emit_line(depth, "lambda @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      params |> each((pm) => emit_line(depth + 1, "param #{pm.pname}"))
      dump_expr(body, depth + 1)
    }
    ERecordLit(name, fields) -> {
      emit_line(depth, "record #{name} @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      fields |> each((fi) => dump_field_init(fi, depth + 1))
    }
    EList(elems) -> {
      emit_line(depth, "list @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      elems |> each((el) => dump_list_elem(el, depth + 1))
    }
    ERange(a, b, opt_step) -> {
      emit_line(depth, "range @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      dump_expr(a, depth + 1)
      dump_expr(b, depth + 1)
      match opt_step { Some(s) -> dump_expr(s, depth + 1) None -> () }
    }
    EBlock(stmts, opt_final) -> {
      emit_line(depth, "block @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      stmts |> each((s) => dump_stmt(s, depth + 1))
      match opt_final { Some(fe) -> dump_expr(fe, depth + 1) None -> () }
    }
    EPipe(a, b) -> {
      emit_line(depth, "pipe @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      dump_expr(a, depth + 1)
      dump_expr(b, depth + 1)
    }
  }
}

fn dump_arm(a: Arm, depth: Int) : Unit {
  emit_line(depth, "arm")
  match a {
    Arm(pat, guard, body) -> {
      dump_pat(pat, depth + 1)
      match guard { Some(g) -> { emit_line(depth + 1, "guard"); dump_expr(g, depth + 2) } None -> () }
      dump_expr(body, depth + 1)
    }
  }
}

fn dump_field_init(fi: FieldInit, depth: Int) : Unit {
  match fi {
    FI(name, val) -> {
      emit_line(depth, "field_init #{name}")
      dump_expr(val, depth + 1)
    }
  }
}

fn dump_list_elem(el: ListElem, depth: Int) : Unit {
  match el {
    ElPlain(e) -> dump_expr(e, depth)
    ElSpread(e) -> {
      emit_line(depth, "spread")
      dump_expr(e, depth + 1)
    }
  }
}

fn dump_stmt(s: Stmt, depth: Int) : Unit {
  match s {
    SLet(pat, opt_ty, rhs) -> {
      emit_line(depth, "let")
      dump_pat(pat, depth + 1)
      match opt_ty { Some(ty) -> dump_type(ty, depth + 1) None -> () }
      dump_expr(rhs, depth + 1)
    }
    SAssert(cond, opt_msg) -> {
      emit_line(depth, "assert")
      dump_expr(cond, depth + 1)
      match opt_msg { Some(m) -> dump_expr(m, depth + 1) None -> () }
    }
    SExprStmt(e) -> dump_expr(e, depth)
  }
}

fn dump_pat(pat: Pattern, depth: Int) : Unit {
  match pat.pkind {
    PWild -> emit_line(depth, "pat _ @#{int_to_string(pat.line)}:#{int_to_string(pat.col)}")
    PLit(e) -> {
      emit_line(depth, "pat_lit @#{int_to_string(pat.line)}:#{int_to_string(pat.col)}")
      dump_expr(e, depth + 1)
    }
    PBind(name) -> emit_line(depth, "pat_bind #{name} @#{int_to_string(pat.line)}:#{int_to_string(pat.col)}")
    PList(pats, opt_rest) -> {
      emit_line(depth, "pat_list @#{int_to_string(pat.line)}:#{int_to_string(pat.col)}")
      pats |> each((pp) => dump_pat(pp, depth + 1))
      match opt_rest { Some(r) -> emit_line(depth + 1, "...#{r}") None -> () }
    }
    PVariant(name, subs) -> {
      emit_line(depth, "pat_variant #{name} @#{int_to_string(pat.line)}:#{int_to_string(pat.col)}")
      subs |> each((pp) => dump_pat(pp, depth + 1))
    }
    PVariantRecord(name, fields) -> {
      emit_line(depth, "pat_variant_record #{name} @#{int_to_string(pat.line)}:#{int_to_string(pat.col)}")
      fields |> each((pf) => dump_pfield(pf, depth + 1))
    }
    PRecord(fields) -> {
      emit_line(depth, "pat_record @#{int_to_string(pat.line)}:#{int_to_string(pat.col)}")
      fields |> each((pf) => dump_pfield(pf, depth + 1))
    }
  }
}

fn dump_pfield(pf: PField, depth: Int) : Unit {
  match pf {
    PField(name, sub, short) -> {
      let suffix = if short { " (shorthand)" } else { "" }
      emit_line(depth, "pat_field #{name}#{suffix}")
      dump_pat(sub, depth + 1)
    }
  }
}

fn dump_type(ty: TypeExpr, depth: Int) : Unit {
  match ty.tkind {
    TyName(name, targs) -> {
      emit_line(depth, "ty_name #{name} @#{int_to_string(ty.line)}:#{int_to_string(ty.col)}")
      targs |> each((a) => dump_type(a, depth + 1))
    }
    TyList(inner) -> {
      emit_line(depth, "ty_list @#{int_to_string(ty.line)}:#{int_to_string(ty.col)}")
      dump_type(inner, depth + 1)
    }
    TyFn(targs, ret) -> {
      emit_line(depth, "ty_fn @#{int_to_string(ty.line)}:#{int_to_string(ty.col)}")
      targs |> each((a) => dump_type(a, depth + 1))
      dump_type(ret, depth + 1)
    }
  }
}

fn dump_decl(d: Decl, depth: Int) : Unit {
  match d {
    DFn(is_pub, name, params, opt_ret, body, line, col) -> {
      let pub_s = if is_pub { "pub " } else { "" }
      emit_line(depth, "fn #{pub_s}\"#{name}\" @#{int_to_string(line)}:#{int_to_string(col)}")
      params |> each((pm) => dump_param(pm, depth + 1))
      match opt_ret { Some(ty) -> dump_type(ty, depth + 1) None -> () }
      dump_expr(body, depth + 1)
    }
    DType(is_pub, name, tparams, body, line, col) -> {
      let pub_s = if is_pub { "pub " } else { "" }
      emit_line(depth, "type #{pub_s}\"#{name}\" @#{int_to_string(line)}:#{int_to_string(col)}")
      tparams |> each((tp) => emit_line(depth + 1, "tparam #{tp}"))
      dump_type_body(body, depth + 1)
    }
    DTest(desc, body, line, col) -> {
      emit_line(depth, "test #{desc} @#{int_to_string(line)}:#{int_to_string(col)}")
      dump_expr(body, depth + 1)
    }
    DImport(ik, line, col) -> {
      match ik {
        IkPath(path) -> emit_line(depth, "import #{path} @#{int_to_string(line)}:#{int_to_string(col)}")
        IkAlias(path, a) -> emit_line(depth, "import #{path} as #{a} @#{int_to_string(line)}:#{int_to_string(col)}")
        IkSelective(path, names) -> {
          emit_line(depth, "import #{path} @#{int_to_string(line)}:#{int_to_string(col)}")
          names |> each((n) => emit_line(depth + 1, "sel #{n}"))
        }
      }
    }
  }
}

fn dump_param(pm: Param, depth: Int) : Unit {
  emit_line(depth, "param #{pm.pname} @#{int_to_string(pm.pline)}:#{int_to_string(pm.pcol)}")
  match pm.ptype { Some(ty) -> dump_type(ty, depth + 1) None -> () }
}

fn dump_type_body(tb: TypeBody, depth: Int) : Unit {
  match tb {
    TBAlias(ty) -> {
      emit_line(depth, "ty_alias")
      dump_type(ty, depth + 1)
    }
    TBRecord(fields) -> {
      emit_line(depth, "ty_record")
      fields |> each((fd) => dump_field_decl(fd, depth + 1))
    }
    TBSum(variants) -> {
      emit_line(depth, "ty_sum")
      variants |> each((v) => dump_variant(v, depth + 1))
    }
  }
}

fn dump_field_decl(fd: FieldDecl, depth: Int) : Unit {
  match fd {
    FD(name, ty) -> {
      emit_line(depth, "field_decl #{name}")
      dump_type(ty, depth + 1)
    }
  }
}

fn dump_variant(v: Variant, depth: Int) : Unit {
  match v {
    Var(name, vargs) -> {
      emit_line(depth, "variant #{name}")
      vargs |> each((a) => dump_type(a, depth + 1))
    }
  }
}

fn dump_program(decls: [Decl]) : Unit {
  print("program")
  decls |> each((d) => dump_decl(d, 1))
}

# ====================================================================
# checker: name resolution
# ====================================================================
#
# Mirrors stage 0's `check.c`. No type inference, no exhaustiveness —
# just "every identifier is bound somewhere in scope." Top-level names
# (fns, type constructors, imported names) are pre-registered so
# forward references work. Each scope introduced by a block, match
# arm, lambda, or function body is pushed and popped as the walker
# enters and leaves. Errors accumulate into `had_error`; the driver
# returns 1 when that flag is set.

type Env = { scopes: [[String]], had_error: Bool, file: String }

fn env_new(file: String) : Env = Env { scopes: [[]], had_error: false, file: file }

fn env_push(e: Env) : Env =
  Env { scopes: [[], ...e.scopes], had_error: e.had_error, file: e.file }

fn env_pop(e: Env) : Env {
  match e.scopes {
    [_, ...rest] -> Env { scopes: rest, had_error: e.had_error, file: e.file }
    _ -> e
  }
}

fn env_add(e: Env, name: String) : Env {
  match e.scopes {
    [top, ...rest] ->
      Env { scopes: [[name, ...top], ...rest], had_error: e.had_error, file: e.file }
    _ -> e
  }
}

fn list_has(names: [String], target: String) : Bool {
  match names {
    [] -> false
    [n, ...rest] -> if n == target { true } else { list_has(rest, target) }
  }
}

fn scopes_has(scopes: [[String]], target: String) : Bool {
  match scopes {
    [] -> false
    [top, ...rest] -> if list_has(top, target) { true } else { scopes_has(rest, target) }
  }
}

fn env_has(e: Env, name: String) : Bool = scopes_has(e.scopes, name)

fn env_mark_err(e: Env) : Env =
  Env { scopes: e.scopes, had_error: true, file: e.file }

fn chk_error(e: Env, line: Int, col: Int, msg: String) : Env {
  eprint("#{e.file}:#{int_to_string(line)}:#{int_to_string(col)}: error: #{msg}")
  env_mark_err(e)
}

# ---- prelude seeding (kept in sync with stage 0's PRELUDE) ----

fn prelude_names() : [String] {
  [
    "print", "eprint", "read_file", "write_file", "read_line", "read_bytes", "args",
    "stdlib_path", "abspath",
    "exit", "panic",
    "int_to_string", "real_to_string", "string_to_int", "string_to_real",
    "int_to_real", "real_to_int",
    # libm bindings (issue #343)
    "real_sqrt", "real_cbrt", "real_exp", "real_log", "real_log2", "real_log10",
    "real_sin", "real_cos", "real_tan",
    "real_asin", "real_acos", "real_atan",
    "real_sinh", "real_cosh", "real_tanh",
    "real_signum", "real_is_nan", "real_is_inf",
    "real_pow", "real_atan2", "real_rem",
    "string_length", "string_concat", "string_concat_all", "string_join",
    "string_split", "string_contains", "char_at",
    "string_slice", "char_to_int", "int_to_char", "int_to_byte_string",
    "string_byte_at_int", "string_cp_at", "string_cp_len", "string_hash", "real_bits",
    "list_length", "list_append", "list_reverse",
    "map", "filter", "reduce", "each",
    "array_make", "array_length", "array_get", "array_set", "array_grow",
    "Some", "None", "Ok", "Err",
    # m5.x #1 — Perceus dup/drop magic names. The pass synthesises
    # `ECall(EVar("__perceus_dup"), [...])` and
    # `ECall(EVar("__perceus_drop"), [...])` after `check_program`. The
    # emitter handles them via special cases in `emit_call_expr`.
    # Listing them here keeps the resolver from rejecting them as
    # undefined and keeps the closure-capture analyser from treating
    # them as free vars to capture inside lambda bodies.
    "__perceus_dup", "__perceus_drop",
    # KIR Lane 1 (docs/kir-design.md §7.2): the in-process libLLVM
    # C-API prim names. The stage 2 compiler's `emit_native` module
    # names these; listing them here keeps stage 1's resolver from
    # rejecting them as undefined while it compiles the stage 2 bundle.
    # Stage 1 emits each as a plain `kai_<name>` call (its non-EP
    # fallback), which is the correct forwarder symbol. Stage 1 links
    # NO libLLVM and never executes these — the bootstrap chain
    # (cc-only) is untouched; the forwarders live behind `#ifdef
    # KAI_LLVM` in stage2/runtime.h and the kaic2 that USES the native
    # backend is the one built with `KAI_LLVM=1`.
    "llvm_module_new", "llvm_int64_type", "llvm_int32_type",
    "llvm_ptr_type", "llvm_void_type", "llvm_fn_type_0", "llvm_fn_type_1",
    "llvm_add_function", "llvm_append_block", "llvm_builder_new",
    "llvm_position_at_end", "llvm_const_int", "llvm_build_call_0",
    "llvm_build_call_1", "llvm_build_ret", "llvm_build_ret_void",
    "llvm_emit_object"
  ]
}

fn add_all(e: Env, names: [String]) : Env =
  reduce(names, e, (acc, n) => env_add(acc, n))

# ---- pattern bindings: walk a pattern and add its bound names ----

fn bind_pat(e: Env, pat: Pattern) : Env {
  match pat.pkind {
    PWild -> e
    PLit(_) -> e
    PBind(name) -> env_add(e, name)
    PList(pats, opt_rest) -> {
      let e1 = bind_pats_loop(e, pats)
      match opt_rest {
        Some(rname) -> env_add(e1, rname)
        None -> e1
      }
    }
    PVariant(_, subs) -> bind_pats_loop(e, subs)
    PVariantRecord(_, fields) -> bind_pfields_loop(e, fields)
    PRecord(fields) -> bind_pfields_loop(e, fields)
  }
}

fn bind_pats_loop(e: Env, ps: [Pattern]) : Env {
  match ps {
    [] -> e
    [p, ...rest] -> bind_pats_loop(bind_pat(e, p), rest)
  }
}

fn bind_pfields_loop(e: Env, fs: [PField]) : Env {
  match fs {
    [] -> e
    [pf, ...rest] -> bind_pfields_loop(bind_pfield(e, pf), rest)
  }
}

fn bind_pfield(e: Env, pf: PField) : Env {
  match pf {
    # Shorthand `{ x }` binds `x` directly; the parser already builds the
    # equivalent of `{ x: x }` so bind_pat handles both cases uniformly.
    PField(_, sub, _) -> bind_pat(e, sub)
  }
}

# m5.x #1 — collect every name a pattern would bind into the
# accumulator. Mirrors `bind_pat` above but operates on `[String]`
# instead of `Env`. Used by the perceus walker to track scope through
# `let`, match arms, and pattern-destructured stmts.
fn pat_bindings(pat: Pattern, acc: [String]) : [String] {
  match pat.pkind {
    PWild -> acc
    PLit(_) -> acc
    PBind(name) -> [name, ...acc]
    PList(pats, opt_rest) -> {
      let acc1 = pat_bindings_loop(pats, acc)
      match opt_rest {
        Some(rname) -> [rname, ...acc1]
        None -> acc1
      }
    }
    PVariant(_, subs) -> pat_bindings_loop(subs, acc)
    PVariantRecord(_, fields) -> pfield_bindings_loop(fields, acc)
    PRecord(fields) -> pfield_bindings_loop(fields, acc)
  }
}

fn pat_bindings_loop(ps: [Pattern], acc: [String]) : [String] {
  match ps {
    [] -> acc
    [p, ...rest] -> pat_bindings_loop(rest, pat_bindings(p, acc))
  }
}

fn pfield_bindings_loop(fs: [PField], acc: [String]) : [String] {
  match fs {
    [] -> acc
    [f, ...rest] -> match f {
      PField(_, sub, _) -> pfield_bindings_loop(rest, pat_bindings(sub, acc))
    }
  }
}

# ---- expression walker ----

fn chk_expr(e: Env, x: Expr) : Env {
  match x.kind {
    EInt(_)    -> e
    EReal(_)   -> e
    EBool(_)   -> e
    EChar(_)   -> e
    EStr(_, _) -> e
    EUnit      -> e
    EUnder     -> e
    EPlaceholder -> e
    EVar(name) -> {
      if env_has(e, name) { e }
      else { chk_error(e, x.line, x.col, "undefined name `#{name}`") }
    }
    ECall(f, xs) -> {
      let e1 = chk_expr(e, f)
      chk_exprs(e1, xs)
    }
    EField(base, _) -> chk_expr(e, base)
    EIndex(base, idx) -> chk_expr(chk_expr(e, base), idx)
    EBinop(_, a, b) -> chk_expr(chk_expr(e, a), b)
    EUnop(_, inner) -> chk_expr(e, inner)
    EIf(c, a, opt_b) -> {
      let e1 = chk_expr(chk_expr(e, c), a)
      match opt_b {
        Some(b) -> chk_expr(e1, b)
        None -> e1
      }
    }
    EMatch(scrut, arms) -> {
      let e1 = chk_expr(e, scrut)
      chk_arms(e1, arms)
    }
    ELambda(params, body) -> {
      let e1 = env_push(e)
      let e2 = add_params(e1, params)
      let e3 = chk_expr(e2, body)
      env_pop(e3)
    }
    ERecordLit(_, fields) -> chk_field_inits(e, fields)
    EList(elems) -> chk_list_elems(e, elems)
    ERange(a, b, opt_step) -> {
      let e1 = chk_expr(chk_expr(e, a), b)
      match opt_step { Some(s) -> chk_expr(e1, s) None -> e1 }
    }
    EBlock(stmts, opt_final) -> {
      let e1 = env_push(e)
      let e2 = chk_stmts(e1, stmts)
      let e3 = match opt_final { Some(f) -> chk_expr(e2, f) None -> e2 }
      env_pop(e3)
    }
    EPipe(a, b) -> chk_expr(chk_expr(e, a), b)
  }
}

fn chk_exprs(e: Env, xs: [Expr]) : Env {
  match xs {
    [] -> e
    [h, ...rest] -> chk_exprs(chk_expr(e, h), rest)
  }
}

fn chk_field_inits(e: Env, fs: [FieldInit]) : Env {
  match fs {
    [] -> e
    [f, ...rest] -> match f {
      FI(_, val) -> chk_field_inits(chk_expr(e, val), rest)
    }
  }
}

fn chk_list_elems(e: Env, es: [ListElem]) : Env {
  match es {
    [] -> e
    [el, ...rest] -> match el {
      ElPlain(x)  -> chk_list_elems(chk_expr(e, x), rest)
      ElSpread(x) -> chk_list_elems(chk_expr(e, x), rest)
    }
  }
}

fn chk_arms(e: Env, arms: [Arm]) : Env {
  match arms {
    [] -> e
    [a, ...rest] -> chk_arms(chk_arm(e, a), rest)
  }
}

fn chk_arm(e: Env, a: Arm) : Env {
  match a {
    Arm(pat, guard, body) -> {
      let e1 = env_push(e)
      let e2 = bind_pat(e1, pat)
      let e3 = match guard { Some(g) -> chk_expr(e2, g) None -> e2 }
      let e4 = chk_expr(e3, body)
      env_pop(e4)
    }
  }
}

fn chk_stmts(e: Env, ss: [Stmt]) : Env {
  match ss {
    [] -> e
    [s, ...rest] -> chk_stmts(chk_stmt(e, s), rest)
  }
}

fn chk_stmt(e: Env, s: Stmt) : Env {
  match s {
    SLet(pat, _, rhs) -> {
      let e1 = chk_expr(e, rhs)
      bind_pat(e1, pat)
    }
    SAssert(cond, opt_msg) -> {
      let e1 = chk_expr(e, cond)
      match opt_msg { Some(m) -> chk_expr(e1, m) None -> e1 }
    }
    SExprStmt(x) -> chk_expr(e, x)
  }
}

fn add_params(e: Env, ps: [Param]) : Env {
  match ps {
    [] -> e
    [p, ...rest] -> add_params(env_add(e, p.pname), rest)
  }
}

# ---- declaration walkers ----

fn chk_decl(e: Env, d: Decl) : Env {
  match d {
    DFn(_, _, params, _, body, _, _) -> {
      let e1 = env_push(e)
      let e2 = add_params(e1, params)
      let e3 = chk_expr(e2, body)
      env_pop(e3)
    }
    DType(_, _, _, _, _, _) -> e
    DTest(_, body, _, _) -> {
      let e1 = env_push(e)
      let e2 = chk_expr(e1, body)
      env_pop(e2)
    }
    DImport(_, _, _) -> e
  }
}

fn chk_decls(e: Env, ds: [Decl]) : Env {
  match ds {
    [] -> e
    [d, ...rest] -> chk_decls(chk_decl(e, d), rest)
  }
}

# ---- top-level pre-registration ----

fn register_decls(e: Env, ds: [Decl]) : Env {
  match ds {
    [] -> e
    [d, ...rest] -> register_decls(register_one(e, d), rest)
  }
}

fn register_one(e: Env, d: Decl) : Env {
  match d {
    DFn(_, name, _, _, _, _, _) -> env_add(e, name)
    DType(_, name, _, body, _, _) -> {
      let e1 = env_add(e, name)
      match body {
        TBSum(variants) -> register_variants_env(e1, variants)
        _ -> e1
      }
    }
    DTest(_, _, _, _) -> e
    DImport(ik, _, _) -> register_import(e, ik)
  }
}

fn register_variants_env(e: Env, vs: [Variant]) : Env {
  match vs {
    [] -> e
    [v, ...rest] -> match v {
      Var(name, _) -> register_variants_env(env_add(e, name), rest)
    }
  }
}

# For imports we add just the surface name: the last segment of the
# dotted path, the alias, or each selected name. Stage 0 does the
# same; deeper module resolution is a stage 2 concern.
fn last_segment(path: String) : String {
  last_segment_loop(path, string_length(path) - 1, string_length(path))
}

fn last_segment_loop(s: String, i: Int, end: Int) : String {
  if i < 0 { string_slice(s, 0, end) }
  else {
    match char_at(s, i) {
      Some(c) -> if c == '.' { string_slice(s, i + 1, end - i - 1) }
                 else { last_segment_loop(s, i - 1, end) }
      None -> string_slice(s, 0, end)
    }
  }
}

fn register_import(e: Env, ik: ImportKind) : Env {
  match ik {
    IkPath(path) -> env_add(e, last_segment(path))
    IkAlias(_, alias) -> env_add(e, alias)
    IkSelective(_, names) -> add_all(e, names)
  }
}

# ---- entry point ----

fn check_program(file: String, decls: [Decl]) : Int {
  let e0 = env_new(file)
  let e1 = add_all(e0, prelude_names())
  let e2 = register_decls(e1, decls)
  let e3 = chk_decls(e2, decls)
  if e3.had_error { 1 } else { 0 }
}

# ====================================================================
# emitter
# ====================================================================
#
# Produces C source that links against stage 0's runtime.h. This
# milestone (6) only covers what hello.kai needs — enough of expressions
# to emit a call, a string literal, a block body, and the top-level
# scaffolding (forward decls, thunks, int main). Subsequent milestones
# extend emit_expr to cover the rest of ExprKind.

# ---- small string helpers ----

fn cat2(a: String, b: String) : String = string_concat(a, b)
fn cat3(a: String, b: String, c: String) : String =
  string_concat(a, string_concat(b, c))
fn cat4(a: String, b: String, c: String, d: String) : String =
  string_concat(a, string_concat(b, string_concat(c, d)))
fn cat5(a: String, b: String, c: String, d: String, ee: String) : String =
  string_concat(a, string_concat(b, string_concat(c, string_concat(d, ee))))

fn concat_all(xs: [String]) : String = string_concat_all(xs)

fn join_with(xs: [String], sep: String) : String = string_join(xs, sep)

# ---- tables: user function arities, variant arities ----
#
# Stage 0 emit keeps parallel tables of user-defined function names and
# variant constructors; the ident dispatcher looks into both before
# falling back to a local. Stage 1 does the same; both tables are
# lists of sum-variant pairs.

type EFn  = EFn(String, Int)
# EVar carries name, arity, and the atom-style global variant tag.
# Tags 0..10 are reserved for builtins per docs/variant-tags.md; user
# variants start at 11 (KAI_USER_VARIANT_TAG_BASE in stage 0) and
# increment in declaration order. The tag is emitted into every
# kai_variant / kai_variant_u call; the matcher still goes through
# strcmp on the variant name today, so an out-of-convention tag
# degrades the runtime nullary/immortal cache hit-rate but does not
# affect correctness.
type EVar = EV(String, Int, Int)

fn efn_find(fns: [EFn], target: String) : Option[Int] {
  match fns {
    [] -> None
    [h, ...rest] -> match h {
      EFn(n, ar) -> if n == target { Some(ar) } else { efn_find(rest, target) }
    }
  }
}

fn evar_find(vs: [EVar], target: String) : Option[Int] {
  match vs {
    [] -> None
    [h, ...rest] -> match h {
      EV(n, ar, _) -> if n == target { Some(ar) } else { evar_find(rest, target) }
    }
  }
}

fn evar_find_tag(vs: [EVar], target: String) : Int {
  match vs {
    [] -> 0
    [h, ...rest] -> match h {
      EV(n, _, t) -> if n == target { t } else { evar_find_tag(rest, target) }
    }
  }
}

fn fn_of_decl(d: Decl) : Option[EFn] {
  match d {
    DFn(_, name, params, _, _, _, _) -> Some(EFn(name, list_length(params)))
    _ -> None
  }
}

fn register_fn_decls(decls: [Decl]) : [EFn] {
  match decls {
    [] -> []
    [d, ...rest] -> match fn_of_decl(d) {
      Some(fs) -> [fs, ...register_fn_decls(rest)]
      None -> register_fn_decls(rest)
    }
  }
}

# Builtin tags per docs/variant-tags.md. Sig*/Exited/Signaled are
# built by the C runtime; user code that pattern-matches against
# them needs the names in the table so evar_find_tag resolves to
# the reserved tag (and matchers stamp the same literal the runtime
# uses).
fn builtin_variants() : [EVar] =
  [EV("Some", 1, 0), EV("None", 0, 1), EV("Ok", 1, 2), EV("Err", 1, 3),
   EV("SigInt", 0, 4), EV("SigTerm", 0, 5), EV("SigHup", 0, 6),
   EV("SigUsr1", 0, 7), EV("SigUsr2", 0, 8),
   EV("Exited", 1, 9), EV("Signaled", 1, 10)]

# First tag handed out to a user-declared variant. Mirrors the
# KAI_USER_VARIANT_TAG_BASE constant in stage0/emit.c.
fn user_variant_tag_base() : Int = 11

fn collect_user_variants_loop(ds: [Decl], next_tag: Int, acc: [EVar]) : [EVar] {
  match ds {
    [] -> acc
    [d, ...rest] -> match d {
      DType(_, _, _, body, _, _) -> match body {
        TBSum(vs) -> {
          let n_new = list_length(vs)
          collect_user_variants_loop(rest, next_tag + n_new, vs_to_evars(vs, next_tag, acc))
        }
        _ -> collect_user_variants_loop(rest, next_tag, acc)
      }
      _ -> collect_user_variants_loop(rest, next_tag, acc)
    }
  }
}

# Acc accumulates with prepend (head-cons), so to preserve the
# declaration-order tag assignment we still pre-pend each EV but feed
# it the correct tag value `next_tag + i` for its index in `vs`.
fn vs_to_evars(vs: [Variant], next_tag: Int, acc: [EVar]) : [EVar] {
  match vs {
    [] -> acc
    [v, ...rest] -> match v {
      Var(n, tys) -> vs_to_evars(rest, next_tag + 1, [EV(n, list_length(tys), next_tag), ...acc])
    }
  }
}

fn register_variants(decls: [Decl]) : [EVar] =
  collect_user_variants_loop(decls, user_variant_tag_base(), builtin_variants())

# ---- prelude mapping for emission ----
#
# For user-facing builtins, we map to their runtime C symbol and arity.
# Stage 1 mirrors stage 0's table 1:1.

type EPrelude = EP(String, String, Int)     # kai name, c name, arity

fn prelude_table() : [EPrelude] {
  [
    EP("print",            "kai_prelude_print",            1),
    EP("eprint",           "kai_prelude_eprint",           1),
    EP("panic",            "kai_prelude_panic",            1),
    EP("exit",             "kai_prelude_exit",             1),
    EP("int_to_string",    "kai_prelude_int_to_string",    1),
    EP("real_to_string",   "kai_prelude_real_to_string",   1),
    EP("int_to_real",      "kai_prelude_int_to_real",      1),
    EP("real_to_int",      "kai_prelude_real_to_int",      1),
    # libm bindings (issue #343)
    EP("real_sqrt",        "kai_prelude_real_sqrt",        1),
    EP("real_cbrt",        "kai_prelude_real_cbrt",        1),
    EP("real_exp",         "kai_prelude_real_exp",         1),
    EP("real_log",         "kai_prelude_real_log",         1),
    EP("real_log2",        "kai_prelude_real_log2",        1),
    EP("real_log10",       "kai_prelude_real_log10",       1),
    EP("real_sin",         "kai_prelude_real_sin",         1),
    EP("real_cos",         "kai_prelude_real_cos",         1),
    EP("real_tan",         "kai_prelude_real_tan",         1),
    EP("real_asin",        "kai_prelude_real_asin",        1),
    EP("real_acos",        "kai_prelude_real_acos",        1),
    EP("real_atan",        "kai_prelude_real_atan",        1),
    EP("real_sinh",        "kai_prelude_real_sinh",        1),
    EP("real_cosh",        "kai_prelude_real_cosh",        1),
    EP("real_tanh",        "kai_prelude_real_tanh",        1),
    EP("real_signum",      "kai_prelude_real_signum",      1),
    EP("real_is_nan",      "kai_prelude_real_is_nan",      1),
    EP("real_is_inf",      "kai_prelude_real_is_inf",      1),
    EP("real_pow",         "kai_prelude_real_pow",         2),
    EP("real_atan2",       "kai_prelude_real_atan2",       2),
    EP("real_rem",         "kai_prelude_real_rem",         2),
    EP("string_length",    "kai_prelude_string_length",    1),
    EP("string_concat",    "kai_prelude_string_concat",    2),
    EP("string_concat_all","kai_prelude_string_concat_all",1),
    EP("string_join",      "kai_prelude_string_join",      2),
    EP("list_length",      "kai_prelude_list_length",      1),
    EP("list_append",      "kai_prelude_list_append",      2),
    EP("list_reverse",     "kai_prelude_list_reverse",     1),
    EP("map",              "kai_prelude_map",              2),
    EP("filter",           "kai_prelude_filter",           2),
    EP("reduce",           "kai_prelude_reduce",           3),
    EP("each",             "kai_prelude_each",             2),
    EP("args",             "kai_prelude_args",             0),
    EP("stdlib_path",      "kai_prelude_stdlib_path",      0),
    EP("abspath",          "kai_prelude_abspath",          1),
    EP("read_file",        "kai_prelude_read_file",        1),
    EP("write_file",       "kai_prelude_write_file",       2),
    EP("read_line",        "kai_prelude_read_line",        0),
    EP("read_bytes",       "kai_prelude_read_bytes",       1),
    EP("string_to_int",    "kai_prelude_string_to_int",    1),
    EP("string_to_real",   "kai_prelude_string_to_real",   1),
    EP("char_at",          "kai_prelude_char_at",          2),
    EP("string_split",     "kai_prelude_string_split",     2),
    EP("string_contains",  "kai_prelude_string_contains",  2),
    EP("string_slice",     "kai_prelude_string_slice",     3),
    EP("char_to_int",      "kai_prelude_char_to_int",      1),
    EP("int_to_char",      "kai_prelude_int_to_char",      1),
    EP("int_to_byte_string","kai_prelude_int_to_byte_string", 1),
    EP("string_byte_at_int","kai_prelude_string_byte_at_int", 2),
    EP("string_cp_at",      "kai_prelude_string_cp_at",      2),
    EP("string_cp_len",     "kai_prelude_string_cp_len",     2),
    EP("string_hash",       "kai_prelude_string_hash",       1),
    EP("real_bits",         "kai_prelude_real_bits",         1),
    EP("array_make",       "kai_prelude_array_make",       2),
    EP("array_length",     "kai_prelude_array_length",     1),
    EP("array_get",        "kai_prelude_array_get",        2),
    EP("array_set",        "kai_prelude_array_set",        3),
    EP("array_grow",       "kai_prelude_array_grow",       3)
  ]
}

fn prelude_find(target: String) : Option[EPrelude] {
  prelude_find_loop(prelude_table(), target)
}

fn prelude_find_loop(table: [EPrelude], target: String) : Option[EPrelude] {
  match table {
    [] -> None
    [ep, ...rest] -> match ep {
      EP(name, _, _) -> if name == target { Some(ep) } else { prelude_find_loop(rest, target) }
    }
  }
}

# ---- raw-prelude prims: in-process libLLVM C-API (KIR Lane 1.2) ----
#
# Stage 2 carries `TyHandle` + `emit_rprelude_call` and marshals each
# native-prim arg by its static type. Stage 1 has no types, so it
# can NOT recover the raw/boxed shape from the AST. But the prim
# signatures ARE known statically (they mirror the C forwarders under
# `#ifdef KAI_LLVM` in stage2/runtime.h), so this table hard-codes the
# per-arg marshalling that stage 2 derives from `ty_is_unboxable_t`.
#
# Without this, stage 1's `emit_named_call_lookup` fell through to its
# `kai_apply(kai_llvm_xxx, …)` closure path — the forwarder is a raw C
# fn, not a callable `KaiValue`, so the kaic2 built by kaic1 panicked
# at runtime ("attempted to call a non-callable value"). The prim names
# were registered in `prelude_names()` (resolver only) but never given
# a real emit path. This table is that path.
#
# An arg's marshalling kind:
#   AHandle — a raw LLVM C-API pointer (`void *`). It rides through a
#             stage-1 `KaiValue *` variable as an opaque pointer; pass
#             it to the forwarder VERBATIM (no box, no unbox). A handle
#             is also kept out of the Perceus dup/drop scope (it is not
#             RC-managed — see `pcs_is_rprelude_call` / `param_is_handle`).
#   AInt    — a raw `int64_t`. Stage 1 renders an Int boxed (`kai_int(…)`),
#             so unbox it at the call site with `kai_intf(…)`.
#   ABoxed  — a `KaiValue *` the forwarder reads directly (a `String`,
#             read via `->as.s.bytes`). Pass it boxed, unchanged.
type RArg = AHandle | AInt | ABoxed

# A native prim's result shape:
#   RHandle — a raw LLVM C-API pointer (or `kai_unit()` for the
#             unit-returning ops). It flows through a stage-1
#             `KaiValue *` binding kept OUT of Perceus, so it is never
#             RC-touched. Most prims.
#   RInt    — a raw `int64_t` the forwarder returns (only `emit_object`,
#             a 0/1 status). Stage 1 has no types, so unlike stage 2 it
#             does NOT box at the return boundary of `build_native_object`
#             — and the result crosses into a USER fn (`build_native_object
#             : Int`) whose `let rc = …` binding IS in Perceus scope. A
#             raw `1` parked in a `KaiValue *` would crash `kai_decref`
#             (deref of 0x1). So box it AT THE CALL SITE with `kai_int(…)`,
#             making it a real RC-free singleton Int — exactly what every
#             other `Int`-returning callee yields. (Stage 2 boxes via
#             `ufn_call_result` at the fn boundary; this is the stage-1
#             equivalent, pushed to the prim call site.)
type RRet = RHandle | RInt

# kai name, C forwarder symbol, per-arg marshalling kinds, result shape.
type RPrelude = RP(String, String, [RArg], RRet)

fn rprelude_table() : [RPrelude] {
  [
    RP("llvm_module_new",   "kai_llvm_module_new",   [ABoxed], RHandle),
    RP("llvm_int64_type",   "kai_llvm_int64_type",   [AHandle], RHandle),
    RP("llvm_int32_type",   "kai_llvm_int32_type",   [AHandle], RHandle),
    RP("llvm_ptr_type",     "kai_llvm_ptr_type",     [AHandle], RHandle),
    RP("llvm_void_type",    "kai_llvm_void_type",    [AHandle], RHandle),
    RP("llvm_fn_type_0",    "kai_llvm_fn_type_0",    [AHandle], RHandle),
    RP("llvm_fn_type_1",    "kai_llvm_fn_type_1",    [AHandle, AHandle], RHandle),
    RP("llvm_add_function", "kai_llvm_add_function", [AHandle, ABoxed, AHandle], RHandle),
    RP("llvm_append_block", "kai_llvm_append_block", [AHandle, AHandle, ABoxed], RHandle),
    RP("llvm_builder_new",  "kai_llvm_builder_new",  [AHandle], RHandle),
    RP("llvm_position_at_end", "kai_llvm_position_at_end", [AHandle, AHandle], RHandle),
    RP("llvm_const_int",    "kai_llvm_const_int",    [AHandle, AInt], RHandle),
    RP("llvm_build_call_0", "kai_llvm_build_call_0", [AHandle, AHandle, AHandle], RHandle),
    RP("llvm_build_call_1", "kai_llvm_build_call_1", [AHandle, AHandle, AHandle, AHandle], RHandle),
    RP("llvm_build_ret",    "kai_llvm_build_ret",    [AHandle, AHandle], RHandle),
    RP("llvm_build_ret_void", "kai_llvm_build_ret_void", [AHandle], RHandle),
    RP("llvm_emit_object",  "kai_llvm_emit_object",  [AHandle, ABoxed], RInt)
  ]
}

fn rprelude_find(target: String) : Option[RPrelude] =
  rprelude_find_loop(rprelude_table(), target)

fn rprelude_find_loop(table: [RPrelude], target: String) : Option[RPrelude] {
  match table {
    [] -> None
    [rp, ...rest] -> match rp {
      RP(name, _, _, _) -> if name == target { Some(rp) } else { rprelude_find_loop(rest, target) }
    }
  }
}

# Emit a raw-prelude call `cname(<marshalled args>)`. Each arg is
# rendered boxed first (the normal stage-1 path), then wrapped per its
# `RArg`: an `AInt` is unboxed with `kai_intf`, an `AHandle`/`ABoxed`
# passes through. An `RHandle` result is consumed raw (no box) — the
# binding it flows into is kept out of Perceus; an `RInt` result is
# boxed with `kai_int` so it becomes a real RC-free singleton Int.
fn emit_rprelude_call(src: String, cname: String, kinds: [RArg], ret: RRet, args_e: [Expr],
                      fns: [EFn], variants: [EVar], lams: [LamInfo], locals: [String]) : String {
  let raw_call = concat_all([cname, "(",
    join_with(emit_rprelude_args(src, args_e, kinds, fns, variants, lams, locals), ", "), ")"])
  match ret {
    RInt    -> cat3("kai_int(", raw_call, ")")
    RHandle -> raw_call
  }
}

fn emit_rprelude_args(src: String, args_e: [Expr], kinds: [RArg],
                      fns: [EFn], variants: [EVar], lams: [LamInfo], locals: [String]) : [String] {
  match args_e {
    [] -> []
    [a, ...rest] -> {
      let kind = match kinds {
        [k, ...__] -> k
        [] -> ABoxed
      }
      let krest = match kinds {
        [_, ...r] -> r
        [] -> []
      }
      let boxed = emit_expr(src, a, fns, variants, lams, locals)
      let marshalled = match kind {
        AInt   -> cat3("kai_intf(", boxed, ")")
        AHandle -> boxed
        ABoxed  -> boxed
      }
      [marshalled, ...emit_rprelude_args(src, rest, krest, fns, variants, lams, locals)]
    }
  }
}

# ---- expression emission ----

fn emit_ident_callee(name: String) : String {
  match prelude_find(name) {
    Some(ep) -> match ep { EP(_, cname, _) -> cname }
    None -> cat2("kai_", name)
  }
}

# Emit an ident used as a value (not a call target).
# `locals` is the list of names currently in lexical scope (fn params,
# captured names, SLet bindings already processed in the current
# block). When `name` is in `locals`, emit `kai_<name>` directly so the
# C scope rules pick up the local variable; otherwise fall back to
# variant / prelude / global-fn closure thunks.
#
# Without the `locals` check, a local that shadows a global fn name
# silently loses to the global — kaic1 would emit a closure pointing
# at the global, ignoring the SLet binding. See
# `project_kaic1_pattern_capture_bug.md` for the m12.6 incident that
# surfaced this.
fn emit_ident_value(name: String, fns: [EFn], variants: [EVar], locals: [String]) : String {
  if list_has(locals, name) { cat2("kai_", name) }
  else { match evar_find(variants, name) {
    Some(_) -> concat_all([
      "kai_variant_u(", int_to_string(evar_find_tag(variants, name)),
      ", \"", name, "\", 0, 0, NULL)"
    ])
    None -> match prelude_find(name) {
      Some(ep) -> match ep {
        EP(_, cname, ar) ->
          cat5("kai_closure(&_", cname, "_thunk, ", int_to_string(ar), ", 0, NULL)")
      }
      None -> match efn_find(fns, name) {
        Some(ar) ->
          cat5("kai_closure(&_kai_", name, "_thunk, ", int_to_string(ar), ", 0, NULL)")
        None -> cat2("kai_", name)
      }
    }
  } }
}

# Emit a raw string literal's *body* as a C string literal. For now this
# only handles hello-style cases: no #{...} interpolation, no \u{HHHH},
# the escapes that kaikai and C share are passed through unchanged.
# Later milestones extend this to full interpolation.
fn emit_string_lit_body(span: String) : String {
  # span includes opening and closing quotes; C literal syntax matches.
  span
}

fn binop_cname(op: String) : Option[String] {
  if op == "+" { Some("kai_op_add") }
  else if op == "-" { Some("kai_op_sub") }
  else if op == "*" { Some("kai_op_mul") }
  else if op == "/" { Some("kai_op_div") }
  else if op == "%" { Some("kai_op_mod") }
  else if op == "<" { Some("kai_op_lt") }
  else if op == ">" { Some("kai_op_gt") }
  else if op == "<=" { Some("kai_op_le") }
  else if op == ">=" { Some("kai_op_ge") }
  else if op == "==" { Some("kai_op_eq_v") }
  else if op == "!=" { Some("kai_op_ne_v") }
  else { None }
}

fn unop_cname(op: String) : Option[String] {
  if op == "-" { Some("kai_op_neg") }
  else if op == "not" { Some("kai_op_boolnot") }
  else { None }
}

fn emit_call_args(src: String, args_e: [Expr], fns: [EFn], variants: [EVar], lams: [LamInfo], locals: [String]) : String =
  join_with(map(args_e, (a) => emit_expr(src, a, fns, variants, lams, locals)), ", ")

# Build the `{.ptr = X0}, {.ptr = X1}, ...` slot-list string from a
# list of arg expressions. Stage 1 only emits boxed-args variants
# (no Phase 2 typed payload), so every slot is a pointer.
fn emit_call_args_slots(src: String, args_e: [Expr], fns: [EFn], variants: [EVar], lams: [LamInfo], locals: [String]) : String =
  join_with(map(args_e, (a) => string_concat("{.ptr = ", string_concat(emit_expr(src, a, fns, variants, lams, locals), "}"))), ", ")

# Wrap an already-rendered argument expression `arg_str` as a single
# slot literal. Used by pipe lowering where the LHS expression is
# rendered separately before the rest of the args.
fn arg_str_as_slot(arg_str: String) : String =
  string_concat("{.ptr = ", string_concat(arg_str, "}"))

# Emit a variant constructor call from a pre-rendered slot list.
# `slot_out` must already be the `{.ptr=X0}, {.ptr=X1}, ...` form.
fn emit_variant_call(name: String, n_args: Int, slot_out: String, variants: [EVar]) : String {
  let tag_str = int_to_string(evar_find_tag(variants, name))
  if n_args == 0 {
    concat_all(["kai_variant_u(", tag_str, ", \"", name, "\", 0, 0, NULL)"])
  } else {
    concat_all([
      "kai_variant_u(", tag_str, ", \"", name, "\", ", int_to_string(n_args),
      ", 0, (KaiVarSlot[]){", slot_out, "})"
    ])
  }
}

# Shared by emit_call_expr's EVar non-special branch. Picks variant /
# prelude / user-fn / closure-thunk emission from the same lookup
# chain. `locals` lets a local closure shadow a same-named top-level
# fn: the user wrote `let drop = ...; drop(x)` and the typer accepted
# it as a local read, so emit `kai_apply(kai_drop, ...)` over the
# local C variable rather than letting prelude_find / efn_find pick
# the global. Mirrors stage2's emit_named_call_lookup (m14 v1.x).
fn emit_named_call_lookup(src: String, callee: String, args_e: [Expr], call_args: String, fns: [EFn], variants: [EVar], lams: [LamInfo], locals: [String]) : String =
  if list_has(locals, callee) {
    concat_all([
      "kai_apply(kai_", callee, ", ", int_to_string(list_length(args_e)),
      ", (KaiValue *[]){", call_args, "})"
    ])
  } else { match evar_find(variants, callee) {
    Some(_) -> emit_variant_call(callee, list_length(args_e),
                                 emit_call_args_slots(src, args_e, fns, variants, lams, locals),
                                 variants)
    # KIR Lane 1.2: a native-backend C-API prim is checked BEFORE the
    # boxed `prelude_find`. Its args marshal per the static `RArg` mask
    # (a handle / String passes through, an Int is unboxed); the result
    # is consumed raw. This replaces the broken `kai_apply` closure path.
    None -> match rprelude_find(callee) {
      Some(RP(_, cname, kinds, ret)) ->
        emit_rprelude_call(src, cname, kinds, ret, args_e, fns, variants, lams, locals)
      None -> match prelude_find(callee) {
      Some(ep) -> match ep {
        EP(_, cname, _) -> cat4(cname, "(", call_args, ")")
      }
      None -> match efn_find(fns, callee) {
        Some(_) -> cat5("kai_", callee, "(", call_args, ")")
        None -> concat_all([
          "kai_apply(kai_", callee, ", ", int_to_string(list_length(args_e)),
          ", (KaiValue *[]){", call_args, "})"
        ])
      }
    }
    }
  } }

# Shared by emit_pipe_expr's EVar / ECall(EVar, _) branches. Same
# lookup chain as emit_named_call_lookup but parameterised on a
# pre-built args string (the pipe LHS is already the first argument).
# `locals` makes a local closure shadow a same-named top-level fn —
# user wrote `let take = ...; xs |> take(1)` and the local must win.
# Mirrors stage2's emit_pipe_named_lookup (m14 v1.x).
fn emit_pipe_named_lookup(src: String, callee: String, arity: Int, lhs_c: String, args_e: [Expr], args_all: String, fns: [EFn], variants: [EVar], lams: [LamInfo], locals: [String]) : String =
  if list_has(locals, callee) {
    concat_all([
      "kai_apply(kai_", callee, ", ", int_to_string(arity),
      ", (KaiValue *[]){", args_all, "})"
    ])
  } else { match evar_find(variants, callee) {
    Some(_) -> {
      let rest_slots = emit_call_args_slots(src, args_e, fns, variants, lams, locals)
      let lhs_slot = arg_str_as_slot(lhs_c)
      let slots_all = if list_length(args_e) == 0 { lhs_slot } else { cat3(lhs_slot, ", ", rest_slots) }
      emit_variant_call(callee, arity, slots_all, variants)
    }
    # KIR Lane 1.2: a native-backend prim piped into. The LHS (`lhs_c`,
    # already rendered) is the first arg; marshal it by the first `RArg`
    # and the remaining `args_e` by the rest. Handles pass through, an
    # Int LHS is unboxed. (No native prim is piped in the current walk;
    # this keeps the path sound if Parte B introduces one.)
    None -> match rprelude_find(callee) {
      Some(RP(_, cname, kinds, ret)) -> {
        let first_kind = match kinds {
          [k, ...__] -> k
          [] -> ABoxed
        }
        let rest_kinds = match kinds {
          [_, ...r] -> r
          [] -> []
        }
        let lhs_m = match first_kind { AInt -> cat3("kai_intf(", lhs_c, ")")  _ -> lhs_c }
        let rest_m = emit_rprelude_args(src, args_e, rest_kinds, fns, variants, lams, locals)
        let all_m = if list_length(args_e) == 0 { lhs_m } else { cat3(lhs_m, ", ", join_with(rest_m, ", ")) }
        let raw_call = concat_all([cname, "(", all_m, ")"])
        match ret { RInt -> cat3("kai_int(", raw_call, ")")  RHandle -> raw_call }
      }
      None -> match prelude_find(callee) {
      Some(ep) -> match ep {
        EP(_, cname, _) -> cat4(cname, "(", args_all, ")")
      }
      None -> match efn_find(fns, callee) {
        Some(_) -> cat5("kai_", callee, "(", args_all, ")")
        None -> concat_all([
          "kai_apply(kai_", callee, ", ", int_to_string(arity),
          ", (KaiValue *[]){", args_all, "})"
        ])
      }
    }
    }
  } }

fn emit_call_expr(src: String, f: Expr, args_e: [Expr], fns: [EFn], variants: [EVar], lams: [LamInfo], locals: [String]) : String {
  let call_args = emit_call_args(src, args_e, fns, variants, lams, locals)
  match f.kind {
    EVar(callee) -> {
      if tcrec_is_sentinel(callee) {
        # Issue #42: self-tail-call site planted by `tcrec_rewrite_decl`.
        # The callee carries `__kai_tcrec|<name>|<dropmask>|<p0>|<p1>|...`;
        # split, parse, and emit the rebind+goto block. The label
        # `_kai_<name>_entry` is planted by `emit_fn_body`.
        let parts = tcrec_split_pipe(callee)
        match parts {
          [_, sym, dropmask_str, ...pnames] -> {
            let dropmask = tcrec_parse_decimal(dropmask_str)
            tcrec_emit_goto(src, sym, dropmask, pnames, args_e,
                            fns, variants, lams, locals)
          }
          _ -> "kai_unit() /* tcrec: malformed sentinel */"
        }
      } else if callee == "__perceus_dup" {
        # m5.x #1 — AST-level dup, lowered to runtime `kai_incref`.
        # Inserted by `perceus_pass` around every non-last EVar read of
        # an in-scope binding.
        match args_e {
          [a] -> cat3("kai_internal_dup(", emit_expr(src, a, fns, variants, lams, locals), ")")
          _   -> "kai_unit() /* __perceus_dup: arity mismatch */"
        }
      } else if callee == "__perceus_drop" {
        # m5.x #1 — AST-level drop, lowered to runtime `kai_decref`
        # (returns Unit so the call site type-checks as KaiValue *).
        match args_e {
          [a] -> cat3("kai_internal_drop(", emit_expr(src, a, fns, variants, lams, locals), ")")
          _   -> "kai_unit() /* __perceus_drop: arity mismatch */"
        }
      } else {
        emit_named_call_lookup(src, callee, args_e, call_args, fns, variants, lams, locals)
      }
    }
    _ -> {
      let fc = emit_expr(src, f, fns, variants, lams, locals)
      concat_all([
        "kai_apply(", fc, ", ", int_to_string(list_length(args_e)),
        ", (KaiValue *[]){", call_args, "})"
      ])
    }
  }
}

fn emit_pipe_expr(src: String, lhs: Expr, rhs: Expr, fns: [EFn], variants: [EVar], lams: [LamInfo], locals: [String]) : String {
  let lhs_c = emit_expr(src, lhs, fns, variants, lams, locals)
  match rhs.kind {
    ECall(f, args_e) -> match f.kind {
      EVar(callee) -> {
        let rest_args = emit_call_args(src, args_e, fns, variants, lams, locals)
        let args_all = if list_length(args_e) == 0 { lhs_c } else { cat3(lhs_c, ", ", rest_args) }
        emit_pipe_named_lookup(src, callee, list_length(args_e) + 1, lhs_c, args_e, args_all, fns, variants, lams, locals)
      }
      _ -> {
        let fc = emit_expr(src, f, fns, variants, lams, locals)
        let rest_args = emit_call_args(src, args_e, fns, variants, lams, locals)
        let args_all = if list_length(args_e) == 0 { lhs_c } else { cat3(lhs_c, ", ", rest_args) }
        concat_all([
          "kai_apply(", fc, ", ", int_to_string(list_length(args_e) + 1),
          ", (KaiValue *[]){", args_all, "})"
        ])
      }
    }
    EVar(callee) -> emit_pipe_named_lookup(src, callee, 1, lhs_c, [], lhs_c, fns, variants, lams, locals)
    _ -> concat_all([
      "kai_apply(", emit_expr(src, rhs, fns, variants, lams, locals),
      ", 1, (KaiValue *[]){", lhs_c, "})"
    ])
  }
}

fn emit_range_expr(src: String, from: Expr, to: Expr, opt_step: Option[Expr],
                   fns: [EFn], variants: [EVar], lams: [LamInfo], locals: [String]) : String {
  let a = emit_expr(src, from, fns, variants, lams, locals)
  let b = emit_expr(src, to, fns, variants, lams, locals)
  match opt_step {
    None -> cat5("kai_range(", a, ", ", b, ")")
    Some(s) -> {
      let sc = emit_expr(src, s, fns, variants, lams, locals)
      concat_all(["kai_range_step(", a, ", ", b, ", ", sc, ")"])
    }
  }
}

# ---- list literal emission ----

fn emit_list_tail(src: String, elems: [ListElem], fns: [EFn], variants: [EVar], lams: [LamInfo], locals: [String]) : String {
  match elems {
    [] -> "kai_nil()"
    # Tail spread `[..., ...xs]`: the spread is the whole remainder.
    # Emit `kai_incref(xs)` instead of `list_append(xs, nil())` — the
    # incref preserves the ownership contract (result RC=1, source
    # untouched) that list_append provided via spine copy, but at
    # O(1) instead of O(|xs|).
    [el] -> match el {
      ElPlain(x) -> concat_all(["kai_cons(", emit_expr(src,x, fns, variants, lams, locals), ", kai_nil())"])
      ElSpread(x) -> concat_all(["kai_incref(", emit_expr(src, x, fns, variants, lams, locals), ")"])
    }
    [el, ...rest] -> match el {
      ElPlain(x) -> concat_all([
        "kai_cons(", emit_expr(src,x, fns, variants, lams, locals), ", ",
        emit_list_tail(src, rest, fns, variants, lams, locals), ")"
      ])
      ElSpread(x) -> concat_all([
        "kai_prelude_list_append(", emit_expr(src,x, fns, variants, lams, locals), ", ",
        emit_list_tail(src, rest, fns, variants, lams, locals), ")"
      ])
    }
  }
}

fn emit_list_expr(src: String, elems: [ListElem], fns: [EFn], variants: [EVar], lams: [LamInfo], locals: [String]) : String =
  emit_list_tail(src, elems, fns, variants, lams, locals)

# ---- record literal emission ----

fn emit_field_init_val(src: String, fi: FieldInit, fns: [EFn], variants: [EVar], lams: [LamInfo], locals: [String]) : String {
  match fi { FI(_, val) -> emit_expr(src,val, fns, variants, lams, locals) }
}

fn emit_field_init_name(fi: FieldInit) : String {
  match fi { FI(name, _) -> cat3("\"", name, "\"") }
}

fn emit_record_lit(src: String, fields: [FieldInit], fns: [EFn], variants: [EVar], lams: [LamInfo], locals: [String]) : String {
  let n = list_length(fields)
  let vals = join_with(map(fields, (fi) => emit_field_init_val(src, fi, fns, variants, lams, locals)), ", ")
  let names = join_with(map(fields, emit_field_init_name), ", ")
  concat_all([
    "kai_record(", int_to_string(n),
    ", (KaiValue *[]){", vals, "}, (const char *[]){", names, "})"
  ])
}

# ---- match: pattern test + bind emission ----

fn emit_pat_test(src: String, pat: Pattern, scr: String, fns: [EFn], variants: [EVar], lams: [LamInfo], locals: [String]) : String {
  match pat.pkind {
    PWild -> "1"
    PBind(_) -> "1"
    PLit(e) -> concat_all(["kai_op_eq(", scr, ", ", emit_expr(src,e, fns, variants, lams, locals), ")"])
    PList(pats, opt_rest) -> emit_pat_test_list(src, pats, opt_rest, scr, fns, variants, lams, locals)
    PVariant(name, subs) -> emit_pat_test_variant(src, name, subs, scr, fns, variants, lams, locals)
    PVariantRecord(name, fields) -> emit_pat_test_variant_record(src, name, fields, scr, fns, variants, lams, locals)
    PRecord(fields) -> emit_pat_test_record(src, fields, scr, fns, variants, lams, locals)
  }
}

fn emit_pat_test_list(src: String, pats: [Pattern], opt_rest: Option[String],
                      scr: String, fns: [EFn], variants: [EVar], lams: [LamInfo], locals: [String]) : String {
  let n_fixed = list_length(pats)
  let has_rest = match opt_rest { Some(_) -> true None -> false }
  if n_fixed == 0 and not has_rest {
    concat_all(["(", scr, " && ", scr, "->tag == KAI_NIL)"])
  } else {
    cat3("(", emit_pat_test_list_loop(src, pats, has_rest, scr, 0, n_fixed, fns, variants, lams, locals), ")")
  }
}

fn emit_pat_test_list_loop(src: String, pats: [Pattern], has_rest: Bool,
                            cur: String, i: Int, n_fixed: Int,
                            fns: [EFn], variants: [EVar], lams: [LamInfo], locals: [String]) : String {
  if i >= n_fixed {
    if has_rest { "1" }
    else { concat_all([cur, " && ", cur, "->tag == KAI_NIL"]) }
  } else {
    let head = cat2(cur, "->as.cons.head")
    let tail = cat2(cur, "->as.cons.tail")
    let pi = list_nth(pats, i)
    let head_test = emit_pat_test(src, pi, head, fns, variants, lams, locals)
    let cons_guard = concat_all([cur, " && ", cur, "->tag == KAI_CONS"])
    concat_all([
      cons_guard, " && ", head_test, " && ",
      emit_pat_test_list_loop(src, pats, has_rest, tail, i + 1, n_fixed, fns, variants, lams, locals)
    ])
  }
}

fn list_nth(xs: [Pattern], i: Int) : Pattern {
  match xs {
    [] -> mk_pat(PWild, 0, 0)
    [h, ...rest] -> if i == 0 { h } else { list_nth(rest, i - 1) }
  }
}

fn emit_pat_test_variant(src: String, name: String, subs: [Pattern],
                         scr: String, fns: [EFn], variants: [EVar], lams: [LamInfo], locals: [String]) : String {
  let base = concat_all([
    "(", scr, " && ", scr, "->tag == KAI_VARIANT && strcmp(kai_variant_name_of(",
    scr, "->variant_tag), \"", name, "\") == 0"
  ])
  cat3(base, emit_pat_test_variant_subs(src, subs, scr, 0, fns, variants, lams, locals), ")")
}

fn emit_pat_test_variant_subs(src: String, subs: [Pattern], scr: String, i: Int,
                              fns: [EFn], variants: [EVar], lams: [LamInfo], locals: [String]) : String {
  match subs {
    [] -> ""
    [sp, ...rest] -> {
      # Issue #440 — variant slot. Phase 1: pointer-only, mask=0,
      # so `.ptr` is the boxed child as before.
      let sub_scr = concat_all(["kai_var_slots(", scr, ")[", int_to_string(i), "].ptr"])
      let t = emit_pat_test(src, sp, sub_scr, fns, variants, lams, locals)
      concat_all([" && ", t, emit_pat_test_variant_subs(src, rest, scr, i + 1, fns, variants, lams, locals)])
    }
  }
}

fn emit_pat_test_record(src: String, fields: [PField], scr: String,
                        fns: [EFn], variants: [EVar], lams: [LamInfo], locals: [String]) : String {
  let base = concat_all(["(", scr, " && ", scr, "->tag == KAI_RECORD"])
  cat3(base, emit_pat_test_record_fields(src, fields, scr, fns, variants, lams, locals), ")")
}

fn emit_pat_test_record_fields(src: String, fields: [PField], scr: String,
                               fns: [EFn], variants: [EVar], lams: [LamInfo], locals: [String]) : String {
  match fields {
    [] -> ""
    [pf, ...rest] -> match pf {
      PField(name, sub, _) -> {
        # m5.x §4b: pat_test only reads — use kai_op_field_borrow so a
        # failing arm doesn't leak. emit_pat_binds further down still
        # uses the incref-ing kai_op_field; bindings own their own refs.
        let tmp = concat_all(["kai_op_field_borrow(", scr, ", \"", name, "\")"])
        let t = emit_pat_test(src, sub, tmp, fns, variants, lams, locals)
        concat_all([" && (", t, ")", emit_pat_test_record_fields(src, rest, scr, fns, variants, lams, locals)])
      }
    }
  }
}

fn emit_pat_test_variant_record(src: String, name: String, fields: [PField], scr: String,
                                 fns: [EFn], variants: [EVar], lams: [LamInfo], locals: [String]) : String {
  # Variant with record destructuring: first check variant tag, then
  # record fields are accessed via kai_op_field on the scrutinee itself
  # because the emit side stores records directly in variants.
  let base = concat_all([
    "(", scr, " && ", scr, "->tag == KAI_VARIANT && strcmp(kai_variant_name_of(",
    scr, "->variant_tag), \"", name, "\") == 0"
  ])
  cat3(base, emit_pat_test_record_fields(src, fields, scr, fns, variants, lams, locals), ")")
}

# `is_alias` = the scrutinee shares storage with its producer (variant args,
# cons head/tail). PBind emits `kai_incref(scr)` so the binding has its own
# owned reference. When false, scr is already owned (top-level _scr / _letv
# from a transferred RHS, or kai_op_field which already increfs its return) and
# the binding takes the ref directly.
fn emit_pat_binds(src: String, pat: Pattern, scr: String, is_alias: Bool,
                  fns: [EFn], variants: [EVar], lams: [LamInfo], locals: [String]) : String {
  match pat.pkind {
    PWild ->
      # #293 Phase 2.3/2.4: when the binder is wildcard and `scr` is
      # an owned (non-alias) reference (record field via kai_op_field
      # or destructuring let composite), the value would otherwise
      # leak. Drop it. For alias paths (cons head/tail, variant arg,
      # match _scr) the parent's decref reclaims it.
      if is_alias { "" }
      else { concat_all(["kai_decref(", scr, "); "]) }
    PLit(_) -> ""
    PBind(name) ->
      # #293 Phase 2.3/2.4: `_`-prefixed names are unused-by-convention.
      # Treat them as wildcards so they do not take ownership (alias
      # path) or leak the owned value (non-alias path).
      if name_is_unused(name) {
        if is_alias { "" }
        else { concat_all(["kai_decref(", scr, "); "]) }
      } else if is_alias {
        concat_all(["KaiValue *kai_", name, " = kai_incref(", scr, "); "])
      } else {
        concat_all(["KaiValue *kai_", name, " = ", scr, "; "])
      }
    PList(pats, opt_rest) -> emit_pat_binds_list(src, pats, opt_rest, scr, 0, fns, variants, lams, locals)
    PVariant(_, subs) -> emit_pat_binds_variant(src, subs, scr, 0, fns, variants, lams, locals)
    PVariantRecord(_, fields) -> emit_pat_binds_record(src, fields, scr, fns, variants, lams, locals)
    PRecord(fields) -> emit_pat_binds_record(src, fields, scr, fns, variants, lams, locals)
  }
}

fn emit_pat_binds_list(src: String, pats: [Pattern], opt_rest: Option[String],
                       cur: String, i: Int, fns: [EFn], variants: [EVar], lams: [LamInfo], locals: [String]) : String {
  match pats {
    [] -> match opt_rest {
      Some(name) -> concat_all(["KaiValue *kai_", name, " = kai_incref(", cur, "); "])
      None -> ""
    }
    [p, ...rest] -> {
      let head = cat2(cur, "->as.cons.head")
      let tail = cat2(cur, "->as.cons.tail")
      # cons.head / cons.tail are aliases of cur's storage.
      cat2(emit_pat_binds(src, p, head, true, fns, variants, lams, locals),
           emit_pat_binds_list(src, rest, opt_rest, tail, i + 1, fns, variants, lams, locals))
    }
  }
}

fn emit_pat_binds_variant(src: String, subs: [Pattern], scr: String, i: Int,
                          fns: [EFn], variants: [EVar], lams: [LamInfo], locals: [String]) : String {
  match subs {
    [] -> ""
    [sp, ...rest] -> {
      # Issue #440 — variant slot, Phase 1 pointer-only.
      let sub_scr = concat_all(["kai_var_slots(", scr, ")[", int_to_string(i), "].ptr"])
      # variant arg slot is alias of scr's storage.
      cat2(emit_pat_binds(src, sp, sub_scr, true, fns, variants, lams, locals),
           emit_pat_binds_variant(src, rest, scr, i + 1, fns, variants, lams, locals))
    }
  }
}

fn emit_pat_binds_record(src: String, fields: [PField], scr: String,
                          fns: [EFn], variants: [EVar], lams: [LamInfo], locals: [String]) : String {
  match fields {
    [] -> ""
    [pf, ...rest] -> match pf {
      PField(name, sub, _) -> {
        # #293 Phase 1.3 — when the sub-pattern destructures further
        # (PRecord/PVariant/PVariantRecord/PList), the field value
        # is an owned composite that needs an explicit drop after
        # the inner binders own their slices. Pre-fix the textual
        # `kai_op_field(scr, "name")` expansion was inlined into
        # every inner access, leaking one Record/Variant per nested
        # destructure. Lift to a uniquely-named C temp and drop it.
        # PBind/PWild/PLit sub-patterns do not need the temp because
        # their consumer (the binder itself or pat_test) reads the
        # value once.
        if pat_is_destructuring(sub) {
          let tname = concat_all(["_pf_", int_to_string(sub.line), "_",
                                    int_to_string(sub.col)])
          let inner = emit_pat_binds(src, sub, tname, true, fns, variants, lams, locals)
          cat2(
            concat_all([
              "KaiValue *", tname, " = kai_op_field(", scr, ", \"", name, "\"); ",
              inner, "kai_decref(", tname, "); "
            ]),
            emit_pat_binds_record(src, rest, scr, fns, variants, lams, locals)
          )
        } else {
          let tmp = concat_all(["kai_op_field(", scr, ", \"", name, "\")"])
          # kai_op_field returns an incref'd value; child is owned.
          cat2(emit_pat_binds(src, sub, tmp, false, fns, variants, lams, locals),
               emit_pat_binds_record(src, rest, scr, fns, variants, lams, locals))
        }
      }
    }
  }
}

fn name_is_unused(name: String) : Bool {
  # `_`-prefixed user-facing names signal "unused" by convention.
  # Excludes `__`-prefixed compiler-internal names (e.g. `__cv_*` from
  # m12.6 const-pattern desugar, `__pcs_ret` / `__perceus_*` from
  # perceus_pass) which the body still references.
  match char_at(name, 0) {
    Some(c0) -> c0 == '_' and match char_at(name, 1) {
      Some(c1) -> c1 != '_'
      None -> true
    }
    None -> false
  }
}

fn pat_is_destructuring(p: Pattern) : Bool {
  match p.pkind {
    PBind(_) -> false
    PWild -> false
    PLit(_) -> false
    PRecord(_) -> true
    PVariant(_, _) -> true
    PVariantRecord(_, _) -> true
    PList(_, _) -> true
  }
}

fn emit_match_arms(src: String, arms: [Arm], fns: [EFn], variants: [EVar], lams: [LamInfo], locals: [String]) : String =
  concat_all(map(arms, (a) => emit_match_arm(src, a, fns, variants, lams, locals)))

fn emit_match_arm(src: String, a: Arm, fns: [EFn], variants: [EVar], lams: [LamInfo], locals: [String]) : String {
  match a {
    Arm(pat, opt_guard, body) -> {
      let pt = emit_pat_test(src, pat, "_scr", fns, variants, lams, locals)
      # _scr is shared across all match arms — subsequent arms re-read
      # it after this one's pat_test/guard rejects, and a guard inside
      # this arm may consume the binding (e.g. const-pattern desugar's
      # `__cv_NAME == NAME()`). Treat as alias so PBind increfs.
      let binds = emit_pat_binds(src, pat, "_scr", true, fns, variants, lams, locals)
      let body_c = emit_expr(src,body, fns, variants, lams, locals)
      match opt_guard {
        Some(g) -> {
          let gc = emit_expr(src,g, fns, variants, lams, locals)
          concat_all([
            "    if (", pt, ") { ", binds,
            "if (kai_op_truthy(", gc, ")) { _r = ", body_c, "; break; } }\n"
          ])
        }
        None -> concat_all([
          "    if (", pt, ") { ", binds, "_r = ", body_c, "; break; }\n"
        ])
      }
    }
  }
}

fn emit_match_expr(src: String, scrut: Expr, arms: [Arm], fns: [EFn], variants: [EVar], lams: [LamInfo], locals: [String]) : String {
  let sc = emit_expr(src,scrut, fns, variants, lams, locals)
  # m5.x §4b: consume the scrutinee linearly. PBind in match arms
  # increfs each binding (Step A is_alias=true), so the bindings own
  # their own refs and `_scr` is free to be decrefed at exit. Multi-
  # read let-bound names arrive pre-wrapped in `__perceus_dup` from
  # the perceus_pass EStr + AST rewrite, so the bare-binding case is
  # always single-use by the time the match sees it.
  concat_all([
    "({ KaiValue *_scr = ", sc, "; KaiValue *_r = kai_unit(); do {\n",
    emit_match_arms(src, arms, fns, variants, lams, locals),
    "    kai_prelude_panic(kai_str(\"non-exhaustive match\"));\n",
    "} while (0); kai_decref(_scr); _r; })"
  ])
}

# ---- string interpolation ----
#
# The raw span includes quotes: either 1 quote on each side for single-
# or 3 quotes for triple. We walk the body (between the quotes) and
# split into literal / expression parts at each `#{...}` boundary, then
# chain them via kai_string_concat wrapping each expression in
# kai_to_string.

type IPart = IpLit(String, String) | IpExp(String)   # lit: body_slice, raw_literal; exp: body_slice

fn interp_is_triple(span: String) : Bool {
  let n = string_length(span)
  if n < 6 { false }
  else {
    match char_at(span, 0) {
      Some(c) -> c == '"' and match char_at(span, 1) {
        Some(c2) -> c2 == '"' and match char_at(span, 2) {
          Some(c3) -> c3 == '"'
          None -> false
        }
        None -> false
      }
      None -> false
    }
  }
}

# Walk the inner body of a string span between (start, end), accumulating
# parts. At `#{`, open a new IpExp until the balanced `}`; otherwise
# grow the current literal span.
type IScan = { parts: [IPart], lit_start: Int, i: Int }

# `st.parts` accumulates in REVERSE order here for O(1) prepend; the
# public iscan_collect entry point reverses once at the end.
fn iscan_collect_rev(span: String, end: Int, st: IScan) : [IPart] {
  if st.i >= end { finish_iscan_rev(span, end, st) }
  else {
    match char_at(span, st.i) {
      None -> finish_iscan_rev(span, end, st)
      Some(c) -> {
        let nxt = match char_at(span, st.i + 1) { Some(c2) -> c2 None -> ' ' }
        if c == '#' and nxt == '{' and st.i + 1 < end {
          let with_lit =
            if st.i > st.lit_start {
              let piece = string_slice(span, st.lit_start, st.i - st.lit_start)
              [IpLit(piece, cat3("\"", piece, "\"")), ...st.parts]
            } else { st.parts }
          let expr_start = st.i + 2
          let expr_end = iscan_expr_end(span, expr_start, end, 1)
          let expr_src = string_slice(span, expr_start, expr_end - expr_start)
          let new_parts = [IpExp(expr_src), ...with_lit]
          let next_i = if expr_end < end { expr_end + 1 } else { expr_end }
          iscan_collect_rev(span, end, IScan { parts: new_parts, lit_start: next_i, i: next_i })
        } else {
          iscan_collect_rev(span, end, IScan { parts: st.parts, lit_start: st.lit_start, i: st.i + 1 })
        }
      }
    }
  }
}

fn iscan_collect(span: String, end: Int, st: IScan) : [IPart] =
  list_reverse(iscan_collect_rev(span, end, st))

fn iscan_expr_end(span: String, i: Int, end: Int, depth: Int) : Int {
  if depth == 0 or i >= end { i }
  else {
    match char_at(span, i) {
      None -> i
      Some(c) -> {
        if c == '{' { iscan_expr_end(span, i + 1, end, depth + 1) }
        else if c == '}' {
          if depth == 1 { i }
          else { iscan_expr_end(span, i + 1, end, depth - 1) }
        }
        else { iscan_expr_end(span, i + 1, end, depth) }
      }
    }
  }
}

fn finish_iscan_rev(span: String, end: Int, st: IScan) : [IPart] {
  if st.lit_start < end {
    let piece = string_slice(span, st.lit_start, end - st.lit_start)
    [IpLit(piece, cat3("\"", piece, "\"")), ...st.parts]
  } else {
    st.parts
  }
}

fn emit_interp_parts(src: String, parts: [IPart], fns: [EFn], variants: [EVar], lams: [LamInfo], locals: [String]) : String {
  match parts {
    [] -> "kai_str(\"\")"
    [p] -> emit_interp_part(src, p, fns, variants, lams, locals)
    [p, ...rest] -> concat_all([
      "kai_string_concat(",
      emit_interp_part(src, p, fns, variants, lams, locals),
      ", ",
      emit_interp_parts(src, rest, fns, variants, lams, locals),
      ")"
    ])
  }
}

fn emit_interp_part(src: String, p: IPart, fns: [EFn], variants: [EVar], lams: [LamInfo], locals: [String]) : String {
  match p {
    IpLit(_, raw) -> cat3("kai_str(", raw, ")")
    IpExp(expr_src) -> {
      let toks = tokenize(expr_src)
      let prs = parser_new("<interp>", expr_src, toks)
      let r = parse_expr(prs)
      match r.r {
        Some(e) -> cat3("kai_to_string(", emit_expr(src,e, fns, variants, lams, locals), ")")
        None -> "kai_str(\"\")"
      }
    }
  }
}

fn emit_string_expr(src: String, span: String, is_triple: Bool, fns: [EFn], variants: [EVar], lams: [LamInfo], locals: [String]) : String {
  let n = string_length(span)
  let body_start = if is_triple { 3 } else { 1 }
  let body_end = if is_triple { n - 3 } else { n - 1 }
  # Fast path: if no `#{` appears, emit as a plain C literal.
  if not has_interp(span, body_start, body_end) {
    cat3("kai_str(", span, ")")
  } else {
    let parts = iscan_collect(span, body_end, IScan { parts: [], lit_start: body_start, i: body_start })
    emit_interp_parts(src, parts, fns, variants, lams, locals)
  }
}

fn has_interp(span: String, i: Int, end: Int) : Bool {
  if i + 1 >= end { false }
  else {
    match char_at(span, i) {
      Some(c) -> {
        if c == '#' {
          match char_at(span, i + 1) {
            Some(c2) -> if c2 == '{' { true } else { has_interp(span, i + 1, end) }
            None -> false
          }
        } else { has_interp(span, i + 1, end) }
      }
      None -> false
    }
  }
}

# ---- lambda collection + emission ----
#
# We pre-walk the program building a list of LamInfo entries; each entry
# gets a unique id and records the lambda's params, its free variables
# (its closure captures), and its body. At emit time the lambda
# expression is replaced with `kai_closure(&_kai_lam_<id>, arity,
# n_caps, captures)`; the body is emitted as a separate function later.

type LamInfo = LamInfo(Int, Int, Int, [Param], [String], Expr)

fn find_lam(lams: [LamInfo], line: Int, col: Int) : Option[LamInfo] {
  match lams {
    [] -> None
    [l, ...rest] -> match l {
      LamInfo(_, ln, cl, _, _, _) ->
        if ln == line and cl == col { Some(l) }
        else { find_lam(rest, line, col) }
    }
  }
}

# Free variables of an expression, given the lambda's own params and the
# program's globals. We skip descent into nested ELambdas (each gets its
# own capture set), and re-parse string interpolations so identifiers
# hidden inside #{...} get captured too.
fn fv_expr(x: Expr, own: [String], globals: [String], acc: [String]) : [String] {
  match x.kind {
    EInt(_)  -> acc
    EReal(_) -> acc
    EBool(_) -> acc
    EChar(_) -> acc
    EStr(span, is_triple) -> fv_interp(span, is_triple, own, globals, acc)
    EUnit -> acc
    EVar(name) -> {
      if list_has(own, name) { acc }
      else if list_has(globals, name) { acc }
      else if list_has(acc, name) { acc }
      else { [name, ...acc] }
    }
    EUnder -> acc
    EPlaceholder -> acc
    ECall(f, xs) -> fv_exprs(xs, own, globals, fv_expr(f, own, globals, acc))
    EField(base, _) -> fv_expr(base, own, globals, acc)
    EIndex(a, b) -> fv_expr(b, own, globals, fv_expr(a, own, globals, acc))
    EBinop(_, a, b) -> fv_expr(b, own, globals, fv_expr(a, own, globals, acc))
    EUnop(_, inner) -> fv_expr(inner, own, globals, acc)
    EIf(c, a, opt_b) -> {
      let acc1 = fv_expr(a, own, globals, fv_expr(c, own, globals, acc))
      match opt_b { Some(b) -> fv_expr(b, own, globals, acc1) None -> acc1 }
    }
    EMatch(scr, arms) -> fv_arms(arms, own, globals, fv_expr(scr, own, globals, acc))
    ELambda(_, _) -> acc                      # nested lambdas collect their own
    ERecordLit(_, fields) -> fv_field_inits(fields, own, globals, acc)
    EList(elems) -> fv_list_elems(elems, own, globals, acc)
    ERange(a, b, opt_step) -> {
      let acc1 = fv_expr(b, own, globals, fv_expr(a, own, globals, acc))
      match opt_step { Some(s) -> fv_expr(s, own, globals, acc1) None -> acc1 }
    }
    EBlock(stmts, opt_final) -> {
      # stage 0 bug #9: thread the scope as it grows through SLet
      # so the trailing tail expression sees the same bindings
      # the earlier statements introduced.
      let r = fv_stmts_scoped(stmts, own, globals, acc)
      match opt_final { Some(f) -> fv_expr(f, r.own, globals, r.acc) None -> r.acc }
    }
    EPipe(a, b) -> fv_expr(b, own, globals, fv_expr(a, own, globals, acc))
  }
}

fn fv_exprs(xs: [Expr], own: [String], globals: [String], acc: [String]) : [String] {
  match xs {
    [] -> acc
    [h, ...rest] -> fv_exprs(rest, own, globals, fv_expr(h, own, globals, acc))
  }
}

fn fv_arms(arms: [Arm], own: [String], globals: [String], acc: [String]) : [String] {
  match arms {
    [] -> acc
    [a, ...rest] -> match a {
      Arm(pat, opt_g, body) -> {
        # stage 0 bug #7: extend `own` with the pattern's bound
        # names so the guard and body don't treat them as free
        # vars when the arm sits inside a lambda body.
        let own1 = pat_bindings(pat, own)
        let acc1 = match opt_g { Some(g) -> fv_expr(g, own1, globals, acc) None -> acc }
        fv_arms(rest, own, globals, fv_expr(body, own1, globals, acc1))
      }
    }
  }
}

fn fv_field_inits(fs: [FieldInit], own: [String], globals: [String], acc: [String]) : [String] {
  match fs {
    [] -> acc
    [f, ...rest] -> match f {
      FI(_, val) -> fv_field_inits(rest, own, globals, fv_expr(val, own, globals, acc))
    }
  }
}

fn fv_list_elems(es: [ListElem], own: [String], globals: [String], acc: [String]) : [String] {
  match es {
    [] -> acc
    [el, ...rest] -> match el {
      ElPlain(x) -> fv_list_elems(rest, own, globals, fv_expr(x, own, globals, acc))
      ElSpread(x) -> fv_list_elems(rest, own, globals, fv_expr(x, own, globals, acc))
    }
  }
}

# stage 0 bug #9: each `SLet(pat, _, rhs)` introduces names that
# subsequent stmts (and the trailing tail of the enclosing
# EBlock) must see as locally bound, not free. Walking with a
# constant `own` set treats `let f1 = ...; let f2 = ...; f1 + f2`
# as free-vars f1/f2 inside any enclosing lambda. Thread the
# scope through stmts so each fv_expr sees the right `own`.
type FvScopedS = { own: [String], acc: [String] }

fn fv_stmts(ss: [Stmt], own: [String], globals: [String], acc: [String]) : [String] {
  fv_stmts_scoped(ss, own, globals, acc).acc
}

fn fv_stmts_scoped(ss: [Stmt], own: [String], globals: [String],
                   acc: [String]) : FvScopedS {
  match ss {
    [] -> FvScopedS { own: own, acc: acc }
    [s, ...rest] -> {
      let r = fv_stmt_scoped(s, own, globals, acc)
      fv_stmts_scoped(rest, r.own, globals, r.acc)
    }
  }
}

fn fv_stmt_scoped(s: Stmt, own: [String], globals: [String], acc: [String]) : FvScopedS {
  match s {
    SLet(pat, _, rhs) -> {
      let acc1 = fv_expr(rhs, own, globals, acc)
      FvScopedS { own: pat_bindings(pat, own), acc: acc1 }
    }
    SAssert(c, opt_m) -> {
      let acc1 = fv_expr(c, own, globals, acc)
      let acc2 = match opt_m { Some(m) -> fv_expr(m, own, globals, acc1) None -> acc1 }
      FvScopedS { own: own, acc: acc2 }
    }
    SExprStmt(x) -> FvScopedS { own: own, acc: fv_expr(x, own, globals, acc) }
  }
}

fn fv_stmt(s: Stmt, own: [String], globals: [String], acc: [String]) : [String] =
  fv_stmt_scoped(s, own, globals, acc).acc

fn fv_interp(span: String, is_triple: Bool, own: [String], globals: [String], acc: [String]) : [String] {
  let n = string_length(span)
  let body_start = if is_triple { 3 } else { 1 }
  let body_end = if is_triple { n - 3 } else { n - 1 }
  let parts = iscan_collect(span, body_end, IScan { parts: [], lit_start: body_start, i: body_start })
  fv_interp_parts(parts, own, globals, acc)
}

fn fv_interp_parts(parts: [IPart], own: [String], globals: [String], acc: [String]) : [String] {
  match parts {
    [] -> acc
    [p, ...rest] -> match p {
      IpLit(_, _) -> fv_interp_parts(rest, own, globals, acc)
      IpExp(esrc) -> {
        let toks = tokenize(esrc)
        let prs = parser_new("<interp>", esrc, toks)
        let r = parse_expr(prs)
        let acc1 = match r.r {
          Some(e) -> fv_expr(e, own, globals, acc)
          None -> acc
        }
        fv_interp_parts(rest, own, globals, acc1)
      }
    }
  }
}

# ---- lambda collection pass ----

type LamCollect = { next_id: Int, lams: [LamInfo], globals: [String] }

fn lc_new(globals: [String]) : LamCollect = LamCollect { next_id: 0, lams: [], globals: globals }

fn params_to_names(ps: [Param]) : [String] =
  map(ps, (pm) => pm.pname)

fn collect_expr(x: Expr, st: LamCollect) : LamCollect {
  match x.kind {
    EInt(_)  -> st
    EReal(_) -> st
    EBool(_) -> st
    EChar(_) -> st
    EStr(span, is_triple) -> collect_interp(span, is_triple, st)
    EUnit -> st
    EVar(_) -> st
    EUnder -> st
    EPlaceholder -> st
    ECall(f, xs) -> collect_exprs(xs, collect_expr(f, st))
    EField(base, _) -> collect_expr(base, st)
    EIndex(a, b) -> collect_expr(b, collect_expr(a, st))
    EBinop(_, a, b) -> collect_expr(b, collect_expr(a, st))
    EUnop(_, inner) -> collect_expr(inner, st)
    EIf(c, a, opt_b) -> {
      let s1 = collect_expr(a, collect_expr(c, st))
      match opt_b { Some(b) -> collect_expr(b, s1) None -> s1 }
    }
    EMatch(scr, arms) -> collect_arms(arms, collect_expr(scr, st))
    ELambda(params, body) -> {
      let id = st.next_id
      let own = params_to_names(params)
      let caps = fv_expr(body, own, st.globals, [])
      let info = LamInfo(id, x.line, x.col, params, caps, body)
      let st1 = LamCollect { next_id: id + 1, lams: [info, ...st.lams], globals: st.globals }
      collect_expr(body, st1)
    }
    ERecordLit(_, fields) -> collect_field_inits(fields, st)
    EList(elems) -> collect_list_elems(elems, st)
    ERange(a, b, opt_step) -> {
      let s1 = collect_expr(b, collect_expr(a, st))
      match opt_step { Some(s) -> collect_expr(s, s1) None -> s1 }
    }
    EBlock(stmts, opt_final) -> {
      let s1 = collect_stmts(stmts, st)
      match opt_final { Some(f) -> collect_expr(f, s1) None -> s1 }
    }
    EPipe(a, b) -> collect_expr(b, collect_expr(a, st))
  }
}

fn collect_exprs(xs: [Expr], st: LamCollect) : LamCollect {
  match xs {
    [] -> st
    [h, ...rest] -> collect_exprs(rest, collect_expr(h, st))
  }
}

fn collect_arms(arms: [Arm], st: LamCollect) : LamCollect {
  match arms {
    [] -> st
    [a, ...rest] -> match a {
      Arm(_, opt_g, body) -> {
        let s1 = match opt_g { Some(g) -> collect_expr(g, st) None -> st }
        collect_arms(rest, collect_expr(body, s1))
      }
    }
  }
}

fn collect_field_inits(fs: [FieldInit], st: LamCollect) : LamCollect {
  match fs {
    [] -> st
    [f, ...rest] -> match f {
      FI(_, val) -> collect_field_inits(rest, collect_expr(val, st))
    }
  }
}

fn collect_list_elems(es: [ListElem], st: LamCollect) : LamCollect {
  match es {
    [] -> st
    [el, ...rest] -> match el {
      ElPlain(x) -> collect_list_elems(rest, collect_expr(x, st))
      ElSpread(x) -> collect_list_elems(rest, collect_expr(x, st))
    }
  }
}

fn collect_stmts(ss: [Stmt], st: LamCollect) : LamCollect {
  match ss {
    [] -> st
    [s, ...rest] -> collect_stmts(rest, collect_stmt(s, st))
  }
}

fn collect_stmt(s: Stmt, st: LamCollect) : LamCollect {
  match s {
    SLet(_, _, rhs) -> collect_expr(rhs, st)
    SAssert(c, opt_m) -> {
      let s1 = collect_expr(c, st)
      match opt_m { Some(m) -> collect_expr(m, s1) None -> s1 }
    }
    SExprStmt(x) -> collect_expr(x, st)
  }
}

fn collect_interp(span: String, is_triple: Bool, st: LamCollect) : LamCollect {
  let n = string_length(span)
  let body_start = if is_triple { 3 } else { 1 }
  let body_end = if is_triple { n - 3 } else { n - 1 }
  let parts = iscan_collect(span, body_end, IScan { parts: [], lit_start: body_start, i: body_start })
  collect_interp_parts(parts, st)
}

fn collect_interp_parts(parts: [IPart], st: LamCollect) : LamCollect {
  match parts {
    [] -> st
    [p, ...rest] -> match p {
      IpLit(_, _) -> collect_interp_parts(rest, st)
      IpExp(esrc) -> {
        let toks = tokenize(esrc)
        let prs = parser_new("<interp>", esrc, toks)
        let r = parse_expr(prs)
        let st1 = match r.r { Some(e) -> collect_expr(e, st) None -> st }
        collect_interp_parts(rest, st1)
      }
    }
  }
}

fn collect_decl(d: Decl, st: LamCollect) : LamCollect {
  match d {
    DFn(_, _, _, _, body, _, _) -> collect_expr(body, st)
    DType(_, _, _, _, _, _) -> st
    DTest(_, body, _, _) -> collect_expr(body, st)
    DImport(_, _, _) -> st
  }
}

fn collect_decls(ds: [Decl], st: LamCollect) : LamCollect {
  match ds {
    [] -> st
    [d, ...rest] -> collect_decls(rest, collect_decl(d, st))
  }
}

# Globals: prelude names + user fn names + variant ctor names. Used as a
# cheap "this ident does not need to be captured" test.
fn efn_name(e: EFn) : String = match e { EFn(n, _) -> n }
fn evar_name(v: EVar) : String = match v { EV(n, _, _) -> n }

fn build_globals(fns: [EFn], variants: [EVar]) : [String] {
  let p = prelude_names()
  let f = map(fns, efn_name)
  let v = map(variants, evar_name)
  list_append(p, list_append(f, v))
}

# ---- lambda helper emission ----

fn emit_lam_arg_reads(params: [Param], i: Int) : String {
  match params {
    [] -> ""
    [p, ...rest] -> concat_all([
      "    KaiValue *kai_", p.pname, " = args[", int_to_string(i), "];\n",
      emit_lam_arg_reads(rest, i + 1)
    ])
  }
}

fn emit_lam_cap_reads(caps: [String], i: Int) : String {
  match caps {
    [] -> ""
    [c, ...rest] -> concat_all([
      "    KaiValue *kai_", c, " = self->as.clo.captures[", int_to_string(i), "];\n",
      emit_lam_cap_reads(rest, i + 1)
    ])
  }
}

fn emit_lam_helper(src: String, l: LamInfo, fns: [EFn], variants: [EVar], lams: [LamInfo]) : String {
  match l {
    LamInfo(id, _, _, params, caps, body) -> {
      let arg_reads = emit_lam_arg_reads(params, 0)
      let cap_reads = emit_lam_cap_reads(caps, 0)
      # Lambda body has its own scope: params + captured names. The
      # enclosing scope's locals are NOT in scope inside the lambda
      # (captures handle the explicit ones).
      let lam_locals = list_append(map(params, (p) => p.pname), caps)
      let body_c = emit_expr(src,body, fns, variants, lams, lam_locals)
      concat_all([
        "static KaiValue *_kai_lam_", int_to_string(id),
        "(KaiValue *self, KaiValue **args, int n) {\n",
        "    (void) self; (void) n;\n",
        arg_reads, cap_reads,
        "    return ", body_c, ";\n}\n\n"
      ])
    }
  }
}

fn emit_lam_helpers(src: String, lams: [LamInfo], fns: [EFn], variants: [EVar]) : String =
  concat_all(map(lams, (l) => emit_lam_helper(src, l, fns, variants, lams)))

fn emit_one_lam_forward(l: LamInfo) : String =
  match l {
    LamInfo(id, _, _, _, _, _) ->
      concat_all(["static KaiValue *_kai_lam_", int_to_string(id), "(KaiValue *, KaiValue **, int);\n"])
  }

fn emit_lam_forward_decls(lams: [LamInfo]) : String =
  concat_all(map(lams, emit_one_lam_forward))

fn emit_closure_caps(caps: [String]) : String =
  join_with(map(caps, (c) => cat2("kai_", c)), ", ")

fn emit_lambda_ref(x: Expr, fns: [EFn], variants: [EVar], lams: [LamInfo], locals: [String]) : String {
  match find_lam(lams, x.line, x.col) {
    None -> "kai_unit() /* lambda: missing info */"
    Some(l) -> match l {
      LamInfo(id, _, _, params, caps, _) -> {
        let arity = list_length(params)
        let n_caps = list_length(caps)
        if n_caps == 0 {
          concat_all([
            "kai_closure(&_kai_lam_", int_to_string(id),
            ", ", int_to_string(arity), ", 0, NULL)"
          ])
        } else {
          concat_all([
            "kai_closure(&_kai_lam_", int_to_string(id),
            ", ", int_to_string(arity), ", ", int_to_string(n_caps),
            ", (KaiValue *[]){", emit_closure_caps(caps), "})"
          ])
        }
      }
    }
  }
}

# ---- full emit_expr (with lambda support) ----

fn emit_expr(src: String, x: Expr, fns: [EFn], variants: [EVar], lams: [LamInfo], locals: [String]) : String {
  match x.kind {
    EInt(n)      -> cat3("kai_int(", int_to_string(n), "LL)")
    EReal(r)     -> cat3("kai_real(", real_to_string(r), ")")
    EBool(b)     -> if b { "kai_bool(1)" } else { "kai_bool(0)" }
    EChar(c)     -> cat3("kai_char(", int_to_string(char_to_int(c)), ")")
    EStr(span, is_triple) -> emit_string_expr(src, span, is_triple, fns, variants, lams, locals)
    EUnit        -> "kai_unit()"
    EVar(name)   -> emit_ident_value(name, fns, variants, locals)
    EUnder       -> "kai_unit() /* _ */"
    EPlaceholder -> "kai_unit() /* placeholder */"
    ECall(f, args_e) -> emit_call_expr(src, f, args_e, fns, variants, lams, locals)
    EField(base, fname) -> {
      # #293 Phase 1.2 — record field access RC discipline.
      # `base` is owned by the time it lands here: perceus_pass wraps
      # non-last reads of in-scope EVar in __perceus_dup, single-use
      # reads transfer their ref, and ctor/call expressions return
      # rc=1. `kai_op_field` increfs the field on read, so the base
      # is no longer reachable through the result. Drop it to balance.
      let b = emit_expr(src, base, fns, variants, lams, locals)
      concat_all([
        "({ KaiValue *_b = ", b,
        "; KaiValue *_f = kai_op_field(_b, \"", fname, "\"); kai_decref(_b); _f; })"
      ])
    }
    EIndex(_, _) -> "kai_unit() /* index: not used by bootstrap examples */"
    EBinop(op, a, b) -> {
      if op == "and" {
        # Issue #82: capture lhs in `_a`, ternary into a fresh `_r`,
        # then drop `_a` before returning. The C ternary never returns
        # `_a` itself (truthy path → fresh RHS, falsy path → fresh
        # `kai_bool(0)`), so the decref is safe and balances the fresh
        # allocation that fed `kai_op_truthy`.
        concat_all([
          "({ KaiValue *_a = ", emit_expr(src, a, fns, variants, lams, locals),
          "; KaiValue *_r = kai_op_truthy(_a) ? ", emit_expr(src, b, fns, variants, lams, locals),
          " : kai_bool(0); kai_decref(_a); _r; })"
        ])
      } else if op == "or" {
        # Issue #82: same shape as `and`. Truthy path returns a fresh
        # `kai_bool(1)`, falsy path returns the fresh RHS — `_a` is
        # never aliased into the result, so dropping it is safe.
        concat_all([
          "({ KaiValue *_a = ", emit_expr(src, a, fns, variants, lams, locals),
          "; KaiValue *_r = kai_op_truthy(_a) ? kai_bool(1) : ", emit_expr(src, b, fns, variants, lams, locals), "; kai_decref(_a); _r; })"
        ])
      } else {
        match binop_cname(op) {
          Some(cn) -> concat_all([
            cn, "(",
            emit_expr(src, a, fns, variants, lams, locals), ", ",
            emit_expr(src, b, fns, variants, lams, locals), ")"
          ])
          None -> cat3("kai_unit() /* unknown binop: ", op, " */")
        }
      }
    }
    EUnop(op, inner) -> {
      match unop_cname(op) {
        Some(cn) -> concat_all([cn, "(", emit_expr(src, inner, fns, variants, lams, locals), ")"])
        None -> cat3("kai_unit() /* unknown unop: ", op, " */")
      }
    }
    EIf(c, a, opt_b) -> {
      # Issue #82: capture cond in `_c`, decref after the ternary.
      # `kai_op_truthy` is non-consuming (intentional, see
      # docs/perceus-honesty-targets.md), so without this drop the
      # fresh cond expression leaked one ref per `if`. The branches
      # return their own fresh values — `_c` is never aliased — so
      # the decref is safe.
      let cb = emit_expr(src, c, fns, variants, lams, locals)
      let tc = emit_expr(src, a, fns, variants, lams, locals)
      let ec = match opt_b {
        Some(eb) -> emit_expr(src, eb, fns, variants, lams, locals)
        None -> "kai_unit()"
      }
      concat_all([
        "({ KaiValue *_c = ", cb,
        "; KaiValue *_r = kai_op_truthy(_c) ? ", tc, " : ", ec,
        "; kai_decref(_c); _r; })"
      ])
    }
    EMatch(scr, arms) -> emit_match_expr(src, scr, arms, fns, variants, lams, locals)
    ELambda(_, _) -> emit_lambda_ref(x, fns, variants, lams, locals)
    ERecordLit(_, fields) -> emit_record_lit(src, fields, fns, variants, lams, locals)
    EList(elems) -> emit_list_expr(src, elems, fns, variants, lams, locals)
    ERange(a, b, opt_step) -> emit_range_expr(src, a, b, opt_step, fns, variants, lams, locals)
    EBlock(stmts, opt_final) -> {
      match stmts {
        [] -> match opt_final {
          Some(fe) -> emit_expr(src, fe, fns, variants, lams, locals)
          None -> "kai_unit()"
        }
        _ -> {
          # m12.6 fix: emit stmts left-to-right, accumulating each
          # SLet binding into the locals snapshot so subsequent stmts
          # (and the final expr) see them. Without this thread, an
          # SLet that shadows a global fn would silently lose the
          # shadow at every reference downstream of the `let`.
          let acc = emit_block_stmts(src, stmts, fns, variants, lams, locals)
          let final_out = match opt_final {
            Some(fe) -> cat2(emit_expr(src, fe, fns, variants, lams, acc.locals), "; ")
            None -> "kai_unit(); "
          }
          cat4("({ ", acc.out, final_out, "})")
        }
      }
    }
    EPipe(a, b) -> emit_pipe_expr(src, a, b, fns, variants, lams, locals)
  }
}

fn emit_stmt(src: String, s: Stmt, fns: [EFn], variants: [EVar], lams: [LamInfo], locals: [String]) : String {
  match s {
    SLet(pat, _, rhs) -> emit_let_stmt(src, pat, rhs, fns, variants, lams, locals)
    SAssert(cond, opt_msg) -> emit_assert_stmt(src, cond, opt_msg, fns, variants, lams, locals)
    SExprStmt(x) -> cat3("{ KaiValue *_ = ", emit_expr(src, x, fns, variants, lams, locals), "; kai_decref(_); } ")
  }
}

# m12.6 fix: emit a sequence of stmts in a block, threading the locals
# scope through each one. Each SLet PBind extends locals before the
# next stmt is emitted; destructuring patterns extend locals with
# every name they bind. Returns both the concatenated C output and the
# final locals snapshot, which the caller hands to the block's tail
# expression so its EVar references see the bindings.
type BlockAcc = { out: String, locals: [String] }

fn emit_block_stmts(src: String, stmts: [Stmt], fns: [EFn], variants: [EVar],
                     lams: [LamInfo], locals: [String]) : BlockAcc {
  match stmts {
    [] -> BlockAcc { out: "", locals: locals }
    [s, ...rest] -> {
      let sc = emit_stmt(src, s, fns, variants, lams, locals)
      let new_locals = stmt_extends_locals(s, locals)
      let tail = emit_block_stmts(src, rest, fns, variants, lams, new_locals)
      BlockAcc { out: cat2(sc, tail.out), locals: tail.locals }
    }
  }
}

fn stmt_extends_locals(s: Stmt, locals: [String]) : [String] {
  match s {
    SLet(pat, _, _) -> pat_extends_locals(pat, locals)
    _ -> locals
  }
}

fn pat_extends_locals(pat: Pattern, locals: [String]) : [String] {
  match pat.pkind {
    PBind(name) -> if list_has(locals, name) { locals } else { [name, ...locals] }
    PWild -> locals
    PLit(_) -> locals
    PVariant(_, subs) -> pat_extends_locals_list(subs, locals)
    PVariantRecord(_, fields) -> pat_extends_locals_pfields(fields, locals)
    PRecord(fields) -> pat_extends_locals_pfields(fields, locals)
    PList(subs, opt_rest) -> {
      let l1 = pat_extends_locals_list(subs, locals)
      match opt_rest {
        Some(nm) -> if list_has(l1, nm) { l1 } else { [nm, ...l1] }
        None -> l1
      }
    }
  }
}

fn pat_extends_locals_list(pats: [Pattern], locals: [String]) : [String] {
  match pats {
    [] -> locals
    [p, ...rest] -> pat_extends_locals_list(rest, pat_extends_locals(p, locals))
  }
}

fn pat_extends_locals_pfields(fs: [PField], locals: [String]) : [String] {
  match fs {
    [] -> locals
    [pf, ...rest] -> match pf {
      PField(_, sub, _) -> pat_extends_locals_pfields(rest, pat_extends_locals(sub, locals))
    }
  }
}

fn emit_let_stmt(src: String, pat: Pattern, rhs: Expr, fns: [EFn], variants: [EVar], lams: [LamInfo], locals: [String]) : String {
  let rhs_c = emit_expr(src, rhs, fns, variants, lams, locals)
  match pat.pkind {
    PBind(name) -> concat_all(["KaiValue *kai_", name, " = ", rhs_c, "; "])
    PWild -> cat3("{ KaiValue *_w = ", rhs_c, "; kai_decref(_w); } ")
    _ -> {
      # Destructuring let: bind a temp, then run pattern binds.
      # `_letv` holds the RHS's owned ref. With is_alias=false, PBind
      # transfers raw and `kai_op_field` increfs each child, so each
      # binder owns its own ref. The composite `_letv` is no longer
      # reachable — drop it (#293 Phase 1.3) so its alloc balances.
      let binds = emit_pat_binds(src, pat, "_letv", true, fns, variants, lams, locals)
      concat_all(["{ KaiValue *_letv = ", rhs_c, "; ", binds, "kai_decref(_letv); } "])
    }
  }
}

fn emit_assert_stmt(src: String, cond: Expr, opt_msg: Option[Expr],
                    fns: [EFn], variants: [EVar], lams: [LamInfo], locals: [String]) : String {
  # kai_assert_check consults kai_test_in_progress at runtime and either
  # aborts (outside a test) or longjmps to the test harness (inside one),
  # so the emitter doesn't need to know whether it's in test mode.
  # `opt_msg` is ignored for now — we always pass the generic string,
  # matching stage 0's out-of-test panic path.
  let cc = emit_expr(src, cond, fns, variants, lams, locals)
  concat_all(["kai_assert_check(", cc, ", \"assertion failed\"); "])
}

# ---- declaration emission ----

fn emit_param_list(params: [Param]) : String {
  match params {
    [] -> "void"
    _ -> join_with(map(params, (pm) => cat2("KaiValue *kai_", pm.pname)), ", ")
  }
}

fn emit_fn_signature(name: String, params: [Param]) : String =
  cat5("static KaiValue *kai_", name, "(", emit_param_list(params), ")")

fn emit_fn_forward(d: Decl) : String {
  match d {
    DFn(_, name, params, _, _, _, _) -> cat2(emit_fn_signature(name, params), ";\n")
    _ -> ""
  }
}

fn emit_thunk_forward(d: Decl) : String {
  match d {
    DFn(_, name, _, _, _, _, _) ->
      cat3("static KaiValue *_kai_", name, "_thunk(KaiValue *, KaiValue **, int);\n")
    _ -> ""
  }
}

fn emit_fn_body(src: String, d: Decl, fns: [EFn], variants: [EVar], lams: [LamInfo]) : String {
  match d {
    DFn(_, name, params, _, body, _, _) -> {
      let sig = emit_fn_signature(name, params)
      # m12.6 fix: locals starts with the fn's params so any
      # subsequent SLet binding that shadows a global fn name
      # (or the params themselves do) resolves to the local kai_<name>
      # in C scope rather than re-emitting a closure thunk.
      let init_locals = map(params, (p) => p.pname)
      let body_c = emit_expr(src, body, fns, variants, lams, init_locals)
      # Issue #42: when `tcrec_rewrite_decl` planted at least one
      # `__kai_tcrec|...` self-tail-call sentinel inside `body`,
      # plant the matching `_kai_<name>_entry:;` label *before*
      # `return ({ ... });` so the goto inside the statement-
      # expression has a target.
      let label = if tcrec_body_has_sentinel(body) {
        concat_all(["_kai_", name, "_entry:;\n    "])
      } else { "" }
      # Lane DIAG (#293) — kaikai-source attribution. Set
      # `kai_current_scope_fn` at the top of every emitted body so
      # every chunk allocated inside this fn (or any fn it calls
      # before the callee in turn sets its own scope) gets credited
      # to this name in the leak-attribution dump. Gated in C —
      # vanilla builds emit nothing, KAI_TRACE_RC_LEAKSITE builds
      # emit the call.
      let scope_hook = concat_all([
        "#ifdef KAI_TRACE_RC_LEAKSITE\n    kai_set_scope_fn(\"",
        name,
        "\");\n#endif\n    "
      ])
      concat_all([sig, " {\n    ", scope_hook, label, "return ", body_c, ";\n}\n\n"])
    }
    _ -> ""
  }
}

fn emit_param_args(params: [Param]) : String =
  join_with(map(params, (pm) => cat2("kai_", pm.pname)), ", ")

fn emit_param_reads(params: [Param], start: Int) : String {
  match params {
    [] -> ""
    [p, ...rest] ->
      cat2(
        concat_all(["    KaiValue *kai_", p.pname, " = args[", int_to_string(start), "];\n"]),
        emit_param_reads(rest, start + 1))
  }
}

fn emit_fn_thunk(d: Decl) : String {
  match d {
    DFn(_, name, params, _, _, _, _) -> {
      let param_reads = emit_param_reads(params, 0)
      let named_args = emit_param_args(params)
      let hdr = concat_all([
        "static KaiValue *_kai_", name,
        "_thunk(KaiValue *self, KaiValue **args, int n) {\n    (void) self; (void) n;\n"
      ])
      let call = concat_all(["    return kai_", name, "(", named_args, ");\n}\n\n"])
      concat_all([hdr, param_reads, call])
    }
    _ -> ""
  }
}

# ---- top-level passes ----

fn fn_forward_decls(decls: [Decl]) : String =
  concat_all(map(decls, emit_fn_forward))

fn thunk_forward_decls(decls: [Decl]) : String =
  concat_all(map(decls, emit_thunk_forward))

fn fn_bodies(src: String, decls: [Decl], fns: [EFn], variants: [EVar], lams: [LamInfo]) : String =
  concat_all(map(decls, (d) => {
    match d {
      DFn(_, _, _, _, _, _, _) -> cat2(emit_fn_body(src, d, fns, variants, lams), emit_fn_thunk(d))
      _ -> ""
    }
  }))

# ---- test function emission (always emitted; only called from int main
#      when test_mode is on) ----

fn emit_test_fn(src: String, id: Int, desc_span: String, body: Expr,
                fns: [EFn], variants: [EVar], lams: [LamInfo], locals: [String]) : String {
  # desc_span is the raw source of the description including its quotes,
  # so it's already a valid C string literal. We wrap the body in
  # setjmp/longjmp: kai_assert_check inside the body can longjmp us out
  # on failure, and the test still counts as a tried test.
  let body_c = emit_expr(src, body, fns, variants, lams, locals)
  concat_all([
    "static void _kai_test_", int_to_string(id), "(void) {\n",
    "    kai_test_begin(", desc_span, ");\n",
    "    if (setjmp(kai_test_jmp) == 0) {\n",
    "        kai_test_in_progress = 1;\n",
    "        KaiValue *_body = ", body_c, ";\n",
    "        kai_decref(_body);\n",
    "        kai_test_in_progress = 0;\n",
    "        kai_test_pass();\n",
    "    } else {\n",
    "        kai_test_in_progress = 0;\n",
    "    }\n",
    "}\n\n"
  ])
}

fn test_decls(decls: [Decl]) : [Decl] =
  filter(decls, (d) => match d { DTest(_, _, _, _) -> true _ -> false })

fn emit_one_test(src: String, fns: [EFn], variants: [EVar], lams: [LamInfo],
                 id_d: DeclWithId) : String {
  match id_d {
    DWI(id, d) -> match d {
      DTest(desc_span, body, _, _) -> emit_test_fn(src, id, desc_span, body, fns, variants, lams, [])
      _ -> ""
    }
  }
}

# Helper pair to zip index with decl for clean iteration.
type DeclWithId = DWI(Int, Decl)

fn number_tests_loop(decls: [Decl], id: Int, acc: [DeclWithId]) : [DeclWithId] {
  match decls {
    [] -> list_reverse(acc)
    [d, ...rest] -> match d {
      DTest(_, _, _, _) -> number_tests_loop(rest, id + 1, [DWI(id, d), ...acc])
      _ -> number_tests_loop(rest, id, acc)
    }
  }
}

fn number_tests(decls: [Decl]) : [DeclWithId] =
  number_tests_loop(decls, 0, [])

fn emit_all_tests(src: String, decls: [Decl], fns: [EFn], variants: [EVar], lams: [LamInfo]) : String {
  let numbered = number_tests(decls)
  concat_all(map(numbered, (dwi) => emit_one_test(src, fns, variants, lams, dwi)))
}

fn test_count(decls: [Decl]) : Int = list_length(test_decls(decls))

fn test_call_list(n: Int, i: Int) : String {
  if i >= n { "" }
  else {
    concat_all(["    _kai_test_", int_to_string(i), "();\n", test_call_list(n, i + 1)])
  }
}

fn has_main_decl(decls: [Decl]) : Bool {
  match decls {
    [] -> false
    [d, ...rest] -> match d {
      DFn(_, n, _, _, _, _, _) -> if n == "main" { true } else { has_main_decl(rest) }
      _ -> has_main_decl(rest)
    }
  }
}

fn emit_main_wrapper(decls: [Decl], test_mode: Bool) : String {
  if test_mode {
    let n = test_count(decls)
    concat_all([
      "int main(int argc, char **argv) {\n",
      "    kai_set_args(argc, argv);\n",
      test_call_list(n, 0),
      "    return kai_test_summary();\n",
      "}\n"
    ])
  } else if has_main_decl(decls) {
    "int main(int argc, char **argv) {\n    kai_set_args(argc, argv);\n    KaiValue *_result = kai_main();\n    kai_decref(_result);\n    return 0;\n}\n"
  } else {
    ""
  }
}

# ====================================================================
# perceus pass (m5.x #1)
# ====================================================================
#
# Mirror of `perceus_pass` in stage 2 (`stage2/compiler.kai`).
# Sits between `check_program` and `emit_program` in the pipeline.
# Walks every `DFn` body twice:
#   1. `pcs_collect_uses_expr` — accumulates `[Use]` for every EVar
#      whose name is currently in scope (params + lets + match
#      pattern bindings + lambda params). The `in_lam` flag flips on
#      entry to a lambda body so reads inside a closure are flagged
#      as captures.
#   2. `pcs_rewrite_expr` — reconstructs the body, wrapping every
#      non-last in-scope EVar in `ECall(EVar("__perceus_dup"), [...])`.
#      The last read sees no wrap, transferring its reference per
#      Koka's Perceus model. Closure captures always wrap (in_lam set).
# Then `pcs_prepend_unused_drops` wraps the body in `EBlock` to drop
# every parameter whose `pcs_last_use_for` is `LUUnused`.
#
# Together with the runtime primitive consumption flip (sub-phase 2),
# this produces a coherent linear discipline: every binding is
# transferred at exactly one position; non-last reads bump the rc via
# dup; unused params drop at body entry.
#
# Stage 1 differs from stage 2: no `EHandle`, no `EBang`, no `SVar`,
# no `SIndexAssign`. The walker is correspondingly simpler.

type Use = U(String, Int, Int, Bool)   # name, line, col, in_lambda

type LU
  = LUAt(String, Int, Int)             # last-use position
  | LUBlocked(String)                  # closure capture blocks last
  | LUUnused(String)                   # never referenced

fn perceus_pass(decls: [Decl]) : [Decl] = map(decls, perceus_decl)

# KIR Lane 1.2: a binding holding an LLVM C-API handle (`TyHandle` in
# stage 2) is NOT RC-managed — it parks a raw `void *` in a stage-1
# `KaiValue *` slot, and `kai_incref`/`kai_decref` on it would deref a
# raw LLVM pointer (corruption). Stage 2 keeps handles out of Perceus
# via `rhs.mode == MUnboxed`; stage 1 has no modes, so it recovers the
# same set SYNTACTICALLY: a param annotated `: Handle`, or a `let` whose
# RHS is a call to a handle-returning native prim. Such names never
# enter the Perceus scope, so they are never wrapped in `__perceus_dup`
# nor dropped — exactly the non-RC discipline a handle needs.
#
# `RInt`-returning prims (only `emit_object`) are NOT excluded: their
# result is boxed at the call site (`kai_int(…)`), so it is a real Int
# and rides the normal RC path.
#
# CAUTION (the dangerous edge): this recovers handle-ness from SYNTAX,
# not types. A handle that flows through an unannotated intermediate
# `let h = some_user_fn()` (where the user fn returns `Handle`) would be
# MISSED — it would re-enter Perceus and corrupt. The current native
# walk (`emit_native.kai`, `main -> 42`) has NO such case: every handle
# is either a `: Handle` param or a direct native-prim `let`. Parte B
# must extend this to track user fns returning `Handle` before any such
# flow is introduced; until then this is sound by construction here.
fn param_is_handle(p: Param) : Bool = match p.ptype {
  Some(te) -> match te.tkind {
    TyName(n, args) -> n == "Handle" and list_length(args) == 0
    _ -> false
  }
  None -> false
}

# True iff `rhs` is a direct call to a handle-returning native prim.
# A `let` whose RHS is this — and a `: Handle` param — are the two
# handle binders excluded from Perceus (see `perceus_decl`). The walk
# (`pcs_block_loop` / `pcs_rewrite_block`) consults this at each `SLet`
# so the bound name never enters scope.
fn pcs_rhs_is_handle_prim(rhs: Expr) : Bool = match rhs.kind {
  ECall(f, _) -> match f.kind {
    EVar(callee) -> match rprelude_find(callee) {
      Some(RP(_, _, _, RHandle)) -> true
      _ -> false
    }
    _ -> false
  }
  _ -> false
}

fn perceus_decl(d: Decl) : Decl {
  match d {
    DFn(is_pub, name, params, opt_ret, body, ln, cl) -> {
      # KIR Lane 1.2: a `: Handle` param is a raw non-RC pointer, so keep
      # it out of the Perceus scope (never dup'd, never dropped). Handle
      # *lets* are excluded inside the walk at their `SLet` (see
      # `pcs_block_loop` / `pcs_rewrite_block`); params are excluded here.
      let rc_params = filter(params, (p) => not param_is_handle(p))
      let pnames = map(rc_params, (p) => p.pname)
      let uses = pcs_collect_uses_expr(body, pnames, false, [])
      let new_body = pcs_rewrite_expr(body, pnames, uses, false)
      let body_with_drops = pcs_prepend_unused_drops(new_body, rc_params, uses)
      DFn(is_pub, name, params, opt_ret, body_with_drops, ln, cl)
    }
    # Test bodies are emitted as their own thunk fns; without rewriting
    # them here, multi-use let-bindings inside test bodies (especially
    # ones captured by closures) skip the dup pass and the closure body
    # double-consumes its captures under the linear runtime. No params
    # to drop, but the dup walker is still needed for in-body multi-use
    # bindings.
    DTest(desc, body, ln, cl) -> {
      let uses = pcs_collect_uses_expr(body, [], false, [])
      let new_body = pcs_rewrite_expr(body, [], uses, false)
      DTest(desc, new_body, ln, cl)
    }
    _ -> d
  }
}

# ---- pcs_collect_uses: scope-tracking EVar collection ----

fn pcs_collect_uses_expr(e: Expr, scope: [String], in_lam: Bool, acc: [Use]) : [Use] =
  pcs_collect_uses_kind(e.kind, e.line, e.col, scope, in_lam, acc)

fn pcs_collect_uses_kind(k: ExprKind, line: Int, col: Int, scope: [String],
                         in_lam: Bool, acc: [Use]) : [Use] {
  match k {
    EVar(nm) -> if list_has(scope, nm) { [U(nm, line, col, in_lam), ...acc] } else { acc }
    EStr(span, is_triple) -> pcs_collect_uses_in_interp(span, is_triple, scope, in_lam, acc)
    ECall(f, xs) -> pcs_collect_uses_in_exprs(xs, scope, in_lam,
                       pcs_collect_uses_expr(f, scope, in_lam, acc))
    EField(x, _) -> pcs_collect_uses_expr(x, scope, in_lam, acc)
    EIndex(x, i) -> pcs_collect_uses_expr(i, scope, in_lam,
                       pcs_collect_uses_expr(x, scope, in_lam, acc))
    EBinop(_, l, r) -> pcs_collect_uses_expr(r, scope, in_lam,
                          pcs_collect_uses_expr(l, scope, in_lam, acc))
    EUnop(_, x) -> pcs_collect_uses_expr(x, scope, in_lam, acc)
    EIf(c, t, opt_e) -> {
      let a1 = pcs_collect_uses_expr(c, scope, in_lam, acc)
      let a2 = pcs_collect_uses_expr(t, scope, in_lam, a1)
      match opt_e {
        None -> a2
        Some(e2) -> pcs_collect_uses_expr(e2, scope, in_lam, a2)
      }
    }
    EMatch(s, arms) -> pcs_collect_uses_in_arms(arms, scope, in_lam,
                          pcs_collect_uses_expr(s, scope, in_lam, acc))
    ELambda(ps, body) -> {
      let pn = map(ps, (p) => p.pname)
      pcs_collect_uses_expr(body, list_append(scope, pn), true, acc)
    }
    ERecordLit(_, fis) -> pcs_collect_uses_in_field_inits(fis, scope, in_lam, acc)
    EList(elems) -> pcs_collect_uses_in_list_elems(elems, scope, in_lam, acc)
    ERange(lo, hi, opt_by) -> {
      let a1 = pcs_collect_uses_expr(lo, scope, in_lam, acc)
      let a2 = pcs_collect_uses_expr(hi, scope, in_lam, a1)
      match opt_by {
        None -> a2
        Some(e2) -> pcs_collect_uses_expr(e2, scope, in_lam, a2)
      }
    }
    EBlock(stmts, opt_tail) -> pcs_collect_uses_in_block(stmts, opt_tail, scope, in_lam, acc)
    EPipe(l, r) -> pcs_collect_uses_expr(r, scope, in_lam,
                      pcs_collect_uses_expr(l, scope, in_lam, acc))
    _ -> acc
  }
}

fn pcs_collect_uses_in_exprs(es: [Expr], scope: [String], in_lam: Bool, acc: [Use]) : [Use] {
  match es {
    [] -> acc
    [h, ...rest] -> pcs_collect_uses_in_exprs(rest, scope, in_lam,
                       pcs_collect_uses_expr(h, scope, in_lam, acc))
  }
}

fn pcs_collect_uses_in_arms(arms: [Arm], scope: [String], in_lam: Bool, acc: [Use]) : [Use] {
  match arms {
    [] -> acc
    [a, ...rest] -> match a {
      Arm(pat, opt_g, body) -> {
        let scope1 = pat_bindings(pat, scope)
        let a1 = match opt_g {
          None -> acc
          Some(g) -> pcs_collect_uses_expr(g, scope1, in_lam, acc)
        }
        let a2 = pcs_collect_uses_expr(body, scope1, in_lam, a1)
        pcs_collect_uses_in_arms(rest, scope, in_lam, a2)
      }
    }
  }
}

fn pcs_collect_uses_in_field_inits(fis: [FieldInit], scope: [String],
                                    in_lam: Bool, acc: [Use]) : [Use] {
  match fis {
    [] -> acc
    [h, ...rest] -> match h {
      FI(_, e) -> pcs_collect_uses_in_field_inits(rest, scope, in_lam,
                     pcs_collect_uses_expr(e, scope, in_lam, acc))
    }
  }
}

fn pcs_collect_uses_in_list_elems(es: [ListElem], scope: [String],
                                   in_lam: Bool, acc: [Use]) : [Use] {
  match es {
    [] -> acc
    [h, ...rest] -> {
      let inner = match h { ElPlain(e) -> e ElSpread(e) -> e }
      pcs_collect_uses_in_list_elems(rest, scope, in_lam,
        pcs_collect_uses_expr(inner, scope, in_lam, acc))
    }
  }
}

fn pcs_collect_uses_in_block(stmts: [Stmt], opt_tail: Option[Expr],
                              scope: [String], in_lam: Bool, acc: [Use]) : [Use] {
  let r = pcs_block_loop(stmts, scope, in_lam, acc)
  match opt_tail {
    None -> r.acc
    Some(e) -> pcs_collect_uses_expr(e, r.scope, in_lam, r.acc)
  }
}

type PcsBlockState = { scope: [String], acc: [Use] }

fn pcs_block_loop(stmts: [Stmt], scope: [String], in_lam: Bool,
                   acc: [Use]) : PcsBlockState {
  match stmts {
    [] -> PcsBlockState { scope: scope, acc: acc }
    [s, ...rest] -> {
      let nxt = match s {
        SLet(pat, _, rhs) -> {
          let acc1 = pcs_collect_uses_expr(rhs, scope, in_lam, acc)
          # KIR Lane 1.2: a `let h = <handle prim>(…)` binds a raw non-RC
          # handle — keep `h` out of scope so its reads are never dup'd.
          let new_scope = if pcs_rhs_is_handle_prim(rhs) { scope } else { pat_bindings(pat, scope) }
          PcsBlockState { scope: new_scope, acc: acc1 }
        }
        SAssert(c, opt_m) -> {
          let a1 = pcs_collect_uses_expr(c, scope, in_lam, acc)
          let a2 = match opt_m {
            None -> a1
            Some(m) -> pcs_collect_uses_expr(m, scope, in_lam, a1)
          }
          PcsBlockState { scope: scope, acc: a2 }
        }
        SExprStmt(e) ->
          PcsBlockState { scope: scope, acc: pcs_collect_uses_expr(e, scope, in_lam, acc) }
      }
      pcs_block_loop(rest, nxt.scope, in_lam, nxt.acc)
    }
  }
}

fn pcs_collect_uses_in_interp(span: String, is_triple: Bool, scope: [String],
                               in_lam: Bool, acc: [Use]) : [Use] {
  let n = string_length(span)
  let body_start = if is_triple { 3 } else { 1 }
  let body_end = if is_triple { n - 3 } else { n - 1 }
  let parts = iscan_collect(span, body_end,
                            IScan { parts: [], lit_start: body_start, i: body_start })
  pcs_collect_uses_interp_parts(parts, scope, in_lam, acc)
}

fn pcs_collect_uses_interp_parts(parts: [IPart], scope: [String], in_lam: Bool,
                                   acc: [Use]) : [Use] {
  match parts {
    [] -> acc
    [p, ...rest] -> match p {
      IpLit(_, _) -> pcs_collect_uses_interp_parts(rest, scope, in_lam, acc)
      IpExp(esrc) -> {
        let toks = tokenize(esrc)
        let prs = parser_new("<interp>", esrc, toks)
        let r = parse_expr(prs)
        let acc1 = match r.r {
          Some(e) -> pcs_collect_uses_expr(e, scope, in_lam, acc)
          None -> acc
        }
        pcs_collect_uses_interp_parts(rest, scope, in_lam, acc1)
      }
    }
  }
}

# ---- pcs_rewrite: wrap non-last in-scope EVar reads in __perceus_dup ----

fn pcs_rewrite_expr(e: Expr, scope: [String], uses: [Use], in_lam: Bool) : Expr =
  Expr { kind: pcs_rewrite_kind(e.kind, e.line, e.col, scope, uses, in_lam),
         line: e.line, col: e.col }

fn pcs_rewrite_kind(k: ExprKind, line: Int, col: Int, scope: [String],
                    uses: [Use], in_lam: Bool) : ExprKind {
  match k {
    EVar(nm) -> {
      if list_has(scope, nm) and pcs_is_non_last(nm, line, col, uses, in_lam) {
        ECall(
          Expr { kind: EVar("__perceus_dup"), line: line, col: col },
          [Expr { kind: EVar(nm), line: line, col: col }]
        )
      } else { EVar(nm) }
    }
    # §4b — interp bodies hide their EVar reads inside an opaque source
    # span; mirror stage 2's surgical token rewrite so the inner reads
    # also get `__perceus_dup` wraps.
    EStr(span, is_triple) -> EStr(pcs_rewrite_estr_span(span, is_triple, scope, uses, in_lam), is_triple)
    ECall(f, xs) -> ECall(pcs_rewrite_expr(f, scope, uses, in_lam),
                          pcs_rewrite_exprs(xs, scope, uses, in_lam))
    EField(x, fname) -> EField(pcs_rewrite_expr(x, scope, uses, in_lam), fname)
    EIndex(x, i) -> EIndex(pcs_rewrite_expr(x, scope, uses, in_lam),
                           pcs_rewrite_expr(i, scope, uses, in_lam))
    EBinop(op, l, r) -> EBinop(op, pcs_rewrite_expr(l, scope, uses, in_lam),
                                   pcs_rewrite_expr(r, scope, uses, in_lam))
    EUnop(op, x) -> EUnop(op, pcs_rewrite_expr(x, scope, uses, in_lam))
    EIf(c, t, opt_e) -> EIf(
      pcs_rewrite_expr(c, scope, uses, in_lam),
      pcs_rewrite_expr(t, scope, uses, in_lam),
      match opt_e {
        None -> None
        Some(e2) -> Some(pcs_rewrite_expr(e2, scope, uses, in_lam))
      }
    )
    EMatch(s, arms) -> EMatch(pcs_rewrite_expr(s, scope, uses, in_lam),
                              pcs_rewrite_arms(arms, scope, uses, in_lam))
    ELambda(ps, body) -> {
      let pn = map(ps, (p) => p.pname)
      ELambda(ps, pcs_rewrite_expr(body, list_append(scope, pn), uses, true))
    }
    ERecordLit(name, fis) -> ERecordLit(name, pcs_rewrite_field_inits(fis, scope, uses, in_lam))
    EList(elems) -> EList(pcs_rewrite_list_elems(elems, scope, uses, in_lam))
    ERange(lo, hi, opt_by) -> ERange(
      pcs_rewrite_expr(lo, scope, uses, in_lam),
      pcs_rewrite_expr(hi, scope, uses, in_lam),
      match opt_by {
        None -> None
        Some(e2) -> Some(pcs_rewrite_expr(e2, scope, uses, in_lam))
      }
    )
    EBlock(stmts, opt_tail) -> {
      let r = pcs_rewrite_block(stmts, scope, uses, in_lam, [])
      let new_tail = match opt_tail {
        None -> None
        Some(e) -> Some(pcs_rewrite_expr(e, r.scope, uses, in_lam))
      }
      # Issue #297 (partial) — block-scope exit drops for SLet PBind
      # bindings that took a `__perceus_dup` per non-last read. Mirror
      # of the stage 2 fix. Conservative: only emit a drop when the
      # binding does not appear in the block's tail (otherwise we'd
      # have to wrap the tail and lose tail-call position, breaking
      # TCO on self-tail-recursive bodies).
      let exit_drops = pcs_collect_block_let_exit_drops(stmts, scope, uses,
                                                         opt_tail, [])
      EBlock(pcs_append_drops(r.stmts, exit_drops), new_tail)
    }
    EPipe(l, r) -> EPipe(pcs_rewrite_expr(l, scope, uses, in_lam),
                          pcs_rewrite_expr(r, scope, uses, in_lam))
    _ -> k
  }
}

fn pcs_rewrite_exprs(es: [Expr], scope: [String], uses: [Use], in_lam: Bool) : [Expr] {
  match es {
    [] -> []
    [h, ...rest] -> [pcs_rewrite_expr(h, scope, uses, in_lam),
                     ...pcs_rewrite_exprs(rest, scope, uses, in_lam)]
  }
}

fn pcs_rewrite_arms(arms: [Arm], scope: [String], uses: [Use], in_lam: Bool) : [Arm] {
  match arms {
    [] -> []
    [a, ...rest] -> match a {
      Arm(pat, opt_g, body) -> {
        let scope1 = pat_bindings(pat, scope)
        let g1 = match opt_g {
          None -> None
          Some(g) -> Some(pcs_rewrite_expr(g, scope1, uses, in_lam))
        }
        let body1 = pcs_rewrite_expr(body, scope1, uses, in_lam)
        [Arm(pat, g1, body1), ...pcs_rewrite_arms(rest, scope, uses, in_lam)]
      }
    }
  }
}

fn pcs_rewrite_field_inits(fis: [FieldInit], scope: [String], uses: [Use],
                            in_lam: Bool) : [FieldInit] {
  match fis {
    [] -> []
    [h, ...rest] -> match h {
      FI(nm, e) -> [FI(nm, pcs_rewrite_expr(e, scope, uses, in_lam)),
                    ...pcs_rewrite_field_inits(rest, scope, uses, in_lam)]
    }
  }
}

fn pcs_rewrite_list_elems(es: [ListElem], scope: [String], uses: [Use],
                           in_lam: Bool) : [ListElem] {
  match es {
    [] -> []
    [h, ...rest] -> {
      let h1 = match h {
        ElPlain(e) -> ElPlain(pcs_rewrite_expr(e, scope, uses, in_lam))
        ElSpread(e) -> ElSpread(pcs_rewrite_expr(e, scope, uses, in_lam))
      }
      [h1, ...pcs_rewrite_list_elems(rest, scope, uses, in_lam)]
    }
  }
}

type PcsRwBlock = { stmts: [Stmt], scope: [String] }

fn pcs_rewrite_block(stmts: [Stmt], scope: [String], uses: [Use], in_lam: Bool,
                     acc: [Stmt]) : PcsRwBlock {
  match stmts {
    [] -> PcsRwBlock { stmts: list_reverse(acc), scope: scope }
    [s, ...rest] -> {
      let r = pcs_rewrite_stmt(s, scope, uses, in_lam)
      pcs_rewrite_block(rest, r.scope, uses, in_lam, [r.stmt, ...acc])
    }
  }
}

type PcsRwStmt = { stmt: Stmt, scope: [String] }

fn pcs_rewrite_stmt(s: Stmt, scope: [String], uses: [Use], in_lam: Bool) : PcsRwStmt {
  match s {
    SLet(pat, ty_opt, rhs) -> {
      let rhs1 = pcs_rewrite_expr(rhs, scope, uses, in_lam)
      # KIR Lane 1.2: keep a handle-prim `let` binder out of scope (must
      # match `pcs_block_loop`'s collect side, or the dup decision and
      # the scope would disagree).
      let new_scope = if pcs_rhs_is_handle_prim(rhs) { scope } else { pat_bindings(pat, scope) }
      PcsRwStmt { stmt: SLet(pat, ty_opt, rhs1), scope: new_scope }
    }
    SAssert(c, opt_m) -> {
      let c1 = pcs_rewrite_expr(c, scope, uses, in_lam)
      let m1 = match opt_m {
        None -> None
        Some(m) -> Some(pcs_rewrite_expr(m, scope, uses, in_lam))
      }
      PcsRwStmt { stmt: SAssert(c1, m1), scope: scope }
    }
    SExprStmt(e) -> {
      let e1 = pcs_rewrite_expr(e, scope, uses, in_lam)
      PcsRwStmt { stmt: SExprStmt(e1), scope: scope }
    }
  }
}

# Dup predicate (m5.x-flip Phase 1, "dup all ≥2 uses" variant). See the
# stage 2 comment for the full rationale. A name is wrapped in
# `__perceus_dup` whenever (a) the use is inside a closure body, (b)
# any in-lam use exists elsewhere (LUBlocked), or (c) the binding has
# at least 2 non-lam uses. Single-use bindings transfer raw. The
# previous "lexically-last raw" rule was unsafe under C's unspecified
# argument-evaluation order; the all-dup variant is order-independent.
fn pcs_is_non_last(nm: String, line: Int, col: Int, uses: [Use],
                   in_lam_here: Bool) : Bool {
  if in_lam_here { true }
  else {
    match last_use_for(nm, uses) {
      LUAt(_, _, _) -> pcs_count_non_lam_uses(nm, uses, 0) >= 2
      LUBlocked(_) -> true
      LUUnused(_) -> false
    }
  }
}

# Count the non-in-lambda uses of `nm` in `uses`. Lambda uses are
# accounted for separately by LUBlocked + the closure-capture incref.
fn pcs_count_non_lam_uses(nm: String, uses: [Use], acc: Int) : Int {
  match uses {
    [] -> acc
    [h, ...rest] -> match h {
      U(uname, _, _, in_lam) -> {
        if uname == nm and not in_lam {
          pcs_count_non_lam_uses(nm, rest, acc + 1)
        } else {
          pcs_count_non_lam_uses(nm, rest, acc)
        }
      }
    }
  }
}

# ---- m5.x §4b: rewrite EVar reads inside EStr interpolation bodies ----
#
# Mirror of stage 2's pcs_rewrite_estr_span. See stage2/compiler.kai
# for the strategy writeup. Stage 1 carries a smaller ExprKind surface
# (no EHandle / EBang / ELitUnit / EHole / etc.) so the dup-mark
# walker covers fewer cases.

type DupMark = DM(Int, Int)   # line, col of an EVar that needs wrapping

fn pcs_rewrite_estr_span(span: String, is_triple: Bool, scope: [String],
                          uses: [Use], in_lam: Bool) : String {
  let n = string_length(span)
  let body_start = if is_triple { 3 } else { 1 }
  let body_end = if is_triple { n - 3 } else { n - 1 }
  if not has_interp(span, body_start, body_end) { span }
  else {
    let parts = iscan_collect(span, body_end,
                  IScan { parts: [], lit_start: body_start, i: body_start })
    let new_parts = pcs_rewrite_iparts(parts, scope, uses, in_lam, [])
    let body = pcs_concat_iparts(new_parts, "")
    let prefix = if is_triple { "\"\"\"" } else { "\"" }
    concat_all([prefix, body, prefix])
  }
}

fn pcs_rewrite_iparts(parts: [IPart], scope: [String], uses: [Use],
                       in_lam: Bool, acc: [IPart]) : [IPart] {
  match parts {
    [] -> list_reverse(acc)
    [p, ...rest] -> {
      let p1 = match p {
        IpLit(_, _) -> p
        IpExp(esrc) -> IpExp(pcs_rewrite_interp_src(esrc, scope, uses, in_lam))
      }
      pcs_rewrite_iparts(rest, scope, uses, in_lam, [p1, ...acc])
    }
  }
}

fn pcs_concat_iparts(parts: [IPart], acc: String) : String {
  match parts {
    [] -> acc
    [p, ...rest] -> match p {
      IpLit(piece, _) -> pcs_concat_iparts(rest, concat_all([acc, piece]))
      # Build the `#{` opener from `"#"` + `"{"` — kaikai has no escape
      # for `#{` in literals so a single `"#{"` would lex as the start
      # of an unterminated interpolation.
      IpExp(esrc) -> pcs_concat_iparts(rest, concat_all([acc, "#", "{", esrc, "}"]))
    }
  }
}

fn pcs_rewrite_interp_src(esrc: String, scope: [String], uses: [Use],
                           in_lam: Bool) : String {
  let toks = tokenize(esrc)
  let prs = parser_new("<interp>", esrc, toks)
  let r = parse_expr(prs)
  match r.r {
    None -> esrc
    Some(parsed) -> {
      let rewritten = pcs_rewrite_expr(parsed, scope, uses, in_lam)
      let marks = pcs_dup_marks_expr(rewritten, [])
      match marks {
        [] -> esrc
        _  -> pcs_render_with_marks(esrc, toks, marks, "", 0)
      }
    }
  }
}

fn pcs_dup_marks_expr(e: Expr, acc: [DupMark]) : [DupMark] {
  let acc1 = match e.kind {
    ECall(f, xs) -> match f.kind {
      EVar(nm) -> if nm == "__perceus_dup" {
        match xs {
          [arg] -> match arg.kind {
            EVar(_) -> [DM(arg.line, arg.col), ...acc]
            _ -> acc
          }
          _ -> acc
        }
      } else { acc }
      _ -> acc
    }
    _ -> acc
  }
  pcs_dup_marks_subs(e.kind, acc1)
}

fn pcs_dup_marks_subs(k: ExprKind, acc: [DupMark]) : [DupMark] {
  match k {
    ECall(callee, args_) -> pcs_dup_marks_exprs(args_, pcs_dup_marks_expr(callee, acc))
    EField(base, _) -> pcs_dup_marks_expr(base, acc)
    EIndex(a, b) -> pcs_dup_marks_expr(b, pcs_dup_marks_expr(a, acc))
    EBinop(_, a, b) -> pcs_dup_marks_expr(b, pcs_dup_marks_expr(a, acc))
    EUnop(_, x) -> pcs_dup_marks_expr(x, acc)
    EIf(c, t_, opt_e) -> {
      let a1 = pcs_dup_marks_expr(c, acc)
      let a2 = pcs_dup_marks_expr(t_, a1)
      match opt_e {
        None -> a2
        Some(e2) -> pcs_dup_marks_expr(e2, a2)
      }
    }
    EMatch(s, arms) -> pcs_dup_marks_arms(arms, pcs_dup_marks_expr(s, acc))
    ELambda(_, body) -> pcs_dup_marks_expr(body, acc)
    ERecordLit(_, fis) -> pcs_dup_marks_field_inits(fis, acc)
    EList(es) -> pcs_dup_marks_list_elems(es, acc)
    ERange(a, b, opt_step) -> {
      let a1 = pcs_dup_marks_expr(a, acc)
      let a2 = pcs_dup_marks_expr(b, a1)
      match opt_step {
        None -> a2
        Some(s) -> pcs_dup_marks_expr(s, a2)
      }
    }
    EBlock(stmts, opt_tail) -> {
      let a1 = pcs_dup_marks_stmts(stmts, acc)
      match opt_tail {
        None -> a1
        Some(t_) -> pcs_dup_marks_expr(t_, a1)
      }
    }
    EPipe(l, r) -> pcs_dup_marks_expr(r, pcs_dup_marks_expr(l, acc))
    _ -> acc
  }
}

fn pcs_dup_marks_exprs(es: [Expr], acc: [DupMark]) : [DupMark] {
  match es {
    [] -> acc
    [h, ...rest] -> pcs_dup_marks_exprs(rest, pcs_dup_marks_expr(h, acc))
  }
}

fn pcs_dup_marks_arms(arms: [Arm], acc: [DupMark]) : [DupMark] {
  match arms {
    [] -> acc
    [a, ...rest] -> match a {
      Arm(_, opt_g, body) -> {
        let a1 = match opt_g {
          None -> acc
          Some(g) -> pcs_dup_marks_expr(g, acc)
        }
        let a2 = pcs_dup_marks_expr(body, a1)
        pcs_dup_marks_arms(rest, a2)
      }
    }
  }
}

fn pcs_dup_marks_field_inits(fis: [FieldInit], acc: [DupMark]) : [DupMark] {
  match fis {
    [] -> acc
    [h, ...rest] -> match h {
      FI(_, e) -> pcs_dup_marks_field_inits(rest, pcs_dup_marks_expr(e, acc))
    }
  }
}

fn pcs_dup_marks_list_elems(es: [ListElem], acc: [DupMark]) : [DupMark] {
  match es {
    [] -> acc
    [h, ...rest] -> {
      let inner = match h { ElPlain(e) -> e ElSpread(e) -> e }
      pcs_dup_marks_list_elems(rest, pcs_dup_marks_expr(inner, acc))
    }
  }
}

fn pcs_dup_marks_stmts(ss: [Stmt], acc: [DupMark]) : [DupMark] {
  match ss {
    [] -> acc
    [h, ...rest] -> {
      let acc1 = match h {
        SLet(_, _, rhs) -> pcs_dup_marks_expr(rhs, acc)
        SAssert(c, opt_m) -> {
          let a1 = pcs_dup_marks_expr(c, acc)
          match opt_m {
            None -> a1
            Some(m) -> pcs_dup_marks_expr(m, a1)
          }
        }
        SExprStmt(e) -> pcs_dup_marks_expr(e, acc)
      }
      pcs_dup_marks_stmts(rest, acc1)
    }
  }
}

fn pcs_dup_mark_has(marks: [DupMark], line: Int, col: Int) : Bool {
  match marks {
    [] -> false
    [h, ...rest] -> match h {
      DM(l, c) ->
        if l == line and c == col { true }
        else { pcs_dup_mark_has(rest, line, col) }
    }
  }
}

fn pcs_render_with_marks(esrc: String, toks: [Token], marks: [DupMark],
                           acc: String, prev_end: Int) : String {
  match toks {
    [] -> concat_all([acc, string_slice(esrc, prev_end, string_length(esrc) - prev_end)])
    [t, ...rest] -> match t.kind {
      TkEof -> concat_all([acc, string_slice(esrc, prev_end, string_length(esrc) - prev_end)])
      TkIdent ->
        if pcs_dup_mark_has(marks, t.line, t.col) {
          let between = string_slice(esrc, prev_end, t.start - prev_end)
          let txt = string_slice(esrc, t.start, t.length)
          let chunk = concat_all([between, "__perceus_dup(", txt, ")"])
          pcs_render_with_marks(esrc, rest, marks,
                                  concat_all([acc, chunk]),
                                  t.start + t.length)
        } else {
          let chunk = string_slice(esrc, prev_end, (t.start + t.length) - prev_end)
          pcs_render_with_marks(esrc, rest, marks,
                                  concat_all([acc, chunk]),
                                  t.start + t.length)
        }
      _ -> {
        let chunk = string_slice(esrc, prev_end, (t.start + t.length) - prev_end)
        pcs_render_with_marks(esrc, rest, marks,
                                concat_all([acc, chunk]),
                                t.start + t.length)
      }
    }
  }
}

# ---- last_use_for: derived from `uses` ----
fn last_use_for(nm: String, uses: [Use]) : LU =
  last_use_for_loop(nm, uses, false, -1, -1)

fn last_use_for_loop(nm: String, uses: [Use], blocked: Bool,
                     mx_line: Int, mx_col: Int) : LU {
  match uses {
    [] -> {
      if blocked { LUBlocked(nm) }
      else if mx_line < 0 { LUUnused(nm) }
      else { LUAt(nm, mx_line, mx_col) }
    }
    [h, ...rest] -> match h {
      U(uname, ln, cl, in_lam) -> {
        if uname == nm {
          if in_lam {
            last_use_for_loop(nm, rest, true, mx_line, mx_col)
          } else if ln > mx_line or (ln == mx_line and cl > mx_col) {
            last_use_for_loop(nm, rest, blocked, ln, cl)
          } else {
            last_use_for_loop(nm, rest, blocked, mx_line, mx_col)
          }
        } else {
          last_use_for_loop(nm, rest, blocked, mx_line, mx_col)
        }
      }
    }
  }
}

# ---- per-param drops: entry for unused, exit for multi-use / blocked ----
#
# Categorisation by `last_use_for`:
#   - LUUnused(p)         → drop at body entry (param never read; release
#                           immediately).
#   - LUBlocked(p)         → drop at body exit (a closure may keep the
#                           param alive past the fn body via capture; the
#                           closure-capture incref balances; the original
#                           param ref is released when the fn returns).
#   - LUAt + count >= 2    → drop at body exit (every read is dup-wrapped
#                           per Phase 1, so the original ref is unconsumed
#                           and must be released).
#   - LUAt + count == 1    → no drop (the single read transfers the
#                           original ref to its consumer).
#
# Wrap shape when both entry and exit drops are needed:
#   EBlock([entry_drops..., SLet(__pcs_ret, body), exit_drops...],
#          Some(EVar("__pcs_ret")))
# `__pcs_ret` is reserved (no kaikai user-source name starts with `__`).
# When neither set has drops, the body is returned unchanged so the
# fixed-point selfhost sees no extra wrap on inert fns.
fn pcs_prepend_unused_drops(body: Expr, params: [Param], uses: [Use]) : Expr {
  let entry = pcs_collect_entry_drops(params, uses, [])
  let exit_ = pcs_collect_exit_drops(params, uses, [])
  match entry {
    [] -> match exit_ {
      [] -> body
      [_, ...__] -> pcs_wrap_with_exit(body, [], exit_)
    }
    [_, ...__] -> pcs_wrap_with_exit(body, entry, exit_)
  }
}

fn pcs_wrap_with_exit(body: Expr, entry: [Stmt], exit_: [Stmt]) : Expr {
  match exit_ {
    [] -> Expr { kind: EBlock(entry, Some(body)), line: body.line, col: body.col }
    [_, ...__] -> {
      let ret_let = SLet(
        Pattern { pkind: PBind("__pcs_ret"), line: body.line, col: body.col },
        None,
        body
      )
      let stmts = list_append(entry, [ret_let, ...exit_])
      let tail = Expr { kind: EVar("__pcs_ret"), line: body.line, col: body.col }
      Expr { kind: EBlock(stmts, Some(tail)), line: body.line, col: body.col }
    }
  }
}

fn pcs_collect_entry_drops(params: [Param], uses: [Use], acc: [Stmt]) : [Stmt] {
  match params {
    [] -> list_reverse(acc)
    [p, ...rest] -> {
      let acc1 = match last_use_for(p.pname, uses) {
        LUUnused(_) -> [pcs_make_drop_stmt(p.pname, p.pline, p.pcol), ...acc]
        _ -> acc
      }
      pcs_collect_entry_drops(rest, uses, acc1)
    }
  }
}

fn pcs_collect_exit_drops(params: [Param], uses: [Use], acc: [Stmt]) : [Stmt] {
  match params {
    [] -> list_reverse(acc)
    [p, ...rest] -> {
      let acc1 = match last_use_for(p.pname, uses) {
        LUBlocked(_) -> [pcs_make_drop_stmt(p.pname, p.pline, p.pcol), ...acc]
        LUAt(_, _, _) ->
          if pcs_count_non_lam_uses(p.pname, uses, 0) >= 2 {
            [pcs_make_drop_stmt(p.pname, p.pline, p.pcol), ...acc]
          } else { acc }
        _ -> acc
      }
      pcs_collect_exit_drops(rest, uses, acc1)
    }
  }
}

# Issue #297 (partial) — block-scope let-binding exit drops.
# Mirror of stage 2's `pcs_collect_block_let_exit_drops`. Stage 1 has
# no raw locals (Tier 2.5), so plain `pat_bindings` suffices and we
# never have to skip an `int64_t` shadow.
fn pcs_collect_block_let_exit_drops(stmts: [Stmt], outer: [String],
                                     uses: [Use], opt_tail: Option[Expr],
                                     acc: [Stmt]) : [Stmt] {
  match stmts {
    [] -> list_reverse(acc)
    [s, ...rest] -> {
      let acc1 = match s {
        SLet(pat, _, _) -> match pat.pkind {
          PBind(nm) -> {
            let in_tail = pcs_name_in_tail(nm, opt_tail)
            if not list_has(outer, nm) and not in_tail {
              match last_use_for(nm, uses) {
                LUBlocked(_) -> [pcs_make_drop_stmt(nm, pat.line, pat.col), ...acc]
                LUAt(_, _, _) ->
                  if pcs_count_non_lam_uses(nm, uses, 0) >= 2 {
                    [pcs_make_drop_stmt(nm, pat.line, pat.col), ...acc]
                  } else { acc }
                _ -> acc
              }
            } else { acc }
          }
          _ -> acc
        }
        _ -> acc
      }
      pcs_collect_block_let_exit_drops(rest, outer, uses, opt_tail, acc1)
    }
  }
}

fn pcs_name_in_tail(nm: String, opt_tail: Option[Expr]) : Bool {
  match opt_tail {
    None -> false
    Some(e) -> {
      let us = pcs_collect_uses_expr(e, [nm], false, [])
      pcs_uses_has_name(us, nm)
    }
  }
}

fn pcs_append_drops(stmts: [Stmt], drops: [Stmt]) : [Stmt] {
  match drops {
    [] -> stmts
    [_, ...__] -> list_append(stmts, list_reverse(drops))
  }
}

fn pcs_uses_has_name(uses: [Use], nm: String) : Bool {
  match uses {
    [] -> false
    [h, ...rest] -> match h {
      U(uname, _, _, _) -> if uname == nm { true } else { pcs_uses_has_name(rest, nm) }
    }
  }
}

fn pcs_make_drop_stmt(nm: String, ln: Int, cl: Int) : Stmt =
  SExprStmt(Expr {
    kind: ECall(
      Expr { kind: EVar("__perceus_drop"), line: ln, col: cl },
      [Expr { kind: EVar(nm), line: ln, col: cl }]
    ),
    line: ln, col: cl
  })

# ====================================================================
# m37 / TCO — self-tail-call rewrite (issue #42 — stage 1 mirror)
# ====================================================================
#
# Stage-1 port of the rewrite pinned in `stage2/compiler.kai`'s
# `tcrec_*` block (commit ddd381e on `main`). Goal: kaic1's emitted
# C uses `goto _kai_<name>_entry` for self-tail-recursive fns so
# the kaic2 binary that kaic1 builds can selfhost on Linux's 8 MiB
# default stack without `kai_runtime_bump_stack_rlimit`.
#
# Differences from the stage-2 source:
#
#  - `Decl::DFn` has no tparams / row / module (`name` is the C
#    symbol directly), so the c_sym_str is `name`.
#  - `Expr` carries no `ty`/`mode`, so the rewritten EVar is
#    `Expr { kind: EVar(sentinel), line, col }`.
#  - `Stmt` only has `SLet` and `SExprStmt`, so the block-scope
#    walker ignores everything else.
#  - Pipeline runs after `perceus_pass` (same as stage 2 — we need
#    the dropmask to mirror `pcs_collect_exit_drops`).
#
# Sentinel encoding is identical to stage 2:
#
#     __kai_tcrec|<sym>|<dropmask>|<p0>|<p1>|...
#
# Pipe was chosen because no kaikai identifier or integer literal
# can contain it.

# ---- M1 — tail-position walker ------------------------------------

fn tcrec_has_tail_self_call(body: Expr, nm: String, arity: Int) : Bool =
  tcrec_walk_tail(body.kind, nm, arity, [])

fn tcrec_walk_tail(k: ExprKind, nm: String, arity: Int, scope: [String]) : Bool {
  match k {
    ECall(f, xs) -> match f.kind {
      EVar(callee) ->
        if callee == nm and not list_has(scope, nm) and list_length(xs) == arity {
          true
        } else { false }
      _ -> false
    }
    EIf(_, t, opt_e) -> {
      if tcrec_walk_tail(t.kind, nm, arity, scope) { true }
      else { match opt_e {
        None -> false
        Some(e2) -> tcrec_walk_tail(e2.kind, nm, arity, scope)
      } }
    }
    EMatch(_, arms) -> tcrec_walk_arms(arms, nm, arity, scope)
    EBlock(stmts, opt_tail) -> {
      let scope1 = tcrec_block_scope(stmts, scope)
      match opt_tail {
        None -> false
        Some(e) -> tcrec_walk_tail(e.kind, nm, arity, scope1)
      }
    }
    _ -> false
  }
}

fn tcrec_walk_arms(arms: [Arm], nm: String, arity: Int, scope: [String]) : Bool {
  match arms {
    [] -> false
    [a, ...rest] -> match a {
      Arm(pat, _, body) -> {
        let scope1 = pat_bindings(pat, scope)
        if tcrec_walk_tail(body.kind, nm, arity, scope1) { true }
        else { tcrec_walk_arms(rest, nm, arity, scope) }
      }
    }
  }
}

fn tcrec_block_scope(stmts: [Stmt], scope: [String]) : [String] {
  match stmts {
    [] -> scope
    [s, ...rest] -> {
      let scope1 = match s {
        SLet(pat, _, _) -> pat_bindings(pat, scope)
        _ -> scope
      }
      tcrec_block_scope(rest, scope1)
    }
  }
}

# ---- M2 — sentinel encode / decode --------------------------------

fn tcrec_pow2(n: Int) : Int =
  if n <= 0 { 1 } else { 2 * tcrec_pow2(n - 1) }

fn tcrec_make_sentinel(sym: String, dropmask: Int, pnames: [String]) : String =
  string_concat("__kai_tcrec|",
    string_concat(sym,
      string_concat("|",
        string_concat(int_to_string(dropmask),
          string_concat("|", string_join(pnames, "|"))))))

fn tcrec_is_sentinel(callee: String) : Bool =
  tcrec_starts_with(callee, "__kai_tcrec|")

# Local string-prefix check; stage 2 has `string_starts_with_q`,
# stage 1 does not, so we keep the helper next to its only caller.
fn tcrec_starts_with(s: String, prefix: String) : Bool =
  tcrec_starts_with_loop(s, prefix, 0, string_length(prefix))

fn tcrec_starts_with_loop(s: String, prefix: String, i: Int, pn: Int) : Bool {
  if i >= pn { true }
  else { match char_at(s, i) {
    None -> false
    Some(sc) -> match char_at(prefix, i) {
      None -> true
      Some(pc) -> if sc == pc { tcrec_starts_with_loop(s, prefix, i + 1, pn) } else { false }
    }
  } }
}

fn tcrec_split_pipe(s: String) : [String] =
  tcrec_split_pipe_loop(s, 0, 0, string_length(s), [])

fn tcrec_split_pipe_loop(s: String, start: Int, i: Int, n: Int, acc: [String]) : [String] {
  if i >= n {
    list_reverse([string_slice(s, start, n - start), ...acc])
  } else {
    match char_at(s, i) {
      None -> list_reverse([string_slice(s, start, n - start), ...acc])
      Some(c) ->
        if c == '|' {
          tcrec_split_pipe_loop(s, i + 1, i + 1, n,
            [string_slice(s, start, i - start), ...acc])
        } else {
          tcrec_split_pipe_loop(s, start, i + 1, n, acc)
        }
    }
  }
}

fn tcrec_parse_decimal(s: String) : Int =
  tcrec_parse_decimal_loop(s, 0, string_length(s), 0)

fn tcrec_parse_decimal_loop(s: String, i: Int, n: Int, acc: Int) : Int {
  if i >= n { acc }
  else { match char_at(s, i) {
    None -> acc
    Some(c) ->
      if ch_is_digit(c) {
        tcrec_parse_decimal_loop(s, i + 1, n, acc * 10 + (char_to_int(c) - char_to_int('0')))
      } else { acc }
  } }
}

# ---- M2 — rewrite pass --------------------------------------------

fn tcrec_rewrite_decls(decls: [Decl]) : [Decl] = map(decls, tcrec_rewrite_decl)

fn tcrec_rewrite_decl(d: Decl) : Decl {
  match d {
    DFn(is_pub, name, params, opt_ret, body, ln, cl) -> {
      let arity = list_length(params)
      if not tcrec_has_tail_self_call(body, name, arity) { d }
      else {
        let pnames = map(params, (p) => p.pname)
        let uses = pcs_collect_uses_expr(body, pnames, false, [])
        if tcrec_any_unused(params, uses) { d }
        else {
          let new_body = tcrec_rewrite_body(body, name, arity, name,
                                            params, pnames, uses, [])
          DFn(is_pub, name, params, opt_ret, new_body, ln, cl)
        }
      }
    }
    _ -> d
  }
}

fn tcrec_any_unused(params: [Param], uses: [Use]) : Bool {
  match params {
    [] -> false
    [p, ...rest] -> match last_use_for(p.pname, uses) {
      LUUnused(_) -> true
      _ -> tcrec_any_unused(rest, uses)
    }
  }
}

# Per-call-site dropmask. Mirrors `pcs_collect_exit_drops` so the
# rebind block at the goto site drops exactly the params the wrap's
# exit drops would have dropped — that is what makes goto-jumping
# out of the wrap refcount-equivalent.
fn tcrec_compute_site_dropmask(params: [Param], uses: [Use],
                                i: Int, acc: Int) : Int {
  match params {
    [] -> acc
    [p, ...rest] -> {
      let drop = match last_use_for(p.pname, uses) {
        LUBlocked(_) -> true
        LUAt(_, _, _) -> pcs_count_non_lam_uses(p.pname, uses, 0) >= 2
        LUUnused(_) -> false
      }
      let acc1 = if drop { acc + tcrec_pow2(i) } else { acc }
      tcrec_compute_site_dropmask(rest, uses, i + 1, acc1)
    }
  }
}

fn tcrec_rewrite_body(body: Expr, nm: String, arity: Int, c_sym_str: String,
                      params: [Param], pnames: [String], uses: [Use],
                      scope: [String]) : Expr =
  Expr { kind: tcrec_rewrite_kind(body.kind, body.line, body.col, nm, arity,
                                   c_sym_str, params, pnames, uses, scope),
         line: body.line, col: body.col }

fn tcrec_rewrite_kind(k: ExprKind, line: Int, col: Int, nm: String, arity: Int,
                      c_sym_str: String, params: [Param], pnames: [String],
                      uses: [Use], scope: [String]) : ExprKind {
  match k {
    ECall(f, xs) -> match f.kind {
      EVar(callee) ->
        if callee == nm and not list_has(scope, nm) and list_length(xs) == arity {
          let dropmask = tcrec_compute_site_dropmask(params, uses, 0, 0)
          let sentinel = tcrec_make_sentinel(c_sym_str, dropmask, pnames)
          ECall(
            Expr { kind: EVar(sentinel), line: f.line, col: f.col },
            xs)
        } else { k }
      _ -> k
    }
    EIf(c, t, opt_e) -> {
      let t1 = tcrec_rewrite_body(t, nm, arity, c_sym_str, params, pnames, uses, scope)
      let opt_e1 = match opt_e {
        None -> None
        Some(e2) -> Some(tcrec_rewrite_body(e2, nm, arity, c_sym_str, params,
                                            pnames, uses, scope))
      }
      EIf(c, t1, opt_e1)
    }
    EMatch(s, arms) ->
      EMatch(s, tcrec_rewrite_arms(arms, nm, arity, c_sym_str, params, pnames,
                                    uses, scope, []))
    EBlock(stmts, opt_tail) -> {
      let scope1 = tcrec_block_scope(stmts, scope)
      match opt_tail {
        None -> k
        Some(e) ->
          EBlock(stmts, Some(tcrec_rewrite_body(e, nm, arity, c_sym_str, params,
                                                 pnames, uses, scope1)))
      }
    }
    _ -> k
  }
}

fn tcrec_rewrite_arms(arms: [Arm], nm: String, arity: Int, c_sym_str: String,
                      params: [Param], pnames: [String], uses: [Use],
                      scope: [String], acc: [Arm]) : [Arm] {
  match arms {
    [] -> list_reverse(acc)
    [a, ...rest] -> match a {
      Arm(pat, opt_g, body) -> {
        let scope1 = pat_bindings(pat, scope)
        let new_body = tcrec_rewrite_body(body, nm, arity, c_sym_str, params,
                                          pnames, uses, scope1)
        tcrec_rewrite_arms(rest, nm, arity, c_sym_str, params, pnames, uses,
                           scope, [Arm(pat, opt_g, new_body), ...acc])
      }
    }
  }
}

# ---- M3 — sentinel scanner (drives the entry-label plant) ---------

fn tcrec_body_has_sentinel(body: Expr) : Bool =
  tcrec_scan_kind(body.kind)

fn tcrec_scan_kind(k: ExprKind) : Bool {
  match k {
    ECall(f, xs) -> match f.kind {
      EVar(callee) ->
        if tcrec_is_sentinel(callee) { true }
        else { tcrec_scan_exprs(xs) }
      _ -> if tcrec_body_has_sentinel(f) { true } else { tcrec_scan_exprs(xs) }
    }
    EIf(c, t, opt_e) ->
      if tcrec_body_has_sentinel(c) { true }
      else if tcrec_body_has_sentinel(t) { true }
      else { match opt_e {
        None -> false
        Some(e2) -> tcrec_body_has_sentinel(e2)
      } }
    EMatch(s, arms) ->
      if tcrec_body_has_sentinel(s) { true } else { tcrec_scan_arms(arms) }
    EBlock(stmts, opt_tail) ->
      if tcrec_scan_stmts(stmts) { true }
      else { match opt_tail {
        None -> false
        Some(e) -> tcrec_body_has_sentinel(e)
      } }
    EBinop(_, l, r) ->
      if tcrec_body_has_sentinel(l) { true } else { tcrec_body_has_sentinel(r) }
    EUnop(_, x) -> tcrec_body_has_sentinel(x)
    EField(x, _) -> tcrec_body_has_sentinel(x)
    EIndex(x, i) ->
      if tcrec_body_has_sentinel(x) { true } else { tcrec_body_has_sentinel(i) }
    EPipe(l, r) ->
      if tcrec_body_has_sentinel(l) { true } else { tcrec_body_has_sentinel(r) }
    _ -> false
  }
}

fn tcrec_scan_exprs(es: [Expr]) : Bool {
  match es {
    [] -> false
    [h, ...rest] ->
      if tcrec_body_has_sentinel(h) { true } else { tcrec_scan_exprs(rest) }
  }
}

fn tcrec_scan_arms(arms: [Arm]) : Bool {
  match arms {
    [] -> false
    [a, ...rest] -> match a {
      Arm(_, _, body) ->
        if tcrec_body_has_sentinel(body) { true } else { tcrec_scan_arms(rest) }
    }
  }
}

fn tcrec_scan_stmts(stmts: [Stmt]) : Bool {
  match stmts {
    [] -> false
    [s, ...rest] -> {
      let here = match s {
        SLet(_, _, e) -> tcrec_body_has_sentinel(e)
        SExprStmt(e) -> tcrec_body_has_sentinel(e)
      }
      if here { true } else { tcrec_scan_stmts(rest) }
    }
  }
}

# ---- M4 — goto-block emission ------------------------------------
#
# Called from `emit_call_expr` when the EVar callee carries a
# `__kai_tcrec|...` sentinel. Emits the rebind+goto statement-
# expression. The label `_kai_<sym>_entry` is planted by
# `emit_fn_body`. Refcount discipline mirrors stage 2:
#   1. Evaluate every arg into `_t<i>` (rc=1 per Perceus contract).
#   2. Drop the params whose bit is set in dropmask — these are
#      the params the wrap's exit drops would have released.
#   3. Rebind `kai_<pname> = _t<i>` in declaration order.
#   4. Goto the entry label.
#   5. Trailing `(KaiValue *)0;` so the statement-expression has a
#      well-typed value (unreachable past the goto).

fn tcrec_emit_goto(src: String, sym: String, dropmask: Int, pnames: [String],
                   args_e: [Expr], fns: [EFn], variants: [EVar],
                   lams: [LamInfo], locals: [String]) : String {
  let arg_lets = tcrec_emit_arg_lets(src, args_e, 0, fns, variants, lams, locals)
  let drops    = tcrec_emit_drops(pnames, dropmask, 0)
  let rebinds  = tcrec_emit_rebinds(pnames, 0)
  concat_all([
    "({ ", arg_lets, drops, rebinds,
    "goto _kai_", sym, "_entry; (KaiValue *)0; })"
  ])
}

fn tcrec_emit_arg_lets(src: String, args_e: [Expr], i: Int,
                       fns: [EFn], variants: [EVar], lams: [LamInfo],
                       locals: [String]) : String {
  match args_e {
    [] -> ""
    [a, ...rest] -> {
      let arg_c = emit_expr(src, a, fns, variants, lams, locals)
      let head = concat_all([
        "KaiValue *_t", int_to_string(i), " = ", arg_c, "; "
      ])
      string_concat(head,
        tcrec_emit_arg_lets(src, rest, i + 1, fns, variants, lams, locals))
    }
  }
}

fn tcrec_emit_drops(pnames: [String], dropmask: Int, i: Int) : String {
  match pnames {
    [] -> ""
    [p, ...rest] -> {
      let bit = tcrec_pow2(i)
      let head =
        if (dropmask / bit) % 2 == 1 {
          concat_all([
            "{ KaiValue *_ = kai_internal_drop(kai_", p, "); (void) _; } "
          ])
        } else { "" }
      string_concat(head, tcrec_emit_drops(rest, dropmask, i + 1))
    }
  }
}

fn tcrec_emit_rebinds(pnames: [String], i: Int) : String {
  match pnames {
    [] -> ""
    [p, ...rest] -> {
      let head = concat_all([
        "kai_", p, " = _t", int_to_string(i), "; "
      ])
      string_concat(head, tcrec_emit_rebinds(rest, i + 1))
    }
  }
}

fn emit_program(file: String, src: String, decls: [Decl], test_mode: Bool) : String {
  let fns = register_fn_decls(decls)
  let variants = register_variants(decls)
  let globals = build_globals(fns, variants)
  let st0 = lc_new(globals)
  let st = collect_decls(decls, st0)
  let lams = st.lams
  let header = "/* generated by kaikai stage 1 */\n#include \"runtime.h\"\n\n"
  let fwd = fn_forward_decls(decls)
  let thunk_fwd = thunk_forward_decls(decls)
  let lam_fwd = emit_lam_forward_decls(lams)
  let bodies = fn_bodies(src, decls, fns, variants, lams)
  let lam_bodies = emit_lam_helpers(src, lams, fns, variants)
  let tests = emit_all_tests(src, decls, fns, variants, lams)
  let main_wr = emit_main_wrapper(decls, test_mode)
  concat_all([header, fwd, "\n", thunk_fwd, "\n", lam_fwd, "\n", bodies, lam_bodies, tests, main_wr])
}

# ====================================================================
# cli + driver
# ====================================================================

type Mode
  = MDefault
  | MTokens
  | MAst
  | MTest
  | MHelp

type CliOptions = { mode: Mode, path: Option[String], prelude: Option[String],
                    include_prelude_tests: Bool }

fn cli_with_mode(opts: CliOptions, m: Mode) : CliOptions =
  CliOptions { mode: m, path: opts.path, prelude: opts.prelude,
               include_prelude_tests: opts.include_prelude_tests }

fn cli_with_path(opts: CliOptions, p: String) : CliOptions =
  CliOptions { mode: opts.mode, path: Some(p), prelude: opts.prelude,
               include_prelude_tests: opts.include_prelude_tests }

fn cli_with_prelude(opts: CliOptions, p: String) : CliOptions =
  CliOptions { mode: opts.mode, path: opts.path, prelude: Some(p),
               include_prelude_tests: opts.include_prelude_tests }

fn cli_with_include_prelude_tests(opts: CliOptions) : CliOptions =
  CliOptions { mode: opts.mode, path: opts.path, prelude: opts.prelude,
               include_prelude_tests: true }

fn parse_cli_loop(rest: [String], opts: CliOptions) : CliOptions {
  match rest {
    [] -> opts
    [a, ...more] -> {
      if a == "--tokens" {
        parse_cli_loop(more, cli_with_mode(opts, MTokens))
      } else if a == "--ast" {
        parse_cli_loop(more, cli_with_mode(opts, MAst))
      } else if a == "--test" {
        parse_cli_loop(more, cli_with_mode(opts, MTest))
      } else if a == "--include-prelude-tests" {
        # Issue #318: keep test blocks defined in `--prelude` files.
        # Without this flag the prelude's tests are dropped at load
        # time so `kai test <file>` runs only the file's own tests.
        parse_cli_loop(more, cli_with_include_prelude_tests(opts))
      } else if a == "-h" or a == "--help" {
        parse_cli_loop(more, cli_with_mode(opts, MHelp))
      } else if a == "--prelude" {
        match more {
          [p, ...rest2] -> parse_cli_loop(rest2, cli_with_prelude(opts, p))
          [] -> {
            eprint("kaic1: --prelude requires a file argument")
            cli_with_mode(opts, MHelp)
          }
        }
      } else {
        parse_cli_loop(more, cli_with_path(opts, a))
      }
    }
  }
}

fn parse_cli(argv: [String]) : CliOptions {
  parse_cli_loop(argv, CliOptions { mode: MDefault, path: None, prelude: None,
                                    include_prelude_tests: false })
}

fn usage() : Unit {
  eprint("usage: kaic1 [options] <file.kai>")
  eprint("  --prelude <file>   include <file>'s decls before the input")
  eprint("  --tokens           print the token stream and exit")
  eprint("  --ast              parse and print the AST and exit")
  eprint("  --test             emit C wired to a test runner (runs test blocks)")
  eprint("  --include-prelude-tests  also run test blocks from --prelude (default: drop them; issue #318)")
  eprint("  -h, --help         this help")
}

# Parse a prelude file and return its decl list. On any error report
# to stderr and return None.
#
# Issue #318: when `include_tests` is false (the default), strip
# every `DTest` block from the prelude before returning it. This
# matches stage 2's behaviour: `kai test <user.kai>` should run
# only the user file's own tests, not the stdlib's.
fn load_prelude(path: String, include_tests: Bool) : Option[[Decl]] {
  match read_file(path) {
    Err(msg) -> { eprint("kaic1: #{path}: #{msg}"); None }
    Ok(src) -> {
      let tokens = tokenize(src)
      let errs = report_errors(path, src, tokens)
      if errs != 0 { None }
      else {
        let parsed = parse_program(path, src, tokens)
        match parsed.decls {
          None -> None
          Some(ds) -> if include_tests { Some(ds) } else { Some(strip_prelude_tests(ds, [])) }
        }
      }
    }
  }
}

# Issue #318: drop every `test` block from a prelude file's decls.
# Stage 1 does not parse `bench`/`check`, so DTest is the only case.
fn strip_prelude_tests(ds: [Decl], acc: [Decl]) : [Decl] = match ds {
  [] -> list_reverse(acc)
  [d, ...rest] -> match d {
    DTest(_, _, _, _) -> strip_prelude_tests(rest, acc)
    _                  -> strip_prelude_tests(rest, [d, ...acc])
  }
}

fn compile_source(path: String, mode: Mode, src: String, prelude_decls: [Decl]) : Int {
  let tokens = tokenize(src)
  let lex_errs = report_errors(path, src, tokens)
  match mode {
    MTokens -> {
      dump_tokens(src, tokens)
      lex_errs
    }
    MHelp -> { usage(); 0 }
    _ -> {
      if lex_errs != 0 { lex_errs }
      else {
        let parsed = parse_program(path, src, tokens)
        match parsed.decls {
          None -> 1
          Some(own_decls) -> {
            let all_decls = list_append(prelude_decls, own_decls)
            match mode {
              MAst -> { dump_program(all_decls); 0 }
              _ -> {
                let chk = check_program(path, all_decls)
                if chk != 0 { chk }
                else {
                  let test_mode = match mode { MTest -> true _ -> false }
                  # Issue #42: TCO rewrite runs BEFORE perceus_pass, mirroring
                  # stage 2's pipeline. Rationale: perceus wraps fns whose
                  # params need exit drops in
                  # `EBlock([SLet("__pcs_ret", body), ...drops], Some(EVar("__pcs_ret")))`,
                  # so the original tail position becomes non-tail. Running
                  # TCO first sees the unwrapped body. Sentinels survive
                  # perceus untouched: the sentinel callee is `EVar(<sym>)`
                  # whose name is not in any param scope, so the dup walker
                  # leaves it alone. The dropmask is computed from the
                  # original use info (no perceus marks yet).
                  let tco_decls = tcrec_rewrite_decls(all_decls)
                  let perc_decls = perceus_pass(tco_decls)
                  let out = emit_program(path, src, perc_decls, test_mode)
                  print(out)
                  0
                }
              }
            }
          }
        }
      }
    }
  }
}

fn run(opts: CliOptions) : Int {
  match opts.mode {
    MHelp -> { usage(); 0 }
    _ -> match opts.path {
      None -> { usage(); 2 }
      Some(p) -> {
        let prelude_decls =
          match opts.prelude {
            None -> Some([])
            Some(pp) -> load_prelude(pp, opts.include_prelude_tests)
          }
        match prelude_decls {
          None -> 1
          Some(pds) -> match read_file(p) {
            Ok(src) -> compile_source(p, opts.mode, src, pds)
            Err(msg) -> { eprint("kaic1: #{p}: #{msg}"); 1 }
          }
        }
      }
    }
  }
}

fn main() {
  let code = run(parse_cli(args()))
  exit(code)
}
