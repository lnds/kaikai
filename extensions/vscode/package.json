{
  "name": "kaikai-lsp",
  "displayName": "kaikai",
  "description": "Language support for kaikai — hover via kai lsp (issue #447).",
  "version": "0.1.0",
  "publisher": "kaikai-lang",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:kaikai"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "kaikai",
        "aliases": ["kaikai", "kai"],
        "extensions": [".kai"],
        "configuration": "./language-configuration.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "kaikai",
      "properties": {
        "kaikai.lspPath": {
          "type": "string",
          "default": "kai",
          "description": "Path to the kai binary. The extension spawns `<lspPath> lsp` as the language server."
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.0"
  }
}
