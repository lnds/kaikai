#[doc("""
Surface helpers on top of the NetTcp effect. `import net.tcp`. The
effect is declared by the compiler; this file adds the small pure
helpers that fall out of the op set. IPv4 only, blocking ops.
""")]

#[doc("""
Read back the local port a Listener is bound to — useful when the
caller passed `port = 0` to `NetTcp.listen` so the kernel picks a
free port.
""")]
pub fn local_port(l: Listener) : Int = l.port
