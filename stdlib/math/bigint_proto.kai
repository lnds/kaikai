#[doc("""
Protocol implementations for `bigint.BigInt`: `Show` (decimal),
`Serialize` (`to_string` / `from_string`), `Eq`, `Ord`, `Hash`, and the
total arithmetic operators `Add` / `Sub` / `Mul` / `Div`. `Div` is
truncating (toward zero) and total: it traps on a zero divisor
(`bigint_convert.op_div`). `bigint_convert.div` / `divmod` return
`Option` for callers that handle the zero case.

`Eq`/`Ord` reduce to `bigint.compare`, a total order on the sign-
magnitude form. `Hash` folds the canonical representation — sign then
limbs — so it is consistent with `Eq` by construction: the one-
representation-per-integer invariant (`bigint.make` is the single
normalization point) means equal values hash identically without the
hash needing any range logic.
""")]

import math.bigint
import math.bigint_convert as bc
import math.bigint_limbs.{sig_len}

impl Show for bigint.BigInt {
  fn show(x: bigint.BigInt) : String = bc.to_string(x)
}

impl Serialize for bigint.BigInt {
  fn to_string(x: bigint.BigInt) : String = bc.to_string(x)
  fn from_string(s: String) : Result[bigint.BigInt, String] = match bc.from_string(s) {
    Some(v) -> Ok(v)
    None    -> Err("not a base-10 integer")
  }
}

impl Eq for bigint.BigInt {
  fn eq(a: bigint.BigInt, b: bigint.BigInt) : Bool = bigint.compare(a, b) == 0
}

impl Ord for bigint.BigInt {
  fn cmp(a: bigint.BigInt, b: bigint.BigInt) : Int = bigint.compare(a, b)
  fn min(a: bigint.BigInt, b: bigint.BigInt) : bigint.BigInt =
    if bigint.compare(a, b) <= 0 { a } else { b }
  fn max(a: bigint.BigInt, b: bigint.BigInt) : bigint.BigInt =
    if bigint.compare(a, b) >= 0 { a } else { b }
}

impl Hash for bigint.BigInt {
  fn hash(x: bigint.BigInt) : Int = bigint_hash(x)
}

impl Add for bigint.BigInt {
  fn add(self: bigint.BigInt, rhs: bigint.BigInt) : bigint.BigInt = bigint.add(self, rhs)
}

impl Sub for bigint.BigInt {
  fn sub(self: bigint.BigInt, rhs: bigint.BigInt) : bigint.BigInt = bigint.sub(self, rhs)
}

impl Mul for bigint.BigInt {
  fn mul(self: bigint.BigInt, rhs: bigint.BigInt) : bigint.BigInt = bigint.mul(self, rhs)
}

impl Div for bigint.BigInt {
  fn div(self: bigint.BigInt, rhs: bigint.BigInt) : bigint.BigInt = bc.op_div(self, rhs)
}

# Multiplicative fold over sign and canonical limbs. The sign seeds the
# accumulator so `n` and `-n` hash apart; the limbs mix in least-
# significant first. Operates on the canonical magnitude, so equal
# values (which share one representation) always agree. Arithmetic wraps
# in `Int`, which is fine for a hash.
fn bigint_hash(x: bigint.BigInt) : Int = {
  let mag = bigint.magnitude(x)
  hash_limbs(mag, 0, sig_len(mag), hash_seed(bigint.sign(x)))
}

fn hash_seed(sign: Int) : Int = if sign < 0 { 0 - 2654435761 } else { 2654435761 }

fn hash_limbs(mag: Array[Int], i: Int, n: Int, acc: Int) : Int =
  if i >= n { acc }
  else { hash_limbs(mag, i + 1, n, (acc + mag[i]) * 1099511628211) }
