#[doc("""
Mutable, separately-chained hash table `HashMap[k, v]` behind the
`Mutable` effect: O(1)-average insert and lookup. Reach for it inside
an effectful body; reach for `Map` (AVL) when you need ordered
iteration or a pure/persistent value.

Conventions:
  - **Mutating, not persistent.** `put` / `remove` mutate the table
    in place and return `Unit`. There is no structural sharing and no
    "old version" after a write — the handle you hold sees every
    later mutation. Aliasing two bindings to one `HashMap` aliases
    the same mutable table.
  - **Every op carries `/ Mutable`.** Even `get` and `size` read the
    table's `Ref` cells, so they demand the `Mutable` effect. The
    runtime installs a trivial default handler for any `main` row
    containing `Mutable`, so callers rarely write a handler — but the
    effect IS in the signature, the source of truth that the value is
    a mutable location.
  - Key equality is structural via `==`; key hashing is the `Hash`
    protocol's `hash(key)`. The two MUST agree: `a == b` implies
    `hash(a) == hash(b)` — every stdlib `impl Hash` and
    `#[derive(Hash)]` upholds this.
  - **Key types: primitives + sum types, NOT records.** `Int`,
    `String`, `Real`, `Bool`, `Char` and user sum types with
    `impl Hash` + `impl Eq` dispatch through the generic boundary. A
    record key boxed through `key: k` reads runtime head tag 0, so
    `hash(key)` panics even with `#[derive(Hash)]` — lift it to a
    primitive id field.
  - **Iteration order is unspecified** (bucket order) and NOT stable
    across resizes. Use `Map` (AVL) if you need ordered iteration.
  - Negative hashes are fine: the bucket index normalises with
    `((h % cap) + cap) % cap`.
  - **No HashDoS mitigation.** Keys are assumed non-adversarial.

The `m[key]` read-side indexing sugar dispatches to `hashmap.get`
(returns `Option[v]`, carries `/ Mutable`). The write-side
`m[key] := v` is NOT provided — use `hashmap.put`.

Rides the pipes (`|`, `||`, `|?`) with element type `Pair[k, v]`,
mirroring the pure `Map`. Duplicate output keys collapse to the last
occurrence. Because every op reads the mutable table, the pipe
combinators carry `/ Mutable` (the runtime's default handler is always
installed, so a call site rarely writes one).
""")]

# ---- Carrier -----------------------------------------------------
#
# Separate chaining: `buckets` is an `Array` of chains, each chain a
# `[Pair[k, v]]`. The array, the live entry count, and the current
# capacity all live in `Ref` cells so a resize can swap the whole
# bucket array atomically from inside a `/ Mutable` body.
#
# Capacity is always a power of two starting at 16; resize doubles
# when the load factor exceeds 0.75 (`count * 4 > cap * 3`).

#[doc("A mutable hash map using separate chaining over a power-of-two bucket array; resizes at load factor 0.75. Operations ride `Mutable`.")]
pub type HashMap[k, v] = {
  priv buckets : Ref[Array[[Pair[k, v]]]],
  priv count   : Ref[Int],
  priv cap     : Ref[Int]
}

fn hashmap_initial_cap() : Int = 16

# Bucket index for a hash under capacity `cap`. Absorbs a negative
# `hash` (the `impl Hash` contract permits two's-complement wrap).
fn bucket_index(h: Int, cap: Int) : Int = {
  let m = h % cap
  if m < 0 { m + cap } else { m }
}

# ---- Chain primitives (pure over [Pair[k, v]]) ------------------

fn chain_get(ps: [Pair[k, v]], key: k) : Option[v] = match ps {
  []        -> None
  [p, ...r] -> if p.fst == key { Some(p.snd) } else { chain_get(r, key) }
}

# Replace `key`'s value if present, else prepend. Returns the new
# chain plus whether the key already existed (so the caller keeps the
# live count exact without a separate probe).
fn chain_put(ps: [Pair[k, v]], key: k, value: v) : Pair[[Pair[k, v]], Bool] = match ps {
  []        -> Pair { fst: [Pair { fst: key, snd: value }], snd: false }
  [p, ...r] ->
    if p.fst == key {
      Pair { fst: [Pair { fst: key, snd: value }, ...r], snd: true }
    } else {
      let sub = chain_put(r, key, value)
      Pair { fst: [p, ...sub.fst], snd: sub.snd }
    }
}

# Drop `key` from a chain. Returns the new chain plus whether a key
# was actually removed.
fn chain_remove(ps: [Pair[k, v]], key: k) : Pair[[Pair[k, v]], Bool] = match ps {
  []        -> Pair { fst: [], snd: false }
  [p, ...r] ->
    if p.fst == key {
      Pair { fst: r, snd: true }
    } else {
      let sub = chain_remove(r, key)
      Pair { fst: [p, ...sub.fst], snd: sub.snd }
    }
}

# ---- Resize ------------------------------------------------------

# Scatter one chain's pairs into the destination bucket array under
# `new_cap`. Order within a destination bucket is not preserved (and
# is unspecified anyway).
fn rehash_chain(ps: [Pair[k, v]], dst: Array[[Pair[k, v]]], new_cap: Int) : Unit / Mutable = match ps {
  []        -> ()
  [p, ...r] -> {
    let j = bucket_index(hash(p.fst), new_cap)
    dst[j] := [p, ...dst[j]]
    rehash_chain(r, dst, new_cap)
  }
}

fn rehash_loop(src: Array[[Pair[k, v]]], i: Int, cap: Int,
               dst: Array[[Pair[k, v]]], new_cap: Int) : Unit / Mutable =
  if i >= cap { () }
  else { rehash_chain(src[i], dst, new_cap); rehash_loop(src, i + 1, cap, dst, new_cap) }

# Grow + rehash when the load factor passes 0.75. Allocates a fresh
# bucket array of double the capacity and swaps it in through the Ref.
fn maybe_grow(m: HashMap[k, v]) : Unit / Mutable = {
  let cap = Mutable.ref_get(m.cap)
  let cnt = Mutable.ref_get(m.count)
  if cnt * 4 > cap * 3 {
    let new_cap = cap * 2
    let src = Mutable.ref_get(m.buckets)
    let dst = Mutable.array_make(new_cap, [])
    rehash_loop(src, 0, cap, dst, new_cap)
    Mutable.ref_set(m.buckets, dst)
    Mutable.ref_set(m.cap, new_cap)
  }
}

# ---- Iteration helper -------------------------------------------

fn collect_buckets(arr: Array[[Pair[k, v]]], i: Int, cap: Int, acc: [Pair[k, v]]) : [Pair[k, v]] / Mutable =
  if i >= cap { acc }
  else { collect_buckets(arr, i + 1, cap, arr[i] ++ acc) }

# ---- Public surface ---------------------------------------------

#[doc("Returns a fresh empty hash map with initial capacity 16.")]
pub fn empty() : HashMap[k, v] / Mutable = {
  let cap0 = hashmap_initial_cap()
  let arr = Mutable.array_make(cap0, [])
  HashMap {
    buckets: Mutable.ref_make(arr),
    count:   Mutable.ref_make(0),
    cap:     Mutable.ref_make(cap0)
  }
}

#[doc("Number of live entries in the map.")]
pub fn size(m: HashMap[k, v]) : Int / Mutable = Mutable.ref_get(m.count)

#[doc("True when the map has no entries.")]
pub fn is_empty(m: HashMap[k, v]) : Bool / Mutable = Mutable.ref_get(m.count) == 0

#[doc("Returns the value bound to `key`, or `None` when absent.")]
pub fn get(m: HashMap[k, v], key: k) : Option[v] / Mutable = {
  let arr = Mutable.ref_get(m.buckets)
  let cap = Mutable.ref_get(m.cap)
  chain_get(arr[bucket_index(hash(key), cap)], key)
}

#[doc("True when `key` has a binding in the map.")]
pub fn contains(m: HashMap[k, v], key: k) : Bool / Mutable = match get(m, key) {
  Some(_) -> true
  None    -> false
}

#[doc("Inserts or replaces the binding for `key` in place, growing the table when the load factor is exceeded.")]
pub fn put(m: HashMap[k, v], key: k, value: v) : Unit / Mutable = {
  let arr = Mutable.ref_get(m.buckets)
  let cap = Mutable.ref_get(m.cap)
  let i = bucket_index(hash(key), cap)
  let res = chain_put(arr[i], key, value)
  arr[i] := res.fst
  if not res.snd {
    Mutable.ref_set(m.count, Mutable.ref_get(m.count) + 1)
    maybe_grow(m)
  }
}

#[doc("Removes `key`'s binding in place; a no-op when `key` is absent.")]
pub fn remove(m: HashMap[k, v], key: k) : Unit / Mutable = {
  let arr = Mutable.ref_get(m.buckets)
  let cap = Mutable.ref_get(m.cap)
  let i = bucket_index(hash(key), cap)
  let res = chain_remove(arr[i], key)
  arr[i] := res.fst
  if res.snd {
    Mutable.ref_set(m.count, Mutable.ref_get(m.count) - 1)
  }
}

#[doc("Returns all entries as `Pair`s in unspecified (bucket) order.")]
pub fn to_pairs(m: HashMap[k, v]) : [Pair[k, v]] / Mutable = {
  let arr = Mutable.ref_get(m.buckets)
  let cap = Mutable.ref_get(m.cap)
  collect_buckets(arr, 0, cap, [])
}

#[doc("Returns the keys in unspecified order.")]
pub fn keys(m: HashMap[k, v]) : [k] / Mutable =
  list.map(to_pairs(m), (p) => p.fst)

#[doc("Returns the values in unspecified order.")]
pub fn values(m: HashMap[k, v]) : [v] / Mutable =
  list.map(to_pairs(m), (p) => p.snd)

# Build a fresh table from pairs; duplicate keys collapse to the last.
fn from_pairs_loop(ps: [Pair[k, v]], acc: HashMap[k, v]) : Unit / Mutable = match ps {
  []           -> ()
  [p, ...rest] -> { put(acc, p.fst, p.snd); from_pairs_loop(rest, acc) }
}

#[doc("Builds a fresh hash map from pairs; on duplicate keys the later pair wins.")]
pub fn from_pairs(ps: [Pair[k, v]]) : HashMap[k, v] / Mutable = {
  let m = empty()
  from_pairs_loop(ps, m)
  m
}

# Left-biased merge: fold `b` into `a`, `a` wins on conflict. Mutates `a`.
fn merge_loop(ps: [Pair[k, v]], acc: HashMap[k, v]) : Unit / Mutable = match ps {
  []           -> ()
  [p, ...rest] -> {
    if not contains(acc, p.fst) { put(acc, p.fst, p.snd) }
    merge_loop(rest, acc)
  }
}

#[doc("Folds `b` into `a` in place (left-biased): `a`'s value is kept on any key conflict.")]
pub fn merge(a: HashMap[k, v], b: HashMap[k, v]) : Unit / Mutable =
  merge_loop(to_pairs(b), a)

# ---- Pipe convention exports ------------------------------------
#
# `HashMap[k, v]` participates in `|`, `||`, `|?` via `map`, `flat_map`,
# `filter`. Elements are `Pair[k, v]` (consistent with `Map`). The ops
# build a fresh table and carry `/ Mutable` (they read the source).

# Insert every pair into a fresh table; duplicate keys collapse to the
# last occurrence (`put` overwrites), matching `Map.map` semantics.
fn hm_collect(ps: [Pair[k, v]], acc: HashMap[k, v]) : Unit / Mutable = match ps {
  []           -> ()
  [p, ...rest] -> { put(acc, p.fst, p.snd); hm_collect(rest, acc) }
}

#[doc("""
Pair-shaped element transform into a fresh hash map: each pair becomes
a new pair, possibly with a different value type. Duplicate output keys
collapse to the last occurrence.
""")]
pub fn map(m: HashMap[k, v], f: (Pair[k, v]) -> Pair[k, w] / e) : HashMap[k, w] / Mutable + e = {
  let out = empty()
  hm_collect(list.map(to_pairs(m), f), out)
  out
}

#[doc("""
Pair-shaped flat-map: each input pair produces a sub-map; the sub-maps
are folded together left-to-right with `merge` semantics (earlier
sub-maps' keys win on conflict, consistent with `merge`).
""")]
pub fn flat_map(m: HashMap[k, v], f: (Pair[k, v]) -> HashMap[k2, v2] / e) : HashMap[k2, v2] / Mutable + e = {
  let out = empty()
  hm_flat_map_loop(to_pairs(m), f, out)
  out
}

fn hm_flat_map_loop(ps: [Pair[k, v]], f: (Pair[k, v]) -> HashMap[k2, v2] / e,
                    acc: HashMap[k2, v2]) : Unit / Mutable + e = match ps {
  []           -> ()
  [p, ...rest] -> { merge(acc, f(p)); hm_flat_map_loop(rest, f, acc) }
}

#[doc("""
Keeps the pairs for which `p` returns true, in a fresh hash map.
Element shape is `Pair[k, v]`, consistent with `map` and `Map.filter`.
""")]
pub fn filter(m: HashMap[k, v], p: (Pair[k, v]) -> Bool / e) : HashMap[k, v] / Mutable + e = {
  let out = empty()
  hm_collect(list.filter(to_pairs(m), p), out)
  out
}
