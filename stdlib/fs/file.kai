#[doc("""
File-level wrappers on top of the prelude `read_file` / `write_file`
builtins. Module path: `import fs.file`.

Bare `read_file` / `write_file` stay bound to the `Result`-returning
prelude builtins; the wrappers here are the panicking, ergonomic
surface, reached qualified (`file.read`).
""")]

#[doc("""
Read the entire file at `path` and return its contents as a
`String`. Panics on any I/O failure (file missing, permission
denied, read short). Use the prelude `read_file(path)` directly
when you want to handle errors.
""")]
pub fn read(path: String) : String / File =
  match read_file(path) {
    Ok(s) -> s
    Err(e) -> panic(string_concat("file.read: ", e))
  }

#[doc("""
Write `content` to `path`, overwriting any existing contents.
Panics on any I/O failure. Use the prelude `write_file(path, c)`
directly when you want to handle errors.
""")]
pub fn write(path: String, content: String) : Unit / File =
  match write_file(path, content) {
    Ok(_)  -> ()
    Err(_) -> panic("file.write: write failed")
  }

#[doc("""
Append `content` to the end of `path`. Creates the file when it
does not exist by writing only `content`. Panics on any I/O
failure.

This is a read-modify-write polyfill — it is **not atomic** and
**not safe under concurrent writers**.
""")]
pub fn append(path: String, content: String) : Unit / File =
  match read_file(path) {
    Ok(existing) -> write(path, string_concat(existing, content))
    Err(_)       -> write(path, content)
  }

# The wrappers (`exists`/`delete`/`rename`) call the `file_`-prefixed
# prelude builtins directly without self-recursing, since the short
# wrapper names do not shadow the prefixed builtins.

#[doc("True when `path` exists on the filesystem.")]
pub fn exists(path: String) : Bool / File =
  file_exists(path)

#[doc("Deletes the file at `path`, returning `Err(message)` on failure.")]
pub fn delete(path: String) : Result[String, Unit] / File =
  file_delete(path)

#[doc("Renames (or moves) `from` to `to`, returning `Err(message)` on failure.")]
pub fn rename(from: String, to: String) : Result[String, Unit] / File =
  file_rename(from, to)

#[doc("""
Read the file at `path` as a raw `Array[Byte]` buffer, returning
`Err(message)` on failure.

Round-trips arbitrary bytes (including 0x00 and 0xFF) that the
String-based `read_file` cannot carry through interpolation.
""")]
pub fn read_bytes(path: String) : Result[String, Array[Byte]] / File =
  file_read_bytes(path)

#[doc("Writes the raw byte buffer to `path` (truncating any existing file), returning `Err(message)` on failure.")]
pub fn write_bytes(path: String, buf: Array[Byte]) : Result[String, Unit] / File =
  file_write_bytes(path, buf)
