fn sha512_big_sigma0(x: Int) : Int =
  bit_xor(bit_xor(sha_rotr64(x, 28), sha_rotr64(x, 34)), sha_rotr64(x, 39))

fn sha512_big_sigma1(x: Int) : Int =
  bit_xor(bit_xor(sha_rotr64(x, 14), sha_rotr64(x, 18)), sha_rotr64(x, 41))

fn sha512_small_sigma0(x: Int) : Int =
  bit_xor(bit_xor(sha_rotr64(x, 1), sha_rotr64(x, 8)), sha_shr64(x, 7))

fn sha512_small_sigma1(x: Int) : Int =
  bit_xor(bit_xor(sha_rotr64(x, 19), sha_rotr64(x, 61)), sha_shr64(x, 6))

# Same window protocol as SHA-256, but 80 rounds and 64-bit words.
fn sha512_extend_loop(window: [Int], remaining: Int, acc_rev: [Int]) : [Int] = {
  if remaining == 0 { list_reverse(acc_rev) }
  else {
    let w_tm16 = sha_word_at(window, 0)
    let w_tm15 = sha_word_at(window, 1)
    let w_tm7  = sha_word_at(window, 9)
    let w_tm2  = sha_word_at(window, 14)
    let wt = sha_add64_4(sha512_small_sigma1(w_tm2), w_tm7,
                         sha512_small_sigma0(w_tm15), w_tm16)
    sha512_extend_loop(sha_append1(sha_drop1(window), wt),
                       remaining - 1, [wt, ...acc_rev])
  }
}

fn sha512_extend(w0_15: [Int]) : [Int] =
  list_append(w0_15, sha512_extend_loop(w0_15, 64, []))

fn sha512_round(s: Sha512State, k: Int, w: Int) : Sha512State = {
  let t1 = sha_add64_5(s.h, sha512_big_sigma1(s.e),
                       sha_ch(s.e, s.f, s.g), k, w)
  let t2 = sha_add64(sha512_big_sigma0(s.a), sha_maj(s.a, s.b, s.c))
  Sha512State {
    a: sha_add64(t1, t2),
    b: s.a, c: s.b, d: s.c,
    e: sha_add64(s.d, t1),
    f: s.e, g: s.f, h: s.g
  }
}

fn sha512_rounds(s: Sha512State, ws: [Int], ks: [Int]) : Sha512State = match ws {
  []         -> s
  [w, ...wt] -> match ks {
    []         -> s
    [k, ...kt] -> sha512_rounds(sha512_round(s, k, w), wt, kt)
  }
}

fn sha512_compress_block(s: Sha512State, block_bytes: [Int]) : Sha512State = {
  let w_init = sha_bytes_to_words64(block_bytes)
  let w_full = sha512_extend(w_init)
  let s2     = sha512_rounds(s, w_full, sha512_k())
  Sha512State {
    a: sha_add64(s.a, s2.a), b: sha_add64(s.b, s2.b),
    c: sha_add64(s.c, s2.c), d: sha_add64(s.d, s2.d),
    e: sha_add64(s.e, s2.e), f: sha_add64(s.f, s2.f),
    g: sha_add64(s.g, s2.g), h: sha_add64(s.h, s2.h)
  }
}

# SHA-512 padding: same shape as SHA-256 but with 128-byte blocks
# and a 16-byte (128-bit) length field. We only support inputs
# whose bit-length fits in 64 bits (the upper 8 bytes are always
# zero). Any [Int] under ~2 EiB satisfies this — a hard ceiling
# for any practical kaikai program.
fn sha512_finalize_pad(partial: [Int], total_bytes: Int) : [Int] = {
  let part_len = sha_byte_len(partial)
  let total_bits = total_bytes * 8
  let after_one = list_append(partial, [128])
  let used = part_len + 1
  # length field is 16 bytes; align such that after appending it
  # the total is a multiple of 128. So zero-pad to length 112 mod 128.
  let target_zero_block = if part_len < 112 { 112 - used } else { 112 + 128 - used }
  let zero_pad = sha_zeros_loop(target_zero_block, [])
  let length_field = list_append(sha_zeros_loop(8, []),
                                 sha_length_bytes_be(total_bits))
  list_append(list_append(after_one, zero_pad), length_field)
}

fn sha512_drive(s: Sha512State, bs: [Int], total_bytes: Int) : Sha512State = {
  match sha_take_n(bs, 128) {
    SplitOk(block, rest) ->
      sha512_drive(sha512_compress_block(s, block), rest, total_bytes)
    SplitShort(partial)  -> {
      let padded = sha512_finalize_pad(partial, total_bytes)
      sha512_drive_padded(s, padded)
    }
  }
}

fn sha512_drive_padded(s: Sha512State, padded: [Int]) : Sha512State =
  match sha_take_n(padded, 128) {
    SplitOk(block, rest) ->
      sha512_drive_padded(sha512_compress_block(s, block), rest)
    SplitShort(_)        -> s
  }

fn sha512_pack_digest(s: Sha512State) : [Int] = {
  let r0 = sha_word64_to_bytes_be(s.a, [])
  let r1 = sha_word64_to_bytes_be(s.b, r0)
  let r2 = sha_word64_to_bytes_be(s.c, r1)
  let r3 = sha_word64_to_bytes_be(s.d, r2)
  let r4 = sha_word64_to_bytes_be(s.e, r3)
  let r5 = sha_word64_to_bytes_be(s.f, r4)
  let r6 = sha_word64_to_bytes_be(s.g, r5)
  let r7 = sha_word64_to_bytes_be(s.h, r6)
  list_reverse(r7)
}

pub fn sha512(bytes: [Int]) : [Int] = {
  let total = sha_byte_len(bytes)
  sha512_pack_digest(sha512_drive(sha512_initial(), bytes, total))
}
