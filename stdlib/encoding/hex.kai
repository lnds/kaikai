# stdlib/encoding/hex.kai — hexadecimal encoding/decoding.
#
# Pure functional. Encoders emit lowercase; decoders accept both
# upper- and lowercase. No `0x` prefix is added or required.
#
# Function set (flat-prefix until m14 namespaced migration):
#
#   pub fn hex_encode(bs: [Int]) : String
#   pub fn hex_decode(s: String) : Option[[Int]]
#   pub fn hex_from_int(n: Int) : String
#   pub fn hex_to_int(s: String) : Option[Int]
#
# `hex_encode` / `hex_decode` operate on `[Int]` byte lists.
# `hex_from_int` / `hex_to_int` operate on a non-negative Int and
# its hex string representation respectively. Negative ints are not
# supported in v1 (the natural representation depends on a fixed
# width which kaikai's Int does not pin); pass None back from
# `hex_to_int` if the input parses to a value that overflows or
# contains invalid characters.

# ---- Alphabet ----------------------------------------------------

fn hex_alpha() : String = "0123456789abcdef"

fn hex_digit(n: Int) : String = string_slice(hex_alpha(), n, 1)

# ---- Byte encoding -----------------------------------------------

fn hex_encode_loop(bs: [Int], acc: String) : String = match bs {
  []           -> acc
  [b, ...rest] -> {
    let hi = hex_digit((b / 16) % 16)
    let lo = hex_digit(b % 16)
    hex_encode_loop(rest, string_concat(acc, string_concat(hi, lo)))
  }
}

pub fn hex_encode(bs: [Int]) : String = hex_encode_loop(bs, "")

# ---- Byte decoding -----------------------------------------------

# Decode a single hex character to a 4-bit value. Accepts both
# `0-9 a-f A-F`. None on anything else.
fn hex_char_value(c: Char) : Option[Int] = {
  if ch_is_digit(c) { Some(char_to_int(c) - char_to_int('0')) }
  else if c >= 'a' and c <= 'f' { Some(char_to_int(c) - char_to_int('a') + 10) }
  else if c >= 'A' and c <= 'F' { Some(char_to_int(c) - char_to_int('A') + 10) }
  else { None }
}

# Walk the input string two chars at a time. Odd-length strings
# return None — there is no convention for which side gets the
# implicit zero, so we refuse to guess.
fn hex_decode_loop(s: String, i: Int, acc: [Int]) : Option[[Int]] = {
  let n = string_length(s)
  if i >= n { Some(list_reverse(acc)) }
  else if i + 1 >= n { None }
  else {
    match char_at(s, i) {
      None     -> None
      Some(ch) -> match hex_char_value(ch) {
        None     -> None
        Some(hi) -> match char_at(s, i + 1) {
          None     -> None
          Some(cl) -> match hex_char_value(cl) {
            None     -> None
            Some(lo) -> hex_decode_loop(s, i + 2, [(hi * 16) + lo, ...acc])
          }
        }
      }
    }
  }
}

pub fn hex_decode(s: String) : Option[[Int]] = hex_decode_loop(s, 0, [])

# ---- Int <-> hex string ------------------------------------------

# Convert a non-negative Int to a lowercase hex string with no
# leading zeros (except for 0 itself, rendered as "0"). Equivalent
# to printf("%x") on unsigned input. Negative inputs return "0";
# v1 has no signed-hex policy.
fn hex_from_int_loop(n: Int, acc: String) : String = {
  if n == 0 { acc }
  else { hex_from_int_loop(n / 16, string_concat(hex_digit(n % 16), acc)) }
}

pub fn hex_from_int(n: Int) : String = {
  if n <= 0 { "0" }
  else { hex_from_int_loop(n, "") }
}

# Parse a lowercase or uppercase hex string into an Int. None on
# any invalid character or empty input. The accumulator is built
# left-to-right; overflow protection beyond Int's natural range is
# not specified — for the common case of ints that fit in 63 bits
# this is fine, larger inputs may wrap.
fn hex_to_int_loop(s: String, i: Int, acc: Int) : Option[Int] = {
  if i >= string_length(s) { Some(acc) }
  else {
    match char_at(s, i) {
      None    -> None
      Some(c) -> match hex_char_value(c) {
        None    -> None
        Some(v) -> hex_to_int_loop(s, i + 1, (acc * 16) + v)
      }
    }
  }
}

pub fn hex_to_int(s: String) : Option[Int] = {
  if string_length(s) == 0 { None }
  else { hex_to_int_loop(s, 0, 0) }
}
