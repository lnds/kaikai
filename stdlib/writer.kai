#[doc("""
stdlib/writer.kai — Doc B §`Reader[T] and Writer[W]` helper.

`Writer[W]` is the write-only accumulating-output effect; the
body invokes `Writer.tell(w)` and the handler accumulates each
value in an internal `[W]` log. This module is the canonical
handler-runner Doc B mandates so users do not have to inline
`handle ... with Writer[W]([]) { ... }` at every call site.

Documented in `docs/stdlib-layout.md` §`writer`. Consumed via
`import writer` with `--path stdlib`. Auto-import wiring is a
follow-up; the driver does not yet inject it implicitly.

Requires m7b #11 (parametric effects), m7b #13 (polymorphic
user-fn signatures), m7b #14 (lambda effect rows). All three
landed before this module.
""")]

#[doc("""
Run `body` under a `Writer[W]` handler that accumulates every
`Writer.tell(w)` call into an internal `[W]` log, returning
the final log when the body completes. Unlike Doc B's
`(S, [W])` shape, this returns just `[W]` because kaikai does
not yet have a tuple type at the surface; harvest the body's
return value via `var` or a closure if needed.
""")]
pub fn with_writer[W](body: () -> Unit / Writer[W]) : [W] = {
  handle {
    body()
  } with Writer[W]([]) {
    tell(w, resume) -> resume((), list_append(log, [w]))
    return(x)       -> { let _ = x; log }
  }
}
