# issue #645 — asymmetry preservation. `logger` declares `/ Stdout`,
# so its scheme carries a closed `{Stdout}` row — no phantom row
# elaboration. Passing it where the slot expects `(String) -> Unit`
# (pure) must still fail. Pure → effectful lifts; effectful → pure
# never does.

fn logger(s: String) : Unit / Stdout = print(s)

fn callback_pure(f: (String) -> Unit, s: String) : Unit = f(s)

fn main() : Unit / Stdout = callback_pure(logger, "hi")
