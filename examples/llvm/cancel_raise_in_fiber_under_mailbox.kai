# Issue #582 regression: `Cancel.raise()` from a fiber spawned under a
# mailboxed parent segfaulted on the LLVM backend because
# `kai_main_install_defaults` did not push a default Cancel handler
# evidence node, leaving `kaix_evidence_lookup_handler("Cancel")`
# returning NULL. The `raise` op then dereferenced the null evidence
# slot and crashed two frames deep in the trampoline.
#
# The fix at stage2/compiler.kai installs the Cancel default handler
# (one op, `raise`, wired to `kai_default_cancel_raise` in
# stage0/runtime.h) alongside the other builtin defaults. The C
# backend has always installed Cancel via the AST-derived
# `default_setups_for`; this fixture exercises the parity through
# tools/test-llvm-driver.sh, which builds it with both backends and
# diffs the combined stdout+stderr.
#
# Both backends now print the two `Stdout.print` lines, the child's
# `Cancel.raise()` unwinds its fiber, the parent stays parked on
# `Actor.receive()`, and the runtime detects the deadlock and exits
# with the same `kai: fiber finished … deadlock` banner. Pre-fix on
# LLVM: SIGSEGV (exit 139).

import actor
import spawn

fn main_inner() : Unit / Actor[String] + Spawn + Cancel + Console = {
  let _ = spawn.spawn(() => {
    Stdout.print("child: about to raise")
    Cancel.raise()
  })
  Stdout.print("main: parking on receive")
  let r = Actor.receive()
  Stdout.print("main: got " ++ r)
}

fn main() : Int / Console + Spawn + Cancel = {
  with_mailbox { main_inner() }
  0
}
