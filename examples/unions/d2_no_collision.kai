# issue #187 phase 2 — the D2-collision escape hatch.
# Pre-declaring `type Foo = ...` once turns every subsequent `Foo` in
# a union body into a *reference* to the existing type, not an
# implicit declaration. This is the single fix the D2 help line
# directs the user toward when `examples/unions/d2_collision.kai`
# fails. Both `A` and `B` reuse the pre-declared `Foo` without
# tripping the resolver.

type Foo = MkFoo
type A = Foo | Bar
type B = Foo | Baz

fn main() : Int = 0
