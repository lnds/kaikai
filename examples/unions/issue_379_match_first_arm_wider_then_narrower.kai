# issue #379 — symmetry-of-arms guard. Pre-fix this case worked by
# accident: the first arm pinned `body_ty` to the wider
# `Result[ErrorAB, _]` and the second arm's narrower `Result[ErrorA, _]`
# upcast cleanly via the existing `union_upcast_ok` rule. The bug was
# the asymmetry — the first arm could not be the narrow one.
# Post-fix both orderings work uniformly because `body_ty` is the
# annotated return type, not the first arm's synthesised type.

type ErrorA  = NoDefinida(String)
type ErrorB  = DivCero
type ErrorAB = ErrorA | ErrorB

fn classify(xs: [Real]) : Result[ErrorAB, Real] =
  match xs {
    [v, ...rest] -> Ok(v)
    []           -> Err(NoDefinida("empty"))
  }

fn main() : Int / Stdout {
  match classify([]) {
    Ok(_)  -> Stdout.print("ok")
    Err(_) -> Stdout.print("err")
  }
  0
}
