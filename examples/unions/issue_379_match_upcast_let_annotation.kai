# issue #379 — second propagation site: an annotated `let` whose RHS
# is a `match`. The let-annotation drives `check_match` so the first
# arm's narrower `Err(NoDefinida(...))` (`Result[ErrorA, _]`) implicitly
# upcasts to the binder's declared `Result[ErrorAB, Real]`. Without
# the bidirectional check the synthesised RHS pinned to
# `Result[ErrorA, _]` and the post-hoc unify against `Result[ErrorAB, Real]`
# rejected the second arm's `Ok(Real)` produced via the wider Result.

type ErrorA  = NoDefinida(String)
type ErrorB  = DivCero
type ErrorAB = ErrorA | ErrorB

fn main() : Int / Stdout {
  let xs : [Real] = []
  let r : Result[ErrorAB, Real] = match xs {
    []           -> Err(NoDefinida("z"))
    [v, ...rest] -> Ok(v)
  }
  match r {
    Ok(_)  -> Stdout.print("ok")
    Err(_) -> Stdout.print("err")
  }
  0
}
