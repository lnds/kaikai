# redundant_if_bool: an if/else whose both branches are nothing but the
# boolean literals `true`/`false` is the condition itself (or its
# negation). The conditional adds no value over `c` / `not c`.

fn is_pos(n: Int) : Bool = if n > 0 { true } else { false }

fn is_nonpos(n: Int) : Bool = if n > 0 { false } else { true }

fn is_pos_blocky(n: Int) : Bool = if n > 0 { { true } } else { { false } }

fn main() : Int = 0
