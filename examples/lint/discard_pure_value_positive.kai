# discard_pure_value: a non-Unit PURE value dropped in statement
# position is dead code. `a_pure_int()` returns Int with no effect, and
# its result is discarded before the block's `c_unit()` tail, so the
# linter reports it. Precedent: OCaml Warning 10.

fn a_pure_int() : Int = 41 + 1

fn c_unit() : Unit = ()

fn run() : Unit {
  a_pure_int()
  c_unit()
}

fn main() : Int {
  run()
  0
}
