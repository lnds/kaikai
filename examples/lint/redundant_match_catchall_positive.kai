# redundant_match_catchall: a `match` with a single unguarded arm whose
# pattern is `_` or a bare binding never destructures. `match e { _ ->
# body }` is `body`; `match e { x -> body }` is `let x = e ... body`.
# Either way the match is ceremony around a direct expression.

fn answer(n: Int) : Int = match n {
  _ -> 42
}

fn bumped(n: Int) : Int = match n {
  x -> x + 1
}

fn main() : Int = answer(0) + bumped(1)
