# effect_ffi_without_extern: a public signature that declares `/ Ffi`
# but whose body calls no extern function. The `/ Ffi` is dead weight —
# either the body lost its FFI call in a refactor, or the row was copied
# from a neighbour. A specialised face of effect_over_declared, with its
# own lint id so it can be allowed / denied on its own.

pub fn fake_ffi(n: Int) : Int / Ffi = n + 1

pub fn also_fake() : Int / Ffi = 0

fn main() : Int = 0
