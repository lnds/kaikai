# dead_code_unused_priv: a private root-file function referenced nowhere
# in the file is dead code. The compiler does not warn about an unused
# private function, so the linter owns this check.

fn unused_helper(n: Int) : Int = n * 2

fn also_unused(s: String) : Int = string_length(s)

pub fn api(n: Int) : Int = n + 1

fn main() : Int = api(5)
