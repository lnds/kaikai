# effect_over_declared: a public signature whose declared effect row
# carries a label its own body never demands. The compiler accepts an
# over-broad row, so the linter owns this check. Bias: only closed,
# monomorphic rows fire, and an effect reached through a call (whose row
# the typer stamped) counts as used.

pub effect Logger { log(s: String) : Unit }

pub fn over_declared() : Int / Logger = 1

pub fn also_over(n: Int) : Int / Logger = n + 1

fn main() : Int = 0
