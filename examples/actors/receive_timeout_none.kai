# issue #638 — receive_timeout on an empty mailbox parks on the timer
# wheel and returns None when the deadline elapses with no message.
# A single fiber suffices: the reactor's own timer wakes the park.

import actor
import time

type Msg = Ping

fn main() : Int / Spawn + Stdout = with_mailbox {
  let got : Option[Msg] = receive_timeout(millis(5))
  match got {
    Some(_) -> { Stdout.print("some"); 1 }
    None    -> { Stdout.print("none"); 0 }
  }
}
