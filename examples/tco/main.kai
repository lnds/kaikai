# Issue #37 fixture — proves the C emitter's self-tail-call rewrite
# produces constant C-stack space for deep tail recursion.
#
# Without TCO, each call frame is ~50–80 B on x86_64 -O0; 50 M
# frames is ~3 GiB, far past Linux's 8 MiB main-thread default.
# With the issue #37 `goto _kai_<sym>_entry` rewrite, the
# C-stack stays O(1) and the program exits cleanly with a small
# `ulimit -s`. Stage 2's emit is what we are exercising — kaic2
# itself was built from stage 1's emit (no rewrite), so this
# fixture tests the *output* of kaic2, not kaic2 itself.

fn count_down(n: Int) : Int =
  if n == 0 { 0 }
  else { count_down(n - 1) }

fn main() {
  print("count_down(50_000_000) = #{int_to_string(count_down(50_000_000))}")
}
