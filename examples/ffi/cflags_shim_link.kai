# The shim rides CFLAGS (`kai info ffi`): CFLAGS="cflags_shim.c" kai build.
# The wrapper must route that `.c` to the link line — as an extra input on a
# `-c … -o` compile, clang rejects it ("cannot specify -o when generating
# multiple output files"). Exercised through bin/kai, not raw kaic2.

extern "C" fn my_double(x: Int) : Int / Ffi

pub fn main() : Unit / Stdout + Ffi = {
  Stdout.print("#{my_double(21)}")
}
