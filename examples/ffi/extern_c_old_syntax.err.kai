# Issue #260 — the legacy `[<extern_c>] axiom` syntax is removed
# (hard rename, not a deprecated alias). Source using the old form
# must be rejected at parse time with a migration error pointing
# at the new `extern "C" fn` syntax.

[<extern_c>]
axiom puts(s: String) : Int / Ffi

fn main() : Unit / Ffi = {
  let _ = puts("never reached")
}
