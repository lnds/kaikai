# P3 (docs/native-codegen-perf-plan.md) — MIXED raw/boxed signature.
#
# `insert(t: Tree, k: Int, depth: Int)` is the balance-shape case: a boxed
# Tree param alongside raw Int k/depth (a PARTIAL raw mask). The native
# backend must emit `define ptr @insert(ptr, i64, i64)` — Tree as `ptr`,
# k/depth as raw `i64`. Because `insert` recurses MODULO-CONS
# (`Node(insert(l, …), v, r)`), this exercises the TRMC back-edge under a
# partial raw mask: a boxed `ptr` store into the raw `i64` k/depth allocas
# would silently miscompile (native returned garbage before the TRMC
# back-edge was made slot-aware). The harness diffs native vs the C-direct
# oracle, guarding that mixed mask + TRMC re-loop.
type Tree = Leaf | Node(Tree, Int, Tree)

fn insert(t: Tree, k: Int, depth: Int) : Tree =
  if depth == 0 { t }
  else { match t {
    Leaf -> Node(Leaf, k, Leaf)
    Node(l, v, r) ->
      if k < v { Node(insert(l, k, depth - 1), v, r) }
      else { Node(l, v, insert(r, k, depth - 1)) }
  } }

fn sum_tree(t: Tree) : Int = match t {
  Leaf -> 0
  Node(l, v, r) -> sum_tree(l) + v + sum_tree(r)
}

fn build(t: Tree, k: Int, n: Int) : Tree =
  if n == 0 { t }
  else { build(insert(t, k * 31 + n, 8), k + 1, n - 1) }

fn main() : Unit / Stdout = {
  Stdout.print("#{sum_tree(build(Leaf, 1, 50))}")
}
