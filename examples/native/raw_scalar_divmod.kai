# P4 (docs/native-codegen-perf-plan.md) — raw scalar `/` and `%`.
#
# P1-P3 left Int `/` and `%` BOXED in the native backend (`kaix_div` /
# `kaix_mod` per use) while `+ - *` lowered raw. This fixture exercises the
# raw `sdiv` / `srem` the P4 patch emits: both helpers take raw Int params
# and a raw Int return, and divide by a RUNTIME-derived value so the
# optimiser cannot fold either operation to a magic-multiply — a literal
# `sdiv`/`srem` must reach the object. The native lowering mirrors the
# C-direct oracle, which emits a bare `a / b` (accepting the `/0` and
# `INT_MIN/-1` UB as a separate concern); the harness diffs native stdout +
# exit vs that oracle, guarding raw-divmod parity.
#
# `gcd` is the `%`-with-variable-divisor case (Euclid); `divsum` is the
# `/`-with-variable-divisor case (a falling divisor each step). `signed` runs
# a NEGATIVE dividend through both so the signed `srem`/`sdiv` truncate toward
# zero exactly as C does (`-7 / 3 == -2`, `-7 % 3 == -1`). No divisor is a
# compile-time constant, so O2 keeps the real division rather than a
# magic-multiply.
fn gcd(a: Int, b: Int) : Int =
  if b == 0 { a }
  else { gcd(b, a % b) }

fn divsum(i: Int, acc: Int) : Int =
  if i == 0 { acc }
  else { divsum(i - 1, acc + 1000000 / i) }

fn signed(a: Int, b: Int) : Int = (a / b) * 100 + (a % b)

fn main() : Unit / Stdout = {
  Stdout.print("#{gcd(1071, 462)}")
  Stdout.print("#{divsum(1000, 0)}")
  Stdout.print("#{signed(0 - 7, 3)}")
}
