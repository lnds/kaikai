# P3 (docs/native-codegen-perf-plan.md) — raw scalar params.
#
# `sum_loop(i, acc)` is a UFn with TWO raw Int params + a raw Int return.
# The native backend must emit `define i64 @sum_loop(i64, i64)` (not the
# all-boxed `ptr @sum_loop(ptr, ptr)`): the body reads each param raw (no
# `kaix_int_field` per use), the self-tail-call back-edge re-stores them
# raw (no `kaix_int` per iteration), and the return is raw. With the body
# already unboxed (P1) and the runtime inlined (P2), the whole loop is
# native arithmetic that O2 amplifies to C parity. `+ - *` only (no `/`,
# which P1 keeps boxed) so the loop is wholly raw.
#
# The harness diffs native stdout + exit vs the C-direct oracle; this
# guards correctness of the raw signature + raw TCO back-edge.
fn sum_loop(i: Int, acc: Int) : Int =
  if i == 0 { acc }
  else { sum_loop(i - 1, acc + (i * i - i)) }

fn main() : Unit / Stdout = {
  Stdout.print("#{sum_loop(1000, 0)}")
}
