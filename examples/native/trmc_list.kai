# Native-walk fixture (KIR Lane 1.2 Parte B, TCO/TRMC subset): a
# tail-recursion-modulo-cons list transform. `[h + 1, ...map_inc(t)]`
# builds the result list with the recursive call INSIDE the cons cell —
# not strict tail position. The frontend rewrites it to a `KTrmcStep`
# (cons site) + `KTrmcApply` (nil terminal); the native walk lowers them
# to a constructor-context goto-loop (`emit_native_trmc.kai`) so the
# recursion runs in O(1) stack instead of one frame per element.
#
# `build` is tail-recursive (ordinary TCO); `map_inc` is the TRMC case;
# `lenacc` is tail-recursive. Only `map_inc` exercises the cctx loop. A
# count of 4000 is well past the ~65K-frame overflow of the pre-TRMC
# stack-growing lowering at a small fixture size, while staying fast; the
# exit code is `count % 256` (4000 -> 160) so the harness diffs it vs
# C-direct end-to-end (both must agree the list was fully built).

fn build(n : Int, acc : [Int]) : [Int] =
  if n == 0 { acc } else { build(n - 1, [n, ...acc]) }

fn map_inc(xs : [Int]) : [Int] =
  match xs {
    [] -> []
    [h, ...t] -> [h + 1, ...map_inc(t)]
  }

fn lenacc(xs : [Int], a : Int) : Int =
  match xs {
    [] -> a
    [_, ...t] -> lenacc(t, a + 1)
  }

fn main() : Unit {
  let xs = build(4000, [])
  let ys = map_inc(xs)
  exit(lenacc(ys, 0))
}
