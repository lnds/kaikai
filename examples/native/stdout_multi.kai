# KIR Lane 1.2 — two `Stdout.print` calls through the SAME installed
# default handler, exercising the evidence-lookup + op dispatch path more
# than once per program. Stdout is the only builtin in main's row, so
# exactly one default is installed and torn down (a single-effect
# install/teardown). The harness diffs the concatenated stdout against
# C-direct.
fn main() : Unit / Stdout = {
  Stdout.print("first line\n")
  Stdout.print("second line\n")
}
