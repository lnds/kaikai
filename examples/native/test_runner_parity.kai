# Regression fixture for #950: the native backend runs `test` blocks.
# `kai test` on this file must produce the SAME pass/fail summary and
# exit code on the native backend as on the C oracle — a passing test, a
# failing assertion (caught, not a crash), and a test that runs AFTER the
# failure (proving the setjmp landing pad lets the run continue).

fn double(n: Int) : Int = n * 2

fn main() : Int = 0

test "double doubles" {
  assert double(0) == 0
  assert double(7) == 14
}

test "this assertion fails" {
  assert double(7) == 99
}

test "runs after the failure" {
  assert double(3) == 6
}
