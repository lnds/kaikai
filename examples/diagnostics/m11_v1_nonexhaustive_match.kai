# m11 v1 Template 2 — non-exhaustive match on a sum type.
# `Color` has variants Red, Green, Blue; we cover only Red and
# Green. The diagnostic should name the type, list the missing
# variant, list what's covered, and propose both an arm and a
# wildcard.

type Color = Red | Green | Blue

fn name_of(c: Color) : String = match c {
  Red   -> "red"
  Green -> "green"
}

fn main() : Int = {
  print(name_of(Red))
  0
}
