# m11 v1.x Template 5 — multiple effects missing from the same
# undeclared body. `helper` performs both `Stdout` (from `print`)
# and `Stderr` (from `eprint`); the diagnostic should fire once
# per missing effect with the same m11 v1 shape so an editor can
# present them as parallel suggestions.

fn helper() : Int = {
  print("a")
  eprint("b")
  0
}

fn main() : Int = helper()
