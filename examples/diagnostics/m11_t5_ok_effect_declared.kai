# m11 v1.x Template 5 regression — when the enclosing function's
# declared row already covers every effect the body performs, the
# diagnostic must NOT fire. Positive fixture (no .err.expected) —
# compiles + runs cleanly.

fn say(s: String) : Unit / Stdout = print(s)

fn main() : Int / Stdout = {
  say("hi")
  0
}
