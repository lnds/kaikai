# m11 v1.x Template 4 — wrong number of arguments (too many).
# `add` expects 2 args; the call site passes 3. The diagnostic
# should name the callee, surface the declared arity and the
# observed count, and suggest removing the extras.

fn add(x: Int, y: Int) : Int = x + y

fn main() : Int = {
  let n = add(1, 2, 3)
  print(int_to_string(n))
  0
}
