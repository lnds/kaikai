# m11 v1 Template 2 regression — a wildcard `_` arm covers the
# missing variants. The compiler must NOT emit a non-exhaustive
# diagnostic. Positive fixture (no .err.expected).

type Color = Red | Green | Blue

fn name_of(c: Color) : String = match c {
  Red -> "red"
  _   -> "other"
}

fn main() : Int = {
  print(name_of(Blue))
  0
}
