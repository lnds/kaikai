# m11 v1 Template 1 — type mismatch in argument N of `fn`.
# Negative fixture: `add` expects (Int, Int) -> Int but we pass a
# String for argument 2. The diagnostic should pinpoint argument 2,
# name the callee, and surface the callee's signature.

fn add(x: Int, y: Int) : Int = x + y

fn main() : Int = {
  let n = add(1, "hello")
  print(int_to_string(n))
  0
}
