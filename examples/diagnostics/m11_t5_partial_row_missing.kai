# m11 v1.x Template 5 — `helper` declares `Stdout` in its row,
# but the body also performs `Stderr` (via `eprint`). The
# diagnostic should NOT mention `Stdout` (it is correctly
# declared); only the truly missing `Stderr` should fire, and
# the `enclosing row:` note should surface the partial row.

fn helper() : Int / Stdout = {
  print("a")
  eprint("b")
  0
}

fn main() : Int / Stdout + Stderr = helper()
