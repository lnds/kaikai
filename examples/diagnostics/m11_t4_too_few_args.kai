# m11 v1.x Template 4 — wrong number of arguments (too few).
# `triple_sum` expects 3 args; the call site passes 2. The
# diagnostic should pinpoint the arity gap and suggest adding
# the missing argument or using `_` as a placeholder hole.

fn triple_sum(x: Int, y: Int, z: Int) : Int = x + y + z

fn main() : Int = {
  let n = triple_sum(1, 2)
  print(int_to_string(n))
  0
}
