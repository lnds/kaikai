# m11 v1.x Template 4 regression — correct arity must NOT trigger
# the diagnostic. Positive fixture (no .err.expected) — compiles +
# runs cleanly, pinning that the arity preflight does not misfire
# on matched-arity calls.

fn add(x: Int, y: Int) : Int = x + y

fn main() : Int = {
  let n = add(1, 2)
  print(int_to_string(n))
  0
}
