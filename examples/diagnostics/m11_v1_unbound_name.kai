# m11 v1 Template 3 — unbound name with did-you-mean.
# `lenght` is a typo of the in-scope `length`; the diagnostic
# should suggest `length` via Levenshtein.

fn length(xs: [Int]) : Int = list_length(xs)

fn main() : Int = {
  let xs = [1, 2, 3]
  let n = lenght(xs)
  print(int_to_string(n))
  0
}
