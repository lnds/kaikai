# Independence oracle (#962 Lane 3) — Lane 2 BENIGN baseline.
#
# Identical to adversary.kai except the protocol op is named
# `is_spacey`, which collides with no bare cross-module call inside any
# core body. The `--dump-typed-core` dump of core taken here is the
# contamination-free reference the adversary's core dump must match.

type Tok = Tok(Int)

protocol Spaceable {
  is_spacey(x: Self) : Bool
}

impl Spaceable for Tok {
  fn is_spacey(x: Tok) : Bool = match x { Tok(n) -> n == 0 }
}

fn main() : Unit / Stdout = {
  println("[" ++ trim("  hi  ") ++ "]")
  println(int_to_string(list_length(lines("a\nb\nc"))))
  println(if is_spacey(Tok(0)) { "tok-space" } else { "tok-nospace" })
}
