# Batch-isolation fixture (#962 Lane 4) — FILE B.
#
# Sibling of file_a.kai with an INCOMPATIBLE `fn tag` (String -> Int
# here, Int -> String there). Compiled standalone B is clean; in a
# batch with A, B's `tag` must resolve to B's own signature, never A's.
# See file_a.kai for the gate.

fn tag(s: String) : Int = string_length(s)

fn main() : Unit / Stdout = {
  let word = "hello"
  println("#{tag(word)}")
}
