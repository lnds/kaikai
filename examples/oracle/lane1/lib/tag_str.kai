# Independence oracle (#962 Lane 3) — Lane 1 (root_fns) probe library.
#
# A `pub fn tag` over the concrete type `String`. Paired with
# `tag_int.tag` (over `Int`), the bare `tag(...)` call inside
# `lib.driver` has two narrowing candidates the typer must
# disambiguate by first-arg type.

#[doc("Tag a String — the concrete-first-arg narrowing candidate.")]
pub fn tag(s: String) : String = "STR:" ++ s
