# Independence oracle (#962 Lane 3) — Lane 1 ADVERSARY.
#
# Defines a root `fn tag(Int)` whose bare name collides with the bare
# `tag(...)` call inside the imported `lib.driver`. Pre-cut, this root
# shadow leaks into `lib`'s typing env and shifts the resolved type of
# `lib.driver`'s `tag("hi")` node. The benign sibling is byte-identical
# except this fn is named `tagx`, which collides with nothing.
#
# Differs from benign.kai by exactly one atom: the fn name `tag` vs
# `tagx`. With the root_fns cut in place, the `--dump-typed-core` dump
# of `lib` is identical for both — core never sees the user. Revert the
# cut and the adversary's core dump diverges (or fails): RED.

import lib

#[doc("Adversarial root shadow of the bare name `lib.driver` calls.")]
fn tag(x: Int) : String = "ROOT"

fn main() : Unit / Stdout = {
  println(lib.driver())
  println(tag(0))
}
