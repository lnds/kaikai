import mid

# `consumer` uses stdlib (string_concat, list iteration) plus mid's
# API. Every layer touches stdlib without re-declaring it.
fn main() {
  let xs = mid.labels(["a", "bc", "def"])
  print(join(xs, " | "))
}

fn join(xs: [String], sep: String) : String = match xs {
  []           -> ""
  [last]       -> last
  [h, ...rest] -> string_concat(h, string_concat(sep, join(rest, sep)))
}
