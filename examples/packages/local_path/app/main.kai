# examples/packages/local_path — demonstrates a local-path dep
# resolved through `kai.toml`. The driver walks up from this file
# looking for kai.toml, parses the [dependencies] table, and
# injects `--path ../lib_greet` so kaic2 finds the `greet` module.
#
# Spec: docs/packages.md (issue #405).

import greet

fn main() {
  print(greet.greet("kaikai"))
}
