import mypkg.util

fn main() {
  # Qualified call to the package's own fn — must NOT resolve to
  # stdlib's list.length.
  print(util.length("hello"))
  # Bare stdlib still works through prelude (string_length is a
  # builtin, list.length is the stdlib qualified path).
  print(int_to_string(string_length("hello")))
}
