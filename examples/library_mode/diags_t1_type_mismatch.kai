# Issue #487 fixture — Template 1 (type mismatch in function call).
# `double` expects Int; passing a String triggers a unification failure
# whose collected Diagnostic mirrors the stderr `error: / note:` block.

fn double(x: Int) : Int = x * 2

fn main() : Int / Console {
  print(int_to_string(double("not an int")))
  0
}
