# Issue #487 fixture — Template 2 (non-exhaustive match).
# Two of the three Color variants are uncovered; the collected
# Diagnostic carries one note per missing variant, a covered list,
# and a help line proposing a fix.

type Color = Red | Green | Blue

fn name(c: Color) : String = match c {
  Red -> "red"
}

fn main() : Int / Console {
  print(name(Red))
  0
}
