# Issue #487 fixture — Template 4 (wrong number of arguments).
# `add` declares two parameters; the call site passes one. The
# preflight inside `st_unify_call` short-circuits before the generic
# unifier, so the header is "wrong number of arguments" rather than
# "type mismatch in function call".

fn add(x: Int, y: Int) : Int = x + y

fn main() : Int / Console {
  print(int_to_string(add(1)))
  0
}
