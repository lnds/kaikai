# A refinement over a dimensioned base checks the bare numeric value:
# the inserted assert compares __strip_unit(self), so the predicate's
# unitless literals type-check and a violating quantity still panics.
unit USD

fn spend(m: Real<USD> where >= 0.0) : Real<USD> = m

fn main() : Unit / Stdout {
  let paid = spend(0.0<USD> - 5.0<USD>)
  Stdout.print(show(paid))
}
