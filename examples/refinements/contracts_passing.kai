# Issue #86 v2 — happy path. Both `requires` and `ensures` hold, so
# no diagnostic is produced and the program runs to completion.
# Companion to the four runtime-panic fixtures in this directory.

fn divide(a: Int, b: Int) : Int
  requires b != 0
  ensures result * b == a
{
  a / b
}

fn main() : Unit / Stdout {
  Stdout.print("q=#{int_to_string(divide(10, 2))}")
  Stdout.print("q=#{int_to_string(divide(20, 5))}")
}
