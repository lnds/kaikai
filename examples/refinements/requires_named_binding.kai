# Issue #86 v2 — diagnostic when the predicate references a named
# parameter. The rendered `required:` line includes the binding name
# verbatim (`count >= 0`), so a reader can tell which input was the
# offender even though we do not yet print the runtime value.

fn at_least(count: Int, baseline: Int) : Int
  requires count >= 0
{
  count + baseline
}

fn main() : Unit / Stdout {
  let neg = -5
  Stdout.print("q=#{int_to_string(at_least(neg, 1))}")
}
