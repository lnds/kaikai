# Issue #86 v3 — predicate-aware diagnostic now formats Char literals.
#
# Calling `classify` with `c = '_'` violates the precondition. Pre-v3
# the rendered predicate showed `c != <expr>` because expr_show_pred
# fell through for EChar. v3 added an EChar arm that wraps the
# character in single quotes via string interpolation.

fn classify(c: Char) : String
  requires c != '_'
{
  "letter"
}

fn main() : Unit / Stdout {
  Stdout.print(classify('_'))
}
