# Issue #86 v2 — structured `requires` violation diagnostic.
#
# Calling `divide` with `b = 0` violates the precondition. The
# runtime panic must include:
#   - the clause kind (`requires`)
#   - the function name (`divide`)
#   - the rendered predicate (`b != 0`)
#   - the decl-site line/col (where the `requires` clause sits)
#
# Call-site span and the offending value at runtime are not yet
# threaded through; see docs/refinements-and-contracts.md v2 sidebar
# for the follow-up plan.

fn divide(a: Int, b: Int) : Int
  requires b != 0
{
  a / b
}

fn main() : Unit / Stdout {
  let z = 0
  Stdout.print("q=#{int_to_string(divide(10, z))}")
}
