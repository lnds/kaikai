# Issue #449 — refinement-type alias passed to a base-type function.
#
# `Probabilidad` is a refined `Real`. A function declared over `Real`
# must accept a `Probabilidad` argument transparently — the alias
# subtypes its carrier via the unifier's `TyRefineT(b, _) ⊑ b` arm.
#
# Before the fix: the alias was nominal, so passing a `Probabilidad`
# value to `real_to_string` was rejected with "expected Real, found
# Probabilidad".

type Probabilidad = Real where self >= 0.0 and self <= 1.0

fn main() : Unit / Stdout {
  let p: Probabilidad = 0.5
  Stdout.print(real_to_string(p))
}
