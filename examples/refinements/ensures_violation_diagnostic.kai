# Issue #86 v2 — structured `ensures` violation diagnostic.
#
# `bug` claims to return a positive value but actually returns 0.
# The runtime panic must include the `ensures` kind, the function
# name, the predicate text, and the decl-site line/col.

fn bug(x: Int) : Int
  ensures result > 0
{
  0
}

fn main() : Unit / Stdout {
  let y = bug(42)
  Stdout.print("q=#{int_to_string(y)}")
}
