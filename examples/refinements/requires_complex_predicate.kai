# Issue #86 v2 — structured diagnostic for a multi-conjunct
# `requires`. The whole predicate is rendered (we do not yet
# isolate which conjunct failed; that is part of the runtime-value
# follow-up tracked under #86).

fn clamp_pos(b: Int) : Int
  requires b > 0 and b < 100
{
  b
}

fn main() : Unit / Stdout {
  let z = 200
  Stdout.print("q=#{int_to_string(clamp_pos(z))}")
}
