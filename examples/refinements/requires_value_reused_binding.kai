# Issue #86 piece 2 — the offending binding is read again inside the
# body, so by emit time Perceus wraps the predicate's read of `b` in
# `__perceus_dup(b)`. The value path must unwrap that one layer to
# recover the bare ident (`contract_single_ident_node` /
# `expr_pred_ident_node`) and still forward `b`'s runtime value. This
# guards the simple-shape detector against a Perceus rewrite blanking
# the ident node — the dup wrapper would otherwise hide the `EVar`.
#
# `safe_div(a, b) : Int` is a pure-scalar UFn, so `b` is a raw-unboxed
# local; combined with the boxed-Char and boxed-Real fixtures this
# covers raw + boxed reprs under a dup-wrapped read. Calling with
# `b = 0` violates `requires b != 0`; the panic carries
# `argument b was: 0`.

fn safe_div(a: Int, b: Int) : Int
  requires b != 0
{
  let q = a / b
  q + b
}

fn zero() : Int = 0

fn main() : Unit / Stdout {
  Stdout.print("#{int_to_string(safe_div(10, zero()))}")
}
