# Issue #750 (piece-3 of #86) — base-type provenance pin.
#
# The same `!= 0`-shaped predicate as `requires_help_narrow`, but the
# offending param is declared `Int` rather than `Real`. The help line must
# read `Int where != 0`, NOT `Real where != 0`: the base type is sourced
# from the param's declared annotation in the typer/parser, not inferred
# from the literal `0` (which is ambiguous between Int and Real). This is
# the gate that distinguishes a declared-type implementation from one that
# guesses the type off the comparison literal.

fn step(n: Int) : Int
  requires n != 0
{
  100 / n
}

fn main() : Unit / Stdout {
  let z = 0
  Stdout.print("q=#{int_to_string(step(z))}")
}
