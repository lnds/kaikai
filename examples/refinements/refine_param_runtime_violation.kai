# A dynamic value flowing into a refined parameter panics at the
# callee boundary with the structured refinement diagnostic.
type NonNeg = Int where self >= 0

fn use_it(n: NonNeg) : Int = n + 1
fn passthrough(x: Int) : Int = use_it(x)

fn main() : Unit / Stdout = Stdout.print(int_to_string(passthrough(0 - 5)))
