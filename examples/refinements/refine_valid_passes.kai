# Valid values flow through refined bindings, params, and returns
# without panics; statically-proven sites insert no check.
type Percent = Real where 0.0 <= self and self <= 1.0
type NonNeg = Int where self >= 0

fn use_it(n: NonNeg) : Int = n + 1
fn passthrough(x: Int) : Int = use_it(x)
fn grow(x: Int) : NonNeg = x + 10

fn main() : Unit / Stdout {
  let ok : Percent = 0.5
  let n : NonNeg = 3
  Stdout.print(real_to_string(ok))
  Stdout.print(int_to_string(n))
  Stdout.print(int_to_string(passthrough(4)))
  Stdout.print(int_to_string(grow(1)))
}
