# i64-inline parity (#747) coherence fixture — a variant with an Int slot
# (kind-1, rides raw i64) ADJACENT to a Real slot (kind-2) and an enum slot
# (kind-3) and a pointer slot (kind-0). Proves the LLVM backend's `k == 1`
# gate packs ONLY the Int slot raw and leaves Real / enum / pointer boxed,
# so a node built by the typed ctor and read back through the match agrees
# with the C backend bit-for-bit. Before the gate was tightened, a `k != 0`
# predicate would have packed the Real slot raw at construction while the
# read fetched it boxed — silent corruption the rb-tree (Int-only) never hit.

type Tag = Lo | Hi

type Cell = MkCell(Int, Real, Tag, String)

fn cell_i(c: Cell) : Int     = match c { MkCell(i, _, _, _) -> i }
fn cell_r(c: Cell) : Real    = match c { MkCell(_, r, _, _) -> r }
fn cell_t(c: Cell) : Int     = match c { MkCell(_, _, t, _) -> match t { Lo -> 0  Hi -> 1 } }
fn cell_s(c: Cell) : String  = match c { MkCell(_, _, _, s) -> s }

# Rebuild path (exercises the typed reuse / fresh-alloc with mixed slots).
fn cell_bump(c: Cell) : Cell = match c {
  MkCell(i, r, t, s) -> MkCell(i + 1, r, t, s)
}

fn main() = {
  let c = MkCell(41, 2.5, Hi, "k")
  let d = cell_bump(c)
  println(int_to_string(cell_i(d)))
  println(real_to_string(cell_r(d)))
  println(int_to_string(cell_t(d)))
  println(cell_s(d))
}
