# Issue #1134 — terminal-fold and range-head deforestation.
#
# `[1..N] | stage |> foldl(init, combine)` is a range head feeding a map
# stage feeding a terminal fold. Fusion collapses all of it into one
# counting loop that folds `combine` over `stage(i)` for each `i` in the
# range, materialising NO list — neither the range nor the mapped list.
#
# Acceptance shape (#1134 + range addendum):
#   - a pure range-headed terminal-fold allocates zero list cells (the
#     range is a loop header, not a cons spine; the map is fused into the
#     fold);
#   - the counting loop is tail-recursive, so a 1M-wide range folds in
#     O(1) stack;
#   - selfhost (C + native) byte-identical.
#
# The fold sums `dbl(i)` over `[1..1000000]`; the result is
# `2 * (1+2+...+1000000) = 1000001000000`. With fusion the run builds no
# cons cells at all (alloc_total in single digits, all bookkeeping).

fn dbl(x: Int) : Int = x * 2
fn addr(a: Int, b: Int) : Int = a + b

fn main() : Unit / Stdout = {
  let total = [1..1000000] | dbl |> list.foldl(0, addr)
  Stdout.print(int_to_string(total))
}
