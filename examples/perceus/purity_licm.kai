# Purity attribute closure fixture (issue #1139). `heavy` is a confirmed
# memory-clean scalar fn, so the native emitter stamps `memory(none)` and
# the C emitter `KAI_CONST` on it — the optimizer may then CSE a repeated
# call and hoist a loop-invariant one. `noisy` allocates a list, so it
# stays an opaque barrier (`nounwind` only). The tier check greps the
# native IR (KAI_NATIVE_DUMP_IR) for `memory(none)` on `heavy` and its
# absence on `noisy`.

# Confirmed pure: raw-scalar arithmetic → stamped memory(none) / KAI_CONST.
fn heavy(x: Int) : Int = x * 31 + 7

# Two identical calls to a pure fn: cc -O2 / opt CSE them to one.
fn twice(k: Int) : Int = heavy(k) + heavy(k)

# A loop-invariant pure call: the optimizer may hoist `heavy(k)` out.
fn sum_loop(n: Int, acc: Int, k: Int) : Int =
  if n <= 0 { acc } else { sum_loop(n - 1, acc + heavy(k), k) }

# Allocates a list box → impure, no memory attribute.
fn noisy(x: Int) : [Int] = [x, x + 1]

pub fn main() : Unit / Io =
  print("#{twice(3)} #{sum_loop(100, 0, 5)} #{list_length(noisy(1))}")
