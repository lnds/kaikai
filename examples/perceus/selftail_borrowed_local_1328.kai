# A `let`-local read >= 2 times, every read landing in a borrowed callee
# slot, in a block whose tail is the self-tail-call: the dup-per-read rule
# nets to zero through the caller-side borrow strip, the block-exit
# collector declines (the tail still reads the local), and the post-tail
# wrap declines (it would hide the call from TCO). The per-iteration list
# was fully orphaned — free_total=0, leaked grows with the iteration
# count — until the per-path drop releases the birth ref before the goto.

type Node = Data(Int, Int) | Skip

fn peek(^ns: [Node]) : Int = match ns {
  [] -> 0
  [d, ..._rest] -> match d {
    Data(a, b) -> a + b
    Skip -> 0
  }
}

fn mk(n: Int, acc: [Node]) : [Node] =
  if n == 0 { acc } else { mk(n - 1, [Data(n * 2, n), ...acc]) }

fn spin(n: Int, acc: Int) : Int =
  if n == 0 { acc } else {
    let ns = mk(8, [])
    let a = peek(ns)
    spin(n - 1, acc + a + peek(ns))
  }

fn main() : Int / Stdout = {
  Stdout.print("total=#{int_to_string(spin(2000, 0))}")
  0
}
