# Issue #599 — branch-aware dup elimination.
#
# Before the fix `pcs_is_non_last` counted every non-lambda use of a
# binding across the whole function body, even when the uses sat in
# mutually-exclusive arms of a `match` or sides of an `if`. Result:
# `f(x, s)` with `match s { A -> use(x); B -> use(x) }` paid a
# `__perceus_dup(kai_x)` on every read, even though at most ONE arm
# executes per call.
#
# After the fix the analysis takes the max over alternative branches
# rather than the sum, so a parameter used at most once on every path
# is treated as last-use and the dup-wrap is skipped.
#
# This fixture exercises the canonical shape (param of a heap type
# used in two mutually-exclusive arms, exactly one read each) and
# asserts the program produces the right answer. Heap-typed args
# (String, [a], variant) go through the Perceus path; primitive
# (Int, Bool, Real) are unboxed by Phase 3 and never wrap.

type Tag = A | B | C

# String param `s` is heap; `t` is the dispatching scrutinee.
fn pick(s: String, t: Tag) : String = match t {
  A -> string_concat(s, " (A)")
  B -> string_concat(s, " (B)")
  C -> string_concat(s, " (C)")
}

# List param `xs`: each arm reads it exactly once on its own path.
fn step(xs: [String], t: Tag) : Int = match t {
  A -> list_length(xs) * 2
  B -> list_length(xs) + 100
  C -> list_length(xs) - 1
}

fn main() : Unit / Stdout = {
  Stdout.print(pick("hello", A))
  Stdout.print(pick("hello", B))
  Stdout.print(pick("hello", C))
  Stdout.print(int_to_string(step(["a", "b", "c"], A)))
  Stdout.print(int_to_string(step(["a", "b", "c"], B)))
  Stdout.print(int_to_string(step(["a", "b", "c"], C)))
}
