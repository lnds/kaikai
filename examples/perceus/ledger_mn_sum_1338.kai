# Issue #1338 — cross-thread KAI_TRACE_RC ledger reduction. Eight
# fibers each thread a private vec through push+set writes; above one
# scheduler thread the in-place counts land on whichever workers ran
# the fibers, so the exit report is only exact if it sums every
# thread's ledger. The harness asserts vec_inplace=8000 vec_cow=0 at
# KAI_THREADS=1 and 4.

import spawn

fn step(v: Vec[Int], k: Int) : Vec[Int] = {
  let w = vec_push(v, k)
  vec_set(w, k - 1, k + k)
}

fn spin(v: Vec[Int], k: Int, n: Int) : Vec[Int] =
  if k > n { v } else { spin(step(v, k), k + 1, n) }

fn run_one(n: Int) : Int = vec_length(spin(vec_empty(), 1, n))

fn total(xs: [Int]) : Int = match xs {
  []        -> 0
  [h, ...t] -> h + total(t)
}

fn main() : Int / Spawn + Stdout = {
  let sizes = [500, 500, 500, 500, 500, 500, 500, 500]
  let lens = nursery { nur ->
    let fibers = sizes | (m => nur.spawn(() => run_one(m)))
    fibers | (f => nur.await(f))
  }
  Stdout.print(int_to_string(total(lens)))
  0
}
