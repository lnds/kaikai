# The [Int]-payload twin of borrowed_match_str_payload_1315: the
# borrowed-scrutinee under-release is payload-type-agnostic, so the gate
# must fail on a str-only fix. Same shape — borrowed deconstructing peek
# re-run N times, owner drops the list after its last borrowed use.

type Node = Data([Int], Int) | Skip

fn peek(^ns: [Node]) : Int = match ns {
  [] -> 0
  [d, ..._rest] -> match d {
    Data(xs, v) -> list_length(xs) + v
    Skip -> 0
  }
}

fn scan(^ns: [Node], n: Int, acc: Int) : Int =
  if n == 0 { acc } else { scan(ns, n - 1, acc + peek(ns)) }

fn mk(n: Int, acc: [Node]) : [Node] =
  if n == 0 { acc }
  else if n % 5 == 0 { mk(n - 1, [Skip, ...acc]) }
  else { mk(n - 1, [Data([n, n], n), ...acc]) }

fn main() : Int / Stdout = {
  let ns = mk(1000, [])
  let total = scan(ns, 1000, 0)
  Stdout.print("total=#{int_to_string(total)}")
  0
}
