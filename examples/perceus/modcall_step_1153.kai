# Companion module for modcall_linear_1153: a real (non-forwarder)
# module fn threading a Vec — the body is a block, so forwarder
# inlining leaves the qualified call in place and the caller's
# linearity verdict for `EModCall` is what keeps the vec unique.
pub fn step(v: Vec[Int], k: Int) : Vec[Int] = {
  let w = vec_push(v, k)
  vec_set(w, k - 1, k + k)
}
