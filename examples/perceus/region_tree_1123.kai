# issue #1123 — kind Region: a linked structure (Tree<r>) built in an
# arena across fn boundaries, folded to a scalar, the whole arena freed
# in one shot. This is what Vec cannot do (Vec is contiguous; a tree is
# linked) and the headline case for the Structural theory.
#
# `tree_insert` / `tree_sum` are region-polymorphic: `<r>` appears only
# in their signatures, the ctors stay pure, and every Node bump-allocates
# in r's arena. The result is an Int, so r does not escape and the arena
# frees wholesale — zero per-node refcount inside the region.
type Tree = Leaf | Node(Tree, Int, Tree)

fn tree_insert[r: Region](t: Tree<r>, k: Int) : Tree<r> =
  match t {
    Leaf -> Node(Leaf, k, Leaf)
    Node(l, v, rr) ->
      if k < v { Node(tree_insert(l, k), v, rr) }
      else if k > v { Node(l, v, tree_insert(rr, k)) }
      else { Node(l, v, rr) }
  }

fn tree_sum[r: Region](t: Tree<r>) : Int =
  match t {
    Leaf -> 0
    Node(l, v, rr) -> tree_sum(l) + v + tree_sum(rr)
  }

fn build_tree[r: Region](t: Tree<r>, n: Int) : Tree<r> =
  if n == 0 { t } else { build_tree(tree_insert(t, n), n - 1) }

fn main() : Unit {
  let total = region { r ->
    let t = build_tree(Leaf, 100)
    tree_sum(t)
  }
  println("#{total}")
}
