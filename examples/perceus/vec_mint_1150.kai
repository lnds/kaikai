# Vec literal minting (the #1091 container shape) plus the slice/index
# surface:
#   - `let a: Vec[Int] = [1, 2, 3]` builds a pre-sized vec (annotation);
#   - a call arg whose declared param is `Vec[T]` mints the same way
#     (argument position);
#   - a BARE `[1, 2, 3]` keeps denoting the cons list — no default flip;
#   - element minting follows the numeric lattice (`Vec[Byte]`);
#   - `xs[i]` reads an element; `xs[a..b]` is the inclusive O(1) slice.
import collections.vec

fn total(v: Vec[Int]) : Int = vec.foldl(v, 0, (acc, x) => acc + x)

fn main() : Int / Stdout = {
  let a: Vec[Int] = [10, 20, 30]
  Stdout.print(int_to_string(vec_length(a)))
  Stdout.print(int_to_string(a[1]))
  Stdout.print(int_to_string(total([1, 2, 3])))
  let bare = [4, 5, 6]
  Stdout.print(int_to_string(list_length(bare)))
  let bare_head = match bare {
    []           -> 0
    [h, ..._rest] -> h
  }
  Stdout.print(int_to_string(bare_head))
  let bytes: Vec[Byte] = [65, 66]
  Stdout.print(int_to_string(vec_length(bytes)))
  let s = a[0..1]
  Stdout.print(int_to_string(vec_length(s)))
  Stdout.print(int_to_string(s[0]))
  0
}
