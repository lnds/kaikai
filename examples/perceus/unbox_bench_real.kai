# Unboxing Phase 2 â€” Real-arithmetic performance benchmark
# (Tongariki Real-unboxing extension).
#
# Tight floating-point inner loop. Pre-Real-unboxing every `+` /
# `*` heap-allocated a `Real`; post-extension the chain inside
# `pure_chain_real` collapses to raw `double` arithmetic.
#
# The companion `unbox_bench_real.c.ref` is the equivalent C
# loop. The wall-clock ratio between this fixture and the C
# reference is the user-facing performance gap targeted by the
# Real-unboxing extension. Acceptance: within ~5â€“10Ă— of the C
# reference under `-O2`. The pre-extension gap on `Real`-heavy
# code was ~50â€“100Ă— because every iteration heap-allocated a
# `Real` box.
#
#   $ time ./build/perceus-unbox_bench_real
#   $ time ./build/unbox_bench_real_c_ref
#
# This is a coverage-ratchet input, not a hard tier1 gate.

fn pure_chain_real(seed: Real) : Real {
  # Same shape as `unbox_bench.kai::pure_chain` but on `Real`
  # operands. `seed` is intentionally consumed only once â€” Phase 2
  # keeps function parameters boxed (non-goal #1) so a chain that
  # started from `seed` would mix MBoxed and MUnboxed and the
  # conservative rule would demote it. The body is intentionally
  # long: the recursion in `bench_loop` is NOT tail-optimized
  # through perceus's drop wrapper (R6 known regression), so we
  # amortise the per-call overhead with a heavy raw chain.
  #
  # `%` is unavailable on `double` in C, so the shape uses
  # multiplication by reciprocals (`* 0.01`, `* 0.001`, `* 0.0001`)
  # in place of the `% 100` / `% 257` / `% 1009` reductions used by
  # the integer counterpart.
  let a = 1.0 + 2.0
  let b = a * 7.0
  let c = b - a
  let d = c + a + b
  let e = d * 0.01
  let f = e * e
  let g = f + d
  let h = g - 1.0
  let i_ = h + 3.0
  let j = i_ * 5.0
  let k = j + a + b + c
  let l = k * 0.001
  let m_ = l + e + f
  let n_ = m_ + j - h
  let o_ = n_ * 3.0 + a
  let p_ = o_ - b + c
  let q_ = p_ + d + e
  let r_ = q_ * 2.0 - f
  let s_ = r_ + g + h
  let t_ = s_ - i_ + j
  let u_ = t_ + k - l
  let v_ = u_ * 7.0 + m_
  let w_ = v_ * 0.0001
  let x_ = w_ + n_ + o_
  let y_ = x_ - p_ + q_
  let z_ = y_ + r_ - s_
  z_ + t_ + u_ + v_ + w_ + x_ + y_
}

fn bench_loop(iters: Int, acc: Real) : Real {
  if iters > 0 {
    let r = pure_chain_real(int_to_real(iters))
    bench_loop(iters - 1, acc + r)
  } else {
    acc
  }
}

fn main() {
  # N kept conservative: TCO on tail calls inside a perceus-wrapped
  # block (`({ ... drop ...; ret; })`) is a known regression
  # tracked separately (R6). Larger N stack-overflows.
  let r = bench_loop(20000, 0.0)
  print(real_to_string(r))
}
