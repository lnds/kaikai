# Match on a BORROWED scrutinee: `peek` deconstructs the same list N
# times while the owner keeps the ref. Two releases must still happen —
# the owner's drop of the list after its last (borrowed-slot) use, and
# the unused rest-binder's non-bind. Before the fix each was missing:
# the whole chain (cons + variant + String payload) leaked linearly.
# The payload strings come from string_concat (fresh heap cells, never
# interned), so `leaked` must stay flat in N.

type Node = Data(String, Int) | Skip

fn peek(^ns: [Node]) : Int = match ns {
  [] -> 0
  [d, ..._rest] -> match d {
    Data(nm, v) -> string_length(nm) + v
    Skip -> 0
  }
}

fn scan(^ns: [Node], n: Int, acc: Int) : Int =
  if n == 0 { acc } else { scan(ns, n - 1, acc + peek(ns)) }

fn mk(n: Int, acc: [Node]) : [Node] =
  if n == 0 { acc }
  else if n % 5 == 0 { mk(n - 1, [Skip, ...acc]) }
  else { mk(n - 1, [Data(string_concat("node-", "payload"), n), ...acc]) }

fn main() : Int / Stdout = {
  let ns = mk(1000, [])
  let total = scan(ns, 1000, 0)
  Stdout.print("total=#{int_to_string(total)}")
  0
}
