# examples/perceus/phase4_unbox_payload.kai — Issue #440 Phase 2
# fixture: variant with a mixed primitive + pointer payload.
# Confirms construction + match destructure + reconstruction round-
# trip without RC drift on the typed slot path.
#
# Layout of `Pair`: pointer slot (the tail tree) + Int slot (the
# leaf value). After Phase 2 of #440 the ctor emits
# `kai_variant_u(... mask=4 ...)` — slot 0 = pointer, slot 1 = Int.

pub type Box = BLeaf | BNode(Box, Int)

fn depth(b: Box) : Int = match b {
  BLeaf -> 0
  BNode(t, _v) -> 1 + depth(t)
}

fn label_sum(b: Box) : Int = match b {
  BLeaf -> 0
  BNode(t, v) -> v + label_sum(t)
}

fn build(n: Int, acc: Box) : Box =
  if n <= 0 { acc }
  else { build(n - 1, BNode(acc, n)) }

fn main() : Unit / Console + Fail = {
  let b = build(5, BLeaf)
  print(int_to_string(depth(b)))
  print(int_to_string(label_sum(b)))
}
