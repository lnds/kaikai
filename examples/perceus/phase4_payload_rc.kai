# examples/perceus/phase4_payload_rc.kai — Issue #440 Phase 2
# fixture: variant whose entire payload is primitive (no pointer
# slot). Confirms that the all-Int Triple cells never cascade
# `kai_decref` over the payload at free time. With Phase 2 of #440
# the cells live with `slot_mask` set to encode three Int slots
# (`mask = 1 + 4 + 16 = 21`); under `KAI_TRACE_RC` the only
# `kai_free_value` events come from the cell itself, no children.

pub type IntTriple = ITR(Int, Int, Int)

fn sum_one(t: IntTriple) : Int = match t {
  ITR(a, b, c) -> a + b + c
}

fn build_loop(n: Int, acc: Int) : Int =
  if n <= 0 { acc }
  else {
    let t = ITR(n, n * 2, n * 3)
    build_loop(n - 1, acc + sum_one(t))
  }

fn main() : Unit / Console + Fail = {
  print(int_to_string(build_loop(10, 0)))
}
