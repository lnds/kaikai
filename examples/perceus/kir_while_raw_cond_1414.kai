# An inlined while whose predicate tail is a raw Int comparison: the KIR
# condbr must read the raw i1 directly (no bool.box, no truthy), and the
# value-discarded body must carry no dead unit ops (`do ()` / unit stores).
import loop

fn spin(start: Int) : Int = {
  var n := start
  var steps := 0
  while { n != 1 } {
    if n % 2 == 0 { n := n / 2 }
    else { n := 3 * n + 1 }
    steps := steps + 1
  }
  steps
}

fn main() = println(int_to_string(spin(27)))
