# Phase 1.B.1 fixture — the cons-head BORROW-SAFE classifier
# (--dump-borrowsafe). A head bind is borrow-safe when every use reads
# its scalar (h->as.i via raw arithmetic/comparison) and never
# propagates the head KaiValue* pointer. Borrow-safe heads can be bound
# without RC (borrowed from _scr), eliding the incref/drop pair — the
# Perceus/Koka "borrowed parameter" pattern, the scalar instance.
#
# This fixture pins the four discriminating shapes:
#   sum_sq — `h` only in `h * h` (raw arithmetic) -> raw (borrow-safe)
#   first  — body is bare `h` (returned -> pointer propagated) -> boxed
#   bump   — `h` in `h + 1` (raw operand; `[h+1,...]` stores the DERIVED
#            value, not h itself) -> raw (borrow-safe; the load is safe
#            even though the constructed list escapes)
#   show   — `h` in `int_to_string(h)` (call arg -> pointer) -> boxed
#
# 1.B.1 ships the CLASSIFIER only; the perceus consumer (suppress the
# head's incref-bind + dup/drop when borrow-safe) is a separate step.
# The analysis changes no emitted text — this is a pure dump golden.

fn sum_sq(xs: [Int]) : Int = match xs {
  []        -> 0
  [h, ...t] -> h * h + sum_sq(t)
}

fn first(xs: [Int]) : Int = match xs {
  []        -> 0
  [h, ..._] -> h
}

fn bump(xs: [Int]) : [Int] = match xs {
  []        -> []
  [h, ...t] -> [h + 1, ...bump(t)]
}

fn show(xs: [Int]) : Int = match xs {
  []        -> 0
  [h, ...t] -> int_to_string(h).length() + show(t)
}

fn main() : Int = sum_sq([1, 2, 3]) + first([4]) + show([5])
