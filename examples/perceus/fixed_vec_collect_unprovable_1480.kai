# A `|` chain whose head has no statically known length cannot collect into
# a fixed-width slot: the aggregate's length is its type, so a wrong-length
# collect would be a silent miscompile. The decline is loud instead.

fn dbl(x: Int) : Int = x * 2

fn main() : Unit / Console = {
  let v : Vec[Int]<5> = [1..5] | dbl
  print(int_to_string(v[0]))
}
