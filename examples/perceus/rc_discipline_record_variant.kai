# #293 Phase 1 — RC discipline for record + variant emit.
#
# Exercises the four sub-shapes the lane addresses:
#   - record literal construction
#   - record field access (the EField fix in stage{1,2}/compiler.kai)
#   - record pattern destructuring in `let`
#   - variant constructor + variant pattern destructuring
#
# Pre-fix, the kaic2 self-compile leaked 98.5% of records and 82.7%
# of variants per the KAI_TRACE_RC strict report (#291 Track #2
# baseline). This fixture is small enough that any residual leak
# shows up as a non-zero `live` count for the affected tag at exit
# under `KAI_TRACE_RC=1`.
#
# Run shape (manual, not gated by tier1):
#   bin/kai run examples/perceus/rc_discipline_record_variant.kai
# matches `rc_discipline_record_variant.out.expected`.
#
# A second build with `cc -DKAI_TRACE_RC=1` will surface any
# remaining record/variant leak as a `LEAK` line; with the Phase 1
# fixes applied the per-tag `record` and `variant` rows show
# `live=0` on the trailing strict report.

type Point = { x: Int, y: Int }
type Box = { p: Point, label: String }
type Maybe = Yes(Int) | No

fn make_point(a: Int, b: Int) : Point = Point { x: a, y: b }

fn read_x(p: Point) : Int = p.x

fn destructure_box(b: Box) : Int = {
  let { p: { x, y }, label: _ } = b
  x + y
}

fn classify(m: Maybe) : Int = match m {
  Yes(n) -> n
  No -> 0
}

fn main() : Int / Console = {
  # record literal + field access: `make_point` allocates, `read_x`
  # consumes via field access. With the EField fix, both record
  # temporaries balance.
  let s1 = read_x(make_point(3, 4))

  # record destructuring let: the composite Box temporary feeds
  # `destructure_box`; inside, the destructuring let releases the
  # temp after the binders own their slices.
  let s2 = destructure_box(Box { p: Point { x: 10, y: 20 }, label: "origin" })

  # variant ctor + destructure: each `Yes(n)` is built fresh, then
  # consumed by `classify` via match. `No` is also fresh — variants
  # without args still allocate a KaiValue (they are not pooled).
  let s3 = classify(Yes(5))
  let s4 = classify(No)

  print(int_to_string(s1 + s2 + s3 + s4))
  0
}
