# issue #381 — `_`-prefixed pattern binders never warn, regardless
# of whether the binder is a tuple-style destructure, a list rest,
# or a variant arg.
fn main() {
  let r = match Some(7) {
    Some(_v) -> "got it"
    None     -> "empty"
  }
  let xs = [1, 2, 3]
  let s = match xs {
    [_h, ..._tail] -> "non-empty"
    []             -> "empty"
  }
  print(r)
  print(s)
}
