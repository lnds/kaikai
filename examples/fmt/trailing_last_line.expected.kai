# Issue #785: a trailing comment on the LAST source line of a
# multi-line construct must round-trip inline, not demote to a
# leading (full-line) comment above on the next `kai fmt` pass.

# A single-arm sum NOT at end-of-file: `decl_line(next)` already
# bounded its trailing correctly, so this case round-tripped before.
pub type Tag
  = Mk(Int)  # the wrapped tag value

fn use_tag(t: Tag) : Int = match t {
  Mk(n) -> n
}

# A single-arm sum whose only arm is the file's LAST source line —
# the exact #785 shape. With the last decl bounded at `decl_line(d)
# + 1`, the trailing sat one line below that bound and demoted on
# re-format; the unbounded last-decl drain keeps it inline.
pub type Thunk
  = Th(String, String)  # name -> body symbol
