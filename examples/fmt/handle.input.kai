pub effect Logger {
  log(s: String) : Unit
}

fn use_logger() : Int / Stdout = handle {
  Logger.log("first")
  Logger.log("second")
  0
} with Logger as log {
  log(s, resume) -> {
    Stdout.print(s)
    resume(())
  }
}

pub effect Reader[T] {
  ask() : T
}

fn use_reader() : Int = handle {
  Reader.ask()
} with Reader[Int](42) as r {
  ask(resume) -> resume(r)
}
