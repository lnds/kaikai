# Issue #93 R7 — single-line trailing comments must stay inline.
# Without the fix every trailing here was promoted to a full-line
# comment immediately above its construct, so a `kai fmt` run
# rearranged the lines that originally lived next to the code.

fn double(x: Int) : Int = x * 2  # trivial doubler

fn main() {
  let x = 42  # answer to everything
  let y = double(x)  # twice the answer
  print(int_to_string(y))  # write the result
}
