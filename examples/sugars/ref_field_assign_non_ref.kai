# `record.field := v` only writes a `Ref`-typed field. A plain (non-Ref)
# field has no `set`, so the desugar `n.x.set(99)` fails the UFCS lookup
# — the field is a value, not a mutable cell.

type Point = { x: Int, y: Int }

fn main() : Unit / Console = {
  let p = Point { x: 1, y: 2 }
  p.x := 99
  print("unreachable")
}
