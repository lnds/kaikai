# Issue #385 — `.` placeholder with equality. `match_int(. == 2, ...)`
# desugars to `match_int((__pl) => __pl == 2, ...)`. The placeholder
# parameter type is inferred from the predicate's signature.
# Self-contained for stage2 test-sugars.

fn matches(p: (Int) -> Bool, x: Int) : Bool = p(x)

fn main() : Unit / Console {
  if matches(. == 2, 2) { print("hit") } else { print("miss") }
  if matches(. == 2, 3) { print("hit") } else { print("miss") }
}
