# In an `if` cond, an expression ending in a nullary variant followed
# by `{` opens the body, not a positional record literal. Without the
# block-vs-record fix this misparsed `Forest { ... }` as a record.

#[derive(Eq)]
type Terrain = Forest | Water

fn paint(id: Terrain) : Int = {
  var n := 0
  if id == Forest {
    n := n + 1
  }
  n
}

fn main() : Int / Console {
  print(int_to_string(paint(Forest)))
  print(int_to_string(paint(Water)))
  0
}
