# `with Int` (form b): habitants are Int values written directly in
# `<>` — `<3>` unifies with `<3>` and never with `<4>`, first-order
# value equality via the qualified-symbol path.
kind Slot : AbelianGroup with Int

fn hold(x: Real<3>) : Real<3> = x

fn main() : Unit / Console = {
  let a : Real<3> = 5.0<3>
  let _ = hold(a)
  print("value domain ok")
}
