# m7b #6 — postfix `a[i]` reads and `a[i] := v` writes desugar to
# the underlying mutable Array ops. With the Mutable effect retrofit
# (Doc B §`Mutable`) this signature should grow `/ Mutable`; the
# desugar emits the same op call either way.

fn main() {
  let xs = array_make(3, 0)
  xs[0] := 10
  xs[1] := 20
  xs[2] := 30
  print(int_to_string(xs[0]))
  print(int_to_string(xs[1]))
  print(int_to_string(xs[2]))
}
