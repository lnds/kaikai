# issue #1108: money and physical units compose when they share one
# abelian kind — `(USD/kWh) * kWh = USD` type-checks in Measure.
unit USD
unit kWh

fn cost(rate: Real<USD/kWh>, energy: Real<kWh>) : Real<USD> = rate * energy

pub fn main() : Unit / Console = {
  let total = cost(0.15<USD/kWh>, 100.0<kWh>)
  print("usd per kwh ok")
}
