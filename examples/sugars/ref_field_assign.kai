# issue #1113 — `record.field := v` writes a `Ref`-typed field. Before
# this sugar, `n.next := 99` was rejected and users had to spell
# `Mutable.ref_set(n.next, 99)` or box a one-cell Array. The `.`-path
# desugars to `n.next.set(99)`, which the typer maps to `Mutable.ref_set`.

type Node = { id: Int, next: Ref[Int] }

fn main() : Unit / Mutable + Console = {
  let n = Node { id: 1, next: &7 }
  print(int_to_string(@n.next))
  n.next := 99
  print(int_to_string(@n.next))
}
