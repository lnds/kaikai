# m7b #13 — the canonical polymorphic identity function. Without
# fn-level type parameters this could not type-check: a lowercase
# identifier in type position used to be a nominal `TyCon`, so
# `id(42)` failed unification with `(a) -> a`.

pub fn id[T](x: T) : T = x

fn main() : Int {
  let n = id(42)
  let s = id("hello")
  let _ = s
  assert n == 42
  0
}
