# A `Shape` variable is an arity-1 constructor: `s[A]`. Applying it to
# two arguments has no meaning — arity-2 (`Map`-shaped) is rejected at
# formation, the strict-arity-1 rule that keeps unification first-order.
fn bad[s: Shape](xs: s[Int, Bool]) : Int = 0

pub fn main() : Unit / Console = print("unreachable")
