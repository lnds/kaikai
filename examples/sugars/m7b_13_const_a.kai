# m7b #13 — multiple type parameters. Each call site instantiates
# the two tparams independently; the two distinct call sites below
# bind (Int, String) and (String, Int) respectively, exercising
# fresh-instantiation per call.

pub fn const_a[A, B](a: A, _b: B) : A = a

fn main() : Int {
  let x = const_a(42, "hello")
  let y = const_a("world", 100)
  let _ = y
  assert x == 42
  0
}
