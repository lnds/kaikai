# issue #1108: `s` (second) is declared in both Metric and Imperial;
# they are distinct habitants that share a spelling, so `metric.s +
# imperial.s` is a type error — the shared name does not make them one.
kind Metric : AbelianGroup with metric
kind Imperial : AbelianGroup with imperial

metric s
imperial s

fn bad(a: Real<Metric.s>, b: Real<Imperial.s>) : Real<Metric.s> = a + b

pub fn main() : Unit / Console = { print("unreachable") }
