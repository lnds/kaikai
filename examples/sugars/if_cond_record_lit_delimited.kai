# No-regression: record literals stay legal inside any delimited
# context that can appear in an `if` cond. Suppression applies only to
# the bare top level of the cond, not inside call args, `()`, `[]`, or
# a block expression — each re-enables record literals for its interior.

#[derive(Eq)]
type Cfg = { v: Int }

fn is_pos(c: Cfg) : Bool = c.v > 0

fn main() : Int / Console {
  # record literal as a call argument
  if is_pos(Cfg { v: 1 }) {
    print("call")
  }
  # parenthesised cond re-enables record literals
  if (Cfg { v: 2 }.v == 2) {
    print("paren")
  }
  # record literal inside a list literal
  if [Cfg { v: 7 }] == [Cfg { v: 7 }] {
    print("list")
  }
  # record literal inside a block expression
  if { let c = Cfg { v: 3 }; c.v == 3 } {
    print("block")
  }
  0
}
