# Negative: a contract predicate may only call effect-pure functions.
# `shout` has `/ Console` in its row, so calling it from a `requires`
# clause is rejected — the predicate would perform I/O while the
# contract is checked. Purity is read off the effect row, so no
# annotation can override this.

fn shout(n: Int) : Bool / Console = {
  Console.print("checking")
  n > 0
}

fn make(n: Int) : Int
  requires shout(n)
  = n

fn main() : Unit / Console = Console.print(int_to_string(make(5)))
