# `with fr { be le }` (form d): a user closed-set kind over the
# Composition engine's known atoms. No habitant decls exist; the set
# is fixed by the declaration and validated against the engine.
kind Frame : Composition over Int with fr { be le }

fn main() : Unit / Console = {
  let x : Real<Frame.be> = 1.0<Frame.be>
  let _ = x
  print("closed set ok")
}
