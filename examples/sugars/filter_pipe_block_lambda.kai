# issue #412 — `|?` accepts a block-lambda RHS, mirroring `|`.
#
# `xs |? { x -> body }` parses: the filter-pipe binop accepts a
# lambda-block as a Primary on its right operand.

fn main() : Int / Console {
  let mults_of_three = [1..10] |? { x -> x % 3 == 0 }
  each(mults_of_three, (x) => print(int_to_string(x)))
  0
}
