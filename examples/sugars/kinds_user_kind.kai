# issue #1108: a user-declared abelian kind, its habitants, a unit-kind
# tparam over it, and same-kind composition — all in user code.
kind Metric : AbelianGroup with metric

metric m
metric s

fn speed(d: Real<m>, t: Real<s>) : Real<m/s> = d / t
fn area_of[u: Metric](w: Real<u>, h: Real<u>) : Real<u^2> = w * h

pub fn main() : Unit / Console = {
  let v = speed(10.0<m>, 2.0<s>)
  let a = area_of(3.0<m>, 4.0<m>)
  print("user kind ok")
}
