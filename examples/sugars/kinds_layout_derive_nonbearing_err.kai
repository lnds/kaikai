# `#[derive(Layout)]` needs EVERY field to be a fixed-width unsigned head
# carrying `<be>`/`<le>`. One non-conforming field disqualifies the record,
# so no partial encoder is generated. Each rejection names the field and the
# remedy that applies to it: a missing byte order, a signed head, and a type
# with no fixed width are three different fixes, not one generic complaint.

#[derive(Layout)]
type NoOrder = { id: U32, port: U16<be> }

#[derive(Layout)]
type Signed = { delta: I32<be> }

#[derive(Layout)]
type NotFixed = { magic: U32<be>, name: String }

pub fn main() : Unit / Console = { print("unreachable") }
