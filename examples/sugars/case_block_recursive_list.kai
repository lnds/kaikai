# Issue #415 — multi-clause function body for a recursive list
# traversal. Demonstrates list-spread patterns with a `when` guard
# inside the case-block form. Uses records for the entries since
# kaikai surface syntax has no tuple expression.

type Entry = { key: String, val: Int }
type Lookup = Found(Int) | Missing

fn lookup(xs: [Entry], k: String) : Lookup {
  case [], _                                  -> Missing
  case [e, ..._], n when e.key == n           -> Found(e.val)
  case [_, ...rest], n                        -> lookup(rest, n)
}

fn show(r: Lookup) : String =
  match r {
    Found(v) -> "found=#{int_to_string(v)}"
    Missing  -> "missing"
  }

fn main() : Int / Console {
  let table = [
    Entry { key: "a", val: 1 },
    Entry { key: "b", val: 2 },
    Entry { key: "c", val: 3 }
  ]
  print(show(lookup(table, "a")))
  print(show(lookup(table, "c")))
  print(show(lookup(table, "z")))
  print(show(lookup([], "x")))
  0
}
