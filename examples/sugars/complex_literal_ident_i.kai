# Phase 1 of #267 — the `i` suffix only attaches when *immediately*
# adjacent to the preceding digits (no whitespace). `i` as a free
# identifier (loop variable, binding) keeps lexing as TkIdent. This
# fixture pins the backwards-compat boundary so the lexer cannot
# regress into over-attaching.

fn main() : Unit / Console = {
  let i = 5
  let a = i + 1
  print(int_to_string(a))
  let b = 3 + i
  print(int_to_string(b))
  let c = 3+i
  print(int_to_string(c))
}
