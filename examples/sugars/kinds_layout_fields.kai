# issue #1189: `Layout` classifies a field's binary representation.
# The width comes from the base type (`U32` = 4 bytes); the `<be>` /
# `<le>` habitant is the byte-order modifier. A record composes its
# field layouts in declaration order. All habitants resolve without an
# import — `be`/`le` are shipped like the default kind.
type Header = {
  magic: U32<be>,
  port:  U16<be>,
  flags: U16<le>,
}

fn same_order(a: U32<be>, b: U32<be>) : U32<be> = a

pub fn main() : Unit / Console = {
  let h = Header { magic: 0<be>, port: 0<be>, flags: 0<le> }
  let _ = same_order(h.magic, 1<be>)
  print("layout fields ok")
}
