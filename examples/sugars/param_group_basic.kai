# Go/Pony-style parameter type grouping. `(a, b, c: Int)` ≡
# `(a: Int, b: Int, c: Int)` — unannotated names inherit the type written
# after the last name of the group. Covers a grouped `fn` and a grouped
# parenthesised lambda.
fn add3(a, b, c: Int) : Int = a + b + c

fn main() : Unit / Stdout {
  let f = (x, y: Int) => x + y
  Stdout.print(int_to_string(add3(1, 2, 3) + f(4, 5)))
}
