# A decl wrapper must not block unit kind-qualification: a dimensioned
# type under `#[unstable]` and a `#[constructor]` fn with dimensioned
# params qualify exactly as the bare forms do, so dimensioned literals
# at the use site unify with the declared fields.

#[unstable]
pub type Frame = { magic: U32<be>, flags: U16<le> }

pub type Header = { magic: U32<be> }

#[constructor]
pub fn make_header(m: U32<be>) : Header = Header { magic: m }

fn same_order(a: U32<be>, b: U32<be>) : U32<be> = a

pub fn main() : Unit / Console = {
  let fr = Frame { magic: 1<be>, flags: 2<le> }
  let h = Header(3<be>)
  let _ = same_order(fr.magic, h.magic)
  print("wrapped decl units ok")
}
