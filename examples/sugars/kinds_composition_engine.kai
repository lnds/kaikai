# The Composition engine unifies a habitant slot nominally: a measure-
# carrying atom (`pct70 = 70`) unifies only with itself, and a
# `[h: Waterfall]` kind param binds to whichever habitant it meets —
# never confusing `pct70` with `pct30`. This is the engine's own slot
# verdict, not the abelian solver: the atoms never multiply or cancel.
kind Waterfall : Composition over Int with pct

pct pct70 = 70
pct pct30 = 30

fn keep[h: Waterfall](x: Real<h>) : Real<h> = x

fn main() : Unit / Console = {
  let _a : Real<pct70> = keep(1.0<pct70>)
  let _b : Real<pct30> = keep(2.0<pct30>)
  print("composition engine ok")
}
