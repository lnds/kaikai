# m7e §13 — negative: `expr!` on a non-Option/Result operand. The
# operator is bound to two compiler-blessed types only; bare `Int`
# (or any other type) is rejected with a clear diagnostic.

fn raw_int() : Int = 7

fn whatever() : Option[Int] {
  let n = raw_int()!     # type error: Int is not Option/Result
  Some(n)
}

fn main() {
  match whatever() {
    Some(_) -> print("ok")
    None    -> print("none")
  }
}
