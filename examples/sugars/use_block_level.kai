# m7e §25: block-level `use Effect`. Opens the effect for the rest
# of the enclosing block. Outside the block (or in a sibling fn
# body), the bare name is unavailable and the qualified `Eff.op`
# form is required.

fn shout(msg: String) : Unit / Stderr = {
  use Stderr
  eprint("ERR: #{msg}")
}

fn quiet(msg: String) : Unit / Stdout = Stdout.print(msg)

fn main() : Unit / Stdout + Stderr {
  quiet("info: starting")
  shout("oops")
  quiet("info: done")
}
