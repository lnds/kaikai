# m7b #6 — `IndexLhs` rejects an indexed write whose base ends in a
# call. The write would mutate a temporary the caller cannot observe
# elsewhere, which is almost always a bug; the parser flags it so the
# programmer binds the result first (`let xs = get_array(); xs[i] := v`).

fn get_array() : Array[Int] {
  array_make(3, 0)
}

fn main() {
  get_array()[0] := 99
}
