# issue #1189, test 3 (polymorphism Type cannot express): generic
# `encode`/`decode` over a Layout record. `encode` lays out each field
# at its base-type width in its `<be>`/`<le>` order; `decode` reverses
# it and returns `Option[T]` (None on a short input). Both derive from
# the one type declaration, so they cannot desync. The `bin_*` byte
# readers are core-visible without an import.

type Header = { magic: U32<be>, port: U16<be>, flags: U16<le> }

fn main() : Unit / Console = {
  let h = Header { magic: 0xCAFEBABE<be>, port: 8080<be>, flags: 513<le> }
  let bytes = encode(h)
  print("len #{array_length(bytes)}")
  # magic big-endian: CA FE BA BE
  match bin_byte_at(bytes, 0) { Ok(b) -> print("b0 #{byte_to_int(b)}") Err(_) -> print("err") }
  match bin_byte_at(bytes, 3) { Ok(b) -> print("b3 #{byte_to_int(b)}") Err(_) -> print("err") }
  # flags 0x0201 little-endian at offset 6: 01 02
  match bin_byte_at(bytes, 6) { Ok(b) -> print("b6 #{byte_to_int(b)}") Err(_) -> print("err") }
  match bin_byte_at(bytes, 7) { Ok(b) -> print("b7 #{byte_to_int(b)}") Err(_) -> print("err") }
  let dec : Option[Header] = decode(bytes)
  match dec {
    Some(h2) -> print("magic #{h2.magic}")
    None -> print("decode failed")
  }
  # A short buffer decodes to None, never a garbage read.
  let short : Array[Byte] = array_make(3, bin_byte(0))
  let d2 : Option[Header] = decode(short)
  match d2 { Some(_) -> print("BAD") None -> print("short None") }
}
