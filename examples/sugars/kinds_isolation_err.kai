# issue #1108: two habitants in distinct abelian kinds never unify —
# `metric m + imperial ft` is the Mars Climate Orbiter class of bug,
# now a compile-time type error.
kind Metric : AbelianGroup with metric
kind Imperial : AbelianGroup with imperial

metric m
imperial ft

fn bad(a: Real<m>, b: Real<ft>) : Real<m> = a + b

pub fn main() : Unit / Console = { print("unreachable") }
