# issue #412 — `|?` filter pipe with a bare predicate name.
#
# `xs |? p` desugars to `list.filter(xs, p)` analogously to how
# `xs | f` desugars to `list.map(xs, f)`. The simplest end-to-end
# shape: list literal on the left, named predicate on the right.

fn even(n: Int) : Bool = n % 2 == 0

fn main() : Int / Console {
  let evens = [1, 2, 3, 4, 5, 6] |? even
  each(evens, (x) => print(int_to_string(x)))
  0
}
