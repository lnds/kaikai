# Issue #970 — a block-lambda pattern binder must be irrefutable.
# `(a, b)` over a `Pair` is irrefutable; a constructor pattern that
# could fail is not. The binder desugars to a single-arm `match`, so
# the existing exhaustiveness check rejects the refutable case with
# the standard non-exhaustive diagnostic — no bespoke error path.

fn apply(x: Option[Int], f: (Option[Int]) -> Int) : Int = f(x)

fn main() : Int / Console {
  let r = apply(Some(3)) { (Some(n)) -> n }
  print(int_to_string(r))
  0
}
