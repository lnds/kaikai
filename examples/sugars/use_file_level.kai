# m7e §25: file-level `use Effect`. After the open, every op of
# the named effect is callable by its bare name in any fn body in
# this file. The effect still appears in the function's row — `use`
# is a name-resolution shortcut, not an effect-handling change.

use Stdout

fn greet(name: String) : Unit / Stdout = print("hello, #{name}")
fn farewell(name: String) : Unit / Stdout = print("bye, #{name}")

fn main() : Unit / Stdout {
  greet("world")
  farewell("world")
}
