# m7b #5 — `var name = init` parses (so `--ast` shows an SVar node)
# but is rejected at resolve time because the desugar pass that lowers
# it to `handle ... with State[T](init)` is not yet implemented. This
# test pins both shapes: untyped (`var counter = 0`) and typed
# (`var counter: Int = 0`). Once m7b #5b lands the desugar, both should
# compile and run; this fixture flips to a runnable .out.expected.

fn main() : Int {
  var counter = 0
  var typed_counter: Int = 0
  counter
}
