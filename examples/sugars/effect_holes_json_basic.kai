# m7f §6 / Phase L #2: --effect-holes-json reports each typed effect
# hole (`?` or `?name` in row tail position) and how the inferencer
# resolved it, plus the body's actually-performed effects so an LLM
# (or human) can suggest a concrete row to fill the hole.
#
# This fixture exists primarily for the smoke check; the default
# test-sugars harness compiles + runs it as a normal kaikai program
# (the JSON view is only emitted when --effect-holes-json is on the
# command line). See the .out.expected for the runtime trace.
#
# Schema (per element):
#   {file, fn, line, col, name, labels, open, tail_var, body_row}

fn helper() : Unit / ?e = print("hi")

fn many() : Int / ?eff = {
  print("step 1")
  eprint("step 2")
  42
}

fn no_effects(x: Int) : Int / ?p = x + 1

fn main() : Unit / Stdout + Stderr {
  helper()
  let n = many()
  let _ = no_effects(n)
}
