# m7d §10 — punning composes with explicit `field: expr` entries
# in the same literal. `{ x, y: other_y, z }` keeps `x` and `z`
# punned and gives `y` an explicit value.

type V3 = { x: Int, y: Int, z: Int }

fn main() {
  let x = 1
  let z = 3
  let v = V3 { x, y: 7, z }
  print(int_to_string(v.x))
  print(int_to_string(v.y))
  print(int_to_string(v.z))
}
