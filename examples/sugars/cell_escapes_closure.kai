# Negative — a closure that reads a cell and whose VALUE reaches the
# block's exit (here returned in the tail) escapes the cell's block. The
# `State` handler is torn down when the block exits, so the closure
# could not run afterwards. Applying the closure inside the block is
# sound (the value is the call result, not the closure) and allowed.
fn make() : () -> Int {
  var counter := 0
  counter := counter + 1
  () => counter
}

fn main() : Int {
  let f = make()
  f()
}
