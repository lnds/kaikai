# Privacy leak in `pub type` sum variant payload: the public
# union `Action` has a variant whose payload type `Token` is a
# non-`pub` type in the same module. A consumer constructing
# `Use(...)` would need to name `Token`. The validator must
# report the leak at the variant payload position.

type Token = Tok(Int)

pub type Action
  = Skip
  | Use(Token)
