# Module habitants keep the module operations: same-habitant addition
# and subtraction, the external scalar action, and full-cancellation
# ratios. Only habitant products/powers are gone.
kind Cur : Module with cur

cur USD

pub fn main() : Unit / Console = {
  let a = 10.0<USD> + 5.0<USD>
  let s = a - 5.0<USD>
  let b = a * 2.0
  let r = b / a
  print("#{s} #{r}")
}
