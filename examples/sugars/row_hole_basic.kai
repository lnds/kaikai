# m7f §6: `?e` in row tail position. The typer treats the hole as
# an anonymous row variable; the body's effects flow into it via
# unification, exactly as they would into a user-named row var
# like `/ Stdout + e`.

fn run() : Unit / ?e = Stdout.print("hello from a hole-row fn")

fn main() : Unit / Stdout = run()
