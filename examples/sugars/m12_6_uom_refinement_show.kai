# m12.6.x #4 (positive) — refinement composes with units of measure
# at the *type* level (`Real<USD> where >= 0.0`); the typer canonicalises
# both surface orderings to `TyRefineT(TyDimT(b, u), p)` (refinement on
# the outside, unit on the inside) via `dim_collapse`.
#
# Printing a dimensioned value goes through `show` (the parametric
# `impl[u: Measure] Show for Real<u>` in stdlib/protocols.kai), which
# strips the unit internally and appends the canonical unit symbol —
# so `show(50.0<USD>)` renders as `"50 USD"` and we get the expected
# `paid=50 USD` line without going through the monomorphic
# `real_to_string : Real -> String` (which would reject the
# dimensioned argument; see the companion negative fixture
# `m12_6_uom_refinement.kai`).

unit USD

fn id_money(m: Real<USD> where >= 0.0) : Real<USD> where >= 0.0 = m

type Account = {
  id: Int,
  balance: Real<USD> where self >= 0.0,
}

fn make(id: Int, balance: Real<USD>) : Account =
  Account { id: id, balance: balance }

fn main() : Unit / Stdout {
  let a = make(1, 100.0<USD>)
  let m = id_money(50.0<USD>)
  Stdout.print("acct=#{int_to_string(a.id)}")
  Stdout.print("paid=#{show(m)}")
}
