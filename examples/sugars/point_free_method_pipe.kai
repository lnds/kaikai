# A point-free section may end in a method call: `.length()` in
# function position desugars to `(__pl) => __pl.length()`, the
# receiver supplied implicitly by UFCS.

fn print_all(xs: [Int]) : Unit / Stdout = match xs {
  []           -> Stdout.print("end")
  [h, ...rest] -> {
    Stdout.print(int_to_string(h))
    print_all(rest)
  }
}

fn main() : Unit / Stdout {
  let words = ["alpha", "beta", "gamma"]
  let lens = words | .length()
  print_all(lens)
}
