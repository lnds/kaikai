# A transparent type alias may take a unit-kind tparam and place it
# in unit position: `Amount[USD]` expands to `Real<USD>` and the
# habitant re-qualifies against its kind after expansion.
kind Cur : Module with cur

cur USD

type Amount[c: Cur] = Real<c>

pub fn main() : Unit / Console = {
  let a: Amount[USD] = 10.0<USD>
  let b: Amount[USD] = a + 5.0<USD>
  print("#{b}")
}
