# issue #412 ‚Äî `|?` chains with `|` left-associatively.
#
# `[1..6] |? even | (n) => n * 2` parses as
# `([1..6] |? even) | ((n) => n * 2)`, yielding [4, 8, 12].

fn even(n: Int) : Bool = n % 2 == 0

fn main() : Int / Console {
  let out = [1..6] |? even | (n) => n * 2
  each(out, (x) => print(int_to_string(x)))
  0
}
