# issue #266 — positional record sugar rejects arity mismatch.
# `Complex` declares two fields; supplying one positional field fails
# at the desugar boundary with a clear diagnostic.

type Complex = { re: Real, im: Real }

fn main() : Unit / Stdout {
  let z = Complex { 1.0 }
  Stdout.print(real_to_string(z.re))
}
