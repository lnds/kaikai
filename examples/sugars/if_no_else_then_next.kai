# m7b #3 review fix — guards parse_if line 2365.
#
# `if cond { body }` without `else` must advance the parser past
# the then-block (state `p3`) before returning. Returning the
# pre-then state caused the next statement to be misparsed.
#
# Test shape: an `if` with no `else` that prints to stdout, then a
# second `print` after it. With the bug, the second `print` would
# never run (parser misparsed the second statement as continuation
# of the first) or the program would crash. With the fix, both
# print lines come out in order.

fn classify(n: Int) : String  / Console {
  if n > 0 { print("positive") }
  if n < 0 { print("negative") }
  "checked"
}

fn main(): Int / Console {
  let r = classify(5)
  print(r)        # "checked" — comes after the two `if`s above
  print("done")   # second statement after consecutive `if`s with no else
  0
}
