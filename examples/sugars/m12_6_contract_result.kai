# m12.6.c — `ensures` predicates can now reference `result`. The
# parser desugars
#   fn foo(x: T) : R requires P ensures Q = body
# to
#   fn foo(x: T) : R = {
#     assert P
#     let result = body
#     assert Q
#     result
#   }
# so `result` is an ordinary local binding inside the `ensures`
# clause. A violated postcondition aborts via the runtime assert
# (`panic: assertion failed`) — same path as a violated precondition.

fn double_pos(x: Int) : Int
  requires x > 0
  ensures result > x
  ensures result == x * 2
  = x * 2

fn main() : Unit / Stdout {
  Stdout.print("d=#{int_to_string(double_pos(5))}")
  Stdout.print("d=#{int_to_string(double_pos(7))}")
  Stdout.print("d=#{int_to_string(double_pos(11))}")
}
