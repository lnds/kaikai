# m7b #9 — map pipe with a lambda-block (m7b #3) on the right.
#
# Confirms `xs | { x -> body }` parses: the `|` binop accepts a
# lambda-block as a Primary on its right operand, just like `|>`.
# Squaring [1..5] yields [1, 4, 9, 16, 25]; reduce sums to 55.

fn main(): Int / Console {
  let squared = [1..5] | { x -> x * x }
  print(int_to_string(reduce(squared, 0, (acc, x) => acc + x)))   # 55
  0
}
