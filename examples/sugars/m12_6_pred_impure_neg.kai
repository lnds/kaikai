# m12.6.x #5 — refinement / contract predicates may only call into
# the closed refinement-pure prelude set (is_some, is_none, is_finite,
# is_nan, string_length, list_length, matches). Calls to user-defined
# functions are rejected at parse time with a fixed-position error.
#
# Future m12.6.x lane will add the `[<refinement-pure>]` attribute
# so user code can opt fns into the pure surface; until then the
# closed list is the entirety of the allowed call surface.

fn user_helper(n: Int) : Bool = n > 0

fn bad(x: Int) : Int
  requires user_helper(x)
  = x

fn main() : Unit / Stdout = Stdout.print("ok")
