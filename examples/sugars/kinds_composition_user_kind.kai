# like `AbelianGroup`/`Module`. A user declares their own kind over it
# and its habitant introducer — the gate that proves the theory ships
# public, not baked into `Layout` alone.
kind Frame : Composition with frame

frame hdr
frame body

pub fn main() : Unit / Console = { print("composition user kind ok") }
