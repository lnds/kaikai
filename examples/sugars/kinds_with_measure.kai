# `with pct` + `pct pct70 = 70` (form c): a declared habitant symbol
# carrying an exact numeric measure. The surface parses, registers,
# and validates; the engine that sums the measures is not wired yet.
kind Waterfall : Composition over Int with pct

pct pct70 = 70
pct pct20 = 20
pct pct10 = 10

fn tranche(x: Real<pct70>) : Real<pct70> = x

fn main() : Unit / Console = {
  let t : Real<pct70> = 1.0<pct70>
  let _ = tranche(t)
  print("measure habitants ok")
}
