# m7e §13 — `expr!` on `Result[E, T]`, success path. Both callees
# return `Ok(...)` so each `!` unwraps and the function returns
# `Ok(sum)`.

fn parse_a() : Result[String, Int] = Ok(40)
fn parse_b() : Result[String, Int] = Ok(2)

fn sum_them() : Result[String, Int] {
  let a = parse_a()!
  let b = parse_b()!
  Ok(a + b)
}

fn main() : Unit / Console {
  match sum_them() {
    Ok(n)  -> print(int_to_string(n))
    Err(e) -> print(e)
  }
}
