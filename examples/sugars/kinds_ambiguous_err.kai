# issue #1108: `USD` lives in both Measure and Currency; a bare `<USD>`
# with no qualification and no `use kind` is rejected, demanding
# disambiguation — never "last declared wins".
kind Currency : AbelianGroup with cur

unit USD
cur USD

fn hold(x: Real<USD>) : Real<USD> = x

pub fn main() : Unit / Console = { print("unreachable") }
