# Issue #415 — multi-clause function bodies, N-arg form.
#
# With N>=2 parameters the scrutinee is the implicit tuple of args;
# in kaikai surface syntax (which has no tuple-expr) this means N
# comma-separated patterns per arm, mirroring the existing multi-arg
# `match a, b { p, q -> ... }` form (issue #129). The desugar reuses
# `desugar_multi_match`.

fn classify2(a: Int, b: Int) : String {
  case 0, 0 -> "both-zero"
  case 0, _ -> "first-zero"
  case _, 0 -> "second-zero"
  case _, _ -> "neither"
}

fn main() : Int / Console {
  print(classify2(0, 0))
  print(classify2(0, 5))
  print(classify2(7, 0))
  print(classify2(7, 9))
  0
}
