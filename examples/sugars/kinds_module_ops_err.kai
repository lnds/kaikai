# Module theory formation guard, operator side: `*`, `^`, and `/`
# combinations that leave a Module habitant off exponent 1 are
# rejected at the operator that would form them.
kind Cur : Module with cur

cur USD

fn main() {
  let a = 10.0<USD>
  let sq = a * a
  let pw = a ^ 2
  let inv = 1.0 / a
  print("no")
}
