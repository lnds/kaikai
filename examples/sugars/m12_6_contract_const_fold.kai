# m12.6.d — constant folding over contract predicates. Predicates
# that the desugar-time evaluator can prove `true` are dropped
# entirely (no runtime cost). Predicates that mention runtime values
# (function args, globals, calls) are left as runtime asserts. The
# evaluator covers literal Int/Bool, the boolean operators
# (`and`/`or`/`not`), and Int comparisons / arithmetic between
# literals — no SMT, no symbolic reasoning, no propagation through
# refined argument types yet.

fn always(x: Int) : Int
  requires 1 < 2
  requires true
  requires not false
  ensures 5 == 5
  ensures (1 + 2) * 3 == 9
  = x

fn runtime_check(x: Int) : Int
  requires x > 0
  ensures result > 0
  = x + 1

fn main() : Unit / Stdout {
  Stdout.print("always(7)=#{int_to_string(always(7))}")
  Stdout.print("runtime(3)=#{int_to_string(runtime_check(3))}")
  Stdout.print("runtime(11)=#{int_to_string(runtime_check(11))}")
}
