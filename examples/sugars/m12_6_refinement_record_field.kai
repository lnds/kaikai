# m12.6.a — refinement on a record field. The `where` clause attaches
# to the field's type and is preserved through alias expansion. Until
# m12.6.b/c land, the predicate is parsed and stored but never checked.

type Account = {
  id: Int,
  balance: Int where >= 0,
}

fn make(id: Int, balance: Int) : Account = Account { id: id, balance: balance }

fn main() : Unit / Stdout {
  let a = make(1, 100)
  Stdout.print("acct=#{int_to_string(a.id)} bal=#{int_to_string(a.balance)}")
}
