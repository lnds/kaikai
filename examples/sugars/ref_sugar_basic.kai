# issue #275 — `Ref[T]` receiver supports the same `:=` / `@` sugar as
# `var`. `let c = Mutable.ref_make(0)` binds a `Ref[Int]`; `@c` reads
# via `Mutable.ref_get(c)` and `c := v` writes via `Mutable.ref_set(c, v)`.
# Mutable rides on the function row exactly the way `a[i] := v` does
# for arrays (issue #265 precedent).

fn main() : Unit / Mutable + Console = {
  let c = Mutable.ref_make(0)
  print(int_to_string(@c))
  c := 42
  print(int_to_string(@c))
}
