# `Dim` — the shape-index kind. A list literal against `Vec[T]<n>`
# must have exactly `n` elements; the index is erased at runtime but
# rides the type, and a `[n: Dim]` tparam threads it through calls.
import math.linalg

fn head3[n: Dim](v: Vec[Real]<n>) : Real = v[0]

fn main() : Unit / Console = {
  let a : Vec[Real]<3> = [1.0, 2.0, 3.0]
  let one : Vec[Real]<1> = [7.5]
  print(real_to_string(a[2]))
  print(real_to_string(head3(a)))
  print(real_to_string(one[0]))
  print(real_to_string(linalg.dot(a, a)))
}
