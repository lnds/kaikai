# Every kind introducer is contextual: `unit` declares a habitant in
# declaration position and is an ordinary identifier everywhere else.
unit m
unit s

fn speed(d: Real<m>, t: Real<s>) : Real<m/s> = d / t

pub fn main() : Unit / Console = {
  let unit = 42
  let currency = 7
  let region = 1
  let layout = 2
  let _v = speed(10.0<m>, 2.0<s>)
  print(int_to_string(unit + currency + region + layout))
}
