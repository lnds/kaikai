# A `match` scrutinee ending in a nullary variant followed by `{`
# opens the arms block, not a positional record literal.

#[derive(Eq)]
type Terrain = Forest | Water

fn describe(id: Terrain) : String = {
  match id == Forest {
    true  -> "trees"
    false -> "waves"
  }
}

fn main() : Int / Console {
  print(describe(Forest))
  print(describe(Water))
  0
}
