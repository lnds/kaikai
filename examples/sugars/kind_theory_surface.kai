# Positive fixture: the `theory` / `kind` declaration surface parses,
# and the existing units-of-measure surface (`unit`, `Real<m>`, unit
# literals) keeps working identically — v1 keeps Measure on its
# hardcoded path, so the catalog decls are recognised but change no
# runtime behaviour.

theory AbelianGroup = { assoc, commut, inverse, identity }
kind Measure : AbelianGroup with unit

unit m

fn scale(d: Real<m>) : Real<m> = d

fn main() : Unit / Console = {
  let d : Real<m> = 5.0<m>
  let _ = scale(d)
  print("kind surface ok")
}
