# Regression for the bug where a parenthesised lambda discarded its
# annotated parameter type (`Param { ptype: None }`). The annotation is the
# only source of `x`'s type here — the body just returns `x`, so without the
# annotation flowing through, monomorphisation has nothing to pin it to. A
# wrong annotation (e.g. `: Real`) would make `int_to_string` reject it.
fn main() : Unit / Stdout {
  let id = (x: Int) => x
  Stdout.print(int_to_string(id(42)))
}
