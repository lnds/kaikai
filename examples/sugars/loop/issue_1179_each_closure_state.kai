# A `var` captured by a non-loop closure (applied eagerly by `each`)
# must keep the dispatched State handler: the loop lowering only
# dissolves the while/until/repeat combinators. The harness greps the
# emitted C for the presence of the desugar-minted State clauses.
fn each_sum(n: Int) : Int = {
  var c := 0
  [1..n] |> each((x) => { c := c + x })
  c
}

fn main() : Unit / Io {
  println(int_to_string(each_sum(4)))
}
