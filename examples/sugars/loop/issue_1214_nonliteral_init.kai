# Issue #1214 — a non-escaping scalar `var` whose init is a PURE scalar but
# not a literal (`var m := n`, `var m := n*2+1`) lowers to a raw register
# cell, exactly like a literal init. The `while`+`var` spelling then compiles
# to the same raw loop tail recursion already gets, closing the ~16x gap.
# An impure init (a call) or a non-scalar init (String) keeps the array slot.
# The harness greps the emitted C for the raw cells and the retained arrays.

import loop

fn twice(x: Int) : Int = x * 2

# `var m := n` — a plain local read init. Promotes.
fn collatz(n: Int) : Int = {
  var m := n
  var steps := 0
  while { m != 1 } {
    if m % 2 == 0 { m := m / 2 } else { m := 3 * m + 1 }
    steps := steps + 1
  }
  steps
}

# `var m := n * 2 + 1` — builtin arithmetic over a local. Promotes.
fn arith(n: Int) : Int = {
  var m := n * 2 + 1
  var i := 0
  while { i < 4 } {
    m := m + i
    i := i + 1
  }
  m
}

# `var m := twice(n)` — a call init. Not locally provable as a raw border;
# keeps the array slot.
fn callinit(n: Int) : Int = {
  var m := twice(n)
  var i := 0
  while { i < 4 } {
    m := m + i
    i := i + 1
  }
  m
}

# `var acc := s` — a String (non-scalar) init. Keeps the array slot.
fn strloop(s: String) : Int = {
  var acc := s
  var i := 0
  while { i < 2 } {
    acc := acc
    i := i + 1
  }
  string_length(acc)
}

fn main() : Int / Stdout = {
  Stdout.print("collatz=#{int_to_string(collatz(27))}")
  Stdout.print("arith=#{int_to_string(arith(5))}")
  Stdout.print("call=#{int_to_string(callinit(5))}")
  Stdout.print("str=#{int_to_string(strloop("hello"))}")
  0
}
