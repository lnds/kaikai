# A local `var` mutated only by while/until/repeat bodies lowers to a
# stack slot on the C backend — no dispatched State handler, the loop
# emitted inline. The harness greps the emitted C for the absence of
# the desugar-minted State clauses.
import loop

fn sum_to(n: Int) : Int = {
  var i := 0
  var sum := 0
  while { i < n } {
    i := i + 1
    sum := sum + i
  }
  sum
}

fn count_down(n: Int) : Int = {
  var i := n
  until { i <= 0 } {
    i := i - 1
  }
  i
}

fn reps(n: Int) : Int = {
  var acc := 0
  repeat(n) {
    acc := acc + 2
  }
  acc
}

fn joins(n: Int) : String = {
  var i := 0
  var s := ""
  while { i < n } {
    i := i + 1
    s := string_concat(s, int_to_string(i))
  }
  s
}

fn nested(n: Int) : Int = {
  var total := 0
  var i := 0
  while { i < n } {
    var j := 0
    while { j < n } {
      j := j + 1
      total := total + 1
    }
    i := i + 1
  }
  total
}

fn main() : Unit / Io {
  println(int_to_string(sum_to(10)))
  println(int_to_string(count_down(5)))
  println(int_to_string(reps(4)))
  println(joins(4))
  println(int_to_string(nested(7)))
}
