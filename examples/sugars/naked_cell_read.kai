# A `var` cell reads NAKED: `counter` (not `@counter`). `:=` is the
# single mark of mutability — it declares the cell (`var counter := 0`)
# and writes it (`counter := counter + 1`). The read on the write's RHS
# is naked too, so read and write are symmetric. A naked cell read also
# flows through string interpolation and a `let` binding.
fn main() : Int {
  var counter := 0
  counter := counter + 1
  counter := counter + 1
  let r = counter
  assert r == 2
  assert counter == 2
  r
}
