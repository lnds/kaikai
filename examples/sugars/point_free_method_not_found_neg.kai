# A point-free section resolves its receiver from the combinator's
# element type, so an unknown method is rejected with the standard
# UFCS method-not-found diagnostic rather than a "receiver not
# resolved" cascade.

fn main() : Unit / Stdout {
  let words = ["alpha", "beta"]
  let bad = words | .no_such_method()
  Stdout.print(int_to_string(bad.length()))
}
