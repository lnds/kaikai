# Issue #385 — `.` placeholder in argument position with a binary
# arith op. `run_unary(. * 2, 3)` desugars to
# `run_unary((__pl) => __pl * 2, 3)` and evaluates as `3 * 2 = 6`.
# Self-contained for stage2 test-sugars (no stdlib loaded there).

fn run_unary(f: (Int) -> Int, x: Int) : Int = f(x)

fn main() : Unit / Console {
  let a = run_unary(. * 2, 3)   # 6
  let b = run_unary(. * 2, 7)   # 14
  print(int_to_string(a))
  print(int_to_string(b))
}
