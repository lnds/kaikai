# m7d §28: record destructuring in `let` with field punning. The
# canonical ergonomic answer to "I want to bind two related values
# without writing three lines" — paired with §10 record punning on
# the construction side.

type Pair = { fst: Int, snd: Int }

fn make_pair() : Pair = Pair { fst: 10, snd: 20 }

fn main() : Unit / Stdout {
  let { fst, snd } = make_pair()
  Stdout.print("fst=#{int_to_string(fst)} snd=#{int_to_string(snd)}")
}
