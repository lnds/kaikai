# Issue #415 — multi-clause function bodies (case-led arms).
#
# Single-arg form: scrutinee is the lone parameter; each `case`
# pattern matches against it directly (no implicit-tuple wrap).
# Desugar is `match n { 0 -> ... ; n when n<0 -> ... ; _ -> ... }`.

fn classify(n: Int) : String {
  case 0          -> "zero"
  case n when n < 0 -> "neg"
  case _          -> "pos"
}

fn main() : Int / Console {
  print(classify(0))
  print(classify(0 - 3))
  print(classify(5))
  0
}
