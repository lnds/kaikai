# issue #1108: `use kind Currency` makes a bare `<USD>` resolve to the
# Currency habitant even though `USD` is also a Measure unit.
kind Currency : AbelianGroup with cur

unit USD
cur USD
use kind Currency

fn hold(x: Real<USD>) : Real<USD> = x

pub fn main() : Unit / Console = {
  let a = hold(10.0<USD>)
  print("use kind ok")
}
