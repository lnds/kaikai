# m12.6.x #6 — a contract predicate that the parser-time const folder
# can prove `false` becomes a compile-time error pointing at the
# clause keyword. Without this check the runtime would panic on the
# first call; with it the compiler refuses the whole program.

fn buggy(x: Int) : Int
  requires false
  = x

fn main() : Unit / Stdout = Stdout.print("never reached")
