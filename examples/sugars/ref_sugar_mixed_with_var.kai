# issue #275 — `Ref[T]` sugar coexists with `var` sugar inside the
# same function. `var x` desugars to `State[Int]`; `c : Ref[Int]`
# routes to `Mutable.ref_*`. Each surface tracks an independent cell
# and the two desugars do not interfere.

fn main() : Unit / Mutable + Console = {
  let c = Mutable.ref_make(7)
  var x = 100
  x := @x + 1
  c := @c + 5
  print(int_to_string(@x))
  print(int_to_string(@c))
}
