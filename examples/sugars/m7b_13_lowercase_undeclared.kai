# m7b #13 — a lowercase identifier in type position is treated as
# a quantified type variable ONLY if it appears in the `[...]`
# tparam list. Without the declaration, `a` falls back to a nominal
# `TyCon("a", [])`, which fails unification at the call site. This
# pins the scoping rule: explicit declaration is required.

pub fn id(x: a) : a = x

fn main() : Int = id(42)
