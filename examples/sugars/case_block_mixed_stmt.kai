# Issue #415 — mixing a stmt (`let`) with case-arms inside the same
# fn body block is rejected at parse time, regardless of order. A
# block is either all statements or all `case` arms; the rule is
# enforced once stmt-mode has been entered (the first significant
# token was `let`, not `case`), so the trailing `case` is the one
# that earns the diagnostic.

fn bad(n: Int) : Int {
  let cache = 1
  case 0 -> cache
  case _ -> n + cache
}

fn main() : Int = 0
