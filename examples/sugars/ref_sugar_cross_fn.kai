# issue #275 — `Ref[T]` crosses function boundaries: `bump` reads its
# parameter `c` via `@c` and writes via `c := @c + 1`. Without the
# sugar this would have to spell `Mutable.ref_set(c, Mutable.ref_get(c) + 1)`.

fn bump(c: Ref[Int]) : Unit / Mutable = {
  c := @c + 1
}

fn main() : Unit / Mutable + Console = {
  let c = Mutable.ref_make(10)
  bump(c)
  bump(c)
  bump(c)
  print(int_to_string(@c))
}
