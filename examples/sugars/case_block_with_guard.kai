# Issue #415 — multi-clause function body, `when` guard form.
# Each arm's optional `when <expr>` mirrors the `if <expr>` guard of
# a regular `match` arm; the desugar attaches it to the lowered Arm.

fn pick(a: Int, b: Int) : String {
  case x, y when x > y -> "first-bigger"
  case x, y when x < y -> "second-bigger"
  case _, _            -> "equal"
}

fn main() : Int / Console {
  print(pick(7, 3))
  print(pick(2, 8))
  print(pick(4, 4))
  0
}
