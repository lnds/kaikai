# m12.6.x #5 — predicates built only from operators / literals /
# parameter references parse cleanly. The closed refinement-pure
# call set (is_some, is_none, is_finite, is_nan, string_length,
# list_length, matches) lives in the stdlib so test-sugars (which
# runs without a prelude) cannot use them — see demos for full-
# stdlib examples; the negative fixture m12_6_pred_impure_neg
# verifies the rejection path.

fn divide(a: Int, b: Int) : Int
  requires b != 0
  ensures result == a / b
  = a / b

fn clamp(x: Int) : Int
  requires x >= 0
  ensures result >= x
  = x + 1

fn main() : Unit / Stdout {
  Stdout.print("d=#{int_to_string(divide(10, 2))}")
  Stdout.print("c=#{int_to_string(clamp(5))}")
}
