# Phase 1 of #267 — `<digits>i` lexes as TkComplex and desugars at
# parse time to `complex.mk(0.0, <digits>)`. Pure imaginary literals
# from int, real, and exponent forms all flow through the same path.

fn main() : Unit / Console = {
  let a = 3i
  print(real_to_string(a.re))
  print(real_to_string(a.im))
  let b = 2.5i
  print(real_to_string(b.re))
  print(real_to_string(b.im))
  let c = 1e10i
  print(real_to_string(c.re))
  print(real_to_string(c.im))
}
