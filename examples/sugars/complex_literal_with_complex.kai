# Phase 1 of #267 — `Complex + 3.0i` works because both operands
# are Complex (3.0i desugars to complex.mk(0.0, 3.0)) and `impl Add
# for Complex` (issue #246) routes the operator. Heterogeneous
# `Real + Complex` still requires #180.

fn main() : Unit / Console = {
  let z = complex.from_real(2.0) + 3.0i
  print(real_to_string(z.re))
  print(real_to_string(z.im))
}
