# issue #412 — `|?` predicates with effects: the effect row is
# captured at the call site exactly as in `|` and `||`. The lambda
# below has effect `Console` (it prints), and the inferred row of
# `main` accumulates that label transitively through `list.filter`.

fn main() : Int / Console {
  let kept = [1, 2, 3, 4] |? (n) => {
    print("test")
    print(int_to_string(n))
    n > 2
  }
  each(kept, (x) => print(int_to_string(x)))
  0
}
