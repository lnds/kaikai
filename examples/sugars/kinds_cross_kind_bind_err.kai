# A habitant binds a unit tparam only within its own kind: a Module
# habitant does not inhabit `Measure`, so instantiating a
# Measure-generic fn at `Real<USD>` is a type error (the body would
# otherwise mint `USD^2` behind the formation guard's back).
kind Cur : Module with cur

cur USD

fn sq[u: Measure](x: Real<u>) : Real<u^2> = x * x

fn main() {
  let b = sq(3.0<USD>)
  print("no")
}
