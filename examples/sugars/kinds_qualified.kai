# issue #1108: `USD` lives in both Measure (`unit`) and Currency (`cur`);
# explicit qualification `<Currency.USD>` picks the Currency habitant.
kind Currency : AbelianGroup with cur

unit USD
cur USD

fn hold(x: Real<Currency.USD>) : Real<Currency.USD> = x

pub fn main() : Unit / Console = {
  let a = hold(10.0<Currency.USD>)
  print("qualified ok")
}
