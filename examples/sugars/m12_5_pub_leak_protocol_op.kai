# Privacy leak in `pub protocol` op signature: the public
# protocol `Sink` has an op whose parameter type `Token` is a
# non-`pub` type in the same module. A consumer implementing
# `impl Sink for X` would need to name `Token` in the method
# signature. The validator must report the leak at the op
# declaration.

type Token = Tok(Int)

pub protocol Sink {
  accept(self: Self, t: Token) : Unit
}
