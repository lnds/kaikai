# `s[A]` ranges over arity-1 constructors only. Passing a bare scalar
# (`Int`) where `s[Int]` is expected fails first-order unification —
# `Int` is not `s` applied to anything — a clean type error, not a hang.
protocol Container[s: Shape] {
  first(xs: s[Int]) : Int
}

type Box[a] = Box(a)

impl Container for Box {
  fn first(xs: Box[Int]) : Int = match xs {
    Box(v) -> v
  }
}

pub fn main() : Unit / Console = print(int_to_string(first(42)))
