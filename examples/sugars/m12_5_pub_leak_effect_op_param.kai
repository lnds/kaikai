# Privacy leak in `pub effect` op signature: the public effect
# `Storage` has an op whose parameter type `Token` is a non-`pub`
# type in the same module. A consumer handling this effect would
# need to bind a `Token` in its handler clause. The validator
# must report the leak at the op signature.

type Token = Tok(Int)

pub effect Storage {
  put(t: Token) : Unit
}
