# issue #422 — `|?` chained with `|` must work even when both
# stages use inline arrow-form lambdas.
#
# `[1..6] |? (n) => n % 2 == 0 | (n) => n * 2` parses as
# `([1..6] |? ((n) => n % 2 == 0)) | ((n) => n * 2)`,
# yielding [4, 8, 12].

fn main() : Int / Console {
  let out = [1..6] |? (n) => n % 2 == 0 | (n) => n * 2
  each(out, (x) => print(int_to_string(x)))
  0
}
