# m7e §13 — negative: `Option!` inside a function whose return type
# is `Result`. The diagnostic must name both the operand family
# (`Option`) and the enclosing return type (`Result[String, Int]`).

fn opt_int() : Option[Int] = Some(3)

fn wrong_return() : Result[String, Int] {
  let n = opt_int()!     # type error: Option in a Result-returning fn
  Ok(n)
}

fn main() {
  match wrong_return() {
    Ok(_)  -> print("ok")
    Err(_) -> print("err")
  }
}
