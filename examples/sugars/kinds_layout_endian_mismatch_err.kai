# issue #1189, test 1 (why a kind): `U32<be>` and `U32<le>` are the
# same base type but distinct representations — they never unify, so a
# big-endian value cannot be passed where little-endian is expected.
fn take_be(x: U32<be>) : U32<be> = x

fn bad(le_val: U32<le>) : U32<be> = take_be(le_val)

pub fn main() : Unit / Console = { print("unreachable") }
