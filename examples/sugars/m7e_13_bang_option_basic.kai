# m7e §13 — `expr!` on `Option[T]`, success path. The two callees
# both return `Some(...)`, so each `!` unwraps cleanly and the
# happy path runs top-to-bottom without a match pyramid.

fn lookup_a() : Option[Int] = Some(3)
fn lookup_b() : Option[Int] = Some(4)

fn add_them() : Option[Int] {
  let a = lookup_a()!
  let b = lookup_b()!
  Some(a + b)
}

fn main() : Unit / Console {
  match add_them() {
    Some(n) -> print(int_to_string(n))
    None    -> print("none")
  }
}
