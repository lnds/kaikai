# issue #266 — positional record sugar rejects mixing positional and
# named fields. The parser commits on the first item: a literal opens
# the positional path, so a subsequent `IDENT :` is rejected.

type Complex = { re: Real, im: Real }

fn main() : Unit / Stdout {
  let z = Complex { 1.0, im: 2.0 }
  Stdout.print(real_to_string(z.re))
}
