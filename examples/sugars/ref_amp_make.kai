# issue #1114 — `&x` opens a first-class `Ref[T]` (`Mutable.ref_make(x)`).
# The full trio on a binding: `&` makes, `:=` writes, `@` reads. `Mutable`
# is never written on the surface; it rides the inferred effect row.

fn main() : Unit / Mutable + Console = {
  let r = &10
  print(int_to_string(@r))
  r := @r + 32
  print(int_to_string(@r))
}
