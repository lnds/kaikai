import collections.map
import core.io

# Map literal builds a Map; `m[key]` get returns Some(value); empty
# literal has size 0.
fn main() : Unit / Stdout {
  let m = %{ "a": 1, "b": 2 }
  let ga = match m["a"] { Some(v) -> v  None -> -1 }
  let gb = match m["b"] { Some(v) -> v  None -> -1 }
  let gz = match m["z"] { Some(v) -> v  None -> -1 }
  let em : Map[String, Int] = %{}
  println("#{ga} #{gb} #{gz} #{map.size(m)} #{map.size(em)}")
}
