# Bug 8: `unitless` was removed from the user-visible prelude. Calling
# it from user code must now fail at name resolution. The typer's
# internal unit erasure is preserved (it's part of codegen) but the
# user cannot invoke it directly.

unit USD

pub fn main() : Unit = {
  let price : Real<USD> = 100.0<USD>
  let _raw = unitless(price)        # error: unknown identifier
  print("unreachable")
}
