# m12.5: emit real numeric value of a `Real<unit>`. Both backends
# must produce identical output. Reveals Bug 3 in docs/m12.8-followup.md
# (LLVM prints `0` instead of the real value).

unit USD

pub fn main() : Unit = {
  let amount : Real<USD> = 100.0<USD>
  print(real_to_string(unitless(amount)))
}
