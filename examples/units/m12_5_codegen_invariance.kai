# m12.5: codegen erasure smoke. Both functions should emit byte-identical C.

unit USD

pub fn add_units(x: Real<USD>, y: Real<USD>) : Real<USD> = x + y
pub fn add_plain(x: Real, y: Real) : Real = x + y

pub fn main() : Unit = {
  let a = add_units(1.0<USD>, 2.0<USD>)
  let b = add_plain(1.0, 2.0)
  print("codegen invariance smoke")
}
