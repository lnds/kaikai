# m12.5: arithmetic over dimensioned values.

unit USD
unit m
unit sec

pub fn main() : Unit  / Console = {
  let usd_a : Real<USD> = 1.0<USD>
  let usd_b : Real<USD> = 2.0<USD>
  let total : Real<USD> = usd_a + usd_b
  let dist : Real<m> = 5.0<m>
  let elapsed : Real<sec> = 2.0<sec>
  let speed = dist / elapsed
  let area_factor = dist * dist
  print("arith ok")
}
