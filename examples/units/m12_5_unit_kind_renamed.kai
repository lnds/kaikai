# Issue #253: the kind for unit-of-measure tparams was renamed
# from `Unit` to `Measure` to disambiguate from `Unit` the
# void-return type. Writing `[u: Unit]` in kind position must now
# fail with a targeted diagnostic that names `Measure` as the
# replacement and points out the type/kind collision.

unit USD

pub fn double[u: Unit](x: Real<u>) : Real<u> = x + x

pub fn main() : Unit = {
  let p : Real<USD> = 100.0<USD>
  let _ = double(p)
  print("unreachable")
}
