# Wave Op-1 — exercise `impl Rem` for a user-defined record where
# the body is a non-trivial computation. Encodes a "clock-arithmetic"
# residue (mod 12) and verifies the protocol-method dispatch carries
# the user's reduction logic through the operator.

type Clock = { hours: Int }

impl Rem for Clock {
  fn rem(self: Clock, rhs: Clock) : Clock = {
    let raw = self.hours % rhs.hours
    let normalised = if raw < 0 { raw + rhs.hours } else { raw }
    Clock { hours: normalised }
  }
}

fn main() : Int {
  let day = Clock { hours: 27 }
  let twelve = Clock { hours: 12 }
  let r1 = day % twelve
  print(int_to_string(r1.hours))

  let neg = Clock { hours: -5 }
  let r2 = neg % twelve
  print(int_to_string(r2.hours))
  0
}
