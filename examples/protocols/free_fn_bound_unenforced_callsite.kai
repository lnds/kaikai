# Issue #1099: a `[T: Eq]` bound on a free fn is a precondition on the
# caller's type, enforced at the concrete call site even when the
# body never dispatches the bounded op. `f`s body ignores `eq`, so
# pre-#1099 this compiled with `Q` (no `Eq` impl); now it is rejected
# at the call site, not inside the callee.

type Q = { v: Int }

fn f[T: Eq](xs: [T]) : Int = 0

fn main() : Int = {
  let _ = f([Q{v:1}])
  0
}
