# Issue #373: `impl Hash for Real` (via the `real_bits` IEEE-754
# bit-cast builtin) must separate distinct doubles — including
# fractions that an `int_of_real` truncation would collapse (1.5 and
# 1.9 both truncate to 1). Plus issue #373/#374 §4: Result / Option
# variant mixing now multiplies the tag against a large prime, so
# distinct variants with equal-hashing payloads no longer collide
# (the old additive offsets made `Ok(1)` == `Err(0)`).

fn main() : Int {
  # Real: fractions that truncation would merge stay distinct.
  if hash(1.5) == hash(1.9) { print("1.5==1.9 (BUG)") } else { print("1.5!=1.9 (ok)") }
  if hash(0.0) == hash(1.0) { print("0.0==1.0 (BUG)") } else { print("0.0!=1.0 (ok)") }
  if hash(1.5) == hash(1.5) { print("1.5==1.5 (ok)") } else { print("1.5!=1.5 (BUG)") }

  # Result: Ok(1) and Err(0) used to both hash to 3.
  let ok1 : Result[Int, Int] = Ok(1)
  let err0 : Result[Int, Int] = Err(0)
  if hash(ok1) == hash(err0) { print("Ok(1)==Err(0) (BUG)") } else { print("Ok(1)!=Err(0) (ok)") }

  # Option: Some(0) and None must not collide either.
  let some0 : Option[Int] = Some(0)
  let none_ : Option[Int] = None
  if hash(some0) == hash(none_) { print("Some(0)==None (BUG)") } else { print("Some(0)!=None (ok)") }
  0
}
