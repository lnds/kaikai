# m12.8: `#derive(Show)` synthesises a structural impl for a record
# whose fields already implement Show.

protocol Show {
  show(x: Self) : String
}

impl Show for Int {
  fn show(n: Int) : String = int_to_string(n)
}

#derive(Show)
type Point = { x: Int, y: Int }

fn main() : Int {
  let p = Point { x: 3, y: 4 }
  print(show(p))
  0
}
