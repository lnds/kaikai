# m12.8.z: sum type with payloads. Variant position dominates: any
# `Square(_)` is greater than every `Circle(_)` regardless of the
# inner radius. Within the same variant, payloads are compared
# lexicographically (here, just one Int).

protocol Ord {
  cmp(a: Self, b: Self) : Int
}

impl Ord for Int {
  fn cmp(a: Int, b: Int) : Int =
    if a < b { -1 } else if a > b { 1 } else { 0 }
}

#derive(Ord)
type Shape = Circle(Int) | Square(Int) | Origin

fn main() : Int {
  # Circle vs Circle: payload decides
  print(int_to_string(cmp(Circle(3), Circle(5))))
  print(int_to_string(cmp(Circle(7), Circle(2))))
  print(int_to_string(cmp(Circle(4), Circle(4))))
  # Position dominates: Circle(huge) < Square(tiny)
  print(int_to_string(cmp(Circle(99), Square(0))))
  # Square > Circle regardless
  print(int_to_string(cmp(Square(0), Circle(99))))
  # Origin (no payload, last position) > everything else
  print(int_to_string(cmp(Origin, Square(100))))
  print(int_to_string(cmp(Square(100), Origin)))
  print(int_to_string(cmp(Origin, Origin)))
  0
}
