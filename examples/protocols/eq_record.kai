# m12.8: protocol Eq dispatched against a user-defined record.

protocol Eq {
  eq(a: Self, b: Self) : Bool
}

type Point = { x: Int, y: Int }

impl Eq for Point {
  fn eq(a: Point, b: Point) : Bool = a.x == b.x and a.y == b.y
}

fn main() : Int {
  let p = Point { x: 1, y: 2 }
  let q = Point { x: 1, y: 2 }
  let r = Point { x: 3, y: 4 }
  if eq(p, q) { print("p == q") } else { print("p != q") }
  if eq(p, r) { print("p == r") } else { print("p != r") }
  0
}
