# Issue #877 (negative): a free `fn[T : Ord]` is instantiated at a
# type with no `Ord` impl. The bound cannot be satisfied, so the
# post-monomorphisation dispatch validator (#174) rejects the call at
# compile time and points at the `cmp(a, b)` site, rather than letting
# the dispatcher panic at runtime.

type Box = Box(Int)

fn pick_larger[T : Ord](a: T, b: T) : T =
  if cmp(a, b) > 0 { a } else { b }

fn main() : Int {
  let _ = pick_larger(Box(1), Box(2))
  0
}
