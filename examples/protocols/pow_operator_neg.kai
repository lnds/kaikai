# Negative fixture: a non-literal exponent on a dimensioned base
# is rejected at type-check time. The compiler cannot lift the unit
# `m^n` when `n` is not known statically (no dependent types).

unit m

fn main() : Int {
  let r : Real<m> = 3.0<m>
  let n = 2
  let bad = r ^ n
  print(real_to_string(__strip_unit(bad)))
  0
}
