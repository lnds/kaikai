# m12.8: minimal protocol smoke test.
#
# `show(42)` resolves to `__pimpl_Show_Int_show(42)` post-inference,
# which delegates to the user-defined impl.

protocol Show {
  show(x: Self) : String
}

impl Show for Int {
  fn show(n: Int) : String = int_to_string(n)
}

fn main() : Int {
  print(show(42))
  print(show(-7))
  0
}
