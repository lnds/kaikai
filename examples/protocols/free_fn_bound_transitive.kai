# Issue #1099: a generic caller `g[T]` that forwards its own tparam to
# a bounded `f[T: Eq]` does NOT propagate the constraint onto `g` — it
# defers to `g`s own instantiation (no Haskell-style propagation). But
# when `g` is instantiated at a concrete `Q` with no `Eq`, the
# transitive instance `f@Q` is materialised and the bound is enforced.

type Q = { v: Int }

fn f[T: Eq](xs: [T]) : Int = 0
fn g[T](xs: [T]) : Int = f(xs)

fn main() : Int = {
  let _ = g([Q{v:1}])
  0
}
