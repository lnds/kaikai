# m12.8: an `impl` whose protocol name is unknown is rejected before
# code generation runs. Coherence requires the protocol to be declared
# (here or in an imported module); a typo or a missing import should
# surface as a clean diagnostic.

protocol Show {
  show(x: Self) : String
}

impl Foo for Int {
  fn foo(n: Int) : String = "x"
}

fn main() : Int = 0
