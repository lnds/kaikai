# m12.8 dogfooding (A2/Z): exercises Show / Eq / Hash / Ord derives on
# record and sum-type shapes that mirror the kaikai compiler's
# internal data structures (Pos = (line, col); Span = (start, length);
# nested record carrying both; a small TokKind sum). The compiler's
# own selfhost pipeline cannot use these protocols — its bootstrap
# does not load stdlib/protocols.kai — so the validation lives here,
# next to the real shapes, instead.

# Pos mirrors the (line, col) carriers throughout stage2/compiler.kai.
#[derive(Show, Eq, Hash, Ord)]
type Pos = { line: Int, col: Int }

# Span mirrors the (start, length) pair the lexer produces alongside
# every token and the diagnostics module reads.
#[derive(Show, Eq, Hash, Ord)]
type Span = { start: Int, length: Int }

# Nested record: record-of-records. Validates that each derived
# protocol on the outer record correctly delegates to the inner
# records' impls.
#[derive(Show, Eq, Hash, Ord)]
type Located = { pos: Pos, span: Span }

# Small sum type mirroring the compiler's TokKind: nullary keywords
# plus payload-bearing literal variants.
#[derive(Show, Eq, Hash, Ord)]
type TokKind
  = TInt(Int)
  | TKwLet
  | TKwFn
  | TLParen
  | TRParen

fn check_pos() : Unit / Console {
  let p1 = Pos { line: 5, col: 3 }
  let p2 = Pos { line: 5, col: 3 }
  let p3 = Pos { line: 6, col: 1 }
  assert eq(p1, p2)
  assert not eq(p1, p3)
  assert hash(p1) == hash(p2)
  assert cmp(p1, p2) == 0
  assert cmp(p1, p3) == -1
  assert cmp(p3, p1) == 1
  print(show(p1))
}

fn check_span() : Unit / Console {
  let s1 = Span { start: 10, length: 4 }
  let s2 = Span { start: 10, length: 4 }
  let s3 = Span { start: 10, length: 5 }
  assert eq(s1, s2)
  assert not eq(s1, s3)
  assert hash(s1) == hash(s2)
  assert cmp(s1, s3) == -1
  print(show(s1))
}

fn check_located() : Unit / Console {
  let l1 = Located { pos: Pos { line: 1, col: 2 }, span: Span { start: 0, length: 3 } }
  let l2 = Located { pos: Pos { line: 1, col: 2 }, span: Span { start: 0, length: 3 } }
  let l3 = Located { pos: Pos { line: 1, col: 2 }, span: Span { start: 4, length: 3 } }
  assert eq(l1, l2)
  assert not eq(l1, l3)
  assert hash(l1) == hash(l2)
  assert cmp(l1, l3) == -1
  print(show(l1))
}

fn check_tokkind() : Unit / Console {
  assert eq(TKwLet, TKwLet)
  assert not eq(TKwLet, TKwFn)
  assert eq(TInt(7), TInt(7))
  assert not eq(TInt(7), TInt(8))
  assert hash(TKwLet) == hash(TKwLet)
  assert hash(TInt(42)) == hash(TInt(42))
  # Variant declaration order: TInt, TKwLet, TKwFn, TLParen, TRParen.
  assert cmp(TInt(1), TKwLet) == -1
  assert cmp(TKwFn, TInt(99)) == 1
  assert cmp(TLParen, TLParen) == 0
  # Same variant, different payload: payload comparison wins.
  assert cmp(TInt(1), TInt(2)) == -1
  print(show(TInt(42)))
  print(show(TKwLet))
  print(show(TLParen))
}

fn main() : Int {
  check_pos()
  check_span()
  check_located()
  check_tokkind()
  0
}
