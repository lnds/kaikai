# Issue #893: the post-rewrite validator is collision-aware. `add` is
# declared by `Ring` here and by the stdlib `Add[a]`; a call on a type
# with NO matching impl (`String`) must be rejected with a clear
# diagnostic naming the protocol — not fixed to the wrong protocol and
# not allowed to reach a misdispatched runtime panic/segfault.

protocol Ring { add(a: Self, b: Self) : Self }
impl Ring for Int { fn add(a: Int, b: Int) : Int = a + b }

fn sum_two[T : Ring](a: T, b: T) : T = add(a, b)

fn main() : Int {
  print(sum_two("x", "y"))
  0
}
