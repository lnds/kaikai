# m12.8.x phase 2 (Bug 4): `#{x}` interpolation now dispatches via
# Show when the program has the protocol declared. The desugar pass
# lifts each interp body into `show(...)` ahead of inference so the
# post-inference rewrite routes to the user's `__pimpl_Show_<T>_show`.
# When `Show` is not declared the legacy `kai_to_string` path stays
# in place — verified by the existing `examples/phase4/*` fixtures.

type Money = { amount: Int, currency: String }

impl Show for Money {
  fn show(m: Money) : String =
    int_to_string(m.amount) ++ " " ++ m.currency
}

fn main() : Int {
  let m = Money { amount: 100, currency: "USD" }
  let m2 = Money { amount: 50, currency: "EUR" }
  print("Balance: #{m}")
  print("Two amounts: #{m} and #{m2}.")
  print("Plain int via Show: #{42}")
  0
}
