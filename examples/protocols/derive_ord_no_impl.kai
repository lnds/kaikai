# m12.8.z: `#derive(Ord)` requires every field's type to have an
# `Ord` impl. Here the record holds a String, but the test scope
# only declares `impl Ord for Int` — the synthesised `cmp` body
# expands to `cmp(a.tag, b.tag)`, and the typer rejects that call
# because no `cmp` impl matches `(String, String)`. The diagnostic
# names the missing protocol, surfacing the failure at the field
# level.

protocol Ord {
  cmp(a: Self, b: Self) : Int
}

impl Ord for Int {
  fn cmp(a: Int, b: Int) : Int =
    if a < b { -1 } else if a > b { 1 } else { 0 }
}

#derive(Ord)
type Tagged = { id: Int, tag: String }

fn main() : Int {
  let p = Tagged { id: 1, tag: "a" }
  let q = Tagged { id: 1, tag: "b" }
  print(int_to_string(cmp(p, q)))
  0
}
