# m12.8: protocol Ord with `cmp` returning Int.

protocol Ord {
  cmp(a: Self, b: Self) : Int
}

impl Ord for Int {
  fn cmp(a: Int, b: Int) : Int {
    if a < b { -1 } else if a > b { 1 } else { 0 }
  }
}

fn main() : Int {
  print(int_to_string(cmp(5, 7)))
  print(int_to_string(cmp(7, 5)))
  print(int_to_string(cmp(7, 7)))
  0
}
