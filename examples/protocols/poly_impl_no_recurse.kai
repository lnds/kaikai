# Issue #174 (case 3): a polymorphic impl whose body never recurses
# on the type variable does NOT need a bound. `T` does not appear in
# any protocol-dispatched position inside the body, so the impl
# trivially monomorphises and runs.

protocol Show {
  show(x: Self) : String
}

impl[T] Show for [T] {
  fn show(xs: [T]) : String = "list-of-something"
}

fn main() : Int {
  let xs : [Int] = [1, 2, 3]
  print(show(xs))
  0
}
