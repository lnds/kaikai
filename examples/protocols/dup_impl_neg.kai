# m12.8: two `impl Show for Int` blocks in the same compilation unit
# violates the single-impl-per-(protocol, type) coherence rule.

protocol Show {
  show(x: Self) : String
}

impl Show for Int {
  fn show(n: Int) : String = int_to_string(n)
}

impl Show for Int {
  fn show(n: Int) : String = "duplicate!"
}

fn main() : Int = 0
