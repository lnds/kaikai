# m12.8: `#derive(Show)` on a sum type whose payload types already
# implement Show.

protocol Show {
  show(x: Self) : String
}

impl Show for Int {
  fn show(n: Int) : String = int_to_string(n)
}

#derive(Show)
type Shape = Circle(Int) | Square(Int) | None_

fn main() : Int {
  print(show(Circle(5)))
  print(show(Square(7)))
  print(show(None_))
  0
}
