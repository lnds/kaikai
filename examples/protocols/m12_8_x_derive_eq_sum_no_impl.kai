# m12.8.x: `#derive(Eq)` rejects sum types whose variants carry a
# field type without a reachable `impl Eq`. The diagnostic must
# name the variant and the offending field type.

protocol Eq {
  eq(a: Self, b: Self) : Bool
}

impl Eq for Int {
  fn eq(a: Int, b: Int) : Bool = a == b
}

# `Payload` has no `impl Eq` and is not itself derived.
type Payload = { data: Int }

#derive(Eq)
type Bad = Plain(Int) | Wrapped(Payload)

fn main() : Int = 0
