# m12.8.x: when both `#derive(Eq)` and `#derive(Hash)` apply to the
# same sum type, the Hash↔Eq invariant must hold: equal values hash
# to the same Int. This fixture exercises payloads of every shape:
# constant variant, single-field variant, multi-field variant.

protocol Eq {
  eq(a: Self, b: Self) : Bool
}

protocol Hash {
  hash(x: Self) : Int
}

impl Eq for Int {
  fn eq(a: Int, b: Int) : Bool = a == b
}

impl Eq for Bool {
  fn eq(a: Bool, b: Bool) : Bool = a == b
}

impl Hash for Int {
  fn hash(n: Int) : Int = n
}

impl Hash for Bool {
  fn hash(b: Bool) : Int = if b { 1 } else { 0 }
}

#derive(Eq, Hash)
type Color = Red | Green | Blue | Custom(Int, Int, Int) | Named(Int)

fn check(label: String, a: Color, b: Color) : Unit / Console {
  let are_eq = eq(a, b)
  let same_hash = hash(a) == hash(b)
  if are_eq {
    if same_hash {
      print(string_concat_all([label, ": eq + same hash (invariant OK)"]))
    } else {
      print(string_concat_all([label, ": eq + diff hash (INVARIANT BROKEN)"]))
    }
  } else {
    if same_hash {
      print(string_concat_all([label, ": neq + same hash (collision)"]))
    } else {
      print(string_concat_all([label, ": neq + diff hash"]))
    }
  }
}

fn main() : Int {
  check("Red == Red", Red, Red)
  check("Red == Green", Red, Green)
  check("Custom == Custom (same)", Custom(255, 0, 0), Custom(255, 0, 0))
  check("Custom == Custom (diff)", Custom(255, 0, 0), Custom(0, 255, 0))
  check("Named == Named (same)", Named(7), Named(7))
  check("Named == Named (diff)", Named(7), Named(8))
  check("Red == Custom", Red, Custom(0, 0, 0))
  0
}
