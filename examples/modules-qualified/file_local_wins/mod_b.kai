# Issue #335 regression — see mod_a.kai. mod_b's `foo` takes two
# arguments; a bare `foo` call inside mod_b's own tests must resolve
# to this two-arg form.

pub fn foo(x: Int, y: Int) : Int = x + y

test "mod_b.foo binds to mod_b's foo (file-local wins)" {
  assert foo(1, 2) == 3
  assert foo(40, 2) == 42
}
