# m6.2 sanity: record-field projection still works after rqc lands.
# This fixture has NO imports, so the module table is empty and
# every EField stays an EField. The whole pipeline behaves exactly
# as before m6.2.

pub type Point = { x: Int, y: Int }

fn main() {
  let p = Point { x: 3, y: 4 }
  print(int_to_string(p.x))
  print(int_to_string(p.y))
}
