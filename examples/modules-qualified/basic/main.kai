# m6.2 qualified-call basic: `arith.add1(...)` resolves to the
# `add1` function exported by module `arith`. Distinct from any
# unqualified `add1` (none here, but the resolver still rewrites
# the EField into EModCall so the codegen path is the qualified
# branch).

import arith

fn main() {
  print(int_to_string(arith.add1(41)))
  print(int_to_string(arith.double(21)))
}
