# Issue #232 negative fixture: an unknown module qualifier in a
# type position must produce a clear diagnostic and fail the
# compile. The qtchk pass walks every decl-level TypeExpr,
# detects the dotted form, and validates `mod` against the module
# table; mismatches raise the diagnostic listed in
# `main.err.expected`.

fn area(s: unknown_module.Foo) : Int { 42 }

fn main() {
  print(int_to_string(area(0)))
}
