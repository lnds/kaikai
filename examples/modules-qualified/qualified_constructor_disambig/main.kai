# Issue #234: qualified variant constructors `mod.Ctor` accepted in
# expression and pattern position. The parser folds the qualifier
# into a regular `EField(EVar(mod), "Ctor")` shape; rqc rewrites it
# to `EVar("Ctor")` once the module table confirms `mod` exports
# `Ctor`. Variant ctors are auto-declared globally per #187, so the
# stripped form resolves like the bare-name surface used today.

import auth
import billing

fn describe_a(s: auth.AuthStatus) : String {
  match s {
    auth.Active    -> "auth: active"
    auth.Suspended -> "auth: suspended"
  }
}

fn describe_b(s: billing.BillStatus) : String {
  match s {
    billing.Pending -> "billing: pending"
    billing.Paid    -> "billing: paid"
  }
}

fn main() {
  let a = auth.Active
  let b = billing.Pending
  print(describe_a(a))
  print(describe_b(b))
}
