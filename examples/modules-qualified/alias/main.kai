# m6.2 qualified-call with alias: `import arith as A` introduces
# the binding `A` (not `arith`). Calls go through `A.add1` etc.
# rqc populates the module table with name=A so the rewrite triggers
# only on `A.<fn>`, never on `arith.<fn>`.

import arith as A

fn main() {
  print(int_to_string(A.add1(41)))
  print(int_to_string(A.square(7)))
}
