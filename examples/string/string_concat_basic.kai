# `string.concat` тАФ public wrapper over the runtime primitive
# `string_concat`. Closes #336 (deferred from #332/#334; unblocked
# by the resolver fix in #335).

fn main() : Unit / Console {
  print(string.concat("ho", "la"))
  print(string.concat("", "abc"))
  print(string.concat("abc", ""))
  print(string.concat("", ""))
}
