# `string.length` тАФ public wrapper over the runtime primitive
# `string_length`. Closes #332 (the m14 phase 2 gap from #203).

fn main() : Unit / Console {
  print("len_empty=#{string.length("")}")
  print("len_one=#{string.length("a")}")
  print("len_hola=#{string.length("hola")}")
  print("len_ascii=#{string.length("hello world")}")
}
