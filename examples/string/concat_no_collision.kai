# Issue #336 — `string.concat(a, b)` and `list.concat(xss)` share
# the bare name but have distinct schemes. With both in scope, the
# qualified surface disambiguates: `string.concat` for binary
# string concatenation, `list.concat` for flattening a list of
# lists. #335's resolver fix keeps file-local precedence working
# inside `core/list.kai` itself; this fixture covers the external
# caller path.

fn show_int_list(xs: [Int]) : String =
  string.concat("[", string.concat(string.join(map(xs, int_to_string), ","), "]"))

fn main() : Unit / Console {
  print(string.concat("ho", "la"))
  print(show_int_list(list.concat([[1, 2], [3], [], [4, 5]])))
  print(show_int_list(list.concat([])))
}
