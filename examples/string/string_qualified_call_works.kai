# Regression guard: the qualified surface `string.length` /
# `string.slice` / `string.concat` and the flat PRELUDE primitives
# `string_length` / `string_slice` / `string_concat` must produce
# the same value. The flat names live below the user-facing
# language (stage 0's PRELUDE table) and are kept available for
# bootstrap code; the wrappers added in #332 (length/slice/to_int)
# and #336 (concat) must not shadow them.

fn main() : Unit / Console {
  let s = "kaikai"
  let qualified = string.length(s)
  let flat = string_length(s)
  if qualified == flat { print("len match=#{qualified}") }
  else { print("len MISMATCH q=#{qualified} f=#{flat}") }

  let qs = string.slice("kaikai", 2, 3)
  let fs = string_slice("kaikai", 2, 3)
  if qs == fs { print("slice match=#{qs}") }
  else { print("slice MISMATCH q=#{qs} f=#{fs}") }

  let qc = string.concat("hen", "ua")
  let fc = string_concat("hen", "ua")
  if qc == fc { print("concat match=#{qc}") }
  else { print("concat MISMATCH q=#{qc} f=#{fc}") }
}
