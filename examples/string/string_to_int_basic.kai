# `string.to_int` — public wrapper over the runtime primitive
# `string_to_int`. Returns `Option[Int]`: `Some(v)` on a clean
# decimal parse, `None` otherwise. The primitive does not
# panic on parse failure; the wrapper inherits that contract.

fn main() : Unit / Console {
  match string.to_int("42") {
    Some(v) -> print("ok=#{v}")
    None -> print("none")
  }
  match string.to_int("0") {
    Some(v) -> print("zero=#{v}")
    None -> print("none")
  }
  match string.to_int("abc") {
    Some(v) -> print("ok=#{v}")
    None -> print("bad=none")
  }
  match string.to_int("") {
    Some(v) -> print("ok=#{v}")
    None -> print("empty=none")
  }
  match string.to_int("12x") {
    Some(v) -> print("ok=#{v}")
    None -> print("trail=none")
  }
}
