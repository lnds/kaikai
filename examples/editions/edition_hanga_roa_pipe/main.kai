# Issue #603 — under `edition = "hanga-roa"` the convention-based pipe
# dispatch from #594 is active. `box.kai` exports a `pub type Box[a]`
# and a canonical `pub fn map`, so `b | f` lowers to `box.map(b, f)`.

import box

fn main() : Unit / Console {
  let b = Box(20)
  let r = b | { x -> x + 1 } | { x -> x * 2 }
  print(int_to_string(unwrap(r)))
}
