# Issue #603 fixture support — a user-defined parametric `pub type
# Box` plus a canonical `pub fn map` that the convention-based pipe
# dispatch (#594) routes against under the hanga-roa edition.

pub type Box[a] = Box(a)

pub fn map(b: Box[a], f: (a) -> b) : Box[b] = match b {
  Box(v) -> Box(f(v))
}

pub fn unwrap(b: Box[a]) : a = match b {
  Box(v) -> v
}
