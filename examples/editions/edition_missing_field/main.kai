# Issue #603 — `kai.toml` without an `edition` field defaults to the
# repo `EDITION` value (today: tongariki). The pipe dispatch over `[a]`
# keeps working through the seeded mapping.

fn main() : Unit / Console {
  let xs = [10, 20, 30]
  let r = xs | { x -> x + 5 }
  match r {
    [a, b, c] -> {
      print(int_to_string(a))
      print(int_to_string(b))
      print(int_to_string(c))
    }
    _ -> print("unexpected")
  }
}
