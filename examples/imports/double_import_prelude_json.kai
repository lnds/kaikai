# Issue #425 regression: same fault shape as
# `double_import_prelude_toml`, applied to `encoding.json`. The JSON
# module is also loaded as a prelude by `bin/kai` so an explicit
# user `import encoding.json` would otherwise emit the module's C
# symbols a second time.

import encoding.json

fn main() : Unit / Stdout = {
  let s = "{\"k\": 1}"
  match json.json_decode(s) {
    Some(_) -> Stdout.print("ok")
    None    -> Stdout.print("fail")
  }
}
