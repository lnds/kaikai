# Issue #425 regression: same fault shape, applied to `core.list`.
# `bin/kai` auto-loads every `stdlib/core/*.kai` file (list, option,
# result, string, ...) as a prelude. An explicit user import of
# `core.list` would otherwise duplicate `kai_list__*` symbols.

import core.list

fn main() : Unit / Stdout = {
  let xs = [1, 2, 3]
  Stdout.print(int_to_string(list.length(xs)))
}
