# issue #205 Constraint #1 — field access wins on ties.
#
# When a record value has both a field `name` and a free function
# `name(record_type, ...)` exists in scope, `record.name` is a
# field access, not a UFCS dispatch. UFCS only fires when the field
# lookup misses. This is mandatory: changing the rule would break
# every existing record-field access whose name happens to clash
# with a function name.
#
# Setup: record `Person { id: Int, label: String }` and free
# function `label(p: Person) : String` that returns a derived
# label. `p.label` must resolve to the field, not the function.

type Person = { id: Int, label: String }

fn label(p: Person) : String = "fn:#{p.label}"

fn main() {
  let p = Person { id: 7, label: "field-label" }
  # Field access — wins over the free function.
  print(p.label)
  # Explicit prefix call — still calls the free function.
  print(label(p))
}
