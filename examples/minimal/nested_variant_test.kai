# Regression fixture — native-parity burn-down 4: nested-variant-test.
#
# A `match` arm with a PAYLOAD-bearing nested constructor sub-pattern
# (`Node(Node(_, kx, _), ky, _)`) needs the inner ctor's tag TESTED in the
# decision tree before its inner binders (`kx`) are read — otherwise a
# runtime `Leaf` in that slot reads garbage. Burn-down 3 covered the
# NULLARY nested case (`Branch(Red, _)`); this is the payload-bearing
# recursion (kir_lower_variant.kai `var_seal_nested` + kir_lower_bind.kai).
#
# Critically exercises the PARTIAL-MATCH path: `Node(Leaf, k, _)` must NOT
# match the first arm (inner is Leaf, not Node) and must fall to the second
# arm — proving the inner `kai_tag_eq` fail routes to the arm's next-fail,
# not the switch default. The `kaix_tag_eq` runtime guard (tagged-immediate
# safe) is also load-bearing: the inner slot can hold an Int (`peek`).

type Tree = Leaf | Node(Tree, Int, Tree)

# Nested Node sub-pattern at slot 0, with an inner binder `kx`.
fn left_key_sum(t: Tree) : Int = match t {
  Node(Node(_, kx, _), ky, _) -> kx + ky   # inner Node matched → bind kx
  Node(_, k, _)               -> k          # inner Leaf → falls here
  Leaf                        -> 0
}

# A second shape: the nested ctor at slot 2 (the right child), proving the
# slot index threads correctly through the recursion.
fn right_key(t: Tree) : Int = match t {
  Node(_, ky, Node(_, kx, _)) -> ky * 100 + kx
  Node(_, k, _)               -> k
  Leaf                        -> -1
}

fn main() = {
  let leaf = Leaf
  let inner = Node(Leaf, 7, Leaf)
  let outer = Node(inner, 3, Leaf)        # left child is a Node
  let flat = Node(Leaf, 5, Leaf)          # left child is a Leaf (partial-match)
  print(int_to_string(left_key_sum(outer)))   # inner matched: 7 + 3 = 10
  print(int_to_string(left_key_sum(flat)))     # inner Leaf → 5
  print(int_to_string(left_key_sum(leaf)))     # Leaf → 0
  let rg = Node(Leaf, 4, Node(Leaf, 9, Leaf))
  print(int_to_string(right_key(rg)))          # 4*100 + 9 = 409
  print(int_to_string(right_key(flat)))        # right Leaf → 5
}
