#[doc("""
A multi-line attribute — its body spans several physical lines and
contains a ] bracket, a [ too, and "quotes".
""")]
fn answer() : Int = 42

#[derive(
  Eq
)]
fn double(n: Int) : Int = n * 2

#[doc("single-line attribute")]
fn greet(name: String) : String = "hi #{name}"

fn main() {
  print(greet("kaikai"))
  print(int_to_string(answer() + double(0)))
}

test "code after a multi-line attribute lexes and runs" {
  assert answer() == 42
}

test "code after a bracketed multi-line attribute lexes and runs" {
  assert double(21) == 42
}
