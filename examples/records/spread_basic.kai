# Issue #326 — record-spread sugar (functional update).
# `T { ...src, x: 10 }` builds a new record from `src`'s fields,
# overriding the named ones. Verifies the simplest happy path:
# a single override; the other two fields come from `p`.

type P = { x: Int, y: Int, z: Int }

fn main() : Unit / Console {
  let p = P { x: 1, y: 2, z: 3 }
  let q = P { ...p, x: 10 }
  print("x=#{q.x}")
  print("y=#{q.y}")
  print("z=#{q.z}")
}
