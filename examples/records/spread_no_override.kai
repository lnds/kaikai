# Issue #326 — record-spread with zero overrides.
# `P { ...p }` is a degenerate but legal form: a structural copy.
# Useful to detect parser/desugar regressions that special-case
# the "must have at least one override" path.

type P = { x: Int, y: Int, z: Int }

fn main() : Unit / Console {
  let p = P { x: 1, y: 2, z: 3 }
  let q = P { ...p }
  print("x=#{q.x}")
  print("y=#{q.y}")
  print("z=#{q.z}")
}
