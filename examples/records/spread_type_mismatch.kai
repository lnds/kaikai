# Issue #326 — spread source must match the outer record type.
# Two structurally-identical records `P` and `Q` are still distinct
# nominal types; spreading a `Q` into a `P` literal must fail. The
# error reuses the typer's existing nominal `let`-annotation check
# (the desugarer wraps `src` in `let __spread_src__ : T = src`).

type P = { x: Int, y: Int }
type Q = { x: Int, y: Int }

fn main() : Unit / Console {
  let q = Q { x: 1, y: 2 }
  let p = P { ...q, x: 10 }
  print("x=#{p.x}")
}
