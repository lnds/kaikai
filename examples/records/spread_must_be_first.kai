# Issue #326 — `...` must be the first item in a record literal.
# `{ x: 10, ...p }` is rejected by the parser to avoid debate about
# override-direction precedence. v1 admits a single, leading spread.

type P = { x: Int, y: Int }

fn main() : Unit / Console {
  let p = P { x: 1, y: 2 }
  let q = P { x: 10, ...p }
  print("x=#{q.x}")
}
