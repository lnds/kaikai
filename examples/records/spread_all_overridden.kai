# Issue #326 — every field overridden in a spread.
# Degenerate case: `P { ...p, x: 10, y: 20, z: 30 }` is observably
# the same as `P { x: 10, y: 20, z: 30 }`. The desugarer should still
# emit a let-binding for `p` (we don't try to dead-code-eliminate
# the source) but the resulting record's fields come entirely from
# the override list.

type P = { x: Int, y: Int, z: Int }

fn main() : Unit / Console {
  let p = P { x: 1, y: 2, z: 3 }
  let q = P { ...p, x: 10, y: 20, z: 30 }
  print("x=#{q.x}")
  print("y=#{q.y}")
  print("z=#{q.z}")
}
