# Issue #326 — pun shorthand is not allowed after `...`.
# `{ ...p, x }` would silently mean "override x with the local x";
# the spec forbids this and requires the explicit `x: x` form to
# remove ambiguity at the construction site.

type P = { x: Int, y: Int }

fn main() : Unit / Console {
  let p = P { x: 1, y: 2 }
  let x = 99
  let q = P { ...p, x }
  print("x=#{q.x}")
}
