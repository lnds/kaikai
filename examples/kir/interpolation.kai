# KIR fixture: string interpolation lowers to a `string_concat_all`
# over a cons spine of the interpolated parts (NOT `string_concat_all(())`,
# the Lane 0 gap). `#{int_to_string(x)}` becomes the show-dispatched
# part joined onto the literal prefix.
fn greet(x: Int) : String = "x is #{int_to_string(x)}"

fn main() : Unit / Console = {
  Stdout.print(greet(42))
}
