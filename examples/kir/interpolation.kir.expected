fn greet(x: box) : box {
  entry:
    .t0: box = int_to_string(x)
    .t1: box = protocols____pimpl_Show_String_show(.t0)
    .t2: box = prim kai_nil()
    .t3: box = prim kai_cons(.t1, .t2)
    .t4: box = prim kai_cons("x is ", .t3)
    .t5: box = string_concat_all(.t4)
    ret .t5
}

fn main() : box {
