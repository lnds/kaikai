# KIR fixture: closures. A top-level fn passed by value lowers to a
# `KClosure` over its thunk; an inline lambda capturing an enclosing
# binding lowers to a `KClosure` carrying the capture, plus a lifted
# `KFnLambda` body whose capture param is marked `@cap`.
fn apply(f: (Int) -> Int, x: Int) : Int = f(x)

fn inc(n: Int) : Int = n + 1

fn main() : Unit / Console = {
  let base = 10
  let bump = (n: Int) => n + base
  Stdout.print(int_to_string(apply(inc, bump(1))))
}
