# KIR fixture: if → condbr + join, match → switch + per-arm blocks.
type Shape = Circle(Int) | Square(Int)

fn area(s: Shape) : Int =
  match s {
    Circle(r) -> r * r * 3
    Square(w) -> w * w
  }

fn sign(n: Int) : Int = if n > 0 { 1 } else { 0 - 1 }

fn main() : Unit / Console = {
  let a = area(Circle(2))
  Stdout.print(int_to_string(a + sign(a)))
}
