fn add(a: box, b: box) : box {
  entry:
    t0: box = prim +(a, b)
    ret t0
}

fn triple(n: box) : box {
  entry:
    t0: box = add(n, n)
    t1: box = add(n, t0)
    ret t1
}

fn main() : box {
  entry:
    t0: box = triple(7)
    r: box = t0
    t1: box = int_to_string(r)
    t2: box = con Stdout.print #0 {t1}
    ret t2
}

