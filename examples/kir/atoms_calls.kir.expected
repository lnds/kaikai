fn add(a: i64, b: i64) : i64 {
  entry:
    .t0: i64 = prim i+(a, b)
    .t1: box = prim int.box(.t0)
    ret .t1
}

fn triple(n: i64) : i64 {
  entry:
    .t0: i64 = add(n, n)
    .t1: i64 = add(n, .t0)
    ret .t1
}

fn main() : box {
  entry:
    .t0: i64 = triple(7)
    r: box = .t0
    .t1: box = prim int.box(r)
    .t2: box = int_to_string(.t1)
    .t3: box = perform Stdout.print(.t2)
    ret .t3
}

