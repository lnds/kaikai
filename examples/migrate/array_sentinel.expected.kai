# array.from / array.copy dropped their `default` sentinel argument in
# Orongo (#1015). Removing it is NOT arity-preserving and could change
# behaviour when `default` is a meaningful expression, so migrate
# reports it as `manual:` rather than rewriting it. The source is left
# untouched; the expected output is byte-identical to the input.
fn build(d: Int) : Int {
  let a = array.from([1, 2], d)
  let b = array.copy([3], d)
  0
}
