# Civil date core surface (issue #767): validating constructor,
# calendar queries, day/month arithmetic, comparison. Expected values
# cross-checked against Python's datetime (proleptic Gregorian).

import date

fn verify(label: String, ok: Bool) : Unit / Stdout =
  if ok { Stdout.print(label ++ ": ok") } else { Stdout.print(label ++ ": FAIL") }

fn check_str(label: String, got: String, want: String) : Unit / Stdout =
  if got == want { Stdout.print(label ++ ": ok") }
  else { Stdout.print(label ++ ": MISMATCH got='" ++ got ++ "' want='" ++ want ++ "'") }

fn check_int(label: String, got: Int, want: Int) : Unit / Stdout =
  if got == want { Stdout.print(label ++ ": ok") }
  else { Stdout.print(label ++ ": MISMATCH got=" ++ int_to_string(got) ++ " want=" ++ int_to_string(want)) }

# Unwrap a date the fixture knows is valid. A `None` yields a sentinel
# whose printed form can never match a golden line, instead of a crash.
fn mk(y: Int, m: Int, d: Int) : Date = match date.make(y, m, d) {
  Some(x) -> x
  None    -> Date { year: 0 - 9999, month: 1, day: 1 }
}

# True when make(y, m, d) accepts the triple.
fn valid(y: Int, m: Int, d: Int) : Bool = match date.make(y, m, d) {
  Some(_) -> true
  None    -> false
}

fn main() = {
  # ---- make: validation -----------------------------------------
  verify("make 2026-06-07 valid",    valid(2026, 6, 7))
  verify("make 2024-02-29 valid",    valid(2024, 2, 29))
  verify("make 2026-02-29 rejected", not valid(2026, 2, 29))
  verify("make month 13 rejected",   not valid(2026, 13, 1))
  verify("make month 0 rejected",    not valid(2026, 0, 10))
  verify("make day 0 rejected",      not valid(2026, 1, 0))
  verify("make day 32 rejected",     not valid(2026, 1, 32))
  verify("make 2026-04-31 rejected", not valid(2026, 4, 31))

  # ---- leap rule: 1900 no / 2000 yes / 2024 yes -------------------
  verify("1900 not leap", not date.is_leap_year(1900))
  verify("2000 leap",     date.is_leap_year(2000))
  verify("2024 leap",     date.is_leap_year(2024))
  verify("2026 not leap", not date.is_leap_year(2026))
  verify("year 0 leap",   date.is_leap_year(0))

  # ---- days_in_month ----------------------------------------------
  check_int("feb 2026", date.days_in_month(2026, 2), 28)
  check_int("feb 2024", date.days_in_month(2024, 2), 29)
  check_int("feb 1900", date.days_in_month(1900, 2), 28)
  check_int("feb 2000", date.days_in_month(2000, 2), 29)
  check_int("jan",      date.days_in_month(2026, 1), 31)
  check_int("apr",      date.days_in_month(2026, 4), 30)

  # ---- day_of_week (ISO: 1 = Monday ... 7 = Sunday) ---------------
  check_int("dow 1970-01-01 (Thu)", date.day_of_week(mk(1970, 1, 1)),   4)
  check_int("dow 2000-01-01 (Sat)", date.day_of_week(mk(2000, 1, 1)),   6)
  check_int("dow 2026-06-07 (Sun)", date.day_of_week(mk(2026, 6, 7)),   7)
  check_int("dow 2024-02-29 (Thu)", date.day_of_week(mk(2024, 2, 29)),  4)
  check_int("dow 1969-12-31 (Wed)", date.day_of_week(mk(1969, 12, 31)), 3)
  check_int("dow 1900-02-28 (Wed)", date.day_of_week(mk(1900, 2, 28)),  3)
  check_int("dow 0001-01-01 (Mon)", date.day_of_week(mk(1, 1, 1)),      1)

  # ---- day_of_year -------------------------------------------------
  check_int("doy 1970-01-01", date.day_of_year(mk(1970, 1, 1)),   1)
  check_int("doy 2024-03-01", date.day_of_year(mk(2024, 3, 1)),   61)
  check_int("doy 2026-03-01", date.day_of_year(mk(2026, 3, 1)),   60)
  check_int("doy 2024-12-31", date.day_of_year(mk(2024, 12, 31)), 366)
  check_int("doy 2026-12-31", date.day_of_year(mk(2026, 12, 31)), 365)

  # ---- add_days ----------------------------------------------------
  check_str("2024-02-28 +1d", date.to_string(date.add_days(mk(2024, 2, 28), 1)),     "2024-02-29")
  check_str("2024-02-29 +1d", date.to_string(date.add_days(mk(2024, 2, 29), 1)),     "2024-03-01")
  check_str("2026-02-28 +1d", date.to_string(date.add_days(mk(2026, 2, 28), 1)),     "2026-03-01")
  check_str("1970-01-01 -1d", date.to_string(date.add_days(mk(1970, 1, 1), 0 - 1)),  "1969-12-31")
  check_str("2025-12-31 +1d", date.to_string(date.add_days(mk(2025, 12, 31), 1)),    "2026-01-01")
  check_str("2026-06-07 +365d", date.to_string(date.add_days(mk(2026, 6, 7), 365)),  "2027-06-07")

  # ---- diff_days ----------------------------------------------------
  check_int("2026-01-01 - 2025-01-01", date.diff_days(mk(2026, 1, 1), mk(2025, 1, 1)), 365)
  check_int("2025-01-01 - 2024-01-01", date.diff_days(mk(2025, 1, 1), mk(2024, 1, 1)), 366)
  check_int("self diff",               date.diff_days(mk(2026, 6, 7), mk(2026, 6, 7)), 0)
  check_int("2024-01-01 - 2024-12-31", date.diff_days(mk(2024, 1, 1), mk(2024, 12, 31)), 0 - 365)

  # ---- add_months: end-of-month clamping ---------------------------
  check_str("2026-01-31 +1m clamps", date.to_string(date.add_months(mk(2026, 1, 31), 1)),     "2026-02-28")
  check_str("2024-01-31 +1m clamps", date.to_string(date.add_months(mk(2024, 1, 31), 1)),     "2024-02-29")
  check_str("2026-08-31 +1m clamps", date.to_string(date.add_months(mk(2026, 8, 31), 1)),     "2026-09-30")
  check_str("2026-03-31 -1m clamps", date.to_string(date.add_months(mk(2026, 3, 31), 0 - 1)), "2026-02-28")
  check_str("2026-01-31 -2m",        date.to_string(date.add_months(mk(2026, 1, 31), 0 - 2)), "2025-11-30")
  check_str("2026-11-30 +3m clamps", date.to_string(date.add_months(mk(2026, 11, 30), 3)),    "2027-02-28")
  check_str("2026-01-15 +12m",       date.to_string(date.add_months(mk(2026, 1, 15), 12)),    "2027-01-15")
  check_str("add_months 0 identity", date.to_string(date.add_months(mk(2026, 1, 31), 0)),     "2026-01-31")

  # ---- comparison ----------------------------------------------------
  verify("eq same",          date.eq(mk(2026, 6, 7), mk(2026, 6, 7)))
  verify("eq differs by day", not date.eq(mk(2026, 6, 7), mk(2026, 6, 8)))
  check_int("cmp year leg",  date.cmp(mk(2025, 12, 31), mk(2026, 1, 1)), 0 - 1)
  check_int("cmp month leg", date.cmp(mk(2026, 7, 1), mk(2026, 6, 30)),  1)
  check_int("cmp day leg",   date.cmp(mk(2026, 6, 7), mk(2026, 6, 8)),   0 - 1)
  check_int("cmp equal",     date.cmp(mk(2026, 6, 7), mk(2026, 6, 7)),   0)
  verify("lt across year",   date.lt(mk(1969, 12, 31), mk(1970, 1, 1)))
  verify("not lt equal",     not date.lt(mk(2026, 6, 7), mk(2026, 6, 7)))
  0
}
