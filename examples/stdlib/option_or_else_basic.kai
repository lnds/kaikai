# issue #182 — smoke test for opt_or_else.

fn show(o: Option[Int]) : String {
  match o {
    Some(v) -> "some=#{int_to_string(v)}"
    None    -> "none"
  }
}

fn main() {
  let s : Option[Int] = Some(7)
  let n : Option[Int] = None
  println(show(opt_or_else(s, () => Some(0))))     # f not called
  println(show(opt_or_else(n, () => Some(99))))    # f supplies fallback
  println(show(opt_or_else(n, () => None)))        # chained None
}
