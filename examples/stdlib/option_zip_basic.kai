# issue #182 — smoke test for option.zip.

fn pretty(o: Option[Pair[Int, String]]) : String {
  match o {
    Some(p) -> "some(#{int_to_string(p.fst)},#{p.snd})"
    None    -> "none"
  }
}

fn main() {
  let a : Option[Int] = Some(1)
  let b : Option[String] = Some("x")
  let na : Option[Int] = None
  let nb : Option[String] = None
  println(pretty(option.zip(a, b)))    # both Some
  println(pretty(option.zip(na, b)))   # first None
  println(pretty(option.zip(a, nb)))   # second None
  println(pretty(option.zip(na, nb)))  # both None
}
