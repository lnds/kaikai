# Lane 4 (#473) — negative fixture.
#
# `Byte` and `Int` are nominally distinct. Passing an `Int` where a `Byte`
# is expected (or vice-versa) is a type error caught at compile time.
# This is the property that makes `Byte = Byte` honest rather than a
# label on `Int`.

fn double_byte(b: Byte) : Byte = byte_add(b, b)

fn main() : Unit / Stdout = {
  # Passing a literal Int — should be rejected by the typer.
  Stdout.print(byte_to_string(double_byte(5)))
}
