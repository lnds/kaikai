# issue #182 — smoke test for opt_or.

fn pretty(o: Option[Int]) : String {
  match o {
    Some(v) -> "some=#{int_to_string(v)}"
    None    -> "none"
  }
}

fn main() {
  let s1 : Option[Int] = Some(1)
  let s2 : Option[Int] = Some(2)
  let n  : Option[Int] = None
  println(pretty(opt_or(s1, s2)))   # first Some wins
  println(pretty(opt_or(n,  s2)))   # falls back
  println(pretty(opt_or(n,  n)))    # both None
}
