# Regression fixture for the native-backend string-literal escape decode
# (native-parity char/hex family).
#
# The native (in-process libLLVM) backend decodes string-literal escapes
# itself in `kai_llvm_build_string_span` (the C-direct oracle instead
# emits the span verbatim into `kai_str("...")` and lets the C compiler
# decode it). That hand-rolled decoder originally handled only
# `\n \t \r \0 \" \\`, so the C99 escapes `\a \b \f \v`, hex `\xHH`, and
# octal `\ooo` fell through to a default that dropped the backslash and
# kept the letter — `"\x41"` became the three bytes `x41` instead of the
# single byte `A`, and `"\a"` became `a` instead of 0x07. That corrupted
# every literal carrying such an escape: the JSON byte-table
# (`"\x01..\xff"`), surrogate decode, regex char classes, etc.
#
# This exercises the byte-exact decode on every escape the C compiler
# recognises, so a future native-decoder regression is caught against
# the C-direct oracle (the parity harness diffs both backends).

fn code_at(s: String, i: Int) : Int =
  match char_at(s, i) {
    None    -> 0 - 1
    Some(c) -> char_to_int(c)
  }

fn main() : Int / Console = {
  # Simple C escapes — each one byte, exact code point.
  print(int_to_string(code_at("\a", 0)))   # 7   bell
  print(int_to_string(code_at("\b", 0)))   # 8   backspace
  print(int_to_string(code_at("\t", 0)))   # 9   tab
  print(int_to_string(code_at("\n", 0)))   # 10  newline
  print(int_to_string(code_at("\v", 0)))   # 11  vertical tab
  print(int_to_string(code_at("\f", 0)))   # 12  form feed
  print(int_to_string(code_at("\r", 0)))   # 13  carriage return

  # Hex escapes — `\xHH` decodes to the byte, not the literal digits.
  print(int_to_string(code_at("\x41", 0)))   # 65  'A'
  print(int_to_string(code_at("\x7e", 0)))   # 126 '~'
  print(int_to_string(code_at("\xff", 0)))   # 255 0xFF

  # Octal escapes — `\ooo`, 1..3 octal digits.
  print(int_to_string(code_at("\101", 0)))   # 65  'A'
  print(int_to_string(code_at("\176", 0)))   # 126 '~'

  # Lengths: a hex/octal escape is ONE byte; `\x41\x42` is "AB" (len 2).
  print(int_to_string(string_length("\x41\x42")))   # 2
  print(int_to_string(string_length("\a\b\f\v")))   # 4

  # The byte-table slice path the JSON `\u` decoder depends on: a table
  # of bytes 0x01..0x05, slice index 4 must be the fifth byte (0x05).
  print(int_to_string(code_at(string_slice("\x01\x02\x03\x04\x05", 4, 1), 0)))  # 5
  0
}
