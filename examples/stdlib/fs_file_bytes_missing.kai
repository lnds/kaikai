# `file_read_bytes` returns `Err` on a missing file. The error
# message is intentionally generic — callers should diagnose by
# checking `file_exists` first if they need finer-grained reporting.

fn main() : Int {
  match file_read_bytes("/tmp/kai_definitely_not_present_byte_file_xyz.bin") {
    Ok(_)  -> { print("unexpected ok"); 1 }
    Err(_) -> { print("err"); 0 }
  }
}
