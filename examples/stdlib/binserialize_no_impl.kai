# Issue #459: `#derive(BinSerialize)` requires every field's type
# to have a BinSerialize impl. Here the record holds a `Color`,
# which has no impl declared — the validator emits a typed
# diagnostic naming the offending field instead of waiting for
# the post-mono `__protocol_dispatch_*` runtime panic.

type Color = { r: Int, g: Int, b: Int }

#[derive(BinSerialize)]
type Pixel = { id: Int, color: Color }

fn main() : Int { 0 }
