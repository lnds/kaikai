# stdlib/fs/file.kai — end-to-end smoke for the v1 file-level
# wrappers. Spec: docs/stdlib-roadmap.md Tier S1 #1; surface in
# stdlib/fs/file.kai's header. v1 ships only `read_file` /
# `write_file` / `append`; the full `write → read → exists →
# metadata → delete` cycle the roadmap names lands once the
# follow-up runtime issue (label `stdlib`+`runtime`) wires
# kai_prelude_file_{exists,delete,rename,metadata} into the
# prelude.
#
# This fixture covers what v1 can guarantee:
#
#   1. write_file overwrites a path with deterministic content
#   2. read_file round-trips that content byte-for-byte
#   3. append concatenates new content onto the existing file
#   4. read_file round-trips the post-append concatenation
#   5. write_file on a path that already has content overwrites
#      cleanly — proves run-to-run determinism without delete()
#
# The fixture path is fixed (`/tmp/kaikai-fs-basic.txt`) rather
# than per-pid so the same fixture file can be reused across runs
# without the post-condition cleanup `delete()` would normally
# perform — every run begins by overwriting the path with a known
# byte sequence. Once kai_prelude_file_delete lands the fixture
# grows a final cleanup step.

import fs.file

fn main() : Unit / Stdout + File = {
  let path = "/tmp/kaikai-fs-basic.txt"

  # Step 1 — clean overwrite. Step 5 (idempotent re-overwrite at
  # the end) is the same op; we use the entry-side write to also
  # establish a deterministic baseline for runs where a prior
  # fixture left stale content at the path.
  file.write(path, "hello, kaikai\n")
  let after_write = file.read(path)
  if after_write == "hello, kaikai\n" {
    Stdout.print("write+read ok")
  } else {
    Stdout.print(string_concat("write+read MISMATCH: ", after_write))
  }

  # Step 2 — append. Polyfill: read existing, concat, write back.
  # Final content should be the original plus the appended suffix.
  file.append(path, "second line\n")
  let after_append = file.read(path)
  if after_append == "hello, kaikai\nsecond line\n" {
    Stdout.print("append+read ok")
  } else {
    Stdout.print(string_concat("append+read MISMATCH: ", after_append))
  }

  # Step 3 — append onto an empty/missing baseline. Overwrite to
  # a known-empty file (write_file with the empty string), then
  # append: the polyfill's "create-if-missing" branch is exercised
  # by reading "" successfully and concatenating "first" onto it.
  file.write(path, "")
  file.append(path, "first")
  let after_first_append = file.read(path)
  if after_first_append == "first" {
    Stdout.print("append-onto-empty ok")
  } else {
    Stdout.print(string_concat("append-onto-empty MISMATCH: ", after_first_append))
  }

  # Step 4 — overwrite-after-append re-establishes the clean state
  # the next run begins with. Confirms write_file truncates rather
  # than appending.
  file.write(path, "final\n")
  let after_overwrite = file.read(path)
  if after_overwrite == "final\n" {
    Stdout.print("overwrite-after-append ok")
  } else {
    Stdout.print(string_concat("overwrite-after-append MISMATCH: ", after_overwrite))
  }

  Stdout.print("done")
}
