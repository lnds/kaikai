# Issue #106 — pipeline acceptance fixture.
#
# Exercises `range |> list.map |> list.filter |> list.foldl` with
# an effectful callback (`println`) inside `list.map`. Verifies the
# four canonical higher-order helpers compose under `|>` with row-
# poly callbacks: the effects raised inside the map's lambda flow
# out through `list.map`'s row variable and up to `main` without
# ceremony.
#
# Wired into `make tier1` via stage2's `test-stdlib` glob over
# `examples/stdlib/*.kai`.

# Local helper since stdlib has no `range` yet (ahu Layer 1 owns
# it; this fixture stays self-contained). Builds `[1, 2, ..., n]`
# tail-recursively.
fn range_loop(i: Int, n: Int, acc: [Int]) : [Int] {
  if i > n { list_reverse(acc) }
  else { range_loop(i + 1, n, [i, ...acc]) }
}

fn range_to(n: Int) : [Int] = range_loop(1, n, [])

# Effectful map callback: prints each input and returns its square.
# Demonstrates effects flowing through `list.map`'s row variable.
fn trace_square(n: Int) : Int = {
  println(string_concat("seen=", int_to_string(n)))
  n * n
}

fn is_even(n: Int) : Bool = n % 2 == 0

fn main() {
  # range_to(5)             -> [1, 2, 3, 4, 5]
  # list.map trace_square   prints seen=1..5, yields [1, 4, 9, 16, 25]
  # list.filter is_even     -> [4, 16]
  # list.foldl + 0          -> 20
  # Single-line: kaikai's `|>` does not continue across newlines.
  let total = range_to(5) |> list.map(_, trace_square) |> list.filter(_, is_even) |> list.foldl(_, 0, (acc, n) => acc + n)
  println(string_concat("total=", int_to_string(total)))

  # list.foreach with the same effectful shape — prints each element
  # for side effect, returns Unit.
  list.foreach([100, 200, 300], (n) => println(int_to_string(n)))
}
