# Map basic operations + ordering invariants.
#
# Exercises the qualified-call canonical surface
# (`map.put`, `map.get`, …) introduced by issue #613. The
# legacy flat-prefix aliases (`map_put`, `map_get`, …) remain
# available under the tongariki edition; see `map_aliases.kai`
# for a smoke test that exercises every alias end-to-end.

fn show_int_pair(p: Pair[String, Int]) : String =
  p.fst ++ "=" ++ int_to_string(p.snd)

fn show_pairs(ps: [Pair[String, Int]]) : String = match ps {
  []           -> ""
  [p]          -> show_int_pair(p)
  [p, ...rest] -> show_int_pair(p) ++ "," ++ show_pairs(rest)
}

fn verify(label: String, ok: Bool) : Unit / Stdout =
  if ok { Stdout.print(label ++ ": ok") } else { Stdout.print(label ++ ": FAIL") }

fn main() = {
  let m0 = map.empty()
  verify("empty size 0", map.size(m0) == 0)
  verify("empty is_empty", map.is_empty(m0))
  verify("empty contains 'x' false", not map.contains(m0, "x"))

  let m1 = map.put(m0, "a", 1)
  let m2 = map.put(m1, "b", 2)
  let m3 = map.put(m2, "c", 3)

  verify("size 3", map.size(m3) == 3)
  verify("not is_empty", not map.is_empty(m3))
  verify("contains 'a'", map.contains(m3, "a"))
  verify("contains 'b'", map.contains(m3, "b"))
  verify("contains 'c'", map.contains(m3, "c"))
  verify("not contains 'd'", not map.contains(m3, "d"))

  match map.get(m3, "b") {
    Some(v) -> verify("get 'b' == 2", v == 2)
    None    -> Stdout.print("get 'b': FAIL (returned None)")
  }
  match map.get(m3, "missing") {
    None    -> Stdout.print("get missing: ok")
    Some(_) -> Stdout.print("get missing: FAIL")
  }

  Stdout.print("keys after 3 inserts: " ++ string.join(map.keys(m3), ","))

  let m4 = map.put(m3, "b", 20)
  verify("size still 3 after update", map.size(m4) == 3)
  match map.get(m4, "b") {
    Some(v) -> verify("get 'b' == 20 after update", v == 20)
    None    -> Stdout.print("get 'b' after update: FAIL")
  }
  Stdout.print("keys after update: " ++ string.join(map.keys(m4), ","))

  let m5 = map.remove(m4, "b")
  verify("size 2 after remove", map.size(m5) == 2)
  verify("not contains 'b' after remove", not map.contains(m5, "b"))
  verify("still contains 'a'", map.contains(m5, "a"))
  verify("still contains 'c'", map.contains(m5, "c"))
  Stdout.print("keys after remove 'b': " ++ string.join(map.keys(m5), ","))

  let m6 = map.remove(m5, "ghost")
  verify("size unchanged after remove missing", map.size(m6) == map.size(m5))

  let from = map.from_pairs([
    Pair { fst: "x", snd: 1 },
    Pair { fst: "y", snd: 2 },
    Pair { fst: "x", snd: 99 }
  ])
  verify("from_pairs size 2", map.size(from) == 2)
  match map.get(from, "x") {
    Some(v) -> verify("from_pairs duplicate 'x' = 99", v == 99)
    None    -> Stdout.print("from_pairs 'x': FAIL")
  }

  Stdout.print("entries: " ++ show_pairs(map.to_pairs(m4)))
  0
}
