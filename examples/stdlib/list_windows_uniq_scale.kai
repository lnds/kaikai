# Regression: list.windows and the two uniq paths on large input.
# windows must complete in O(n*(L-n+1)) (no per-step length re-walk),
# and hashset.uniq must agree element-for-element with the Eq-only
# list.uniq while running in O(n) amortized.

import collections.hashset

fn verify(label: String, ok: Bool) : Unit / Stdout =
  if ok { Stdout.print(label ++ ": ok") } else { Stdout.print(label ++ ": FAIL") }

# A large list with heavy duplication: each value in 0..999 repeated,
# so dedup collapses 5000 elements down to 1000 distinct ones, in
# first-occurrence order.
fn dup_heavy(i: Int, n: Int, acc: [Int]) : [Int] =
  if i >= n { list.reverse(acc) }
  else { dup_heavy(i + 1, n, [i % 1000, ...acc]) }

fn last_of(xs: [Int]) : Int = match xs {
  []        -> 0 - 1
  [x]       -> x
  [_, ...t] -> last_of(t)
}

fn first_eq(xs: [[Int]], want: [Int]) : Bool = match xs {
  []         -> false
  [w, ..._]  -> w == want
}

fn first_int(xs: [Int], want: Int) : Bool = match xs {
  []         -> false
  [h, ..._]  -> h == want
}

fn main() : Int / Stdout + Mutable = {
  # ---- windows over a large list: count + endpoints ----
  let big = [1..5000]
  verify("big length", big.length() == 5000)

  let w3 = list.windows(big, 3)
  # L - n + 1 = 5000 - 3 + 1 = 4998 full windows.
  verify("windows count", w3.length() == 4998)
  verify("first window", first_eq(w3, [1, 2, 3]))
  verify("last window", first_eq(list.reverse(w3), [4998, 4999, 5000]))

  # window larger than the list yields nothing; n <= 0 yields nothing.
  verify("windows too wide", list.windows([1, 2], 5).length() == 0)
  verify("windows n<=0", list.windows(big, 0).length() == 0)

  # ---- uniq: Eq path vs Hash path agree ----
  let xs = dup_heavy(0, 5000, [])
  verify("dup input length", xs.length() == 5000)

  let u_eq = list.uniq(xs)
  let u_hash = hashset.uniq(xs)
  verify("eq uniq dedups to 1000", u_eq.length() == 1000)
  verify("hash uniq dedups to 1000", u_hash.length() == 1000)
  verify("eq and hash agree", u_eq == u_hash)
  verify("first-occurrence order kept", first_int(u_hash, 0))
  verify("uniq last is 999", last_of(u_hash) == 999)

  # already-unique input is returned unchanged by both.
  let uniq_in = [1..500]
  verify("eq uniq idempotent", list.uniq(uniq_in) == uniq_in)
  verify("hash uniq idempotent", hashset.uniq(uniq_in) == uniq_in)

  0
}
