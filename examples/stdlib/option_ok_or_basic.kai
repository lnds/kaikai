# issue #182 — smoke test for opt_ok_or (Option -> Result with eager error).

fn show(r: Result[String, Int]) : String {
  match r {
    Ok(v)  -> "ok=#{int_to_string(v)}"
    Err(e) -> "err=#{e}"
  }
}

fn main() {
  let s : Option[Int] = Some(7)
  let n : Option[Int] = None
  println(show(opt_ok_or(s, "missing")))
  println(show(opt_ok_or(n, "missing")))
}
