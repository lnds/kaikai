# issue #182 — smoke test for option.ok_or (Option -> Result with eager error).

fn pretty(r: Result[Int, String]) : String {
  match r {
    Ok(v)  -> "ok=#{int_to_string(v)}"
    Err(e) -> "err=#{e}"
  }
}

fn main() {
  let s : Option[Int] = Some(7)
  let n : Option[Int] = None
  println(pretty(option.ok_or(s, "missing")))
  println(pretty(option.ok_or(n, "missing")))
}
