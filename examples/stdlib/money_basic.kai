# Money over the Currency kind: same-currency arithmetic, the scalar
# module action, and full-cancellation ratios, all on the exact
# Decimal carrier.
import money
import decimal as dec
import decimal_proto

pub fn main() : Unit / Console = {
  let a: Money[USD] = 10.50<USD>
  let b: Money[USD] = 4.50<USD>
  let total = a + b
  let k: dec.Decimal = 3
  let tripled = total * k
  let ratio: dec.Decimal = tripled / total
  print("#{money.to_string(total)} #{money.to_string(tripled)} #{dec.to_string(ratio)}")
}
