# Money basic operations + currency-mismatch failure modes.

fn verify(label: String, ok: Bool) : Unit / Stdout =
  if ok { Stdout.print(label ++ ": ok") } else { Stdout.print(label ++ ": FAIL") }

fn check_eq_str(label: String, got: String, want: String) : Unit / Stdout =
  if got == want { Stdout.print(label ++ ": ok") }
  else { Stdout.print(label ++ ": MISMATCH got='" ++ got ++ "' want='" ++ want ++ "'") }

fn main() = {
  # ---- construction + display -----------------------------------
  let zero_usd = money_zero("USD")
  check_eq_str("zero USD",       money_to_string(zero_usd),                  "USD 0")
  check_eq_str("from_int 100",   money_to_string(money_from_int(100, "USD")),"USD 100")
  check_eq_str("from_parts",     money_to_string(money_from_parts(12, 50, 2, "USD")), "USD 12.50")
  check_eq_str("yen 1000",       money_to_string(money_from_int(1000, "JPY")),"JPY 1000")
  check_eq_str("clp 99999",      money_to_string(money_from_int(99999, "CLP")),"CLP 99999")

  # ---- parse round-trip -----------------------------------------
  match money_parse("USD 12.50") {
    Some(m) -> check_eq_str("parse USD 12.50",   money_to_string(m), "USD 12.50")
    None    -> Stdout.print("parse USD 12.50: FAIL (None)")
  }
  match money_parse("EUR 0.99") {
    Some(m) -> check_eq_str("parse EUR 0.99",    money_to_string(m), "EUR 0.99")
    None    -> Stdout.print("parse EUR 0.99: FAIL (None)")
  }
  match money_parse("BTC 0.001") {
    Some(m) -> check_eq_str("parse BTC 0.001",   money_to_string(m), "BTC 0.001")
    None    -> Stdout.print("parse BTC 0.001: FAIL (None)")
  }
  match money_parse("USD -7.50") {
    Some(m) -> check_eq_str("parse USD -7.50",   money_to_string(m), "USD -7.50")
    None    -> Stdout.print("parse USD -7.50: FAIL (None)")
  }

  match money_parse("nope")          { None -> Stdout.print("parse 'nope': ok (None)")        Some(_) -> Stdout.print("parse 'nope': FAIL") }
  match money_parse("USD")           { None -> Stdout.print("parse 'USD': ok (None)")         Some(_) -> Stdout.print("parse 'USD': FAIL") }
  match money_parse("USD ")          { None -> Stdout.print("parse 'USD ': ok (None)")        Some(_) -> Stdout.print("parse 'USD ': FAIL") }
  match money_parse("12.50 USD")     { None -> Stdout.print("parse '12.50 USD': ok (None)")   Some(_) -> Stdout.print("parse '12.50 USD': FAIL (digits-first not supported)") }
  match money_parse("US1 12.50")     { None -> Stdout.print("parse 'US1 12.50': ok (None)")   Some(_) -> Stdout.print("parse 'US1 12.50': FAIL") }

  # ---- same-currency arithmetic ---------------------------------
  let a = money_from_parts(100, 0, 2, "USD")
  let b = money_from_parts(12, 50, 2, "USD")

  match money_add(a, b) {
    Some(m) -> check_eq_str("USD 100 + USD 12.50",  money_to_string(m), "USD 112.50")
    None    -> Stdout.print("add same currency: FAIL")
  }
  match money_sub(a, b) {
    Some(m) -> check_eq_str("USD 100 - USD 12.50",  money_to_string(m), "USD 87.50")
    None    -> Stdout.print("sub same currency: FAIL")
  }

  # ---- cross-currency rejection --------------------------------
  let euros = money_from_parts(20, 0, 2, "EUR")
  match money_add(a, euros) {
    None    -> Stdout.print("USD + EUR add: ok (None)")
    Some(_) -> Stdout.print("USD + EUR add: FAIL (returned Some)")
  }
  match money_sub(a, euros) {
    None    -> Stdout.print("USD - EUR sub: ok (None)")
    Some(_) -> Stdout.print("USD - EUR sub: FAIL")
  }
  match money_cmp(a, euros) {
    None    -> Stdout.print("USD vs EUR cmp: ok (None)")
    Some(_) -> Stdout.print("USD vs EUR cmp: FAIL")
  }
  match money_ratio(a, euros, 2) {
    None    -> Stdout.print("USD / EUR ratio: ok (None)")
    Some(_) -> Stdout.print("USD / EUR ratio: FAIL")
  }
  verify("USD eq EUR is false",        not money_eq(a, euros))
  verify("zero USD eq zero EUR false", not money_eq(zero_usd, money_zero("EUR")))

  # ---- scale and ratio (same currency) -------------------------
  # 5% interest on USD 100.00
  let five_pct = dec_from_parts(0, 5, 2)
  let interest = money_scale(a, five_pct)
  # money_scale yields scale 4 (2 + 2). Round to cents.
  let interest_2dp = money_make(dec_round(money_amount(interest), 2),
                                 money_currency(interest))
  check_eq_str("5% of USD 100.00 (2dp)", money_to_string(interest_2dp), "USD 5.00")

  # USD 100 / 3 with 4dp precision. Some(Money) on success.
  let three = dec_from_int(3)
  match money_divide_scalar(a, three, 4) {
    Some(split) -> check_eq_str("USD 100 / 3 (4dp)", money_to_string(split), "USD 33.3333")
    None        -> Stdout.print("USD 100 / 3 (4dp): FAIL (None)")
  }

  # Ratio: USD 50 to USD 100 = 0.50
  let half = money_from_parts(50, 0, 2, "USD")
  match money_ratio(half, a, 2) {
    Some(r) -> check_eq_str("ratio 50/100",            dec_to_string(r), "0.50")
    None    -> Stdout.print("ratio same currency: FAIL")
  }

  # ---- sign / abs / neg ----------------------------------------
  let debt = money_from_parts(0 - 50, 0, 2, "USD")
  verify("debt is_negative",        money_is_negative(debt))
  check_eq_str("abs(debt)",        money_to_string(money_abs(debt)),  "USD 50.00")
  check_eq_str("neg(USD 12.50)",   money_to_string(money_neg(b)),     "USD -12.50")
  verify("zero is_zero",            money_is_zero(zero_usd))
  verify("100 not is_zero",         not money_is_zero(a))

  # ---- mini-ledger flow ----------------------------------------
  # Three deposits of USD 12.50 on top of USD 100.00 starting
  # balance, then 5% interest rounded to cents.
  let bal_0 = money_from_parts(100, 0, 2, "USD")
  let dep   = money_from_parts(12, 50, 2, "USD")
  match money_add(bal_0, dep) {
    None       -> Stdout.print("dep1: FAIL")
    Some(b1)   -> match money_add(b1, dep) {
      None     -> Stdout.print("dep2: FAIL")
      Some(b2) -> match money_add(b2, dep) {
        None     -> Stdout.print("dep3: FAIL")
        Some(b3) -> {
          check_eq_str("balance after 3 deposits", money_to_string(b3), "USD 137.50")
          let r = dec_from_parts(0, 5, 2)
          let raw_interest = money_scale(b3, r)
          let it_2dp = money_make(dec_round(money_amount(raw_interest), 2),
                                   money_currency(raw_interest))
          check_eq_str("5% interest (2dp)", money_to_string(it_2dp), "USD 6.88")
          match money_add(b3, it_2dp) {
            Some(final_bal) ->
              check_eq_str("final balance", money_to_string(final_bal), "USD 144.38")
            None -> Stdout.print("final: FAIL")
          }
        }
      }
    }
  }
  0
}
