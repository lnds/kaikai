# issue #182 — smoke test for result_map_err.

fn show(r: Result[Int, Int]) : String {
  match r {
    Ok(v)  -> "ok=#{int_to_string(v)}"
    Err(e) -> "err=#{int_to_string(e)}"
  }
}

fn main() {
  let ok  : Result[String, Int] = Ok(7)
  let err : Result[String, Int] = Err("boom")
  println(show(result_map_err(ok,  (e) => string_length(e))))
  println(show(result_map_err(err, (e) => string_length(e))))
}
