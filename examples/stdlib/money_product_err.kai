# Two distinct currencies have no product: `USD*CLP` is structurally
# inexpressible in the Module theory, with or without the removed
# name-list guard.
import money
import decimal as dec
import decimal_proto

fn main() {
  let a: Money[dec.Decimal]<USD> = 10.50<USD>
  let b: Money[dec.Decimal]<CLP> = 2.00<CLP>
  let c = a * b
  print("no")
}
