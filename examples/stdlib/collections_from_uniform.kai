# Uniform `X.from` construction across the four collections that L1
# unifies: `map.from` / `set.from` build immutable persistent values
# (pure), `hashmap.from` / `hashset.from` build mutable tables (`/
# Mutable`). One verb, one per module — no `from_pairs` / `from_list`
# split. Duplicate handling: last key wins for maps, dedup for sets.

import collections.map
import collections.set
import collections.hashmap
import collections.hashset

fn verify(label: String, ok: Bool) : Unit / Stdout =
  if ok { Stdout.print(label ++ ": ok") } else { Stdout.print(label ++ ": FAIL") }

fn main() : Unit / Stdout + Mutable = {
  # map.from — last duplicate key wins
  let m = map.from([
    Pair { fst: "a", snd: 1 },
    Pair { fst: "b", snd: 2 },
    Pair { fst: "a", snd: 9 }
  ])
  verify("map.from size 2", map.size(m) == 2)
  verify("map.from last wins", map.get(m, "a") == Some(9))

  # set.from — duplicates collapse
  let s = set.from([3, 1, 2, 3, 1])
  verify("set.from size 3", set.size(s) == 3)
  verify("set.from order", set.to_list(s) == [3, 1, 2])

  # hashmap.from — mutable, last duplicate key wins
  let hm = hashmap.from([
    Pair { fst: "x", snd: 1 },
    Pair { fst: "x", snd: 7 }
  ])
  verify("hashmap.from size 1", hashmap.size(hm) == 1)
  verify("hashmap.from last wins", hashmap.get(hm, "x") == Some(7))

  # hashset.from — mutable, duplicates collapse
  let hs = hashset.from([5, 6, 5, 6, 7])
  verify("hashset.from size 3", hashset.size(hs) == 3)
  verify("hashset.from has 7", hashset.contains(hs, 7))
}
