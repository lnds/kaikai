# Regression fixture for issue #614 batch B1 (file).
#
# Exercises both the canonical qualified form (`file.read`) and the
# legacy flat alias (`file_read_file`) for stdlib/fs/file.kai. Both
# must return the same value when reading a file that exists.

import fs.file

fn main() : Unit / Console + File = {
  let path = "/tmp/kaikai-issue614-b1.txt"
  let _ = file.write(path, "hello")
  let via_qualified = file.read(path)
  let via_alias     = file_read_file(path)
  print(via_qualified)
  print(via_alias)
  if via_qualified == via_alias { print("match") } else { print("MISMATCH") }
}
