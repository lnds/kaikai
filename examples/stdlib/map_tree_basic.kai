# issue #128 — exercises the AVL-backed Map[K, V] and the
# read-side indexing sugar `m[k] : Option[V]`.
#
# Three angles:
#   1. Round-trip through `map_put / map_get` at N=1000 keyed by
#      `int_to_string(i)`. If the carrier degraded to O(n) lookup
#      this fixture would still pass, but the runtime would stretch
#      from milliseconds into seconds — the smoke test here is
#      correctness, not throughput.
#   2. The indexing sugar `m["alice"]` lowers to `map_get(m, "alice")`
#      via the typer rule (synth_index dispatches on the inferred
#      container type). The result type is `Option[V]`, matched
#      directly so we never silently fall back to Array semantics.
#   3. Iteration order is by key, not by insertion order. The
#      v0 carrier returned insert order from `map_keys`; the AVL
#      carrier returns the in-order traversal. The fixture inserts
#      "c", "a", "b" deliberately and asserts the key listing
#      arrives sorted.

fn opt_int_str(o: Option[Int]) : String = match o {
  None    -> "none"
  Some(n) -> int_to_string(n)
}

fn fill_loop(m: Map[String, Int], i: Int, n: Int) : Map[String, Int] =
  if i >= n { m }
  else      { fill_loop(map_put(m, int_to_string(i), i * 2), i + 1, n) }

fn main() {
  # 1. Indexing sugar over a small map keyed by the registered names
  # ahu's Registry will use in production. Note the literal `[k]` —
  # this fixture is the regression test for the typer's EIndex
  # dispatch rule.
  let registry = map_put(
    map_put(
      map_put(map_empty(), "alice", 10),
      "bob", 7),
    "charlie", 42)
  println("alice  -> " ++ opt_int_str(registry["alice"]))
  println("bob    -> " ++ opt_int_str(registry["bob"]))
  println("ghost  -> " ++ opt_int_str(registry["ghost"]))

  # 2. Iteration order is by key. Inserting "c", "a", "b" must
  # produce keys "a,b,c". A reversion to the association-list
  # carrier would print "c,a,b" and break this assertion loudly.
  let ordered = map_put(
    map_put(
      map_put(map_empty(), "c", 3),
      "a", 1),
    "b", 2)
  println("keys (insert c,a,b): " ++ string.join(map_keys(ordered), ","))

  # 3. N=1000 round-trip. We probe four positions evenly across the
  # range so a missing balance step surfaces as a wrong value or a
  # `none` rather than a silent slowdown. The picked indices double
  # as a sanity check that values survived intact.
  let big = fill_loop(map_empty(), 0, 1000)
  println("size 1000: " ++ int_to_string(map_size(big)))
  println("k=0    -> " ++ opt_int_str(big["0"]))
  println("k=250  -> " ++ opt_int_str(big["250"]))
  println("k=500  -> " ++ opt_int_str(big["500"]))
  println("k=999  -> " ++ opt_int_str(big["999"]))
  println("k=1000 -> " ++ opt_int_str(big["1000"]))

  # 4. Read indexing inside a let — confirms the dispatch fires in
  # binding RHS position, not just at the tail expression.
  let n = registry["alice"]
  match n {
    Some(v) -> println("let n = registry[\"alice\"] -> " ++ int_to_string(v))
    None    -> println("let n: FAIL")
  }

  0
}
