# A String-carrier Money constructs but cannot add or scale: the
# carrier check fires at the concrete instance, where the operator
# needs a numeric carrier.
import money

fn main() {
  let a: Money[String]<USD> = money.of("ten")
  let b: Money[String]<USD> = money.of("two")
  let c = a + b
  let d = a * "3"
  print("no")
}
