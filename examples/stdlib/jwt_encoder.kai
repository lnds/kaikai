# JWT encoder/decoder showcase — exercises stdlib/encoding/base64,
# stdlib/encoding/hex, stdlib/encoding/json, and stdlib/collections/map
# together.
#
# Implements `alg: none` JWTs (RFC 7519 §6.1) — three dot-separated
# parts where the third (signature) is empty:
#
#   base64url(header).base64url(payload).
#
# A real production JWT signs the first two parts with HMAC-SHA256
# (HS256) or RSA (RS256) and writes the base64url-encoded signature
# in the third slot. SHA-256 lives in the future `stdlib/crypto/`
# module (m14, blocked on bit ops m13); this demo uses `alg: none`
# which is RFC-valid for unprotected tokens.
#
# v2 (2026-04-27 night): the JSON for the header and the payload
# now goes through `json_encode` / `json_decode` from the real
# `stdlib/encoding/json` module instead of the hardcoded
# string-concat encoder the v1 carried.

# ---- byte/string helpers ----------------------------------------

fn string_to_bytes_loop(s: String, i: Int, acc: [Int]) : [Int] = {
  if i >= string_length(s) { list_reverse(acc) }
  else { match char_at(s, i) {
    None    -> list_reverse(acc)
    Some(c) -> string_to_bytes_loop(s, i + 1, [char_to_int(c), ...acc])
  } }
}

fn string_to_bytes(s: String) : [Int] = string_to_bytes_loop(s, 0, [])

# ASCII printable range (32–126) packed as a string. Each index `i`
# maps to the char with codepoint `32 + i`. Non-printable bytes
# render as `?` — fine for JSON-shaped JWT payloads (the spec
# limits payload bytes to UTF-8 anyway, and our demo values are
# pure ASCII).
fn ascii_printable() : String =
  " !\"#$%&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRSTUVWXYZ[\\]^_`abcdefghijklmnopqrstuvwxyz{|}~"

fn byte_to_str(b: Int) : String = {
  if b < 32 or b > 126 { "?" }
  else { string_slice(ascii_printable(), b - 32, 1) }
}

fn bytes_to_string(bs: [Int]) : String =
  string.join(map(bs, byte_to_str), "")

# ---- JWT encoding ------------------------------------------------

fn jwt_encode(header_json: String, payload_json: String) : String = {
  let h = base64_encode_url(string_to_bytes(header_json))
  let p = base64_encode_url(string_to_bytes(payload_json))
  # alg:none = empty signature segment, but the trailing dot stays
  h ++ "." ++ p ++ "."
}

# ---- JWT decoding ------------------------------------------------

type Decoded = { header: JsonValue, payload: JsonValue }

fn jwt_decode(token: String) : Option[Decoded] = {
  let parts = string_split(token, ".")
  match parts {
    [h_b64, p_b64, _] -> match base64_decode_url(h_b64) {
      None     -> None
      Some(hb) -> match base64_decode_url(p_b64) {
        None     -> None
        Some(pb) -> {
          let h_str = bytes_to_string(hb)
          let p_str = bytes_to_string(pb)
          match json_decode(h_str) {
            None    -> None
            Some(h) -> match json_decode(p_str) {
              None    -> None
              Some(p) -> Some(Decoded { header: h, payload: p })
            }
          }
        }
      }
    }
    _ -> None
  }
}

# ---- JsonValue helpers -------------------------------------------

# Look up a string-valued field of a JObj. Useful for reading
# specific claims (`sub`, `iss`, `kid`...) out of a decoded JWT
# without writing match arms by hand.
fn json_lookup_str(v: JsonValue, key: String) : Option[String] = match v {
  JObj(pairs) -> json_lookup_str_loop(pairs, key)
  _           -> None
}

fn json_lookup_str_loop(pairs: [Pair[String, JsonValue]], key: String) : Option[String] = match pairs {
  []           -> None
  [p, ...rest] -> if p.fst == key { match p.snd {
                                      JStr(s) -> Some(s)
                                      _       -> None
                                    } }
                  else { json_lookup_str_loop(rest, key) }
}

# Lift a `Pair[String, String]` claim into `Pair[String, JsonValue]`
# so the resulting list can be wrapped in a `JObj`. Top-level
# helper because nested `fn` is not valid in a let-block body.
fn jwt_lift_claim(p: Pair[String, String]) : Pair[String, JsonValue] =
  Pair { fst: p.fst, snd: JStr(p.snd) }

# ---- Demo --------------------------------------------------------

fn main() = {
  # Compute the key id as the hex of a fixed seed. In production
  # this would be the hex sha256 of the public key; here it is just
  # a placeholder to exercise `hex_from_int`. 48879 = 0xBEEF.
  let kid_hex = hex_from_int(48879)

  # Header: alg=none, typ=JWT, kid=<hex>. v2 builds it as a
  # JsonValue tree and serialises through `json_encode` — escaping,
  # quoting, and key ordering all handled by the encoder.
  let header_v = JObj([
    Pair { fst: "alg", snd: JStr("none") },
    Pair { fst: "typ", snd: JStr("JWT") },
    Pair { fst: "kid", snd: JStr(kid_hex) }
  ])
  let header = json_encode(header_v)

  # Payload: claims live in a Map first to demo `map_put` / `map_get`,
  # then convert to JsonValue pairs for serialisation. Iteration is
  # by key (issue #128 made the carrier an AVL tree); the demo
  # leans on that to keep the JSON output deterministic across
  # rebuilds without any explicit sort step.
  let claims_0 = map_empty()
  let claims_1 = map_put(claims_0, "sub",  "user_42")
  let claims_2 = map_put(claims_1, "iss",  "kaikai-demo")
  let claims_3 = map_put(claims_2, "iat",  "1700000000")
  let claims   = map_put(claims_3, "name", "Eric")

  let payload_pairs = map(map_to_pairs(claims), jwt_lift_claim)
  let payload_v = JObj(payload_pairs)
  let payload = json_encode(payload_v)

  Stdout.print("=== build ===")
  Stdout.print("header  : " ++ header)
  Stdout.print("payload : " ++ payload)
  Stdout.print("claims size: " ++ int_to_string(map_size(claims)))
  match map_get(claims, "sub") {
    Some(v) -> Stdout.print("claim sub: " ++ v)
    None    -> Stdout.print("claim sub: <missing>")
  }
  match map_get(claims, "missing") {
    Some(_) -> Stdout.print("claim missing: <found unexpectedly>")
    None    -> Stdout.print("claim missing: not present")
  }

  let token = jwt_encode(header, payload)
  Stdout.print("")
  Stdout.print("=== encoded ===")
  Stdout.print(token)

  Stdout.print("")
  Stdout.print("=== decoded ===")
  match jwt_decode(token) {
    None -> Stdout.print("decode failed")
    Some(d) -> {
      let header_back  = json_encode(d.header)
      let payload_back = json_encode(d.payload)
      Stdout.print("header  : " ++ header_back)
      Stdout.print("payload : " ++ payload_back)
      # Inspect specific fields out of the decoded JsonValue
      # without re-parsing — the AST is structured.
      match json_lookup_str(d.header, "kid") {
        Some(k) -> Stdout.print("decoded kid : " ++ k)
        None    -> Stdout.print("decoded kid : <missing>")
      }
      match json_lookup_str(d.payload, "sub") {
        Some(s) -> Stdout.print("decoded sub : " ++ s)
        None    -> Stdout.print("decoded sub : <missing>")
      }
      let header_ok  = header_back == header
      let payload_ok = payload_back == payload
      if header_ok and payload_ok { Stdout.print("round-trip: ok") }
      else { Stdout.print("round-trip: MISMATCH") }
    }
  }
  0
}
