# Negative: a read-only handle cannot flow into `write_chunk` —
# `<read>` does not subsume into `<write>`.

fn main() : Unit / Stdout + File {
  match File.open_read("/tmp/kai_perm_1251_reject.txt") {
    Ok(h) -> match File.write_chunk(h, "nope") {
      Ok(_) -> Stdout.print("wrote")
      Err(e) -> Stdout.print(e)
    }
    Err(e) -> Stdout.print(e)
  }
}
