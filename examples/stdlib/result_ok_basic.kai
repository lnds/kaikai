# issue #182 — smoke test for result_ok (Result -> Option of value).

fn show(o: Option[Int]) : String {
  match o {
    Some(v) -> "some=#{int_to_string(v)}"
    None    -> "none"
  }
}

fn main() {
  let good : Result[String, Int] = Ok(11)
  let bad  : Result[String, Int] = Err("nope")
  println(show(result.ok(good)))
  println(show(result.ok(bad)))
}
