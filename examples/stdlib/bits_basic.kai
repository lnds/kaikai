# bit operations smoke test — exercises every entry in
# stdlib/math/bits.kai. The compiler lowers each call to the
# matching C operator inline; the structural grep in stage2's
# `test-stdlib` target asserts the lowering happened.

fn show_bool(b: Bool) : String = if b { "true" } else { "false" }

fn main() = {
  # Logical bitwise (decimal literals stand in for hex):
  #   240 = 0xF0, 15 = 0x0F, 255 = 0xFF, 254 = 0xFE.
  Stdout.print(int_to_string(bit_and(240, 15)))         # 0
  Stdout.print(int_to_string(bit_or(240, 15)))          # 255
  Stdout.print(int_to_string(bit_xor(255, 15)))         # 240
  Stdout.print(int_to_string(bit_not(0)))               # -1

  # Shifts. `bit_shr` is arithmetic (sign-preserving);
  # `bit_ushr` is logical (zero-fill via uint64_t cast).
  Stdout.print(int_to_string(bit_shl(1, 3)))            # 8
  Stdout.print(int_to_string(bit_shr(8, 3)))            # 1
  Stdout.print(int_to_string(bit_shr(-8, 1)))           # -4
  Stdout.print(int_to_string(bit_ushr(-1, 60)))         # 15

  # Population count, bit test, and per-bit set/clear/toggle.
  # 10 = 0b1010 — bit 0 = 0, bit 1 = 1.
  Stdout.print(int_to_string(bit_count(7)))             # 3
  Stdout.print(show_bool(bit_test(10, 1)))              # true
  Stdout.print(show_bool(bit_test(10, 0)))              # false
  Stdout.print(int_to_string(bit_set(0, 5)))            # 32
  Stdout.print(int_to_string(bit_clear(255, 0)))        # 254
  Stdout.print(int_to_string(bit_toggle(0, 0)))         # 1
  Stdout.print(int_to_string(bit_toggle(1, 0)))         # 0
}
