# Issue #340 — group_by / find_map / last / init coverage.
#
# `group_by` uses Erlang / Elixir semantics (groups *consecutive*
# equal keys, NOT all-equal regardless of position). `find_map`
# returns the first `Some` from `f` over `xs`. `last` / `init` are
# symmetric to `head` / `tail`.

fn show_int_list(xs: [Int]) : String =
  string_concat("[", string_concat(string.join(map(xs, int_to_string), ","), "]"))

fn show_int_list_list(xss: [[Int]]) : String =
  string_concat("[",
    string_concat(string.join(map(xss, show_int_list), ";"), "]"))

fn show_opt_int(o: Option[Int]) : String {
  match o {
    None    -> "none"
    Some(x) -> int_to_string(x)
  }
}

fn show_opt_int_list(o: Option[[Int]]) : String {
  match o {
    None     -> "none"
    Some(xs) -> show_int_list(xs)
  }
}

fn parity(n: Int) : Int = n % 2

fn main() {
  # group_by: consecutive runs by key.
  println(show_int_list_list(list.group_by([1, 1, 2, 2, 2, 3, 1, 1], (x) => x)))
  println(show_int_list_list(list.group_by([1, 3, 5, 2, 4, 7], parity)))
  println(show_int_list_list(list.group_by([], (x) => x)))
  println(show_int_list_list(list.group_by([7], (x) => x)))
  println(show_int_list_list(list.group_by([1, 2, 3], (x) => 0)))

  # find_map: first Some wins.
  println(show_opt_int(list.find_map([1, 2, 3, 4], (x) => if x > 2 { Some(x * 10) } else { None })))
  println(show_opt_int(list.find_map([1, 2, 3], (x) => if x > 100 { Some(x) } else { None })))
  println(show_opt_int(list.find_map([], (x) => Some(x))))

  # last / init: symmetric to head / tail.
  println(show_opt_int(list.last([])))
  println(show_opt_int(list.last([42])))
  println(show_opt_int(list.last([1, 2, 3])))
  println(show_opt_int_list(list.init([])))
  println(show_opt_int_list(list.init([42])))
  println(show_opt_int_list(list.init([1, 2, 3])))
  println(show_opt_int_list(list.init([1, 2, 3, 4])))
}
