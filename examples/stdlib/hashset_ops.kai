# HashSet[t] set algebra — union / intersection / difference /
# is_subset on small Int sets with known expected results. The
# algebra ops return a FRESH set and leave both arguments untouched.

import collections.hashset

fn verify(label: String, ok: Bool) : Unit / Stdout =
  if ok { Stdout.print(label ++ ": ok") } else { Stdout.print(label ++ ": FAIL") }

fn int_cmp(a: Int, b: Int) : Int = if a == b { 0 } else if a < b { 0 - 1 } else { 1 }

# Sorted, comma-joined member list — deterministic regardless of the
# unspecified bucket iteration order.
fn show(s: HashSet[Int]) : String / Mutable =
  string.join(list.map(list.sort_by(hashset.to_list(s), int_cmp), int_to_string), ",")

fn main() : Int / Stdout + Mutable = {
  let a = hashset.from_list([1, 2, 3, 4])
  let b = hashset.from_list([3, 4, 5, 6])

  # ---- union: {1,2,3,4,5,6} ----
  let u = hashset.union(a, b)
  verify("union size 6", hashset.size(u) == 6)
  Stdout.print("union: " ++ show(u))
  verify("union has 1", hashset.contains(u, 1))
  verify("union has 6", hashset.contains(u, 6))

  # ---- intersection: {3,4} ----
  let i = hashset.intersection(a, b)
  verify("intersection size 2", hashset.size(i) == 2)
  Stdout.print("intersection: " ++ show(i))
  verify("intersection has 3", hashset.contains(i, 3))
  verify("intersection no 1", not hashset.contains(i, 1))

  # ---- difference a - b: {1,2}, b - a: {5,6} ----
  let dab = hashset.difference(a, b)
  verify("a-b size 2", hashset.size(dab) == 2)
  Stdout.print("a-b: " ++ show(dab))
  let dba = hashset.difference(b, a)
  verify("b-a size 2", hashset.size(dba) == 2)
  Stdout.print("b-a: " ++ show(dba))

  # ---- disjoint sets ----
  let x = hashset.from_list([10, 20])
  let y = hashset.from_list([30, 40])
  verify("disjoint intersection empty", hashset.is_empty(hashset.intersection(x, y)))
  verify("disjoint union size 4", hashset.size(hashset.union(x, y)) == 4)

  # ---- is_subset ----
  let sub = hashset.from_list([3, 4])
  let notsub = hashset.from_list([3, 4, 7])
  let emptySet = hashset.empty()
  verify("{3,4} subset of a", hashset.is_subset(sub, a))
  verify("{3,4,7} not subset of a", not hashset.is_subset(notsub, a))
  verify("empty subset of a", hashset.is_subset(emptySet, a))
  verify("a subset of itself", hashset.is_subset(a, a))
  verify("a not subset of {3,4}", not hashset.is_subset(a, sub))

  # ---- args are not mutated by the algebra ops ----
  verify("a unchanged after ops", hashset.size(a) == 4)
  verify("b unchanged after ops", hashset.size(b) == 4)
  Stdout.print("a: " ++ show(a))
  Stdout.print("b: " ++ show(b))

  0
}
