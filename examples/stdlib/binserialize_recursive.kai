# Issue #459: round-trip a recursive sum (binary tree of Ints).
# `BTree` references itself in the `Branch` payload; the validator
# whitelists the type's own name so the derive succeeds, and the
# synthesised `from_bytes` calls itself transitively via
# `__pimpl_BinSerialize_BTree_from_bytes` to decode each subtree.
# No explicit visit-cycle detection is needed because the encoded
# stream is a finite serialisation of a finite tree.

#derive(BinSerialize)
type BTree = Leaf(Int) | Branch(BTree, BTree)

fn show_tree(t: BTree) : String = match t {
  Leaf(n)       -> string_concat("L(", string_concat(int_to_string(n), ")"))
  Branch(l, r)  -> string_concat("B(",
                     string_concat(show_tree(l),
                       string_concat(",",
                         string_concat(show_tree(r), ")"))))
}

fn round(t: BTree) : Unit / Stdout = {
  let bs = to_bytes(t)
  print(int_to_string(list_length(bs)))
  match btree_from_bytes(bs, 0) {
    Ok(r)  -> { print(show_tree(r.value)); print(int_to_string(r.pos)) }
    Err(m) -> print(m)
  }
}

fn main() : Int {
  round(Leaf(42))
  round(Branch(Leaf(1), Leaf(2)))
  round(Branch(Leaf(1), Branch(Leaf(2), Leaf(3))))
  0
}
