# issue #162 — currency mismatch in a `Decimal<u>` slot. The
# rewrite path bails out when the literal's unit differs from the
# expected field's unit, leaving the regular unifier to surface
# the unit-mismatch diagnostic. No silent USD↔EUR coercion.

unit USD
unit EUR

fn main() : Unit / Stdout = {
  let x : Decimal<USD> = 4.0<EUR>
  Stdout.print("ok")
}
