# Issue #348 — smoke test for the tuple helper surface in core/tuple.kai:
# swap, map_fst, map_snd, map_pair on Pair[a, b] plus
# first/second/third on Triple[a, b, c].
#
# Compiled with `--prelude ../stdlib/core/*.kai`. Output is line-oriented
# so the golden stays grep-friendly.
#
# (Projection helpers `fst` / `snd` are intentionally NOT in the
# surface — see `stdlib/core/tuple.kai` header for the field-vs-function
# shadowing rationale.)

fn double(n: Int) : Int = n * 2
fn shout(s: String) : String = string_concat(s, "!")

fn main() {
  let p = Pair { fst: 1, snd: "two" }

  # swap — round-trip preserves the Pair
  let q = tuple.swap(p)
  println(q.fst)
  println(int_to_string(q.snd))
  let r = tuple.swap(q)
  println(int_to_string(r.fst))
  println(r.snd)

  # map_fst / map_snd
  let p2 = tuple.map_fst(p, double)
  println(int_to_string(p2.fst))
  println(p2.snd)

  let p3 = tuple.map_snd(p, shout)
  println(int_to_string(p3.fst))
  println(p3.snd)

  # map_pair — both at once
  let p4 = tuple.map_pair(p, double, shout)
  println(int_to_string(p4.fst))
  println(p4.snd)

  # Triple — first / second / third
  let t = Triple { fst: 10, snd: "mid", trd: 99 }
  println(int_to_string(tuple.first(t)))
  println(tuple.second(t))
  println(int_to_string(tuple.third(t)))
}
