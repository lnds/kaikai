# Regression for issue #318 — `kai test <file>` runs only the file's
# own test blocks. Pre-fix, every stdlib `test "..."` block reached
# the test runner because `--prelude` files were parsed and their
# decls (DTest included) were concatenated into the global flat decl
# stream. The fix drops `DTest`/`DBench`/`DCheck` from each prelude
# at load time unless `--include-prelude-tests` is passed.
#
# Run via `test-issue-318` (default) and `test-issue-318-include`
# (opt-in legacy behaviour). The default invocation must report
# exactly the two tests defined here; the opt-in invocation reports
# them plus every test block in the loaded preludes.

fn main() {
  println("issue 318")
}

test "issue 318 — first user test runs" {
  assert 1 + 1 == 2
}

test "issue 318 — second user test runs" {
  assert 2 * 3 == 6
}
