# issue #182 — smoke test for result_err (Result -> Option of error).

fn show(o: Option[String]) : String {
  match o {
    Some(e) -> "some=#{e}"
    None    -> "none"
  }
}

fn main() {
  let ok  : Result[String, Int] = Ok(11)
  let bad : Result[String, Int] = Err("nope")
  println(show(result.err(ok)))
  println(show(result.err(bad)))
}
