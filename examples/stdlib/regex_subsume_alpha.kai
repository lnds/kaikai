# m12.6.x #7b — narrower-alphabet subsumption variant. `[a-c]+` ⊆
# `[a-z]+` exercises the range-vs-range path inside the ASCII mask
# subset check (every code point that the strict mask flags must be
# flagged in the loose mask too). Same drop-the-assert proof
# obligation as `regex_subsume_basic.kai`, different shape.

type AlphaABC = String where matches ~r/^[a-c]+$/

import regexp.{matches}

fn echo(s: String where matches ~r/^[a-c]+$/) : String
  requires matches(s, ~r/^[a-z]+$/)
  = s

fn classify(s: String) : String = match s {
  x : AlphaABC -> echo(x)
  _            -> "out"
}

fn main() : Unit / Stdout {
  Stdout.print(classify("aabbcc"))  # accepts
  Stdout.print(classify("a"))       # accepts: single char
  Stdout.print(classify("abcd"))    # rejects: `d` is outside [a-c]
  Stdout.print(classify("ABC"))     # rejects: uppercase
}
