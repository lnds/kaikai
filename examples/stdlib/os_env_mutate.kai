# Issue #127 acceptance fixture — `Env.set_var` / `Env.var` /
# `Env.unset_var` round-trip plus `Env.vars()` enumeration.
# Asserts the new write side actually mutates the process env
# block (the value just written reads back) and that `unset_var`
# wipes the entry. The `vars()` walk asserts the just-set entry
# appears in the snapshot — proves the runtime walks `**environ`
# correctly and the `Pair { fst, snd }` lift wires up.

fn check_eq(label: String, got: String, want: String) : Unit / Stdout =
  if got == want { Stdout.print(label ++ ": ok") }
  else { Stdout.print(label ++ ": MISMATCH got=\"" ++ got ++ "\" want=\"" ++ want ++ "\"") }

fn check_bool(label: String, got: Bool, want: Bool) : Unit / Stdout =
  if got == want { Stdout.print(label ++ ": ok") }
  else { Stdout.print(label ++ ": MISMATCH") }

fn read_back(name: String) : String / Env =
  match Env.get(name) {
    Some(v) -> v
    None    -> "<unset>"
  }

fn vars_contain(name: String, want: String, xs: [Pair[String, String]]) : Bool =
  match xs {
    []          -> false
    [p, ...rest] ->
      if p.fst == name { p.snd == want }
      else             { vars_contain(name, want, rest) }
  }

fn main() : Unit / Stdout + Env = {
  let key = "KAIKAI_ISSUE_127_X"

  # 1. clean slate — the key is not pre-set in CI.
  check_eq("absent before set", read_back(key), "<unset>")

  # 2. set then read back.
  match Env.set_var(key, "42") {
    Ok(_)    -> Stdout.print("set: ok")
    Err(msg) -> Stdout.print("set: ERR " ++ msg)
  }
  check_eq("readback after set", read_back(key), "42")

  # 3. overwrite (setenv with overwrite=1) — second write wins.
  match Env.set_var(key, "99") {
    Ok(_)    -> Stdout.print("overwrite: ok")
    Err(msg) -> Stdout.print("overwrite: ERR " ++ msg)
  }
  check_eq("readback after overwrite", read_back(key), "99")

  # 4. enumerate — the just-written entry must surface in `vars()`.
  check_bool("vars contains entry", vars_contain(key, "99", Env.vars()), true)

  # 5. unset, then verify gone.
  match Env.unset_var(key) {
    Ok(_)    -> Stdout.print("unset: ok")
    Err(msg) -> Stdout.print("unset: ERR " ++ msg)
  }
  check_eq("readback after unset", read_back(key), "<unset>")

  # 6. unset of an absent key is also Ok per POSIX.
  match Env.unset_var(key) {
    Ok(_)    -> Stdout.print("unset absent: ok")
    Err(msg) -> Stdout.print("unset absent: ERR " ++ msg)
  }
}
