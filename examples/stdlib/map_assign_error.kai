# issue #128 — `m[k] := v` is rejected on `Map[K, V]` in v1. The
# write-side sugar over persistent containers needs a separate
# design pass (the v2 lane that lands alongside HAMT); meanwhile
# the typer points at `map.put`. The .err.expected golden requires
# the diagnostic substring to appear, so any wording change here
# also needs an update there.

import collections.map

fn main() {
  let m = map.put(map.empty(), "alice", 1)
  m["bob"] := 2
  0
}
