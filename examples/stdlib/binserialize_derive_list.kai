# `#derive(BinSerialize)` for a record with a `[T]` field. Before the
# combinator extension (`docs/binserialize-collections-design.md`)
# this derive would have been rejected by the validator because there
# is no usable `impl BinSerialize for List`. The derive now routes
# list fields through `bin_list_to_bytes` / `bin_list_from_bytes` and
# the inner element type's encoder/decoder symbols, supplied via
# closure.

#derive(BinSerialize)
type Bag = { name: String, items: [Int] }

fn main() : Int {
  let b = Bag { name: "things", items: [10, 20, 30] }
  let bs = to_bytes(b)
  print(int_to_string(list_length(bs)))
  match bag_from_bytes(bs, 0) {
    Err(m) -> print(m)
    Ok(c)  -> {
      print(c.value.name)
      match c.value.items {
        [a, b2, c2] -> {
          print(int_to_string(a))
          print(int_to_string(b2))
          print(int_to_string(c2))
        }
        _ -> print("unexpected length")
      }
    }
  }
  0
}
