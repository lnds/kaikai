# Lane 4 (#473) — `Byte` nominal primitive surface.
#
# Covers the round-trip Int -> Byte -> Int, the 0..255 range guard, and
# the boundary values (0, 128, 255, 256-as-error).

fn show_result(r: Result[Byte, String]) : String = match r {
  Ok(b)  -> "Ok(" ++ byte_to_string(b) ++ ")"
  Err(e) -> "Err(" ++ e ++ ")"
}

fn main() : Unit / Stdout = {
  Stdout.print(show_result(int_to_byte(0)))
  Stdout.print(show_result(int_to_byte(128)))
  Stdout.print(show_result(int_to_byte(255)))
  Stdout.print(show_result(int_to_byte(256)))
  Stdout.print(show_result(int_to_byte(-1)))

  # Round-trip through byte_to_int.
  let b = match int_to_byte(200) { Ok(x) -> x Err(_) -> panic("unreachable") }
  Stdout.print("byte_to_int(200) = " ++ int_to_string(byte_to_int(b)))
}
