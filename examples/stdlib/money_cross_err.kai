# Cross-currency arithmetic is a compile-time unit mismatch: USD and
# EUR are distinct habitants of the Currency kind and never unify.
import money
import decimal as dec
import decimal_proto

fn main() {
  let a: Money[USD] = 10.50<USD>
  let b: Money[EUR] = 2.00<EUR>
  let c = a + b
  print("no")
}
