# m12.6.x #7 — negative fixture. v1 of the regex sigil forbids a
# literal `#` in the pattern body because the desugared string
# carrier would collide with kaikai's `#{...}` interpolation
# syntax. Users who genuinely need `#` precompose the regex via
# `regexp.compile` directly. Tracked under the m12.6.x #7
# follow-up issue.

type Bad = String where matches ~r/has#hash/

fn main() : Unit / Stdout {
  Stdout.print("unreached")
}
