# `#derive(BinSerialize)` for a record with a `Char` field. Char
# encodes as 4 little-endian bytes (its Int representation).

#derive(BinSerialize)
type Tag = { initial: Char, name: String }

fn main() : Int {
  let t = Tag { initial: 'Z', name: "zeta" }
  let bs = to_bytes(t)
  print(int_to_string(array_length(bs)))
  match tag_from_bytes(bs, 0) {
    Err(m) -> print(m)
    Ok(c)  -> {
      print(string_concat("initial=", "#{c.value.initial}"))
      print(c.value.name)
    }
  }
  0
}
