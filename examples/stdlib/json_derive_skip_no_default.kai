# Negative fixture: a `#[json(skip)]` field has no wire value to read
# back, so decode cannot reconstruct it unless a `#[json(default)]` or an
# `Option` type supplies one. A bare skip on a required field is a
# compile error at the derive.

#[derive(Json)]
type Config = { host: String, #[json(skip)] cache: [Int] }

fn main() : Int = 0
