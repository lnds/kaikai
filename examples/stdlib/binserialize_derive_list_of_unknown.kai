# The validator for `#derive(BinSerialize)` recursively unwraps `[T]`
# and `Option[T]` to report the *element* type as missing rather than
# the outer collection. Here `[Color]` reports `Color`, which matches
# the user's mental model ("BinSerialize for Color is what I need to
# add") instead of an unhelpful "no impl for List".

type Color = { r: Int, g: Int, b: Int }

#[derive(BinSerialize)]
type Palette = { items: [Color] }

fn main() : Int { 0 }
