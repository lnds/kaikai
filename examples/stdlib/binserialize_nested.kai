# Issue #459: nested optional shapes via two derived sums. Parametric
# `Option[T]` is out of scope for v1 derive (the precedent — Show /
# Eq / Hash / Ord — only handles non-parametric heads), so this
# fixture nests `MaybeInt` inside `MaybeMaybeInt` to exercise the
# "decode a sum whose payload is another derived sum" path. The
# synth threads `mi_from_bytes` for the inner type before
# constructing the outer variant.

#derive(BinSerialize)
type MaybeInt = NoneI | SomeI(Int)

#derive(BinSerialize)
type MaybeMaybeInt = NoneMI | SomeMI(MaybeInt)

fn show_mi(m: MaybeInt) : String = match m {
  NoneI    -> "NoneI"
  SomeI(n) -> string_concat("SomeI(", string_concat(int_to_string(n), ")"))
}

fn show_mmi(m: MaybeMaybeInt) : String = match m {
  NoneMI    -> "NoneMI"
  SomeMI(x) -> string_concat("SomeMI(", string_concat(show_mi(x), ")"))
}

fn round_trip(m: MaybeMaybeInt) : Unit / Stdout = {
  let bs = to_bytes(m)
  match maybemaybeint_from_bytes(bs, 0) {
    Ok(r)  -> { print(show_mmi(r.value)); print(int_to_string(r.pos)) }
    Err(s) -> print(s)
  }
}

fn main() : Int {
  round_trip(NoneMI)
  round_trip(SomeMI(NoneI))
  round_trip(SomeMI(SomeI(99)))
  0
}
