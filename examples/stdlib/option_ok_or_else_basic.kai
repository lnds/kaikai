# issue #182 — smoke test for option.ok_or_else (Option -> Result, lazy error).

fn pretty(r: Result[Int, String]) : String {
  match r {
    Ok(v)  -> "ok=#{int_to_string(v)}"
    Err(e) -> "err=#{e}"
  }
}

fn main() {
  let s : Option[Int] = Some(3)
  let n : Option[Int] = None
  println(pretty(option.ok_or_else(s, () => "lazy")))
  println(pretty(option.ok_or_else(n, () => "lazy")))
}
