# issue #182 — smoke test for opt_ok_or_else (Option -> Result, lazy error).

fn show(r: Result[String, Int]) : String {
  match r {
    Ok(v)  -> "ok=#{int_to_string(v)}"
    Err(e) -> "err=#{e}"
  }
}

fn main() {
  let s : Option[Int] = Some(3)
  let n : Option[Int] = None
  println(show(opt_ok_or_else(s, () => "lazy")))
  println(show(opt_ok_or_else(n, () => "lazy")))
}
