# Issue #744 — UTF-8 codepoint model fixture.
#
# `bytes(s)` is the byte-level view (one Char per UTF-8 byte);
# `chars(s)` is the codepoint-level view (one Char per Unicode
# codepoint, decoding the buffer). `length`/`byte_length` count bytes;
# `char_count` counts codepoints. `char_indices` pairs each codepoint
# with the byte offset it starts at. For ASCII the two views coincide;
# the divergence shows on multibyte input.
#
# The motivating string from the issue: "áé▸" is á(2B) é(2B) ▸(3B) = 7
# bytes, 3 codepoints; the first byte is 0xC3 (195, a UTF-8 lead byte),
# the first codepoint is 0xE1 (225, the scalar value of á).

fn first_int(cs: [Char]) : Int =
  match cs {
    []         -> -1
    [c, ..._r] -> char_to_int(c)
  }

fn show_indices(ps: [string.CharIndex]) : Unit / Stdout =
  match ps {
    [] -> ()
    [p, ...rest] -> {
      Stdout.print("  off=#{int_to_string(p.off)} cp=#{int_to_string(char_to_int(p.cp))}")
      show_indices(rest)
    }
  }

fn main() : Unit / Stdout = {
  let s = "áé▸"

  # byte vs codepoint length
  Stdout.print("byte_length=#{int_to_string(string.byte_length(s))}")   # 7
  Stdout.print("length=#{int_to_string(string.length(s))}")             # 7
  Stdout.print("char_count=#{int_to_string(string.char_count(s))}")     # 3

  # byte vs codepoint lists (count + first element)
  Stdout.print("bytes_len=#{int_to_string(list.length(string.bytes(s)))}")   # 7
  Stdout.print("chars_len=#{int_to_string(list.length(string.chars(s)))}")   # 3
  Stdout.print("first_byte=#{int_to_string(first_int(string.bytes(s)))}")    # 195
  Stdout.print("first_char=#{int_to_string(first_int(string.chars(s)))}")    # 225

  # ASCII: the two views coincide
  Stdout.print("ascii_bytes=#{int_to_string(list.length(string.bytes("abc")))}")   # 3
  Stdout.print("ascii_chars=#{int_to_string(list.length(string.chars("abc")))}")   # 3

  # char_indices: codepoint with its starting byte offset. "á!" is
  # á(bytes 0..1) then '!' at byte 2.
  Stdout.print("indices of á!:")
  show_indices(string.char_indices("á!"))
}
