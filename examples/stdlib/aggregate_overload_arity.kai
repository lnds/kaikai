# Regression smoke test for the generalised aggregates (#891): the
# arity-1 `max(xs)` (list aggregate) and the arity-2 `min(a, b)` (Ord
# protocol) coexist bare in one program and resolve correctly. Must
# keep printing `a = 3 y b = 2` after list.max/min generalise to [T:Ord].
fn main() {
  let a = max([1, 2, 3]).unwrap_or(0)
  let b = min(a, 2)
  println("a = #{a} y b = #{b}")
}
