# issue #182 — smoke test for result_unwrap_or_else.

fn main() {
  let ok  : Result[String, Int] = Ok(42)
  let err : Result[String, Int] = Err("xyz")
  # Ok keeps inner.
  println(int_to_string(result.unwrap_or_else(ok, (e) => 0)))
  # Err computes recovery from the error payload.
  println(int_to_string(result.unwrap_or_else(err, (e) => string_length(e))))
}
