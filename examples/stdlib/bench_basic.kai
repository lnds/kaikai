# bench v1 (issue #40) — smoke fixture for `kai bench`.
#
# Run with:
#
#   bin/kai bench examples/stdlib/bench_basic.kai
#
# Each `bench "name" { body }` block is timed for KAI_BENCH_ITERS
# iterations (fixed at 1000 in stage0/runtime.h) under
# clock_gettime(CLOCK_MONOTONIC). The runner prints
#
#   <name>: 1000 iter / <ns> ns/iter
#
# per block, followed by a `3 benches` summary line. ns/iter values
# vary per run; the `make test-bench` target greps for the format
# rather than diffing against a golden file.

fn fib(n: Int) : Int {
  if n < 2 { n }
  else { fib(n - 1) + fib(n - 2) }
}

# Tier 1 — primitive arithmetic. No allocation; expected to be the
# cheapest of the three.
bench "arith: 2 + 3 * 4" {
  2 + 3 * 4
}

# Tier 2 — list construction + traversal. Exercises cons / record
# allocations and the linear-pass length walker.
bench "allocs: list_repeat(1, 16) length" {
  list_length(list_repeat(1, 16))
}

# Tier 3 — recursion + arithmetic. fib(10) doubles as a smoke for
# self-tail-call rewrite + recursive call accounting.
bench "recursive: fib(10)" {
  fib(10)
}
