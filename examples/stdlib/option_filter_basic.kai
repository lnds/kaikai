# issue #182 — smoke test for opt_filter.

fn show(o: Option[Int]) : String {
  match o {
    Some(v) -> "some=#{int_to_string(v)}"
    None    -> "none"
  }
}

fn main() {
  let s : Option[Int] = Some(4)
  let n : Option[Int] = None
  println(show(opt_filter(s, (x) => x > 2)))   # passes
  println(show(opt_filter(s, (x) => x > 9)))   # fails
  println(show(opt_filter(n, (x) => true)))    # None stays None
}
