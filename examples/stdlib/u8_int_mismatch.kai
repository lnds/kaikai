# Lane 4 (#473) — negative fixture.
#
# `u8` and `Int` are nominally distinct. Passing an `Int` where a `u8`
# is expected (or vice-versa) is a type error caught at compile time.
# This is the property that makes `Byte = u8` honest rather than a
# label on `Int`.

fn double_byte(b: u8) : u8 = u8_add(b, b)

fn main() : Unit / Stdout = {
  # Passing a literal Int — should be rejected by the typer.
  Stdout.print(u8_to_string(double_byte(5)))
}
