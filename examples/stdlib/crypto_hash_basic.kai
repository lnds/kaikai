# SHA-256 / SHA-512 / HMAC-SHA-{256,512} acceptance.
#
# Test vectors:
#   - SHA-256 empty + "abc"     — FIPS 180-4 Appendix B.1 / B.2
#   - SHA-512 empty             — FIPS 180-4 Appendix C.1
#   - HMAC-SHA-256 RFC 4231 §4.2 (test case 2)
#   - HMAC-SHA-512 RFC 4231 §4.2 (test case 2)

import crypto.hash.{sha256, sha512}
import crypto.mac.{hmac_sha256, hmac_sha512}
import encoding.hex

fn str_to_bytes_loop(s: String, i: Int, acc: [Int]) : [Int] = {
  if i >= string_length(s) { list_reverse(acc) }
  else { match char_at(s, i) {
    None    -> list_reverse(acc)
    Some(c) -> str_to_bytes_loop(s, i + 1, [char_to_int(c), ...acc])
  } }
}

fn str_to_bytes(s: String) : [Int] = str_to_bytes_loop(s, 0, [])

fn check_digest(label: String, got: [Int], want: String) : Unit / Stdout = {
  let got_hex = hex.encode(got)
  if got_hex == want { Stdout.print(label ++ ": ok") }
  else {
    Stdout.print(label ++ ": MISMATCH")
    Stdout.print("  got : " ++ got_hex)
    Stdout.print("  want: " ++ want)
  }
}

fn main() = {
  check_digest("sha256 empty", sha256([]),
        "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855")

  # FIPS 180-4 Appendix B.1.
  check_digest("sha256 abc", sha256(str_to_bytes("abc")),
        "ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad")

  check_digest("sha512 empty", sha512([]),
        "cf83e1357eefb8bdf1542850d66d8007d620e4050b5715dc83f4a921d36ce9ce47d0d13c5d85f2b0ff8318d2877eec2f63b931bd47417a81a538327af927da3e")

  check_digest("hmac-sha256 rfc4231 case 2",
        hmac_sha256(str_to_bytes("Jefe"),
                    str_to_bytes("what do ya want for nothing?")),
        "5bdcc146bf60754e6a042426089575c75a003f089d2739839dec58b964ec3843")

  check_digest("hmac-sha512 rfc4231 case 2",
        hmac_sha512(str_to_bytes("Jefe"),
                    str_to_bytes("what do ya want for nothing?")),
        "164b7a7bfcf819e2e395fbe73b56e0a387bd64222e831fd610270cd7ea2505549758bf75c05a994a6d034f65f8f0e6fdcaeab1a34d4a6b4b636e070a38bce737")
  0
}
