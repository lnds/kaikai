# issue #201 — `||` flat-map-pipe over `[T]`.
#
# Each input element produces a list; `||` concatenates them in
# input order. Smoke-test for the full lex / parse / typer / codegen
# pipeline of the new operator.

fn main() : Int {
  let zipped = [1, 2, 3] || (x) => [x, x * 10]
  each(zipped, (x) => print(int_to_string(x)))
  0
}
