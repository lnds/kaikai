# issue #201 Constraint #1 — `Option` is NOT in the pipe-dispatch
# table. The compiler must reject `opt | f` (and `opt || f`) with a
# diagnostic that points at the alternatives: `!` for propagation
# and `opt_and_then` for explicit chaining.

fn main() : Int {
  let bad = Some(5) | (x) => x * 2
  0
}
