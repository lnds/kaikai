# issue #201 — mixed `|` / `||` chain.
#
# Verifies the two operators compose left-to-right at the same
# precedence (left-assoc): the LHS of the second `|` is the result
# of the prior `||`, all dispatched on `List` head type.

fn main() : Int {
  let r = [1, 2, 3] || (x) => [x, x + 100] | (y) => y * 2
  each(r, (x) => print(int_to_string(x)))
  0
}
