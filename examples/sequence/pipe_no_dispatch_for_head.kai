# issue #201 Constraint #2 — a user-defined head type that no
# module claims must reject `|` / `||` with a typed error pointing
# at the missing `pub fn map` / `pub fn flat_map`.
#
# `Box[T]` is declared locally and no module registers it in the
# head-type-to-module map, so the dispatch path returns "no module"
# and the typer issues the diagnostic.

type Box[T] = MkBox(T)

fn main() : Int {
  let b = MkBox(5)
  let r = b | (v) => v + 1
  0
}
