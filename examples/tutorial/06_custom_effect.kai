# Tutorial step 6 — define and handle a custom effect.
#
# Three pieces:
#
#   1. The effect declaration: `effect Logger { log(...) : Unit }`.
#      This adds the capability `Logger` and the op `Logger.log`.
#
#   2. The producer: any function that calls `Logger.log` is forced
#      by the typer to declare `/ Logger` in its row. The effect is
#      visible in every signature that uses it.
#
#   3. The consumer: `handle { body } with Logger { log(level, msg, resume) -> ... }`
#      removes `Logger` from the body's row by interpreting every
#      `log` op call. `resume(())` continues the producer past the
#      op call.
#
# Result: the same `process` function can run with different
# handlers — print to stdout, drop the message, prefix with a tag,
# write to a file — without changing producer code.

effect Logger {
  log(level: String, msg: String) : Unit
}

#derive(Show)
type Event
  = Login(String)
  | Logout(String)
  | Error(String)

fn process(ev: Event) : Unit / Logger = match ev {
  Login(u)  -> Logger.log("INFO",  "user login: #{u}")
  Logout(u) -> Logger.log("INFO",  "user logout: #{u}")
  Error(m)  -> Logger.log("ERROR", m)
}

fn main() : Unit / Stdout = {
  let events = [Login("alice"), Logout("alice"), Error("disk full")]

  print("--- handler 1: stdout, with [LEVEL] prefix ---")
  handle {
    each(events, process)
  } with Logger {
    log(level, msg, resume) -> {
      print("[#{level}] #{msg}")
      resume(())
    }
  }

  print("--- handler 2: silent (drops every log call) ---")
  handle {
    each(events, process)
    print("(handler 2 done; no log lines above)")
  } with Logger {
    log(level, msg, resume) -> resume(())
  }
}
