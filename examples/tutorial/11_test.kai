# Tutorial step 11 — the builtin test runner.
#
# Tests are first-class syntax: `test "description" { body }` plus
# `assert <bool>`. Run them with `kai test path/to/file.kai`.
#
# Test blocks live next to production code in the same file. They
# do not run on `kai build` or `kai run`; only `kai test` enables
# them.

fn collatz_length(n: Int) : Int =
  if n <= 1            { 0 }
  else if n % 2 == 0   { 1 + collatz_length(n / 2) }
  else                 { 1 + collatz_length(3 * n + 1) }

test "collatz of 1 is 0" {
  assert collatz_length(1) == 0
}

test "collatz of 6 is 8" {
  # 6 -> 3 -> 10 -> 5 -> 16 -> 8 -> 4 -> 2 -> 1 (8 steps).
  assert collatz_length(6) == 8
}

test "collatz of small inputs is bounded" {
  assert collatz_length(2)  == 1
  assert collatz_length(3)  == 7
  assert collatz_length(7)  == 16
  assert collatz_length(27) == 111
}

# A `main` is still required so `kai run` and `kai build` produce a
# binary. The test blocks above are only enabled by `kai test`.
fn main() : Unit / Stdout = {
  print("collatz(27) = #{collatz_length(27)}")
}
