# Tutorial step 9 — refinements and contracts.
#
# A refinement narrows a base type to values that satisfy a
# predicate. Two forms:
#
#   - Inline on parameters: `fn f(x: Int where x > 0) : Int = ...`.
#     The caller's value is checked against the predicate at the
#     call site.
#
#   - Named: `type NonNeg = Int where >= 0`. The leading-comparator
#     form `where >= 0` desugars to `where self >= 0`. Named
#     refinements show up as match-arm patterns and as documentation;
#     v1 keeps them as a wrapper around the base type rather than a
#     coercion target.
#
# Function contracts:
#   - `requires <pred>` — precondition; checked on entry.
#   - `ensures <pred>`  — postcondition; checked on return. The
#     keyword `result` binds the return value inside the predicate.
#
# Both desugar to runtime asserts in v1.

const MAX_PORT : Int = 65535
const MIN_PORT : Int = 1

# Named refinement — handy for documentation and pattern-arm narrowing.
type Port = Int where MIN_PORT <= self and self <= MAX_PORT

# Inline-refinement parameters check the predicate at the call site.
fn factorial(n: Int where n >= 0) : Int
  ensures result >= 1
  = if n == 0 { 1 } else { n * factorial(n - 1) }

fn next_port(p: Int where MIN_PORT <= p and p < MAX_PORT) : Int
  ensures result > p
  = p + 1

fn main() : Unit / Stdout = {
  let f5  = factorial(5)
  let f10 = factorial(10)
  print("factorial(5)  = #{f5}")
  print("factorial(10) = #{f10}")

  let np = next_port(8080)
  print("next_port(8080) = #{np}")

  let max = MAX_PORT
  print("MAX_PORT = #{max}")

  # Named refinements as match-arm patterns.
  let classify = (n: Int) => match n {
    p : Port -> "port"
    _        -> "out-of-range"
  }
  let c80  = classify(80)
  let c70k = classify(70000)
  print("classify(80)    = #{c80}")
  print("classify(70000) = #{c70k}")
}
