# issue #624 regression guard (variant 4): alias with a hardcoded row
# (no row variable in the tparam list). This path also never paniced;
# the fixture pins it so a future change cannot regress it silently.

pub type Foo[t] = () -> Option[t] / Stdout

fn main() : Int = {
  let f : Foo[Int] = () => None
  let _ = f
  print("alias_hardcoded_row ok")
  0
}
