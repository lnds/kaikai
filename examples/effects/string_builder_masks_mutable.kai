# StringBuilder masking — a function that creates a builder, appends
# to it, and builds the result entirely locally has `Mutable` MASKED
# at its boundary: `assemble` declares NO `/ Mutable` even though it
# drives `append` (which rides `Mutable`), because the builder never
# escapes and `build` only reads the fragment array. Companion to
# `array_local_masks_mutable.kai` for the StringBuilder carrier.
#
# The appends past the initial capacity of 8 also exercise the
# amortised array_grow path while staying local — masking holds
# across the grow.

import string_builder
import core.list

fn assemble(n: Int) : String = {
  let sb = list.foldl([1..n], string_builder.new(), (b, k) => string_builder.append(b, "#{int_to_string(k)};"))
  string_builder.build(sb)
}

fn main() : Unit / Console = {
  print(assemble(3))
  print(assemble(12))
}
