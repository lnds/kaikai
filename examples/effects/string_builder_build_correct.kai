# StringBuilder correctness — append many fragments, including past
# the initial capacity (forcing several amortised grows), then build
# once and check the joined text is exactly the concatenation in
# append order. `append_char` and the empty-builder case are covered
# too. `run` is local, so its row stays pure (Mutable masked); only
# `main`'s own Console shows up.

import string_builder
import core.list

fn run() : String = {
  # 30 numeric fragments past cap 8 → grows 8→16→32
  let nums = list.foldl([1..30], string_builder.new(), (b, k) => string_builder.append(b, "#{int_to_string(k)},"))
  let a = string_builder.build(nums)

  # mixed append / append_char
  let mixed0 = string_builder.new()
  let mixed1 = string_builder.append(mixed0, "ka")
  let mixed2 = string_builder.append_char(mixed1, 'i')
  let mixed3 = string_builder.append(mixed2, "kai")
  let b = string_builder.build(mixed3)

  # empty builder builds the empty string
  let c = string_builder.build(string_builder.new())

  "#{a}|#{b}|#{c}|empty=#{if string_builder.is_empty(string_builder.new()) { "yes" } else { "no" }}|len=#{int_to_string(string_builder.len(mixed3))}"
}

fn main() : Unit / Console = print(run())
