# m12.8 Phase 4b: a user-declared `Io` alias mixes its own
# `Io.print` / `Io.eprint` shapes with atomic `Stdout.print` /
# `Stderr.eprint`. The typer resolves each alias.op to the matching
# component effect; both forms appear interchangeably in the same
# function body.

type Io = Stdout + Stderr

fn main() : Int / Io {
  Io.print("hello via Io.print")
  Stdout.print("hello via Stdout.print")
  Io.eprint("warn via Io.eprint")
  Stderr.eprint("warn via Stderr.eprint")
  0
}
