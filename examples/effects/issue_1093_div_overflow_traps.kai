# Regression for issue #1093. INT64_MIN / -1 overflows two's complement (the
# result is unrepresentable) and is UB for a bare `sdiv`; it must trap like a
# zero divisor. Both operands are runtime values the compiler cannot fold.

fn zero_of(n: Int) : Int = n - n

fn main() : Int / Console = {
  let mn = -9223372036854775807 - 1
  let neg_one = zero_of(mn) - 1
  Stdout.print("about to overflow divide")
  let c = mn / neg_one
  Stdout.print("UNREACHABLE: div overflow did not trap")
  c
}
