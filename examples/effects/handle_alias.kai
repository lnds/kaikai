# m7a #4b smoke test (positive) — `Eff as alias` rebinds the
# capability inside the body. The alias appears in the AST as a
# Some(...) on the EHandle node.

effect Io {
  print(s: String) : Unit
}

fn main() : Int {
  handle {
    log.print("via alias")
    0
  } with Io as log {
    print(s, resume) -> resume(())
  }
}
