# Regression fixture for R11 (issue #61, closed) — parameterised
# handler clause reads `state` once and forwards it to a downstream
# decref-aware sink. Pre-fix, `pcs_is_non_last` returned false for the
# single read, the emit pass produced a raw transfer of the EvE state
# slot's storage, and `kai_prelude_string_concat` freed it before the
# next op call could read it again. The fix special-cases `state` /
# `log` in `pcs_is_non_last` so every read pays a `__perceus_dup`,
# balancing the consumer's burn-off (see
# `docs/lane-diagnostic-r10-r11.md`).
#
# This fixture is the "Carrier" arm — same shape as the "Reader" arm
# in `r10_repro.kai`, with the parameterised effect named `Carrier`
# and its read op named `read` to match how R11 was originally
# logged. Both arms exercise the same bug; keeping both as
# regression fixtures means a future revert of this lane fails
# tier1-asan via either name.
#
# A regression of this shape (raw alias re-introduced) shows up as
# either:
#   - blank or garbage prefix bytes on the second/third Trace.log
#   - SIGSEGV / SIGBUS, or
#   - heap-use-after-free under ASAN+UBSan in
#     `kai_prelude_string_concat`.

import trace

effect Carrier[T] {
  read() : T
}

pub fn with_log_prefix_buggy[R, e](
  prefix: String,
  body: () -> R / Trace + e
) : R / Trace + e = {
  handle {
    handle {
      body()
    } with Trace {
      log(msg, resume) -> {
        Trace.log(Carrier.read() ++ ": " ++ msg)
        resume(())
      }
      checkpoint(name, resume) -> {
        Trace.log(Carrier.read() ++ ": checkpoint: " ++ name)
        resume(())
      }
      return(x) -> x
    }
  } with Carrier[String](prefix) {
    # Single read of `state`. Pre-fix this raw-transferred the EvE
    # slot's storage to `kai_prelude_string_concat`, which decrefed
    # it; the next op call into this clause then read freed memory.
    read(resume) -> resume(state)
    return(x)    -> x
  }
}

fn worker() : Unit / Trace = {
  Trace.log("first")
  Trace.log("second")
  Trace.log("third")
}

fn main() : Unit / Stdout = with_trace_default() {
  with_log_prefix_buggy("P", worker)
}
