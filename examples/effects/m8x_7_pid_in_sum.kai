# Issue #71 (option (a)) — symmetric to m8x_7_fiber_in_sum but for
# Pid: a user-defined sum carrying a `Pid[Nothing]` payload no
# longer escapes the region-brand walker. The walker substitutes
# the type's tparams into each variant's payload TypeExpr and
# recurses, citing the constructor + sum type in the diagnostic.

import actor

type PidBox = Hold(Pid[Nothing])

fn leaky() : PidBox = Hold(mailbox_alloc())

fn main() : Int = {
  let _ = leaky()
  0
}
