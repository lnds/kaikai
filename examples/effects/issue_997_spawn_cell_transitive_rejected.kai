# #997 — the transitive case. The spawned task does not name the cell directly;
# it applies a closure (`reader`) that captured it. The escape check forward-
# taints `reader` (it carries a cell-reading closure) and rejects the spawn that
# applies it, just as it rejects a spawn that reads the cell inline.
import spawn

fn main() : Int / Spawn = {
  var counter := 0
  let reader = () => { let _ = counter; () }
  nursery { n ->
    let f = n.spawn(() => { reader(); () })
    ()
  }
  0
}
