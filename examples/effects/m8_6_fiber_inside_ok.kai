# m8 #6 positive — `Fiber[T]` is fine in let bindings inside a
# function body; the m8 #6 check only fires on RETURN types of
# user-visible functions. Here `process_pair` produces a Fiber
# locally, awaits it inside the same scope, and returns the
# unwrapped Int. Compiles cleanly.

import spawn

fn task() : Int = 99

fn process_pair() : Int / Spawn = {
  let f = fiber_spawn(task)
  fiber_await(f)
}

fn main() : Int / Console + Spawn {
  Stdout.print(int_to_string(process_pair()))
  0
}
