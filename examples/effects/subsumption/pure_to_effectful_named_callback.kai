# issue #645 — a pure named callback passed to a row-polymorphic
# higher-order fn. Both `add` and `apply` need to compile without the
# caller writing `[e] / e` boilerplate on the pure function.

fn add(a: Int, b: Int) : Int = a + b

fn apply[e](f: (Int, Int) -> Int / e, x: Int, y: Int) : Int / e = f(x, y)

fn main() : Int / Stdout = {
  let r = apply(add, 1, 2)
  println(int_to_string(r))
  0
}
