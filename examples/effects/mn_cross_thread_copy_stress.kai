# M:N cross-thread message copy: heap-carrying messages (lists) migrate
# correctly across scheduler threads. Each worker builds a list on its
# own heap and sends it back; the supervisor sums the lengths. The copy
# path (kai_deep_copy_out into the sender's heap) is exercised for a
# non-immediate payload — an Int message would stay unboxed and skip it.
#
# Deterministic total, so N=1 and N=4 print the same line (the
# determinism gate). Wired into the effects tier as a positive fixture.

import spawn
import actor

fn build(n: Int, acc: [Int]) : [Int] =
  if n <= 0 { acc } else { build(n - 1, [n, ...acc]) }

fn sum_len(xs: [Int]) : Int = xs.length()

fn worker(parent: Pid[[Int]], n: Int) : Unit / Actor[[Int]] + Spawn = {
  Actor.send(parent, build(n, []))
}

fn collect(remaining: Int, acc: Int) : Int / Actor[[Int]] =
  if remaining <= 0 { acc }
  else { collect(remaining - 1, acc + sum_len(Actor.receive())) }

fn spawn_n(parent: Pid[[Int]], n: Int) : Unit / Spawn + Actor[[Int]] =
  if n <= 0 { () }
  else {
    let _ = spawn_actor(() => worker(parent, 50))
    spawn_n(parent, n - 1)
  }

fn main() : Int / Spawn + Console = {
  let total = with_mailbox {
    let me = Actor.self()
    spawn_n(me, 20)
    collect(20, 0)
  }
  Console.print(int_to_string(total))
  0
}
