# Regression for issue #1067. The dual of the contained case: a
# runtime trap at the TOP LEVEL — no fiber pad installed — must still
# terminate the process with a clear message and a non-zero exit, the
# pre-existing behaviour. Routing traps to the fiber pad must not turn
# an unsupervised trap into a longjmp to nowhere or a silent success.

fn main() : Int / Console + Mutable = {
  let xs = array_make(3, 0)
  Stdout.print("about to read xs[10] with no supervisor")
  let _ = xs[10]
  Stdout.print("UNREACHABLE: top-level trap did not terminate")
  0
}
