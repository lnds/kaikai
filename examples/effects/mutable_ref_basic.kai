# issue #257 — Ref[T] in the Mutable effect. Single-cell mutable
# reference: ref_make allocates, ref_get reads, ref_set writes the
# slot. Repro from the issue.

fn main() : Unit / Mutable + Console = {
  let c = Mutable.ref_make(0)
  Mutable.ref_set(c, Mutable.ref_get(c) + 1)
  Mutable.ref_set(c, Mutable.ref_get(c) + 1)
  print(int_to_string(Mutable.ref_get(c)))
}
