# `pat : Type` union-narrow arms (`a:A`, `b:B`) dispatch on the runtime
# tag, not the source order. The typer rewrites each into a top-level
# `PAs(name, PVariant(..))` arm; the lowering must test the inner variant
# tag, not treat the whole arm as a catch-all (which always takes the first).
type U = A | B

fn classify(u : U) : Int = match u { _a:A -> 1; _b:B -> 2 }

fn main() : Int / Stdout = {
  Stdout.print("#{classify(A)} #{classify(B)} #{classify(B)}\n"); 0
}
