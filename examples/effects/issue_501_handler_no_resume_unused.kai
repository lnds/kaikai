# issue #501 — handle result is discarded entirely (no `let`,
# the handle stmt-expr's value is dropped). Used to make sure the
# volatile fix does not break the no-binding shape.

effect Fail {
  fail() : Nothing
}

fn main() : Unit / Stdout {
  handle {
    Fail.fail()
  } with Fail {
    fail(resume) -> 0
  }
  print("done")
}
