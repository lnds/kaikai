# Issue #244 fixture — call site that imports a `pub axiom` from
# a sibling module. Triggers the codegen path that emits
# `kai_myffi__abs(...)` for the cross-module call; the linker
# resolves it to the FFI shim emitted by `myffi.kai` (also
# `kai_myffi__abs` post-fix).

import myffi

fn main() : Unit / Console + Ffi = {
  print(int_to_string(myffi.abs(0 - 7)))
}
