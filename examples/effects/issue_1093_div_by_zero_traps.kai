# Regression for issue #1093. Raw integer division by a runtime zero must
# trap cleanly (non-zero exit + message on stderr), the same failure class as
# an out-of-range array index — not silent UB returning divergent garbage
# across backends. `zero_of` yields a runtime zero the compiler cannot fold.

fn zero_of(n: Int) : Int = n - n

fn main() : Int / Console = {
  let a = 10
  let b = zero_of(a)
  Stdout.print("about to divide by zero")
  let c = a / b
  Stdout.print("UNREACHABLE: div by zero did not trap")
  c
}
