# Correctness oracle for the #820 L1 evidence-obligation analysis: two
# live instances of one effect, each named by an explicit `with State as`
# alias so each op call (`a.get()` / `b.set()`) says which cell it means.
# The dump must keep the pair DISTINCT — two obligations `State@a` /
# `State@b`, each discharged by its own lexical handle — and must NOT
# fuse them into one `State`; fusing them is the wrong evidence model the
# whole lane exists to prevent. Both call sites are alias-disambiguated
# and each handler is the only live one at its op call, so this runs
# correctly today and carries a golden.
fn main() : Int / Stdout = {
  let r = handle {
    a.set(1)
    handle {
      b.set(2)
      a.get() + b.get()
    } with State[Int](0) as b {
      get(resume)    -> resume(state)
      set(v, resume) -> resume((), v)
      return(x)      -> x
    }
  } with State[Int](0) as a {
    get(resume)    -> resume(state)
    set(v, resume) -> resume((), v)
    return(x)      -> x
  }
  Stdout.print(int_to_string(r))
  r
}
