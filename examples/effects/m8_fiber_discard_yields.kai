# R4 regression coverage with `spawn.yield()` — combines `let _ =
# spawn.spawn(...)` discard with cooperative scheduling under the
# scheduler-side fiber RC discipline. Stresses the path the simpler
# `m8_fiber_discard.kai` fixture does not exercise: the discarded
# fiber suspends, hands control back, resumes, then completes — the
# trampoline tail's scheduler-ref drop and the deferred struct free
# both run in a context where another fiber later returns from
# `swapcontext` and must drain `kai_pending_free`.

import actor
import spawn

fn worker(target: Pid[String]) : Unit / Actor[String] + Spawn + Console = {
  Actor.send(target, "h")
  spawn.yield()
  Actor.send(target, "i")
}

fn run() : Unit / Actor[String] + Spawn + Console = {
  let me = Actor.self()
  # The worker installs its own Actor handler — a capability does not cross a
  # spawn — and sends to main's Pid `me`.
  let _ = spawn.spawn(() => with_mailbox { worker(me) })
  Stdout.print(Actor.receive())
  Stdout.print(Actor.receive())
}

fn main() : Int / Console + Spawn = {
  with_mailbox { run() }
  0
}
