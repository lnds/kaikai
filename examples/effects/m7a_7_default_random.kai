# Default Random handler — Doc B §`Random`. `int_range(lo, hi)` draws
# a value in `[lo, hi)` from the per-process PCG32 seeded at first
# use from `time(NULL)`. Output is non-deterministic so the fixture
# only verifies the value falls in range.

fn main() : Int / Stdout + Random {
  let n = Random.int_range(0, 100)
  if n >= 0 and n < 100 {
    Stdout.print("ok")
    0
  } else {
    Stdout.print("FAIL: out of range")
    1
  }
}
