# Issue #771 Phase 1 — negative path. `open_read` of a path that does
# not exist returns an inspectable `Err(msg)` on the `Result` register
# (never a panic, never EOF). The caller branches on the motive and
# prints it, exactly as a real consumer would before deciding to abort.

fn main() : Int / Console + File = {
  match File.open_read("/tmp/kai_file_stream_771_definitely_absent") {
    Ok(_h) -> {
      Stdout.print("UNEXPECTED OK\n")
      1
    }
    Err(e) -> {
      Stdout.print("open_read failed: #{e}\n")
      0
    }
  }
}
