# #997 control — a spawned task that never touches the enclosing `var`, and the
# parent mutating the cell from a non-spawned position. Runs fine; the escape
# check must not flag a spawn merely because a cell exists in scope.
import spawn

fn main() : Int / Spawn + Stdout = {
  var counter := 0
  nursery { n ->
    let f = n.spawn(() => { Stdout.print("worker: no cell access"); () })
    n.await(f)
  }
  counter := counter + 1
  Stdout.print("counter=#{int_to_string(counter)}")
  0
}
