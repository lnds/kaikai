# Regression: a receive deadline and a message send racing for the same wake.
#
# `Actor.receive_timeout` parks on the mailbox recv-waiter chain AND the
# reactor timer wheel. Here every deadline equals the producer's pacing, so
# timer expiry and message arrival collide constantly: the reactor drains the
# fiber off the wheel while a sender dequeues it off the chain. Each wake path
# must tolerate the other having already resumed (and even re-parked) the
# fiber — a wake delivered to a later park must not be mistaken for the
# deadline firing, or the receive returns None while still linked into the
# wheel and the next park corrupts the wheel's list structure.
#
# A None is a retry, so the total stays deterministic at KAI_THREADS=1, 4
# and 8; the failure shapes are a stranded fiber (deadlock detector or hang),
# a corrupted wheel, or a premature-timeout cascade.

import spawn
import actor
import time

fn burn(n: Int, acc: Int) : Int =
  if n <= 0 { acc } else { burn(n - 1, acc + (n % 7)) }

fn cpu_worker(rounds: Int) : Int =
  if rounds <= 0 { 0 } else { burn(40000, 0); cpu_worker(rounds - 1) }

# Independent sleepers: pure timer-wheel traffic so wheel corruption strands
# a sleeper even when every receiver got lucky.
fn sleep_n(rounds: Int, ms: Int) : Unit / Clock =
  if rounds <= 0 { () } else { sleep(millis(ms)); sleep_n(rounds - 1, ms) }

fn consume(n: Int, acc: Int) : Int / Actor[Int] + Clock =
  if n <= 0 { acc }
  else {
    match receive_timeout(millis(2)) {
      Some(v) -> consume(n - 1, acc + v)
      None    -> consume(n, acc)
    }
  }

fn consumer(sup: Pid[Int], n: Int) : Unit / Actor[Int] + Clock + Spawn = {
  let total = consume(n, 0)
  Actor.send(sup, total)
}

# Pacing equal to the deadline: the send lands right as the timer fires, which
# is what makes both wake sources race for the same park.
fn producer(to: Pid[Int], n: Int) : Unit / Actor[Int] + Clock + Spawn =
  if n <= 0 { () }
  else {
    sleep(millis(2))
    Actor.send(to, 1)
    producer(to, n - 1)
  }

fn spawn_pairs(sup: Pid[Int], p: Int, n: Int) : Unit / Spawn + Actor[Int] + Clock =
  if p <= 0 { () }
  else {
    let c = spawn_actor(() => consumer(sup, n))
    let _ = spawn_actor(() => producer(c, n))
    spawn_pairs(sup, p - 1, n)
  }

fn collect(remaining: Int, acc: Int) : Int / Actor[Int] =
  if remaining <= 0 { acc } else { collect(remaining - 1, acc + Actor.receive()) }

fn main() : Int / Spawn + Clock + Stdout = {
  let total = with_mailbox {
    let me = Actor.self()
    nursery { nur ->
      let _ = [1, 2, 3, 4] | (i => { let _ = i; nur.spawn(() => cpu_worker(4)) })
      let _ = [1, 2, 3, 4] | (i => { let _ = i; nur.spawn(() => sleep_n(30, 1)) })
      spawn_pairs(me, 6, 16)
      collect(6, 0)
    }
  }
  Stdout.print("recv timeout deadline race total: #{int_to_string(total)}")
  0
}
