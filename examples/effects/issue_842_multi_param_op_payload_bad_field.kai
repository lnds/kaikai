# Negative fixture (issue #842 — the Tier 1 escape canary). Same
# two-type-parameter effect whose ops reference both params, `save`
# raised before `find` (the order that regressed). Once the row dedup
# binds `find`'s payload `?a` to the concrete `User` from `save`'s
# label, a nonexistent field on the payload must be rejected on the
# CONCRETE type — not pass silently because the receiver stayed a free
# tyvar. `u.zzz` is the canary: it must fail with a field error on
# `User`, proving the fix resolves the receiver rather than masking the
# check.
type User = { name: String, age: Int }

effect Repo[a, i] {
  find(key: i) : Option[a]
  save(key: i, ent: a) : Unit
}

fn scenario() : Unit / Repo[User, Int] + Stdout = {
  Repo.save(1, User { name: "alice", age: 30 })
  match Repo.find(1) {
    Some(u) -> Stdout.print(u.zzz)
    None    -> Stdout.print("none")
  }
}

fn main() : Int / Stdout = { 0 }
