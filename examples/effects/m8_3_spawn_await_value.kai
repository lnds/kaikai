# m8 #3 smoke test — fiber_spawn + fiber_await round-trip a value
# through the inline-eager scheduler. The wrapper's polymorphic
# signature carries `T = Int`; the runtime executes `worker` inline
# and stores the result in a KAI_FIBER handle, which `fiber_await`
# unwraps.

import spawn

fn worker() : Int = 42

fn main() : Int / Console + Spawn {
  let fib = fiber_spawn(worker)
  let v   = fiber_await(fib)
  Stdout.print(int_to_string(v))
  0
}
