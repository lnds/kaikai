# Issue #801 — S1 early-stop. A push stream of five elements under
# `take(3)` must drive the producer exactly three times and stop: no
# further `yield` calls, constant memory. The pipeline exercises the
# canonical `|?` (filter) and `|` (map) pipes dispatching on `Stream`
# by head type, then `take` + `count`. `count == 3` proves `take`'s
# `false` from yield unwound the producer at the third element.

import stream

fn main() : Int / Stdout = {
  let n = stream.from_list([10, 20, 30, 40, 50])
    |? (x) => x > 15
    | (x) => x * 10
    |> stream.take(3)
    |> stream.count
  Stdout.print("early_stop count=#{int_to_string(n)}\n")
  0
}
