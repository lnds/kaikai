# Regression for issue #1093. Raw integer modulo by a runtime zero traps
# cleanly, like division by zero — not silent UB.

fn zero_of(n: Int) : Int = n - n

fn main() : Int / Console = {
  let a = 10
  let b = zero_of(a)
  Stdout.print("about to modulo by zero")
  let c = a % b
  Stdout.print("UNREACHABLE: mod by zero did not trap")
  c
}
