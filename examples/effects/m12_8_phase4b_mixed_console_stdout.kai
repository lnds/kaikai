# m12.8 Phase 4b: a single fn mixes the alias `Console.print` with
# the atomic `Stdout.print` and `Stderr.eprint` directly. The typer's
# alias-aware op resolution rewrites `Console.print` to `Stdout.print`
# (Console = Stdout + Stderr + Stdin), so all three call shapes
# co-exist in one row declared as `/ Console`.

fn main() : Int / Console {
  Console.print("alias-form")
  Stdout.print("atomic stdout")
  Stderr.eprint("atomic stderr")
  Console.eprint("alias-form to stderr")
  0
}
