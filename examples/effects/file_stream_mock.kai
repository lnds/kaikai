# Issue #771 Phase 1 — mock the chunked `File` ops via
# `handle ... with File`, never touching disk. The handler hands back a
# fabricated `FileHandle` and a canned chunk stream that EOFs after two
# reads, proving the new ops are interceptable (the whole point of
# putting them on the `File` effect rather than the non-interceptable
# prelude builtins).

fn drive() : String / File =
  match File.open_read("ignored-by-mock") {
    Ok(h) -> {
      let a = pull(h)
      let b = pull(h)
      let c = pull(h)
      File.close_file(h)
      string_concat(a, string_concat(b, c))
    }
    Err(e) -> string_concat("open ERR: ", e)
  }

fn pull(h: FileHandle) : String / File =
  match File.read_chunk(h, 8) {
    Ok(s)  -> s
    Err(e) -> string_concat("chunk ERR: ", e)
  }

fn main() : Int / Console = {
  # Stateless mock: open hands back fd 1, every read returns "ab". The
  # consumer pulls a fixed three times, so the result is "ababab" — the
  # point is that all three ops route to the handler, not to disk.
  let got = handle { drive() } with File {
    open_read(_p, resume)      -> resume(Ok(FileHandle { fd: 1 }))
    read_chunk(_h, _m, resume) -> resume(Ok("ab"))
    close_file(_h, resume)     -> resume(())
    return(x)                  -> x
  }
  Stdout.print("mock: #{got}\n")
  0
}
