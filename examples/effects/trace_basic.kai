# stdlib/trace.kai smoke test — exercises the Trace effect surface
# under the default handler. Two worker functions emit `log` and
# `checkpoint` events; `with_trace_default` routes each event to
# stdout with the `[trace]` prefix. `main` then prints the
# computed answer via the `print` builtin, which shares the
# `Console` row the handler already needs.
#
# Compiled with `--path ../stdlib` so the resolver finds the module;
# the fixture stays inside the bare-prelude surface that `--path`
# exposes (no `stdlib/core/*.kai` preludes required).

import trace

fn worker_a() : Int / Trace = {
  Trace.log("worker_a started")
  Trace.checkpoint("worker_a midpoint")
  Trace.log("worker_a result: 42")
  42
}

fn worker_b(x: Int) : String / Trace = {
  Trace.log("worker_b received #{int_to_string(x)}")
  Trace.checkpoint("worker_b done")
  "answer=#{int_to_string(x * 2)}"
}

fn main() : Unit / Console = with_trace_default(() => {
  let a = worker_a()
  let b = worker_b(a)
  print(b)
})
