# issue #743 — Tier 1 escape (the worse half). A *nonexistent* field
# (`b.zzz`) on the payload of a generic effect op must be REJECTED at
# compile time. Before the fix the receiver's type was an unbound tyvar
# at the field-access site, so the access fell to the UFCS fallback (or
# was stamped TyAny) and compiled silently. The deferred-field drain now
# resolves the receiver to `Box` and reports the missing field on the
# concrete type.
effect Repo[a, i] { find(key: i) : Option[a] }
type Box = { id: String }
fn get(key: String) : String / Repo[Box, String] = match Repo.find(key) {
  Some(b) -> b.zzz
  None    -> "none"
}
fn main() : Unit / Stdout = {
  let r = handle { get("x") } with Repo[Box, String] {
    find(key, resume) -> resume(Some(Box { id: "found" }))
    return(x)         -> x
  }
  Stdout.print(r)
}
