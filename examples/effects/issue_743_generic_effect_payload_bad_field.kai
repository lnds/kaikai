# issue #743 — Tier 1 escape (the worse half of the bug). A
# *nonexistent* field access (`b.zzz`) on the payload of a generic
# effect op must be REJECTED at compile time. Before the fix the
# receiver's type never reached `Box` (it stayed a free tyvar), so
# `b.zzz` was stamped TyAny and compiled silently — a safe-at-compile-
# time (Tier 1) hole. With the payload tyvar now bound to the row's
# `Box`, the typer reports the missing field on the concrete type.
effect Repo[a, i] { find(key: i) : Option[a] }
type Box = { id: String }
fn get(key: String) : String / Repo[Box, String] = match Repo.find(key) {
  Some(b) -> b.zzz
  None    -> "none"
}
fn main() : Unit / Stdout = {
  let r = handle { get("x") } with Repo[Box, String] {
    find(key, resume) -> resume(Some(Box { id: "found" }))
    return(x)         -> x
  }
  Stdout.print(r)
}
