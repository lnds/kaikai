# Positive fixture (issue #842). A parametric effect with TWO type
# parameters whose ops reference BOTH of them: `save` mentions the
# entity type `a` AND the key type `i`, `find` returns `Option[a]`.
#
# `worker`'s DECLARED row fixes the instantiation to `Repo[User, Int]`.
# Inside it, both ops raise a row label named `Repo`: `save`'s arguments
# pin it to the concrete `Repo[User, Int]`, `find`'s leave the return
# payload free, so it raises `Repo[?a, Int]`. The two share an effect
# name; the row dedup collapses them. Before the fix, with `save` raised
# first, the dedup dropped `find`'s label without recording `?a := User`,
# leaving the `Some(u)` payload an unresolved tyvar and rejecting
# `u.name` with a spurious "type annotation needed". The fix pins the
# dropped op's payload from the DECLARED row at the deferred-field drain,
# so `u : User` regardless of the order the two ops appear — `save` is
# first here, the failing order. `main` discharges the row through a
# handler that supplies the entity.
type User = { name: String, age: Int }

effect Repo[a, i] {
  find(key: i) : Option[a]
  save(key: i, ent: a) : Unit
}

fn worker() : Unit / Repo[User, Int] + Stdout = {
  Repo.save(1, User { name: "alice", age: 30 })
  match Repo.find(1) {
    Some(u) -> Stdout.print(u.name ++ " " ++ int_to_string(u.age))
    None    -> Stdout.print("none")
  }
}

fn main() : Int / Stdout = {
  handle {
    worker()
    0
  } with Repo[User, Int] {
    find(key, resume)      -> resume(Some(User { name: "alice", age: 30 }))
    save(key, ent, resume) -> resume(())
    return(x)              -> x
  }
}
