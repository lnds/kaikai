# m7a #4b smoke test (positive) — parse `handle { body } with Eff
# { clauses }` with a single op clause and a `return(x) -> body`
# clause. Type-checking and runtime are deferred to m7a #4d / #6;
# this file only exercises the parser and the AST shape.

effect Io {
  print(s: String) : Unit
}

fn main() : Int {
  let r = handle {
    Io.print("inside")
    42
  } with Io {
    print(s, resume) -> resume(())
    return(x)        -> x
  }
  r
}
