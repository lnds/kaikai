# m8.x #2 — cooperative scheduler interleaves yielding fibers.
#
# Two spawned fibers each print three marks (A0/A1/A2 and B0/B1/B2)
# with a `spawn.yield()` between each print. Under the m8.x
# cooperative scheduler (landed v0.4.0) every `yield` rotates the
# run queue: A0 prints, A yields, scheduler picks B; B0 prints, B
# yields, scheduler picks A; and so on. The expected output is the
# interleaved `A0 B0 A1 B1 A2 B2`. The diff against `.out.expected`
# is the demo gate for Phase 2 — the fixture is *only* testable
# under a real scheduler, and a synchronous `spawn` would print
# `A0 A1 A2 B0 B1 B2` instead. The rotation holds on one scheduler
# thread only — the sibling `.env` pins KAI_THREADS=1, and every
# corpus harness runs it at the pin.

import spawn

fn worker_a() : Unit / Spawn + Console {
  Stdout.print("A0")
  spawn.yield()
  Stdout.print("A1")
  spawn.yield()
  Stdout.print("A2")
}

fn worker_b() : Unit / Spawn + Console {
  Stdout.print("B0")
  spawn.yield()
  Stdout.print("B1")
  spawn.yield()
  Stdout.print("B2")
}

fn main() : Unit / Console + Spawn {
  let fa = spawn.spawn(worker_a)
  let fb = spawn.spawn(worker_b)
  spawn.await(fa)
  spawn.await(fb)
}
