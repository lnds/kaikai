# A reassigned record-typed `var` whose field is read inside a `#{...}`
# interpolation. The reassignment forces the canonical State handler (so
# `cur` is read as a cell), and the field access rides two adjacent interp
# segments where the earlier segment reads a second cell (`trace`). Two
# coupled paths must hold for `cur.id` to resolve: the op-label dedup, where
# a `State.get` payload must inherit the state type an earlier `State.set`
# pinned; and the interp span scan, where two adjacent `#{...}#{...}` regions
# must not skip the second opener.

type P = { id: Int, tag: Int }

fn main() : Int / Stdout = {
  let a = P { id: 1, tag: 9 }
  let b = P { id: 2, tag: 8 }

  var cur := a
  var trace := ""

  trace := "#{trace}#{int_to_string(cur.id)} "
  cur := b
  trace := "#{trace}#{int_to_string(cur.tag)} "

  Stdout.print("trace=#{trace}")
  0
}
