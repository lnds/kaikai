# issue #624 regression guard (variant 2): a type alias parameterised
# by two type variables but no row variable was always fine; this
# fixture keeps that path covered so a future row-substitution change
# does not accidentally break it.

pub type Pairy[a, b] = (a, b)

fn main() : Int = {
  let p : Pairy[Int, Int] = (1, 2)
  let _ = p
  print("alias_two_type_params ok")
  0
}
