# m8 #8 — Bounded(2, DropNewest) mailbox. Three messages are sent;
# the third ("c") is rejected because the mailbox is full and
# DropNewest keeps the existing contents. Receives produce "a", "b".

import actor

fn main() : Int / Console = {
  with_mailbox_policy(Bounded(2, DropNewest)) {
    Actor.send(Actor.self(), "a")
    Actor.send(Actor.self(), "b")
    Actor.send(Actor.self(), "c")
    Console.print(Actor.receive())
    Console.print(Actor.receive())
    0
  }
}
