# Issue #771 Phase 1 — chunked streaming IO, real-disk path. Opens a
# file for writing, streams two chunks, closes it; then reopens it for
# reading and pulls `read_chunk` (4 bytes at a time) until EOF (`""`),
# reassembling the contents. Exercises all five new `File` ops against
# the runtime default handler (R1 pool + fiber parking).

fn read_all(h: FileHandle, acc: String) : String / File =
  match File.read_chunk(h, 4) {
    Ok(s) ->
      if string_length(s) == 0 { acc }
      else { read_all(h, string_concat(acc, s)) }
    Err(e) -> string_concat("read_chunk ERR: ", e)
  }

fn main() : Int / Console + File = {
  let path = "/tmp/kai_file_stream_roundtrip_771.txt"
  match File.open_write(path) {
    Ok(h) -> {
      match File.write_chunk(h, "hello ") {
        Ok(_)  -> ()
        Err(e) -> Stderr.eprint("write_chunk1: #{e}")
      }
      match File.write_chunk(h, "streaming world") {
        Ok(_)  -> ()
        Err(e) -> Stderr.eprint("write_chunk2: #{e}")
      }
      File.close_file(h)
    }
    Err(e) -> Stderr.eprint("open_write: #{e}")
  }
  match File.open_read(path) {
    Ok(h) -> {
      let got = read_all(h, "")
      File.close_file(h)
      Stdout.print("#{got}\n")
    }
    Err(e) -> Stderr.eprint("open_read: #{e}")
  }
  0
}
