# m7a #6a smoke test — every `effect Eff { ops }` declaration emits
# a typed `Ev<Eff>` struct in the C output (Doc C §*Surface-to-runtime
# mapping*). No op call yet: that lowering is m7a #6c; this file only
# checks that the struct is emitted, has the right shape, and that
# the resulting C compiles.

effect Counter {
  tick() : Unit
  get() : Int
}

effect Greeter {
  hello(name: String) : Unit
  bye(name: String, count: Int) : Unit
}

fn main() : Int {
  0
}
