# Issue #80 regression — foreign caller of polymorphic prelude helpers.
#
# Loaded with `--prelude examples/effects/foreign_prelude_lib.kai`,
# so every polymorphic helper called below is "foreign" from this
# file's perspective: its scheme was built by `fn_scheme_of_decl`
# while the lib was loaded as a prelude, and the typer must re-
# fresh-instantiate the bound type and row vars at every call site.
#
# Two distinct instantiations per helper are deliberate. A second
# call site reusing a frozen tyvar from an earlier call would unify
# the second site's element type with the first (e.g. `Int = String`)
# and fail loudly. Identical-type call sites would not catch that
# regression — they would silently succeed.

fn shout(s: String) : String = string_concat(s, "!")
fn double_int(n: Int) : Int = n * 2

fn first_or_dash_int(o: Option[Int]) : String = match o {
  Some(n) -> int_to_string(n)
  None    -> "none"
}

fn first_or_dash_str(o: Option[String]) : String = match o {
  Some(s) -> s
  None    -> "none"
}

fn main() : Unit / Console = {
  # `dup_first` — implicit tparam, two distinct types + the empty list.
  let a = dup_first([1, 2, 3])
  let b = dup_first(["x", "y", "z"])
  let c: Option[Int] = dup_first([])
  Stdout.print(first_or_dash_int(a))
  Stdout.print(first_or_dash_str(b))
  Stdout.print(first_or_dash_int(c))

  # `run_each` — row-polymorphic callback, called twice with Console
  # in the row at both sites. Different element types force the
  # element-type tparam to fresh-instantiate per call.
  run_each([1, 2, 3], (n) => Stdout.print(int_to_string(n)))
  run_each(["a", "b"], (s) => Stdout.print(s))

  # `with_reader` + `ask_then` — parametric Reader[T] effect. Two
  # distinct Ts (Int, String); the bound row var must fresh-instantiate
  # at every site or the inner Reader.ask() leaks the wrong type.
  let r1 = with_reader(21) { ask_then(double_int) }
  let r2 = with_reader("hi") { ask_then(shout) }
  Stdout.print(int_to_string(r1))
  Stdout.print(r2)
}
