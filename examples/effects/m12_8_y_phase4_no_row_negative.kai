# m12.8.x phase 4 (Bug 6): a helper fn that performs IO via the
# prelude (`print`, `eprint`, `read_line`, `read_file`,
# `write_file`) but does NOT declare the matching effect in its
# row is rejected by the typer with a clean diagnostic naming the
# fn and the missing effect. CLAUDE.md Tier 1 #1 ("every effect a
# function uses appears in its row") is enforced.

fn pure_fn(x: Int) : Int = {
  print("side effect!")
  x + 1
}

fn main() : Int = pure_fn(0)
