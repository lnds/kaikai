# m7a #7 — default Stdin handler. `read_line()` returns an
# `Option[String]`: Some(line) on a successful read (with the
# trailing '\n' stripped), None on EOF. Doc B §`Stdin`. The /Fail
# row entry that Doc B's signature includes is m7a's open
# simplification — read errors panic the same way Console does
# until row-typed ops land.

fn main() : Int / Console + Stdin {
  match Stdin.read_line() {
    Some(line) -> Stdout.print("got: #{line}")
    None       -> Stdout.print("eof")
  }
  0
}
