# m8 #4 — `Cancel.raise()` with the runtime's default handler. The
# default writes a banner to stderr and exits with code 0 (Doc B
# §`Cancel`/Default handler). Exit code is 0 (not 1 like Fail)
# because cancellation is an expected termination path, not a
# programmer error.

fn main() : Int / Console + Cancel {
  Console.print("before raise")
  Cancel.raise()
  Console.print("never reached")
  0
}
