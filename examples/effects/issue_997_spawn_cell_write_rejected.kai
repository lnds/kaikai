# #997 — the write variant. A spawned fiber that WRITES the enclosing `var`
# crashes identically to the read case: the cell's `State` handler is on the
# parent fiber and does not cross the `spawn`. Rejected at compile time by the
# same escape check.
import spawn

fn main() : Int / Spawn = {
  var counter := 0
  nursery { n ->
    let f = n.spawn(() => { counter := counter + 1; () })
    ()
  }
  0
}
