# issue #251 — reading from an `Array[T]` parameter does NOT raise
# the `Mutable` demand. `array_get` is pure from the caller's POV
# regardless of the array's provenance. `sum_array` compiles
# cleanly without `/ Mutable` and runs end-to-end.

fn sum_array(a: Array[Int]) : Int {
  sum_loop(a, 0, 0)
}

fn sum_loop(a: Array[Int], i: Int, acc: Int) : Int {
  if i >= array_length(a) { acc }
  else { sum_loop(a, i + 1, acc + a[i]) }
}

fn main() : Unit / Mutable + Console = {
  let a = array_make(3, 0)
  a[0] := 10
  a[1] := 20
  a[2] := 30
  print(int_to_string(sum_array(a)))
}
