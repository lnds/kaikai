# Evidence forwarded two call levels deep: `deep` performs the op, `mid`
# only forwards, `main` handles. Under capability passing the handle's
# evidence must reach `deep` through both forward hops. Two sequential
# handles over the same `mid` must each thread their own evidence — the
# call-site supplier (the handle in main) is what fills the slot, not the
# callee's own classification (which is forwarded-caller-param at every
# hop). 7 + 9 = 16.
effect Tok { ask() : Int }

fn deep() : Int / Tok =
  Tok.ask()

fn mid() : Int / Tok =
  deep()

fn main() : Int / Stdout = {
  let a = handle {
    mid()
  } with Tok {
    ask(resume) -> resume(7)
  }
  let b = handle {
    mid()
  } with Tok {
    ask(resume) -> resume(9)
  }
  Stdout.print(int_to_string(a + b))
  0
}
