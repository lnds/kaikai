# issue #501 — same shape as the Int case but the discarded value
# is a String. Catches a regression where the volatile qualifier
# would be dropped or the cast would be wrong for a non-integer
# clause result.

effect Fail {
  fail() : Nothing
}

fn main() : Unit / Stdout {
  let r : String = handle {
    Fail.fail()
  } with Fail {
    fail(resume) -> "oops"
  }
  print("r=" ++ r)
}
