# m7a #2 functional test (positive) — passing a function whose
# row matches the parameter's expected row should compile.
#
# `use_io` expects a `(Int) -> Int / Io`. `double` has exactly that
# row, so unify_row({Io}, {Io}) must succeed and the call type-checks.

effect Io {
  print(s: String) : Unit
}

fn double(x: Int) : Int / Io { x + x }

fn use_io(f: (Int) -> Int / Io) : Int { 42 }

fn main() : Int { use_io(double) }
