# Issue #533: a `default { clauses }` block may omit the `return`
# clause, mirroring `handle ... with` (the typer synthesises identity
# per docs/decisions/handler-return-clause-optional-2026-05-12.md).
# Parser smoke only — same scope as default_block_parses.kai.

effect Beep {
  beep() : Unit
  default {
    beep(resume) -> resume(())
  }
}

fn main() : Int {
  let r = handle {
    Beep.beep()
    11
  } with Beep {
    beep(resume) -> resume(())
  }
  r
}
