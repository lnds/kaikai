# m7d §27 — multi-arg match sugar. The two scrutinees are matched
# column-by-column without an intermediate tuple/Pair. Bodies bind
# the column patterns just like a single-scrutinee match.

fn count_toques(guess: [Int], target: [Int]) : Int = match guess, target {
  [], _                  -> 0
  _, []                  -> 0
  [g, ...gs], [t, ...ts] -> {
    let here = if g == t { 1 } else { 0 }
    here + count_toques(gs, ts)
  }
}

fn main() = {
  let n = count_toques([1, 2, 3, 4], [1, 0, 3, 5])
  Stdout.print("toques=#{int_to_string(n)}")
  0
}
