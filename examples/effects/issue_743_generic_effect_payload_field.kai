# issue #743 — a field access on the payload of a *generic* effect op
# must type-check against the row's concrete ty_args. Root cause was a
# timing problem in the field-access path, NOT effect propagation: when
# `synth_field` met `b.id` the receiver `b` was still an unbound tyvar
# (the op scheme `Repo.find : ∀a,i. i -> Option[a]` instantiates `?a`
# fresh-and-free; `?a` is only pinned to `Box` later by `check_body_row`
# against the declared row). The eager UFCS fallback then misfired
# because a `id` binding/function was in scope. The fix defers the
# field-vs-UFCS decision until the receiver resolves.
#
# Triple condition from the issue (generic effect + field `id` +
# same-named `id` binding in scope): type-checks and runs.
effect Repo[a, i] { find(id: i) : Option[a] }
type Box = { id: String }
fn get(id: String) : String / Repo[Box, String] = match Repo.find(id) {
  Some(b) -> b.id
  None    -> "none"
}
fn main() : Unit / Stdout = {
  let r = handle { get("x") } with Repo[Box, String] {
    find(id, resume) -> resume(Some(Box { id: "found" }))
    return(x)        -> x
  }
  Stdout.print(r)
}
