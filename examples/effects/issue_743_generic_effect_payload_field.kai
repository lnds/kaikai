# issue #743 — a field access on the payload of a *generic* effect op
# must type-check against the row's concrete ty_args. The op scheme
# `Repo.find : ∀a,i. i -> Option[a]` is instantiated fresh-and-free;
# the typer must bind the fresh payload tyvar `?a` to the enclosing
# signature's declared row arg (`Repo[Box, String]` → `?a = Box`) so
# `b.id` resolves against `Box` rather than escaping the type check.
#
# Triple condition from the issue: generic effect + field name `id` +
# a same-named binding (`id`) in scope. Before the fix this was
# rejected with a bogus UFCS diagnostic; now it type-checks and runs.
effect Repo[a, i] { find(id: i) : Option[a] }
type Box = { id: String }
fn get(id: String) : String / Repo[Box, String] = match Repo.find(id) {
  Some(b) -> b.id
  None    -> "none"
}
fn main() : Unit / Stdout = {
  let r = handle { get("x") } with Repo[Box, String] {
    find(id, resume) -> resume(Some(Box { id: "found" }))
    return(x)        -> x
  }
  Stdout.print(r)
}
