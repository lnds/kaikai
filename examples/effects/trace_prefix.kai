# Smoke test for `with_log_prefix` — exercises handler composition
# with delegate-to-outer semantics. The inner handler installed by
# `with_log_prefix` consumes `Trace`, prepends `prefix ++ ": "`, and
# re-emits via `Trace.log`. That re-emit resolves to the outer
# `with_trace_default` handler thanks to the `KaiEvidence.in_dispatch`
# flag (m8 #12). `Trace.checkpoint` is folded into a `log` call so
# the outer's `[trace] checkpoint: ` framing does not stack on top
# of the prefix.
#
# Wire-up: invoked with `--path ../stdlib`, so `import trace`
# resolves to `stdlib/trace.kai`.

import trace

fn worker() : Unit / Trace = {
  Trace.log("started")
  Trace.checkpoint("midpoint")
  Trace.log("done")
}

fn main() : Unit / Stdout = with_trace_default() {
  Trace.log("outside prefix")
  with_log_prefix("worker-1", worker)
  Trace.log("after prefix")
}
