# Issue #801 — S2 per-element resume (skip policy), the flagship of the
# design: clean `String` elements, per-fault recovery decided by the
# consumer's handler. The mocked `read_chunk` faults on its second pull;
# the `ReadFault` handler RESUMES `bad_chunk`, so the producer drops the
# failed chunk and keeps going. The bad chunk is skipped, not aborted,
# and the surviving lines (a, b, c) are counted — `count == 3`. Delete
# the `resume(())` and the same pipeline aborts instead: the policy is a
# handler choice, zero changes to the stages. No referent expresses this
# without contaminating the element type.

import stream

fn count_lines(path: String) : Int / File + ReadFault =
  stream.read_lines(path) |> stream.count

fn main() : Int / Stdout = {
  let st = array_make(1, 0)
  let n = handle {
    handle { count_lines("x") }
    with ReadFault {
      bad_chunk(_m, resume)  -> resume(())   # resume = drop the bad chunk, continue
      open_fault(_m, resume) -> resume(())
    }
  } with File {
    open_read(_p, resume)        -> resume(Ok(FileHandle { fd: 1 }))
    read_chunk(_h, _max, resume) -> {
      let i = st[0]
      st[0] := i + 1
      if i == 0 { resume(Ok("a\nb\n")) }
      else { if i == 1 { resume(Err("transient read error")) }
             else { if i == 2 { resume(Ok("c\n")) }
                    else { resume(Ok("")) } } }
    }
    close_file(_h, resume)       -> resume(())
    open_write(_p, resume)       -> resume(Err("no write"))
    write_chunk(_h, _d, resume)  -> resume(Err("no write"))
    return(x)                    -> x
  }
  Stdout.print("skip count=#{int_to_string(n)}\n")
  0
}
