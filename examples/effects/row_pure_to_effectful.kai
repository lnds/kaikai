# m7a #2 functional test (negative) — Doc A "no subsumption":
# a pure function (empty row) cannot be passed where an
# effect-bearing function is expected, even though "pure ⊆ {Io}"
# would seem benign.
#
# `pure_double` has empty row; `use_io` expects {Io}. unify_row
# partitions into only_right={Io} with both tails None; the
# both-rigid case fails because only_right is non-empty.

effect Io { print(s: String) : Unit }

fn pure_double(x: Int) : Int { x + x }

fn use_io(f: (Int) -> Int / Io) : Int { 42 }

fn main() : Int { use_io(pure_double) }
