# m12.8.x phase 4 (Bug 6): a helper fn that calls the prelude
# `print` builtin must declare the matching effect (Console here)
# in its row. The typer's `add_prelude_effect_label` shim adds the
# label on every direct prelude IO call, so `check_body_row`
# rejects any helper that calls `print`/`eprint`/`read_line`/etc.
# without an appropriate row. This fixture is the positive case.

fn say_hello() : Unit / Console = print("hello explicit")

fn main() : Unit / Console {
  say_hello()
  ()
}
