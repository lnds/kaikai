# m8 #5 — `nursery { n -> ... }` scopes a structured-concurrency
# block with a cap binder `n` for the spawn ops. Two child fibers
# are spawned, each computes a value, and the block's value is the
# sum of their results. Under the m8.x cooperative scheduler each
# `n.spawn(task)` allocates a fiber with a private mmap'd stack and
# enqueues it READY; the dispatcher swaps in via `setcontext`. The
# `n.await(f)` calls park the caller on the target's awaiter chain
# until the child completes.
#
# Migrated from the bare-form `nursery { spawn.await(spawn.spawn(...)) }`
# in this lane (issue #71 option (b) prerequisite, m7b #4): the
# cap-binding pre-typecheck pass strips `n` from the lambda
# parameter list and rewrites every `n.<spawn|await|...>` to the
# corresponding `Spawn.<op>` so the runtime entry points are the
# same the bare form used to reach via `spawn.spawn` /
# `spawn.await`.

import spawn

fn task1() : Int = 11
fn task2() : Int = 22

fn main() : Int / Console + Spawn {
  let total = nursery { n ->
    n.await(n.spawn(task1)) + n.await(n.spawn(task2))
  }
  Stdout.print(int_to_string(total))
  0
}
