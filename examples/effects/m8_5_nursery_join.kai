# m8 #5 — `nursery { ... }` scopes a structured-concurrency block.
# Two child fibers are spawned, each computes a value, and the
# block's value is the sum of their results. Under the v1 inline-
# eager scheduler the children run synchronously, so the joins
# (`fiber_await`) return immediately; the nursery's pass-through
# semantics still match what the m8.x cooperative scheduler will do
# — body returns once every spawned thunk has finished.

import spawn

fn task1() : Int = 11
fn task2() : Int = 22

fn main() : Int / Console + Spawn {
  let total = nursery {
    fiber_await(fiber_spawn(task1)) + fiber_await(fiber_spawn(task2))
  }
  Console.print(int_to_string(total))
  0
}
