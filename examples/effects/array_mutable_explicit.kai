# issue #251 — writing to an `Array[T]` parameter, with `Mutable`
# correctly declared. Compiles cleanly and runs end-to-end.

fn set_first(a: Array[Int], v: Int) : Unit / Mutable {
  a[0] := v
}

fn main() : Unit / Mutable + Console = {
  let a = array_make(3, 0)
  set_first(a, 42)
  print(int_to_string(a[0]))
}
