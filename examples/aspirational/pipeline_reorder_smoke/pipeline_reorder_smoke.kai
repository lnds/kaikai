# pipeline_reorder_smoke — pipeline order `perceus → tcrec` smoke
# fixture (Eric review 2026-05-06).
#
# After this lane, tcrec runs AFTER perceus_pass, so the body it
# rewrites may already be wrapped in
# `EBlock([entry_drops, SLet(__pcs_ret, INNER), exit_drops],
# Some(EVar(__pcs_ret)))` (`pcs_wrap_with_exit`). Tcrec descends
# into the wrap and rewrites only the inner body; the wrap stays
# intact so its exit drops still fire on the non-tail path, and
# the goto fires on the tail path before reaching them.
#
# This fixture exercises the new contract end-to-end:
# - `walk` is multi-arg + multi-use (params `xs` and `acc` are
#   read more than once, triggering perceus's exit-drop wrap).
# - The recursive call sits in `match`-tail position, so tcrec
#   plants a sentinel and the emitter rewrites it as a goto.
# - The 1M-iter run must terminate cleanly (TCO preserved) and
#   under `KAI_TRACE_RC=1` the int-tag live count must stay O(1)
#   (no per-iter leaks introduced by the reorder).
#
# Pre-reorder, the goto bypassed the wrap's exit drops and tcrec
# emulated `pcs_collect_exit_drops` byte-for-byte to keep the
# same RC discipline; the two passes were implicitly coupled and
# any change to one had to be mirrored in the other (issue #92
# R6 four-time failure mode). Post-reorder, perceus puts the
# drops in the AST as data and tcrec preserves them — the
# coordination is structural, not lockstep.

fn walk(xs: [Int], acc: Int) : Int = match xs {
  [] -> acc
  [_, ...rest] -> walk(rest, acc + 1)
}

fn build(n: Int, acc: [Int]) : [Int] = match n {
  0 -> acc
  _ -> build(n - 1, [n, ...acc])
}

fn main() {
  let xs = build(1000, [])
  print(int_to_string(walk(xs, 0)))
}
