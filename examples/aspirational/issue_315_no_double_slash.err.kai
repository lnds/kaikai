# Issue #315 — the `//` integer-division operator is removed.
# Post-#246 (operator overloading via protocols), `Int / Int`
# already truncates via the `Div[Int]` primitive impl, so `//`
# was redundant. Source still using `//` must be rejected at
# lex time with a migration error pointing at `/`.

fn main() : Unit / Stdout = {
  let q = 20 // 6
  print(int_to_string(q))
}
