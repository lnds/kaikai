# Issue #644 — prelude integrity sanity. The `Response.Ok` user
# variant must NOT clobber prelude `Result.Ok` resolution. This
# fixture exercises a `Result[String, Int]` path that the prelude
# itself uses (e.g. `Serialize.from_string`) to prove the bare-name
# `Ok` keeps resolving to `Result.Ok` when the surrounding
# annotation forces it.

pub type Response = Ok(String) | NotFound

fn parse_int_safe(s: String) : Result[String, Int] = match string_to_int(s) {
  Some(n) -> Ok(n)
  None    -> Err("not a number: " ++ s)
}

fn show_parsed(r: Result[String, Int]) : String = match r {
  Ok(n)  -> "parsed " ++ int_to_string(n)
  Err(e) -> "err " ++ e
}

fn show_resp(r: Response) : String = match r {
  Ok(s)    -> "resp ok " ++ s
  NotFound -> "resp 404"
}

fn make_resp_ok(s: String) : Response = Ok(s)

fn main() : Unit / Stdout = {
  println(show_parsed(parse_int_safe("42")))
  println(show_parsed(parse_int_safe("not-a-num")))
  println(show_resp(make_resp_ok("payload")))
}
