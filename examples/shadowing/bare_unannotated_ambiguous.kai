# Issue #644 — bare unannotated ctor ambiguity diagnostic. With both
# `Result.Ok` (prelude) and `Response.Ok` (user) in scope, a bare
# `let x = Ok("x")` would silently resolve to the prelude `Result.Ok`
# pre-fix. The diagnostic now lists both candidates and asks the
# user to disambiguate via annotation or qualified syntax.
#
# Negative fixture — must produce a non-zero exit AND emit the
# `ambiguous constructor 'Ok'` diagnostic line on stderr.

pub type Response = Ok(String) | NotFound

fn main() : Unit / Stdout = {
  let _x = Ok("hello")
  println("unreachable")
}
