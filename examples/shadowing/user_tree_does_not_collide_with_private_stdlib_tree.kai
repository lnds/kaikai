# Issue #643 — `stdlib/collections/map.kai` declares a non-`pub`
# `type Tree[k, v] = TEmpty | TNode(...)`. Before the fix, the
# typer's variant table walked both definitions when the user
# declared `type Tree = Leaf | Node(...)`, and the
# match-exhaustiveness check reported the prelude's variants as
# "covered" and the user's as "missing".
#
# This is the canonical book chapter 5 (recursive sum types)
# example — was blocked by the leak until the resolver started
# discriminating variants by their return tycon arity.

type Tree
  = Leaf
  | Node(Int, Tree, Tree)

fn max_int(a: Int, b: Int) : Int = if a > b { a } else { b }

fn height(t: Tree) : Int = match t {
  Leaf            -> 0
  Node(_, l, r)   -> 1 + max_int(height(l), height(r))
}

fn main() : Unit / Stdout = {
  let t = Node(1, Node(2, Leaf, Leaf), Leaf)
  println("height: #{height(t)}")
}
