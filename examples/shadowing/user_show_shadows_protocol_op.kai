# Issue #466 (closed as a side effect of #748) — a user `fn show(stack:
# [Int])` shadows the stdlib `impl Show[List[T]] { fn show(xs: [T]) }`.
# Before the fix this panicked at runtime with "non-exhaustive match":
# the user's call `show([-3])` was routed to the protocol Show dispatch
# (which has different match arms), and the recursive `show(rest)` inside
# the user's body resolved to the wrong target. #466 documents this as
# the same class as #748 — a name collision between a user fn and a
# stdlib export, where the shadow must win.
#
# Both halves of the #748 fix are exercised here: the typer-side root
# shadow precedence (`show([-3])` calls the USER's fn, not the protocol
# dispatch) and the codegen-side module-body prune (the user's recursive
# `show(rest)` resolves to the user's own `kai_show`). The user shadow
# wins on both backends.

fn show(stack: [Int]) : String = match stack {
  []           -> ""
  [a]          -> int_to_string(a)
  [a, ...rest] -> int_to_string(a) ++ " " ++ show(rest)
}

fn main() : Unit / Stdout = {
  println(show([-3]))
  println(show([1, 2, 3]))
  println("len=#{int_to_string(0)} -> [#{show([])}]")
}
