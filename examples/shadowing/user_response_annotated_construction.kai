# Issue #644 — annotation-driven ctor disambiguation. The `let r:
# Response = Ok("x")` binding picks `Response.Ok` because the
# annotation context narrows the bare `Ok` callee to the user
# variant. Same path covers `let r: Response = NotFound`.

pub type Response = Ok(String) | NotFound | ServerError(String)

fn render(r: Response) : String = match r {
  Ok(s)          -> "ok " ++ s
  NotFound       -> "404"
  ServerError(s) -> "500 " ++ s
}

fn main() : Unit / Stdout = {
  let r1 : Response = Ok("first")
  let r2 : Response = NotFound
  let r3 : Response = ServerError("boom")
  println(render(r1))
  println(render(r2))
  println(render(r3))
}
