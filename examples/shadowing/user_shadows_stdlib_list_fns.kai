# Issue #748 — a user `fn sum(x, y)` collides with the stdlib
# `list.sum(xs)` export. Before the fix, BOTH lowered to the bare C
# symbol `kai_sum`, and the stdlib `list.sum` body's internal recursive
# call `sum(t)` resolved to the USER's 2-arg `sum`, emitting invalid C
# ("too few arguments, expected 2, have 1"). On the LLVM backend the
# same mis-resolution produced a `call @kai_sum(1 arg)` against a 2-arg
# definition — silent ABI-level UB (same class as #466).
#
# The fix prunes the root-file shadow from a module body's resolution
# table (`fns_prefer_module`), so the stdlib self-call mangles to
# `kai_list__sum` while the user's stays `kai_sum`. The user's shadow
# WINS in user code — `sum(10, 20)` calls the user's 2-arg fn — and the
# stdlib `list.sum` stays internally consistent. This is valid and
# desired: to reach the stdlib one the user writes `list.sum(...)` (see
# user_shadows_and_qualified_coexist.kai).
#
# Exercises several stdlib `pub fn` names a user is likely to shadow:
# sum, reverse, length, product, concat. Each user redefinition wins.
#
# `length` is the load-bearing case: the user's `fn length(s: String)`
# has the SAME signature as the stdlib `string.length(s: String)`
# export. The shadow must still win — a bare `length("...")` in user
# code calls the USER's fn (-> 42), never `string.length`. This needs
# both the C-symbol prune (#748) AND type-directed resolution to prefer
# the root-file decl over a same-signature stdlib export of the same
# name. The user shadow wins regardless of whether the signatures
# collide.

fn sum(x: Int, y: Int) : Int { x + y }
fn reverse(x: Int) : Int { 0 - x }
fn length(s: String) : Int { 42 }
fn product(a: Int, b: Int) : Int { a * b }
fn concat(a: Int, b: Int) : Int { a * 100 + b }

fn main() : Unit / Stdout = {
  println("sum (10, 20) = #{int_to_string(sum(10, 20))}")
  println("reverse 7 = #{int_to_string(reverse(7))}")
  println("length any = #{int_to_string(length("ignored"))}")
  println("product 6 7 = #{int_to_string(product(6, 7))}")
  println("concat 3 4 = #{int_to_string(concat(3, 4))}")
}
