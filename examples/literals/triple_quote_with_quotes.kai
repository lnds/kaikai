# Triple-quote with embedded `"` and `""` plus a tab. The lexer admits
# any number of `"` short of three; the C escape pass must turn each
# unescaped `"` into `\"`. The literal tab byte must escape to `\t`.
# Closes the second half of issue #311.

fn main() : Unit / Console {
  let m = """one "quoted" word and two ""quotes"" here"""
  print(m)
  let t = """col1	col2"""
  print(t)
}
