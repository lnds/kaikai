# Hex integer literals: round-trip selected values to known decimals.
# Closes #156.

fn report(label: String, got: Int, want: Int) : Unit / Console {
  if got == want {
    print("ok #{label}")
  } else {
    print("FAIL #{label} got=#{got} want=#{want}")
  }
}

fn main() : Unit / Console {
  report("zero",      0x0,                255 - 255)
  report("byte",      0xFF,               255)
  report("mixed",     0xCAFE,             51966)
  report("u32_max",   0xFFFFFFFF,         4294967295)
  report("i64_max",   0x7FFFFFFFFFFFFFFF, 9223372036854775807)
  report("upper_x",   0X10,               16)
  report("lower_hex", 0xabcdef,           11259375)
  report("upper_hex", 0xABCDEF,           11259375)
  report("neg_byte",  0 - 0xFF,           0 - 255)
}
