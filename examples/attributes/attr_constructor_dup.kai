# Negative fixture: two `#[constructor]` fns returning the same type.
# A type has at most one — arity/type overloading is out (Tier 1 #3).

pub type Meters = { v: Int }

#[constructor]
pub fn from_int(n: Int) : Meters = Meters { v: n }

#[constructor]
pub fn from_pair(a: Int, b: Int) : Meters = Meters { v: a + b }

fn main() : Unit / Console = print("never reached")
