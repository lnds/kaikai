# Issue #608: positive fixture — `#[unstable]` annotation on a `pub fn`.
# The annotation parses cleanly and the wrapped declaration behaves
# exactly as before #608 (DUnstable AST shape unchanged).

#[unstable]
pub fn answer() : Int = 42

fn main() : Unit / Console = {
  let a = answer()
  print(int_to_string(a))
}
