# Negative fixture: `Rational(5)` desugars to `rational.make(5)`, but
# `make` takes two args (num, den). Single-arg integer-to-rational is
# `rational.from_int(5)`, a named fn — the sugar does not overload arity.

import rational

fn main() : Unit / Console = {
  let r = Rational(5)
  print(rational.to_string(r))
}
