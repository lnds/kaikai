# Issue #608: positive fixture — `#[derive(Show, Eq)]` on a record.
# Verifies the migrated annotation syntax is functionally identical to
# the pre-#608 `#derive(Show, Eq)` form.

#[derive(Show, Eq)]
pub type Point = { x: Int, y: Int }

fn main() : Unit / Console = {
  let a = Point { x: 1, y: 2 }
  let b = Point { x: 1, y: 2 }
  let c = Point { x: 3, y: 4 }
  print(show(a))
  print(if eq(a, b) { "eq" } else { "neq" })
  print(if eq(a, c) { "eq" } else { "neq" })
}
