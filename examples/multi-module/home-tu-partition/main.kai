# home_tu partition fixture — one program covering every decl-to-TU case:
#   - a root pub fn      -> homes to <basename>.c  (main.c)
#   - a root private fn  -> homes to root TU        (__root__.c)
#   - fn main            -> homes to root TU        (__root__.c)
#   - a lambda           -> homes to root TU        (__root__.c)
#   - an imported pub fn  -> homes to its module TU  (widget.c)
#   - a cross-module spec -> homes to defining module (widget.c)
# The c-modular partition places each symbol in the TU home_tu names.

import lib.widget

#[doc("Root pub fn — mangles to kai_main__badge, homes to main.c.")]
pub fn badge() : Int = 41

# Root private fn — bare kai_helper symbol, homes to __root__.c.
fn helper(x: Int) : Int = x + 1

fn main() : Unit / Stdout = {
  let bump = (n) => n + helper(0)
  let total = badge() + widget.label() + bump(1) + list.sum(widget.wrap(10))
  println("total = #{int_to_string(total)}")
}
