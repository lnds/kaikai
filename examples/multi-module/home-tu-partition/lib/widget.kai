# Imported module: its pub fn homes to widget.c, and its generic wrap
# homes its cross-module spec to widget.c too (home_tu of a spec is the
# defining generic's module, not the call site).

#[doc("A module pub fn — homes to widget.c.")]
pub fn label() : Int = 7

#[doc("A cross-module generic — its spec homes to the defining module widget.c.")]
pub fn wrap[T](x: T) : [T] = [x]
