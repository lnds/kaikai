import spawn

# Cross-module fiber axis: opens its OWN nursery and drives a spawn/await
# round-trip. When `main` spawns a fiber whose body calls this, the spawn/await
# ops run in worker's object while main's fiber is parked on the SAME shared
# scheduler (the L1 runtime owner). Disjoint per-object schedulers would diverge
# here; one ready queue + one active-fiber pointer must span both objects.
pub fn doubled(n: Int) : Int / Spawn =
  nursery {
    spawn.await(spawn.spawn(() => n * 2))
  }
