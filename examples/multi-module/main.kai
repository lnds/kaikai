# issue #233 — sibling-module + nested-directory auto-discovery via
# `kai run`. The driver passes `--path "$(dirname "$src")"` so the
# resolver finds `math.kai` next to `main.kai` and `geo/shapes.kai`
# under the entry directory.

import math
import geo.shapes

fn main() {
  print(int_to_string(math.square(7)))
  print(int_to_string(shapes.area_square(5)))
}
