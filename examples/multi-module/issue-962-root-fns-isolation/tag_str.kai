# issue #962 Lane 1 — root_fns isolation fixture (1 of 3 modules).
#
# A `pub fn tag` whose first parameter is the concrete type `String`.
# Paired with `tag_int.tag` (first param `Int`), it gives the bare
# `tag(...)` call inside `lib.driver` two candidates that
# receiver-type narrowing must disambiguate by first-arg type.

#[doc("Tag a String — the concrete-first-arg candidate for narrowing.")]
pub fn tag(s: String) : String = "STR:" ++ s
