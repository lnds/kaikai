# issue #962 Lane 1 — root_fns isolation fixture (2 of 3 modules).
#
# The sibling `pub fn tag` over `Int`. Same bare name as
# `tag_str.tag` and as the user's root `fn tag`, so the imported
# `lib` module's bare call has a genuine 2-candidate narrowing
# decision to make.

#[doc("Tag an Int — the other narrowing candidate for the bare `tag`.")]
pub fn tag(n: Int) : String = "INT"
