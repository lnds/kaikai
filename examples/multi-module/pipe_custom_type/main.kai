# Issue #594 consumer side. The `mybox` module declares `pub type
# MyBox[t]` and exports `map / flat_map / filter` with the canonical
# signatures; the head-owner cache built once per compile resolves
# `mb | f` to `mybox.map(mb, f)` without any compiler-side dispatch
# entry being added.

import mybox

fn main() : Unit / Console {
  let b = MkBox(7) | (n) => n + 1
  print(int_to_string(mybox.unwrap(b)))
  let c = MkBox(3) || (n) => MkBox(n * 10)
  print(int_to_string(mybox.unwrap(c)))
}
