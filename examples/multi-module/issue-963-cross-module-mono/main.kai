# Root imports the two instantiating modules but never `boxer` directly:
# each shared spec (boxer.box[Int], boxer.pick[Real]) is reached only across
# module boundaries, exactly the cross-module case the home-TU rule governs.
import feature_b
import feature_c

fn main() : Unit / Stdout = {
  println("b = #{int_to_string(feature_b.amount_b())}")
  println("c = #{int_to_string(feature_c.amount_c())}")
  println("near = #{int_to_string(feature_b.near_b())}#{int_to_string(feature_c.near_c())}")
}
