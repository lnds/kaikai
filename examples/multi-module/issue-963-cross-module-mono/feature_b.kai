# First instantiating module: reaches boxer's generics at Int and Real.
import boxer

#[doc("Instantiate boxer.box at Int from module b (boxed-list spec).")]
pub fn amount_b() : Int = list.sum(boxer.box(7))

#[doc("Instantiate boxer.pick at Real from module b (unboxed double spec).")]
pub fn near_b() : Int = if boxer.pick(2.5, 1.5) > 2.0 { 1 } else { 0 }
