# Second instantiating module: reaches boxer's generics at the SAME types as
# feature_b, so each (generic, type) shares one deduped spec across modules.
import boxer

#[doc("Instantiate boxer.box at Int from module c — same type as b.")]
pub fn amount_c() : Int = list.sum(boxer.box(35))

#[doc("Instantiate boxer.pick at Real from module c — same type as b.")]
pub fn near_c() : Int = if boxer.pick(0.5, 9.0) > 2.0 { 1 } else { 0 }
