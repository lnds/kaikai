# Issue #748 separate-compilation edge case: stdlib higher-order
# functions whose bodies create lambda closures. Under `--emit=c-modular`
# all lambdas are emitted into the ROOT translation unit (LamInfo carries
# no module origin), but a stdlib module body (`list.c`, `protocols.c`,
# ...) REFERENCES those lambda symbols via `kai_closure(&_kai_lam_N, ...)`
# — a cross-translation-unit reference. This links only because the
# `static`-strip externalises every emitted top-level symbol (including
# `_kai_lam_N` definitions AND their forward declarations in the shared
# `kai_decls.h`), so the module TU's reference resolves to the root TU's
# external definition at link time. Without the strip, the lambda would
# keep internal linkage and the link would fail.
#
# This fixture exercises that path: list.map / list.filter create
# closures inside `list`'s module body, used from a multi-module program.
# The single-TU golden and the modular build must produce the same
# output.

import math

fn main() : Unit / Stdout = {
  let xs = [1, 2, 3, 4, 5]
  let squared = map(xs, (x: Int) => math.square(x))
  let evens = filter(xs, (x: Int) => x % 2 == 0)
  println("squared_sum = #{int_to_string(list.sum(squared))}")
  println("evens_sum = #{int_to_string(list.sum(evens))}")
}
