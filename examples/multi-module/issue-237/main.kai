# issue #237 — multi-module project that exercises the qualified-call
# chain into stdlib extensions whose exports use a legacy short prefix:
#   - `regexp.compile` + `regexp.find_all` resolve via the `regex_*`
#     prefix override registered in `module_legacy_prefix`.
#   - `decimal.from_int` resolves via the `dec_*` override.
# Both overrides were added alongside the existing `char` -> `ch_*`
# mapping. Without them the rqc EField -> EModCall rewrite would emit
# a "module 'regexp' does not export 'compile'" diagnostic and the
# typer would then reject `regexp` as undefined.

import util

fn main() {
  let n = util.double(7)
  match regexp.compile("[a-z]+") {
    Ok(re) -> {
      let ms = regexp.find_all(re, "ab cd ef")
      print(int_to_string(n))
      print(int_to_string(list.length(ms)))
    }
    Err(_) -> print("compile err")
  }
  let _ = decimal.from_int(42)
  print("decimal ok")
}
