# Cross-module unit export: `pub unit` makes the symbol importable
# from any module that resolves this file via `import lib`. The
# unit-hygiene validator in `compile_source` walks the post-import
# decl stream, so `pub unit K` declared here is visible to a `Real<K>`
# annotation written in `main.kai`.

pub unit K

pub fn warmer(t: Real<K>) : Real<K> = t
