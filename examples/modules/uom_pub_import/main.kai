# Positive cross-module unit-import fixture: `lib` exports a
# `pub unit K`; here in `main` we annotate a fn parameter with
# `Real<K>` and call `lib.warmer` to round-trip the value. Both
# the type annotation and the literal `15.0<K>` must resolve
# against `lib`'s declaration.

import lib

fn round_trip(t: Real<K>) : Real<K> = lib.warmer(t)

fn main() : Unit / Stdout {
  let _ = round_trip(15.0<K>)
  Stdout.print("ok")
}
