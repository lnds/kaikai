# issue #502: a user-declared variant `Ok(String)` would otherwise
# overwrite the bare `Ok` constructor of the built-in `Result` in the
# typer's env, breaking every prelude site that constructs
# `Result.Ok(...)` and producing cascading errors with line numbers
# pointing at prelude code instead of the user file. The compiler
# rejects the declaration up front with a precise diagnostic.

pub type Respuesta
  = Ok(String)
  | Other

fn main() {
  print("unreachable")
}
