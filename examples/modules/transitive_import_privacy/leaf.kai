# Issue #565 — positive fixture: leaf module exposes a `pub`
# function whose body calls a non-`pub` helper. The privacy
# validator must accept the intra-module call regardless of how
# many import hops the consumer is away.

fn leaf_private_helper(x: Int) : Int = x + 1

pub fn leaf_public_step(x: Int) : Int = leaf_private_helper(x)
