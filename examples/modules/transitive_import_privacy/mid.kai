# Issue #565 — intermediate module that imports `leaf` and re-
# exposes only its own `pub` surface. `mid` does not re-export
# any of `leaf`'s names; the consumer only sees `mid.mid_keep`.
import leaf

fn mid_private_helper(x: Int) : Int = x * 2

pub fn mid_keep(x: Int) : Int = leaf.leaf_public_step(mid_private_helper(x))
