# Issue #565 — consumer reaches `leaf` only transitively through
# `mid`. Before the fix, the privacy validator mis-attributed
# every decl of `leaf` to `mid` and rejected the intra-`leaf`
# call `leaf_private_helper(x)` inside `leaf_public_step` as a
# cross-module privacy violation.
import mid

fn main() : Unit / Console {
  print(int_to_string(mid.mid_keep(20)))
}
