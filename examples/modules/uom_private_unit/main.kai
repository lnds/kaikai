# Negative cross-module fixture: `lib` declares `unit Secret`
# without `pub`, so it cannot be named from a different module.
# Writing `Real<Secret>` in `main` must trigger an `unknown unit`
# diagnostic at the use site.

import lib

fn use_secret(t: Real<Secret>) : Real<Secret> = t

fn main() : Unit / Stdout {
  let _ = use_secret(2.0<Secret>)
  Stdout.print("should-not-compile")
}
