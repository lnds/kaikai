# issue #376 — `type Foo = Int` is a transparent alias.
# Pre-#376 this raised `type mismatch in let annotation: expected
# Age, found Int`. Single-component (no `|`) bodies whose RHS is
# a primitive desugar to a structural alias, restoring the contract
# documented in `docs/kaikai-minimal.md` lines 194-195.

type Age = Int

fn double(n: Int) : Int = n * 2

fn main() : Int / Stdout {
  let a : Age = 30
  Stdout.print(int_to_string(double(a)))
  0
}
