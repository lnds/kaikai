# issue #376 — String alias flows through fn signatures.
# `type Name = String` was the second alias example in
# `docs/kaikai-minimal.md` line 195; pre-#376 the binding
# `let n : Name = "..."` failed type-checking.

type Name = String

fn greet(n: Name) : String = string_concat("hello, ", n)

fn main() : Int / Stdout {
  let n : Name = "kaikai"
  Stdout.print(greet(n))
  0
}
