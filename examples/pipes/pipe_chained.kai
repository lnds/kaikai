# Issue #594 — chain three convention-dispatched pipes back to back.
# Each operator hits the head-owner cache; the LHS at each step is
# the previous step's result, so type inference must thread `[Int]`
# through every dispatch decision.

fn main() : Unit / Console {
  let xs = [1, 2, 3, 4, 5]
    | (n) => n * 2
    || (n) => [n, n + 1]
    |? (n) => n > 5
  each(xs, (n) => print(int_to_string(n)))
}
