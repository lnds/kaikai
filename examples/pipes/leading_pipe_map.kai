# issue #130 — `|` (map pipe, m7b #9) may also lead a continuation
# line. Each `| f` continues the chain instead of terminating the
# previous statement. Uses lambda-block RHS form because
# `(x) => body` greedily absorbs the next `|` as part of its body
# (existing precedence behaviour, see `map_pipe_chained.kai`).

fn main() : Unit / Console {
  let doubled = [1, 2, 3]
    | { x -> x * 2 }
    | { x -> x + 1 }
  each(doubled, (x) => print(int_to_string(x)))
}
