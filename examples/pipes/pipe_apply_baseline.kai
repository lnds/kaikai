# Issue #594 baseline regression guard for `|>` (apply pipe). The
# apply pipe does NOT use the head-owner dispatch table — it is
# pure syntactic rewriting of `x |> f(args)` to `f(x, args)`. This
# fixture pins that the convention-based dispatch lane left this
# path untouched.

fn show(n: Int) : String = int_to_string(n)

fn main() : Unit / Console {
  let s = 42 |> show
  print(s)
}
