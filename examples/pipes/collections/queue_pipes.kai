# `Queue[a]` rides the pipes (`|`, `||`, `|?`) with element type `a`,
# preserving head → tail (FIFO) order through every pipe.

import collections.queue

fn show_ints(xs: [Int]) : String = match xs {
  []           -> ""
  [x]          -> int_to_string(x)
  [x, ...rest] -> int_to_string(x) ++ "," ++ show_ints(rest)
}

fn even(x: Int) : Bool = x % 2 == 0
fn dbl(x: Int) : Int = x * 2
fn dup(x: Int) : Queue[Int] = queue.from_list([x, x])

fn main() : Unit / Stdout = {
  let q = queue.from_list([1, 2, 3, 4, 5, 6])

  let evens = q |? even | dbl
  Stdout.print("filter|map: " ++ show_ints(queue.to_list(evens)))

  # || flat-map: first element's sub-queue drains first.
  let doubled = queue.from_list([1, 2]) || dup
  Stdout.print("flat_map: " ++ show_ints(queue.to_list(doubled)))
}
