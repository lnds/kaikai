# issue #130 — the pre-existing trailing-pipe shape (operator at end
# of line, continuation indented on the next line) must not regress
# when `parse_pipe_rest` starts skipping leading newlines.

fn add1(x: Int) : Int = x + 1
fn double(x: Int) : Int = x * 2

fn main() : Unit / Console {
  let r = 3 |>
    add1 |>
    double |>
    add1
  print(int_to_string(r))
}
