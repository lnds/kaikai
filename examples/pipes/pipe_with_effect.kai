# Issue #594 — the lambda body inside the pipe carries an effect
# (`Console` via `print`). The pipe-dispatch path must propagate
# the row through the rewrite so the enclosing function's row sees
# `Console` and `main`'s declared `/ Console` annotation matches.
# Pre-#594 this worked through the hardcoded `List` entry; the
# cache-driven path has to behave identically.

fn main() : Unit / Console {
  let xs = [1, 2, 3] | (n) => { print(int_to_string(n)); n * 2 }
  each(xs, (n) => print(int_to_string(n)))
}
