# issue #130 — `|>` may lead a continuation line. The parser skips
# leading newlines before scanning for the apply pipe so this shape
# parses identically to `xs |>\n  f |>\n  g`.

fn add1(x: Int) : Int = x + 1
fn double(x: Int) : Int = x * 2

fn main() : Unit / Console {
  let r = 3
    |> add1
    |> double
    |> add1
  print(int_to_string(r))
}
