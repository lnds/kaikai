# Issue #594 baseline regression guard. The historical hardcoded
# `head_module_for("List") -> Some("list")` table is gone; this
# fixture pins that the convention-based head-owner cache resolves
# `[Int] | f` to `core.list.map` exactly as the pre-#594 path did.

fn main() : Unit / Console {
  let xs = [1, 2, 3] | (n) => n * 2
  each(xs, (n) => print(int_to_string(n)))
}
