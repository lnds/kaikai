# Issue #328 — bare `...` in list spread patterns. The preferred form
# for "match any non-empty list, tail unused": no invented binding name,
# no editorial noise.

fn first_or(xs: [Int], default: Int) : Int =
  match xs {
    []       -> default
    [h, ...] -> h
  }

fn main() : Int / Console {
  print(int_to_string(first_or([10, 20, 30], -1)))
  print(int_to_string(first_or([], -1)))
  0
}
