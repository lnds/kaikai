# Issue #129 — multi-arg match parse-error: more than 4 scrutinees
# in the head. The cap is by design (re-evaluate if a use case
# wants 5+); the diagnostic must point at the limit.

fn f(a: Int, b: Int, c: Int, d: Int, e: Int) : Int = match a, b, c, d, e {
  1, 2, 3, 4, 5 -> 0
  _, _, _, _, _ -> 1
}

fn main() : Int = f(1, 2, 3, 4, 5)
