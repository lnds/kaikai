# Issue #328 — positive control: the `...rest` form keeps working
# unchanged. `rest` is consumed (its length is reported) so we know the
# binding still flows through to codegen.

fn describe(xs: [Int]) : String =
  match xs {
    []           -> "empty"
    [h, ...rest] -> "head=#{int_to_string(h)} tail_len=#{int_to_string(list_length(rest))}"
  }

fn main() : Int / Console {
  print(describe([10, 20, 30]))
  print(describe([]))
  0
}
