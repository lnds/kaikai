# Issue #325 — record `match` with a guarded arm and a total
# fall-through arm. Verifies the guard path (which compiles into a
# C `if (test) { if (guard) { ... } }` chain inside the per-arm
# body) still routes through the rewritten `PRecord` test instead
# of the `KAI_VARIANT` test that produced the regression.

type P = { x: Int, y: Int }

fn classify(p: P) : String =
  match p {
    P { x, y } if x == 0 and y == 0 -> "origin"
    P { x: _, y: _ } -> "other"
  }

fn main() : Int / Console {
  print(classify(P { x: 0, y: 0 }))
  print(classify(P { x: 1, y: 2 }))
  0
}
