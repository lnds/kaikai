# issue #1137 negative — a range pattern over a non-numeric scrutinee is
# a type error. The `lo..hi` desugars to `>= lo and <= hi`, which does
# not type-check against a String scrutinee.

fn f(s: String) : String = match s {
  1..9 -> "in"
  _    -> "out"
}

fn main() : Unit / Stdout = Stdout.print(f("hi"))
