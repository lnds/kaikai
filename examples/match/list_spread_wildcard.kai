# Issue #328 тАФ `..._` form. Same decision tree as bare `[h, ...]`;
# accepted for users who reach for `_` by analogy with every other
# pattern position.

fn first_or(xs: [Int], default: Int) : Int =
  match xs {
    []        -> default
    [h, ..._] -> h
  }

fn main() : Int / Console {
  print(int_to_string(first_or([10, 20, 30], -1)))
  print(int_to_string(first_or([], -1)))
  0
}
