# Issue #129 — multi-arg match parse-error: arm has more patterns
# than the head has scrutinees. Head = 2 scrutinees, second arm has
# 3 patterns. The parser must reject this with a diagnostic pointing
# at the offending arm.

fn f(a: Int, b: Int) : Int = match a, b {
  1, 2    -> 0
  3, 4, 5 -> 1
  _, _    -> 2
}

fn main() : Int = f(1, 2)
