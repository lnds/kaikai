# Issue #325 — `match` over a record value with a single total arm.
#
# Pre-fix the parser produced `PVariantRecord("P", ...)` for the
# `P { x, y }` arm, and the emitter generated a `KAI_VARIANT` tag
# check that never matched the record's `KAI_RECORD` tag — falling
# through to the runtime "non-exhaustive match" panic on what is in
# fact a total pattern. The typer is unchanged: it already accepts
# a record-alias name in this position via
# `check_variant_record_pattern`. The fix rewrites the pattern to
# `PRecord` post-typing in `synth_match` so codegen routes through
# `emit_pat_test_record` (the `KAI_RECORD` check).

type P = { x: Int, y: Int }

fn describe(p: P) : String =
  match p {
    P { x, y } -> int_to_string(x)
  }

fn main() : Int / Console {
  let p = P { x: 1, y: 2 }
  print(describe(p))
  0
}
