# `Decimal / 0` via the Div operator must trap cleanly (non-zero exit +
# `trap: divide by zero`), the same failure class as an out-of-range
# index. `decimal.div` (explicit scale, returning Option) is the opt-in
# zero-handling variant. The zero divisor is built at runtime.

import decimal as dec
import decimal_proto

fn main() : Int / Stdout = {
  let a = dec.from_int(10)
  let z = dec.sub(a, a)
  Stdout.print("about to divide by zero")
  let c = a / z
  Stdout.print("UNREACHABLE: " ++ dec.to_string(c))
  0
}
