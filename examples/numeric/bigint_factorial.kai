# factorial(n) via BigInt: exact products far beyond i64.

import math.bigint
import math.bigint_convert as bc

fn fact(n: Int, acc: bigint.BigInt) : bigint.BigInt =
  if n <= 1 { acc }
  else { fact(n - 1, bigint.mul(acc, bigint.from_int(n))) }

fn main() : Int / Stdout = {
  Stdout.print(bc.to_string(fact(20, bigint.one())))
  Stdout.print(bc.to_string(fact(30, bigint.one())))
  Stdout.print(bc.to_string(fact(50, bigint.one())))
  0
}
