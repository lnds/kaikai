# BigInt error paths surface as values, never as panics or wrong
# results: bad parse -> None, divide by zero -> None.

import math.bigint
import math.bigint_convert as bc

fn want_none(label: String, o: Option[bigint.BigInt]) : Unit / Stdout =
  match o { None -> Stdout.print(label ++ ": ok (None)") Some(_) -> Stdout.print(label ++ ": FAIL") }

fn main() : Int / Stdout = {
  # from_string rejects empty, lone sign, and non-digit input.
  want_none("empty", bc.from_string(""))
  want_none("lone -", bc.from_string("-"))
  want_none("letters", bc.from_string("12a34"))
  want_none("spaces", bc.from_string("1 2"))

  # divmod / div / rem by zero are None, not a panic.
  match bc.divmod(bc_unwrap(bc.from_string("100")), bigint.zero()) {
    None -> Stdout.print("divmod by 0: ok (None)")
    Some(_) -> Stdout.print("divmod by 0: FAIL")
  }
  match bc.div(bigint.from_int(5), bigint.zero()) {
    None -> Stdout.print("div by 0: ok (None)")
    Some(_) -> Stdout.print("div by 0: FAIL")
  }
  0
}

fn bc_unwrap(o: Option[bigint.BigInt]) : bigint.BigInt = match o { Some(v) -> v None -> bigint.zero() }
