{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "kaikai",
  "scopeName": "source.kaikai",
  "fileTypes": ["kai"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#chars" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#effects" },
    { "include": "#holes" },
    { "include": "#declarations" },
    { "include": "#constructors" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "meta.preprocessor.derive.kaikai",
          "match": "#derive\\b"
        },
        {
          "name": "comment.line.number-sign.kaikai",
          "match": "#(?!derive\\b).*$",
          "captures": {
            "0": {
              "patterns": [
                {
                  "name": "keyword.codetag.kaikai",
                  "match": "\\b(TODO|FIXME|XXX|NOTE|HACK)\\b"
                }
              ]
            }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.kaikai",
          "match": "\\b(if|else|match|for|with|handle|where|requires|ensures)\\b"
        },
        {
          "name": "storage.type.kaikai",
          "match": "\\b(fn|let|var|const|type|effect|protocol|impl|import|use|test|axiom|unit)\\b"
        },
        {
          "name": "storage.modifier.kaikai",
          "match": "\\b(pub|as|assert)\\b"
        },
        {
          "name": "keyword.operator.logical.kaikai",
          "match": "\\b(and|or|not)\\b"
        },
        {
          "name": "constant.language.boolean.kaikai",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "invalid.deprecated.todo.kaikai",
          "match": "\\btodo!"
        }
      ]
    },
    "types": {
      "name": "support.type.builtin.kaikai",
      "match": "\\b(Int|Real|Bool|String|Char|Unit|Nothing|Option|Result|List|Pair|Map|Set|Stack|Queue|Array|Decimal|Money|Fiber|Pid|Regex|Match|Capture|WallTime|Instant|Duration)\\b"
    },
    "effects": {
      "name": "support.class.effect.kaikai",
      "match": "\\b(Console|Stdin|Stdout|Stderr|File|Env|State|Reader|Writer|Actor|Spawn|Cancel|Mutable|Fail|Random|Time|Clock|Ffi)\\b"
    },
    "constructors": {
      "name": "entity.name.type.kaikai",
      "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
    },
    "declarations": {
      "patterns": [
        {
          "match": "\\b(fn)\\s+([a-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.kaikai" },
            "2": { "name": "entity.name.function.kaikai" }
          }
        },
        {
          "match": "\\b(type|effect|protocol|impl)\\s+([A-Z][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.kaikai" },
            "2": { "name": "entity.name.type.kaikai" }
          }
        }
      ]
    },
    "numbers": {
      "name": "constant.numeric.kaikai",
      "match": "\\b\\d[0-9_]*(\\.\\d[0-9_]*)?([eE][+-]?\\d+)?\\b"
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.triple.kaikai",
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "patterns": [
            { "include": "#string-escapes" },
            { "include": "#string-interp" }
          ]
        },
        {
          "name": "string.quoted.double.kaikai",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "include": "#string-escapes" },
            { "include": "#string-interp" }
          ]
        }
      ]
    },
    "string-escapes": {
      "name": "constant.character.escape.kaikai",
      "match": "\\\\([\\\\\"'nrt0]|u\\{[0-9a-fA-F]+\\})"
    },
    "string-interp": {
      "name": "meta.embedded.expression.kaikai",
      "begin": "#\\{",
      "end": "\\}",
      "beginCaptures": { "0": { "name": "punctuation.section.embedded.begin.kaikai" } },
      "endCaptures":   { "0": { "name": "punctuation.section.embedded.end.kaikai" } },
      "patterns": [
        { "include": "#numbers" },
        { "include": "#keywords" },
        { "include": "#types" },
        { "include": "#effects" },
        { "include": "#strings" },
        { "include": "#chars" },
        { "include": "#operators" },
        { "include": "#constructors" }
      ]
    },
    "chars": {
      "name": "string.quoted.single.kaikai",
      "match": "'(\\\\(u\\{[0-9a-fA-F]+\\}|.)|[^\\\\'])'"
    },
    "holes": {
      "name": "variable.language.hole.kaikai",
      "match": "\\?[a-zA-Z_][a-zA-Z0-9_]*|\\?"
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.pipe.kaikai",
          "match": "\\|>|\\|"
        },
        {
          "name": "keyword.operator.arrow.kaikai",
          "match": "->|=>"
        },
        {
          "name": "keyword.operator.comparison.kaikai",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.assignment.kaikai",
          "match": ":=|="
        },
        {
          "name": "keyword.operator.concat.kaikai",
          "match": "\\+\\+"
        },
        {
          "name": "keyword.operator.range.kaikai",
          "match": "\\.\\.\\.|\\.\\."
        },
        {
          "name": "keyword.operator.arithmetic.kaikai",
          "match": "[+\\-*/%^]"
        },
        {
          "name": "keyword.operator.other.kaikai",
          "match": "[!@:]|::"
        }
      ]
    }
  }
}
