# deep_rec.kai — honest non-tail recursion (bench c).
# Naive recursive Fibonacci: every call spawns two non-tail calls, so
# there is NO TCO — the work is a real call tree. Stresses call/return
# overhead, argument passing, and (in the boxed native path) per-call
# box/unbox of the Int arguments and results.
fn fib(n: Int) : Int =
  if n < 2 { n }
  else { fib(n - 1) + fib(n - 2) }

fn loop_fib(k: Int, acc: Int, base: Int) : Int =
  if k == 0 { acc }
  else {
    # fib's argument VARIES with k (base + k % 3 ∈ {base..base+2}), so
    # the optimiser cannot CSE the call or fold it to a constant — each
    # iteration runs a genuinely different recursive tree.
    let total = acc + fib(base + (k % 3))
    loop_fib(k - 1, total, base)
  }

fn main() : Unit / Stdout = {
  # base ≈ 29 (runtime-opaque), k = 9: 9 fib(29..31) trees, ~15M
  # non-tail calls that actually execute on both backends.
  let seed = string_length(program_name())
  let one = seed / seed
  let total = loop_fib(9 * one, 0, 29 * one)
  Stdout.print("#{total}")
}
