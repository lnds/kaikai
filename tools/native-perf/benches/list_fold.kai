# list_fold.kai — honest list build + fold (bench b).
# Builds a large cons list, then folds it. Exercises heap allocation,
# Perceus RC (incref/decref on every cons cell), and the list traversal
# path — NOT just arithmetic. The total iteration count is repeated so
# the list is rebuilt many times (keeps peak memory bounded while still
# stressing alloc/free throughput).
fn build(i: Int, acc: [Int]) : [Int] =
  if i == 0 { acc }
  else { build(i - 1, [i, ...acc]) }

fn fold_sum(xs: [Int], acc: Int) : Int =
  match xs {
    []          -> acc
    [h, ...t]   -> fold_sum(t, acc + h)
  }

fn rounds(r: Int, total: Int) : Int =
  if r == 0 { total }
  else {
    let xs = build(20000, [])
    rounds(r - 1, total + fold_sum(xs, 0))
  }

fn main() : Unit / Stdout = {
  # seed/seed is 1 at runtime but opaque to the optimiser, fixing the
  # round count at exactly 30_000 (30_000 * 20_000 = 600M cons cells).
  let seed = string_length(program_name())
  let r = 30000 * (seed / seed)
  let total = rounds(r, 0)
  Stdout.print("#{total}")
}
