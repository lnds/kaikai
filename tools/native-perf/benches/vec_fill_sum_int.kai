fn fill(v: Vec[Int], k: Int, n: Int) : Vec[Int] =
  if k > n { v } else { fill(vec_push(v, k), k + 1, n) }

fn sum(v: Vec[Int], i: Int, n: Int, acc: Int) : Int =
  if i >= n { acc } else { sum(v, i + 1, n, acc + vec_get(v, i)) }

fn main() : Int / Stdout = {
  let n = 10000000
  let v = fill(vec_empty(), 1, n)
  Stdout.print(int_to_string(sum(v, 0, n, 0)))
  0
}
