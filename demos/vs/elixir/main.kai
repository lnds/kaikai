# vs Elixir — typed actors with exhaustive match
#
# Elixir's `receive` matches incoming messages against patterns at
# runtime. A typo in a message tag, a forgotten case, or a renamed
# message becomes a runtime mailbox stall — the receiver waits forever
# for a message it will never recognise. There is no compile-time
# guarantee.
#
# kaikai: `Actor[Msg]` is parameterised by a sum type. The `match`
# inside the loop is checked for exhaustiveness at compile time.
# Adding a variant to the message type forces every receiver to
# handle it. Renaming is a refactor, not a runtime ghost.
#
# === Elixir equivalent (~20 lines) ===
#
#   defmodule Counter do
#     def start(n) do spawn(fn -> loop(n) end) end
#     def loop(n) do
#       receive do
#         :inc                  -> loop(n + 1)
#         :dec                  -> loop(n - 1)
#         {:get, caller}        -> send(caller, n); loop(n)
#         # add a new variant here? receivers elsewhere need updating —
#         # the compiler will not tell you which.
#       end
#     end
#   end
#
# === kaikai equivalent (target syntax) ===

use Console
use Spawn

#[derive(Show, Eq)]
type CounterMsg = Inc | Dec | Get(Pid[Int])

# Adding `Reset` here? Every match below stops compiling until handled.
fn counter_loop(n: Int) : Unit / Actor[CounterMsg] =
  match Actor.receive() {
    Inc           -> counter_loop(n + 1)
    Dec           -> counter_loop(n - 1)
    Get(replyto)  -> {
      replyto.send(n)
      counter_loop(n)
    }
    # match exhaustiveness: compile error if a variant is missing.
  }

fn main() = nursery { n ->
  let counter = n.spawn_actor { counter_loop(0) }
  counter.send(Inc)
  counter.send(Inc)
  counter.send(Inc)
  counter.send(Dec)
  let me = n.self()
  counter.send(Get(me))
  let value = Actor.receive()  # Int (the reply)
  println("counter = #{value}")    # impl Show for Int
}
