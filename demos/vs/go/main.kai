# vs Go — error handling without `if err != nil` ladders
#
# Go's idiomatic error handling means every fallible call gets a
# 3-line wrap: assignment, check, return. Pipelines that read a file,
# parse, validate, and write spend more lines on `if err != nil` than
# on actual logic.
#
# kaikai: `!` postfix propagates `Result` / `Option` errors to the
# enclosing `Fail` handler. The pipeline reads as the dataflow it is.
#
# === Go equivalent (~25 lines) ===
#
#   func process(in, out string) error {
#       data, err := os.ReadFile(in)
#       if err != nil { return err }
#       parsed, err := parseJSON(data)
#       if err != nil { return err }
#       err = validate(parsed)
#       if err != nil { return err }
#       result, err := transform(parsed)
#       if err != nil { return err }
#       return os.WriteFile(out, marshal(result), 0644)
#   }
#
# === kaikai equivalent (target syntax) ===

use Console
use File
use Env

type Record = { id: Int, name: String, amount: Int }

fn parse(data: String) : Result[Record, String] = todo!("json parser")
fn validate(r: Record) : Result[Record, String] =
  if r.amount >= 0 { Ok(r) } else { Err("negative amount") }
fn transform(r: Record) : Result[Record, String] = Ok({ r with amount = r.amount * 2 })
fn marshal(r: Record) : String = todo!("json emit")

# Whole pipeline in 5 lines; every `!` is a possible early return on
# Err, propagated to the Fail handler in main.
fn process(input: String, output: String) : Unit / File + Fail = {
  let data    = File.read(input)!
  let parsed  = parse(data)!
  let valid   = validate(parsed)!
  let result  = transform(valid)!
  File.write(output, marshal(result))!
}

fn main() = match Env.args() {
  [input, output] -> handle { process(input, output) } with Fail {
    fail(msg, _) -> Console.eprint("error: " ++ msg)
    return(_)    -> ()
  }
  _ -> println("usage: process <input> <output>")
}
