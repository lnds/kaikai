# vs Scala — typed effects without monad transformers
#
# Scala's effect story (ZIO, Cats Effect) tracks effects in types but
# composes them via monad transformers or environment ZIO[R, E, A]. A
# function that reads a Config, writes Logs, talks to a DB, and may
# fail ends up as `EitherT[StateT[IO, S, ...], E, A]` (transformer
# stack) or `ZIO[Config & Log & DB, AppError, A]` (environment).
# Either way the type is heavy and the syntax requires `for` blocks
# with `<-` — far from regular Scala.
#
# kaikai: a row of effects in the signature. Body reads as ordinary
# code. Handlers compose horizontally, no transformer stacking.
#
# === Scala 3 with ZIO equivalent (~20 lines) ===
#
#   def transfer(from: AccountId, to: AccountId, amount: Money): ZIO[Log & DB & Clock, TransferError, Receipt] =
#     for {
#       _    <- Log.info(s"transfer $from -> $to: $amount")
#       src  <- DB.fetch(from)
#       dst  <- DB.fetch(to)
#       _    <- if (src.balance < amount) ZIO.fail(InsufficientFunds) else ZIO.unit
#       now  <- Clock.now
#       _    <- DB.update(src.copy(balance = src.balance - amount))
#       _    <- DB.update(dst.copy(balance = dst.balance + amount))
#     } yield Receipt(from, to, amount, now)
#
# === kaikai equivalent (target syntax) ===

use Console

type AccountId = String
type Money     = Decimal<USD> where >= 0

#derive(Show, Eq)
type Account   = { id: AccountId, balance: Money }

#derive(Show)
type Receipt   = { from: AccountId, to: AccountId, amount: Money, at: Instant }

fn transfer(from: AccountId, to: AccountId, amount: Money) : Receipt
  / Logger + DB + Clock + Fail
  requires amount > 0.0<USD>
=
  Logger.info("transfer " ++ from ++ " -> " ++ to ++ ": " ++ decimal_to_string(amount))
  let src = DB.fetch(from)!
  let dst = DB.fetch(to)!
  if src.balance < amount { Fail.fail("insufficient funds") }
  let now = Clock.now()
  DB.update({ src with balance = src.balance - amount })!
  DB.update({ dst with balance = dst.balance + amount })!
  Receipt { from: from, to: to, amount: amount, at: now }

fn main() = todo!("wire handlers + run")
