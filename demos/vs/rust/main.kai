# vs Rust — memory safety without the borrow checker
#
# Rust enforces memory safety via the borrow checker. Sharing mutable
# state between concurrent producers and consumers requires `Arc<Mutex<T>>`,
# `RefCell`, or channels — every choice has cognitive cost and
# documentation overhead. The borrow rules are correct but expensive
# at the program-design phase.
#
# kaikai: memory safety via Perceus (compile-time RC) + isolated
# fibers (BEAM-style: each fiber owns its heap, messages copied or
# moved). No `Arc`, no `Mutex`, no `'a` lifetimes, no `RefCell`. Same
# safety guarantees, very different cognitive load.
#
# === Rust equivalent (~25 lines) ===
#
#   use std::sync::{Arc, Mutex};
#   use std::thread;
#
#   fn main() {
#       let queue: Arc<Mutex<Vec<i32>>> = Arc::new(Mutex::new(Vec::new()));
#       let producer = {
#           let q = Arc::clone(&queue);
#           thread::spawn(move || {
#               for i in 0..10 { q.lock().unwrap().push(i); }
#           })
#       };
#       producer.join().unwrap();
#       let total: i32 = queue.lock().unwrap().iter().sum();
#       println!("total = {}", total);
#   }
#
# === kaikai equivalent (target syntax) ===

use Console
use Spawn

#[derive(Show, Eq)]
type WorkMsg = Push(Int) | Done

# The actor owns its mailbox and internal state. Messages are copied
# on send. No `Arc`, no `Mutex`, no lifetimes — the type system + the
# fiber isolation rule out shared mutable state by construction.
fn worker(acc: Int) : Int / Actor[WorkMsg] = match Actor.receive() {
  Push(n) -> worker(acc + n)
  Done    -> acc
}

fn main() = nursery { n ->
  let w = n.spawn_actor { worker(0) }
  list.each([0..9], (i) => w.send(Push(i)))
  w.send(Done)
  let total = w.join()
  println("total = #{total}")    # impl Show for Int
}
