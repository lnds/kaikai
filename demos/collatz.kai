module Collatz

fn chain(n: Int) -> [Int] {
    switch  {
        case n == 1: [1]
        case even(n): [n, chain(n/2)...]
        case odd(n): [n, chain(n*3+1)...]
     }
}

fn main() {
    let num_long_chain := 1..100 | chain | filter(\{xs -> len(xs) > 15}) |> len()
    perform println!(num_long_chain)
}