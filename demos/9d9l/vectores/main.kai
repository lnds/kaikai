# 9d9l #3 — Vectores
#
# Reads a file of fixed-width records, consolidates 6 period vectors of
# 23 elements each into a single deduplicated, sorted vector of at most
# 23 elements. Marks the result S/N/D depending on overflow/empty/short.
#
# Record layout (per line):
#   header: 9 digits
#   detail: 6 vectors × 23 periods × 6 digits/period = 828 chars
# Output:
#   header: 9 digits (copied)
#   mark:   1 char (S, N, or D)
#   vector: at most 23 periods × 6 digits = 138 chars (padded with spaces)
#
# Pending features:
#   - `use Effect`            — m7e §25
#   - `File.read_lines` etc.  — File effect catalog (post-m14)
#   - `Clock.monotonic`       — Time effect (post-m8)
#   - `list.sort` desc + `list.uniq` — stdlib lite (m5-stdlib lane)
#   - `++`                    — m7d §23

use Console
use Env
use File
use Clock

let header_len  : Int = 9
let period_len  : Int = 6
let vec_size    : Int = 23
let n_vectors   : Int = 6
let detail_len  : Int = period_len * vec_size * n_vectors   # 828

fn parse_period(s: String) : Option[Int] =
  if string.length(s) != period_len { None } else { string.parse_int(s) }

fn slice_periods(detail: String, offset: Int, n: Int, acc: [Int]) : [Int] =
  if n == 0 { acc }
  else {
    let p = string.slice(detail, offset, period_len)
    match parse_period(p) {
      None        -> slice_periods(detail, offset + period_len, n - 1, acc)
      Some(0)     -> slice_periods(detail, offset + period_len, n - 1, acc)
      Some(v)     -> slice_periods(detail, offset + period_len, n - 1, [v, ...acc])
    }
  }

fn consolidate(detail: String) : [Int] = {
  let raw = slice_periods(detail, 0, vec_size * n_vectors, [])
  raw |> list.uniq |> list.sort |> list.reverse
}

fn pad_periods(periods: [Int], padding: Int) : String = {
  let body = periods | int_to_string |> string.join("")
  body ++ string.repeat(" ", padding * period_len)
}

fn process_line(line: String) : String =
  if string.length(line) < header_len + detail_len { "" }
  else {
    let header = string.slice(line, 0, header_len)
    let detail = string.slice(line, header_len, detail_len)
    let periods = consolidate(detail)
    let n = list.length(periods)
    if n > vec_size {
      header ++ "S" ++ string.repeat(" ", vec_size * period_len)
    } else if n == 0 {
      header ++ "N" ++ string.repeat(" ", vec_size * period_len)
    } else {
      header ++ "D" ++ pad_periods(periods, vec_size - n)
    }
  }

fn format_elapsed(secs: Real) : String = {
  let m = (secs / 60.0) |> real.floor |> real_to_int
  let s = secs - real_of_int(m * 60)
  int_to_string(m) ++ "m " ++ real_to_string(s) ++ "s"
}

fn process(input: String, output: String) : Unit / Console + File + Clock + Fail = {
  let t0 = Clock.monotonic()
  let lines = File.read_lines(input)!
  let processed = lines | process_line
  File.write_lines(output, processed)!
  let t1 = Clock.monotonic()
  println("Tiempo: " ++ format_elapsed(Clock.diff_secs(t0, t1)))
}

fn main() = match Env.args() {
  [input, output] -> handle { process(input, output) } with Fail {
    fail(msg, _) -> Console.eprint("error: " ++ msg)
    return(_)    -> ()
  }
  _ -> println("usage: ordenar_vector <input> <output>")
}
