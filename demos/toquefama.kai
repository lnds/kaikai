module ToqueFama

import IO.Effects as _
import Math.Random.shuffle!

enum Result[E,O] {
    Error(e:E)
    Ok(o:O)
}

let max_nums := 5

let gen = 0..9 | perform shuffle!() | List.take(max_nums)

fn main() = {
    println ("Bienvenido, trata de adivina el número de cinco cifras")
    game (gen)
}

fn game (num :Int) {
    switch  input() | ans_to_num {
        case Error("salir"):
            println ("ok, adios")
            return
        case Error(_):
            println ("entrada inválida")
        case Ok(guess):
            let, f := toques (guess, num), famas (guess, num)
            perform println!("tienes #{toques} toques y #{famas} famas")
            if t == f {
                perform println!("ganaste, el numero esperado era #{num}")
                return
            }
    }
    game (num)
}       

fn input() := perform prompt!("ingrese una secuencia de 5 dígitos: ")

fn ans_to_num(ans: String): Result[String,[Int]] {
    let nums := ans | List.filter(isDigit) | toDigit
    if len(nums) == max_nums {
        Ok(nums)
    } else {
        Error(ans)
    }
}

fn toques (guess, num: [Int]) :=  guess | List.zip(num) | List.filter (\{g, n -> g == n}) | List.count

fn famas (guess, num: [Int]) := guess | List.filter(\{g -> List.member(num, g)}) | List.count