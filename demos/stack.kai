module Stack

effect Stack(xs) =  push!(s, x) | pop!(s)

handle {
    | push!(Stack(xs), x) -> resume Stack([x|xs]) with ()
    | pop!(Stack([])) -> perform error!("empty stack")
    | pop!(Stack([x|xs])) -> resume Stack(xs) with x
}

fn main() {
    stack := Stack([])
    perform push!(stack, 10 )
    perform push!(stack, 20 )
    IO.println (perform pop!(stack))
}