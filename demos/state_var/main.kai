# Mutable counter using m7b #5b — `var x = init` desugars to
# `with State[Int](init) as x`, exposed via `x.get()` / `x.set(v)`.
# (The `x := v` short form lands later with m7b #4.)
#
# Sister demo to `state_explicit/` (explicit State[Int] handler) and
# `state/` (target syntax with `var` + `:=`, blocked on m7b #4).

fn main() : Int / Console = {
  var n := 0
  n.set(n.get() + 1)
  n.set(n.get() + 1)
  n.set(n.get() + 1)
  Console.print(int_to_string(n.get()))
  0
}
