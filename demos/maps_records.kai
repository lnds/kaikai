module MapRecords 

struct Employee{ name: String, age: Int, budget: Int}

let employee = Employee{name: "Eduardo", age: 55, budget: 1_000}

let raised = employee | .{.budget: 2_000}

let map = %{"name" "Eduardo", "age" 55}

type %Employee{:name, :age, :budget}

let employee2 = %Employee{name: "Eduardo", age: 55, budget: 1_000}

let atom = :atom

let tuple = {:a, :b}



