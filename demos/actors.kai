module Actors

type Messages = enum {
        Ping(sender),
        Pong(sender)
 }

fn main() {
    let pid := spawn(\{ _ ->
        match receive() {
        case Ping(sender):
            println("Got ping")
            send(sender,Pong)
        }})
    }

    send (pid, Ping(self()))
    match receive() {
        case msg -> println("Got #{msg} back")
        case after 10000 -> println("Timeout")
    }
}

