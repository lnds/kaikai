module Counter

enum Messages {
    Inc,
    Val(sender)
}

fn start(initialCount:Int) {
    spawn(\() -> { listen(initialCount) })
}

fn listen(count:Int) {
    switch receive() {
    case Inc: listen(count+1)
    case Val(sender):
        send(sender, count)
        listen(count)
    }
}

fn main() {
    let counterPid := Counter.start(10)
    send(counterPid, Inc)
    send(counterPid, Inc)
    send(counterPid, Val(self())
    switch receive() {
    case value: println(value)
    }
}