module IMC

fn str_imc(peso, altura : Real): String {
    let imc := peso / altura ** 2
    let delgado, normal, gordo := 18.5, 25.0, 30.0
    switch {
    case imc <= delgado: "estas bajo el peso normal"
    case imc <= normal: "tu peso es normal"
    case imc <= gordo: "estas con sobrepeso"
    default: "estas obeso, cuidado!"
    }
}
