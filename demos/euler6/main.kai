# Project Euler #6: difference between square-of-sum and sum-of-squares for [1..100].

fn sum_n(n: Int) : Int = (n * (n + 1)) / 2

fn sum_squares(n: Int, acc: Int) : Int = {
  if n == 0 { acc }
  else { sum_squares(n - 1, acc + n * n) }
}

fn main() = {
  let n = 100
  let s = sum_n(n)
  let diff = s * s - sum_squares(n, 0)
  println("Euler 6: #{int_to_string(diff)}")
}
