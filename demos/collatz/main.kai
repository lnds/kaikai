fn chain(n: Int) : [Int] = match n {
  1                 -> [1]
  m if m % 2 == 0   -> [m, ...chain(m / 2)]
  m                 -> [m, ...chain(m * 3 + 1)]
}

fn main() = {
  let long_chains = [1..100] | chain |> filter((xs) => list_length(xs) > 15) |> list_length
  println("chains over 15 in [1..100]: #{int_to_string(long_chains)}")
}
