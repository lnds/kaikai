module Euler5

fn gcd(x, y : Num) = if y == 0 { x } else { gcd(x, x % y) }

fn lcm(a, b: Num) : Num {
    switch {
    case a == 0: 0
    case b == 0: 0
    default: b * (a // gcd(a, b))
    }
}

fn reduce(f : (Num,Num) -> Num, acum: Num, seq: Num...) : Num {
    switch seq{
        case $: acum
        case a: f(acum, a)
        case a,b...: reduce(f, f(acum,a), b...)
    }
}

fn divisors(n:Num): Num { range(2,n) | reduce(\{x,y-> lcm (x, y)}, 1) }

fn main() {
 divisors(20) |> IO.println
}