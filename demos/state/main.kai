# Mutable counter using `var` cells (m7b #5b once it lands again).
# This demo intentionally uses the sugar form; for the State[T]
# explicit form that runs today, see `state_explicit/`.

fn make_counter() : () -> Int / Mutable = {
  var n = 0
  () => {
    n := n + 1
    n
  }
}

fn main() = {
  let next = make_counter()
  println(int_to_string(next()))
  println(int_to_string(next()))
  println(int_to_string(next()))
}
