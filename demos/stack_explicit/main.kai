# Custom Stack effect with parametric stateful handler.
#
# Sister demo to `stack/`. Same shape as `state_explicit/` is to
# `state/`: the effect declares its state slot via `[s]`, the handler
# uses the `state` magic + 2-arg `resume(v, ns)` to thread the state
# across clause invocations.
#
# `stack/main.kai` is the sugar form (`var xs = []` as a sibling of
# clauses) and is blocked on the m7b #5b extension to handler-clause
# scope. This file is what compiles today.

effect Stack[s] {
  push(x: Int) : Unit
  pop()        : Int
}

fn run() : Unit / Stack[[Int]] + Stdout = {
  Stack.push(10)
  Stack.push(20)
  Stack.push(30)
  let a = Stack.pop()
  let b = Stack.pop()
  print("popped: #{int_to_string(a)} then #{int_to_string(b)}")
}

fn main() : Unit / Stdout + Fail = {
  handle { run() } with Stack[[Int]]([]) {
    push(x, resume) -> resume((), [x, ...state])
    pop(resume) -> match state {
      []           -> Fail.fail("empty stack")
      [x, ...rest] -> resume(x, rest)
    }
    return(x) -> x
  }
}
