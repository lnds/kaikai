# Project Euler #2: sum of even Fibonacci terms below 4_000_000.

fn even_fib_sum(a: Int, b: Int, limit: Int, acc: Int) : Int = {
  if a > limit { acc }
  else {
    let acc2 = if a % 2 == 0 { acc + a } else { acc }
    even_fib_sum(b, a + b, limit, acc2)
  }
}

fn main() = {
  let total = even_fib_sum(1, 2, 4_000_000, 0)
  println("Euler 2: #{int_to_string(total)}")
}
