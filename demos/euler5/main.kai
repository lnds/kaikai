# Project Euler #5: smallest number divisible by all of [1..20].

fn gcd(a: Int, b: Int) : Int = {
  if b == 0 { a } else { gcd(b, a % b) }
}

fn lcm(a: Int, b: Int) : Int = (a / gcd(a, b)) * b

fn lcm_range(lo: Int, hi: Int, acc: Int) : Int = {
  if lo > hi { acc }
  else { lcm_range(lo + 1, hi, lcm(acc, lo)) }
}

fn main() = println("Euler 5: #{int_to_string(lcm_range(1, 20, 1))}")
