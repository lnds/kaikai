# m12.6 — refinements + contracts on a textbook recursive function.
# `requires n >= 0` rejects negative inputs with a runtime panic; the
# `ensures result >= 1` post-condition reads as the mathematical
# invariant of the factorial. Both checks are produced by the parser
# desugar in stage2/compiler.kai (m12.6.b/c); the const-folder of
# m12.6.d cannot eliminate them because they reference `n` and
# `result`, so they remain runtime asserts.

fn factorial(n: Int) : Int
  requires n >= 0
  ensures  result >= 1
  = if n == 0 { 1 } else { n * factorial(n - 1) }

fn main() = [0..10] |> each((n) => println("#{int_to_string(n)}! = #{int_to_string(factorial(n))}"))

test "factorial base cases" {
  assert factorial(0) == 1
  assert factorial(1) == 1
}

test "factorial small values" {
  assert factorial(5) == 120
  assert factorial(10) == 3628800
}
