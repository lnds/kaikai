# wc — line, word and character counts, the classic Unix way.
#
# Demonstrates the stream module (#801): a single fold over a lazy line
# stream computes all three counters in one pass, in constant memory —
# a 10 GB log costs the same RAM as a 10 KB one.
#
# Notes vs coreutils wc:
# - chars approximates `wc -c` by re-adding the newline that read_lines
#   strips; a file whose last line lacks a trailing newline counts one
#   extra. Exact byte counting would fold over read_chunk directly.
# - read_lines carries `File + ReadFault`; `main` handles ReadFault with
#   the abort policy (open failure stops, a bad chunk is skipped). A
#   real CLI would branch on the policy it wants.
# - stdin input (no argument) awaits the Console split (#360).
import stream

type Counts = { lines: Int, words: Int, chars: Int }

# Words on one line: split on space, dropping empties (collapses runs
# of spaces, like wc does).
fn words_in(line: String) : Int =
  string.split(line, " ")
    |? (w) => not string.is_empty(w)
    |> list.length

fn wc(path: String) : Counts / File + ReadFault =
  stream.read_lines(path)
    |> stream.fold(Counts { lines: 0, words: 0, chars: 0 }) { acc, l ->
      Counts {
        lines: acc.lines + 1,
        words: acc.words + words_in(l),
        chars: acc.chars + string.length(l) + 1
      }
    }

fn main() : Unit / Console + Env + File = {
  let path = match list.nth(args(), 0) {
    Some(p) -> p
    None    -> "demos/wc.kai"
  }
  let c = handle {
    wc(path)
  } with ReadFault {
    bad_chunk(_m, resume) -> resume(())
    open_fault(_m, _r)    -> ()
  }
  Stdout.print("#{int_to_string(c.lines)} #{int_to_string(c.words)} #{int_to_string(c.chars)} #{path}")
}
