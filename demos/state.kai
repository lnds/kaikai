module State

effect Counter(x) =  inc!(c) | dec!(c) |get!(c)

fn counter () = {
    state := Counter(2)

    perform inc!(state)
    let c = perform get!(state)
    if c == 10 { 0 } else { counter() }

    handle {
      | inc!(Counter(x)) -> resume Counter (x + 1) with ()
      | dec!(Counter(x)) -> resume Counter (x - 1) with ()
      | get!(Counter(x)) -> resume Counter(x)  with x
    }
}

fn main() = counter()