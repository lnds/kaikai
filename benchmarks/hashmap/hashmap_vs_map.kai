# benchmarks/hashmap/hashmap_vs_map.kai — AVL Map vs HAMT HashMap.
#
# Issue #374: document the crossover between the ordered AVL `Map`
# (O(log n) tree walk) and the HAMT `HashMap` (O(log32 n) ≈ O(1)
# practical) across N = 100, 1K, 10K, 100K.
#
# Run with:
#
#   bin/kai bench benchmarks/hashmap/hashmap_vs_map.kai
#   KAI_BENCH_ITERS=200 KAI_BENCH_WARMUP=20 bin/kai bench \
#       benchmarks/hashmap/hashmap_vs_map.kai
#
# Each `bench` block reports median ns / MAD / mean / range. The
# numbers vary per run and machine; the comparison of interest is
# Map-vs-HashMap at the same N, and how the ratio shifts as N grows.
# See README.md for the crossover analysis and a sample run.
#
# `kai bench` has no setup hook — the whole block body is the timed
# region — so we cannot pre-build a map once and time only lookups.
# Instead each block measures one of two honest end-to-end workloads,
# identical between the two structures so the ratio is fair:
#
#   build_*  — N puts from empty. Allocation + spine-rebuild cost.
#              This is where the O(log n) vs O(log32 n) depth gap and
#              the AVL rebalance constant show up most directly.
#   roundtrip_* — N puts from empty, then N gets back. The populate-
#              and-query workload a registry / dedup table actually
#              runs. Build dominates, but the lookup tail is included
#              for both, so the comparison stays apples-to-apples.
#
# Keys are `Int` (Map's `<` and HashMap's `hash` both dispatch on the
# stdlib primitive impls). Values are `Int`.

import collections.map
import collections.hashmap

# ---- builders ----------------------------------------------------

fn build_map(i: Int, n: Int, m: Map[Int, Int]) : Map[Int, Int] =
  if i >= n { m } else { build_map(i + 1, n, map.put(m, i, i * 2)) }

fn build_hashmap(i: Int, n: Int, m: HashMap[Int, Int]) : HashMap[Int, Int] =
  if i >= n { m } else { build_hashmap(i + 1, n, hashmap.hashmap_put(m, i, i * 2)) }

# ---- lookup loops (sum the hits so the work is not dead-code) -----

fn lookup_map(i: Int, n: Int, m: Map[Int, Int], acc: Int) : Int =
  if i >= n { acc }
  else {
    let v = match map.get(m, i) { Some(x) -> x  None -> 0 }
    lookup_map(i + 1, n, m, acc + v)
  }

fn lookup_hashmap(i: Int, n: Int, m: HashMap[Int, Int], acc: Int) : Int =
  if i >= n { acc }
  else {
    let v = match hashmap.hashmap_get(m, i) { Some(x) -> x  None -> 0 }
    lookup_hashmap(i + 1, n, m, acc + v)
  }

fn roundtrip_map(n: Int) : Int = lookup_map(0, n, build_map(0, n, map.empty()), 0)
fn roundtrip_hashmap(n: Int) : Int = lookup_hashmap(0, n, build_hashmap(0, n, hashmap.hashmap_empty()), 0)

# ---- build benchmarks (N puts from empty) ------------------------

bench "build map      N=100"    { build_map(0, 100, map.empty()) }
bench "build hashmap  N=100"    { build_hashmap(0, 100, hashmap.hashmap_empty()) }

bench "build map      N=1000"   { build_map(0, 1000, map.empty()) }
bench "build hashmap  N=1000"   { build_hashmap(0, 1000, hashmap.hashmap_empty()) }

bench "build map      N=10000"  { build_map(0, 10000, map.empty()) }
bench "build hashmap  N=10000"  { build_hashmap(0, 10000, hashmap.hashmap_empty()) }

bench "build map      N=100000" { build_map(0, 100000, map.empty()) }
bench "build hashmap  N=100000" { build_hashmap(0, 100000, hashmap.hashmap_empty()) }

# ---- round-trip benchmarks (N puts then N gets) ------------------

bench "roundtrip map      N=100"    { roundtrip_map(100) }
bench "roundtrip hashmap  N=100"    { roundtrip_hashmap(100) }

bench "roundtrip map      N=1000"   { roundtrip_map(1000) }
bench "roundtrip hashmap  N=1000"   { roundtrip_hashmap(1000) }

bench "roundtrip map      N=10000"  { roundtrip_map(10000) }
bench "roundtrip hashmap  N=10000"  { roundtrip_hashmap(10000) }

bench "roundtrip map      N=100000" { roundtrip_map(100000) }
bench "roundtrip hashmap  N=100000" { roundtrip_hashmap(100000) }
