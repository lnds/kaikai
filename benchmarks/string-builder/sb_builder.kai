import string_builder
import core.list
import loop

fn build_sb(n: Int) : String = {
  var sb = string_builder.new()
  var i = 0
  while { @i < n } {
    sb := string_builder.append(@sb, "frag")
    i := @i + 1
  }
  string_builder.build(@sb)
}

fn main() : Unit / Console = {
  let s = build_sb(50000)
  print("len=#{int_to_string(string.length(s))}")
}
