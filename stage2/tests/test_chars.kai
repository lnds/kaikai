# compiler/chars.kai unit tests — first per-module test under
# issue #677 Phase 1.
#
# Layout follows `kai info testing`'s sibling-tests convention:
# this file sits in stage2/tests/, the package manifest is at
# stage2/kai.toml, and imports resolve to `compiler.<module>`
# against the parent package's source. The runner is `kai test
# stage2/.`.

import compiler.chars

test "ch_is_digit recognises every ASCII digit" {
  assert chars.ch_is_digit('0')
  assert chars.ch_is_digit('5')
  assert chars.ch_is_digit('9')
}

test "ch_is_digit rejects non-digits" {
  assert not chars.ch_is_digit('a')
  assert not chars.ch_is_digit('Z')
  assert not chars.ch_is_digit(' ')
  assert not chars.ch_is_digit('_')
  assert not chars.ch_is_digit('/')
}

test "ch_is_lower / ch_is_upper / ch_is_alpha agree on letters" {
  assert chars.ch_is_lower('a') and chars.ch_is_alpha('a')
  assert chars.ch_is_upper('Z') and chars.ch_is_alpha('Z')
  assert not chars.ch_is_lower('A')
  assert not chars.ch_is_upper('a')
}

test "underscore is alpha but not letter" {
  assert chars.ch_is_alpha('_')
  assert not chars.ch_is_lower('_')
  assert not chars.ch_is_upper('_')
  assert not chars.ch_is_digit('_')
}

test "ch_is_alnum covers letters, digits, and underscore" {
  assert chars.ch_is_alnum('a')
  assert chars.ch_is_alnum('Z')
  assert chars.ch_is_alnum('7')
  assert chars.ch_is_alnum('_')
  assert not chars.ch_is_alnum(' ')
  assert not chars.ch_is_alnum('-')
}

test "ch_is_space is intra-line only (newline excluded)" {
  assert chars.ch_is_space(' ')
  assert chars.ch_is_space('\t')
  assert chars.ch_is_space('\r')
  assert not chars.ch_is_space('\n')
  assert not chars.ch_is_space('a')
}

test "ch_is_hex_digit covers 0-9, a-f, A-F" {
  assert chars.ch_is_hex_digit('0')
  assert chars.ch_is_hex_digit('9')
  assert chars.ch_is_hex_digit('a')
  assert chars.ch_is_hex_digit('f')
  assert chars.ch_is_hex_digit('A')
  assert chars.ch_is_hex_digit('F')
  assert not chars.ch_is_hex_digit('g')
  assert not chars.ch_is_hex_digit('G')
  assert not chars.ch_is_hex_digit(' ')
  assert not chars.ch_is_hex_digit('_')
}

# Property checks — shrinking-driven invariants. Each `check` block
# is the kaikai equivalent of a small property-based test; the
# runner generates inputs of the declared type and reports a
# minimal counterexample on failure. See `kai info testing`.
#
# NOTE: the body of a `check` block must be an EXPRESSION that
# returns Bool — `assert` inside a check (which `kai info testing`
# unfortunately shows as the example shape) causes the runner to
# report failure on every input. Use plain Bool expressions
# instead. Observed against bin/kai 0.83.3.

check "ch_is_alpha implies ch_is_alnum" with c: Char {
  not chars.ch_is_alpha(c) or chars.ch_is_alnum(c)
}

check "ch_is_digit implies ch_is_alnum" with c: Char {
  not chars.ch_is_digit(c) or chars.ch_is_alnum(c)
}

check "ch_is_digit and ch_is_alpha are disjoint" with c: Char {
  not (chars.ch_is_digit(c) and chars.ch_is_alpha(c))
}

check "ch_is_lower and ch_is_upper are disjoint" with c: Char {
  not (chars.ch_is_lower(c) and chars.ch_is_upper(c))
}

check "ch_is_hex_digit is a superset of ch_is_digit" with c: Char {
  not chars.ch_is_digit(c) or chars.ch_is_hex_digit(c)
}
