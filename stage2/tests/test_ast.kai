# compiler/ast.kai unit tests — per-module tests for the AST data
# model + semantic Ty/Row extracted under issue #677 Phase 1f.
#
# Coverage focuses on the four AST constructor helpers (mk_expr,
# with_ty, mk_pat, mk_ty) and a handful of round-trip checks
# proving the type variants survive construction and matching.
# The rest of ast.kai is data-only — every type is exercised
# implicitly every time the compiler self-compiles.
#
# Runner: `kai test stage2/.`. Tier 1 wiring deferred until
# #452 / #677 Phase 2 lowers the per-test-file cost.

import compiler.ast

test "mk_expr builds an Expr with the given kind, line, col" {
  let e = ast.mk_expr(ast.EInt(42), 7, 3)
  assert e.line == 7
  assert e.col == 3
  match e.kind {
    ast.EInt(n) -> { assert n == 42 }
    _ -> { assert false }
  }
}

test "mk_expr stamps a fresh Expr with no resolved type" {
  let e = ast.mk_expr(ast.EBool(true), 1, 1)
  assert e.ty == None
}

test "mk_expr stamps MUnknown for the initial value mode" {
  let e = ast.mk_expr(ast.EInt(0), 1, 1)
  match e.mode {
    ast.MUnknown -> { assert true }
    _ -> { assert false }
  }
}

test "with_ty attaches a Ty to an Expr without touching kind or position" {
  let e0 = ast.mk_expr(ast.EInt(7), 5, 9)
  let e1 = ast.with_ty(e0, ast.TyInt)
  assert e1.line == 5
  assert e1.col == 9
  match e1.kind {
    ast.EInt(n) -> { assert n == 7 }
    _ -> { assert false }
  }
  match e1.ty {
    Some(t) -> match t {
      ast.TyInt -> { assert true }
      _ -> { assert false }
    }
    None -> { assert false }
  }
}

test "mk_pat builds a Pattern with the given kind, line, col" {
  let p = ast.mk_pat(ast.PWild, 4, 2)
  assert p.line == 4
  assert p.col == 2
  match p.pkind {
    ast.PWild -> { assert true }
    _ -> { assert false }
  }
}

test "mk_ty builds a TypeExpr with the given kind, line, col" {
  let te = ast.mk_ty(ast.TyName("Int", []), 3, 1)
  assert te.line == 3
  assert te.col == 1
  match te.tkind {
    ast.TyName(name, args) -> {
      assert name == "Int"
      assert list_length(args) == 0
    }
    _ -> { assert false }
  }
}

test "EInt / EReal / EBool / EStr carry their literal value" {
  let ei = ast.mk_expr(ast.EInt(123), 1, 1)
  let er = ast.mk_expr(ast.EReal(2.5, "2.5"), 1, 1)
  let eb = ast.mk_expr(ast.EBool(false), 1, 1)
  let es = ast.mk_expr(ast.EStr("hi"), 1, 1)
  match ei.kind { ast.EInt(n) -> { assert n == 123 } _ -> { assert false } }
  match er.kind { ast.EReal(r, _) -> { assert r == 2.5 } _ -> { assert false } }
  match eb.kind { ast.EBool(b) -> { assert b == false } _ -> { assert false } }
  match es.kind { ast.EStr(s) -> { assert s == "hi" } _ -> { assert false } }
}

test "Ty primitives are distinct variants under match" {
  let ty_table = [ast.TyInt, ast.TyReal, ast.TyBool, ast.TyString, ast.TyChar, ast.TyUnit, ast.TyByte]
  assert list_length(ty_table) == 7
  match list_head_or_default(ty_table, ast.TyAny) {
    ast.TyInt -> { assert true }
    _ -> { assert false }
  }
}

test "Row record carries labels, tail, and display_alias fields" {
  let r = ast.Row { labels: [], tail: None, display_alias: None }
  assert list_length(r.labels) == 0
  assert r.tail == None
  assert r.display_alias == None
}

test "RVBind constructs and preserves its (name, id) pair" {
  let rvb = ast.RVB("e", 0)
  match rvb {
    ast.RVB(n, i) -> {
      assert n == "e"
      assert i == 0
    }
  }
}

# Tiny helper used above so the test stays one-liner-friendly.
fn list_head_or_default(xs: [a], dflt: a) : a {
  match xs {
    [] -> dflt
    [h, ..._] -> h
  }
}

# Property checks — body must be Bool expression (see
# tests/test_chars.kai header note about kai info testing's
# misleading example).

check "mk_expr preserves line and col regardless of kind constructor" with n: Int {
  let e = ast.mk_expr(ast.EInt(n), 42, 7)
  e.line == 42 and e.col == 7
}

check "with_ty does not change the inner kind shape" with n: Int {
  let e0 = ast.mk_expr(ast.EInt(n), 1, 1)
  let e1 = ast.with_ty(e0, ast.TyInt)
  match e1.kind {
    ast.EInt(m) -> m == n
    _ -> false
  }
}

check "mk_pat round-trips its line / col" with n: Int {
  let p = ast.mk_pat(ast.PWild, n, n)
  p.line == n and p.col == n
}
