# compiler/util.kai unit tests — per-module tests for the low-level
# string / list helpers extracted under issue #677 Phase 1h (sub-lane
# H1a) to break the main.kai <-> refinements.kai import cycle.
#
# Coverage: every pub fn in util.kai. The helpers are pure and total,
# so the tests are direct input/output assertions plus a handful of
# property checks for the algebraic helpers (cat associativity-shape,
# string_lt order axioms, list_has membership).
#
# Runner: `../bin/kai test tests/test_util.kai` from stage2/, or
# `kai test stage2/.`. Tier 1 wiring deferred until #452 / #677
# Phase 2 lowers the per-test-file cost.

import compiler.util

# ---- cat2 / cat3 / cat4 / cat5 ----

test "cat2 concatenates two strings" {
  assert util.cat2("foo", "bar") == "foobar"
}

test "cat2 with empty left is identity" {
  assert util.cat2("", "bar") == "bar"
}

test "cat2 with empty right is identity" {
  assert util.cat2("foo", "") == "foo"
}

test "cat3 concatenates three strings in order" {
  assert util.cat3("a", "b", "c") == "abc"
}

test "cat4 concatenates four strings in order" {
  assert util.cat4("a", "b", "c", "d") == "abcd"
}

test "cat5 concatenates five strings in order" {
  assert util.cat5("a", "b", "c", "d", "e") == "abcde"
}

# ---- concat_all ----

test "concat_all of empty list is empty string" {
  assert util.concat_all([]) == ""
}

test "concat_all of a single element returns it" {
  assert util.concat_all(["solo"]) == "solo"
}

test "concat_all joins all elements with no separator" {
  assert util.concat_all(["a", "b", "c", "d"]) == "abcd"
}

# ---- append_char ----

test "append_char adds a char to the accumulator" {
  assert util.append_char("ab", 'c') == "abc"
}

test "append_char onto empty yields a one-char string" {
  assert util.append_char("", 'x') == "x"
}

# ---- char_at_or_zero ----

test "char_at_or_zero returns the char at an in-bounds index" {
  assert util.char_at_or_zero("abc", 0) == 'a'
}

test "char_at_or_zero returns the last char" {
  assert util.char_at_or_zero("abc", 2) == 'c'
}

test "char_at_or_zero returns the sentinel out of bounds" {
  assert util.char_at_or_zero("abc", 9) == 'x'
}

# ---- list_has ----

test "list_has finds a present element" {
  assert util.list_has(["a", "b", "c"], "b")
}

test "list_has misses an absent element" {
  assert not util.list_has(["a", "b", "c"], "z")
}

test "list_has on empty list is false" {
  assert not util.list_has([], "a")
}

# ---- list_is_empty ----

test "list_is_empty is true for the empty list" {
  assert util.list_is_empty([])
}

test "list_is_empty is false for a non-empty list" {
  assert not util.list_is_empty([1])
}

# ---- string_lt ----

test "string_lt orders a shorter prefix before its extension" {
  assert util.string_lt("ab", "abc")
}

test "string_lt orders by first differing char" {
  assert util.string_lt("abc", "abd")
}

test "string_lt is false when equal" {
  assert not util.string_lt("abc", "abc")
}

test "string_lt is false in the reverse direction" {
  assert not util.string_lt("abd", "abc")
}

test "string_lt places empty before any non-empty string" {
  assert util.string_lt("", "a")
}

# ---- escape_str_body_for_c ----

test "escape_str_body_for_c passes plain text through" {
  assert util.escape_str_body_for_c("hello") == "hello"
}

test "escape_str_body_for_c escapes a literal newline" {
  # build "a<NL>b" via append_char so the source stays single-line
  let body = util.append_char(util.append_char("a", '\n'), 'b')
  assert util.escape_str_body_for_c(body) == "a\\nb"
}

test "escape_str_body_for_c escapes a literal tab" {
  let body = util.append_char(util.append_char("a", '\t'), 'b')
  assert util.escape_str_body_for_c(body) == "a\\tb"
}

test "escape_str_body_for_c escapes a double quote" {
  let body = util.append_char(util.append_char("a", '"'), 'b')
  assert util.escape_str_body_for_c(body) == "a\\\"b"
}

# ---- property checks ----

check "cat2 left-identity: empty ++ s == s" with s: String {
  util.cat2("", s) == s
}

check "cat2 right-identity: s ++ empty == s" with s: String {
  util.cat2(s, "") == s
}

check "concat_all of a singleton equals the element" with s: String {
  util.concat_all([s]) == s
}

check "string_lt is irreflexive" with s: String {
  not util.string_lt(s, s)
}

check "string_lt is asymmetric on distinct singletons" with n: Int {
  let a = util.concat_all(["x", "#{n}"])
  let b = util.cat2(a, "y")
  not (util.string_lt(a, b) and util.string_lt(b, a))
}

check "list_has finds an element appended to a list" with s: String {
  util.list_has([s], s)
}
