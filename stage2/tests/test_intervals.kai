# compiler/intervals.kai unit tests — per-module tests for the
# integer interval lattice extracted under issue #677 Phase 1g.
#
# Coverage focuses on the pure lattice operations (top / bot /
# const / range / join / intersect / arithmetic / comparisons /
# environment helpers) — every fn that operates on `Interval`
# values without needing AST input. The post-typing propagation
# entry points (ival_of_expr, ival_of_decl, …) are exercised
# implicitly during every selfhost; per-shape AST testing would
# duplicate the parser + typer harness.
#
# Runner: `kai test stage2/.`. Tier 1 wiring deferred until
# #452 / #677 Phase 2 lowers the per-test-file cost.

import compiler.intervals

test "ival_const yields a singleton range" {
  match intervals.ival_const(5) {
    intervals.Ival(lo, hi) -> {
      assert lo == 5
      assert hi == 5
    }
    _ -> { assert false }
  }
}

test "ival_top is the top of the lattice" {
  match intervals.ival_top() {
    intervals.ITop -> { assert true }
    _ -> { assert false }
  }
}

test "ival_bot is the bottom of the lattice" {
  match intervals.ival_bot() {
    intervals.IBot -> { assert true }
    _ -> { assert false }
  }
}

test "ival_range builds an inclusive [lo, hi]" {
  match intervals.ival_range(3, 7) {
    intervals.Ival(lo, hi) -> {
      assert lo == 3
      assert hi == 7
    }
    _ -> { assert false }
  }
}

test "ival_join of bot with x is x" {
  let r = intervals.ival_join(intervals.ival_bot(), intervals.ival_const(4))
  match r {
    intervals.Ival(lo, hi) -> {
      assert lo == 4
      assert hi == 4
    }
    _ -> { assert false }
  }
}

test "ival_join of top with x is top" {
  let r = intervals.ival_join(intervals.ival_top(), intervals.ival_const(4))
  match r {
    intervals.ITop -> { assert true }
    _ -> { assert false }
  }
}

test "ival_join expands the union bounds" {
  let r = intervals.ival_join(intervals.ival_range(1, 3), intervals.ival_range(5, 7))
  match r {
    intervals.Ival(lo, hi) -> {
      assert lo == 1
      assert hi == 7
    }
    _ -> { assert false }
  }
}

test "ival_intersect of top with x is x" {
  let r = intervals.ival_intersect(intervals.ival_top(), intervals.ival_const(4))
  match r {
    intervals.Ival(lo, hi) -> {
      assert lo == 4
      assert hi == 4
    }
    _ -> { assert false }
  }
}

test "ival_intersect of bot with x is bot" {
  let r = intervals.ival_intersect(intervals.ival_bot(), intervals.ival_const(4))
  match r {
    intervals.IBot -> { assert true }
    _ -> { assert false }
  }
}

test "ival_add sums lower and upper bounds" {
  let r = intervals.ival_add(intervals.ival_range(1, 3), intervals.ival_range(10, 20))
  match r {
    intervals.Ival(lo, hi) -> {
      assert lo == 11
      assert hi == 23
    }
    _ -> { assert false }
  }
}

test "ival_sub subtracts upper from lower respectively" {
  let r = intervals.ival_sub(intervals.ival_range(10, 20), intervals.ival_range(1, 3))
  match r {
    intervals.Ival(lo, hi) -> {
      assert lo == 7
      assert hi == 19
    }
    _ -> { assert false }
  }
}

test "ival_mul of two positive ranges multiplies bounds" {
  let r = intervals.ival_mul(intervals.ival_range(2, 4), intervals.ival_range(3, 5))
  match r {
    intervals.Ival(lo, hi) -> {
      assert lo == 6
      assert hi == 20
    }
    _ -> { assert false }
  }
}

test "ival_lt is Some(true) when ranges are strictly ordered" {
  assert intervals.ival_lt(intervals.ival_range(1, 3), intervals.ival_range(5, 7)) == Some(true)
}

test "ival_lt is Some(false) when ranges overlap going the other way" {
  assert intervals.ival_lt(intervals.ival_range(5, 7), intervals.ival_range(1, 3)) == Some(false)
}

test "ival_lt is None when ranges overlap" {
  assert intervals.ival_lt(intervals.ival_range(1, 5), intervals.ival_range(3, 7)) == None
}

test "ival_eq is Some(true) for singleton equality" {
  assert intervals.ival_eq(intervals.ival_const(7), intervals.ival_const(7)) == Some(true)
}

test "ival_eq is Some(false) for disjoint singletons" {
  assert intervals.ival_eq(intervals.ival_const(1), intervals.ival_const(2)) == Some(false)
}

test "ival_ne mirrors ival_eq" {
  assert intervals.ival_ne(intervals.ival_const(1), intervals.ival_const(2)) == Some(true)
  assert intervals.ival_ne(intervals.ival_const(7), intervals.ival_const(7)) == Some(false)
}

test "ie_empty produces a lookup that returns ITop for any name" {
  let env = intervals.ie_empty()
  match intervals.ie_lookup(env, "nope") {
    intervals.ITop -> { assert true }
    _ -> { assert false }
  }
}

test "ie_extend then ie_lookup round-trip a value" {
  let env = intervals.ie_extend(intervals.ie_empty(), "x", intervals.ival_const(42))
  match intervals.ie_lookup(env, "x") {
    intervals.Ival(lo, hi) -> {
      assert lo == 42
      assert hi == 42
    }
    _ -> { assert false }
  }
}

test "ie_extend shadows earlier bindings of the same name" {
  let env0 = intervals.ie_extend(intervals.ie_empty(), "x", intervals.ival_const(1))
  let env1 = intervals.ie_extend(env0, "x", intervals.ival_const(2))
  match intervals.ie_lookup(env1, "x") {
    intervals.Ival(lo, hi) -> {
      assert lo == 2
      assert hi == 2
    }
    _ -> { assert false }
  }
}

# Property checks — body must be Bool expression (see header note
# in tests/test_chars.kai about kai info testing's misleading
# example).

check "ival_const(n) produces an Ival(n, n)" with n: Int {
  match intervals.ival_const(n) {
    intervals.Ival(lo, hi) -> lo == n and hi == n
    _ -> false
  }
}

check "ival_add is commutative on singleton ranges" with n: Int {
  let a = intervals.ival_const(n)
  let b = intervals.ival_const(5)
  let r1 = intervals.ival_add(a, b)
  let r2 = intervals.ival_add(b, a)
  match r1 {
    intervals.Ival(lo1, hi1) -> match r2 {
      intervals.Ival(lo2, hi2) -> lo1 == lo2 and hi1 == hi2
      _ -> false
    }
    _ -> false
  }
}

check "ival_join is reflexive" with n: Int {
  let iv = intervals.ival_const(n)
  match intervals.ival_join(iv, iv) {
    intervals.Ival(lo, hi) -> lo == n and hi == n
    _ -> false
  }
}

check "ival_intersect is reflexive" with n: Int {
  let iv = intervals.ival_const(n)
  match intervals.ival_intersect(iv, iv) {
    intervals.Ival(lo, hi) -> lo == n and hi == n
    _ -> false
  }
}

check "ival_int_min and ival_int_max agree on the same value" with n: Int {
  intervals.ival_int_min(n, n) == n and intervals.ival_int_max(n, n) == n
}
