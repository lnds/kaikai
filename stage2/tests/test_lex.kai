# compiler/lex.kai unit tests — per-module tests for the lexer
# extracted under issue #677 Phase 1e.
#
# Coverage focuses on the public entry point `tokenize` over
# small source fixtures. The intent is to exercise each TokKind
# family with at least one positive case so that any future
# refactor of the per-shape scanners (lex_ident / lex_number /
# lex_string / lex_punct / lex_regex / lex_char_literal /
# lex_dispatch) trips a test before it trips selfhost.
#
# Not in scope here:
#
#   - The full kaikai source corpus — that is what selfhost
#     itself is for; running the compiler over its own source
#     is the integration check.
#   - Error-path tokens (TkError). One smoke test covers them;
#     the negative-fixture harness wired into tier1 (see
#     examples/negative/) carries the systematic coverage.
#   - The token-dump and error-scanning helpers that live in
#     main.kai (they will move into a sibling module when
#     extracted).
#
# Runner: `kai test stage2/.`. The package compile dominates
# wall-clock time; tier1 wiring is deferred until #452 lands.

import compiler.lex
import compiler.chars

# Convenience: project the first token's TokKind.
fn first_kind(src: String) : lex.TokKind {
  match lex.tokenize(src) {
    [] -> lex.TkEof
    [t, ..._] -> t.kind
  }
}

test "tokenize of empty source yields just TkEof" {
  let ts = lex.tokenize("")
  match ts {
    [t] -> match t.kind {
      lex.TkEof -> { assert true }
      _ -> { assert false }
    }
    _ -> { assert false }
  }
}

test "integer literal lexes as TkInt" {
  match first_kind("42") {
    lex.TkInt -> { assert true }
    _ -> { assert false }
  }
}

test "real literal lexes as TkReal" {
  match first_kind("3.14") {
    lex.TkReal -> { assert true }
    _ -> { assert false }
  }
}

test "imaginary literal lexes as TkComplex" {
  match first_kind("2.5i") {
    lex.TkComplex -> { assert true }
    _ -> { assert false }
  }
}

test "string literal lexes as TkString" {
  match first_kind("\"hello\"") {
    lex.TkString -> { assert true }
    _ -> { assert false }
  }
}

test "char literal lexes as TkChar" {
  match first_kind("'a'") {
    lex.TkChar -> { assert true }
    _ -> { assert false }
  }
}

test "lowercase identifier lexes as TkIdent" {
  match first_kind("foo") {
    lex.TkIdent -> { assert true }
    _ -> { assert false }
  }
}

test "underscore alone lexes as TkUnderscore" {
  match first_kind("_") {
    lex.TkUnderscore -> { assert true }
    _ -> { assert false }
  }
}

test "keyword fn lexes as TkFn" {
  match first_kind("fn") {
    lex.TkFn -> { assert true }
    _ -> { assert false }
  }
}

test "keyword let lexes as TkLet" {
  match first_kind("let") {
    lex.TkLet -> { assert true }
    _ -> { assert false }
  }
}

test "keyword match lexes as TkMatch" {
  match first_kind("match") {
    lex.TkMatch -> { assert true }
    _ -> { assert false }
  }
}

test "keyword type lexes as TkType" {
  match first_kind("type") {
    lex.TkType -> { assert true }
    _ -> { assert false }
  }
}

test "keyword pub lexes as TkPub" {
  match first_kind("pub") {
    lex.TkPub -> { assert true }
    _ -> { assert false }
  }
}

test "true and false lex as the dedicated literal tokens" {
  match first_kind("true") {
    lex.TkTrue -> { assert true }
    _ -> { assert false }
  }
  match first_kind("false") {
    lex.TkFalse -> { assert true }
    _ -> { assert false }
  }
}

test "hash-open attribute syntax lexes as TkHashOpen" {
  match first_kind("#[derive(Show)]") {
    lex.TkHashOpen -> { assert true }
    _ -> { assert false }
  }
}

test "whitespace between tokens does not produce extra tokens" {
  let ts1 = lex.tokenize("foo")
  let ts2 = lex.tokenize("   foo   ")
  assert list_length(ts1) == list_length(ts2)
}

test "dollar lexes as TkDollar (reserved for compiler intrinsics)" {
  match first_kind("$") {
    lex.TkDollar -> { assert true }
    _ -> { assert false }
  }
}

test "malformed hex number lexes as TkError" {
  # `0x` with no following hex digits is a TkError (see lex_number's
  # documented invariant: prefix must be followed by at least one digit).
  let ts = lex.tokenize("0x")
  match ts {
    [t, ..._] -> match t.kind {
      lex.TkError(_) -> { assert true }
      _ -> { assert false }
    }
    [] -> { assert false }
  }
}

test "Token carries 1-indexed line and col" {
  match lex.tokenize("foo") {
    [t, ..._] -> {
      assert t.line == 1
      assert t.col == 1
    }
    [] -> { assert false }
  }
}

# Property checks — body is a Bool expression. See header note in
# test_chars.kai about the assert-inside-check sharp edge.

check "tokenize always yields a non-empty token list ending in TkEof" with s: String {
  let ts = lex.tokenize(s)
  match list_reverse(ts) {
    [] -> false
    [last, ..._] -> match last.kind {
      lex.TkEof -> true
      _ -> false
    }
  }
}

check "first token of an ASCII letter is always TkIdent or a keyword (not TkError)" with c: Char {
  if chars.ch_is_lower(c) {
    match lex.tokenize("#{c}") {
      [] -> false
      [t, ..._] -> match t.kind {
        lex.TkError(_) -> false
        _ -> true
      }
    }
  } else {
    true
  }
}
