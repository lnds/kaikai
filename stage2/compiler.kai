# Default Clock handler — three ops bridging to OS clocks via
# `clock_gettime(CLOCK_REALTIME, ...)` (wall_now), `clock_gettime
# (CLOCK_MONOTONIC, ...)` (monotonic_now), and `nanosleep` (sleep_ns).
# Installed when `main`'s row mentions `Clock`. The Clock effect
# itself is declared in stdlib/time.kai (not as a compiler builtin),
# so user code reaches this handler by `import time` + writing
# `time.now()` / `time.monotonic()` / `time.sleep(d)`. See
# `kai_default_clock_*` in stage0/runtime.h. m8.x follow-up: under
# the m8 v1 inline-eager scheduler `sleep_ns` blocks the OS thread
# and is not Cancel-aware; the cooperative scheduler upgrades it.
fn default_clock_shims() : String =
  concat_all([
    "static KaiValue *_kai_default_clock_wall_now_shim(EvClock *self, KaiCont *k) {\n",
    "    return kai_default_clock_wall_now(self, k);\n",
    "}\n",
    "static KaiValue *_kai_default_clock_monotonic_now_shim(EvClock *self, KaiCont *k) {\n",
    "    return kai_default_clock_monotonic_now(self, k);\n",
    "}\n",
    "static KaiValue *_kai_default_clock_sleep_ns_shim(EvClock *self, KaiValue *kai_ns, KaiCont *k) {\n",
    "    return kai_default_clock_sleep_ns(self, kai_ns, k);\n",
    "}\n"
  ])

fn default_clock_setup() : String =
  concat_all([
    "    static EvClock _kai_default_ev_clock;\n",
    "    static KaiEvidence _kai_default_node_clock;\n",
    "    _kai_default_ev_clock.handler_id = kai_fresh_handler_id();\n",
    "    _kai_default_ev_clock.wall_now      = &_kai_default_clock_wall_now_shim;\n",
    "    _kai_default_ev_clock.monotonic_now = &_kai_default_clock_monotonic_now_shim;\n",
    "    _kai_default_ev_clock.sleep_ns      = &_kai_default_clock_sleep_ns_shim;\n",
    "    kai_evidence_push(&_kai_default_node_clock, \"Clock\", &_kai_default_ev_clock);\n"
  ])

# Default Random handler — non-deterministic per-process PCG64
# seeded from time(NULL) ^ getpid() at first use. See
# `kai_default_random_int_range` in stage0/runtime.h.
fn default_random_shims() : String =
  concat_all([
    "static KaiValue *_kai_default_random_int_range_shim(EvRandom *self, KaiValue *kai_lo, KaiValue *kai_hi, KaiCont *k) {\n",
    "    return kai_default_random_int_range(self, kai_lo, kai_hi, k);\n",
    "}\n"
  ])

fn default_random_setup() : String =
  concat_all([
    "    static EvRandom _kai_default_ev_random;\n",
    "    static KaiEvidence _kai_default_node_random;\n",
    "    _kai_default_ev_random.handler_id = kai_fresh_handler_id();\n",
