    "    kai_evidence_push(&_kai_default_node_random, \"Random\", &_kai_default_ev_random);\n"
  ])

# net-tcp-v1: default NetTcp handler — POSIX sockets, blocking. Six
# ops wired to `kai_default_nettcp_*` in stage0/runtime.h. Installed
# whenever `main`'s row mentions `NetTcp` (or expands an alias that
# resolves to it). v1 limitations (IPv4-only, blocking, no listener
# close) live with the spec memo in stdlib/effects.kai.
fn default_nettcp_shims() : String =
  concat_all([
    "static KaiValue *_kai_default_nettcp_connect_shim(EvNetTcp *self, KaiValue *kai_host, KaiValue *kai_port, KaiCont *k) {\n",
    "    return kai_default_nettcp_connect(self, kai_host, kai_port, k);\n",
    "}\n",
    "static KaiValue *_kai_default_nettcp_listen_shim(EvNetTcp *self, KaiValue *kai_host, KaiValue *kai_port, KaiCont *k) {\n",
    "    return kai_default_nettcp_listen(self, kai_host, kai_port, k);\n",
    "}\n",
    "static KaiValue *_kai_default_nettcp_accept_shim(EvNetTcp *self, KaiValue *kai_listener, KaiCont *k) {\n",
    "    return kai_default_nettcp_accept(self, kai_listener, k);\n",
    "}\n",
    "static KaiValue *_kai_default_nettcp_send_shim(EvNetTcp *self, KaiValue *kai_conn, KaiValue *kai_bytes, KaiCont *k) {\n",
    "    return kai_default_nettcp_send(self, kai_conn, kai_bytes, k);\n",
    "}\n",
    "static KaiValue *_kai_default_nettcp_recv_shim(EvNetTcp *self, KaiValue *kai_conn, KaiValue *kai_max, KaiCont *k) {\n",
    "    return kai_default_nettcp_recv(self, kai_conn, kai_max, k);\n",
    "}\n",
    "static KaiValue *_kai_default_nettcp_close_shim(EvNetTcp *self, KaiValue *kai_conn, KaiCont *k) {\n",
    "    return kai_default_nettcp_close(self, kai_conn, k);\n",
    "}\n"
  ])

fn default_nettcp_setup() : String =
  concat_all([
    "    static EvNetTcp _kai_default_ev_nettcp;\n",
    "    static KaiEvidence _kai_default_node_nettcp;\n",
    "    _kai_default_ev_nettcp.handler_id = kai_fresh_handler_id();\n",
    "    _kai_default_ev_nettcp.connect = &_kai_default_nettcp_connect_shim;\n",
    "    _kai_default_ev_nettcp.listen  = &_kai_default_nettcp_listen_shim;\n",
    "    _kai_default_ev_nettcp.accept  = &_kai_default_nettcp_accept_shim;\n",
    "    _kai_default_ev_nettcp.send    = &_kai_default_nettcp_send_shim;\n",
    "    _kai_default_ev_nettcp.recv    = &_kai_default_nettcp_recv_shim;\n",
    "    _kai_default_ev_nettcp.close   = &_kai_default_nettcp_close_shim;\n",
    "    kai_evidence_push(&_kai_default_node_nettcp, \"NetTcp\", &_kai_default_ev_nettcp);\n"
  ])

# Issue #107: default Signal handler — three ops wired to
# `kai_default_signal_*` in stage0/runtime.h. Subscribed signals are
# blocked at the process level via sigprocmask; `await()` synchronously
# dequeues via sigwait. Installed when `main`'s row mentions `Signal`.
fn default_signal_shims() : String =
  concat_all([
    "static KaiValue *_kai_default_signal_on_shim(EvSignal *self, KaiValue *kai_sig, KaiCont *k) {\n",
    "    return kai_default_signal_on(self, kai_sig, k);\n",
    "}\n",
    "static KaiValue *_kai_default_signal_off_shim(EvSignal *self, KaiValue *kai_sig, KaiCont *k) {\n",
    "    return kai_default_signal_off(self, kai_sig, k);\n",
