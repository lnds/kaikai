    # dispatch table stays UBSan-clean.
    "static KaiValue *_kai_default_env_set_var_shim(EvEnv *self, KaiValue *kai_name, KaiValue *kai_value, KaiCont *k) {\n",
    "    return kai_default_env_set_var(self, kai_name, kai_value, k);\n",
