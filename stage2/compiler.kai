# stage 2: kaikai compiler, targeting full kaikai.
#
# Milestone 1 starts as a verbatim copy of stage 1's source. It is
# compiled by stage 1 (`../stage1/kaic1`) into `kaic2`, which behaves
# as a drop-in replacement for kaic1 — same tokens, same AST shape,
# same emitted C. From this baseline the compiler grows: HM-extended
# checker, LLVM backend, monomorphised generics, Perceus, modules,
# effects + handlers, fibers + scheduler, structured concurrency, and
# typed holes. See `docs/stage2-design.md`.
#
# Invariant during the early milestones: `make test` in stage2/ must
# pass by diffing every artefact against stage 1's output. Any stage 2
# feature that diverges must be explicitly gated behind a flag so the
# parity tests keep working until parity is retired (post self-host).

# ====================================================================
# char classification helpers
# ====================================================================
#
# These would naturally live in `stage2/chars.kai` now that the
# module system exists, but stage 1 (which compiles stage 2) does
# not resolve imports — partitioning the compiler is blocked until
# M6.1 is ported to stage 1 too. See
# `memory/project_stage0_bugs.md` and TODO notes for the plan.

fn ch_is_digit(c: Char) : Bool = c >= '0' and c <= '9'
fn ch_is_lower(c: Char) : Bool = c >= 'a' and c <= 'z'
fn ch_is_upper(c: Char) : Bool = c >= 'A' and c <= 'Z'
fn ch_is_alpha(c: Char) : Bool = ch_is_lower(c) or ch_is_upper(c) or c == '_'
fn ch_is_alnum(c: Char) : Bool = ch_is_alpha(c) or ch_is_digit(c)
fn ch_is_space(c: Char) : Bool = c == ' ' or c == '\t' or c == '\r'

# ====================================================================
# token kinds + tokens
# ====================================================================

type TokKind
  = TkEof
  | TkNewline
  # keywords (alphabetical)
  | TkAnd | TkAs | TkAssert | TkAxiom | TkBench | TkCase | TkCheck | TkConst | TkEffect | TkElse | TkEnsures | TkExtern | TkFalse | TkFn | TkFor
  | TkHandle | TkIf | TkImpl | TkImport
  | TkLet | TkMatch | TkNot | TkOr | TkProtocol | TkPub | TkRequires | TkTest | TkTrue | TkType
  | TkUnitKw | TkUse | TkVar | TkWhen | TkWhere | TkWith
  # m12.8: `#derive(P, ...)` annotation. The lexer recognises `#derive`
  # specifically (instead of treating it as a comment) so the parser can
  # consume it as a prefix to a `type` declaration.
  | TkDerive
  # m12.6.x #7: regex literal `/pattern/`, only emitted when the
  # previous non-newline token is the identifier `matches` (the
  # refinement-pure predicate). Outside that narrow context, `/` keeps
  # its arithmetic meaning as TkSlash. The token's source span covers
  # both delimiters so the parser can carve out the inner pattern with
  # `tok_source` + `string_slice`.
  | TkRegex
  # literals
  | TkInt | TkReal | TkChar | TkString
  # m12.x: numeric literal followed *immediately* (no whitespace) by
  # `i` lexes as TkComplex. The token span includes the trailing `i`;
  # the parser strips it before decoding the imaginary value as Real
  # and desugars to `complex.mk(0.0, im)`. Phase 1 of #267; full
  # `Real + Complex` heterogeneous arithmetic awaits #180.
  | TkComplex
  # identifiers
  | TkIdent | TkUnderscore
  # punctuation
  | TkLparen | TkRparen | TkLbracket | TkRbracket | TkLbrace | TkRbrace
  | TkComma | TkColon | TkColonEq | TkSemi | TkDot | TkDotDot | TkEllipsis
  # operators
  | TkEq | TkArrow | TkFatArrow | TkPipe | TkPipeApply | TkBarBar | TkPipeQuestion
  | TkPlus | TkMinus | TkStar | TkSlash | TkPercent
  # m7d §23: `++` is the string / list concatenation operator.
  # Right-associative, lower precedence than `+`/`-`/`*`/`/`,
  # higher than comparison.
  | TkPlusPlus
  | TkEqEq | TkNeq | TkLt | TkGt | TkLe | TkGe
  | TkBang | TkAt
  # m12.5: caret used for integer power inside unit expressions, e.g.
  # `m^2`, `sec^-1`. Reserved exclusively for unit syntax — outside
  # `<...>` annotations it is a parser error.
  | TkCaret
  # typed holes (M10): TkHole is a bare `?`; TkHoleName carries the
  # identifier for `?foo`. The lexer recognises `?ident` as one token
  # so the parser does not have to re-synthesise the form.
  | TkHole | TkHoleName(String)
  # m7d §1: `todo!` is a single token. The lexer recognises the
  # `todo` identifier followed immediately by `!` as `TkTodoBang`,
  # so the parser sees one symbol at the call site.
  | TkTodoBang
  # error token carries a human-readable message
  | TkError(String)

type Token = { kind: TokKind, line: Int, col: Int, start: Int, length: Int }

# Convenience constructor — fewer characters at call sites.
fn tok(kind: TokKind, line: Int, col: Int, start: Int, end: Int) : Token {
  Token { kind: kind, line: line, col: col, start: start, length: end - start }
}

# Mnemonic for token kinds (for --tokens dump). Keep in sync with TokKind.
fn tk_name(k: TokKind) : String {
  match k {
    TkEof -> "EOF"
    TkNewline -> "NEWLINE"
    TkAnd -> "and" TkAs -> "as" TkAssert -> "assert" TkAxiom -> "axiom" TkBench -> "bench" TkCase -> "case" TkCheck -> "check" TkConst -> "const" TkEffect -> "effect" TkElse -> "else"
    TkEnsures -> "ensures"
    TkExtern -> "extern"
    TkFalse -> "false" TkFn -> "fn" TkFor -> "for" TkHandle -> "handle"
    TkIf -> "if" TkImpl -> "impl" TkImport -> "import"
    TkLet -> "let" TkMatch -> "match" TkNot -> "not" TkOr -> "or"
    TkProtocol -> "protocol" TkPub -> "pub" TkRequires -> "requires"
    TkTest -> "test" TkTrue -> "true" TkType -> "type"
    TkUnitKw -> "unit" TkUse -> "use" TkVar -> "var" TkWhen -> "when" TkWhere -> "where" TkWith -> "with"
    TkDerive -> "#derive"
    TkRegex -> "REGEX"
    TkInt -> "INT" TkReal -> "REAL" TkChar -> "CHAR" TkString -> "STRING"
    TkComplex -> "COMPLEX"
    TkIdent -> "IDENT" TkUnderscore -> "_"
    TkLparen -> "(" TkRparen -> ")" TkLbracket -> "[" TkRbracket -> "]"
    TkLbrace -> "{" TkRbrace -> "}"
    TkComma -> "," TkColon -> ":" TkColonEq -> ":=" TkSemi -> ";"
    TkDot -> "." TkDotDot -> ".." TkEllipsis -> "..."
    TkEq -> "=" TkArrow -> "->" TkFatArrow -> "=>"
    TkPipe -> "|" TkPipeApply -> "|>" TkBarBar -> "||" TkPipeQuestion -> "|?"
    TkPlus -> "+" TkMinus -> "-" TkStar -> "*" TkSlash -> "/"
    TkPercent -> "%" TkPlusPlus -> "++"
    TkEqEq -> "==" TkNeq -> "!=" TkLt -> "<" TkGt -> ">"
    TkLe -> "<=" TkGe -> ">=" TkBang -> "!" TkAt -> "@" TkCaret -> "^"
    TkHole -> "?" TkHoleName(_) -> "?NAME"
    TkTodoBang -> "todo!"
    TkError(_) -> "ERROR"
  }
}

# ====================================================================
# lexer state + helpers
# ====================================================================

type Lexer = { src: String, pos: Int, line: Int, col: Int }

fn lex_new(src: String) : Lexer = Lexer { src: src, pos: 0, line: 1, col: 1 }

fn lex_at_end(l: Lexer) : Bool = l.pos >= string_length(l.src)

fn lex_peek_at(l: Lexer, off: Int) : Option[Char] =
  char_at(l.src, l.pos + off)

fn lex_peek(l: Lexer) : Option[Char] = lex_peek_at(l, 0)

fn lex_advance(l: Lexer) : Lexer {
  match char_at(l.src, l.pos) {
    None -> l
    Some(c) -> {
      if c == '\n' {
        Lexer { src: l.src, pos: l.pos + 1, line: l.line + 1, col: 1 }
      } else {
        Lexer { src: l.src, pos: l.pos + 1, line: l.line, col: l.col + 1 }
      }
    }
  }
}

# Pair of lexer state + emitted token. Used everywhere the scanner
# returns both a new position and a produced token.
type LexStep = Step(Lexer, Token)

# Returns true if the next char matches `want` (and does not consume it).
fn lex_peek_is(l: Lexer, want: Char) : Bool {
  match lex_peek(l) {
    None -> false
    Some(c) -> c == want
  }
}

fn lex_peek2_is(l: Lexer, want: Char) : Bool {
  match lex_peek_at(l, 1) {
    None -> false
    Some(c) -> c == want
  }
}

fn lex_peek3_is(l: Lexer, want: Char) : Bool {
  match lex_peek_at(l, 2) {
    None -> false
    Some(c) -> c == want
  }
}

# ====================================================================
# whitespace and comments
# ====================================================================

fn lex_skip_comment(l: Lexer) : Lexer {
  # `#` already consumed. Stop at newline or EOF; the newline itself is a
  # token and stays for the main loop to emit.
  match lex_peek(l) {
    None -> l
    Some(c) -> if c == '\n' { l } else { lex_skip_comment(lex_advance(l)) }
  }
}

fn lex_skip_ws(l: Lexer) : Lexer {
  match lex_peek(l) {
    None -> l
    Some(c) -> {
      if ch_is_space(c) { lex_skip_ws(lex_advance(l)) }
      else if c == '#' {
        # m12.8: `#derive` is a token, not a comment. Leave the `#`
        # in place so lex_punct can produce TkDerive. Anything else
        # starting with `#` is still a line comment.
        if lex_match_word_at(l, 1, "derive") { l }
        else { lex_skip_ws(lex_skip_comment(lex_advance(l))) }
      }
      else { l }
    }
  }
}

# m12.8: return true when `s` starts at offset `off` AND the character
# right after is not alphanumeric (so `#derive` matches `#derive(` but
# not `#deriveable`).
fn lex_match_word_at(l: Lexer, off: Int, s: String) : Bool {
  if not lex_match_str_at(l, off, s, 0) { false }
  else {
    let after = l.pos + off + string_length(s)
    match char_at(l.src, after) {
      None -> true
      Some(c) -> not ch_is_alnum(c)
    }
  }
}

fn lex_match_str_at(l: Lexer, off: Int, s: String, i: Int) : Bool {
  let n = string_length(s)
  if i >= n { true }
  else {
    match char_at(s, i) {
      None -> true
      Some(want) -> match char_at(l.src, l.pos + off + i) {
        None -> false
        Some(have) -> if have == want { lex_match_str_at(l, off, s, i + 1) } else { false }
      }
    }
  }
}

# ====================================================================
# identifiers and keywords
# ====================================================================

fn lex_scan_ident_rest(l: Lexer) : Lexer {
  match lex_peek(l) {
    None -> l
    Some(c) -> if ch_is_alnum(c) { lex_scan_ident_rest(lex_advance(l)) } else { l }
  }
}

fn keyword_kind(text: String) : TokKind {
  if text == "and" { TkAnd }
  else if text == "as" { TkAs }
  else if text == "assert" { TkAssert }
  else if text == "axiom" { TkAxiom }   # m12.7
  else if text == "bench" { TkBench }   # bench v1 (issue #40)
  else if text == "case" { TkCase }     # issue #415: multi-clause fn body
  else if text == "check" { TkCheck }   # check v1 (issue #44)
  else if text == "const" { TkConst }   # §29 / m12.6.x #const
  else if text == "effect" { TkEffect }
  else if text == "else" { TkElse }
  else if text == "ensures" { TkEnsures }   # m12.6.b
  else if text == "extern" { TkExtern }     # issue #260: FFI extern "C" fn
  else if text == "false" { TkFalse }
  else if text == "fn" { TkFn }
  else if text == "for" { TkFor }
  else if text == "handle" { TkHandle }
  else if text == "if" { TkIf }
  else if text == "impl" { TkImpl }
  else if text == "import" { TkImport }
  else if text == "let" { TkLet }
  else if text == "match" { TkMatch }
  else if text == "not" { TkNot }
  else if text == "or" { TkOr }
  else if text == "protocol" { TkProtocol }
  else if text == "pub" { TkPub }
  else if text == "requires" { TkRequires }  # m12.6.b
  else if text == "test" { TkTest }
  else if text == "true" { TkTrue }
  else if text == "type" { TkType }
  else if text == "unit" { TkUnitKw }   # m12.5
  else if text == "use" { TkUse }       # m7e §25
  else if text == "var" { TkVar }
  else if text == "when" { TkWhen }     # issue #415: multi-clause guard
  else if text == "where" { TkWhere }   # m12.6
  else if text == "with" { TkWith }
  else { TkIdent }
}

fn lex_ident(l: Lexer) : LexStep {
  let start = l.pos
  let sl = l.line
  let sc = l.col
  let l2 = lex_scan_ident_rest(l)
  let text = string_slice(l.src, start, l2.pos - start)
  # m7d §1: `todo!` lexes as a single token. We recognise the
  # identifier `todo` immediately followed by `!` (no whitespace)
  # so the parser sees `TkTodoBang` instead of `TkIdent` + `TkBang`.
  # The bang stays available as a postfix operator elsewhere (m7e §13).
  if text == "todo" and lex_peek_is(l2, '!') {
    let l3 = lex_advance(l2)
    Step(l3, tok(TkTodoBang, sl, sc, start, l3.pos))
  } else {
    let kind =
      if string_length(text) == 1 and text == "_" {
        TkUnderscore
      } else {
        keyword_kind(text)
      }
    Step(l2, tok(kind, sl, sc, start, l2.pos))
  }
}

# ====================================================================
# numbers
# ====================================================================

fn lex_scan_digits(l: Lexer) : Lexer {
  match lex_peek(l) {
    None -> l
    Some(c) -> {
      if ch_is_digit(c) or c == '_' { lex_scan_digits(lex_advance(l)) }
      else { l }
    }
  }
}

fn ch_is_hex_digit(c: Char) : Bool {
  ch_is_digit(c) or (c >= 'a' and c <= 'f') or (c >= 'A' and c <= 'F')
}

fn lex_scan_hex_digits(l: Lexer) : Lexer {
  match lex_peek(l) {
    None -> l
    Some(c) -> {
      if ch_is_hex_digit(c) { lex_scan_hex_digits(lex_advance(l)) }
      else { l }
    }
  }
}

fn lex_scan_bin_digits(l: Lexer) : Lexer {
  match lex_peek(l) {
    None -> l
    Some(c) -> {
      if c == '0' or c == '1' { lex_scan_bin_digits(lex_advance(l)) }
      else { l }
    }
  }
}

# Recognise `0x[0-9a-fA-F]+` and `0b[01]+` as TkInt.
# Caller has confirmed `lex_peek(l) == Some('0')` and the next char
# is one of x/X/b/B. Emits TkError if no digits follow the prefix.
fn lex_hex_or_bin_int(l: Lexer, is_hex: Bool, sl: Int, sc: Int, start: Int) : LexStep {
  # Skip the `0` and the base marker.
  let l_after_prefix = lex_advance(lex_advance(l))
  let l_end = if is_hex { lex_scan_hex_digits(l_after_prefix) }
              else { lex_scan_bin_digits(l_after_prefix) }
  if l_end.pos == l_after_prefix.pos {
    let msg = if is_hex { "malformed number: expected hex digits after 0x" }
              else { "malformed number: expected binary digits after 0b" }
    Step(l_end, tok(TkError(msg), sl, sc, start, l_end.pos))
  } else {
    Step(l_end, tok(TkInt, sl, sc, start, l_end.pos))
  }
}

fn lex_number(l: Lexer) : LexStep {
  let start = l.pos
  let sl = l.line
  let sc = l.col
  # Hex (`0x`/`0X`) and binary (`0b`/`0B`) literals branch off here so
  # they share TkInt with decimal and skip the float/exponent path below.
  let is_zero_prefix =
    match lex_peek(l) { Some(c) -> c == '0' _ -> false }
  if is_zero_prefix {
    match lex_peek_at(l, 1) {
      Some(n) -> {
        if n == 'x' or n == 'X' { lex_hex_or_bin_int(l, true, sl, sc, start) }
        else if n == 'b' or n == 'B' { lex_hex_or_bin_int(l, false, sl, sc, start) }
        else { lex_number_decimal(l, sl, sc, start) }
      }
      None -> lex_number_decimal(l, sl, sc, start)
    }
  } else {
    lex_number_decimal(l, sl, sc, start)
  }
}

fn lex_number_decimal(l: Lexer, sl: Int, sc: Int, start: Int) : LexStep {
  let l1 = lex_scan_digits(l)
  # Fractional part: only when `.` is followed by a digit. `x..y` (range)
  # and `x.field` (access) must be left alone.
  let after_frac_kind =
    if lex_peek_is(l1, '.') {
      match lex_peek_at(l1, 1) {
        Some(d) -> if ch_is_digit(d) { Some(true) } else { Some(false) }
        None -> Some(false)
      }
    } else {
      Some(false)
    }
  let l2 =
    match after_frac_kind {
      Some(true) -> lex_scan_digits(lex_advance(lex_advance(l1)))
      _ -> l1
    }
  let is_real1 = match after_frac_kind { Some(true) -> true _ -> false }
  # Exponent part: `e` or `E`, optional sign, digits.
  let has_exp =
    match lex_peek(l2) {
      Some(c) -> c == 'e' or c == 'E'
      None -> false
    }
  if has_exp {
    let l3 = lex_advance(l2)
    let l4 =
      match lex_peek(l3) {
        Some(c) -> if c == '+' or c == '-' { lex_advance(l3) } else { l3 }
        None -> l3
      }
    match lex_peek(l4) {
      Some(d) -> {
        if ch_is_digit(d) {
          let l5 = lex_scan_digits(l4)
          lex_maybe_complex_suffix(l5, sl, sc, start, TkReal)
        } else {
          Step(l4, tok(TkError("malformed number: expected digits after exponent"),
                       sl, sc, start, l4.pos))
        }
      }
      None -> {
        Step(l4, tok(TkError("malformed number: expected digits after exponent"),
                     sl, sc, start, l4.pos))
      }
    }
  } else {
    let kind = if is_real1 { TkReal } else { TkInt }
    lex_maybe_complex_suffix(l2, sl, sc, start, kind)
  }
}

# Phase 1 of #267 — after a complete numeric scan, peek for an
# *immediately adjacent* `i` and, if present, consume it and emit
# TkComplex. The token span covers the digits + `i` suffix; the
# parser strips the trailing `i` before decoding the imaginary value
# as Real. Whitespace before `i` already terminates the numeric scan,
# so `3 + i` and `for i in ...` continue to lex `i` as TkIdent.
fn lex_maybe_complex_suffix(l: Lexer, sl: Int, sc: Int, start: Int, fallback: TokKind) : LexStep {
  if lex_peek_is(l, 'i') {
    let l_after = lex_advance(l)
    Step(l_after, tok(TkComplex, sl, sc, start, l_after.pos))
  } else {
    Step(l, tok(fallback, sl, sc, start, l.pos))
  }
}

# ====================================================================
# strings
# ====================================================================

# Walk a string literal consuming chars until the closing `"` (or `"""`).
# Handles backslash escapes and `#{...}` interpolation (nested braces).
# Return the lexer positioned past the closing quote, plus the kind of
# token to emit (TkString or TkError(msg)).

type StrResult = StrOk(Lexer) | StrErr(Lexer, String)

# Skip past a nested {...} block inside interpolation, counting braces.
fn lex_skip_interp(l: Lexer, depth: Int) : StrResult {
  if depth == 0 { StrOk(l) }
  else {
    match lex_peek(l) {
      None -> StrErr(l, "unterminated interpolation in string")
      Some(c) -> {
        match c {
          '{' -> lex_skip_interp(lex_advance(l), depth + 1)
          '}' -> lex_skip_interp(lex_advance(l), depth - 1)
          '"' -> {
            # Skip a nested string literal inside the interpolation.
            match lex_skip_inner_string(lex_advance(l)) {
              StrOk(l2) -> lex_skip_interp(l2, depth)
              StrErr(l2, msg) -> StrErr(l2, msg)
            }
          }
          _ -> lex_skip_interp(lex_advance(l), depth)
        }
      }
    }
  }
}

fn lex_skip_inner_string(l: Lexer) : StrResult {
  match lex_peek(l) {
    None -> StrErr(l, "unterminated string inside interpolation")
    Some(c) -> {
      match c {
        '"' -> StrOk(lex_advance(l))
        '\\' -> {
          let l1 = lex_advance(l)
          match lex_peek(l1) {
            None -> StrErr(l1, "unterminated string inside interpolation")
            Some(_) -> lex_skip_inner_string(lex_advance(l1))
          }
        }
        _ -> lex_skip_inner_string(lex_advance(l))
      }
    }
  }
}

fn lex_string_body(l: Lexer, triple: Bool) : StrResult {
  match lex_peek(l) {
    None -> StrErr(l, "unterminated string")
    Some(c) -> {
      if c == '\\' {
        let l1 = lex_advance(l)
        match lex_peek(l1) {
          None -> StrErr(l1, "unterminated string")
          Some(_) -> lex_string_body(lex_advance(l1), triple)
        }
      } else if c == '#' and lex_peek2_is(l, '{') {
        let l1 = lex_advance(lex_advance(l))
        match lex_skip_interp(l1, 1) {
          StrOk(l2) -> lex_string_body(l2, triple)
          StrErr(l2, msg) -> StrErr(l2, msg)
        }
      } else if triple {
        if c == '"' and lex_peek2_is(l, '"') and lex_peek3_is(l, '"') {
          StrOk(lex_advance(lex_advance(lex_advance(l))))
        } else {
          lex_string_body(lex_advance(l), triple)
        }
      } else {
        if c == '\n' {
          StrErr(l, "unterminated string (newline in single-line string)")
        } else if c == '"' {
          StrOk(lex_advance(l))
        } else {
          lex_string_body(lex_advance(l), triple)
        }
      }
    }
  }
}

fn lex_string(l: Lexer) : LexStep {
  let start = l.pos
  let sl = l.line
  let sc = l.col
  let l1 = lex_advance(l)                  # consume opening "
  let triple = lex_peek_is(l1, '"') and lex_peek2_is(l1, '"')
  let l2 = if triple { lex_advance(lex_advance(l1)) } else { l1 }
  match lex_string_body(l2, triple) {
    StrOk(l3) -> Step(l3, tok(TkString, sl, sc, start, l3.pos))
    StrErr(l3, msg) -> Step(l3, tok(TkError(msg), sl, sc, start, l3.pos))
  }
}

# ====================================================================
# regex literals (m12.6.x #7)
# ====================================================================
#
# Elixir-style sigil: `~r/pattern/` lexes as a single `TkRegex` token
# whose source span covers the full sigil including delimiters. The
# `~` route in `lex_punct` handles the prefix; this helper takes
# over once the cursor is positioned at the opening `/`. Because
# the prefix is unambiguous, `/` keeps its arithmetic meaning
# everywhere else — no contextual lookback in the lexer, no parser
# backtracking.
#
# Pattern body rules: any byte except an unescaped `/` or unescaped
# newline; `\` escapes the next byte; inside `[...]` a `/` is a
# literal class element, not a terminator (mirrors JS / Pony / Perl
# regex literal lexing).

fn lex_regex(l: Lexer, sl: Int, sc: Int, start: Int) : LexStep {
  let l1 = lex_advance(l)                  # consume opening /
  match lex_regex_body(l1, false) {
    StrOk(l2) -> Step(l2, tok(TkRegex, sl, sc, start, l2.pos))
    StrErr(l2, msg) -> Step(l2, tok(TkError(msg), sl, sc, start, l2.pos))
  }
}

# `in_class` is true when the cursor is inside a `[...]` character
# class, where `/` and `]` swap their meaning relative to the outer
# state.
fn lex_regex_body(l: Lexer, in_class: Bool) : StrResult {
  match lex_peek(l) {
    None -> StrErr(l, "unterminated regex literal")
    Some(c) -> {
      if c == '\\' {
        let l1 = lex_advance(l)
        match lex_peek(l1) {
          None -> StrErr(l1, "unterminated regex literal")
          Some(_) -> lex_regex_body(lex_advance(l1), in_class)
        }
      } else if c == '\n' {
        StrErr(l, "unterminated regex literal (newline before closing `/`)")
      } else if in_class {
        if c == ']' { lex_regex_body(lex_advance(l), false) }
        else { lex_regex_body(lex_advance(l), true) }
      } else {
        if c == '/' { StrOk(lex_advance(l)) }
        else if c == '[' { lex_regex_body(lex_advance(l), true) }
        else { lex_regex_body(lex_advance(l), false) }
      }
    }
  }
}

# ====================================================================
# char literals
# ====================================================================

fn lex_char_skip_u_escape(l: Lexer) : Lexer {
  # We're past `\u`; consume `{HHHH}`.
  match lex_peek(l) {
    None -> l
    Some(c) -> {
      if c == '}' { lex_advance(l) }
      else { lex_char_skip_u_escape(lex_advance(l)) }
    }
  }
}

fn lex_char(l: Lexer) : LexStep {
  let start = l.pos
  let sl = l.line
  let sc = l.col
  let l1 = lex_advance(l)                 # consume opening '
  match lex_peek(l1) {
    None -> Step(l1, tok(TkError("unterminated char literal"),
                         sl, sc, start, l1.pos))
    Some(c) -> {
      let l2 =
        if c == '\\' {
          let la = lex_advance(l1)
          match lex_peek(la) {
            None -> la
            Some(e) -> {
              if e == 'u' and lex_peek2_is(la, '{') {
                lex_char_skip_u_escape(lex_advance(lex_advance(la)))
              } else {
                lex_advance(la)
              }
            }
          }
        } else {
          # One byte of a UTF-8 codepoint. For the stage-0-compatible
          # subset we treat multi-byte characters structurally: consume
          # one byte and trust the closing quote to appear.
          lex_advance(l1)
        }
      if lex_peek_is(l2, '\'') {
        Step(lex_advance(l2), tok(TkChar, sl, sc, start, l2.pos + 1))
      } else {
        Step(l2, tok(TkError("unterminated char literal"),
                     sl, sc, start, l2.pos))
      }
    }
  }
}

# ====================================================================
# punctuation and operators
# ====================================================================

fn lex_punct(l: Lexer) : LexStep {
  let start = l.pos
  let sl = l.line
  let sc = l.col
  match lex_peek(l) {
    None -> Step(l, tok(TkEof, sl, sc, start, start))
    Some(c) -> {
      let l1 = lex_advance(l)
      match c {
        '(' -> Step(l1, tok(TkLparen, sl, sc, start, l1.pos))
        ')' -> Step(l1, tok(TkRparen, sl, sc, start, l1.pos))
        '[' -> Step(l1, tok(TkLbracket, sl, sc, start, l1.pos))
        ']' -> Step(l1, tok(TkRbracket, sl, sc, start, l1.pos))
        '{' -> Step(l1, tok(TkLbrace, sl, sc, start, l1.pos))
        '}' -> Step(l1, tok(TkRbrace, sl, sc, start, l1.pos))
        ',' -> Step(l1, tok(TkComma, sl, sc, start, l1.pos))
        '@' -> Step(l1, tok(TkAt, sl, sc, start, l1.pos))
        # m12.5: caret token for unit exponents — only meaningful inside
        # `<...>` annotations; the parser rejects it elsewhere.
        '^' -> Step(l1, tok(TkCaret, sl, sc, start, l1.pos))
        ':' -> {
          if lex_peek_is(l1, '=') {
            let l2 = lex_advance(l1)
            Step(l2, tok(TkColonEq, sl, sc, start, l2.pos))
          } else {
            Step(l1, tok(TkColon, sl, sc, start, l1.pos))
          }
        }
        ';' -> Step(l1, tok(TkSemi, sl, sc, start, l1.pos))
        '+' -> {
          # m7d §23: `++` is the concatenation operator. The lexer
          # fuses two adjacent `+` characters into a single token; a
          # space breaks it (so `1 + +2` is still allowed if anyone
          # writes it).
          if lex_peek_is(l1, '+') {
            let l2 = lex_advance(l1)
            Step(l2, tok(TkPlusPlus, sl, sc, start, l2.pos))
          } else {
            Step(l1, tok(TkPlus, sl, sc, start, l1.pos))
          }
        }
        '*' -> Step(l1, tok(TkStar, sl, sc, start, l1.pos))
        '%' -> Step(l1, tok(TkPercent, sl, sc, start, l1.pos))
        '-' -> {
          if lex_peek_is(l1, '>') {
            let l2 = lex_advance(l1)
            Step(l2, tok(TkArrow, sl, sc, start, l2.pos))
          } else {
            Step(l1, tok(TkMinus, sl, sc, start, l1.pos))
          }
        }
        '/' -> {
          if lex_peek_is(l1, '/') {
            # Issue #315 — `//` integer division operator is removed.
            # Post-#246, `Int / Int` already truncates via `Div[Int]`.
            let l2 = lex_advance(l1)
            Step(l2, tok(TkError("`//` operator is removed (issue #315) — use `/` instead (Int / Int truncates)"),
                         sl, sc, start, l2.pos))
          } else {
            Step(l1, tok(TkSlash, sl, sc, start, l1.pos))
          }
        }
        '=' -> {
          if lex_peek_is(l1, '=') {
            let l2 = lex_advance(l1)
            Step(l2, tok(TkEqEq, sl, sc, start, l2.pos))
          } else if lex_peek_is(l1, '>') {
            let l2 = lex_advance(l1)
            Step(l2, tok(TkFatArrow, sl, sc, start, l2.pos))
          } else {
            Step(l1, tok(TkEq, sl, sc, start, l1.pos))
          }
        }
        '<' -> {
          if lex_peek_is(l1, '=') {
            let l2 = lex_advance(l1)
            Step(l2, tok(TkLe, sl, sc, start, l2.pos))
          } else {
            Step(l1, tok(TkLt, sl, sc, start, l1.pos))
          }
        }
        '>' -> {
          if lex_peek_is(l1, '=') {
            let l2 = lex_advance(l1)
            Step(l2, tok(TkGe, sl, sc, start, l2.pos))
          } else {
            Step(l1, tok(TkGt, sl, sc, start, l1.pos))
          }
        }
        '!' -> {
          if lex_peek_is(l1, '=') {
            let l2 = lex_advance(l1)
            Step(l2, tok(TkNeq, sl, sc, start, l2.pos))
          } else {
            Step(l1, tok(TkBang, sl, sc, start, l1.pos))
          }
        }
        '?' -> {
          # `?ident` is one TkHoleName token; `?` alone is TkHole.
          # Peek at the next char: if it's alpha (or `_`), read an
          # identifier.
          match lex_peek(l1) {
            Some(nc) -> {
              if ch_is_alpha(nc) {
                let l_end = lex_scan_ident_rest(lex_advance(l1))
                let name = string_slice(l.src, start + 1, l_end.pos - (start + 1))
                Step(l_end, tok(TkHoleName(name), sl, sc, start, l_end.pos))
              } else {
                Step(l1, tok(TkHole, sl, sc, start, l1.pos))
              }
            }
            None -> Step(l1, tok(TkHole, sl, sc, start, l1.pos))
          }
        }
        '|' -> {
          if lex_peek_is(l1, '>') {
            let l2 = lex_advance(l1)
            Step(l2, tok(TkPipeApply, sl, sc, start, l2.pos))
          } else if lex_peek_is(l1, '|') {
            # issue #201: `||` (no whitespace between bars) is the
            # flat-map pipe. Single token so the parser sees one symbol
            # at the operator slot, mirroring how `|>` is one token.
            let l2 = lex_advance(l1)
            Step(l2, tok(TkBarBar, sl, sc, start, l2.pos))
          } else if lex_peek_is(l1, '?') {
            # issue #412: `|?` (no whitespace between bar and question)
            # is the filter pipe. Single token, mirroring `|>` and `||`.
            let l2 = lex_advance(l1)
            Step(l2, tok(TkPipeQuestion, sl, sc, start, l2.pos))
          } else {
            Step(l1, tok(TkPipe, sl, sc, start, l1.pos))
          }
        }
        '.' -> {
          if lex_peek_is(l1, '.') and lex_peek2_is(l1, '.') {
            let l2 = lex_advance(lex_advance(l1))
            Step(l2, tok(TkEllipsis, sl, sc, start, l2.pos))
          } else if lex_peek_is(l1, '.') {
            let l2 = lex_advance(l1)
            Step(l2, tok(TkDotDot, sl, sc, start, l2.pos))
          } else {
            Step(l1, tok(TkDot, sl, sc, start, l1.pos))
          }
        }
        '#' -> {
          # m12.8: `#derive` is a single token; the `#` here cannot be a
          # comment because lex_skip_ws only forwards `#` here when it is
          # immediately followed by `derive` and a non-alphanumeric tail.
          let l_end = lex_advance_n(l1, 6)
          Step(l_end, tok(TkDerive, sl, sc, start, l_end.pos))
        }
        '~' -> {
          # m12.6.x #7: Elixir-style sigils. Currently only `~r/pattern/`
          # is recognised — opens a regex literal that lexes as a single
          # `TkRegex` token spanning `~r/.../`. The sigil family is
          # designed for future growth (`~s`, `~w`, etc.) but those
          # require their own runtime carriers and are out of scope
          # for this lane. Anything other than `~r` followed by a
          # delimiter falls through as an error so tildes don't silently
          # turn into a junk-drawer prefix.
          if lex_peek_is(l1, 'r') and lex_peek_at(l1, 1) == Some('/') {
            let l_r = lex_advance(l1)            # consume `r`
            lex_regex(l_r, sl, sc, start)
          } else {
            let msg = string_concat("unexpected character '~' (only `~r/.../` regex sigil is supported)", "")
            Step(l1, tok(TkError(msg), sl, sc, start, l1.pos))
          }
        }
        _ -> {
          let msg = string_concat("unexpected character '", string_concat("#{c}", "'"))
          Step(l1, tok(TkError(msg), sl, sc, start, l1.pos))
        }
      }
    }
  }
}

fn lex_advance_n(l: Lexer, n: Int) : Lexer {
  if n <= 0 { l } else { lex_advance_n(lex_advance(l), n - 1) }
}

# ====================================================================
# dispatch: one token
# ====================================================================

fn lex_next(l: Lexer) : LexStep {
  let l0 = lex_skip_ws(l)
  let sl = l0.line
  let sc = l0.col
  match lex_peek(l0) {
    None -> Step(l0, tok(TkEof, sl, sc, l0.pos, l0.pos))
    Some(c) -> {
      if c == '\n' {
        let l1 = lex_advance(l0)
        Step(l1, tok(TkNewline, sl, sc, l0.pos, l1.pos))
      }
      else if ch_is_alpha(c) { lex_ident(l0) }
      else if ch_is_digit(c) { lex_number(l0) }
      else if c == '"' { lex_string(l0) }
      else if c == '\'' { lex_char(l0) }
      else { lex_punct(l0) }
    }
  }
}

# Build the full token list. Accumulate in reverse for O(1) prepend, then
# list_reverse once at the end.
fn lex_loop(l: Lexer, acc: [Token]) : [Token] {
  match lex_next(l) {
    Step(l1, t) -> {
      let acc1 = [t, ...acc]
      match t.kind {
        TkEof -> list_reverse(acc1)
        _ -> lex_loop(l1, acc1)
      }
    }
  }
}

fn tokenize(src: String) : [Token] {
  lex_loop(lex_new(src), [])
}

# ====================================================================
# token dump (for --tokens)
# ====================================================================

fn tok_text(src: String, t: Token) : String = string_slice(src, t.start, t.length)

fn tok_line_str(t: Token) : String = int_to_string(t.line)
fn tok_col_str(t: Token)  : String = int_to_string(t.col)

fn dump_token(src: String, t: Token) : Unit / Console {
  match t.kind {
    TkNewline -> print("#{tok_line_str(t)}:#{tok_col_str(t)}  NEWLINE")
    TkError(msg) -> eprint("#{tok_line_str(t)}:#{tok_col_str(t)}  ERROR  #{msg}")
    _ -> {
      let text = tok_text(src, t)
      print("#{tok_line_str(t)}:#{tok_col_str(t)}  #{tk_name(t.kind)}  \"#{text}\"")
    }
  }
}

fn dump_tokens(src: String, tokens: [Token]) : Unit {
  tokens |> each((t) => dump_token(src, t))
}

# ====================================================================
# diagnostics
# ====================================================================
#
# Rust-style source snippets for error reporting. A diagnostic site
# (file, line, col) renders as:
#
#     error: <msg>
#       --> foo.kai:5:12
#        |
#      5 | let x = bar(42)
#        |         ^
#
# Caret is placed by byte column, which matches the (line, col) kept
# on tokens and AST nodes. Multi-byte characters in source therefore
# shift the caret rightwards of the logical glyph — acceptable for
# the ASCII-heavy code we compile, and easy to replace later with
# a codepoint-aware locator.

# Build a string of `n` spaces in a single allocation via string_slice.
# Sidesteps the O(n²) fold of string_concat(acc, " "). 128 is the
# widest line-number gutter we plausibly print; grow on demand.
fn spaces(n: Int) : String {
  if n <= 0 { "" }
  else if n <= 128 { string_slice(spaces_pool(), 0, n) }
  else { string_concat(spaces_pool(), spaces(n - 128)) }
}

fn spaces_pool() : String =
  "                                                                                                                                "

# Extract the `n`-th (1-indexed) line from `src`, without the trailing
# newline. Two passes of char_at to locate [start, end) in the source,
# then a single string_slice — avoids the O(m²) per-char acc build.
fn nth_line(src: String, n: Int) : Option[String] {
  if n <= 0 { None }
  else {
    let total = string_length(src)
    let start = nth_line_start(src, 0, total, 1, n)
    if start < 0 { None }
    else {
      let end = scan_to_newline(src, start, total)
      Some(string_slice(src, start, end - start))
    }
  }
}

# Walk forward returning the byte offset where the target'th line
# starts, or -1 if the source ends first.
fn nth_line_start(src: String, i: Int, total: Int, cur: Int, target: Int) : Int {
  if cur == target { i }
  else if i >= total { -1 }
  else {
    match char_at(src, i) {
      None -> -1
      Some(c) -> {
        if c == '\n' { nth_line_start(src, i + 1, total, cur + 1, target) }
        else { nth_line_start(src, i + 1, total, cur, target) }
      }
    }
  }
}

fn scan_to_newline(src: String, i: Int, total: Int) : Int {
  if i >= total { total }
  else {
    match char_at(src, i) {
      None -> total
      Some(c) -> if c == '\n' { i } else { scan_to_newline(src, i + 1, total) }
    }
  }
}

# Render a snippet to stderr. `src` is the source of the entry file;
# for imported modules we re-read on the fly (see emit_source_caret).
fn emit_src_snippet(line: Int, col: Int, src_line: String) : Unit / Console {
  let num = int_to_string(line)
  let margin = spaces(string_length(num))
  eprint("  #{margin} |")
  eprint("  #{num} | #{src_line}")
  let caret_gap = if col > 1 { spaces(col - 1) } else { "" }
  eprint("  #{margin} | #{caret_gap}^")
}

fn emit_source_caret_from_src(src: String, line: Int, col: Int) : Unit / Console {

  match nth_line(src, line) {
    None       -> ()
    Some(text) -> emit_src_snippet(line, col, text)
  }
}

# Self-contained variant: takes a path, reads it, and emits the
# snippet. Used by diagnostics that don't already have the source
# threaded through (most checker/infer sites).
fn emit_source_caret(file: String, line: Int, col: Int) : Unit / File + Console {

  match read_file(file) {
    Err(_)  -> ()
    Ok(src) -> emit_source_caret_from_src(src, line, col)
  }
}

fn diag_error(file: String, line: Int, col: Int, msg: String) : Unit / Console + File {

  eprint("error: #{msg}")
  eprint("  --> #{file}:#{int_to_string(line)}:#{int_to_string(col)}")
  emit_source_caret(file, line, col)
}

# m4c Phase 3 invariant report types. Defined here so
# `report_mono_leaks` (next fn) can reference `LR` / `LL` despite
# stage 1's order-sensitive type resolution. The walkers that build
# these values live near `monomorphise` (single-source-of-truth for
# the Phase 3 invariant pass).
type LeakLoc = MLeakAt(Int, Int, String)
type MLeakRecord = MLeakRec(String, Int, Option[LeakLoc])

fn diag_note(msg: String) : Unit / Console = eprint("  = note: #{msg}")
fn diag_help(msg: String) : Unit / Console = eprint("  = help: #{msg}")

# Issue #487 — structured diagnostic surface (Approach A, narrow scope).
# Defines the data types LSP v1 (#447) needs to publish diagnostics
# via the JSON-RPC `textDocument/publishDiagnostics` notification.
#
# Scope discipline: only the m11 v1 + v1.x templates (T1-T5) are wired
# into the collection path. The remaining ~140 legacy diag_* call-sites
# keep stderr-only behavior and migrate lane by lane.
#
# `Severity` mirrors the LSP severity scale (Error=1, Warning=2,
# Information=3, Hint=4). Kaikai uses symbolic variants so future tiers
# (warnings, hints) plug in without renaming.
type Severity
  = SevError
  | SevWarning
  | SevHint
  | SevInfo

# `RelatedInfo` captures the `note:` / `help:` follow-ups attached to
# a primary diagnostic. Each carries its own (file, line, col, message)
# so LSP can render them at independent ranges if the related site is
# elsewhere; today the typer pins notes at the parent diagnostic's
# location, so most RelatedInfo values share the parent (line, col).
type RelatedInfo = DR(String, Int, Int, String)
# (file, line, col, message). Variant tag is `DR` (diagnostic-related)
# because stage 2 uses a single global variant-tag namespace and `RI`
# was already taken by `type RecInfo = RI(String, [String], [FieldDecl])`
# at line 26701. LSP serialization sees the field positions, not the
# tag, so the shorter `DR` name has no impact on the wire format.

# `Diagnostic` is the structured value the LSP consumer reads from
# `TypedProgram.diags`. Field shape:
#   severity : Severity
#   file     : String   (source file path)
#   line     : Int      (1-indexed; -1 when the diagnostic has no span)
#   col      : Int      (1-indexed; -1 when no column)
#   message  : String   (primary `error:` line, no prefix)
#   related  : [RelatedInfo]  (the `note:` / `help:` lines)
type Diagnostic = D(Severity, String, Int, Int, String, [RelatedInfo])

fn severity_to_string(s: Severity) : String = match s {
  SevError   -> "error"
  SevWarning -> "warning"
  SevHint    -> "hint"
  SevInfo    -> "info"
}

# Build a primary `Diagnostic` value. Used by the T1-T5 emit sites in
# parallel with their existing `diag_error/note/help` calls — the stderr
# stream is unchanged; only the in-memory collection is new.
fn mk_diag(sev: Severity, file: String, line: Int, col: Int,
            msg: String, related: [RelatedInfo]) : Diagnostic =
  D(sev, file, line, col, msg, related)

fn ri_note(file: String, line: Int, col: Int, msg: String) : RelatedInfo =
  DR(file, line, col, string_concat("note: ", msg))

fn ri_help(file: String, line: Int, col: Int, msg: String) : RelatedInfo =
  DR(file, line, col, string_concat("help: ", msg))

# `[Diagnostic]` accumulator helpers — push, finalize. Diagnostics are
# stored in reverse insertion order inside the accumulator so a prepend
# is O(1); the entry point flips them back to source order via
# `finalize_diags` before exposing through `TypedProgram.diags`.
fn push_diag(acc: [Diagnostic], d: Diagnostic) : [Diagnostic] = [d, ...acc]

fn finalize_diags(acc: [Diagnostic]) : [Diagnostic] = list_reverse(acc)

# m4c Phase 3 invariant reporter: print one diag per spec leak,
# return total leak count (0 = clean). Lives near `diag_error` so
# its row is `Console`-only and the caller's row inference picks it
# up cleanly.
fn report_mono_leaks(file: String, rs: [MLeakRecord]) : Int / Console + File {

  match rs {
    [] -> 0
    [r, ...rest] -> match r {
      MLeakRec(name, n, loc) -> {
        let loc_s = match loc {
          Some(MLeakAt(line, col, ty_s)) ->
            concat_all([" first at ", int_to_string(line), ":",
                        int_to_string(col), " ty=", ty_s])
          None -> ""
        }
        diag_error(file, 0, 0,
          concat_all(["m4c Phase 3 invariant: spec '", name,
                       "' has ", int_to_string(n),
                       " TyVarT/UVar leak(s) in body Expr.ty",
                       loc_s]))
        n + report_mono_leaks(file, rest)
      }
    }
  }
}

# Levenshtein edit distance for "did you mean?" suggestions. Plain
# DP over rows, immutable — each row is a freshly-built list. Small
# strings + small scope means cost is negligible in practice; we
# only pay on the error path.

fn min3(a: Int, b: Int, c: Int) : Int {
  let ab = if a < b { a } else { b }
  if ab < c { ab } else { c }
}

fn row_at(xs: [Int], i: Int) : Int {
  match xs {
    [] -> 0
    [h, ...rest] -> if i == 0 { h } else { row_at(rest, i - 1) }
  }
}

fn row_head(xs: [Int]) : Int {
  match xs {
    [] -> 0
    [h, ..._rest] -> h
  }
}

fn int_range_list(lo: Int, hi: Int) : [Int] = int_range_list_loop(lo, hi, [])

fn int_range_list_loop(i: Int, hi: Int, acc: [Int]) : [Int] {
  if i >= hi { list_reverse(acc) }
  else { int_range_list_loop(i + 1, hi, [i, ...acc]) }
}

fn char_eq_at(a: String, ai: Int, b: String, bi: Int) : Bool {
  match char_at(a, ai) {
    None -> false
    Some(ac) -> match char_at(b, bi) {
      None -> false
      Some(bc) -> ac == bc
    }
  }
}

fn lev_row_loop(a: String, b: String, i: Int, n: Int,
                prev: [Int], j: Int, acc: [Int]) : [Int] {
  if j > n { list_reverse(acc) }
  else {
    let cost = if char_eq_at(a, i - 1, b, j - 1) { 0 } else { 1 }
    let above = row_at(prev, j)         # d[i-1][j]
    let left  = row_head(acc)           # d[i][j-1]
    let diag  = row_at(prev, j - 1)     # d[i-1][j-1]
    let cell  = min3(above + 1, left + 1, diag + cost)
    lev_row_loop(a, b, i, n, prev, j + 1, [cell, ...acc])
  }
}

fn lev_row(a: String, b: String, i: Int, n: Int, prev: [Int]) : [Int] =
  lev_row_loop(a, b, i, n, prev, 1, [i])

fn lev_rows(a: String, b: String, m: Int, n: Int, i: Int, prev: [Int]) : Int {
  if i > m { row_at(prev, n) }
  else { lev_rows(a, b, m, n, i + 1, lev_row(a, b, i, n, prev)) }
}

fn levenshtein(a: String, b: String) : Int {
  let m = string_length(a)
  let n = string_length(b)
  let row0 = int_range_list(0, n + 1)
  lev_rows(a, b, m, n, 1, row0)
}

# Return the candidate whose Levenshtein distance to `target` is
# smallest, provided it's within `max_dist`. If several tie, keep
# the first one in order (matches insertion order of the scope,
# which is nearest-first by virtue of list prepending).
fn abs_int(n: Int) : Int = if n < 0 { 0 - n } else { n }

fn closest_name_loop(target: String, cands: [String], max_dist: Int,
                     best: Option[String], best_d: Int) : Option[String] {
  match cands {
    [] -> best
    [c, ...rest] -> {
      let la = string_length(target)
      let lb = string_length(c)
      if abs_int(la - lb) > max_dist {
        closest_name_loop(target, rest, max_dist, best, best_d)
      } else {
        let d = levenshtein(target, c)
        if d < best_d and d <= max_dist {
          closest_name_loop(target, rest, max_dist, Some(c), d)
        } else {
          closest_name_loop(target, rest, max_dist, best, best_d)
        }
      }
    }
  }
}

fn closest_name(target: String, cands: [String]) : Option[String] {
  # Cap at 3 to keep suggestions confident; otherwise completely
  # unrelated names start showing up on short identifiers.
  closest_name_loop(target, cands, 3, None, 999999)
}

fn diag_error_from_src(file: String, src: String, line: Int, col: Int, msg: String) : Unit / Console {
  eprint("error: #{msg}")
  eprint("  --> #{file}:#{int_to_string(line)}:#{int_to_string(col)}")
  emit_source_caret_from_src(src, line, col)
}

# ====================================================================
# error scanning
# ====================================================================

fn report_one_error(path: String, src: String, t: Token, msg: String) : Unit / Console =

  diag_error_from_src(path, src, t.line, t.col, msg)

fn report_errors_loop(path: String, src: String, ts: [Token], count: Int) : Int / Console {

  match ts {
    [] -> count
    [t, ...rest] -> match t.kind {
      TkError(msg) -> {
        report_one_error(path, src, t, msg)
        report_errors_loop(path, src, rest, count + 1)
      }
      _ -> report_errors_loop(path, src, rest, count)
    }
  }
}

# Returns 0 on success, 1 if any TkError tokens appeared (all reported to stderr).
fn report_errors(path: String, src: String, tokens: [Token]) : Int / Console {

  if report_errors_loop(path, src, tokens, 0) > 0 { 1 } else { 0 }
}

# ====================================================================
# AST types
# ====================================================================

# Expressions carry their source position on the wrapper, so variants
# stay compact. Pattern matching on expressions therefore destructures
# the record to reach `.kind`, then matches the sum.

# `mode` records the value representation chosen for this node by the
# unbox analysis pass (Tier 2.5; see `docs/unboxing-phase2-design.md`).
# Parser stamps every `Expr` with `MUnknown`; the unbox pass rewrites
# nodes whose type is unboxable and whose consumer accepts a raw scalar
# to `MUnboxed`, otherwise `MBoxed`. The emitter consults `mode` to
# pick between `KaiValue *` and the underlying C scalar (`int64_t` /
# `int` / `uint32_t`). Phase 1 of the lane (this commit) lands the
# field with codegen unchanged; the pass + emitter switches arrive in
# subsequent milestones.
type Expr = { kind: ExprKind, line: Int, col: Int,
              ty: Option[Ty], mode: ValueMode }

type ValueMode
  = MUnknown   # parser default; unbox_pass assigns one of the below
  | MBoxed     # KaiValue * (current behaviour everywhere)
  | MUnboxed   # raw int64_t / int / uint32_t, chosen by `ty`

type ExprKind
  = EInt(Int)
  | EReal(Real)
  | EBool(Bool)
  | EChar(Char)
  | EStr(String, Bool)                      # raw source span (includes quotes), is_triple
  | EUnit
  | EVar(String)
  | EUnder                                  # `_` (pattern context only, but lexer produces it anywhere)
  | EPlaceholder                            # `.` placeholder (stage 1 extension; stage 0 rejects)
  | ECall(Expr, [Expr])
  | EField(Expr, String)
  | EIndex(Expr, Expr)
  | EBinop(String, Expr, Expr)
  | EUnop(String, Expr)                     # "-" or "not"
  | EIf(Expr, Expr, Option[Expr])
  | EMatch(Expr, [Arm])
  | ELambda([Param], Expr)
  | ERecordLit(String, [FieldInit])
  | EList([ListElem])
  | ERange(Expr, Expr, Option[Expr])
  | EBlock([Stmt], Option[Expr])
  | EPipe(Expr, Expr)
  # issue #201: `xs | f` — map-pipe. Until #201 the parser desugared
  # `|` straight to `ECall(EVar("map"), [xs, f])`. The new shape keeps
  # the surface visible to the typer so `|` and `||` can dispatch by
  # the LHS's head type via the head-type-to-module map. The typer
  # rewrites `EMapPipe` into `ECall(EModCall(<module>, "map"), …)` once
  # the head type is known. Codegen never sees `EMapPipe` directly —
  # it sees the rewritten ECall.
  | EMapPipe(Expr, Expr)
  # issue #201: `xs || f` — flat-map-pipe. Same dispatch rule as
  # `EMapPipe` but looks up `flat_map` in the head's declaring module.
  | EFlatMapPipe(Expr, Expr)
  # issue #412: `xs |? p` — filter-pipe. Same dispatch rule as
  # `EMapPipe` but looks up `filter` in the head's declaring module.
  # The typer rewrites `EFilterPipe` into
  # `ECall(EModCall(<module>, "filter"), …)` once the head type is known.
  | EFilterPipe(Expr, Expr)
  # Typed hole (M10). `None` payload → anonymous `?`. `Some(name)` →
  # `?name`. Checker reports at each hole site; emitter falls back
  # to a runtime panic so unfilled holes in a binary are loud.
  | EHole(Option[String])
  # m7d §1: `todo!(msg) : T` — a typed *unimplemented* marker. The
  # message is a literal `String` extracted at parse time. Behaves
  # like `EHole(None)` for inference (any expected type fits) and
  # like a panic at runtime, but the checker reports it under a
  # distinct `kind = "todo"` so tooling can tell `?` apart from
  # "I will fill this in" markers.
  | ETodo(String)
  # m7e §13: `expr!` — postfix `Option`/`Result` propagation.
  # `e!` on `Option[T]` unwraps `Some(x) -> x`; `None` short-circuits
  # with `return None` from the enclosing function. On `Result[E, T]`,
  # `Ok(x) -> x`; `Err(e)` short-circuits with `return Err(e)`. The
  # enclosing function's return type must be the matching `Option[U]`
  # or `Result[E, U]` (same E — no `From`-style coercion). The typer
  # validates the enclosing return type and stamps `x.ty` with the
  # unwrapped success type, which the emitter consumes to choose the
  # correct discriminator (`Some` / `Ok`).
  | EBang(Expr)
  # Effect handler (m7a #4b). `handle { body } with Eff [as alias]
  # { clauses [return(x) -> expr] }`. The `alias` (Option[String])
  # rebinds the capability name inside the body. m7a #4b is parser
  # only; type-checking and runtime are #4d / #6.
  # m7b #11: parametric effects. `eff_tyargs` is the `[T1, T2]` after
  # the effect name in `with Reader[Int]` (empty when none); `init_opt`
  # is the `(init)` after the type args in `with State[Int](0)` form
  # (None when the handler is stateless). Both extensions are inert
  # for stateless effects, so existing handlers parse to `[]` /
  # `None` and behave as before.
  | EHandle(Expr, String, [TypeExpr], Option[Expr], Option[String], [HClause], Option[HReturn])
  # m12.5: numeric literal annotated with a unit, e.g. `1.50<USD>` or
  # `42<UserId>`. The inner Expr is always EInt or EReal; the
  # UnitExprT comes from the source between the angle brackets.
  | ELitUnit(Expr, UnitExprT)
  # m7e §11: `variants[T]()` — enumerate the constructors of a sum
  # type T whose every variant is nullary. The compiler has the
  # constructor list after resolution; this node is a request to
  # materialise it as a `[T]` literal in declaration order. The
  # `()` suffix is required by the syntax but carries no payload —
  # the parser rejects any argument list. Parser produces this via
  # an explicit lookahead in `parse_ident_primary` when the source
  # ident is `variants` and the next token is `[`. Resolver
  # validates T (sum + nullary-only). Emitter materialises the
  # ordered constructor list.
  #
  # The second field carries the resolved variant names. Parser
  # leaves it `[]`; the typer fills it in `synth_variants_of` once
  # T has been validated as a nullary-only sum. The emitter consumes
  # the list directly — it has no env access to look the names up
  # itself.
  | EVariantsOf(TypeExpr, [String])
  # m6.2: qualified module call. The resolver pass rewrites
  # `EField(EVar(mod), fn)` to this variant when `mod` is unbound
  # locally and bound in the module table (rule B — locals shadow
  # imports). Phase 2.1 only adds the variant + the walker arms;
  # the rewrite logic and typer/codegen support land in 2.3 / 2.4
  # / 3 respectively. Until then, this variant is never constructed
  # at runtime — every walker arm exists purely to keep the
  # exhaustive matches valid.
  | EModCall(String, String)

type ListElem = ElPlain(Expr) | ElSpread(Expr)

type Arm = Arm(Pattern, Option[Expr], Expr)

type FieldInit = FI(String, Expr)

type Param = { pname: String, ptype: Option[TypeExpr], pline: Int, pcol: Int }

type Stmt
  = SLet(Pattern, Option[TypeExpr], Expr)
  | SAssert(Expr, Option[Expr])
  | SExprStmt(Expr)
  # m7b #6: indexed write `a[i] := v` (with `a` an `Ident ("." Ident)*`
  # field path). Lowered to a `Mutable.array_set`-style call by the
  # pre-resolve `desugar_index_assign` pass; never reaches the checker.
  | SIndexAssign(Expr, Expr, Expr, Int, Int)
  # m7b #5: local mutable cell `var name [: T] = init`. The parser
  # produces this node; the pre-resolve `desugar_var_decls` pass
  # rewrites every block containing an SVar into the canonical
  # `handle { rest } with State[T](init) as name { canonical clauses }`
  # form (Doc B §`State[T]` *Syntax note*, Doc C §m7b #5). SVar
  # therefore never reaches the resolver. The line/col point at the
  # `var` keyword.
  | SVar(String, Option[TypeExpr], Expr, Int, Int)
  # m7e §25: `use Effect` at block scope — opens the effect's ops
  # for bare-name resolution in the rest of the enclosing block.
  # Same desugar pass as DUse handles both file-scope and block-
  # scope opens. The line/col point at the `use` keyword.
  | SUse(String, Int, Int)

type Pattern = { pkind: PatKind, line: Int, col: Int }

type PatKind
  = PWild
  | PLit(Expr)                              # literal pattern (stores an Expr of literal shape)
  | PBind(String)
  | PList([Pattern], Option[String])         # fixed sub-patterns, optional rest binder name
  | PVariant(String, [Pattern])
  | PVariantRecord(String, [PField])
  | PRecord([PField])
  | PHole(Option[String])                   # `?` or `?name` in pattern position
  # m7d §14: `name @ pattern` — bind the whole scrutinee to `name`
  # while still destructuring it as `pattern`. The bound name must
  # be a fresh identifier; the inner pattern's bindings (if any)
  # remain visible in the arm body. Disjoint from m7b §2's prefix
  # `@cap` (an expression), which never appears in pattern position.
  | PAs(String, Pattern)
  # issue #187 phase 3: type-narrowing pattern `name : T`. Used over a
  # union scrutinee to bind `name` at component type `T`; covers every
  # variant of `T` for exhaustiveness purposes. The parser emits this
  # for every `name : TyName(t, ...)` arm-pattern suffix, including
  # refinement-type aliases — `lower_pattern_narrow_decls` rewrites
  # the alias case back into `PBind` + `__ref_pred_t(name)` guard so
  # m12.6.x semantics are preserved. What survives into the typer is
  # always a non-refinement narrowing over a union component.
  | PNarrow(String, TypeExpr)

type PField = PField(String, Pattern, Bool) # field name, sub-pattern, is_shorthand

type TypeExpr = { tkind: TyKind, line: Int, col: Int }

type TyKind
  = TyName(String, [TypeExpr])              # Name or Name[T1, T2, ...]
  | TyList(TypeExpr)
  | TyFn([TypeExpr], TypeExpr, RowExpr)
  # m12.5: dimensioned numeric type, e.g. `Real<USD>` or `Int<m/sec>`.
  # The base TypeExpr is the underlying primitive (parser only ever
  # produces this with `Real`/`Int` underneath); the UnitExprT carries
  # the unit annotation that the typer canonicalises and unifies.
  | TyDim(TypeExpr, UnitExprT)
  # m12.6: refinement type, `BaseT where Predicate(self)`. The predicate
  # is parsed as an Expr in the same expression grammar as the rest of
  # the language; m12.6.b/c restrict it to the decidable subset and
  # use it for compile-time + runtime contract verification. m12.6.a
  # only stores the syntactic form; resolve_ty drops the refinement
  # so it does not affect inference / unification yet.
  | TyRefine(TypeExpr, Expr)

# Syntactic effect row: REmpty for `T` (no `/`), RClosed for `T / Io
# + Fail`, ROpen for `T / Io + e` or `T / e` where the lowercase tail
# `e` is a row variable scoped to the enclosing function declaration
# (m7b #12). In the AST this is the *raw* parsed shape; resolve_ty
# converts it into the semantic `Row` that lives inside `TyFnT`.
#
# m7b #11: each label carries optional type arguments (`Reader[Int]`
# parses as `RL("Reader", [TyName("Int", [])])`). Stateless effects
# (and pre-m7b #11 syntax) carry an empty arg list. ROpen merges m7b
# #11 (parametric labels) with m7b #12 (open row variable in tail).
type RowExpr = REmpty | RClosed([RowLabel]) | ROpen(String, [RowLabel])
type RowLabel = RL(String, [TypeExpr])

# m12.5: units of measure. UnitExprT is a tree of unit operations.
# The canonicaliser flattens it to a sorted vector of (sym, exponent).
# UVar appears only at the semantic level — the parser produces only
# the other shapes; UVar is allocated by the unifier for unit
# inference variables (parallel to TyVarT).
type UnitExprT
  = UOne                                    # the dimensionless unit "1"
  | USym(String)                            # atomic unit name (USD, m, kg)
  | UMul(UnitExprT, UnitExprT)              # product
  | UInv(UnitExprT)                          # multiplicative inverse
  | UPow(UnitExprT, Int)                     # integer power
  | UVar(Int)                                # unit unification variable

# m12.5: kind of a type parameter. KType is the default; KUnit marks a
# parameter that ranges over units rather than types (`[u: Measure]`).
# The surface keyword is `Measure` (issue #253: disambiguates from
# `Unit` the void-return type). The internal AST tag and "#Unit"
# suffix encoding are unchanged to minimise blast radius — they are
# not user-visible. Kinds are encoded inside the tparam name with a
# "#Unit" suffix so the existing `tparams: [String]` plumbing keeps
# working unchanged.
type Kind = KType | KUnit

# Handler clause (op): `op_name(args..., resume) -> body`. The
# resume binding is conventionally the last param; m7a #4d will
# validate. m7a #4b stores the param list verbatim.
type HClause = HC(String, [Param], Expr, Int, Int)

# Optional `return(x) -> expr` clause inside a handle. `pname` is
# the parameter name bound inside `body`.
type HReturn = HR(String, Expr, Int, Int)

type Decl
  # m7b #13: optional type parameters on the function declaration —
  # `pub fn id[T](x: T) : T = x`. Empty list for monomorphic decls.
  # Each name in tparams is a quantified type variable in scope across
  # the param types, return type, row, and body. Generalised in
  # fn_scheme_of_decl so each call site fresh-instantiates.
  #
  # m6.2 v2: trailing `Option[String]` is the *module origin* — the
  # surface name of the module that owns this decl, or None for
  # decls authored in the root file. expand_imports + the prelude
  # loader populate it (every imported / preloaded decl gets a
  # `Some(<surface_name>)`); the parser produces only `None`. The
  # codegen mints `kai_<m>__<name>` for `Some(m)` and `kai_<name>`
  # for `None`, which lets two modules export the same bare name
  # without a linker collision and lets a root-file `fn sum`
  # silently shadow `pub fn sum` exported by a prelude.
  = DFn(Bool, String, [String], [Param], Option[TypeExpr], RowExpr, Expr, Int, Int, Option[String])
  | DType(Bool, String, [String], TypeBody, Int, Int)
  | DTest(String, Expr, Int, Int)
  # bench v1 (issue #40): mirrors DTest but the runner times the body.
  # Fields: description (raw quoted span), body, line, col.
  | DBench(String, Expr, Int, Int)
  # check v1 (issue #44): property-based check block. Mirrors DTest +
  # DBench but the body is run N times with random inputs generated
  # from the parameter type list. Fields: description (raw quoted
  # span), `with`-clause params (each carrying an explicit type), body
  # (must produce Bool), line, col.
  | DCheck(String, [Param], Expr, Int, Int)
  | DImport(ImportKind, Int, Int)
  # m7b #11: optional type parameters on the effect declaration —
  # `effect Reader[T] { ask() : T }`. Empty list for stateless effects.
  | DEffect(Bool, String, [String], [EffectOp], Int, Int)
  # m12.8: `protocol P { op_decls }` — single-dispatch ad-hoc
  # polymorphism. Each ProtoOp carries a parameter list using `Self`
  # as the first-position dispatch type. Defaults are not parsed in
  # the v1 (the parser only accepts bodyless op signatures).
  # Issue #180: optional [A1, A2, ...] type parameter list bound at
  # protocol declaration scope (alongside the implicit `Self`). The
  # impl-table key remains `(P, Self)` — `Ai` resolve at impl-site.
  | DProtocol(Bool, String, [String], [ProtoOp], Int, Int)
  # m12.8: `impl P for T { fn op(args) = body ... }` — supplies the
  # ops of protocol `pname` for the concrete type `target`. The body
  # decls live as ordinary DFns whose name is the op name (no
  # mangling at parse time; the lower-protocols pass renames them to
  # `__pimpl_<P>_<T>_<op>`).
  # Issue #180: optional [T1, T2, ...] type-arg list (the protocol's
  # `[A1, ...]` parameters monomorphised at this impl-site). Empty
  # list means the legacy un-parametrised form `impl P for X`, which
  # the resolver treats as `impl P[X] for X` (`Ai := Self`).
  | DImpl(String, [TypeExpr], TypeExpr, [Decl], Int, Int)
  # m12.8: `#derive(P, ...) type T = ...` — opt-in structural impl
  # generator. The lower-protocols pass walks the type body and
  # synthesises one DImpl per derived protocol. The parser keeps the
  # annotation alongside the wrapped DType so the desugar pass has all
  # the data in one node.
  | DDerive([String], Decl, Int, Int)
  # m12.6.x #5(a): `[<refinement_pure>]` attribute on a fn signature.
  # Wraps a DFn so the post-parse `extract_pure_names_decls` walker
  # can collect the marked names; the validator pass then admits
  # calls to these names inside contract / refinement predicates.
  # The wrapper is unwrapped before any other Decl walker runs.
  | DAttribPure(Decl, Int, Int)
  # m12.5: unit declaration. `unit USD` (alias = None) introduces an
  # atomic unit symbol; `unit Newton = kg * m / sec^2` (alias = Some)
  # introduces a named alias whose RHS the resolver expands eagerly
  # before unification ever runs. Codegen emits nothing for DUnit.
  | DUnit(Bool, String, Option[UnitExprT], Int, Int)
  # m7e §25: `use Effect` at file scope — opens the effect's ops
  # for bare-name resolution in every fn body of the file. The
  # resolver desugar_use_decls expands every `EVar(name)` matching
  # an opened op into `EField(EVar(eff), name)`. Ambiguity (two
  # opened effects expose the same op name) is a hard error.
  # `use` does NOT remove the cap from the row — the effect still
  # appears in any caller's row annotation.
  | DUse(String, Int, Int)
  # m12.7: `axiom name[tparams](params) : T / row` — postulate a
  # typed symbol with no body. Useful for FFI declarations,
  # architectural placeholders, and selfhost scaffolding while a
  # real definition is pending. Calling an axiom at runtime aborts
  # via the same `todo!` trap (m7d §1) the lower pass synthesises:
  # "any type fits" at inference, `kai_prelude_panic` at runtime.
  # `lower_axioms` rewrites every DAxiom to a DFn with the panic
  # body BEFORE any other Decl walker runs, so downstream passes
  # only see DFn. Doc: `docs/proposed-extensions.md` §4.
  #
  # m12.7.x FFI v1: a `[<extern_c>]` attribute prefix flips the
  # second `Bool` field on. When set, `lower_axiom_one` synthesises
  # a real FFI shim body (an `ETodo` whose message is the magic
  # tag `__kai_ffi__`) instead of the panic. The C / LLVM emitters
  # detect that tag inside `emit_fn_body` and lower the body to a
  # direct `extern "C"` call against the named symbol, so call
  # sites of the form `puts("hi")` link straight to libc without
  # any wrapper allocation.
  #
  # Issue #260: the surface syntax for FFI is now `extern "C" fn
  # name(...) : T / Ffi`, equivalent to the old `[<extern_c>] axiom`
  # form (which is rejected with a migration error). The `extern_c`
  # flag stays as the underlying mechanism.
  #
  # Issue #261: the third `String` field carries an optional
  # C-symbol override. Empty string means "no override — emit the
  # kaikai identifier verbatim as the C symbol". A non-empty value
  # (e.g. "InitWindow") means "emit that C symbol instead". Only
  # meaningful when `extern_c` is true.
  | DAxiom(Bool, Bool, String, String, [String], [Param], TypeExpr, RowExpr, Int, Int)
  # Issue #269: `const NAME : T = expr` — top-level named constant.
  # Replaces the earlier `DAttribPure(DFn arity-0)` desugar that
  # treated every const as a parameterless function and pushed it
  # into bare-name dispatch ranking. DConst binds the name
  # monomorphically (`name : T`, no scheme, no instantiation) so
  # const reads are global loads, not function calls, and consts
  # never become dispatch candidates. Fields: is_pub, name,
  # declared type, body expression, line, col. Today body is always
  # a literal (number / string / list literal) — the kaikai const
  # surface only allows literals.
  | DConst(Bool, String, TypeExpr, Expr, Int, Int)

# m12.8: a single operation declared inside a `protocol P { ... }`
# block. Mirrors EffectOp's shape (no body, with optional generic
# tparams), but lives in its own type so the resolver / typer can
# distinguish protocol ops from effect ops cleanly.
type ProtoOp = POp(String, [String], [Param], TypeExpr, Int, Int)

# An operation declared inside an `effect Eff { ... }` block.
# name[op_tparams](params) : ret_ty — no body, no `fn` keyword.
# m7b #2: per-op type generics. `op_tparams` is the optional
# `[T1, T2]` between op name and `(args)`. Empty for monomorphic
# ops; non-empty when the op signature itself quantifies over
# types (Doc B §`Mutable`'s `array_get[T]`, etc.).
type EffectOp = EOp(String, [String], [Param], TypeExpr, Int, Int)

# TBEffectAlias holds a closed sum of effect labels, e.g.
# `type Io = Console + Stdin + Env + File` (m7b #1). The body is a
# list of label names; non-effect labels and cycles are rejected at
# resolve time. Single-effect aliases (`type Foo = Console`) parse as
# TBAlias(TyName(name, [])) and are recognised at resolve time.
type TypeBody = TBAlias(TypeExpr) | TBRecord([FieldDecl]) | TBSum([Variant]) | TBEffectAlias([String])
type FieldDecl = FD(String, TypeExpr)
type Variant = Var(String, [TypeExpr])

type ImportKind
  = IkPath(String)
  | IkAlias(String, String)
  | IkSelective(String, [String])
  # m7f §7: `import ?name` — dependency hole. The compiler scans
  # known stdlib modules (and modules in the search path) for a
  # `pub fn name` and reports candidates so the user can replace
  # the hole with an explicit module path. The hole itself does
  # NOT load any module — it is a diagnostic-only construct that
  # downstream passes drop after the symbol index runs.
  | IkHole(String)

# ---- small constructors ----
fn mk_expr(k: ExprKind, line: Int, col: Int) : Expr =
  Expr { kind: k, line: line, col: col, ty: None, mode: MUnknown }

# Return a copy of `e` with its inferred type set. Used by `synth` to
# hand back a typed expression tree alongside its Ty. Downstream passes
# (emitter today ignores it; M3/M4 will consume) can traverse the tree
# and read `.ty` at each node without re-running inference.
fn with_ty(e: Expr, t: Ty) : Expr =
  Expr { kind: e.kind, line: e.line, col: e.col, ty: Some(t), mode: e.mode }
fn mk_pat(k: PatKind, line: Int, col: Int) : Pattern = Pattern { pkind: k, line: line, col: col }
fn mk_ty(k: TyKind, line: Int, col: Int) : TypeExpr = TypeExpr { tkind: k, line: line, col: col }

# ====================================================================
# parser state
# ====================================================================
#
# The Parser is immutable; each helper returns a new one with `rest`
# advanced and `had_error` possibly flipped. We don't carry a token
# index — `rest` is the unconsumed suffix of the token list, so
# p_advance is O(1) (takes tail). Peek-ahead uses list destructuring
# up to depth 3, which covers every lookahead stage 0 does.

type Parser = { file: String, src: String, rest: [Token], had_error: Bool,
                # m7b §1: trailing lambdas attach to Calls, but the
                # condition of `if` / `match` (and similar prefix
                # constructs that take an Expr followed by a `{`-block)
                # must not consume the `{` as a trailing lambda. This
                # flag is set to false while parsing such a cond and
                # restored when the cond parser finishes.
                allow_trailing_lambda: Bool }

# A result = a new parser plus an optional payload. `None` means the
# parser failed (had_error is set on `p`). This mirrors stage 0's
# error-then-stop style.

type PExpr   = { p: Parser, r: Option[Expr] }
type PStmt   = { p: Parser, r: Option[Stmt] }
type PPat    = { p: Parser, r: Option[Pattern] }
type PTy     = { p: Parser, r: Option[TypeExpr] }
type PDecl   = { p: Parser, r: Option[Decl] }
type PArm    = { p: Parser, r: Option[Arm] }
type PParam  = { p: Parser, r: Option[Param] }
type PFI     = { p: Parser, r: Option[FieldInit] }
type PVar    = { p: Parser, r: Option[Variant] }
type PFD     = { p: Parser, r: Option[FieldDecl] }
type PPF     = { p: Parser, r: Option[PField] }
type PEL     = { p: Parser, r: Option[ListElem] }

fn parser_new(file: String, src: String, toks: [Token]) : Parser =
  Parser { file: file, src: src, rest: toks, had_error: false, allow_trailing_lambda: true }

fn p_mark_err(p: Parser) : Parser =
  Parser { file: p.file, src: p.src, rest: p.rest, had_error: true,
           allow_trailing_lambda: p.allow_trailing_lambda }

fn p_advance(p: Parser) : Parser {
  match p.rest {
    [_, ...rest1] -> Parser { file: p.file, src: p.src, rest: rest1,
                              had_error: p.had_error,
                              allow_trailing_lambda: p.allow_trailing_lambda }
    [] -> p
  }
}

# A sentinel EOF token used when peeking past the list end. In practice
# the tokenizer always appends a TkEof, so we rarely hit this.
fn eof_tok() : Token = Token { kind: TkEof, line: 0, col: 0, start: 0, length: 0 }

fn p_peek(p: Parser) : Token {
  match p.rest {
    [t, ..._rs] -> t
    [] -> eof_tok()
  }
}

fn p_peek1(p: Parser) : Token {
  match p.rest {
    [_, t, ..._rs] -> t
    _ -> eof_tok()
  }
}

fn p_peek2(p: Parser) : Token {
  match p.rest {
    [_, _, t, ..._rs] -> t
    _ -> eof_tok()
  }
}

# Token-kind comparison by structural case (TkError is the only payload-
# carrying variant, and we never compare it for equality in the parser).
fn tk_is(a: TokKind, b: TokKind) : Bool {
  match a {
    TkEof        -> match b { TkEof -> true _ -> false }
    TkNewline    -> match b { TkNewline -> true _ -> false }
    TkAnd        -> match b { TkAnd -> true _ -> false }
    TkAs         -> match b { TkAs -> true _ -> false }
    TkAssert     -> match b { TkAssert -> true _ -> false }
    TkAxiom      -> match b { TkAxiom -> true _ -> false }
    TkBench      -> match b { TkBench -> true _ -> false }
    TkCase       -> match b { TkCase -> true _ -> false }
    TkCheck      -> match b { TkCheck -> true _ -> false }
    TkConst      -> match b { TkConst -> true _ -> false }
    TkEffect     -> match b { TkEffect -> true _ -> false }
    TkElse       -> match b { TkElse -> true _ -> false }
    TkEnsures    -> match b { TkEnsures -> true _ -> false }
    TkExtern     -> match b { TkExtern -> true _ -> false }
    TkFalse      -> match b { TkFalse -> true _ -> false }
    TkFn         -> match b { TkFn -> true _ -> false }
    TkFor        -> match b { TkFor -> true _ -> false }
    TkHandle     -> match b { TkHandle -> true _ -> false }
    TkIf         -> match b { TkIf -> true _ -> false }
    TkImpl       -> match b { TkImpl -> true _ -> false }
    TkImport     -> match b { TkImport -> true _ -> false }
    TkLet        -> match b { TkLet -> true _ -> false }
    TkMatch      -> match b { TkMatch -> true _ -> false }
    TkNot        -> match b { TkNot -> true _ -> false }
    TkOr         -> match b { TkOr -> true _ -> false }
    TkProtocol   -> match b { TkProtocol -> true _ -> false }
    TkPub        -> match b { TkPub -> true _ -> false }
    TkRequires   -> match b { TkRequires -> true _ -> false }
    TkTest       -> match b { TkTest -> true _ -> false }
    TkTrue       -> match b { TkTrue -> true _ -> false }
    TkType       -> match b { TkType -> true _ -> false }
    TkUnitKw     -> match b { TkUnitKw -> true _ -> false }
    TkUse        -> match b { TkUse -> true _ -> false }
    TkVar        -> match b { TkVar -> true _ -> false }
    TkWhen       -> match b { TkWhen -> true _ -> false }
    TkWhere      -> match b { TkWhere -> true _ -> false }
    TkWith       -> match b { TkWith -> true _ -> false }
    TkInt        -> match b { TkInt -> true _ -> false }
    TkReal       -> match b { TkReal -> true _ -> false }
    TkComplex    -> match b { TkComplex -> true _ -> false }
    TkChar       -> match b { TkChar -> true _ -> false }
    TkString     -> match b { TkString -> true _ -> false }
    TkIdent      -> match b { TkIdent -> true _ -> false }
    TkUnderscore -> match b { TkUnderscore -> true _ -> false }
    TkLparen     -> match b { TkLparen -> true _ -> false }
    TkRparen     -> match b { TkRparen -> true _ -> false }
    TkLbracket   -> match b { TkLbracket -> true _ -> false }
    TkRbracket   -> match b { TkRbracket -> true _ -> false }
    TkLbrace     -> match b { TkLbrace -> true _ -> false }
    TkRbrace     -> match b { TkRbrace -> true _ -> false }
    TkComma      -> match b { TkComma -> true _ -> false }
    TkColon      -> match b { TkColon -> true _ -> false }
    TkColonEq    -> match b { TkColonEq -> true _ -> false }
    TkSemi       -> match b { TkSemi -> true _ -> false }
    TkDot        -> match b { TkDot -> true _ -> false }
    TkDotDot     -> match b { TkDotDot -> true _ -> false }
    TkEllipsis   -> match b { TkEllipsis -> true _ -> false }
    TkEq         -> match b { TkEq -> true _ -> false }
    TkArrow      -> match b { TkArrow -> true _ -> false }
    TkFatArrow   -> match b { TkFatArrow -> true _ -> false }
    TkPipe       -> match b { TkPipe -> true _ -> false }
    TkPipeApply  -> match b { TkPipeApply -> true _ -> false }
    TkBarBar     -> match b { TkBarBar -> true _ -> false }
    TkPipeQuestion -> match b { TkPipeQuestion -> true _ -> false }
    TkPlus       -> match b { TkPlus -> true _ -> false }
    TkMinus      -> match b { TkMinus -> true _ -> false }
    TkStar       -> match b { TkStar -> true _ -> false }
    TkSlash      -> match b { TkSlash -> true _ -> false }
    TkPercent    -> match b { TkPercent -> true _ -> false }
    TkEqEq       -> match b { TkEqEq -> true _ -> false }
    TkNeq        -> match b { TkNeq -> true _ -> false }
    TkLt         -> match b { TkLt -> true _ -> false }
    TkGt         -> match b { TkGt -> true _ -> false }
    TkLe         -> match b { TkLe -> true _ -> false }
    TkGe         -> match b { TkGe -> true _ -> false }
    TkBang       -> match b { TkBang -> true _ -> false }
    TkAt         -> match b { TkAt -> true _ -> false }
    TkCaret      -> match b { TkCaret -> true _ -> false }
    TkHole       -> match b { TkHole -> true _ -> false }
    TkHoleName(_) -> match b { TkHoleName(_) -> true _ -> false }
    TkTodoBang   -> match b { TkTodoBang -> true _ -> false }
    TkPlusPlus   -> match b { TkPlusPlus -> true _ -> false }
    TkDerive     -> match b { TkDerive -> true _ -> false }
    TkRegex      -> match b { TkRegex -> true _ -> false }
    TkError(_)   -> false
  }
}

fn p_at(p: Parser, k: TokKind) : Bool = tk_is(p_peek(p).kind, k)

fn p_try_consume(p: Parser, k: TokKind) : Option[Parser] {
  if p_at(p, k) { Some(p_advance(p)) } else { None }
}

fn p_skip_newlines(p: Parser) : Parser {
  if p_at(p, TkNewline) { p_skip_newlines(p_advance(p)) } else { p }
}

# m7b §1: temporarily disable trailing-lambda attachment for the
# parser passed in (used by `if` / `match` cond parsing). Returns
# a parser identical except for the flag. The caller is expected
# to restore the original flag value after the cond parses by
# threading the flag back via `p_with_trailing_lambda(p, true)`.
fn p_with_trailing_lambda(p: Parser, allow: Bool) : Parser {
  Parser { file: p.file, src: p.src, rest: p.rest, had_error: p.had_error,
           allow_trailing_lambda: allow }
}

fn p_skip_newlines_and_semis(p: Parser) : Parser {
  if p_at(p, TkNewline) or p_at(p, TkSemi) { p_skip_newlines_and_semis(p_advance(p)) }
  else { p }
}

fn p_error(p: Parser, t: Token, msg: String) : Parser / Console {

  if p.had_error { p }
  else {
    diag_error_from_src(p.file, p.src, t.line, t.col, msg)
    p_mark_err(p)
  }
}

fn p_error_here(p: Parser, msg: String) : Parser / Console = p_error(p, p_peek(p), msg)

fn p_expect(p: Parser, k: TokKind, msg: String) : PExpr / Console {

  # PExpr is a misnomer — we just reuse the record structure. We return
  # an Expr-less PExpr; callers that need the consumed token use
  # p_expect_tok instead. This variant is a convenience for "advance
  # past a required delimiter".
  if p_at(p, k) { PExpr { p: p_advance(p), r: Some(mk_expr(EUnit, 0, 0)) } }
  else { PExpr { p: p_error_here(p, msg), r: None } }
}

# Same, but returns the consumed token in the Option payload slot (as an
# EStr carrying the raw span — caller decodes).
fn p_expect_tok(p: Parser, k: TokKind, msg: String) : Token {
  if p_at(p, k) { p_peek(p) }
  else { eof_tok() }
}

fn is_upper_ident(src: String, t: Token) : Bool {
  match char_at(src, t.start) {
    Some(c) -> c >= 'A' and c <= 'Z'
    None -> false
  }
}

fn tok_source(src: String, t: Token) : String = string_slice(src, t.start, t.length)

# ====================================================================
# literal decoders
# ====================================================================

fn decode_int_loop(s: String, i: Int, n: Int, acc: Int, neg: Bool) : Int {
  if i >= n { if neg { 0 - acc } else { acc } }
  else {
    match char_at(s, i) {
      None -> if neg { 0 - acc } else { acc }
      Some(c) -> {
        if c == '_' { decode_int_loop(s, i + 1, n, acc, neg) }
        else if ch_is_digit(c) {
          let d = char_to_int(c) - char_to_int('0')
          decode_int_loop(s, i + 1, n, acc * 10 + d, neg)
        } else {
          if neg { 0 - acc } else { acc }
        }
      }
    }
  }
}

fn decode_bin_loop(s: String, i: Int, n: Int, acc: Int) : Int {
  if i >= n { acc }
  else {
    match char_at(s, i) {
      None -> acc
      Some(c) -> {
        if c == '0' { decode_bin_loop(s, i + 1, n, acc * 2) }
        else if c == '1' { decode_bin_loop(s, i + 1, n, acc * 2 + 1) }
        else { acc }
      }
    }
  }
}

fn decode_int_after_sign(span: String, i: Int, n: Int, neg: Bool) : Int {
  # Detect 0x / 0b base prefixes; otherwise fall back to decimal.
  let has_prefix =
    if i + 1 < n {
      match char_at(span, i) {
        Some(c0) -> {
          if c0 == '0' {
            match char_at(span, i + 1) {
              Some(c1) -> c1 == 'x' or c1 == 'X' or c1 == 'b' or c1 == 'B'
              None -> false
            }
          } else { false }
        }
        None -> false
      }
    } else { false }
  if has_prefix {
    match char_at(span, i + 1) {
      Some(c1) -> {
        let is_hex = c1 == 'x' or c1 == 'X'
        let v = if is_hex { decode_hex_loop(span, i + 2, n, 0) }
                else { decode_bin_loop(span, i + 2, n, 0) }
        if neg { 0 - v } else { v }
      }
      None -> if neg { 0 } else { 0 }
    }
  } else {
    decode_int_loop(span, i, n, 0, neg)
  }
}

fn decode_int(span: String) : Int {
  let n = string_length(span)
  if n == 0 { 0 }
  else {
    match char_at(span, 0) {
      Some(c) -> if c == '-' { decode_int_after_sign(span, 1, n, true) }
                 else { decode_int_after_sign(span, 0, n, false) }
      None -> 0
    }
  }
}

fn strip_underscores_loop(s: String, i: Int, n: Int, acc: String) : String {
  if i >= n { acc }
  else {
    match char_at(s, i) {
      None -> acc
      Some(c) -> {
        if c == '_' { strip_underscores_loop(s, i + 1, n, acc) }
        else { strip_underscores_loop(s, i + 1, n, string_concat(acc, "#{c}")) }
      }
    }
  }
}

fn decode_real(span: String) : Real {
  let clean = strip_underscores_loop(span, 0, string_length(span), "")
  match string_to_real(clean) {
    Some(r) -> r
    None -> 0.0
  }
}

fn decode_char_escape(c: Char) : Char {
  match c {
    'n' -> '\n'
    't' -> '\t'
    'r' -> '\r'
    '\\' -> '\\'
    '\'' -> '\''
    '"' -> '"'
    '0' -> int_to_char(0)
    _ -> c
  }
}

fn decode_hex_loop(s: String, i: Int, n: Int, acc: Int) : Int {
  if i >= n { acc }
  else {
    match char_at(s, i) {
      None -> acc
      Some(c) -> {
        if c == '}' { acc }
        else {
          let v =
            if ch_is_digit(c) { char_to_int(c) - char_to_int('0') }
            else if c >= 'a' and c <= 'f' { char_to_int(c) - char_to_int('a') + 10 }
            else if c >= 'A' and c <= 'F' { char_to_int(c) - char_to_int('A') + 10 }
            else { 0 }
          decode_hex_loop(s, i + 1, n, acc * 16 + v)
        }
      }
    }
  }
}

# span is the raw char literal including surrounding quotes: 'a', '\n', '\u{2603}'
fn decode_char(span: String) : Char {
  let n = string_length(span)
  if n < 2 { int_to_char(0) }
  else {
    match char_at(span, 1) {
      None -> int_to_char(0)
      Some(c1) -> {
        if c1 == '\\' {
          match char_at(span, 2) {
            None -> int_to_char(0)
            Some(c2) -> {
              if c2 == 'u' {
                int_to_char(decode_hex_loop(span, 4, n - 1, 0))
              } else {
                decode_char_escape(c2)
              }
            }
          }
        } else {
          c1
        }
      }
    }
  }
}

# ====================================================================
# precedence climbing: forward declarations
# ====================================================================
#
# These are implemented below. Listed here as a reading aid.
#  parse_expr   -> parse_pipe
#  parse_pipe   -> parse_or ("|>" parse_or)*
#  parse_or     -> parse_and ("or" parse_and)*
#  parse_and    -> parse_cmp ("and" parse_cmp)*
#  parse_cmp    -> parse_add (cmpop parse_add)?        (no chains)
#  parse_add    -> parse_mul ([+-] parse_mul)*
#  parse_mul    -> parse_unary ([*/%] parse_unary)*
#  parse_unary  -> ("-" | "not")? parse_postfix
#  parse_postfix-> parse_primary (call | field | index)*
#  parse_primary-> literal | ident | "(" expr ")" | if | match | block | record | list | lambda

fn op_of_tok(k: TokKind) : String {
  match k {
    TkPlus -> "+" TkMinus -> "-" TkStar -> "*" TkSlash -> "/"
    TkPercent -> "%" TkPlusPlus -> "++"
    TkEqEq -> "==" TkNeq -> "!=" TkLt -> "<" TkGt -> ">" TkLe -> "<=" TkGe -> ">="
    TkAnd -> "and" TkOr -> "or"
    _ -> "?"
  }
}

# ====================================================================
# expression parsing
# ====================================================================

fn ok_e(p: Parser, e: Expr) : PExpr = PExpr { p: p, r: Some(e) }
fn err_e(p: Parser) : PExpr = PExpr { p: p, r: None }
fn ok_s(p: Parser, s: Stmt) : PStmt = PStmt { p: p, r: Some(s) }
fn err_s(p: Parser) : PStmt = PStmt { p: p, r: None }
fn ok_p(p: Parser, x: Pattern) : PPat = PPat { p: p, r: Some(x) }
fn err_p(p: Parser) : PPat = PPat { p: p, r: None }
fn ok_t(p: Parser, x: TypeExpr) : PTy = PTy { p: p, r: Some(x) }
fn err_t(p: Parser) : PTy = PTy { p: p, r: None }
fn ok_d(p: Parser, x: Decl) : PDecl = PDecl { p: p, r: Some(x) }
fn err_d(p: Parser) : PDecl = PDecl { p: p, r: None }
fn ok_a(p: Parser, x: Arm) : PArm = PArm { p: p, r: Some(x) }
fn err_a(p: Parser) : PArm = PArm { p: p, r: None }
fn ok_pm(p: Parser, x: Param) : PParam = PParam { p: p, r: Some(x) }
fn err_pm(p: Parser) : PParam = PParam { p: p, r: None }
fn ok_fi(p: Parser, x: FieldInit) : PFI = PFI { p: p, r: Some(x) }
fn err_fi(p: Parser) : PFI = PFI { p: p, r: None }
fn ok_v(p: Parser, x: Variant) : PVar = PVar { p: p, r: Some(x) }
fn err_v(p: Parser) : PVar = PVar { p: p, r: None }
fn ok_fd(p: Parser, x: FieldDecl) : PFD = PFD { p: p, r: Some(x) }
fn err_fd(p: Parser) : PFD = PFD { p: p, r: None }
fn ok_pf(p: Parser, x: PField) : PPF = PPF { p: p, r: Some(x) }
fn err_pf(p: Parser) : PPF = PPF { p: p, r: None }
fn ok_el(p: Parser, x: ListElem) : PEL = PEL { p: p, r: Some(x) }
fn err_el(p: Parser) : PEL = PEL { p: p, r: None }

fn parse_expr(p: Parser) : PExpr / Console = parse_pipe(p)

fn parse_pipe(p: Parser) : PExpr / Console {

  let r = parse_or(p)
  match r.r {
    None -> r
    Some(lhs) -> parse_pipe_rest(r.p, lhs)
  }
}

# m7d §21 — outcome of a pipeline placeholder substitution attempt.
# `PPRPassthrough` keeps the legacy first-arg behaviour. The other
# two arms either return the substituted call expression (single `_`
# in the rhs args) or report a multiple-placeholder error.
type PPRResult
  = PPRPassthrough
  | PPRSubstituted(Expr, Parser)
  | PPRError(Parser)

fn try_pipe_placeholder(line: Int, col: Int, lhs: Expr, rhs: Expr, p: Parser) : PPRResult / Console {

  match rhs.kind {
    ECall(callee, args_) -> {
      let n = count_underscores(args_, 0)
      if n == 0 { PPRPassthrough }
      else if n > 1 {
        PPRError(p_error(p, p_peek(p),
          "multiple `_` in a `|>` call would evaluate the left-hand side more than once"))
      }
      else {
        # The substitution evaluates the lhs once via an immediate
        # lambda application: `((__pipe) => f(args[_ := __pipe]))(lhs)`.
        # Equivalent to a `let __pipe = lhs in f(...)` block but
        # composes through the existing lambda machinery (closure
        # capture, perceus, monomorphisation) without depending on
        # the SLet -> EBlock walker quirks for sub-expressions
        # synthesised mid-parse.
        let tmp_name = "__pipe"
        let tmp_var = mk_expr(EVar(tmp_name), lhs.line, lhs.col)
        let new_args = subst_underscores(args_, tmp_var)
        let new_call = mk_expr(ECall(callee, new_args), rhs.line, rhs.col)
        let param = Param { pname: tmp_name, ptype: None, pline: lhs.line, pcol: lhs.col }
        let lam = mk_expr(ELambda([param], new_call), line, col)
        let app = mk_expr(ECall(lam, [lhs]), line, col)
        PPRSubstituted(app, p)
      }
    }
    _ -> PPRPassthrough
  }
}

fn count_underscores(es: [Expr], acc: Int) : Int {
  match es {
    [] -> acc
    [h, ...rest] -> match h.kind {
      EUnder -> count_underscores(rest, acc + 1)
      _      -> count_underscores(rest, acc)
    }
  }
}

fn subst_underscores(es: [Expr], replacement: Expr) : [Expr] {
  match es {
    [] -> []
    [h, ...rest] -> match h.kind {
      EUnder -> [replacement, ...subst_underscores(rest, replacement)]
      _      -> [h, ...subst_underscores(rest, replacement)]
    }
  }
}

# Issue #385 — `.` placeholder desugar at call-argument position.
#
# `f(. < 3)` desugars to `f((__pl) => __pl < 3)` so the placeholder
# sugar documented in `docs/kaikai-minimal.md` §"Placeholder rules"
# works wherever a function value is expected. The walk stops at
# inner `ELambda` / `EHandle` boundaries: `.` inside a nested
# explicit-arrow lambda binds to that nested scope (and per the
# docs, multi-arg / nested-scope cases must use named arrows — a
# stray `.` that survives the desugar is rejected by the typer).
#
# Multiple `.` occurrences in the same argument all refer to the
# same `__pl` parameter (unary), per docs.

fn arg_has_placeholder(e: Expr) : Bool {
  match e.kind {
    EPlaceholder        -> true
    EInt(_)             -> false
    EReal(_)            -> false
    EBool(_)            -> false
    EChar(_)            -> false
    EStr(_, _)          -> false
    EUnit               -> false
    EVar(_)             -> false
    EUnder              -> false
    EHole(_)            -> false
    ETodo(_)            -> false
    EVariantsOf(_, _)   -> false
    EModCall(_, _)      -> false
    # `ELambda` introduces a fresh scope. Per docs, `.` does NOT
    # reach into a nested arrow lambda — that's the multi-arg /
    # nested case the spec rejects.
    ELambda(_, _)       -> false
    # `EHandle` clauses are themselves lambdas; treat the whole
    # node as a scope barrier. The handler body is a normal
    # expression but mixing `.` with effect handlers in argument
    # position is not in the documented sugar surface.
    EHandle(_, _, _, _, _, _, _) -> false
    ECall(callee, args_) ->
      arg_has_placeholder(callee) or any_arg_has_placeholder(args_)
    EField(base, _)     -> arg_has_placeholder(base)
    EIndex(a, b)        -> arg_has_placeholder(a) or arg_has_placeholder(b)
    EBinop(_, a, b)     -> arg_has_placeholder(a) or arg_has_placeholder(b)
    EUnop(_, x)         -> arg_has_placeholder(x)
    EIf(c, t_, eo)      ->
      arg_has_placeholder(c) or arg_has_placeholder(t_) or
      opt_arg_has_placeholder(eo)
    EMatch(scr, arms)   ->
      arg_has_placeholder(scr) or any_arm_has_placeholder(arms)
    ERecordLit(_, fs)   -> any_field_has_placeholder(fs)
    EList(els)          -> any_elem_has_placeholder(els)
    ERange(a, b, opt_step) ->
      arg_has_placeholder(a) or arg_has_placeholder(b) or
      opt_arg_has_placeholder(opt_step)
    EBlock(stmts, tail) ->
      any_stmt_has_placeholder(stmts) or opt_arg_has_placeholder(tail)
    EPipe(a, b)         -> arg_has_placeholder(a) or arg_has_placeholder(b)
    EMapPipe(a, b)      -> arg_has_placeholder(a) or arg_has_placeholder(b)
    EFlatMapPipe(a, b)  -> arg_has_placeholder(a) or arg_has_placeholder(b)
    EFilterPipe(a, b)   -> arg_has_placeholder(a) or arg_has_placeholder(b)
    ELitUnit(inner, _)  -> arg_has_placeholder(inner)
    EBang(inner)        -> arg_has_placeholder(inner)
  }
}

fn any_arg_has_placeholder(es: [Expr]) : Bool = match es {
  []           -> false
  [h, ...rest] -> if arg_has_placeholder(h) { true } else { any_arg_has_placeholder(rest) }
}

fn opt_arg_has_placeholder(o: Option[Expr]) : Bool = match o {
  None    -> false
  Some(e) -> arg_has_placeholder(e)
}

fn any_arm_has_placeholder(arms: [Arm]) : Bool = match arms {
  []           -> false
  [h, ...rest] -> match h {
    Arm(_, g, b) ->
      if opt_arg_has_placeholder(g) { true }
      else if arg_has_placeholder(b) { true }
      else { any_arm_has_placeholder(rest) }
  }
}

fn any_field_has_placeholder(fs: [FieldInit]) : Bool = match fs {
  []           -> false
  [h, ...rest] -> match h {
    FI(_, v) -> if arg_has_placeholder(v) { true } else { any_field_has_placeholder(rest) }
  }
}

fn any_elem_has_placeholder(els: [ListElem]) : Bool = match els {
  []           -> false
  [h, ...rest] -> match h {
    ElPlain(x)  -> if arg_has_placeholder(x) { true } else { any_elem_has_placeholder(rest) }
    ElSpread(x) -> if arg_has_placeholder(x) { true } else { any_elem_has_placeholder(rest) }
  }
}

fn any_stmt_has_placeholder(ss: [Stmt]) : Bool = match ss {
  []           -> false
  [h, ...rest] -> if stmt_has_placeholder(h) { true } else { any_stmt_has_placeholder(rest) }
}

fn stmt_has_placeholder(s: Stmt) : Bool = match s {
  SLet(_, _, rhs)             -> arg_has_placeholder(rhs)
  SAssert(c, m)               -> arg_has_placeholder(c) or opt_arg_has_placeholder(m)
  SExprStmt(x)                -> arg_has_placeholder(x)
  SIndexAssign(b, i, v, _, _) ->
    arg_has_placeholder(b) or arg_has_placeholder(i) or arg_has_placeholder(v)
  SVar(_, _, rhs, _, _)       -> arg_has_placeholder(rhs)
  SUse(_, _, _)               -> false
}

fn subst_placeholder_expr(e: Expr, repl: Expr) : Expr {
  match e.kind {
    EPlaceholder -> repl
    # ELambda / EHandle are scope barriers — leave them alone.
    ELambda(_, _) -> e
    EHandle(_, _, _, _, _, _, _) -> e
    _ -> {
      let new_kind = subst_placeholder_kind(e.kind, repl)
      Expr { kind: new_kind, line: e.line, col: e.col, ty: e.ty, mode: e.mode }
    }
  }
}

fn subst_placeholder_kind(k: ExprKind, repl: Expr) : ExprKind {
  match k {
    EInt(_)             -> k
    EReal(_)            -> k
    EBool(_)            -> k
    EChar(_)            -> k
    EStr(_, _)          -> k
    EUnit               -> k
    EVar(_)             -> k
    EUnder              -> k
    EHole(_)            -> k
    ETodo(_)            -> k
    EVariantsOf(_, _)   -> k
    EModCall(_, _)      -> k
    EPlaceholder        -> k    # handled by subst_placeholder_expr
    ELambda(_, _)       -> k    # scope barrier
    EHandle(_, _, _, _, _, _, _) -> k    # scope barrier
    ECall(callee, args_) ->
      ECall(subst_placeholder_expr(callee, repl),
            map(args_, (a) => subst_placeholder_expr(a, repl)))
    EField(base, name)  -> EField(subst_placeholder_expr(base, repl), name)
    EIndex(a, b)        -> EIndex(subst_placeholder_expr(a, repl),
                                    subst_placeholder_expr(b, repl))
    EBinop(op, a, b)    -> EBinop(op, subst_placeholder_expr(a, repl),
                                       subst_placeholder_expr(b, repl))
    EUnop(op, x)        -> EUnop(op, subst_placeholder_expr(x, repl))
    EIf(c, t_, eo)      ->
      EIf(subst_placeholder_expr(c, repl),
          subst_placeholder_expr(t_, repl),
          subst_placeholder_opt(eo, repl))
    EMatch(scr, arms)   ->
      EMatch(subst_placeholder_expr(scr, repl),
              map(arms, (a) => subst_placeholder_arm(a, repl)))
    ERecordLit(name, fs) ->
      ERecordLit(name, map(fs, (fi) => subst_placeholder_field(fi, repl)))
    EList(els)          -> EList(map(els, (el) => subst_placeholder_elem(el, repl)))
    ERange(a, b, opt_step) ->
      ERange(subst_placeholder_expr(a, repl),
              subst_placeholder_expr(b, repl),
              subst_placeholder_opt(opt_step, repl))
    EBlock(stmts, tail) ->
      EBlock(map(stmts, (s) => subst_placeholder_stmt(s, repl)),
              subst_placeholder_opt(tail, repl))
    EPipe(a, b)         -> EPipe(subst_placeholder_expr(a, repl),
                                  subst_placeholder_expr(b, repl))
    EMapPipe(a, b)      -> EMapPipe(subst_placeholder_expr(a, repl),
                                      subst_placeholder_expr(b, repl))
    EFlatMapPipe(a, b)  -> EFlatMapPipe(subst_placeholder_expr(a, repl),
                                          subst_placeholder_expr(b, repl))
    EFilterPipe(a, b)   -> EFilterPipe(subst_placeholder_expr(a, repl),
                                        subst_placeholder_expr(b, repl))
    ELitUnit(inner, u)  -> ELitUnit(subst_placeholder_expr(inner, repl), u)
    EBang(inner)        -> EBang(subst_placeholder_expr(inner, repl))
  }
}

fn subst_placeholder_opt(o: Option[Expr], repl: Expr) : Option[Expr] = match o {
  None    -> None
  Some(e) -> Some(subst_placeholder_expr(e, repl))
}

fn subst_placeholder_arm(a: Arm, repl: Expr) : Arm = match a {
  Arm(p, g, b) ->
    Arm(p, subst_placeholder_opt(g, repl), subst_placeholder_expr(b, repl))
}

fn subst_placeholder_field(fi: FieldInit, repl: Expr) : FieldInit = match fi {
  FI(n, v) -> FI(n, subst_placeholder_expr(v, repl))
}

fn subst_placeholder_elem(el: ListElem, repl: Expr) : ListElem = match el {
  ElPlain(x)  -> ElPlain(subst_placeholder_expr(x, repl))
  ElSpread(x) -> ElSpread(subst_placeholder_expr(x, repl))
}

fn subst_placeholder_stmt(s: Stmt, repl: Expr) : Stmt = match s {
  SLet(p, ann, rhs)           -> SLet(p, ann, subst_placeholder_expr(rhs, repl))
  SAssert(c, m)               -> SAssert(subst_placeholder_expr(c, repl),
                                          subst_placeholder_opt(m, repl))
  SExprStmt(x)                -> SExprStmt(subst_placeholder_expr(x, repl))
  SIndexAssign(b, i, v, l, c) -> SIndexAssign(subst_placeholder_expr(b, repl),
                                                subst_placeholder_expr(i, repl),
                                                subst_placeholder_expr(v, repl),
                                                l, c)
  SVar(n, ty, rhs, l, c)      -> SVar(n, ty, subst_placeholder_expr(rhs, repl), l, c)
  SUse(n, l, c)               -> SUse(n, l, c)
}

# Wrap a single argument expression in a placeholder lambda when
# it carries a top-level `.`. Returns the argument unchanged when
# it has no placeholder, or when the top-level node is itself a
# lambda / handler (scope barriers), preserving the existing
# parser shape for those cases.
fn desugar_placeholder_arg(arg: Expr) : Expr {
  if arg_has_placeholder(arg) {
    let pl_name = "__pl"
    let pl_var = mk_expr(EVar(pl_name), arg.line, arg.col)
    let body = subst_placeholder_expr(arg, pl_var)
    let pl_param = Param { pname: pl_name, ptype: None,
                            pline: arg.line, pcol: arg.col }
    mk_expr(ELambda([pl_param], body), arg.line, arg.col)
  } else {
    arg
  }
}

fn desugar_placeholder_args(args_: [Expr]) : [Expr] =
  map(args_, desugar_placeholder_arg)

fn parse_pipe_rest(p: Parser, lhs: Expr) : PExpr / Console {

  # `|>` (apply), `|` (map), and `||` (flat-map) all sit at the lowest
  # binop level, left-associative. The `|` variant separator in
  # `type T = A | B` is parsed by `parse_sum_body`, not the expression
  # grammar, so there is no ambiguity here.
  #
  # Issue #130: pipe operators may also lead a continuation line. The
  # peeked parser skips leading newlines so `xs\n  |> f\n  |> g` parses
  # the same as `xs |>\n  f |>\n  g`. If the next non-newline token is
  # NOT a pipe we return the ORIGINAL `p` — those newlines belong to
  # the enclosing statement boundary, not the pipe chain.
  #
  # Issue #201: `|` and `||` are typed as `EMapPipe` / `EFlatMapPipe`
  # AST nodes. The typer dispatches them against the head type of the
  # LHS via the head-type-to-module map (see `head_type_module` and
  # `synth_map_pipe` / `synth_flat_map_pipe`) and rewrites the node
  # into a `<module>.map(xs, f)` / `<module>.flat_map(xs, f)` call.
  # Pre-#201, the parser desugared `|` straight into
  # `ECall(EVar("map"), [xs, f])` against a hardcoded prelude `map`
  # entry; the new shape lets `[T]` and any future container-shaped
  # head type share one surface without a hardcoded receiver.
  let p_look = p_skip_newlines(p)
  if p_at(p_look, TkPipeApply) {
    let t = p_peek(p_look)
    let p1 = p_skip_newlines(p_advance(p_look))
    let r = parse_or(p1)
    match r.r {
      None -> err_e(r.p)
      Some(rhs) -> {
        # m7d §21: pipeline placeholder. If the rhs is a call whose
        # arg list contains exactly one `_`, the apply pipe lands
        # the lhs at that position instead of as the first arg.
        # `let __pipe = lhs in f(args[_ := __pipe])` — the let
        # binding ensures the lhs is evaluated once, even if it has
        # side effects. The default-first-arg behaviour stays for
        # calls with no `_`. Multiple `_` in the same call would
        # silently duplicate side effects, so we reject them.
        match try_pipe_placeholder(t.line, t.col, lhs, rhs, r.p) {
          PPRError(p2)         -> err_e(p2)
          PPRSubstituted(e, p2) -> parse_pipe_rest(p2, e)
          PPRPassthrough       -> parse_pipe_rest(r.p, mk_expr(EPipe(lhs, rhs), t.line, t.col))
        }
      }
    }
  } else if p_at(p_look, TkPipe) {
    let t = p_peek(p_look)
    let p1 = p_skip_newlines(p_advance(p_look))
    let r = parse_or(p1)
    match r.r {
      None -> err_e(r.p)
      Some(rhs) -> parse_pipe_rest(r.p, mk_expr(EMapPipe(lhs, rhs), t.line, t.col))
    }
  } else if p_at(p_look, TkBarBar) {
    let t = p_peek(p_look)
    let p1 = p_skip_newlines(p_advance(p_look))
    let r = parse_or(p1)
    match r.r {
      None -> err_e(r.p)
      Some(rhs) -> parse_pipe_rest(r.p, mk_expr(EFlatMapPipe(lhs, rhs), t.line, t.col))
    }
  } else if p_at(p_look, TkPipeQuestion) {
    let t = p_peek(p_look)
    let p1 = p_skip_newlines(p_advance(p_look))
    let r = parse_or(p1)
    match r.r {
      None -> err_e(r.p)
      Some(rhs) -> parse_pipe_rest(r.p, mk_expr(EFilterPipe(lhs, rhs), t.line, t.col))
    }
  } else {
    ok_e(p, lhs)
  }
}

fn parse_or(p: Parser) : PExpr / Console {

  let r = parse_and(p)
  match r.r {
    None -> r
    Some(lhs) -> parse_or_rest(r.p, lhs)
  }
}

fn parse_or_rest(p: Parser, lhs: Expr) : PExpr / Console {

  if p_at(p, TkOr) {
    let t = p_peek(p)
    let r = parse_and(p_skip_newlines(p_advance(p)))
    match r.r {
      None -> err_e(r.p)
      Some(rhs) -> parse_or_rest(r.p, mk_expr(EBinop("or", lhs, rhs), t.line, t.col))
    }
  } else {
    ok_e(p, lhs)
  }
}

fn parse_and(p: Parser) : PExpr / Console {

  let r = parse_cmp(p)
  match r.r {
    None -> r
    Some(lhs) -> parse_and_rest(r.p, lhs)
  }
}

fn parse_and_rest(p: Parser, lhs: Expr) : PExpr / Console {

  if p_at(p, TkAnd) {
    let t = p_peek(p)
    let r = parse_cmp(p_skip_newlines(p_advance(p)))
    match r.r {
      None -> err_e(r.p)
      Some(rhs) -> parse_and_rest(r.p, mk_expr(EBinop("and", lhs, rhs), t.line, t.col))
    }
  } else {
    ok_e(p, lhs)
  }
}

fn is_cmp_tok(k: TokKind) : Bool {
  tk_is(k, TkEqEq) or tk_is(k, TkNeq) or tk_is(k, TkLt) or tk_is(k, TkGt) or tk_is(k, TkLe) or tk_is(k, TkGe)
}

# Comparison is deliberately non-associative (see `kaikai-minimal.md`
# → Operator precedence): `a < b < c` is a syntax error, not a chain.
# A plain fall-through would report "expected `fn`, `type`, ..." at
# the outer statement parser, which is useless. Instead, when we see
# a second comparison token right after `lhs OP rhs`, we emit a
# tailored diagnostic pointing at the offending `OP'` and suggesting
# the `and`-based rewrite.
fn parse_cmp(p: Parser) : PExpr / Console {

  let r = parse_concat(p)
  match r.r {
    None -> r
    Some(lhs) -> {
      let t = p_peek(r.p)
      if is_cmp_tok(t.kind) {
        let op = op_of_tok(t.kind)
        let r2 = parse_concat(p_skip_newlines(p_advance(r.p)))
        match r2.r {
          None -> err_e(r2.p)
          Some(rhs) -> {
            let after = p_peek(r2.p)
            if is_cmp_tok(after.kind) {
              let hint = "comparison is non-associative; write `... and ... #{op_of_tok(after.kind)} ...` instead"
              err_e(p_error(r2.p, after, hint))
            } else {
              ok_e(r2.p, mk_expr(EBinop(op, lhs, rhs), t.line, t.col))
            }
          }
        }
      } else { ok_e(r.p, lhs) }
    }
  }
}

# m7d §23 — `++` sits one slot below comparison, one above
# additive (`+`/`-`). Right-associative, so `a ++ b ++ c` parses
# as `a ++ (b ++ c)` — which matches both `string_concat` and
# `list_append` since both are the natural fold direction (no
# spine duplication on the head list / left string).
fn parse_concat(p: Parser) : PExpr / Console {

  let r = parse_add(p)
  match r.r {
    None -> r
    Some(lhs) -> {
      if p_at(r.p, TkPlusPlus) {
        let t = p_peek(r.p)
        let rr = parse_concat(p_skip_newlines(p_advance(r.p)))
        match rr.r {
          None -> err_e(rr.p)
          Some(rhs) -> ok_e(rr.p, mk_expr(EBinop("++", lhs, rhs), t.line, t.col))
        }
      } else { ok_e(r.p, lhs) }
    }
  }
}

fn parse_add(p: Parser) : PExpr / Console {

  let r = parse_mul(p)
  match r.r {
    None -> r
    Some(lhs) -> parse_add_rest(r.p, lhs)
  }
}

fn parse_add_rest(p: Parser, lhs: Expr) : PExpr / Console {

  let t = p_peek(p)
  if tk_is(t.kind, TkPlus) or tk_is(t.kind, TkMinus) {
    let op = op_of_tok(t.kind)
    let r = parse_mul(p_skip_newlines(p_advance(p)))
    match r.r {
      None -> err_e(r.p)
      Some(rhs) -> parse_add_rest(r.p, mk_expr(EBinop(op, lhs, rhs), t.line, t.col))
    }
  } else { ok_e(p, lhs) }
}

fn parse_mul(p: Parser) : PExpr / Console {

  let r = parse_unary(p)
  match r.r {
    None -> r
    Some(lhs) -> parse_mul_rest(r.p, lhs)
  }
}

fn parse_mul_rest(p: Parser, lhs: Expr) : PExpr / Console {

  let t = p_peek(p)
  if tk_is(t.kind, TkStar) or tk_is(t.kind, TkSlash) or tk_is(t.kind, TkPercent) {
    let op = op_of_tok(t.kind)
    let r = parse_unary(p_skip_newlines(p_advance(p)))
    match r.r {
      None -> err_e(r.p)
      Some(rhs) -> parse_mul_rest(r.p, mk_expr(EBinop(op, lhs, rhs), t.line, t.col))
    }
  } else { ok_e(p, lhs) }
}

fn parse_unary(p: Parser) : PExpr / Console {

  let t = p_peek(p)
  if tk_is(t.kind, TkMinus) {
    let r = parse_unary(p_advance(p))
    match r.r {
      None -> err_e(r.p)
      Some(e) -> ok_e(r.p, mk_expr(EUnop("-", e), t.line, t.col))
    }
  } else if tk_is(t.kind, TkNot) {
    let r = parse_unary(p_advance(p))
    match r.r {
      None -> err_e(r.p)
      Some(e) -> ok_e(r.p, mk_expr(EUnop("not", e), t.line, t.col))
    }
  } else if tk_is(t.kind, TkAt) {
    # m7b #4: `@cap` desugars to `cap.get()`. The alias rewrite later
    # remaps `Reader[T].get` to `Reader.ask`. Doc B §`Syntax note:
    # capability read/write sugar` rule 3: the identifier after `@`
    # must be a simple capability binding (no dotted paths).
    let p1 = p_advance(p)
    let id = p_peek(p1)
    if not tk_is(id.kind, TkIdent) {
      err_e(p_error(p1, id, "expected capability name after `@`"))
    } else {
      let name = tok_source(p1.src, id)
      let p2 = p_advance(p1)
      let cap = mk_expr(EVar(name), id.line, id.col)
      let getter = mk_expr(EField(cap, "get"), t.line, t.col)
      ok_e(p2, mk_expr(ECall(getter, []), t.line, t.col))
    }
  } else {
    parse_pow(p)
  }
}

# `^` — integer-exponent power. Higher precedence than `*`/`/` and
# right-associative (Haskell convention): `2 ^ 3 ^ 2` parses as
# `2 ^ (3 ^ 2)` = `2 ^ 9` = 512. The LHS is `parse_postfix` so calls
# and field accesses bind tighter than `^`; the RHS calls back into
# `parse_unary` so a leading sign on the exponent (`r ^ -2`) lexes
# as `EUnop("-", EInt(2))`. The typer treats `^` specially: when the
# base has a non-trivial unit, the exponent must be a literal Int
# (or `-Int`) so the result unit `u^n` resolves at compile time.
fn parse_pow(p: Parser) : PExpr / Console {

  let r = parse_postfix(p)
  match r.r {
    None -> r
    Some(lhs) -> {
      let t = p_peek(r.p)
      if tk_is(t.kind, TkCaret) {
        let rr = parse_unary(p_skip_newlines(p_advance(r.p)))
        match rr.r {
          None -> err_e(rr.p)
          Some(rhs) -> ok_e(rr.p, mk_expr(EBinop("^", lhs, rhs), t.line, t.col))
        }
      } else { ok_e(r.p, lhs) }
    }
  }
}

fn parse_postfix(p: Parser) : PExpr / Console {

  let r = parse_primary(p)
  match r.r {
    None -> r
    Some(e) -> parse_postfix_rest(r.p, e)
  }
}

fn parse_postfix_rest(p: Parser, lhs: Expr) : PExpr / Console {

  let t = p_peek(p)
  if tk_is(t.kind, TkLparen) {
    let args_r = parse_call_args(p_advance(p))
    match args_r.r {
      None -> err_e(args_r.p)
      Some(xs) -> {
        # m7b §1/§5: same-line `{` after `f(args)` attaches as a
        # trailing lambda. Up to two consecutive trailings (greedy,
        # both must be on the same line as the previous token).
        # Trailing-lambda attachment is disabled for cond positions
        # (see p_with_trailing_lambda).
        let lam_r = if args_r.p.allow_trailing_lambda {
          parse_trailing_lambdas(args_r.p, xs)
        } else {
          ok_args(args_r.p, xs)
        }
        match lam_r.r {
          None -> err_e(lam_r.p)
          Some(xs1) -> {
            # Issue #385: rewrite `f(. < 3)` to `f((__pl) => __pl < 3)`
            # so the documented placeholder sugar reaches the typer as
            # a function value. See `desugar_placeholder_arg` for the
            # scope rules.
            let xs2 = desugar_placeholder_args(xs1)
            parse_postfix_rest(lam_r.p, mk_expr(ECall(lhs, xs2), t.line, t.col))
          }
        }
      }
    }
  } else if tk_is(t.kind, TkDot) {
    let p1 = p_advance(p)
    let id = p_peek(p1)
    # m7b #5: `var` is a new statement keyword (§3 of syntax-sugars)
    # but also the name of a Doc B `Env` effect op (`Env.var(name)`).
    # Accept `var` here as a field-name token so the keyword does not
    # break existing Env-op call sites.
    # m13: `and` / `or` / `not` are keywords for the boolean
    # operators but also the natural names for `bit.and` / `bit.or`
    # / `bit.not` in the dotted intrinsic surface. `test` is a
    # keyword for the test-block declaration but also the natural
    # name for `bit.test`. After `.` there is no production that
    # consumes any of them, so accepting them here as field-name
    # tokens is unambiguous and lets the qualified bit ops parse
    # without renaming.
    if tk_is(id.kind, TkIdent) or tk_is(id.kind, TkVar) or
       tk_is(id.kind, TkAnd)   or tk_is(id.kind, TkOr)  or
       tk_is(id.kind, TkNot)   or tk_is(id.kind, TkTest) or
       tk_is(id.kind, TkBench) or tk_is(id.kind, TkCheck) {
      let name = tok_source(p.src, id)
      parse_postfix_rest(p_advance(p1), mk_expr(EField(lhs, name), t.line, t.col))
    } else {
      err_e(p_error_here(p1, "expected field name after `.`"))
    }
  } else if tk_is(t.kind, TkLbracket) {
    let p1 = p_advance(p)
    let r = parse_expr(p1)
    match r.r {
      None -> err_e(r.p)
      Some(idx) -> {
        let closed = p_expect(r.p, TkRbracket, "expected `]` after index")
        match closed.r {
          None -> err_e(closed.p)
          Some(_) -> parse_postfix_rest(closed.p, mk_expr(EIndex(lhs, idx), t.line, t.col))
        }
      }
    }
  } else if tk_is(t.kind, TkBang) {
    # m7e §13: `expr!` — postfix Option/Result propagation. Binds
    # tighter than calls and field access can chain through it
    # (`f()!.field`, `xs[0]!`), but binary operators sit lower.
    parse_postfix_rest(p_advance(p), mk_expr(EBang(lhs), t.line, t.col))
  } else if tk_is(t.kind, TkLbrace) and p.allow_trailing_lambda {
    # m7b §1: paren-free trailing lambda — `f { body }` desugars
    # to `f(() => body)`, optionally followed by a second trailing
    # lambda (§5). Same-line is implicit: parse_postfix_rest does
    # not skip newlines, so a `{` appearing here is on the same
    # source line as `lhs`. Disabled inside `if` / `match` conds.
    let lam_r = parse_trailing_lambdas(p, [])
    match lam_r.r {
      None -> err_e(lam_r.p)
      Some(xs1) -> parse_postfix_rest(lam_r.p, mk_expr(ECall(lhs, xs1), t.line, t.col))
    }
  } else {
    ok_e(p, lhs)
  }
}

# m7b §1 + §5 — parse zero, one, or two trailing lambdas after a
# call site. Each trailing lambda must be on the same line as the
# preceding token (parse_postfix_rest never skips newlines, so a
# `TkLbrace` at the head of `p` is by construction same-line).
# `acc` is the call's existing argument list; the parsed lambdas
# are appended in source order. Returns the call's full arg list.
fn parse_trailing_lambdas(p: Parser, acc: [Expr]) : PArgs / Console {

  if p_at(p, TkLbrace) {
    let lr = parse_trailing_lambda(p)
    match lr.r {
      None -> err_args(lr.p)
      Some(lam) -> {
        let acc1 = list_append(acc, [lam])
        if p_at(lr.p, TkLbrace) {
          let lr2 = parse_trailing_lambda(lr.p)
          match lr2.r {
            None -> err_args(lr2.p)
            Some(lam2) -> ok_args(lr2.p, list_append(acc1, [lam2]))
          }
        } else {
          ok_args(lr.p, acc1)
        }
      }
    }
  } else {
    ok_args(p, acc)
  }
}

# Parse a single trailing-lambda `{ (LambdaParams "->")? Block }`.
# Position is at the `{`. Returns an `ELambda(params, body)` where
# `body` is an EBlock (the lambda's body block). The block-form
# `{ x -> body }` desugars to `(x) => body` per syntax-sugars §1.
fn parse_trailing_lambda(p: Parser) : PExpr / Console {

  let t = p_peek(p)
  # Consume `{`.
  let p1 = p_advance(p)
  # Decide between `(LambdaParams "->")? Block`. Peek past optional
  # newlines after `{` to see whether we're staring at a parameter
  # list. The lookahead is bounded: `Ident ("," Ident)* "->"` or
  # just `->` for zero arity.
  let p1n = p_skip_newlines(p1)
  let pp_r = try_parse_lambda_block_params(p1n)
  match pp_r {
    Some(res) -> {
      # `res.p` is positioned right after `->`. Body is a brace-less
      # block of statements terminated by `}`.
      let body_r = parse_lambda_block_body(res.p, t)
      match body_r.r {
        None -> err_e(body_r.p)
        Some(body) -> ok_e(body_r.p, mk_expr(ELambda(res.params, body), t.line, t.col))
      }
    }
    None -> {
      # Zero-arity trailing lambda: no `params ->` prefix. The body
      # is the contents of the brace block. Treat as a lambda with
      # an empty parameter list whose body is the parsed block.
      let body_r = parse_lambda_block_body(p1, t)
      match body_r.r {
        None -> err_e(body_r.p)
        Some(body) -> ok_e(body_r.p, mk_expr(ELambda([], body), t.line, t.col))
      }
    }
  }
}

# Parse the contents of a lambda-block body up to the closing `}`.
# Position is after the optional `params ->` prefix. The body is
# the same shape as a regular block: zero or more statements
# followed by an optional final expression. We reuse the existing
# parse_block_body machinery for this.
fn parse_lambda_block_body(p: Parser, t: Token) : PExpr / Console {

  let p0 = p_skip_newlines_and_semis(p)
  parse_block_body(p0, [], t)
}

# Bounded-lookahead: tentatively scan for `LambdaParams "->"` or
# bare `"->"`. Returns Some(parser-after-arrow, params) on match,
# None otherwise. The scan never consumes tokens of the underlying
# parser on failure (it's a pure predicate over the token stream).
type LamBlockParams = { p: Parser, params: [Param] }

fn try_parse_lambda_block_params(p: Parser) : Option[LamBlockParams] {
  # Zero-arity: `{ -> body }`.
  if p_at(p, TkArrow) {
    Some(LamBlockParams { p: p_advance(p), params: [] })
  } else if p_at(p, TkIdent) {
    try_parse_lambda_block_params_loop(p, [])
  } else {
    None
  }
}

fn try_parse_lambda_block_params_loop(p: Parser, acc: [Param]) : Option[LamBlockParams] {
  let t = p_peek(p)
  if not tk_is(t.kind, TkIdent) { None }
  else {
    let name = tok_source(p.src, t)
    let p1 = p_advance(p)
    let pm = Param { pname: name, ptype: None, pline: t.line, pcol: t.col }
    let acc1 = [pm, ...acc]
    if p_at(p1, TkComma) {
      try_parse_lambda_block_params_loop(p_skip_newlines(p_advance(p1)), acc1)
    } else if p_at(p1, TkArrow) {
      Some(LamBlockParams { p: p_advance(p1), params: list_reverse(acc1) })
    } else {
      None
    }
  }
}

# Parse the argument list of a call. Position is AT the token after the
# opening `(`. Returns with `(` already consumed by caller, `)` to be
# consumed here. Newlines between args are allowed.
type PArgs = { p: Parser, r: Option[[Expr]] }

fn ok_args(p: Parser, xs: [Expr]) : PArgs = PArgs { p: p, r: Some(xs) }
fn err_args(p: Parser) : PArgs = PArgs { p: p, r: None }

fn parse_call_args(p: Parser) : PArgs / Console {

  let p0 = p_skip_newlines(p)
  if p_at(p0, TkRparen) { ok_args(p_advance(p0), []) }
  else { parse_call_args_loop(p0, []) }
}

fn parse_call_args_loop(p: Parser, acc: [Expr]) : PArgs / Console {

  let p_start = p_skip_newlines(p)
  if p_at(p_start, TkRparen) {
    # Trailing comma: `f(a, b,)` — `acc` already has all args.
    ok_args(p_advance(p_start), list_reverse(acc))
  } else {
    let r = parse_expr(p_start)
    match r.r {
      None -> err_args(r.p)
      Some(e) -> {
        let p1 = p_skip_newlines(r.p)
        if p_at(p1, TkComma) { parse_call_args_loop(p_skip_newlines(p_advance(p1)), [e, ...acc]) }
        else if p_at(p1, TkRparen) {
          ok_args(p_advance(p1), list_reverse([e, ...acc]))
        }
        else { err_args(p_error_here(p1, "expected `,` or `)` in call arguments")) }
      }
    }
  }
}

# ====================================================================
# primary expressions — placeholders for later implementations
# ====================================================================

# m12.5: after a numeric literal, peek for an *adjacent* `<` (no
# whitespace between the literal and the `<`). When found, parse the
# unit expression and wrap the literal in an ELitUnit. Adjacency is
# the only disambiguator from a comparison `1 < 2`; the spec explicitly
# requires no space between the number and `<`.
fn try_lit_unit_annotation(p: Parser, lit: Expr, lit_tok: Token) : PExpr / Console {

  let nxt = p_peek(p)
  let lit_end = lit_tok.start + lit_tok.length
  if tk_is(nxt.kind, TkLt) and nxt.start == lit_end {
    let p2 = p_skip_newlines(p_advance(p))
    let ru = parse_unit_expr(p2)
    match ru.r {
      None -> err_e(ru.p)
      Some(u) -> {
        let p3 = p_skip_newlines(ru.p)
        if not p_at(p3, TkGt) {
          err_e(p_error_here(p3, "expected `>` to close the unit annotation on a literal"))
        } else {
          ok_e(p_advance(p3), mk_expr(ELitUnit(lit, u), lit_tok.line, lit_tok.col))
        }
      }
    }
  } else {
    ok_e(p, lit)
  }
}

fn parse_primary(p: Parser) : PExpr / Console {

  let t = p_peek(p)
  match t.kind {
    TkInt -> {
      let span = tok_source(p.src, t)
      let lit = mk_expr(EInt(decode_int(span)), t.line, t.col)
      try_lit_unit_annotation(p_advance(p), lit, t)
    }
    TkReal -> {
      let span = tok_source(p.src, t)
      let lit = mk_expr(EReal(decode_real(span)), t.line, t.col)
      try_lit_unit_annotation(p_advance(p), lit, t)
    }
    # Phase 1 of #267 — `<digits>i` desugars at parse time to
    # `complex.mk(0.0, <digits>)`. Span covers digits + trailing `i`;
    # strip the `i` before decoding. Resolver rewrites the
    # `EField(EVar("complex"), "mk")` callee to an EModCall once the
    # `complex` module is bound (auto-imported via the prelude path).
    TkComplex -> {
      let span = tok_source(p.src, t)
      let im_span = string_slice(span, 0, string_length(span) - 1)
      let im = decode_real(im_span)
      let zero = mk_expr(EReal(0.0), t.line, t.col)
      let im_e = mk_expr(EReal(im), t.line, t.col)
      let mod_var = mk_expr(EVar("complex"), t.line, t.col)
      let callee = mk_expr(EField(mod_var, "mk"), t.line, t.col)
      ok_e(p_advance(p), mk_expr(ECall(callee, [zero, im_e]), t.line, t.col))
    }
    TkTrue  -> ok_e(p_advance(p), mk_expr(EBool(true),  t.line, t.col))
    TkFalse -> ok_e(p_advance(p), mk_expr(EBool(false), t.line, t.col))
    TkChar  -> {
      let span = tok_source(p.src, t)
      ok_e(p_advance(p), mk_expr(EChar(decode_char(span)), t.line, t.col))
    }
    TkString -> {
      let span = tok_source(p.src, t)
      let is_triple =
        string_length(span) >= 6 and
        match char_at(span, 0) { Some(c) -> c == '"' _ -> false } and
        match char_at(span, 1) { Some(c) -> c == '"' _ -> false } and
        match char_at(span, 2) { Some(c) -> c == '"' _ -> false }
      ok_e(p_advance(p), mk_expr(EStr(span, is_triple), t.line, t.col))
    }
    TkUnderscore -> ok_e(p_advance(p), mk_expr(EUnder, t.line, t.col))
    TkDot -> {
      # m7f §19 (v1): `.method` in expression position desugars to
      # the closure `(__pl) => __pl.method`. Covers the
      # `xs | .label` and `map(xs, .label)` patterns the spec
      # cites as the most common method-ref use case. The fully
      # general `obj.method` (receiver-bound ref) form requires
      # parser ambiguity resolution against record field access
      # plus brand machinery for receiver-Fiber refs — deferred
      # to v2.
      let p1 = p_advance(p)
      let nxt = p_peek(p1)
      if tk_is(nxt.kind, TkIdent) {
        let name = tok_source(p1.src, nxt)
        let p2 = p_advance(p1)
        # Synthesise `(__pl) => __pl.name`. The placeholder param
        # name is mangled to avoid colliding with user bindings.
        let pl_name = "__pl"
        let pl_param = Param { pname: pl_name, ptype: None,
                                 pline: t.line, pcol: t.col }
        let pl_var = mk_expr(EVar(pl_name), t.line, t.col)
        let body = mk_expr(EField(pl_var, name), t.line, t.col)
        ok_e(p2, mk_expr(ELambda([pl_param], body), t.line, t.col))
      } else {
        # Bare `.` — pipeline placeholder per syntax-sugars.md.
        ok_e(p1, mk_expr(EPlaceholder, t.line, t.col))
      }
    }
    TkHole -> ok_e(p_advance(p), mk_expr(EHole(None), t.line, t.col))
    TkHoleName(nm) -> ok_e(p_advance(p), mk_expr(EHole(Some(nm)), t.line, t.col))
    TkTodoBang -> parse_todo_bang(p, t)
    TkRegex -> parse_regex_sigil(p, t)
    TkIdent -> parse_ident_primary(p, t)
    TkLparen -> parse_paren_or_lambda(p, t)
    TkLbracket -> parse_list_or_range(p, t)
    TkLbrace -> parse_brace_primary(p, t)
    TkIf -> parse_if(p, t)
    TkMatch -> parse_match(p, t)
    TkHandle -> parse_handle(p_advance(p), t)
    _ -> err_e(p_error_here(p, "expected expression"))
  }
}

# m7d §1: `todo!(msg)` — `todo!` is a single token (lexer-fused).
# The message must be a plain (non-triple, no interpolation) string
# literal so the compile-time `--holes-json` report and the runtime
# panic message agree on a single static value. The token at `t` is
# the `todo!`, and `p` is positioned right after it.
fn parse_todo_bang(p: Parser, t: Token) : PExpr / Console {

  let p1 = p_advance(p)
  if not p_at(p1, TkLparen) {
    err_e(p_error_here(p1, "expected `(` after `todo!`"))
  } else {
    let p2 = p_skip_newlines(p_advance(p1))
    let st = p_peek(p2)
    if not tk_is(st.kind, TkString) {
      err_e(p_error(p2, st, "`todo!` requires a literal string message: `todo!(\"...\")`"))
    } else {
      let span = tok_source(p2.src, st)
      let n = string_length(span)
      let is_triple =
        n >= 6 and
        match char_at(span, 0) { Some(c) -> c == '"' _ -> false } and
        match char_at(span, 1) { Some(c) -> c == '"' _ -> false } and
        match char_at(span, 2) { Some(c) -> c == '"' _ -> false }
      if is_triple {
        err_e(p_error(p2, st, "`todo!` does not accept triple-quoted strings"))
      } else {
        let body_start = 1
        let body_end = n - 1
        if has_interp(span, body_start, body_end) {
          err_e(p_error(p2, st,
            "`todo!` message must be a plain string literal (no interpolation)"))
        } else {
          let msg = string_slice(span, body_start, body_end - body_start)
          let p3 = p_skip_newlines(p_advance(p2))
          if not p_at(p3, TkRparen) {
            err_e(p_error_here(p3, "expected `)` after `todo!` message"))
          } else {
            ok_e(p_advance(p3), mk_expr(ETodo(msg), t.line, t.col))
          }
        }
      }
    }
  }
}

# `handle { body } with Eff [as alias] { clauses }`. Pinned in
# Doc A §*Handling*. Both blocks are parsed by handle-specific
# rules; the body is an ordinary block expression, the clauses
# block contains `op_name(args, resume) -> body` plus an optional
# `return(x) -> body` at the end.
fn parse_handle(p: Parser, t: Token) : PExpr / Console {

  let bt = p_peek(p)
  if not p_at(p, TkLbrace) {
    err_e(p_error_here(p, "expected `{` to start handle body"))
  } else {
    let body_r = parse_block(p, bt)
    match body_r.r {
      None -> err_e(body_r.p)
      Some(body) -> {
        let p1 = p_skip_newlines(body_r.p)
        if not p_at(p1, TkWith) {
          err_e(p_error_here(p1, "expected `with` after handle body"))
        } else {
          let p2 = p_advance(p1)
          let eff_t = p_peek(p2)
          if not tk_is(eff_t.kind, TkIdent) {
            err_e(p_error(p2, eff_t, "expected effect name after `with`"))
          } else {
            let eff_name = tok_source(p2.src, eff_t)
            let p3 = p_advance(p2)
            # m7b #11: optional `[T1, T2]` after the effect name —
            # the type instantiation. e.g. `with Reader[Int]`.
            let tyargs_r =
              if p_at(p3, TkLbracket) {
                parse_row_label_args(p_skip_newlines(p_advance(p3)), [])
              } else {
                PRowArgs { p: p3, r: Some([]) }
              }
            match tyargs_r.r {
              None -> err_e(tyargs_r.p)
              Some(eff_tyargs) -> {
                # m7b #11: optional `(init)` after the type args —
                # the handler-state initial value, e.g. `with State[Int](0)`.
                let init_r =
                  if p_at(tyargs_r.p, TkLparen) {
                    let p_io = p_skip_newlines(p_advance(tyargs_r.p))
                    let ie = parse_expr(p_io)
                    match ie.r {
                      None -> PInit { p: ie.p, r: None, has_init: true }
                      Some(ix) -> {
                        let p_ic = p_skip_newlines(ie.p)
                        if not p_at(p_ic, TkRparen) {
                          PInit { p: p_error_here(p_ic, "expected `)` after handler-state initializer"),
                                  r: None, has_init: true }
                        } else {
                          PInit { p: p_advance(p_ic), r: Some(ix), has_init: true }
                        }
                      }
                    }
                  } else {
                    PInit { p: tyargs_r.p, r: None, has_init: false }
                  }
                let init_failed =
                  if init_r.has_init {
                    match init_r.r { None -> true Some(_) -> false }
                  } else { false }
                if init_failed {
                  err_e(init_r.p)
                } else {
                let alias_r = parse_handle_alias(init_r.p)
                let p4 = p_skip_newlines(alias_r.p)
                if not p_at(p4, TkLbrace) {
                  err_e(p_error_here(p4, "expected `{` to start handler clauses"))
                } else {
                  let p5 = p_skip_newlines(p_advance(p4))
                  let cr = parse_handle_clauses(p5, [], None, [])
                  match cr.r {
                    None -> err_e(cr.p)
                    Some(_) -> {
                      let handle_e = mk_expr(
                        EHandle(body, eff_name, eff_tyargs, init_r.r,
                                alias_r.r, cr.clauses, cr.return_clause),
                        t.line, t.col)
                      # m7b #5b extension (issue #148, Option A): a `var`
                      # or `let` decl at the top of the clause list lifts
                      # to a sibling block whose tail is the handler. The
                      # existing `desugar_var_block` pass then converts
                      # each `SVar` into a wrapping `with State[T] as
                      # name` handler. When the prelude is empty we emit
                      # the bare `EHandle` so handlers without `var` pay
                      # no wrapping overhead.
                      match cr.prelude {
                        [] -> ok_e(cr.p, handle_e)
                        _  -> ok_e(cr.p,
                                mk_expr(EBlock(cr.prelude, Some(handle_e)),
                                        t.line, t.col))
                      }
                    }
                  }
                }
                }
              }
            }
          }
        }
      }
    }
  }
}

type PInit = { p: Parser, r: Option[Expr], has_init: Bool }

# Handler-clause params: like fn params but the type annotation is
# optional. `print(s, resume) -> ...` is the common shape.
fn parse_clause_params(p: Parser, acc: [Param]) : PParams / Console {

  if p_at(p, TkRparen) { PParams { p: p_advance(p), r: Some(list_reverse(acc)) } }
  else {
    let t = p_peek(p)
    if not tk_is(t.kind, TkIdent) {
      PParams { p: p_error(p, t, "expected parameter name"), r: None }
    } else {
      let name = tok_source(p.src, t)
      let p1 = p_advance(p)
      let opt_ty_r =
        if p_at(p1, TkColon) {
          let rt = parse_type(p_advance(p1))
          match rt.r {
            None -> PTy { p: rt.p, r: None }
            Some(ty) -> PTy { p: rt.p, r: Some(ty) }
          }
        } else {
          PTy { p: p1, r: None }
        }
      let pm = Param { pname: name, ptype: opt_ty_r.r, pline: t.line, pcol: t.col }
      let p2 = p_skip_newlines(opt_ty_r.p)
      if p_at(p2, TkComma) {
        parse_clause_params(p_skip_newlines(p_advance(p2)), [pm, ...acc])
      } else if p_at(p2, TkRparen) {
        PParams { p: p_advance(p2), r: Some(list_reverse([pm, ...acc])) }
      } else {
        PParams { p: p_error_here(p2, "expected `,` or `)` in parameter list"), r: None }
      }
    }
  }
}

type PAlias = { p: Parser, r: Option[String] }

fn parse_handle_alias(p: Parser) : PAlias / Console {

  if not p_at(p, TkAs) { PAlias { p: p, r: None } }
  else {
    let p1 = p_advance(p)
    let nt = p_peek(p1)
    if not tk_is(nt.kind, TkIdent) {
      PAlias { p: p_error(p1, nt, "expected alias name after `as`"), r: None }
    } else {
      PAlias { p: p_advance(p1), r: Some(tok_source(p1.src, nt)) }
    }
  }
}

type PClauses = {
  p: Parser,
  clauses: [HClause],
  return_clause: Option[HReturn],
  prelude: [Stmt],
  r: Option[Bool]
}

# m7b #5b extension (issue #148, Option A): a `var` or `let` decl
# may appear at the top of the clause list, before all operation
# clauses. The parser collects them into a `prelude` and the
# caller wraps the `EHandle` in an `EBlock(prelude, Some(EHandle))`.
# The existing `desugar_var_block` pass then lifts each `SVar`
# into a sibling `with State[T](init) as name` that wraps the
# handler. Once an operation clause has been seen, any further
# `var` / `let` is a parse error — the rule is "var/let must
# precede all operation clauses inside one handler block."
fn parse_handle_clauses(p: Parser, acc: [HClause], rret: Option[HReturn], prelude: [Stmt]) : PClauses / Console {

  let p0 = p_skip_newlines(p)
  if p_at(p0, TkRbrace) {
    PClauses { p: p_advance(p0), clauses: list_reverse(acc),
               return_clause: rret, prelude: list_reverse(prelude), r: Some(true) }
  } else {
    let id_t = p_peek(p0)
    if tk_is(id_t.kind, TkVar) {
      match acc {
        [] -> {
          let sr = parse_var(p0, id_t)
          match sr.r {
            None -> PClauses { p: sr.p, clauses: [], return_clause: None,
                               prelude: [], r: None }
            Some(s) -> parse_handle_clauses(sr.p, acc, rret, [s, ...prelude])
          }
        }
        _ -> PClauses { p: p_error(p0, id_t,
               "`var` and `let` must precede all operation clauses inside a handler"),
               clauses: [], return_clause: None, prelude: [], r: None }
      }
    } else if tk_is(id_t.kind, TkLet) {
      match acc {
        [] -> {
          let sr = parse_let(p0, id_t)
          match sr.r {
            None -> PClauses { p: sr.p, clauses: [], return_clause: None,
                               prelude: [], r: None }
            Some(s) -> parse_handle_clauses(sr.p, acc, rret, [s, ...prelude])
          }
        }
        _ -> PClauses { p: p_error(p0, id_t,
               "`var` and `let` must precede all operation clauses inside a handler"),
               clauses: [], return_clause: None, prelude: [], r: None }
      }
    } else if not tk_is(id_t.kind, TkIdent) {
      PClauses { p: p_error(p0, id_t, "expected operation name in handler"),
                 clauses: [], return_clause: None, prelude: [], r: None }
    } else {
      let name = tok_source(p0.src, id_t)
      let p1 = p_advance(p0)
      if not p_at(p1, TkLparen) {
        PClauses { p: p_error_here(p1, "expected `(` after operation name"),
                   clauses: [], return_clause: None, prelude: [], r: None }
      } else {
        let p2 = p_skip_newlines(p_advance(p1))
        let params_r = parse_clause_params(p2, [])
        match params_r.r {
          None -> PClauses { p: params_r.p, clauses: [], return_clause: None,
                             prelude: [], r: None }
          Some(params) -> {
            let p3 = p_skip_newlines(params_r.p)
            if not p_at(p3, TkArrow) {
              PClauses { p: p_error_here(p3, "expected `->` after operation parameters"),
                         clauses: [], return_clause: None, prelude: [], r: None }
            } else {
              let p4 = p_skip_newlines(p_advance(p3))
              let rb = parse_expr(p4)
              match rb.r {
                None -> PClauses { p: rb.p, clauses: [], return_clause: None,
                                   prelude: [], r: None }
                Some(body) -> {
                  if name == "return" {
                    match params {
                      [pp] -> {
                        let hr = HR(pp.pname, body, id_t.line, id_t.col)
                        parse_handle_clauses(rb.p, acc, Some(hr), prelude)
                      }
                      _ -> PClauses { p: p_error(p3, id_t,
                             "return clause takes exactly one parameter"),
                             clauses: [], return_clause: None, prelude: [], r: None }
                    }
                  } else {
                    let hc = HC(name, params, body, id_t.line, id_t.col)
                    parse_handle_clauses(rb.p, [hc, ...acc], rret, prelude)
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}

fn parse_ident_primary(p: Parser, t: Token) : PExpr / Console {

  let name = tok_source(p.src, t)
  let p1 = p_advance(p)
  # m7e §11: `variants[T]()` — compile-time enumeration of a nullary
  # sum type's constructors. Special-cased before `[` would otherwise
  # pick up the postfix EIndex path. Active only when the source
  # ident is exactly "variants" and the next token is `[`. Any other
  # use of an identifier called `variants` followed by an expression
  # in `[...]` still parses as EIndex via parse_postfix_rest.
  if name == "variants" and p_at(p1, TkLbracket) {
    parse_variants_of(p1, t)
  }
  # m12.6.e: `ensure(value) where pred` primary — narrows `value`
  # into the refined type via a runtime check, returning
  # `Option[T]`. Recognised only when the call is followed by
  # `where`; without it, `ensure(x)` parses as an ordinary call so
  # user code that defines a function called `ensure` is unaffected.
  else if name == "ensure" and p_at(p1, TkLparen) {
    parse_ensure_primary(p1, t)
  }
  # Lambda: `name => body`. Body is parsed via `parse_or`, NOT
  # `parse_expr`, so a top-level pipe operator (`|`, `||`, `|?`,
  # `|>`) terminates the body and chains at the enclosing pipe
  # level. See issue #422 and `docs/syntax-sugars.md` §11.
  else if p_at(p1, TkFatArrow) {
    let p2 = p_advance(p1)
    let r = parse_or(p2)
    match r.r {
      None -> err_e(r.p)
      Some(body) -> {
        let param = Param { pname: name, ptype: None, pline: t.line, pcol: t.col }
        ok_e(r.p, mk_expr(ELambda([param], body), t.line, t.col))
      }
    }
  }
  # Record literal: `Name { ... }` — but only when the name is Uppercase.
  else if is_upper_ident(p.src, t) and p_at(p1, TkLbrace) {
    parse_record_lit(p1, name, t)
  }
  # Issue #456: qualified record literal `mod.Type { ... }`. Lowercase
  # head + `.UpperIdent` + `{` commits to a record literal whose type
  # name is folded into the dotted string `"mod.Type"`. The qualtype
  # rewriter pass validates against the module table and strips the
  # qualifier before resolve runs (mirrors the qualified-type-head
  # treatment in `parse_named_type`, issue #232).
  else if (not is_upper_ident(p.src, t)) and p_at(p1, TkDot) and
          tk_is(p_peek1(p1).kind, TkIdent) and
          is_upper_ident(p1.src, p_peek1(p1)) and
          tk_is(p_peek2(p1).kind, TkLbrace) {
    let nt = p_peek1(p1)
    let qname = concat_all([name, ".", tok_source(p1.src, nt)])
    # Advance past `.` and the UpperIdent so `p2` is at the `{`.
    let p2 = p_advance(p_advance(p1))
    parse_record_lit(p2, qname, t)
  }
  # Plain variable reference.
  else {
    ok_e(p1, mk_expr(EVar(name), t.line, t.col))
  }
}

# m7e §11: parse `variants[T]()`. `p` is positioned at the `[`; `t` is
# the original `variants` token (used for line/col). The closing `()`
# is mandatory and carries no payload — `variants[T](anything)` is a
# parse error. The TypeExpr inside the brackets is whatever
# `parse_type` accepts; resolver validates that it is a sum type with
# nullary-only variants.
fn parse_variants_of(p: Parser, t: Token) : PExpr / Console {

  let p1 = p_skip_newlines(p_advance(p))
  let r = parse_type(p1)
  match r.r {
    None -> err_e(r.p)
    Some(ty) -> {
      let p2 = p_skip_newlines(r.p)
      if not p_at(p2, TkRbracket) {
        err_e(p_error_here(p2, "expected `]` after type in `variants[T]`"))
      } else {
        let p3 = p_advance(p2)
        if not p_at(p3, TkLparen) {
          err_e(p_error_here(p3, "expected `()` after `variants[T]`"))
        } else {
          let p4 = p_advance(p3)
          if not p_at(p4, TkRparen) {
            err_e(p_error_here(p4,
              "`variants[T]()` does not accept arguments"))
          } else {
            ok_e(p_advance(p4),
                  mk_expr(EVariantsOf(ty, []), t.line, t.col))
          }
        }
      }
    }
  }
}

# m12.6.e: parse `ensure(value) where pred`. `p` is positioned at the
# `(` of `ensure(...)`; `t` is the original `ensure` token. The form
# desugars to:
#   { let self = value
#     if pred { Some(self) } else { None } }
# `self` is bound to the value so the predicate (which conventionally
# uses `self`, possibly elided in the leading-comparator form) sees it
# as a regular local. Without a `where` suffix, `ensure(...)` falls
# through to an ordinary call so user-defined `ensure` functions are
# preserved.
fn parse_ensure_primary(p: Parser, t: Token) : PExpr / Console {

  let p1 = p_skip_newlines(p_advance(p))
  let rv = parse_expr(p1)
  match rv.r {
    None -> err_e(rv.p)
    Some(value) -> {
      let p2 = p_skip_newlines(rv.p)
      if not p_at(p2, TkRparen) {
        err_e(p_error_here(p2, "expected `)` after value in `ensure(...)`"))
      } else {
        let p3 = p_advance(p2)
        if not p_at(p3, TkWhere) {
          # No `where` suffix — fall back to an ordinary call so the
          # name `ensure` remains usable as a regular function.
          let callee = mk_expr(EVar("ensure"), t.line, t.col)
          ok_e(p3, mk_expr(ECall(callee, [value]), t.line, t.col))
        } else {
          let p4 = p_skip_newlines(p_advance(p3))
          let pred_r = parse_refinement_predicate(p4, t.line, t.col)
          match pred_r.r {
            None -> err_e(pred_r.p)
            Some(pred) -> {
              # Build the desugared block:
              #   let self = value
              #   if pred { Some(self) } else { None }
              let self_let = SLet(mk_pat(PBind("self"), t.line, t.col),
                                  None, value)
              let self_var = mk_expr(EVar("self"), t.line, t.col)
              let some_call = mk_expr(ECall(
                mk_expr(EVar("Some"), t.line, t.col),
                [self_var]), t.line, t.col)
              let none_var = mk_expr(EVar("None"), t.line, t.col)
              let if_expr = mk_expr(EIf(pred, some_call, Some(none_var)),
                                    t.line, t.col)
              let block = mk_expr(EBlock([self_let], Some(if_expr)),
                                  t.line, t.col)
              ok_e(pred_r.p, block)
            }
          }
        }
      }
    }
  }
}

# m12.6.x #7: parse a `~r/pattern/` sigil token into an expression.
# The lexer has already validated the delimiter shape and stored the
# full sigil source span on the token. We desugar to a runtime call
# `regex_compile_or_panic("<pattern>")` whose result is a `Regex`
# value — meaning `~r/pat/` works as a first-class expression in any
# position, not just inside refinement predicates.
#
# The pattern body is wrapped as a kaikai string literal with two
# byte-level escapes (`\` -> `\\`, `"` -> `\"`) so the post-decode
# bytes match the regex source verbatim. v1 forbids `#` in the body
# because it would collide with kaikai's `#{...}` string
# interpolation; users wanting `#` in v1 can build the regex via
# `regex_compile` directly.
fn parse_regex_sigil(p: Parser, t: Token) : PExpr / Console {

  let span = tok_source(p.src, t)
  let n = string_length(span)
  # Span shape: `~r/pattern/`. Strip the 3-char prefix `~r/` and the
  # trailing `/`. The lexer guarantees both delimiters are present
  # (otherwise it emitted TkError, never TkRegex).
  let pattern = string_slice(span, 3, n - 4)
  if regex_pattern_has_hash(pattern, 0, string_length(pattern)) {
    err_e(p_error_here(p,
      "regex sigil contains `#`, which v1 forbids (would collide with kaikai string interpolation); use `regex_compile` directly for patterns containing `#`"))
  } else {
    let escaped = regex_pattern_to_kai_str_body(pattern, 0, string_length(pattern), "")
    let str_span = concat_all(["\"", escaped, "\""])
    let pat_str = mk_expr(EStr(str_span, false), t.line, t.col)
    let callee = mk_expr(EVar("regex_compile_or_panic"), t.line, t.col)
    let call = mk_expr(ECall(callee, [pat_str]), t.line, t.col)
    ok_e(p_advance(p), call)
  }
}

# Walk the regex pattern body byte-by-byte, escaping the two
# characters that have a load-bearing meaning inside a kaikai
# string literal: `\` (escape introducer) and `"` (terminator).
# Every other byte passes through verbatim — including bytes that
# would be metacharacters at the regex level. The result is the
# *body* of a kaikai string literal; the caller wraps it in `"..."`.
fn regex_pattern_to_kai_str_body(s: String, i: Int, n: Int, acc: String) : String {
  if i >= n { acc }
  else {
    match char_at(s, i) {
      None -> acc
      Some(c) -> {
        let piece =
          if c == '\\' { "\\\\" }
          else if c == '"' { "\\\"" }
          else { "#{c}" }
        regex_pattern_to_kai_str_body(s, i + 1, n, string_concat(acc, piece))
      }
    }
  }
}

fn regex_pattern_has_hash(s: String, i: Int, n: Int) : Bool {
  if i >= n { false }
  else {
    match char_at(s, i) {
      None -> false
      Some(c) -> if c == '#' { true } else { regex_pattern_has_hash(s, i + 1, n) }
    }
  }
}

fn parse_record_lit(p: Parser, type_name: String, tname: Token) : PExpr / Console {

  # `{` is next. Consume it.
  let p1 = p_skip_newlines(p_advance(p))
  if p_at(p1, TkRbrace) {
    ok_e(p_advance(p1), mk_expr(ERecordLit(type_name, []), tname.line, tname.col))
  } else if p_at(p1, TkEllipsis) {
    # issue #326 — record-spread sugar: `T { ...src, x: 10, y: 20 }`.
    # The `...src` MUST be the first item; only named-field overrides
    # may follow. The source is captured as the first FieldInit with
    # the `__spread__` sentinel name and resolved by
    # `dpr_record_lit` against the record's declared field list.
    let _dotsTok = p_peek(p1)
    let p2 = p_skip_newlines(p_advance(p1))
    let r = parse_expr(p2)
    match r.r {
      None -> err_e(r.p)
      Some(src) -> {
        let acc0 = [FI(spread_field_marker(), src)]
        let p3 = p_skip_newlines(r.p)
        if p_at(p3, TkRbrace) {
          ok_e(p_advance(p3), mk_expr(ERecordLit(type_name, list_reverse(acc0)),
                                      tname.line, tname.col))
        } else if p_at(p3, TkComma) {
          parse_record_spread_loop(p_skip_newlines(p_advance(p3)), acc0, type_name, tname)
        } else {
          err_e(p_error_here(p3, "expected `,` or `}` after `...` source in record literal"))
        }
      }
    }
  } else {
    # issue #266 dispatch: peek the first item to choose between the
    # named-field path (existing) and the positional-sugar path. The
    # named path also covers `{ x, y }` punning, where the first item
    # is a bare ident followed by `,` or `}` — keeping legacy
    # behavior. Anything else (literal, call, expression, or an ident
    # followed by an expression-continuation token) routes to the
    # positional path. The positional fields are tagged with a
    # `__pos_<i>__` sentinel name; `desugar_pos_records_decls`
    # rewrites them into real field names using the record's
    # declared field order before any other pre-typer pass runs.
    let tk0 = p_peek(p1)
    let tk1 = p_peek1(p1)
    let tk1_named_follow = tk_is(tk1.kind, TkColon) or tk_is(tk1.kind, TkComma) or tk_is(tk1.kind, TkRbrace)
    let is_named_first = tk_is(tk0.kind, TkIdent) and tk1_named_follow
    if is_named_first {
      parse_record_fields_loop(p1, [], type_name, tname)
    } else {
      parse_record_pos_loop(p1, [], 0, type_name, tname)
    }
  }
}

# issue #326 — parse named-field overrides after `...src,`. The
# spread already lives at `acc[0]` with the `__spread__` sentinel.
# Pun and positional are rejected explicitly: pun would silently
# bind `x: x` from the local scope, which the proposal forbids;
# positional would conflict with #266. A second `...` is also
# rejected — v1 admits a single spread per literal.
fn parse_record_spread_loop(p: Parser, acc: [FieldInit], type_name: String, tname: Token) : PExpr / Console {

  let p0 = p_skip_newlines(p)
  if p_at(p0, TkRbrace) {
    ok_e(p_advance(p0), mk_expr(ERecordLit(type_name, list_reverse(acc)),
                                tname.line, tname.col))
  } else if p_at(p0, TkEllipsis) {
    err_e(p_error_here(p0,
      "record literal admits a single `...` spread; remove the second one"))
  } else {
    let tk = p_peek(p0)
    if not tk_is(tk.kind, TkIdent) {
      err_e(p_error(p0, tk,
        "expected named field override (`x: expr`) after `...` in record literal"))
    } else {
      let fname = tok_source(p0.src, tk)
      let p1 = p_advance(p0)
      if p_at(p1, TkColon) {
        let p2 = p_skip_newlines(p_advance(p1))
        let r = parse_expr(p2)
        match r.r {
          None -> err_e(r.p)
          Some(val) -> {
            let acc1 = [FI(fname, val), ...acc]
            let p3 = p_skip_newlines(r.p)
            if p_at(p3, TkComma) {
              parse_record_spread_loop(p_skip_newlines(p_advance(p3)), acc1, type_name, tname)
            } else if p_at(p3, TkRbrace) {
              ok_e(p_advance(p3), mk_expr(ERecordLit(type_name, list_reverse(acc1)),
                                          tname.line, tname.col))
            } else {
              err_e(p_error_here(p3, "expected `,` or `}` in record literal"))
            }
          }
        }
      } else {
        err_e(p_error(p1, p_peek(p1),
          "spread record overrides must use named field syntax `x: expr`; pun shorthand is not allowed after `...`"))
      }
    }
  }
}

# issue #266 — positional record sugar. Accumulates positional
# expressions tagged with `__pos_<i>__` field-name sentinels. Each
# item is a full Expr; intermixing `IDENT :` is a parse error.
fn parse_record_pos_loop(p: Parser, acc: [FieldInit], i: Int, type_name: String, tname: Token) : PExpr / Console {

  let p0 = p_skip_newlines(p)
  # Reject mixed forms: any subsequent item starting with `IDENT :`
  # signals named-field syntax inside a positional list.
  let tk0 = p_peek(p0)
  let tk1 = p_peek1(p0)
  if tk_is(tk0.kind, TkRbrace) {
    # Trailing comma: `R { 1, 2, }` — close the literal.
    ok_e(p_advance(p0), mk_expr(ERecordLit(type_name, list_reverse(acc)), tname.line, tname.col))
  } else if tk_is(tk0.kind, TkIdent) and tk_is(tk1.kind, TkColon) {
    err_e(p_error_here(p0, "expected positional or all-named record fields, found mixed forms"))
  } else {
    let r = parse_expr(p0)
    match r.r {
      None -> err_e(r.p)
      Some(val) -> {
        let acc1 = [FI(pos_field_marker(i), val), ...acc]
        let p1 = p_skip_newlines(r.p)
        if p_at(p1, TkComma) {
          parse_record_pos_loop(p_skip_newlines(p_advance(p1)), acc1, i + 1, type_name, tname)
        } else if p_at(p1, TkRbrace) {
          ok_e(p_advance(p1), mk_expr(ERecordLit(type_name, list_reverse(acc1)), tname.line, tname.col))
        } else {
          err_e(p_error_here(p1, "expected `,` or `}` in positional record literal"))
        }
      }
    }
  }
}

# Sentinel field-name builder. Resolved by `desugar_pos_records_decls`
# back to the record's declared field name in declaration order. Any
# leak into a downstream pass is a bug — the sentinel is never a
# legal record-field identifier (real ones cannot start with `__`).
fn pos_field_marker(i: Int) : String =
  string_concat("__pos_", string_concat(int_to_string(i), "__"))

# issue #326 — sentinel field name used by the parser when the
# first item in a record literal is `...src`. `dpr_record_lit`
# detects this marker, captures the source expression, and expands
# it against the record's declared fields before any later pass
# sees the literal. As with `__pos_<i>__`, real field names
# cannot start with `__`, so the sentinel is unambiguous.
fn spread_field_marker() : String = "__spread__"

fn is_spread_field_marker(s: String) : Bool = s == "__spread__"

fn is_pos_field_marker(s: String) : Bool {
  let n = string_length(s)
  if n < 8 { false }
  else {
    match char_at(s, 0) { Some(c0) -> if c0 != '_' { false } else {
      match char_at(s, 1) { Some(c1) -> if c1 != '_' { false } else {
        match char_at(s, 2) { Some(c2) -> if c2 != 'p' { false } else {
          match char_at(s, 3) { Some(c3) -> if c3 != 'o' { false } else {
            match char_at(s, 4) { Some(c4) -> if c4 != 's' { false } else {
              match char_at(s, 5) { Some(c5) -> c5 == '_'
                None -> false
              }
              } None -> false }
            } None -> false }
          } None -> false }
        } None -> false }
      } None -> false }
  }
}

fn parse_record_fields_loop(p: Parser, acc: [FieldInit], type_name: String, tname: Token) : PExpr / Console {

  let p0 = p_skip_newlines(p)
  let tk = p_peek(p0)
  if tk_is(tk.kind, TkEllipsis) {
    err_e(p_error(p0, tk,
      "`...` must be the first item in a record literal — found a field before the spread"))
  } else if tk_is(tk.kind, TkRbrace) {
    # Trailing comma: `R { a: 1, b: 2, }` — `acc` already contains the
    # parsed fields; close the literal here.
    ok_e(p_advance(p0), mk_expr(ERecordLit(type_name, list_reverse(acc)), tname.line, tname.col))
  } else if not tk_is(tk.kind, TkIdent) {
    err_e(p_error(p0, tk, "expected field name in record literal"))
  } else {
    let fname = tok_source(p0.src, tk)
    let p1 = p_advance(p0)
    if p_at(p1, TkColon) {
      let p2 = p_skip_newlines(p_advance(p1))
      let r = parse_expr(p2)
      match r.r {
        None -> err_e(r.p)
        Some(val) -> {
          let acc1 = [FI(fname, val), ...acc]
          let p3 = p_skip_newlines(r.p)
          if p_at(p3, TkComma) {
            parse_record_fields_loop(p_skip_newlines(p_advance(p3)), acc1, type_name, tname)
          } else if p_at(p3, TkRbrace) {
            ok_e(p_advance(p3), mk_expr(ERecordLit(type_name, list_reverse(acc1)), tname.line, tname.col))
          } else {
            err_e(p_error_here(p3, "expected `,` or `}` in record literal"))
          }
        }
      }
    }
    # m7d §10: record-literal punning. `{ x, y }` desugars to
    # `{ x: x, y: y }`. Symmetric with the pattern form already
    # parsed by `parse_record_pattern_fields` (PField is_shorthand).
    # Mixed forms (`{ x, y: other }`) compose because the punning
    # decision is per-field.
    else if p_at(p1, TkComma) or p_at(p1, TkRbrace) {
      let val = mk_expr(EVar(fname), tk.line, tk.col)
      let acc1 = [FI(fname, val), ...acc]
      if p_at(p1, TkComma) {
        parse_record_fields_loop(p_skip_newlines(p_advance(p1)), acc1, type_name, tname)
      } else {
        ok_e(p_advance(p1), mk_expr(ERecordLit(type_name, list_reverse(acc1)), tname.line, tname.col))
      }
    }
    else {
      err_e(p_error_here(p1, "expected `:`, `,`, or `}` after field name in record literal"))
    }
  }
}

fn parse_paren_or_lambda(p: Parser, t: Token) : PExpr / Console {

  # We need to distinguish:
  #   (expr)                  — grouping
  #   ()                       — unit
  #   () => expr               — zero-arg lambda
  #   (a, b, ...) => expr      — multi-arg lambda
  #   (a) => expr              — single-arg lambda (parenthesised)
  # Strategy: speculatively parse a lambda-param list. If followed by
  # `=>`, it's a lambda. Otherwise it was a parenthesised expression
  # and we re-parse from the original position.
  let p1 = p_skip_newlines(p_advance(p))
  # Empty parens: unit, or zero-arg lambda. Lambda body is parsed
  # via `parse_or` so a trailing pipe operator chains at the
  # enclosing level (issue #422).
  if p_at(p1, TkRparen) {
    let p2 = p_advance(p1)
    if p_at(p2, TkFatArrow) {
      let p3 = p_advance(p2)
      let r = parse_or(p3)
      match r.r {
        None -> err_e(r.p)
        Some(body) -> ok_e(r.p, mk_expr(ELambda([], body), t.line, t.col))
      }
    } else {
      ok_e(p2, mk_expr(EUnit, t.line, t.col))
    }
  } else {
    # Try lambda: tentatively scan for an ident list ending with `)` `=>`.
    # Body parsed via `parse_or` (issue #422).
    match try_parse_lambda_params(p1) {
      Some(res) -> {
        let r = parse_or(res.p)
        match r.r {
          None -> err_e(r.p)
          Some(body) -> ok_e(r.p, mk_expr(ELambda(res.params, body), t.line, t.col))
        }
      }
      None -> {
        # Fall back to `( expr )` or `( a, b, ... )` n-tuple sugar (#154).
        let r = parse_expr(p1)
        match r.r {
          None -> err_e(r.p)
          Some(e) -> {
            let p2 = p_skip_newlines(r.p)
            if p_at(p2, TkRparen) { ok_e(p_advance(p2), e) }
            else if p_at(p2, TkComma) {
              # n-tuple expression sugar: (a, b) => Pair { fst: a, snd: b },
              # (a, b, c) => Triple { ... }, (a, b, c, d) => Quad { ... }.
              # N capped at 4 — wider products should be a named record.
              parse_tuple_expr_rest(p_skip_newlines(p_advance(p2)), [e], t)
            }
            else { err_e(p_error_here(p2, "expected `)` after expression")) }
          }
        }
      }
    }
  }
}

# n-tuple expression sugar (#154). Called once the leading expr and a
# trailing `,` have been consumed. Accumulates further comma-separated
# exprs (in reverse) until `)`. On close, desugars to a record literal
# of the appropriate stdlib type (Pair / Triple / Quad). Arity > 4 is
# rejected with a diagnostic naming the cap.
fn parse_tuple_expr_rest(p: Parser, acc: [Expr], t: Token) : PExpr / Console {

  if p_at(p, TkRparen) {
    # Trailing comma: `(1, 2, 3,)` — `acc` already has all elements.
    let elems = list_reverse(acc)
    let p2 = p_advance(p)
    match tuple_type_for_arity(list_length(elems)) {
      None -> err_e(p_error_here(p, "n-tuple sugar supports arity 2..4 only — use a named record for wider products"))
      Some(name) -> ok_e(p2, mk_expr(ERecordLit(name, build_tuple_field_inits(elems, 0, [])), t.line, t.col))
    }
  } else {
  let r = parse_expr(p)
  match r.r {
    None -> err_e(r.p)
    Some(e) -> {
      let p1 = p_skip_newlines(r.p)
      if p_at(p1, TkComma) {
        parse_tuple_expr_rest(p_skip_newlines(p_advance(p1)), [e, ...acc], t)
      } else if p_at(p1, TkRparen) {
        let elems = list_reverse([e, ...acc])
        let p2 = p_advance(p1)
        match tuple_type_for_arity(list_length(elems)) {
          None -> err_e(p_error_here(p1, "n-tuple sugar supports arity 2..4 only — use a named record for wider products"))
          Some(name) -> ok_e(p2, mk_expr(ERecordLit(name, build_tuple_field_inits(elems, 0, [])), t.line, t.col))
        }
      } else {
        err_e(p_error_here(p1, "expected `,` or `)` in tuple expression"))
      }
    }
  }
  }
}

# Map arity → stdlib tuple type name. `None` for unsupported arities.
fn tuple_type_for_arity(n: Int) : Option[String] {
  match n {
    2 -> Some("Pair")
    3 -> Some("Triple")
    4 -> Some("Quad")
    _ -> None
  }
}

# Map positional index → tuple field name. Same convention across
# Pair / Triple / Quad: fst, snd, trd, frt.
fn tuple_field_name(i: Int) : String {
  match i {
    0 -> "fst"
    1 -> "snd"
    2 -> "trd"
    _ -> "frt"
  }
}

fn build_tuple_field_inits(elems: [Expr], i: Int, acc: [FieldInit]) : [FieldInit] {
  match elems {
    [] -> list_reverse(acc)
    [e, ...rest] -> build_tuple_field_inits(rest, i + 1, [FI(tuple_field_name(i), e), ...acc])
  }
}

# A lambda parameter list is a comma-separated sequence of identifiers
# (optionally with `: Type` annotations) followed by `)` then `=>`.
# This scan is non-destructive: it returns the parser advanced past the
# `=>` on success, None on failure.
type LamParams = { p: Parser, params: [Param] }

fn try_parse_lambda_params(p: Parser) : Option[LamParams] / Console {

  try_parse_lambda_params_loop(p, [])
}

fn try_parse_lambda_params_loop(p: Parser, acc: [Param]) : Option[LamParams] / Console {

  let t = p_peek(p)
  if not tk_is(t.kind, TkIdent) { None }
  else {
    let name = tok_source(p.src, t)
    let p1 = p_advance(p)
    # Optional `: Type`
    let p2_opt =
      if p_at(p1, TkColon) {
        let r = parse_type(p_advance(p1))
        match r.r {
          None -> None
          Some(_) -> Some(r.p)
        }
      } else {
        Some(p1)
      }
    match p2_opt {
      None -> None
      Some(p2) -> {
        let param = Param { pname: name, ptype: None, pline: t.line, pcol: t.col }
        let acc1 = [param, ...acc]
        if p_at(p2, TkComma) {
          try_parse_lambda_params_loop(p_skip_newlines(p_advance(p2)), acc1)
        } else if p_at(p2, TkRparen) {
          let p3 = p_advance(p2)
          if p_at(p3, TkFatArrow) {
            Some(LamParams { p: p_advance(p3), params: list_reverse(acc1) })
          } else { None }
        } else { None }
      }
    }
  }
}

# ====================================================================
# list / range
# ====================================================================

fn parse_list_or_range(p: Parser, t: Token) : PExpr / Console {

  let p1 = p_skip_newlines(p_advance(p))
  if p_at(p1, TkRbracket) {
    ok_e(p_advance(p1), mk_expr(EList([]), t.line, t.col))
  } else {
    # Parse first element (could start with `...`).
    parse_first_list_elem(p1, t)
  }
}

fn parse_first_list_elem(p: Parser, t: Token) : PExpr / Console {

  if p_at(p, TkEllipsis) {
    let r = parse_expr(p_advance(p))
    match r.r {
      None -> err_e(r.p)
      Some(e) -> parse_list_rest(r.p, [ElSpread(e)], t)
    }
  } else {
    let r = parse_expr(p)
    match r.r {
      None -> err_e(r.p)
      Some(first) -> {
        # Range: `[ a .. b ]` or `[ a .. b .. step ]`.
        let p1 = p_skip_newlines(r.p)
        if p_at(p1, TkDotDot) {
          let r2 = parse_expr(p_skip_newlines(p_advance(p1)))
          match r2.r {
            None -> err_e(r2.p)
            Some(to) -> {
              let p2 = p_skip_newlines(r2.p)
              if p_at(p2, TkDotDot) {
                let r3 = parse_expr(p_skip_newlines(p_advance(p2)))
                match r3.r {
                  None -> err_e(r3.p)
                  Some(step) -> {
                    let p3 = p_skip_newlines(r3.p)
                    if p_at(p3, TkRbracket) {
                      ok_e(p_advance(p3), mk_expr(ERange(first, to, Some(step)), t.line, t.col))
                    } else { err_e(p_error_here(p3, "expected `]` at end of range")) }
                  }
                }
              } else if p_at(p2, TkRbracket) {
                ok_e(p_advance(p2), mk_expr(ERange(first, to, None), t.line, t.col))
              } else { err_e(p_error_here(p2, "expected `]` at end of range")) }
            }
          }
        } else {
          parse_list_rest(p1, [ElPlain(first)], t)
        }
      }
    }
  }
}

fn parse_list_rest(p: Parser, acc: [ListElem], t: Token) : PExpr / Console {

  let p0 = p_skip_newlines(p)
  if p_at(p0, TkRbracket) {
    ok_e(p_advance(p0), mk_expr(EList(list_reverse(acc)), t.line, t.col))
  } else if p_at(p0, TkComma) {
    let p1 = p_skip_newlines(p_advance(p0))
    if p_at(p1, TkRbracket) {
      ok_e(p_advance(p1), mk_expr(EList(list_reverse(acc)), t.line, t.col))
    } else if p_at(p1, TkEllipsis) {
      let r = parse_expr(p_advance(p1))
      match r.r {
        None -> err_e(r.p)
        Some(e) -> parse_list_rest(r.p, [ElSpread(e), ...acc], t)
      }
    } else {
      let r = parse_expr(p1)
      match r.r {
        None -> err_e(r.p)
        Some(e) -> parse_list_rest(r.p, [ElPlain(e), ...acc], t)
      }
    }
  } else {
    err_e(p_error_here(p0, "expected `,` or `]` in list"))
  }
}

# ====================================================================
# block, if, match
# ====================================================================

fn parse_block(p: Parser, t: Token) : PExpr / Console {

  # `{` is at current position.
  let p1 = p_skip_newlines_and_semis(p_advance(p))
  parse_block_body(p1, [], t)
}

# m7b §1 *Lambda-block in non-trailing positions* — a `{` in
# expression position (i.e., reached via parse_primary, not via
# parse_handle's body) may start either a lambda-block or an
# ordinary block expression. Disambiguation is bounded lookahead:
#   {  ->  body    } -> zero-arity lambda-block
#   {  Ident ("," Ident)* "->"  body  } -> parameterised lambda-block
#   anything else -> ordinary block expression
# parse_handle still calls parse_block directly, so its body is
# always a block (a `{ x -> ... }` shape there is a syntax error,
# matching Doc A — handle clauses use a different production).
fn parse_brace_primary(p: Parser, t: Token) : PExpr / Console {

  # `{` is at p_peek(p). Peek past it (and any whitespace).
  let after_lbrace = p_skip_newlines(p_advance(p))
  let pp_r = try_parse_lambda_block_params(after_lbrace)
  match pp_r {
    Some(res) -> {
      let body_r = parse_lambda_block_body(res.p, t)
      match body_r.r {
        None -> err_e(body_r.p)
        Some(body) -> ok_e(body_r.p, mk_expr(ELambda(res.params, body), t.line, t.col))
      }
    }
    None -> parse_block(p, t)
  }
}

fn parse_block_body(p: Parser, stmts: [Stmt], t: Token) : PExpr / Console {

  let p0 = p_skip_newlines_and_semis(p)
  if p_at(p0, TkRbrace) {
    ok_e(p_advance(p0), mk_expr(EBlock(list_reverse(stmts), None), t.line, t.col))
  } else {
    let r = parse_stmt(p0)
    match r.r {
      None -> err_e(r.p)
      Some(s) -> {
        let p1 = p_skip_newlines_and_semis(r.p)
        if p_at(p1, TkRbrace) {
          # If the last stmt was an expression statement, it becomes the
          # block's final expression.
          match s {
            SExprStmt(e) -> ok_e(p_advance(p1), mk_expr(EBlock(list_reverse(stmts), Some(e)), t.line, t.col))
            _ -> ok_e(p_advance(p1), mk_expr(EBlock(list_reverse([s, ...stmts]), None), t.line, t.col))
          }
        } else {
          parse_block_body(p1, [s, ...stmts], t)
        }
      }
    }
  }
}

fn parse_stmt(p: Parser) : PStmt / Console {

  let t = p_peek(p)
  if tk_is(t.kind, TkLet) {
    parse_let(p, t)
  } else if tk_is(t.kind, TkVar) {
    parse_var(p, t)
  } else if tk_is(t.kind, TkCase) {
    # issue #415: `case` inside a stmt-block is the second half of a
    # mixed stmt + case body. The opening of the block was a stmt, so
    # the parser took the stmt-block path. Surface the pure-block
    # rule explicitly here instead of letting the user chase a stale
    # "expected expression" error.
    err_s(p_error(p, t, "case-block must contain only `case` arms; mix with stmt-block by extracting a helper or using `= match { ... }`"))
  } else if tk_is(t.kind, TkAssert) {
    parse_assert(p, t)
  } else if tk_is(t.kind, TkUse) {
    # m7e §25: `use Effect` at block scope. Same shape as the
    # file-level Decl form, but produces a Stmt so it can sit
    # mid-block. `desugar_use_decls` strips both before resolve.
    let p1 = p_advance(p)
    let id = p_peek(p1)
    if not tk_is(id.kind, TkIdent) {
      err_s(p_error(p1, id, "expected effect name after `use`"))
    } else if not is_upper_ident(p1.src, id) {
      err_s(p_error(p1, id, "effect name in `use` must start with an uppercase letter"))
    } else {
      let name = tok_source(p1.src, id)
      ok_s(p_advance(p1), SUse(name, t.line, t.col))
    }
  } else {
    let r = parse_expr(p)
    match r.r {
      None -> err_s(r.p)
      Some(e) -> {
        # m7b #6: indexed write `a[i] := v`. The LHS expression we just
        # parsed must be an `EIndex(base, idx)` whose `base` is a plain
        # identifier or a `.`-chain of fields rooted at an identifier
        # (the IndexLhs of `docs/syntax-sugars.md` §4). Anything else
        # (e.g. a call result) is rejected so the write hits a named
        # binding the caller can observe elsewhere.
        if p_at(r.p, TkColonEq) {
          parse_index_assign_rest(r.p, e, t)
        } else {
          ok_s(r.p, SExprStmt(e))
        }
      }
    }
  }
}

# m7b #6 + m7b #4: validate the LHS of `:=` and parse the RHS.
# Accepted shapes:
#   `Ident[i] := v`            (m7b #6 indexed write — SIndexAssign)
#   `Ident.field…[i] := v`     (m7b #6 indexed write through field path)
#   `Ident := v`               (m7b #4 capability write — desugared to
#                              `cap.set(v)`; the alias rewrite later
#                              maps it to `State.set(cap, v)`)
fn parse_index_assign_rest(p: Parser, lhs: Expr, t: Token) : PStmt / Console {

  match lhs.kind {
    EIndex(base, idx) -> {
      if not is_index_lhs_path(base) {
        err_s(p_error(p, t,
          string_concat(
            "left-hand side of `:=` must be `Ident` or `Ident.field…[i]`; ",
            "bind a temporary first if you need to write to a call result")))
      } else {
        let p1 = p_skip_newlines(p_advance(p))
        let rv = parse_expr(p1)
        match rv.r {
          None -> err_s(rv.p)
          Some(v) -> ok_s(rv.p, SIndexAssign(base, idx, v, lhs.line, lhs.col))
        }
      }
    }
    EVar(name) -> {
      # m7b #4: `cap := v` — desugar inline to `cap.set(v)` as a
      # statement. The alias rewrite remaps the resulting field
      # expression to `State.set(cap, v)`. Doc B §`Syntax note:
      # capability read/write sugar` rule 2: only `State[T].set(v)`
      # is the semantic target; if cap is a Reader binding the
      # desugar still produces `cap.set(v)`, the alias rewrite emits
      # `Reader.set(v)`, and the resolver rejects it ("Reader has
      # no operation `set`").
      let p1 = p_skip_newlines(p_advance(p))
      let rv = parse_expr(p1)
      match rv.r {
        None -> err_s(rv.p)
        Some(v) -> {
          let cap = mk_expr(EVar(name), lhs.line, lhs.col)
          let setter = mk_expr(EField(cap, "set"), lhs.line, lhs.col)
          let call = mk_expr(ECall(setter, [v]), lhs.line, lhs.col)
          ok_s(rv.p, SExprStmt(call))
        }
      }
    }
    _ -> err_s(p_error(p, t,
      "left-hand side of `:=` must be a capability binding `Ident`, an indexed `Ident[i]`, or `Ident.field…[i]`"))
  }
}

# IndexLhs ::= Ident ("." Ident)*  — used by m7b #6 to reject call-LHS
# index writes like `get_array()[0] := v`.
fn is_index_lhs_path(e: Expr) : Bool {
  match e.kind {
    EVar(_) -> true
    EField(base, _) -> is_index_lhs_path(base)
    _ -> false
  }
}

fn parse_let(p: Parser, t: Token) : PStmt / Console {

  let p1 = p_advance(p)
  let rp = parse_pattern(p1)
  match rp.r {
    None -> err_s(rp.p)
    Some(pat) -> {
      # Optional `: Type` annotation.
      let pa = p_skip_newlines(rp.p)
      let ty_opt_r =
        if p_at(pa, TkColon) {
          let rt = parse_type(p_advance(pa))
          match rt.r {
            None -> PTy { p: rt.p, r: None }
            Some(ty) -> PTy { p: rt.p, r: Some(ty) }
          }
        } else {
          PTy { p: pa, r: None }
        }
      if ty_opt_r.p.had_error and not pa.had_error { err_s(ty_opt_r.p) }
      else {
        let p_eq = p_skip_newlines(ty_opt_r.p)
        if not p_at(p_eq, TkEq) {
          err_s(p_error_here(p_eq, "expected `=` in let binding"))
        } else {
          let p_rhs = p_skip_newlines(p_advance(p_eq))
          let re = parse_expr(p_rhs)
          match re.r {
            None -> err_s(re.p)
            Some(rhs) -> ok_s(re.p, SLet(pat, ty_opt_r.r, rhs))
          }
        }
      }
    }
  }
}

# m7b #5: `var name (: T)? = init` — local mutable cell. The parser
# produces an `SVar` node; the pre-resolve `desugar_var_decls` pass
# rewrites every block containing an SVar into the canonical
# `handle { rest } with State[T](init) as name { ... }` form. No
# `var name` (without `= init`) form: rejected here with a syntax
# error so the desugared `with State[T](init)` always has a state
# value to thread.
fn parse_var(p: Parser, t: Token) : PStmt / Console {

  let p1 = p_advance(p)
  let nt = p_peek(p1)
  if not tk_is(nt.kind, TkIdent) {
    err_s(p_error(p1, nt, "expected identifier after `var`"))
  } else {
    let name = tok_source(p1.src, nt)
    let p2 = p_advance(p1)
    let ty_opt_r =
      if p_at(p2, TkColon) {
        let rt = parse_type(p_advance(p2))
        match rt.r {
          None -> PTy { p: rt.p, r: None }
          Some(ty) -> PTy { p: rt.p, r: Some(ty) }
        }
      } else {
        PTy { p: p2, r: None }
      }
    if ty_opt_r.p.had_error and not p2.had_error { err_s(ty_opt_r.p) }
    else {
      let p_eq = p_skip_newlines(ty_opt_r.p)
      if not p_at(p_eq, TkEq) {
        err_s(p_error_here(p_eq, "expected `=` in var binding (initialiser is required)"))
      } else {
        let p_rhs = p_skip_newlines(p_advance(p_eq))
        let re = parse_expr(p_rhs)
        match re.r {
          None -> err_s(re.p)
          Some(rhs) -> ok_s(re.p, SVar(name, ty_opt_r.r, rhs, t.line, t.col))
        }
      }
    }
  }
}

fn parse_assert(p: Parser, t: Token) : PStmt / Console {

  let p1 = p_advance(p)
  let re = parse_expr(p1)
  match re.r {
    None -> err_s(re.p)
    Some(cond) -> {
      if p_at(re.p, TkComma) {
        let p2 = p_skip_newlines(p_advance(re.p))
        let rm = parse_expr(p2)
        match rm.r {
          None -> err_s(rm.p)
          Some(msg) -> ok_s(rm.p, SAssert(cond, Some(msg)))
        }
      } else {
        ok_s(re.p, SAssert(cond, None))
      }
    }
  }
}

fn parse_if(p: Parser, t: Token) : PExpr / Console {

  let p1 = p_advance(p)
  # m7b §1: cond cannot consume a trailing `{` as a trailing lambda
  # — that `{` is the `if` body. Disable while parsing cond, then
  # restore the flag's prior value before consuming the body.
  let prev_atl = p1.allow_trailing_lambda
  let pc = p_with_trailing_lambda(p1, false)
  let rc = parse_expr(pc)
  match rc.r {
    None -> err_e(rc.p)
    Some(cond) -> {
      # Then-block
      let p2 = p_skip_newlines(p_with_trailing_lambda(rc.p, prev_atl))
      if not p_at(p2, TkLbrace) {
        err_e(p_error_here(p2, "expected `{` after `if` condition"))
      } else {
        let tb = p_peek(p2)
        let rt = parse_block(p2, tb)
        match rt.r {
          None -> err_e(rt.p)
          Some(then_e) -> {
            let p3 = p_skip_newlines(rt.p)
            if p_at(p3, TkElse) {
              let p4 = p_skip_newlines(p_advance(p3))
              if p_at(p4, TkIf) {
                let te = p_peek(p4)
                let re = parse_if(p4, te)
                match re.r {
                  None -> err_e(re.p)
                  Some(else_e) -> ok_e(re.p, mk_expr(EIf(cond, then_e, Some(else_e)), t.line, t.col))
                }
              } else if p_at(p4, TkLbrace) {
                let teb = p_peek(p4)
                let re = parse_block(p4, teb)
                match re.r {
                  None -> err_e(re.p)
                  Some(else_e) -> ok_e(re.p, mk_expr(EIf(cond, then_e, Some(else_e)), t.line, t.col))
                }
              } else {
                err_e(p_error_here(p4, "expected `if` or `{` after `else`"))
              }
            } else {
              ok_e(p3, mk_expr(EIf(cond, then_e, None), t.line, t.col))
            }
          }
        }
      }
    }
  }
}

fn parse_match(p: Parser, t: Token) : PExpr / Console {

  let p1 = p_advance(p)
  # m7b §1: same as `if` — scrutinees cannot eat the `{` that opens
  # the arms block as a trailing lambda.
  let prev_atl = p1.allow_trailing_lambda
  let ps = p_with_trailing_lambda(p1, false)
  let rs = parse_expr(ps)
  match rs.r {
    None -> err_e(rs.p)
    Some(scrut1) -> {
      # m7d §27: comma after the first scrutinee opens multi-scrutinee
      # match — `match e1, e2, ..., eN { p1, p2, ..., pN -> body | ... }`.
      # Parser-only sugar: desugars to nested EMatch over each column,
      # with fall-through to the remaining arms duplicated at the
      # column-1 wildcard branch. For N=1 (the original form), the
      # behaviour is unchanged.
      let r_more = parse_more_scruts(rs.p, [scrut1])
      let p2 = p_skip_newlines(p_with_trailing_lambda(r_more.p, prev_atl))
      if not p_at(p2, TkLbrace) {
        err_e(p_error_here(p2, "expected `{` after `match` expression"))
      } else {
        let scruts = list_reverse(r_more.r)
        let n = list_length(scruts)
        if n == 1 {
          parse_match_arms(p_skip_newlines(p_advance(p2)), [], scrut1, t)
        } else if n > 4 {
          # Issue #129: cap multi-arg `match` at 4 columns. Higher
          # arities exist (revisit if a use case wants 5+) but in
          # practice they push the desugared nesting past what stays
          # readable in diagnostics. Re-evaluate with concrete need.
          err_e(p_error_here(p2, "multi-arg `match` supports up to 4 scrutinees"))
        } else {
          parse_multi_match_arms(p_skip_newlines(p_advance(p2)), [], scruts, n, t)
        }
      }
    }
  }
}

# m7d §27: collect additional scrutinees after the first. `acc` is in
# reverse order; caller reverses. Returns the parser state pointing
# at the first non-`,` non-newline token.
type PScruts = { p: Parser, r: [Expr] }

fn parse_more_scruts(p: Parser, acc: [Expr]) : PScruts / Console {

  let p0 = p_skip_newlines(p)
  if not p_at(p0, TkComma) { PScruts { p: p0, r: acc } }
  else {
    let p1 = p_skip_newlines(p_advance(p0))
    let r = parse_expr(p1)
    match r.r {
      None    -> PScruts { p: r.p, r: acc }
      Some(e) -> parse_more_scruts(r.p, [e, ...acc])
    }
  }
}

# m7d §27: a multi-scrutinee arm carries N patterns (where N ==
# number of scrutinees). Mirrors `Arm` but with a list of patterns
# instead of a single one. Lives only in the parser; the desugar
# rewrites every MArm into nested standard `Arm`s before the AST
# leaves the parser.
type MArm = MArm([Pattern], Option[Expr], Expr)

# m7d §27: parse arms where each arm has N patterns separated by commas,
# optional guard, `->`, body. Stops at `}`.
fn parse_multi_match_arms(p: Parser, acc: [MArm], scruts: [Expr], n: Int, t: Token) : PExpr / Console {

  let p0 = p_skip_newlines_and_semis(p)
  if p_at(p0, TkRbrace) {
    let p1 = p_advance(p0)
    let arms_in_order = list_reverse(acc)
    let desugared = desugar_multi_match(scruts, arms_in_order, t.line, t.col)
    ok_e(p1, desugared)
  } else {
    let ra = parse_multi_arm(p0, n)
    match ra.r {
      None -> err_e(ra.p)
      Some(arm) -> parse_multi_match_arms(ra.p, [arm, ...acc], scruts, n, t)
    }
  }
}

# m7d §27: parse N comma-separated patterns followed by optional guard,
# `->`, body. The arity must match `n` (scrutinee count); mismatched
# arities are a parse error per the §27 spec.
type PMArm = { p: Parser, r: Option[MArm] }

fn err_marm(p: Parser) : PMArm = PMArm { p: p, r: None }
fn ok_marm(p: Parser, m: MArm) : PMArm = PMArm { p: p, r: Some(m) }

fn parse_multi_arm(p: Parser, n: Int) : PMArm / Console {

  let r_pats = parse_n_patterns(p, n, [])
  match r_pats.r {
    None -> err_marm(r_pats.p)
    Some(pats) -> {
      let p1 = p_skip_newlines(r_pats.p)
      let guard_opt_r =
        if p_at(p1, TkIf) {
          let prev_atl = p1.allow_trailing_lambda
          let pg = p_with_trailing_lambda(p_advance(p1), false)
          let rg = parse_expr(pg)
          let rg_p = p_with_trailing_lambda(rg.p, prev_atl)
          match rg.r {
            None -> PExpr { p: rg_p, r: None }
            Some(g) -> PExpr { p: rg_p, r: Some(g) }
          }
        } else {
          PExpr { p: p1, r: None }
        }
      let p2 = p_skip_newlines(guard_opt_r.p)
      if not p_at(p2, TkArrow) {
        err_marm(p_error_here(p2, "expected `->` in multi-arg match arm"))
      } else {
        let p3 = p_skip_newlines(p_advance(p2))
        let rb = parse_expr(p3)
        match rb.r {
          None -> err_marm(rb.p)
          Some(body) -> ok_marm(rb.p, MArm(pats, guard_opt_r.r, body))
        }
      }
    }
  }
}

# m7d §27: parse exactly `n` patterns, separated by commas. Returns
# None if any pattern fails to parse or if the comma count does not
# match (n-1 commas expected between n patterns).
type PPatN = { p: Parser, r: Option[[Pattern]] }

fn err_patn(p: Parser) : PPatN = PPatN { p: p, r: None }
fn ok_patn(p: Parser, ps: [Pattern]) : PPatN = PPatN { p: p, r: Some(ps) }

fn parse_n_patterns(p: Parser, n: Int, acc: [Pattern]) : PPatN / Console {

  if n == 0 {
    ok_patn(p, list_reverse(acc))
  } else {
    let rp = parse_pattern(p)
    match rp.r {
      None -> err_patn(rp.p)
      Some(pat) -> {
        let next = n - 1
        if next == 0 { ok_patn(rp.p, list_reverse([pat, ...acc])) }
        else {
          let p1 = p_skip_newlines(rp.p)
          if not p_at(p1, TkComma) {
            err_patn(p_error_here(p1, "expected `,` between multi-arg match patterns"))
          } else {
            parse_n_patterns(p_skip_newlines(p_advance(p1)), next, [pat, ...acc])
          }
        }
      }
    }
  }
}

# m7d §27: build the desugared AST. The shape is:
#
#   {
#     let __mm_s_0 = e0
#     let __mm_s_1 = e1
#     ...
#     match __mm_s_0 {
#       p0_arm0 -> match __mm_s_1 { p1_arm0 -> ... pN_arm0 -> body_arm0 | _ -> fall_arm1 }
#       _       -> fall_arm1
#     }
#   }
#
# where `fall_arm1` is the same shape recursively built over arm 1.
# The base case (no arms left) is a panic via `Fail.fail`. Bodies
# are duplicated only structurally — kaikai bodies are immutable
# Exprs, so the duplication does not cost runtime evaluation, only
# emitted-code size. For typical demo arities (N=2, K=3) the blow-up
# is bounded.
fn desugar_multi_match(scruts: [Expr], arms: [MArm], line: Int, col: Int) : Expr {
  let stmts = build_scrut_lets(scruts, 0, [])
  let scrut_vars = make_scrut_var_exprs(scruts, 0, line, col)
  let body = build_multi_match_chain(scrut_vars, arms, line, col)
  mk_expr(EBlock(list_reverse(stmts), Some(body)), line, col)
}

# m7d §27: emit `let __mm_s_i = scrut_i` statements, in the order
# they appear; returned reversed so the desugar wraps them with
# `list_reverse` to restore source order.
fn build_scrut_lets(scruts: [Expr], i: Int, acc: [Stmt]) : [Stmt] {
  match scruts {
    [] -> acc
    [e, ...rest] -> {
      let nm = scrut_var_name(i)
      let pat = mk_pat(PBind(nm), e.line, e.col)
      build_scrut_lets(rest, i + 1, [SLet(pat, None, e), ...acc])
    }
  }
}

fn make_scrut_var_exprs(scruts: [Expr], i: Int, line: Int, col: Int) : [Expr] {
  match scruts {
    [] -> []
    [_, ...rest] -> [
      mk_expr(EVar(scrut_var_name(i)), line, col),
      ...make_scrut_var_exprs(rest, i + 1, line, col)
    ]
  }
}

fn scrut_var_name(i: Int) : String =
  string_concat("__mm_s_", int_to_string(i))

# m7d §27: recursive builder for the arm chain. At each arm,
# constructs an EMatch over scrut_var_0 with two arms:
#   - column-1 pattern -> nested match on remaining columns
#   - wildcard         -> fall-through to next arm
# Both branches reference the same fall-through subtree, which is
# computed once but referenced twice (the AST is shared structurally
# since `Expr` values are immutable). When `arms` is empty, returns
# a panic via Fail-style trap.
fn build_multi_match_chain(scrut_vars: [Expr], arms: [MArm], line: Int, col: Int) : Expr {
  match arms {
    [] -> non_exhaustive_trap(line, col)
    [head, ...rest] -> {
      let fall = build_multi_match_chain(scrut_vars, rest, line, col)
      build_one_marm(scrut_vars, head, fall, line, col)
    }
  }
}

# m7d §27: lower one MArm into the nested-EMatch chain it stands for,
# wiring the failing-pattern branch to `fall`. The guard, when present,
# is attached to the innermost arm (last column).
fn build_one_marm(scrut_vars: [Expr], arm: MArm, fall: Expr, line: Int, col: Int) : Expr {
  match arm {
    MArm(pats, guard, body) -> build_marm_columns(scrut_vars, pats, guard, body, fall, line, col)
  }
}

fn build_marm_columns(scrut_vars: [Expr], pats: [Pattern], guard: Option[Expr],
                       body: Expr, fall: Expr, line: Int, col: Int) : Expr {
  match scrut_vars {
    [] -> body
    [sv, ...rest_svs] -> match pats {
      [] -> body
      [p, ...rest_ps] -> {
        let inner = match rest_ps {
          [] -> Arm(p, guard, body)
          _  -> Arm(p, None, build_marm_columns(rest_svs, rest_ps, guard, body, fall, line, col))
        }
        let wild = mk_pat(PWild, line, col)
        mk_expr(EMatch(sv, [inner, Arm(wild, None, fall)]), line, col)
      }
    }
  }
}

# m7d §27: trap for "no arm matched". Uses `todo!` (m7d §1) which
# behaves like a panic at runtime and matches any expected type in
# inference, without forcing the surrounding fn to declare a `/ Fail`
# row. v2 can refine to a static cross-column exhaustiveness check
# that elides the trap when arms statically cover the cartesian space.
fn non_exhaustive_trap(line: Int, col: Int) : Expr =
  mk_expr(ETodo("non-exhaustive multi-arg match"), line, col)

fn parse_match_arms(p: Parser, acc: [Arm], scrut: Expr, t: Token) : PExpr / Console {

  let p0 = p_skip_newlines_and_semis(p)
  if p_at(p0, TkRbrace) {
    ok_e(p_advance(p0), mk_expr(EMatch(scrut, list_reverse(acc)), t.line, t.col))
  } else {
    let ra = parse_arm(p0)
    match ra.r {
      None -> err_e(ra.p)
      Some(arm) -> parse_match_arms(ra.p, [arm, ...acc], scrut, t)
    }
  }
}

fn parse_arm(p: Parser) : PArm / Console {

  let rp = parse_pattern(p)
  match rp.r {
    None -> err_a(rp.p)
    Some(pat) -> {
      # m12.6.x #3: optional refinement-narrowing `: Type where ...`
      # after a binding pattern. Lowers to a guard that evaluates the
      # refinement's predicate with `self` bound to the name. Only
      # PBind patterns participate; other shapes ignore the suffix.
      let p_after_ty = p_skip_newlines(rp.p)
      let nr = parse_optional_arm_refine(p_after_ty, pat)
      # issue #187 phase 3: arm-refine may rewrite the pattern (PNarrow).
      let pat_eff = match nr.new_pat { Some(np) -> np  None -> pat }
      let p1 = p_skip_newlines(nr.p)
      # Optional guard: `if expr`. Same discipline as `parse_if` /
      # `parse_match`: the guard expression cannot eat the `->` (or
      # an arm body's `{`) by extending into a trailing lambda. Off
      # the flag for the guard, restore for the body.
      let guard_opt_r =
        if p_at(p1, TkIf) {
          let prev_atl = p1.allow_trailing_lambda
          let pg = p_with_trailing_lambda(p_advance(p1), false)
          let rg = parse_expr(pg)
          let rg_p = p_with_trailing_lambda(rg.p, prev_atl)
          match rg.r {
            None -> PExpr { p: rg_p, r: None }
            Some(g) -> PExpr { p: rg_p, r: Some(g) }
          }
        } else {
          PExpr { p: p1, r: None }
        }
      let combined_guard = combine_guards(nr.guard, guard_opt_r.r)
      match guard_opt_r.r {
        None -> if guard_opt_r.p.had_error { err_a(guard_opt_r.p) } else {
          parse_arm_body(guard_opt_r.p, pat_eff, combined_guard)
        }
        Some(_) -> parse_arm_body(guard_opt_r.p, pat_eff, combined_guard)
      }
    }
  }
}

# m12.6.x #3 result: parser state after consuming an optional `: Type`
# refinement-narrowing suffix on a match arm pattern. `guard` holds
# the synthesised predicate (or None when no suffix was present).
# issue #187 phase 3: `new_pat` overrides the original pattern when
# the suffix lowers to a `PNarrow` instead of a guard. `None` means
# leave the caller's pattern unchanged.
type ArmRefine = { p: Parser, guard: Option[Expr], new_pat: Option[Pattern] }

fn parse_optional_arm_refine(p: Parser, pat: Pattern) : ArmRefine / Console {

  if not p_at(p, TkColon) { ArmRefine { p: p, guard: None, new_pat: None } }
  else { match pat.pkind {
    PBind(name) -> {
      let p1 = p_skip_newlines(p_advance(p))
      let rt = parse_type(p1)
      match rt.r {
        None -> ArmRefine { p: rt.p, guard: None, new_pat: None }
        Some(ty) -> match ty.tkind {
          TyRefine(_, pred) -> {
            # Lower to `{ let self = <name>; pred }`. The let binding
            # makes the user-side `self` reference inside the predicate
            # resolve to the bound match variable. Same desugar as
            # `ensure(value) where pred` (m12.6.e).
            let var_e = mk_expr(EVar(name), pat.line, pat.col)
            let self_let = SLet(mk_pat(PBind("self"), pat.line, pat.col),
                                None, var_e)
            let block = mk_expr(EBlock([self_let], Some(pred)),
                                 pat.line, pat.col)
            ArmRefine { p: rt.p, guard: Some(block), new_pat: None }
          }
          # issue #187 phase 3 + m12.6.x #3 v2: `name : TyName(t, ...)`.
          # Parser cannot tell whether `t` is a refinement-type alias
          # (m12.6.x) or a union-component nominal type (#187), so it
          # emits a uniform `PNarrow(name, ty)` pattern with no guard.
          # `lower_pattern_narrow_decls` later splits the cases: for
          # every refinement alias declared in the program, the
          # narrowing is rewritten back into `PBind(name)` + a guard
          # call to `__ref_pred_t(name)` (preserving the m12.6.x
          # behaviour); narrowings whose target is not a refinement
          # alias survive as `PNarrow` for the typer, which checks
          # the scrutinee is a union containing the component.
          TyName(_, _) -> ArmRefine {
            p: rt.p,
            guard: None,
            new_pat: Some(mk_pat(PNarrow(name, ty), pat.line, pat.col))
          }
          _ -> ArmRefine {
            p: p_error(rt.p, p_peek(p),
                       "match-arm narrowing `: Type` requires either an inline `Int where ...` or a refinement-type alias name"),
            guard: None, new_pat: None
          }
        }
      }
    }
    _ -> ArmRefine {
      p: p_error(p, p_peek(p),
                 "match-arm narrowing `: Type` only applies to a binding pattern (a bare name)"),
      guard: None, new_pat: None
    }
  } }
}

# m12.6.x #3 v2: the synthesised pred-fn name for a refinement-type
# alias. Centralised so the call-site builder and the post-parse
# generator agree on the spelling.
fn synth_refine_pred_fn_name(tyname: String) : String =
  string_concat("__ref_pred_", tyname)

# m12.6.x #3: combine two optional guards with `and`. When either
# side is None, return the other; when both are present, build
# `narrow_guard and user_guard` so a violated refinement
# short-circuits before the user predicate runs.
fn combine_guards(narrow: Option[Expr], user: Option[Expr]) : Option[Expr] {
  match narrow {
    None -> user
    Some(n) -> match user {
      None -> Some(n)
      Some(u) -> Some(mk_expr(EBinop("and", n, u), n.line, n.col))
    }
  }
}

fn parse_arm_body(p: Parser, pat: Pattern, guard: Option[Expr]) : PArm / Console {

  let p1 = p_skip_newlines(p)
  if not p_at(p1, TkArrow) {
    err_a(p_error_here(p1, "expected `->` in match arm"))
  } else {
    let p2 = p_skip_newlines(p_advance(p1))
    let rb = parse_expr(p2)
    match rb.r {
      None -> err_a(rb.p)
      Some(body) -> ok_a(rb.p, Arm(pat, guard, body))
    }
  }
}

# ====================================================================
# patterns
# ====================================================================

fn parse_pattern(p: Parser) : PPat / Console {

  let t = p_peek(p)
  match t.kind {
    TkHole          -> ok_p(p_advance(p), mk_pat(PHole(None), t.line, t.col))
    TkHoleName(nm)  -> ok_p(p_advance(p), mk_pat(PHole(Some(nm)), t.line, t.col))
    _ -> parse_pattern_rest(p, t)
  }
}

fn parse_pattern_rest(p: Parser, t: Token) : PPat / Console {

  if tk_is(t.kind, TkUnderscore) {
    ok_p(p_advance(p), mk_pat(PWild, t.line, t.col))
  } else if tk_is(t.kind, TkInt) {
    let span = tok_source(p.src, t)
    let lit = mk_expr(EInt(decode_int(span)), t.line, t.col)
    ok_p(p_advance(p), mk_pat(PLit(lit), t.line, t.col))
  } else if tk_is(t.kind, TkReal) {
    let span = tok_source(p.src, t)
    let lit = mk_expr(EReal(decode_real(span)), t.line, t.col)
    ok_p(p_advance(p), mk_pat(PLit(lit), t.line, t.col))
  } else if tk_is(t.kind, TkTrue) {
    ok_p(p_advance(p), mk_pat(PLit(mk_expr(EBool(true), t.line, t.col)), t.line, t.col))
  } else if tk_is(t.kind, TkFalse) {
    ok_p(p_advance(p), mk_pat(PLit(mk_expr(EBool(false), t.line, t.col)), t.line, t.col))
  } else if tk_is(t.kind, TkChar) {
    let span = tok_source(p.src, t)
    ok_p(p_advance(p), mk_pat(PLit(mk_expr(EChar(decode_char(span)), t.line, t.col)), t.line, t.col))
  } else if tk_is(t.kind, TkString) {
    let span = tok_source(p.src, t)
    ok_p(p_advance(p), mk_pat(PLit(mk_expr(EStr(span, false), t.line, t.col)), t.line, t.col))
  } else if tk_is(t.kind, TkMinus) {
    let nxt = p_peek1(p)
    if tk_is(nxt.kind, TkInt) {
      let span = tok_source(p.src, nxt)
      let v = 0 - decode_int(span)
      let p1 = p_advance(p_advance(p))
      ok_p(p1, mk_pat(PLit(mk_expr(EInt(v), t.line, t.col)), t.line, t.col))
    } else {
      err_p(p_error_here(p, "expected literal after `-` in pattern"))
    }
  } else if tk_is(t.kind, TkLbracket) {
    parse_list_pattern(p, t)
  } else if tk_is(t.kind, TkLparen) {
    # n-tuple pattern sugar (#154). `(a, b)` desugars to a record
    # pattern matching the corresponding stdlib type — `Pair` for
    # arity 2, `Triple` for 3, `Quad` for 4. Single-element parens
    # `(p)` are grouping (returns `p` unchanged); zero-element `()`
    # is reserved for the unit pattern (rejected here as a parse
    # error to keep the surface small until a use case appears).
    parse_tuple_pattern(p, t)
  } else if tk_is(t.kind, TkLbrace) {
    # m7d §28: anonymous record pattern. `{ fst, snd }` (with field
    # punning) or `{ fst: a, snd: b }`. The typer + bind_pat +
    # emitter machinery for PRecord is shared with the existing
    # match-arm record patterns, so this only needs the parser
    # entry point. Useful primarily on the LHS of `let` to
    # destructure multi-return shapes (Pair[a, b], etc.) without
    # the three-line `let p = ...; let a = p.fst; let b = p.snd`
    # ceremony.
    parse_record_pattern_fields(p_skip_newlines(p_advance(p)), [], None, t)
  } else if tk_is(t.kind, TkIdent) {
    parse_ident_pattern(p, t)
  } else {
    err_p(p_error_here(p, "expected pattern"))
  }
}

fn parse_list_pattern(p: Parser, t: Token) : PPat / Console {

  let p1 = p_skip_newlines(p_advance(p))
  if p_at(p1, TkRbracket) {
    ok_p(p_advance(p1), mk_pat(PList([], None), t.line, t.col))
  } else {
    parse_list_pattern_loop(p1, [], None, t)
  }
}

fn parse_list_pattern_loop(p: Parser, acc: [Pattern], rest: Option[String], t: Token) : PPat / Console {

  if p_at(p, TkEllipsis) {
    # Spread binder. Issue #328: `...` may stand alone (preferred form
    # `[h, ...]`) or be followed by `_` (uniform-with-`_` form
    # `[h, ..._]`); both discard the tail with no binding. The named
    # form `[h, ...rest]` keeps the existing semantics. Bare/`_` spread
    # uses a synthesized sentinel name (`__list_rest_<line>_<col>__`)
    # that round-trips as `Some(name)` through the rest of the pipeline,
    # preserving the spread-vs-no-spread distinction the typer needs
    # for exhaustiveness while leaving the binding unread.
    let p1 = p_advance(p)
    let id = p_peek(p1)
    if tk_is(id.kind, TkIdent) {
      let name = tok_source(p1.src, id)
      let p2 = p_skip_newlines(p_advance(p1))
      if p_at(p2, TkRbracket) {
        ok_p(p_advance(p2), mk_pat(PList(list_reverse(acc), Some(name)), t.line, t.col))
      } else {
        err_p(p_error_here(p2, "expected `]` after spread pattern"))
      }
    } else if tk_is(id.kind, TkUnderscore) {
      let sentinel = concat_all(["__list_rest_", int_to_string(id.line), "_",
                                  int_to_string(id.col), "__"])
      let p2 = p_skip_newlines(p_advance(p1))
      if p_at(p2, TkRbracket) {
        ok_p(p_advance(p2), mk_pat(PList(list_reverse(acc), Some(sentinel)), t.line, t.col))
      } else {
        err_p(p_error_here(p2, "expected `]` after spread pattern"))
      }
    } else if tk_is(id.kind, TkRbracket) {
      let sentinel = concat_all(["__list_rest_", int_to_string(id.line), "_",
                                  int_to_string(id.col), "__"])
      ok_p(p_advance(p1), mk_pat(PList(list_reverse(acc), Some(sentinel)), t.line, t.col))
    } else {
      err_p(p_error_here(p1, "expected identifier, `_`, or `]` after `...` in list pattern"))
    }
  } else {
    let r = parse_pattern(p)
    match r.r {
      None -> err_p(r.p)
      Some(pat) -> {
        let p1 = p_skip_newlines(r.p)
        if p_at(p1, TkComma) {
          parse_list_pattern_loop(p_skip_newlines(p_advance(p1)), [pat, ...acc], None, t)
        } else if p_at(p1, TkRbracket) {
          ok_p(p_advance(p1), mk_pat(PList(list_reverse([pat, ...acc]), None), t.line, t.col))
        } else {
          err_p(p_error_here(p1, "expected `,` or `]` in list pattern"))
        }
      }
    }
  }
}

# n-tuple pattern sugar (#154). Mirrors parse_tuple_expr_rest: starts
# with `(`, parses N≥2 comma-separated sub-patterns, closes with `)`,
# desugars to a `PVariantRecord` of the corresponding stdlib type
# (`Pair` / `Triple` / `Quad`). Single-paren `(p)` is grouping —
# returns the inner pattern unchanged. Empty `()` is rejected.
fn parse_tuple_pattern(p: Parser, t: Token) : PPat / Console {

  let p1 = p_skip_newlines(p_advance(p))
  if p_at(p1, TkRparen) {
    err_p(p_error_here(p1, "empty tuple pattern `()` not supported"))
  } else {
    let r = parse_pattern(p1)
    match r.r {
      None -> err_p(r.p)
      Some(first) -> {
        let p2 = p_skip_newlines(r.p)
        if p_at(p2, TkRparen) {
          # Single-pattern parens: grouping.
          ok_p(p_advance(p2), first)
        } else if p_at(p2, TkComma) {
          parse_tuple_pattern_rest(p_skip_newlines(p_advance(p2)), [first], t)
        } else {
          err_p(p_error_here(p2, "expected `,` or `)` in tuple pattern"))
        }
      }
    }
  }
}

fn parse_tuple_pattern_rest(p: Parser, acc: [Pattern], t: Token) : PPat / Console {

  let r = parse_pattern(p)
  match r.r {
    None -> err_p(r.p)
    Some(pat) -> {
      let p1 = p_skip_newlines(r.p)
      if p_at(p1, TkComma) {
        parse_tuple_pattern_rest(p_skip_newlines(p_advance(p1)), [pat, ...acc], t)
      } else if p_at(p1, TkRparen) {
        let pats = list_reverse([pat, ...acc])
        let p2 = p_advance(p1)
        match tuple_type_for_arity(list_length(pats)) {
          None -> err_p(p_error_here(p1, "n-tuple sugar supports arity 2..4 only — use a named record for wider products"))
          Some(name) -> ok_p(p2, mk_pat(PVariantRecord(name, build_tuple_pfields(pats, 0, [])), t.line, t.col))
        }
      } else {
        err_p(p_error_here(p1, "expected `,` or `)` in tuple pattern"))
      }
    }
  }
}

fn build_tuple_pfields(pats: [Pattern], i: Int, acc: [PField]) : [PField] {
  match pats {
    [] -> list_reverse(acc)
    [pat, ...rest] -> build_tuple_pfields(rest, i + 1, [PField(tuple_field_name(i), pat, false), ...acc])
  }
}

fn parse_ident_pattern(p: Parser, t: Token) : PPat / Console {

  let name = tok_source(p.src, t)
  let p1 = p_advance(p)
  # Issue #234: qualified variant pattern `mod.Ctor[(subs)|{fields}]`.
  # Lowercase head + `.UpperIdent` is a qualifier; drop it and let
  # the trailing UpperIdent flow through the existing variant
  # arms. Module-table validation happens at runtime in
  # rqc_kind for expressions; for patterns the qualifier is purely
  # disambiguation surface so dropping it is sound — the typer
  # narrows the variant's parent type from the scrutinee anyway.
  if (not is_upper_ident(p.src, t)) and p_at(p1, TkDot) and tk_is(p_peek1(p1).kind, TkIdent) and is_upper_ident(p1.src, p_peek1(p1)) {
    let nt = p_peek1(p1)
    parse_ident_pattern(p_advance(p1), nt)
  } else if is_upper_ident(p.src, t) and p_at(p1, TkLparen) {
    # Variant with positional sub-patterns.
    let p2 = p_skip_newlines(p_advance(p1))
    if p_at(p2, TkRparen) {
      ok_p(p_advance(p2), mk_pat(PVariant(name, []), t.line, t.col))
    } else {
      parse_variant_sub_patterns(p2, [], name, t)
    }
  } else if is_upper_ident(p.src, t) and p_at(p1, TkLbrace) {
    # Variant-record pattern: parse as record, wrap in PVariantRecord.
    let p2 = p_skip_newlines(p_advance(p1))
    parse_record_pattern_fields(p2, [], Some(name), t)
  } else if is_upper_ident(p.src, t) {
    # Bare uppercase ident: 0-arg variant.
    ok_p(p1, mk_pat(PVariant(name, []), t.line, t.col))
  } else if p_at(p1, TkAt) {
    # m7d §14: `name @ pattern` — as-pattern. Bind `name` to the
    # whole scrutinee and continue matching with the sub-pattern.
    # The lowercase ident already implies a fresh binding; the inner
    # pattern is parsed by the same `parse_pattern` entry, so list,
    # variant, record, hole, and even nested as-patterns compose.
    let p2 = p_skip_newlines(p_advance(p1))
    let r = parse_pattern(p2)
    match r.r {
      None -> err_p(r.p)
      Some(sub) -> ok_p(r.p, mk_pat(PAs(name, sub), t.line, t.col))
    }
  } else {
    ok_p(p1, mk_pat(PBind(name), t.line, t.col))
  }
}

fn parse_variant_sub_patterns(p: Parser, acc: [Pattern], name: String, t: Token) : PPat / Console {

  let r = parse_pattern(p)
  match r.r {
    None -> err_p(r.p)
    Some(sub) -> {
      let p1 = p_skip_newlines(r.p)
      if p_at(p1, TkComma) {
        parse_variant_sub_patterns(p_skip_newlines(p_advance(p1)), [sub, ...acc], name, t)
      } else if p_at(p1, TkRparen) {
        ok_p(p_advance(p1), mk_pat(PVariant(name, list_reverse([sub, ...acc])), t.line, t.col))
      } else {
        err_p(p_error_here(p1, "expected `,` or `)` in variant pattern"))
      }
    }
  }
}

fn parse_record_pattern_fields(p: Parser, acc: [PField], ctor: Option[String], t: Token) : PPat / Console {

  let p0 = p_skip_newlines(p)
  if p_at(p0, TkRbrace) {
    let p1 = p_advance(p0)
    match ctor {
      None -> ok_p(p1, mk_pat(PRecord(list_reverse(acc)), t.line, t.col))
      Some(name) -> ok_p(p1, mk_pat(PVariantRecord(name, list_reverse(acc)), t.line, t.col))
    }
  } else {
    let fn_t = p_peek(p0)
    if not tk_is(fn_t.kind, TkIdent) {
      err_p(p_error(p0, fn_t, "expected field name in record pattern"))
    } else {
      let fname = tok_source(p0.src, fn_t)
      let p1 = p_advance(p0)
      let sub_r =
        if p_at(p1, TkColon) {
          let r = parse_pattern(p_advance(p1))
          match r.r {
            None -> PPat { p: r.p, r: None }
            Some(sp) -> PPat { p: r.p, r: Some(sp) }
          }
        } else {
          PPat { p: p1, r: Some(mk_pat(PBind(fname), fn_t.line, fn_t.col)) }
        }
      match sub_r.r {
        None -> err_p(sub_r.p)
        Some(sub) -> {
          let is_short = not p_at(p1, TkColon)
          let pf = PField(fname, sub, is_short)
          let p2 = p_skip_newlines(sub_r.p)
          if p_at(p2, TkComma) {
            parse_record_pattern_fields(p_skip_newlines(p_advance(p2)), [pf, ...acc], ctor, t)
          } else if p_at(p2, TkRbrace) {
            parse_record_pattern_fields(p2, [pf, ...acc], ctor, t)
          } else {
            err_p(p_error_here(p2, "expected `,` or `}` in record pattern"))
          }
        }
      }
    }
  }
}

# ====================================================================
# type expressions
# ====================================================================

# After a return-type is parsed, an optional row suffix can follow:
#   T / Eff
#   T / Eff + Eff + ...
#   T / e                # row variable alone (m7b #12)
#   T / Eff + e          # closed labels followed by a row variable
# Capitalisation disambiguates: TitleCase identifiers are effect
# labels, lowercase identifiers in tail position are row variables.
# Two row variables (`/ e + r`) and a row variable not in tail
# (`/ e + Eff`) are syntax errors — kaikai picks the simpler
# tail-variable semantics. If `/` is absent, REmpty.
type PRow = { p: Parser, r: RowExpr }

fn parse_row_suffix(p: Parser) : PRow / Console {

  if not p_at(p, TkSlash) { PRow { p: p, r: REmpty } }
  else {
    let p1 = p_advance(p)
    parse_row_labels(p1, [])
  }
}

fn parse_row_labels(p: Parser, acc: [RowLabel]) : PRow / Console {

  let t = p_peek(p)
  # m7f §6: `?e` or `?` in row tail position. Treated as an
  # anonymous row variable with a prefix-marked name so the reporter
  # can identify it as a user-supplied hole vs an ordinary row var.
  # Must be the last item in the row — `?e + Stdout` is rejected
  # for the same reason `e + Stdout` is.
  if tk_is(t.kind, TkHole) {
    let p1 = p_advance(p)
    let placeholder = concat_all(["__rowhole__anon_",
                                    int_to_string(t.line), "_",
                                    int_to_string(t.col)])
    if p_at(p1, TkPlus) {
      let pe = p_error(p1, p_peek(p1),
        "row hole must be the last item in the row")
      PRow { p: pe, r: ROpen(placeholder, list_reverse(acc)) }
    } else {
      PRow { p: p1, r: ROpen(placeholder, list_reverse(acc)) }
    }
  } else if match t.kind { TkHoleName(_) -> true _ -> false } {
    let p1 = p_advance(p)
    let nm = match t.kind {
      TkHoleName(n) -> n
      _             -> "anon"
    }
    let placeholder = concat_all(["__rowhole_", nm, "_",
                                    int_to_string(t.line), "_",
                                    int_to_string(t.col)])
    if p_at(p1, TkPlus) {
      let pe = p_error(p1, p_peek(p1),
        "row hole must be the last item in the row")
      PRow { p: pe, r: ROpen(placeholder, list_reverse(acc)) }
    } else {
      PRow { p: p1, r: ROpen(placeholder, list_reverse(acc)) }
    }
  } else if not tk_is(t.kind, TkIdent) {
    PRow { p: p_error(p, t, "expected effect name in row"), r: REmpty }
  } else {
    let name = tok_source(p.src, t)
    let p1 = p_advance(p)
    if is_upper_ident(p.src, t) {
      # m7b #11: optional `[T1, T2]` after the label name. `Reader[Int]`
      # in row position parses the same way as a generic type
      # application — distinct labels for distinct instantiations.
      let args_r =
        if p_at(p1, TkLbracket) {
          parse_row_label_args(p_skip_newlines(p_advance(p1)), [])
        } else {
          PRowArgs { p: p1, r: Some([]) }
        }
      match args_r.r {
        None -> PRow { p: args_r.p, r: REmpty }
        Some(targs) -> {
          let acc1 = [RL(name, targs), ...acc]
          if p_at(args_r.p, TkPlus) {
            parse_row_labels(p_advance(args_r.p), acc1)
          } else {
            PRow { p: args_r.p, r: RClosed(list_reverse(acc1)) }
          }
        }
      }
    } else {
      # m7b #12: lowercase identifier — a row variable in tail
      # position. Row variables themselves carry no type args and
      # must be the last item in the row; anything after `+` here
      # is rejected.
      if p_at(p1, TkPlus) {
        let pe = p_error(p1, p_peek(p1),
          "row variable must be the last item in the row")
        PRow { p: pe, r: ROpen(name, list_reverse(acc)) }
      } else {
        PRow { p: p1, r: ROpen(name, list_reverse(acc)) }
      }
    }
  }
}

type PRowArgs = { p: Parser, r: Option[[TypeExpr]] }

fn parse_row_label_args(p: Parser, acc: [TypeExpr]) : PRowArgs / Console {

  let r = parse_type(p)
  match r.r {
    None -> PRowArgs { p: r.p, r: None }
    Some(arg) -> {
      let p1 = p_skip_newlines(r.p)
      if p_at(p1, TkComma) {
        parse_row_label_args(p_skip_newlines(p_advance(p1)), [arg, ...acc])
      } else if p_at(p1, TkRbracket) {
        PRowArgs { p: p_advance(p1), r: Some(list_reverse([arg, ...acc])) }
      } else {
        PRowArgs { p: p_error_here(p1, "expected `,` or `]` after row-label type arguments"), r: None }
      }
    }
  }
}

fn parse_type(p: Parser) : PTy / Console {

  let base = parse_type_base(p)
  match base.r {
    None -> base
    Some(_) -> parse_optional_refinement(base)
  }
}

# m12.6.a: after a base type parses, peek for `where` and consume the
# refinement predicate as a single Expr. The predicate parses with the
# normal expression grammar; m12.6.b/c restrict it to the decidable
# subset and wire it into typer + codegen. The unary form
# `where >= 0` (predicate begins with a comparator and elides `self`
# on the LHS) is desugared at parse time into `self >= 0`.
fn parse_optional_refinement(base: PTy) : PTy / Console {

  if not p_at(base.p, TkWhere) { base } else {
    match base.r {
      None -> base
      Some(bt) -> {
        let p1 = p_advance(base.p)
        let pe = parse_refinement_predicate(p1, bt.line, bt.col)
        match pe.r {
          None -> PTy { p: pe.p, r: None }
          Some(pred) ->
            PTy { p: pe.p, r: Some(mk_ty(TyRefine(bt, pred), bt.line, bt.col)) }
        }
      }
    }
  }
}

# m12.6.a: parse the body of a `where` clause. The grammar accepts any
# Expr; in addition, when the next token is a comparison operator
# (`<`, `<=`, `==`, `!=`, `>`, `>=`), `self` is implicitly inserted as
# the LHS so that `where >= 0` desugars to `self >= 0`. Validation that
# the resulting Expr lies in the decidable subset is the typer's job
# (m12.6.b).
#
# m12.6.x #7: a second receiver-elision sugar — `where matches <expr>`
# desugars to `matches(self, <expr>)`. This is the refinement-side
# counterpart to the regex sigil: typical use is `String where matches
# ~r/^[a-z]+$/`. The desugar applies whenever the predicate begins
# with the bare identifier `matches` and the next non-`(` token is an
# expression starter — that excludes `matches(s, p)` (an explicit
# call) and `matches.field` (a member access on a value bound to
# `matches`), so user code that already names a function `matches` is
# unaffected.
fn parse_refinement_predicate(p: Parser, line: Int, col: Int) : PExpr / Console {

  let t = p_peek(p)
  if is_cmp_token(t.kind) {
    let lhs = mk_expr(EVar("self"), line, col)
    parse_refinement_cmp_with(p, lhs, line, col)
  } else if is_matches_sugar_start(p, t) {
    parse_refinement_matches_with(p, t, line, col)
  } else {
    parse_expr(p)
  }
}

fn is_matches_sugar_start(p: Parser, t: Token) : Bool {
  if not tk_is(t.kind, TkIdent) { false }
  else if tok_source(p.src, t) != "matches" { false }
  else { refinement_matches_sugar_at(p_advance(p)) }
}

fn parse_refinement_matches_with(p: Parser, t: Token, line: Int, col: Int) : PExpr / Console {

  let p1 = p_advance(p)
  let rhs = parse_expr(p1)
  match rhs.r {
    None -> rhs
    Some(rv) -> {
      let self_e = mk_expr(EVar("self"), line, col)
      let callee = mk_expr(EVar("matches"), t.line, t.col)
      let call = mk_expr(ECall(callee, [self_e, rv]), t.line, t.col)
      PExpr { p: rhs.p, r: Some(call) }
    }
  }
}

# True when the token after `matches` looks like the start of an
# expression argument (rather than `(` — which signals an explicit
# call — or `.` — a member access on a value named `matches`). Used
# to gate the `where matches <expr>` receiver-elision sugar.
fn refinement_matches_sugar_at(p: Parser) : Bool {
  let t = p_peek(p)
  if tk_is(t.kind, TkLparen) { false }
  else if tk_is(t.kind, TkDot) { false }
  else if tk_is(t.kind, TkRegex) { true }
  else if tk_is(t.kind, TkIdent) { true }
  else if tk_is(t.kind, TkString) { true }
  else { false }
}

fn is_cmp_token(k: TokKind) : Bool {
  if tk_is(k, TkLt) { true }
  else if tk_is(k, TkLe) { true }
  else if tk_is(k, TkEqEq) { true }
  else if tk_is(k, TkNeq) { true }
  else if tk_is(k, TkGt) { true }
  else if tk_is(k, TkGe) { true }
  else { false }
}

# Build `self <op> rhs` when the where clause begins with a bare
# comparator. Emitted as an EBinop so the typer / codegen treat it
# identically to a written-out comparison. The spec's bounded-interval
# form `1 <= self <= 65535` is not chained here because parse_expr
# rejects non-associative comparison chaining; users who want both
# sides write `where 1 <= self and self <= 65535`.
fn parse_refinement_cmp_with(p: Parser, lhs: Expr, line: Int, col: Int) : PExpr / Console {

  let op_tok = p_peek(p)
  let op_name = cmp_op_name(op_tok.kind)
  let p1 = p_advance(p)
  let rhs = parse_expr(p1)
  match rhs.r {
    None -> rhs
    Some(rv) -> {
      let cmp = mk_expr(EBinop(op_name, lhs, rv), line, col)
      PExpr { p: rhs.p, r: Some(cmp) }
    }
  }
}

fn cmp_op_name(k: TokKind) : String {
  if tk_is(k, TkLt) { "<" }
  else if tk_is(k, TkLe) { "<=" }
  else if tk_is(k, TkEqEq) { "==" }
  else if tk_is(k, TkNeq) { "!=" }
  else if tk_is(k, TkGt) { ">" }
  else if tk_is(k, TkGe) { ">=" }
  else { "==" }
}

fn parse_type_base(p: Parser) : PTy / Console {

  let t = p_peek(p)
  if tk_is(t.kind, TkLbracket) {
    let p1 = p_advance(p)
    let r = parse_type(p1)
    match r.r {
      None -> err_t(r.p)
      Some(inner) -> {
        if p_at(r.p, TkRbracket) {
          ok_t(p_advance(r.p), mk_ty(TyList(inner), t.line, t.col))
        } else {
          err_t(p_error_here(r.p, "expected `]` in list type"))
        }
      }
    }
  } else if tk_is(t.kind, TkLparen) {
    parse_fn_type(p, t)
  } else if tk_is(t.kind, TkIdent) {
    parse_named_type(p, t)
  } else {
    err_t(p_error_here(p, "expected type"))
  }
}

fn parse_named_type(p: Parser, t: Token) : PTy / Console {

  let name = tok_source(p.src, t)
  let p1 = p_advance(p)
  # Issue #232: qualified type head `mod.Type[args?]`. When the
  # leading ident is lowercase and followed by `.UpperIdent`, fold
  # the qualifier into the TyName payload as a dotted string. The
  # qualtype rewriter pass validates against the module table and
  # strips the qualifier before resolve_ty runs.
  if (not is_upper_ident(p.src, t)) and p_at(p1, TkDot) and tk_is(p_peek1(p1).kind, TkIdent) and is_upper_ident(p1.src, p_peek1(p1)) {
    let nt = p_peek1(p1)
    let qname = concat_all([name, ".", tok_source(p1.src, nt)])
    let p2 = p_advance(p_advance(p1))
    if p_at(p2, TkLbracket) and not tk_is(p_peek1(p2).kind, TkLt) {
      let p3 = p_skip_newlines(p_advance(p2))
      parse_type_args_loop(p3, [], qname, t)
    } else {
      ok_t(p2, mk_ty(TyName(qname, []), t.line, t.col))
    }
  }
  # m12.6.x #5 inline: peek-2 disambiguation. `Foo[<...>]` is the
  # `[<refinement_pure>]` attribute (handled by the caller, e.g.
  # parse_fn_decl), NOT a generic-type opener. So when `[` is
  # followed by `<`, leave both tokens for the outer parser.
  else if p_at(p1, TkLbracket) and not tk_is(p_peek1(p1).kind, TkLt) {
    # Generic type: Name[T1, T2, ...]
    let p2 = p_skip_newlines(p_advance(p1))
    parse_type_args_loop(p2, [], name, t)
  } else if (name == "Real" or name == "Int" or name == "Decimal") and p_at(p1, TkLt) {
    # m12.5: dimensioned numeric — `Real<unit-expr>` / `Int<unit-expr>` /
    # `Decimal<unit-expr>`. `Decimal` is the stdlib alias that ledger /
    # finance demos reach for; the parser accepts the annotation here so
    # record fields (`balance: Decimal<USD>`) and top-level positions
    # share one route. The typer collapses TyDim to the head TyName at
    # protocol-dispatch time (see `proto_type_name`).
    let p2 = p_skip_newlines(p_advance(p1))
    let ru = parse_unit_expr(p2)
    match ru.r {
      None -> err_t(ru.p)
      Some(u) -> {
        let p3 = p_skip_newlines(ru.p)
        if not p_at(p3, TkGt) {
          err_t(p_error_here(p3, "expected `>` to close the unit annotation"))
        } else {
          let base = mk_ty(TyName(name, []), t.line, t.col)
          ok_t(p_advance(p3), mk_ty(TyDim(base, u), t.line, t.col))
        }
      }
    }
  } else {
    ok_t(p1, mk_ty(TyName(name, []), t.line, t.col))
  }
}

fn parse_type_args_loop(p: Parser, acc: [TypeExpr], name: String, t: Token) : PTy / Console {

  let r = parse_type(p)
  match r.r {
    None -> err_t(r.p)
    Some(arg) -> {
      let p1 = p_skip_newlines(r.p)
      if p_at(p1, TkComma) {
        parse_type_args_loop(p_skip_newlines(p_advance(p1)), [arg, ...acc], name, t)
      } else if p_at(p1, TkRbracket) {
        ok_t(p_advance(p1), mk_ty(TyName(name, list_reverse([arg, ...acc])), t.line, t.col))
      } else {
        err_t(p_error_here(p1, "expected `,` or `]` after type arguments"))
      }
    }
  }
}

fn parse_fn_type(p: Parser, t: Token) : PTy / Console {

  let p1 = p_skip_newlines(p_advance(p))
  if p_at(p1, TkRparen) {
    let p2 = p_advance(p1)
    if not p_at(p2, TkArrow) {
      err_t(p_error_here(p2, "expected `->` in function type"))
    } else {
      let r = parse_type(p_advance(p2))
      match r.r {
        None -> err_t(r.p)
        Some(ret) -> {
          let row_r = parse_row_suffix(r.p)
          ok_t(row_r.p, mk_ty(TyFn([], ret, row_r.r), t.line, t.col))
        }
      }
    }
  } else {
    parse_fn_type_args(p1, [], t)
  }
}

# Function-type args OR n-tuple type sugar (#154). The disambiguation
# is local: parse a comma-separated list of types until `)`. If `->`
# follows, it's a function type. Otherwise it's a tuple type and we
# desugar to `Pair[A, B]` / `Triple[A, B, C]` / `Quad[A, B, C, D]`.
# A single type in parens (`(A)`) followed by no `->` is grouping —
# returns the inner type unchanged. Zero-arg `()` keeps the existing
# function-type contract (handled in parse_fn_type, must be `() -> T`).
fn parse_fn_type_args(p: Parser, acc: [TypeExpr], t: Token) : PTy / Console {

  let r = parse_type(p)
  match r.r {
    None -> err_t(r.p)
    Some(arg) -> {
      let p1 = p_skip_newlines(r.p)
      if p_at(p1, TkComma) {
        parse_fn_type_args(p_skip_newlines(p_advance(p1)), [arg, ...acc], t)
      } else if p_at(p1, TkRparen) {
        let p2 = p_advance(p1)
        if p_at(p2, TkArrow) {
          let rr = parse_type(p_advance(p2))
          match rr.r {
            None -> err_t(rr.p)
            Some(ret) -> {
              let row_r = parse_row_suffix(rr.p)
              ok_t(row_r.p, mk_ty(TyFn(list_reverse([arg, ...acc]), ret, row_r.r), t.line, t.col))
            }
          }
        } else {
          # Not a function type: re-interpret as tuple-type sugar or grouping.
          let args = list_reverse([arg, ...acc])
          let n = list_length(args)
          if n == 1 {
            # Single type in parens: grouping. `(A)` ≡ `A`.
            ok_t(p2, arg)
          } else {
            match tuple_type_for_arity(n) {
              None -> err_t(p_error_here(p1, "n-tuple type sugar supports arity 2..4 only — use a named record for wider products"))
              Some(name) -> ok_t(p2, mk_ty(TyName(name, args), t.line, t.col))
            }
          }
        }
      } else {
        err_t(p_error_here(p1, "expected `,` or `)` in type"))
      }
    }
  }
}

# ====================================================================
# declarations
# ====================================================================

fn parse_decl(p: Parser) : PDecl / Console {

  let p_pre = p_skip_newlines(p)
  # Issue #260: the legacy `[<extern_c>]` attribute prefix is
  # rejected before any other parsing happens — the spec syntax is
  # now `extern "C" fn ...` (and the override variant from issue
  # #261). We surface a migration error pointing at the new form.
  if parse_at_legacy_extern_c_attribute(p_pre) {
    let line_msg = "`[<extern_c>] axiom` is removed (issue #260) — use `extern \"C\" fn name(...) : T / Ffi` instead"
    err_d(p_error_here(p_pre, line_msg))
  } else {
  let p0 = p_pre
  let t = p_peek(p0)
  # Issue #260: `extern` is a top-level keyword introducing an FFI
  # declaration. It binds tighter than `pub`, so the surface form
  # is `extern "C" pub fn ...`. The optional name override (issue
  # #261) sits between the ABI literal and the `pub`/`fn`.
  if tk_is(t.kind, TkExtern) {
    parse_extern_decl(p_advance(p0), t)
  } else {
  let is_pub_r =
    if tk_is(t.kind, TkPub) { PTy { p: p_advance(p0), r: Some(mk_ty(TyName("", []), 0, 0)) } }
    else { PTy { p: p0, r: None } }
  let is_pub =
    match is_pub_r.r { Some(_) -> true None -> false }
  let p1 = is_pub_r.p
  let hd = p_peek(p1)
  if tk_is(hd.kind, TkFn) {
    parse_fn_decl(p_advance(p1), is_pub, hd)
  } else if tk_is(hd.kind, TkType) {
    parse_type_decl(p_advance(p1), is_pub, hd)
  } else if tk_is(hd.kind, TkEffect) {
    parse_effect_decl(p_advance(p1), is_pub, hd)
  } else if tk_is(hd.kind, TkProtocol) {
    parse_protocol_decl(p_advance(p1), is_pub, hd)
  } else if tk_is(hd.kind, TkImpl) {
    if is_pub { err_d(p_error(p1, hd, "`pub` is not allowed on an impl")) }
    else { parse_impl_decl(p_advance(p1), hd) }
  } else if tk_is(hd.kind, TkDerive) {
    if is_pub { err_d(p_error(p1, hd, "`pub` must precede the `type` declaration after `#derive`")) }
    else { parse_derive_decl(p_advance(p1), hd) }
  } else if tk_is(hd.kind, TkTest) {
    if is_pub { err_d(p_error(p1, hd, "`pub` is not allowed on a test")) }
    else { parse_test_decl(p_advance(p1), hd) }
  } else if tk_is(hd.kind, TkBench) {
    if is_pub { err_d(p_error(p1, hd, "`pub` is not allowed on a bench")) }
    else { parse_bench_decl(p_advance(p1), hd) }
  } else if tk_is(hd.kind, TkCheck) {
    if is_pub { err_d(p_error(p1, hd, "`pub` is not allowed on a check")) }
    else { parse_check_decl(p_advance(p1), hd) }
  } else if tk_is(hd.kind, TkImport) {
    if is_pub { err_d(p_error(p1, hd, "`pub` is not allowed on an import")) }
    else { parse_import_decl(p_advance(p1), hd) }
  } else if tk_is(hd.kind, TkUnitKw) {
    parse_unit_decl(p_advance(p1), is_pub, hd)
  } else if tk_is(hd.kind, TkUse) {
    if is_pub { err_d(p_error(p1, hd, "`pub` is not allowed on a `use` declaration")) }
    else { parse_use_decl(p_advance(p1), hd) }
  } else if tk_is(hd.kind, TkAxiom) {
    parse_axiom_decl(p_advance(p1), is_pub, false, "", hd)
  } else if tk_is(hd.kind, TkConst) {
    parse_const_decl(p_advance(p1), is_pub, hd)
  } else {
    let base = "expected `fn`, `type`, `effect`, `protocol`, `impl`, `test`, `unit`, `use`, `axiom`, `const`, or `import`"
    let msg = if tk_is(hd.kind, TkIdent) {
      let text = tok_source(p1.src, hd)
      match closest_name(text, ["fn", "type", "effect", "protocol", "impl", "test", "unit", "use", "axiom", "const", "import", "pub"]) {
        Some(sug) -> concat_all([base, " (did you mean `", sug, "`?)"])
        None      -> base
      }
    } else { base }
    err_d(p_error(p1, hd, msg))
  }
  }
  }
}

# §29 const NAME : T = expr — top-level named constant. Parses to
# the dedicated `DConst` variant (issue #269). The `lower_consts`
# pass converts it to `DAttribPure(DFn arity-0)` early in the
# pipeline so downstream walkers (typer, monomorphiser, emitters)
# keep seeing the legacy shape until the structural typer/emitter
# integration lands. Const reads still go through the `desugar_const_refs_decls`
# pass that rewrites `EVar(NAME)` to `ECall(EVar(NAME), [])`; that
# pass is now scope-aware so a fn parameter named `NAME` shadows
# the const correctly (the bug filed in #269).
fn parse_const_decl(p: Parser, is_pub: Bool, t: Token) : PDecl / Console {

  let id = p_peek(p)
  if not tk_is(id.kind, TkIdent) {
    err_d(p_error(p, id, "expected constant name after `const`"))
  } else {
    let name = tok_source(p.src, id)
    let p1 = p_advance(p)
    let p2 = p_skip_newlines(p1)
    if not p_at(p2, TkColon) {
      err_d(p_error_here(p2, "expected `:` after constant name (`const NAME : T = expr`)"))
    } else {
      let p3 = p_skip_newlines(p_advance(p2))
      let rt = parse_type(p3)
      match rt.r {
        None -> err_d(rt.p)
        Some(ty) -> {
          let p4 = p_skip_newlines(rt.p)
          if not p_at(p4, TkEq) {
            err_d(p_error_here(p4, "expected `=` in constant declaration"))
          } else {
            let p5 = p_skip_newlines(p_advance(p4))
            let re = parse_expr(p5)
            match re.r {
              None -> err_d(re.p)
              Some(body) -> {
                ok_d(re.p, DConst(is_pub, name, ty, body, t.line, t.col))
              }
            }
          }
        }
      }
    }
  }
}

# Issue #260: detect the legacy `[<extern_c>]` attribute prefix
# without consuming any tokens. We peek for the exact 3-token shape
# `[`, `<`, `extern_c` so the much-more-common `[` (a list literal
# at the top of a const) does not trigger. Returns true only when
# the migration error should fire. The parser then surfaces a
# diagnostic without trying to recover.
fn parse_at_legacy_extern_c_attribute(p: Parser) : Bool {
  if not p_at(p, TkLbracket) { false }
  else if not tk_is(p_peek1(p).kind, TkLt) { false }
  else {
    # Peek the third token (the attribute name). `p_peek1` is +1, so
    # we advance once into the `<` and peek1 from there to get the
    # ident slot. `extern_c` is the only attribute that lived inside
    # `[<...>]` to date; other names are likely typos and still get
    # the same migration message (cheaper than enumerating valid
    # alternatives, none of which exist).
    let p1 = p_advance(p)
    let id = p_peek1(p1)
    if not tk_is(id.kind, TkIdent) { false }
    else { tok_source(p1.src, id) == "extern_c" }
  }
}

# Issue #260: parse the new spec form
#   extern STRING_LIT [ "(" STRING_LIT ")" ] [ "pub" ] "fn" name(...) : T [ / row ]
# Routes into `parse_axiom_decl` so the rest of the pipeline keeps
# seeing a uniform `DAxiom(extern_c=true, c_sym_over=...)` shape.
# `t` is the `extern` token, used for line/col on the resulting
# decl.
#
# Issue #261 hooks in here too: the optional `("symbol")` after the
# ABI literal becomes the `c_sym_over` argument. The override must
# be a valid C identifier (`[A-Za-z_][A-Za-z0-9_]*`); anything else
# is rejected so a typo'd quote does not silently link a symbol the
# user did not intend.
fn parse_extern_decl(p: Parser, t: Token) : PDecl / Console {

  let p_abi = p_skip_newlines(p)
  let abi_tok = p_peek(p_abi)
  if not tk_is(abi_tok.kind, TkString) {
    err_d(p_error(p_abi, abi_tok, "expected an ABI string literal after `extern` (only `\"C\"` is supported)"))
  } else {
    let abi_span = tok_source(p_abi.src, abi_tok)
    if not (abi_span == "\"C\"") {
      err_d(p_error(p_abi, abi_tok,
        concat_all(["unsupported FFI ABI ", abi_span, " — only \"C\" is supported"])))
    } else {
      let p1 = p_advance(p_abi)
      # Optional `("real_symbol")` name override (issue #261). Sits
      # immediately after the ABI literal with no intervening
      # newline so the parser cannot mistake a list literal that
      # follows on the next line for the override.
      let over_r = parse_optional_extern_c_override(p1)
      match over_r.r {
        None -> err_d(over_r.p)
        Some(c_sym_over) -> {
          let p2 = p_skip_newlines(over_r.p)
          let is_pub_tok = p_peek(p2)
          let is_pub = tk_is(is_pub_tok.kind, TkPub)
          let p3 = if is_pub { p_skip_newlines(p_advance(p2)) } else { p2 }
          let fn_tok = p_peek(p3)
          if not tk_is(fn_tok.kind, TkFn) {
            err_d(p_error(p3, fn_tok, "expected `fn` after `extern \"C\"` (FFI declarations look like `extern \"C\" fn name(...) : T / Ffi`)"))
          } else {
            let decl_r = parse_axiom_decl(p_advance(p3), is_pub, true, c_sym_over, t)
            validate_extern_c_decl(decl_r, t)
          }
        }
      }
    }
  }
}

type PStr = { p: Parser, r: Option[String] }

# Issue #261: parse the optional `("real_symbol")` override after
# the ABI literal. Returns:
#   - `None` parser-error on a malformed override (unmatched paren,
#     non-string token inside, or a non-C-identifier symbol);
#   - `Some("")` when there is no override (caller will use the
#     kaikai identifier as the C symbol);
#   - `Some(s)` when the override is `s`.
fn parse_optional_extern_c_override(p: Parser) : PStr / Console {

  if not p_at(p, TkLparen) { PStr { p: p, r: Some("") } }
  else {
    let p1 = p_advance(p)
    let sym_tok = p_peek(p1)
    if not tk_is(sym_tok.kind, TkString) {
      PStr { p: p_error(p1, sym_tok, "expected a C-symbol string literal inside `extern \"C\"(...)`"), r: None }
    } else {
      let sym_span = tok_source(p1.src, sym_tok)
      let n = string_length(sym_span)
      # The span includes the surrounding quotes — strip them.
      let sym_clean = if n >= 2 { string_slice(sym_span, 1, n - 2) } else { "" }
      if not is_valid_c_identifier(sym_clean) {
        PStr {
          p: p_error(p1, sym_tok,
            concat_all(["invalid C symbol override ", sym_span,
                        " — must match `[A-Za-z_][A-Za-z0-9_]*`"])),
          r: None
        }
      } else {
        let p2 = p_advance(p1)
        if not p_at(p2, TkRparen) {
          PStr { p: p_error_here(p2, "expected `)` to close `extern \"C\"(\"<symbol>\")` override"), r: None }
        } else {
          PStr { p: p_advance(p2), r: Some(sym_clean) }
        }
      }
    }
  }
}

# Issue #536: an `extern "C" fn` declaration MUST advertise `Ffi` in
# its effect row. The capability discipline pinned in CLAUDE.md
# baseline architecture says FFI crosses to C *via* the `Ffi`
# capability; an extern without that label silently bypasses the
# contract and downstream Tier-1 invariants about effect rows lose
# their teeth. Returns true iff the row syntactically contains a
# label named `Ffi` (label args are irrelevant — `Ffi` is nullary).
fn extern_row_has_ffi(row: RowExpr) : Bool {
  match row {
    REmpty         -> false
    RClosed(lbs)   -> row_label_names_has(lbs, "Ffi")
    ROpen(_, lbs)  -> row_label_names_has(lbs, "Ffi")
  }
}

fn row_label_names_has(labels: [RowLabel], target: String) : Bool {
  match labels {
    [] -> false
    [l, ...rest] -> match l {
      RL(name, _) -> if name == target { true } else { row_label_names_has(rest, target) }
    }
  }
}

# Issue #536 shape 2: a type appearing in the parameter list or
# return slot of an `extern "C" fn` MUST be C-ABI compatible. The
# kaikai layout for `[T]` (singly-linked list), `Option[T]` (tagged
# sum), records, and user-declared sum types is implementation-
# defined and unsafe to expose across the C boundary. The allowlist
# is intentionally small — Int, Real, Bool, String, Unit (return
# only). Future extensions (Int32, opaque pointer types) get added
# here explicitly, not via heuristics.
#
# `is_return_slot` widens the allowlist to include `Unit` (a `void`
# return is fine in C; a `void` parameter is not the same shape as
# kaikai's nullary `Unit` and is excluded).
fn is_c_abi_safe_type(t: TypeExpr, is_return_slot: Bool) : Bool {
  match t.tkind {
    TyName(name, targs) ->
      if list_length(targs) > 0 { false }
      else if name == "Int" { true }
      else if name == "Real" { true }
      else if name == "Bool" { true }
      else if name == "String" { true }
      else if name == "Unit" { is_return_slot }
      else { false }
    _ -> false
  }
}

# Issue #536: walk an `extern "C" fn` parameter list and return the
# first param whose type is NOT C-ABI safe, or `None` if every
# parameter is safe. Untyped parameters (`ptype: None`) cannot occur
# in an extern signature — `parse_fn_params` rejects missing
# annotations on axiom-shape decls — but we guard for it anyway.
fn first_non_c_abi_param(params: [Param]) : Option[Param] {
  match params {
    [] -> None
    [p, ...rest] -> match p.ptype {
      None -> Some(p)
      Some(ty) ->
        if is_c_abi_safe_type(ty, false) { first_non_c_abi_param(rest) }
        else { Some(p) }
    }
  }
}

# Issue #536: render a TypeExpr surface form for diagnostics. We
# only need the cases the validator might reject; the fallthrough
# emits a placeholder that still anchors the diagnostic to the
# offending site.
fn type_surface(t: TypeExpr) : String {
  match t.tkind {
    TyName(name, targs) ->
      if list_length(targs) == 0 { name }
      else { concat_all([name, "[", type_args_surface(targs), "]"]) }
    TyList(inner) -> concat_all(["[", type_surface(inner), "]"])
    TyFn(_, _, _) -> "fn(...)"
    TyDim(base, _) -> concat_all([type_surface(base), "<...>"])
    TyRefine(base, _) -> concat_all([type_surface(base), " where ..."])
  }
}

fn type_args_surface(ts: [TypeExpr]) : String {
  match ts {
    [] -> ""
    [t]  -> type_surface(t)
    [t, ...rest] -> concat_all([type_surface(t), ", ", type_args_surface(rest)])
  }
}

# Issue #536: post-process a successfully parsed `extern "C" fn`
# declaration. Three independent checks, each surfacing a parse-
# time diagnostic anchored to the `extern` keyword token:
#   (a) the effect row must contain `Ffi`;
#   (b) every parameter type must be C-ABI compatible;
#   (c) the return type must be C-ABI compatible.
# A failure in any check converts the PDecl into an error result;
# on success, the original PDecl flows through unchanged so the
# rest of the pipeline keeps seeing the uniform DAxiom shape.
fn validate_extern_c_decl(decl_r: PDecl, t: Token) : PDecl / Console {
  match decl_r.r {
    None -> decl_r
    Some(d) -> match d {
      DAxiom(_, _, name, _, _, params, ret_ty, row, _, _) -> {
        if not extern_row_has_ffi(row) {
          let msg = concat_all([
            "`extern \"C\" fn ", name,
            "` must declare `/ Ffi` in its row — FFI declarations always cross the Ffi capability boundary"
          ])
          err_d(p_error(decl_r.p, t, msg))
        } else {
          match first_non_c_abi_param(params) {
            Some(p) -> {
              let ty_s = match p.ptype {
                Some(ty) -> type_surface(ty)
                None     -> "<missing>"
              }
              let msg = concat_all([
                "`extern \"C\" fn ", name,
                "` parameter `", p.pname,
                "` has type `", ty_s,
                "` which is not C-ABI compatible — allowed: Int, Real, Bool, String"
              ])
              err_d(p_error(decl_r.p, t, msg))
            }
            None ->
              if not is_c_abi_safe_type(ret_ty, true) {
                let msg = concat_all([
                  "`extern \"C\" fn ", name,
                  "` return type `", type_surface(ret_ty),
                  "` is not C-ABI compatible — allowed: Int, Real, Bool, String, Unit"
                ])
                err_d(p_error(decl_r.p, t, msg))
              } else { decl_r }
          }
        }
      }
      # parse_axiom_decl always produces a DAxiom on success; any
      # other shape would be a structural surprise and should fall
      # through unchanged so the user sees the original parser
      # error rather than a misleading FFI message.
      _ -> decl_r
    }
  }
}

# Issue #261: the override must be a syntactically valid C
# identifier so the emitted call site survives the C compiler. We
# do not try to validate that the symbol actually links — that is
# a build-time concern, not a parse-time one.
fn is_valid_c_identifier(s: String) : Bool {
  let n = string_length(s)
  if n == 0 { false }
  else {
    let c0 = char_at_or_zero(s, 0)
    if not (ch_is_alpha(c0) or c0 == '_') { false }
    else { is_valid_c_identifier_rest(s, 1, n) }
  }
}

fn is_valid_c_identifier_rest(s: String, i: Int, n: Int) : Bool {
  if i >= n { true }
  else {
    let c = char_at_or_zero(s, i)
    if ch_is_alnum(c) or c == '_' { is_valid_c_identifier_rest(s, i + 1, n) }
    else { false }
  }
}

# m12.7: parse `axiom name[tparams](params) : T / row`. Mirrors
# `parse_fn_decl`'s prologue (name + tparams + params) but the
# return type is REQUIRED (no default `Unit`) and there is no body
# clause — `=` or `{` after the row annotation is rejected. The
# Decl carries everything `lower_axioms` needs to synthesise a
# `todo!` body in the desugar pass.
#
# m12.7.x FFI v1: `extern_c` was historically set by the legacy
# `[<extern_c>]` attribute prefix (removed in issue #260). After
# the migration, `extern_c` is only set via `parse_extern_decl`
# routing through `parse_axiom_decl_inner`; bare `axiom` decls
# always pass `extern_c=false, c_sym_over=""`.
#
# Issue #261: `c_sym_over` carries the optional C-symbol override
# (empty string when absent). Only meaningful when `extern_c` is true.
fn parse_axiom_decl(p: Parser, is_pub: Bool, extern_c: Bool, c_sym_over: String, t: Token) : PDecl / Console {

  let id = p_peek(p)
  if not tk_is(id.kind, TkIdent) {
    err_d(p_error(p, id, "expected axiom name"))
  } else {
    let name = tok_source(p.src, id)
    let p1 = p_advance(p)
    let tparams_r =
      if p_at(p1, TkLbracket) {
        parse_type_params_loop(p_skip_newlines(p_advance(p1)), [])
      } else {
        PTParams { p: p1, r: Some([]) }
      }
    match tparams_r.r {
      None -> err_d(tparams_r.p)
      Some(tparams) -> {
        let pp = tparams_r.p
        if not p_at(pp, TkLparen) {
          err_d(p_error_here(pp, "expected `(` after axiom name"))
        } else {
          let p2 = p_skip_newlines(p_advance(pp))
          let params_r = parse_fn_params(p2, [])
          match params_r.r {
            None -> err_d(params_r.p)
            Some(params) -> {
              let p3 = p_skip_newlines(params_r.p)
              if not p_at(p3, TkColon) {
                err_d(p_error_here(p3, "axiom requires a return type — write `axiom name(...) : T`"))
              } else {
                let rt = parse_type(p_advance(p3))
                match rt.r {
                  None -> err_d(rt.p)
                  Some(ty) -> {
                    let row_r = parse_row_suffix(rt.p)
                    let p4 = p_skip_newlines(row_r.p)
                    if p_at(p4, TkEq) or p_at(p4, TkLbrace) {
                      err_d(p_error_here(p4, "axiom must not have a body — drop the `=` / `{` and trailing block"))
                    } else {
                      ok_d(row_r.p, DAxiom(is_pub, extern_c, name, c_sym_over, tparams, params, ty, row_r.r, t.line, t.col))
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}

# m7e §25: parse `use Effect` as a Decl. The token at `t` is the
# `use` keyword; `p` is positioned right after it. Effect names are
# uppercase idents (matches the existing convention enforced by
# `parse_effect_decl`). Aliases (`use Console as C`) are not part
# of the v1.
fn parse_use_decl(p: Parser, t: Token) : PDecl / Console {

  let id = p_peek(p)
  if not tk_is(id.kind, TkIdent) {
    err_d(p_error(p, id, "expected effect name after `use`"))
  } else if not is_upper_ident(p.src, id) {
    err_d(p_error(p, id, "effect name in `use` must start with an uppercase letter"))
  } else {
    let name = tok_source(p.src, id)
    ok_d(p_advance(p), DUse(name, t.line, t.col))
  }
}

# m12.5: parse a unit declaration. Two shapes:
#   `unit USD`                                    — atomic
#   `unit Newton = kg * m / sec^2`                — alias
fn parse_unit_decl(p: Parser, is_pub: Bool, t: Token) : PDecl / Console {

  let id = p_peek(p)
  if not tk_is(id.kind, TkIdent) {
    err_d(p_error(p, id, "expected unit name after `unit`"))
  } else {
    let name = tok_source(p.src, id)
    let p1 = p_advance(p)
    if p_at(p1, TkEq) {
      let p2 = p_skip_newlines(p_advance(p1))
      let rb = parse_unit_expr(p2)
      match rb.r {
        None -> err_d(rb.p)
        Some(u) -> ok_d(rb.p, DUnit(is_pub, name, Some(u), t.line, t.col))
      }
    } else {
      ok_d(p1, DUnit(is_pub, name, None, t.line, t.col))
    }
  }
}

# m12.5: unit-expression grammar.
#   unit_expr := unit_term ( ('*' | '/') unit_term )*
#   unit_term := unit_factor ('^' integer)?
#   unit_factor := IDENT | INT('1') | '(' unit_expr ')'
type PUnit = { p: Parser, r: Option[UnitExprT] }

fn ok_u(p: Parser, u: UnitExprT) : PUnit = PUnit { p: p, r: Some(u) }
fn err_u(p: Parser) : PUnit = PUnit { p: p, r: None }

fn parse_unit_expr(p: Parser) : PUnit / Console {

  let r = parse_unit_term(p)
  match r.r {
    None -> err_u(r.p)
    Some(lhs) -> parse_unit_expr_rest(r.p, lhs)
  }
}

fn parse_unit_expr_rest(p: Parser, lhs: UnitExprT) : PUnit / Console {

  if p_at(p, TkStar) {
    let r = parse_unit_term(p_advance(p))
    match r.r {
      None -> err_u(r.p)
      Some(rhs) -> parse_unit_expr_rest(r.p, UMul(lhs, rhs))
    }
  } else if p_at(p, TkSlash) {
    let r = parse_unit_term(p_advance(p))
    match r.r {
      None -> err_u(r.p)
      Some(rhs) -> parse_unit_expr_rest(r.p, UMul(lhs, UInv(rhs)))
    }
  } else {
    ok_u(p, lhs)
  }
}

fn parse_unit_term(p: Parser) : PUnit / Console {

  let r = parse_unit_factor(p)
  match r.r {
    None -> err_u(r.p)
    Some(base) -> {
      if p_at(r.p, TkCaret) {
        let p1 = p_advance(r.p)
        let rn = parse_unit_signed_int(p1)
        match rn.r {
          None -> err_u(rn.p)
          Some(n) -> ok_u(rn.p, UPow(base, n))
        }
      } else {
        ok_u(r.p, base)
      }
    }
  }
}

type PUInt = { p: Parser, r: Option[Int] }

fn parse_unit_signed_int(p: Parser) : PUInt / Console {

  let neg = p_at(p, TkMinus)
  let p1 = if neg { p_advance(p) } else { p }
  let t = p_peek(p1)
  if not tk_is(t.kind, TkInt) {
    PUInt { p: p_error_here(p1, "expected integer after `^` in unit expression"), r: None }
  } else {
    let n = decode_int(tok_source(p1.src, t))
    let v = if neg { 0 - n } else { n }
    PUInt { p: p_advance(p1), r: Some(v) }
  }
}

fn parse_unit_factor(p: Parser) : PUnit / Console {

  let t = p_peek(p)
  if tk_is(t.kind, TkIdent) {
    ok_u(p_advance(p), USym(tok_source(p.src, t)))
  } else if tk_is(t.kind, TkInt) {
    # Per spec §6 `<1>` is the dimensionless unit. Reject other ints.
    let span = tok_source(p.src, t)
    if decode_int(span) == 1 { ok_u(p_advance(p), UOne) }
    else { err_u(p_error(p, t, "only `1` is allowed as a unit literal (use a unit symbol or a parenthesised expression instead)")) }
  } else if tk_is(t.kind, TkLparen) {
    let r = parse_unit_expr(p_advance(p))
    match r.r {
      None -> err_u(r.p)
      Some(u) -> {
        if not p_at(r.p, TkRparen) {
          err_u(p_error_here(r.p, "expected `)` in unit expression"))
        } else {
          ok_u(p_advance(r.p), u)
        }
      }
    }
  } else {
    err_u(p_error(p, t, "expected unit symbol, `1`, or parenthesised unit expression"))
  }
}

fn parse_fn_decl(p: Parser, is_pub: Bool, t: Token) : PDecl / Console {

  let id = p_peek(p)
  if not tk_is(id.kind, TkIdent) {
    err_d(p_error(p, id, "expected function name"))
  } else {
    let name = tok_source(p.src, id)
    let p1 = p_advance(p)
    # m7b #13: optional `[T1, T2, ...]` type parameter list before `(`.
    # Same shape as effect tparams (m7b #11) — uppercase or lowercase
    # identifiers, comma-separated. Empty when omitted.
    let tparams_r =
      if p_at(p1, TkLbracket) {
        parse_type_params_loop(p_skip_newlines(p_advance(p1)), [])
      } else {
        PTParams { p: p1, r: Some([]) }
      }
    match tparams_r.r {
      None -> err_d(tparams_r.p)
      Some(tparams) -> {
        let pp = tparams_r.p
        if not p_at(pp, TkLparen) {
          err_d(p_error_here(pp, "expected `(` after function name"))
        } else {
      let p2 = p_skip_newlines(p_advance(pp))
      let params_r = parse_fn_params(p2, [])
      match params_r.r {
        None -> err_d(params_r.p)
        Some(params) -> {
          let p3 = p_skip_newlines(params_r.p)
          # Optional `: ReturnType`
          let ret_r =
            if p_at(p3, TkColon) {
              let rt = parse_type(p_advance(p3))
              match rt.r {
                None -> PTy { p: rt.p, r: None }
                Some(ty) -> PTy { p: rt.p, r: Some(ty) }
              }
            } else {
              PTy { p: p3, r: None }
            }
          if ret_r.p.had_error and not p3.had_error { err_d(ret_r.p) }
          else {
            # Optional effect-row suffix: `T / Io + Fail`. m7a #3b.
            let row_r = parse_row_suffix(ret_r.p)
            # m12.6.x #5(a): optional `[<refinement_pure>]` attribute
            # between the signature/row and the contract clauses. The
            # parser uses peek-2 lookahead so a bare `[` (e.g. the
            # rare list-type follow-up) doesn't trigger.
            let attr = parse_optional_pure_attribute(p_skip_newlines(row_r.p))
            # m12.6.b: optional `requires` / `ensures` clauses between
            # the signature and the body. They desugar to asserts in
            # the body — see wrap_with_contracts.
            let cc = parse_contracts_loop(p_skip_newlines(attr.p), [], [])
            let p4 = p_skip_newlines(cc.p)
            # Body: `= expr` or `{ block }`.
            if p_at(p4, TkEq) {
              let p5 = p_skip_newlines(p_advance(p4))
              let rb = parse_expr(p5)
              match rb.r {
                None -> err_d(rb.p)
                Some(body) -> {
                  let body2 = wrap_with_contracts(body, cc.reqs, cc.enss, params, name, t.line, t.col)
                  let dfn = DFn(is_pub, name, tparams, params, ret_r.r, row_r.r, body2, t.line, t.col, None)
                  ok_d(rb.p, maybe_wrap_pure(attr.is_pure, dfn, t.line, t.col))
                }
              }
            } else if p_at(p4, TkLbrace) {
              let tb = p_peek(p4)
              # issue #415: peek past `{` and any newlines/semis. If
              # the first significant token is `case`, parse a
              # multi-clause body that desugars to a `match` over the
              # implicit tuple of args. Otherwise, fall through to the
              # existing statement-block form.
              let after_lbrace = p_skip_newlines_and_semis(p_advance(p4))
              if p_at(after_lbrace, TkCase) {
                let rb = parse_clause_block(after_lbrace, params, tb)
                match rb.r {
                  None -> err_d(rb.p)
                  Some(body) -> {
                    let body2 = wrap_with_contracts(body, cc.reqs, cc.enss, params, name, t.line, t.col)
                    let dfn = DFn(is_pub, name, tparams, params, ret_r.r, row_r.r, body2, t.line, t.col, None)
                    ok_d(rb.p, maybe_wrap_pure(attr.is_pure, dfn, t.line, t.col))
                  }
                }
              } else {
                let rb = parse_block(p4, tb)
                match rb.r {
                  None -> err_d(rb.p)
                  Some(body) -> {
                    let body2 = wrap_with_contracts(body, cc.reqs, cc.enss, params, name, t.line, t.col)
                    let dfn = DFn(is_pub, name, tparams, params, ret_r.r, row_r.r, body2, t.line, t.col, None)
                    ok_d(rb.p, maybe_wrap_pure(attr.is_pure, dfn, t.line, t.col))
                  }
                }
              }
            } else {
              err_d(p_error_here(p4, "expected `=` or `{` to start function body"))
            }
          }
        }
      }
        }
      }
    }
  }
}

# issue #415: parse a multi-clause function body. The opening `{`
# has already been consumed; `p` points at the first `case` keyword
# (or whatever follows `{` and any newlines/semis — caller verified
# `p_at(p, TkCase)`). Each arm is `case <pat> (when <guard>)? -> <body>`.
# For a 1-arg fn the scrutinee is `EVar(arg_name)` and arms carry a
# single pattern (reuses `parse_match_arms`). For an N-arg fn (N>=2)
# the scrutinee tuple is `(arg1, ..., argN)` represented as N parallel
# scrutinees and arms carry N comma-separated patterns (reuses
# `parse_multi_match_arms`). After collection the result is an
# `EMatch` indistinguishable from a hand-written `match` body, so the
# typer / codegen / perceus see no new shape.
#
# Pure-block rule: if any non-`case` token appears between arms, the
# arm-collection loop fails with "expected `case` or `}`" and the
# whole fn body is rejected — stmt-block mixed with case-arms is a
# hard parse error, never a warning.
fn parse_clause_block(p: Parser, params: [Param], t: Token) : PExpr / Console {

  let n = list_length(params)
  if n == 0 {
    # Zero-arg fn with case-arms: there's nothing to discriminate
    # on. Reject explicitly so the diagnostic points at the keyword.
    err_e(p_error_here(p, "case-block requires at least one parameter to discriminate on"))
  } else if n == 1 {
    let scrut = make_param_scrut(list_head(params))
    parse_case_arms(p, [], scrut, t)
  } else if n > 4 {
    # Issue #129 cap on multi-arg match also bounds the desugared
    # tuple here; raising it requires re-evaluating the nested-match
    # blowup as in `parse_match`.
    err_e(p_error_here(p, "case-block supports up to 4 parameters"))
  } else {
    let scruts = make_param_scruts(params, [])
    parse_case_multi_arms(p, [], scruts, n, t)
  }
}

fn list_head(xs: [Param]) : Param {
  match xs {
    [] -> Param { pname: "_", ptype: None, pline: 0, pcol: 0 }
    [h, ..._] -> h
  }
}

fn make_param_scrut(pm: Param) : Expr =
  mk_expr(EVar(pm.pname), pm.pline, pm.pcol)

fn make_param_scruts(params: [Param], acc: [Expr]) : [Expr] {
  match params {
    [] -> list_reverse(acc)
    [pm, ...rest] -> make_param_scruts(rest, [make_param_scrut(pm), ...acc])
  }
}

# issue #415: arm collector for the 1-arg case-block. Mirrors
# `parse_match_arms` but expects each arm to be led by `case`. Stops
# at `}`. Errors point at the offending token when neither `case`
# nor `}` appears next.
fn parse_case_arms(p: Parser, acc: [Arm], scrut: Expr, t: Token) : PExpr / Console {

  let p0 = p_skip_newlines_and_semis(p)
  if p_at(p0, TkRbrace) {
    if list_is_empty(acc) {
      err_e(p_error_here(p0, "case-block must have at least one `case` arm"))
    } else {
      ok_e(p_advance(p0), mk_expr(EMatch(scrut, list_reverse(acc)), t.line, t.col))
    }
  } else if not p_at(p0, TkCase) {
    err_e(p_error_here(p0, "case-block must contain only `case` arms; mix with stmt-block by extracting a helper or using `= match { ... }`"))
  } else {
    let p1 = p_skip_newlines(p_advance(p0))
    let ra = parse_case_arm_tail(p1)
    match ra.r {
      None -> err_e(ra.p)
      Some(arm) -> parse_case_arms(ra.p, [arm, ...acc], scrut, t)
    }
  }
}

# issue #415: parse the tail of a `case` arm — pattern, optional
# `when` guard, `->`, body. The leading `case` keyword has already
# been consumed by the caller.
fn parse_case_arm_tail(p: Parser) : PArm / Console {

  let rp = parse_pattern(p)
  match rp.r {
    None -> err_a(rp.p)
    Some(pat) -> {
      let p1 = p_skip_newlines(rp.p)
      let guard_opt_r =
        if p_at(p1, TkWhen) {
          let prev_atl = p1.allow_trailing_lambda
          let pg = p_with_trailing_lambda(p_advance(p1), false)
          let rg = parse_expr(pg)
          let rg_p = p_with_trailing_lambda(rg.p, prev_atl)
          match rg.r {
            None -> PExpr { p: rg_p, r: None }
            Some(g) -> PExpr { p: rg_p, r: Some(g) }
          }
        } else {
          PExpr { p: p1, r: None }
        }
      match guard_opt_r.r {
        None -> if guard_opt_r.p.had_error { err_a(guard_opt_r.p) } else {
          parse_arm_body(guard_opt_r.p, pat, None)
        }
        Some(_) -> parse_arm_body(guard_opt_r.p, pat, guard_opt_r.r)
      }
    }
  }
}

# issue #415: arm collector for N-arg case-block. Mirrors
# `parse_multi_match_arms`. Each arm is `case p1, ..., pN (when g)? -> body`.
fn parse_case_multi_arms(p: Parser, acc: [MArm], scruts: [Expr], n: Int, t: Token) : PExpr / Console {

  let p0 = p_skip_newlines_and_semis(p)
  if p_at(p0, TkRbrace) {
    if list_is_empty(acc) {
      err_e(p_error_here(p0, "case-block must have at least one `case` arm"))
    } else {
      let p1 = p_advance(p0)
      let arms_in_order = list_reverse(acc)
      let desugared = desugar_multi_match(scruts, arms_in_order, t.line, t.col)
      ok_e(p1, desugared)
    }
  } else if not p_at(p0, TkCase) {
    err_e(p_error_here(p0, "case-block must contain only `case` arms; mix with stmt-block by extracting a helper or using `= match { ... }`"))
  } else {
    let p1 = p_skip_newlines(p_advance(p0))
    let ra = parse_case_multi_arm(p1, n)
    match ra.r {
      None -> err_e(ra.p)
      Some(arm) -> parse_case_multi_arms(ra.p, [arm, ...acc], scruts, n, t)
    }
  }
}

# issue #415: parse `pat1, ..., patN (when guard)? -> body` after the
# leading `case` has been consumed. Mirrors `parse_multi_arm` but
# uses `when` instead of `if` for the guard.
fn parse_case_multi_arm(p: Parser, n: Int) : PMArm / Console {

  let r_pats = parse_n_patterns(p, n, [])
  match r_pats.r {
    None -> err_marm(r_pats.p)
    Some(pats) -> {
      let p1 = p_skip_newlines(r_pats.p)
      let guard_opt_r =
        if p_at(p1, TkWhen) {
          let prev_atl = p1.allow_trailing_lambda
          let pg = p_with_trailing_lambda(p_advance(p1), false)
          let rg = parse_expr(pg)
          let rg_p = p_with_trailing_lambda(rg.p, prev_atl)
          match rg.r {
            None -> PExpr { p: rg_p, r: None }
            Some(g) -> PExpr { p: rg_p, r: Some(g) }
          }
        } else {
          PExpr { p: p1, r: None }
        }
      let p2 = p_skip_newlines(guard_opt_r.p)
      if not p_at(p2, TkArrow) {
        err_marm(p_error_here(p2, "expected `->` in case-arm"))
      } else {
        let p3 = p_skip_newlines(p_advance(p2))
        let rb = parse_expr(p3)
        match rb.r {
          None -> err_marm(rb.p)
          Some(body) -> ok_marm(rb.p, MArm(pats, guard_opt_r.r, body))
        }
      }
    }
  }
}

# m12.6.x #5(a): result of attempting to parse the optional
# `[<refinement_pure>]` attribute after a fn signature / row. When
# the bracket is absent (or doesn't open with `<`), `is_pure` stays
# false and the parser is returned unchanged (peek-2 lookahead so a
# bare `[` doesn't trigger).
type PureAttr = { p: Parser, is_pure: Bool }

fn parse_optional_pure_attribute(p: Parser) : PureAttr / Console {

  if not p_at(p, TkLbracket) { PureAttr { p: p, is_pure: false } }
  else if not tk_is(p_peek1(p).kind, TkLt) {
    PureAttr { p: p, is_pure: false }
  } else {
    let p1 = p_skip_newlines(p_advance(p))
    let p2 = p_skip_newlines(p_advance(p1))
    let id = p_peek(p2)
    if not tk_is(id.kind, TkIdent) {
      PureAttr {
        p: p_error(p2, id, "expected attribute name after `[<`"),
        is_pure: false
      }
    } else {
      let attr_name = tok_source(p2.src, id)
      let p3 = p_skip_newlines(p_advance(p2))
      if not p_at(p3, TkGt) {
        PureAttr {
          p: p_error_here(p3, "expected `>` to close fn attribute"),
          is_pure: false
        }
      } else {
        let p4 = p_skip_newlines(p_advance(p3))
        if not p_at(p4, TkRbracket) {
          PureAttr {
            p: p_error_here(p4, "expected `]` to close fn attribute"),
            is_pure: false
          }
        } else {
          let p5 = p_advance(p4)
          if attr_name == "refinement_pure" {
            PureAttr { p: p5, is_pure: true }
          } else {
            PureAttr {
              p: p_error(p5, id, concat_all([
                "unknown fn attribute `", attr_name,
                "` — only `refinement_pure` is recognised in m12.6.x v1"
              ])),
              is_pure: false
            }
          }
        }
      }
    }
  }
}

fn maybe_wrap_pure(is_pure: Bool, dfn: Decl, line: Int, col: Int) : Decl =
  if is_pure { DAttribPure(dfn, line, col) } else { dfn }

# m12.6.b: contract-clause result. Carries the parser advanced past
# all `requires` / `ensures` clauses plus the accumulated predicates.
# Both lists are stored in source order (parse_contracts_loop reverses
# the accumulators before returning).
type Contracts = { p: Parser, reqs: [Expr], enss: [Expr] }

# m12.6.b: parse zero-or-more `requires <expr>` / `ensures <expr>`
# clauses, in any interleaving, until the next token is `=` or `{`
# (the start of the body) or anything else. Each clause's predicate
# is parsed as a single Expr; parse_expr stops at TkRequires /
# TkEnsures / TkEq / TkLbrace because none are operators.
fn parse_contracts_loop(p: Parser, reqs: [Expr], enss: [Expr]) : Contracts / Console {

  let p0 = p_skip_newlines(p)
  if p_at(p0, TkRequires) {
    let kw = p_peek(p0)
    let pe = parse_expr(p_skip_newlines(p_advance(p0)))
    match pe.r {
      None -> Contracts { p: pe.p, reqs: list_reverse(reqs), enss: list_reverse(enss) }
      Some(pred) -> {
        let p1 = check_pred_not_false(pe.p, pred, "requires", kw)
        # m12.6.x #5(a) v2: pure-call check moved to a post-parse pass
        # so it can consult the program-wide list of fns marked with
        # `[<refinement_pure>]`. See validate_contract_predicates_decls.
        parse_contracts_loop(p1, [pred, ...reqs], enss)
      }
    }
  } else if p_at(p0, TkEnsures) {
    let kw = p_peek(p0)
    let pe = parse_expr(p_skip_newlines(p_advance(p0)))
    match pe.r {
      None -> Contracts { p: pe.p, reqs: list_reverse(reqs), enss: list_reverse(enss) }
      Some(pred) -> {
        let p1 = check_pred_not_false(pe.p, pred, "ensures", kw)
        parse_contracts_loop(p1, reqs, [pred, ...enss])
      }
    }
  } else {
    Contracts { p: p0, reqs: list_reverse(reqs), enss: list_reverse(enss) }
  }
}

# m12.6.x #5 (v1): enforce that a contract predicate calls only into
# the closed refinement-pure prelude set + the standard subset
# operators. Walks the Expr tree once; the first illegal call lands
# as a parse-time error pointing at the offending span.
#
# What is allowed:
#  - Literals (Int, Real, Bool, Char, String, EUnit)
#  - EVar (parameter / `self` / `result` / outer locals — the typer
#    later checks the binding actually exists in scope)
#  - EField, EIndex (read-only access)
#  - EBinop, EUnop (the standard arithmetic / boolean operators)
#  - EIf (allowed for short-circuiting)
#  - ECall whose callee is one of the closed pure prelude names
#  - EBlock (allowed only when every stmt + tail is pure — m12.6.x
#    leaves this conservative for now and rejects EBlock outright;
#    the spec does not show predicates with let bindings).
#
# Pre-existing limitation: this pass does not parse the
# `[<refinement-pure>]` attribute on user fn signatures, so user fns
# that *would* be marked pure are rejected today. The closed
# prelude list below is the entirety of the allowed call surface.
fn refinement_pure_names() : [String] = [
  "is_some", "is_none", "is_finite", "is_nan",
  "string_length", "list_length",
  # m12.6.x #7: `matches` is the refinement-side regex predicate;
  # `regex_compile_or_panic` is the runtime carrier the parser
  # desugars `~r/.../` sigils into. Both are predicate-pure: the
  # compile is deterministic in the pattern, and a parse-failure
  # panics rather than returning, so the refinement either evaluates
  # or aborts the program — never observes a half-state.
  "matches", "regex_compile_or_panic"
]

# Walk an Expr looking for the first ECall whose callee is an EVar
# not in `pure_names`. Returns the offending name, or None.
fn find_impure_call(e: Expr, pure_names: [String]) : Option[String] {
  match e.kind {
    EInt(_) -> None
    EReal(_) -> None
    EBool(_) -> None
    EChar(_) -> None
    EStr(_, _) -> None
    EUnit -> None
    EVar(_) -> None
    EField(b, _) -> find_impure_call(b, pure_names)
    EIndex(a, b) -> match find_impure_call(a, pure_names) {
      Some(n) -> Some(n)
      None -> find_impure_call(b, pure_names)
    }
    EBinop(_, a, b) -> match find_impure_call(a, pure_names) {
      Some(n) -> Some(n)
      None -> find_impure_call(b, pure_names)
    }
    EUnop(_, x) -> find_impure_call(x, pure_names)
    EIf(c, t_, eo) -> match find_impure_call(c, pure_names) {
      Some(n) -> Some(n)
      None -> match find_impure_call(t_, pure_names) {
        Some(n) -> Some(n)
        None -> match eo {
          Some(eb) -> find_impure_call(eb, pure_names)
          None -> None
        }
      }
    }
    ECall(callee, args_) -> {
      let callee_check = match callee.kind {
        EVar(name) ->
          if list_has(pure_names, name) { None }
          else { Some(name) }
        _ -> Some("<expression>")
      }
      match callee_check {
        Some(n) -> Some(n)
        None -> find_impure_call_args(args_, pure_names)
      }
    }
    _ -> Some("<unsupported>")
  }
}

fn find_impure_call_args(args_: [Expr], pure_names: [String]) : Option[String] {
  match args_ {
    [] -> None
    [a, ...rest] -> match find_impure_call(a, pure_names) {
      Some(n) -> Some(n)
      None -> find_impure_call_args(rest, pure_names)
    }
  }
}

# m12.6.x #6: if a contract predicate folds to `false` at parse time,
# emit a compile-time error pointing at the clause keyword. The
# contract list still accumulates the predicate so downstream stmts
# parse cleanly; the parser's `had_error` flag aborts code emission
# at the end of the file, the same path as any other parse error.
fn check_pred_not_false(p: Parser, pred: Expr, kind: String, kw: Token) : Parser / Console {

  match try_eval_pred(pred) {
    Some(false) -> p_error(p, kw, concat_all([
      "`", kind, "` predicate is statically `false` — the contract ",
      "would always panic. Remove the clause or fix the predicate."
    ]))
    _ -> p
  }
}

# m12.6.b: desugar contracts into asserts inside the body. The
# semantics are:
#   requires P  -> assert P at function entry
#   ensures  Q  -> assert Q after binding `result` to the body's value
# The combined shape is a single EBlock:
#   { assert P1; ...; let result = body; assert Q1; ...; result }
# The block's final expression is `result` so the function still
# returns the body's value. When both lists are empty, the body is
# returned unchanged so functions without contracts cost nothing.
fn wrap_with_contracts(body: Expr, reqs: [Expr], enss: [Expr],
                       params: [Param], fn_name: String,
                       line: Int, col: Int) : Expr {
  if reqs == [] and enss == [] { body } else {
    let pp = collect_param_preds(params, [])
    let req_stmts = preds_to_asserts(reqs, [], "requires", pp, fn_name)
    if enss == [] {
      if req_stmts == [] { body }
      else { mk_expr(EBlock(req_stmts, Some(body)), line, col) }
    } else {
      # m12.6.c: bind `result` to the body's value so `ensures`
      # predicates can reference it. The shape is
      #   { req_asserts; let result = body; ens_asserts; result }
      let bind_pat = mk_pat(PBind("result"), line, col)
      let bind = SLet(bind_pat, None, body)
      let ens_stmts = preds_to_asserts(enss, [], "ensures", pp, fn_name)
      if req_stmts == [] and ens_stmts == [] { body }
      else {
        let res_var = mk_expr(EVar("result"), line, col)
        let stmts = list_append(req_stmts, [bind, ...ens_stmts])
        mk_expr(EBlock(stmts, Some(res_var)), line, col)
      }
    }
  }
}

fn preds_to_asserts(preds: [Expr], acc: [Stmt], kind: String,
                     param_preds: [ParamPred], fn_name: String) : [Stmt] {
  match preds {
    [] -> list_reverse(acc)
    # m12.6.d: drop trivially-true predicates at parse time.
    # m12.6.x #2: drop a predicate that is structurally identical to
    # some param's refinement — the type-system already guarantees
    # it. (Caller-side narrowing into the refined type is the proof
    # obligation; the callee body inherits the refinement for free.)
    # m12.6.x #8 v2 (#86): build a structured message containing the
    # clause kind, the function name, the rendered predicate text, and
    # the decl-site line/col. The leading `"requires violated` /
    # `"ensures violated` prefix is preserved so contract_assert_kind
    # / extract_requires_asserts (which key off the prefix) keep
    # working. Call-site span and runtime value formatting are
    # follow-up (see docs/refinements-and-contracts.md v2 sidebar).
    [p, ...rest] -> {
      if pred_entailed_by_params(p, param_preds) {
        preds_to_asserts(rest, acc, kind, param_preds, fn_name)
      } else { match try_eval_pred(p) {
        Some(true) -> preds_to_asserts(rest, acc, kind, param_preds, fn_name)
        _          -> {
          let msg_span = build_violation_msg_span(kind, fn_name, p)
          let msg = mk_expr(EStr(msg_span, false), p.line, p.col)
          preds_to_asserts(rest, [SAssert(p, Some(msg)), ...acc], kind, param_preds, fn_name)
        }
      } }
    }
  }
}

# m12.6.x #8 v2 (#86): assemble the multi-line panic message for a
# contract violation. The result is the *raw* EStr span (including
# surrounding double quotes and backslash-escaped newlines) so the
# emitter can pass it through as a C string literal unchanged. Format:
#
#   "requires violated in `<fn>`\nrequired: <pred>\ndeclared at line N, col C"
#
# When printed by `kai_prelude_panic` the `\n` escapes render as real
# line breaks, producing a multi-line diagnostic. The leading
# `"requires violated` / `"ensures violated` prefix is kept so the
# detectors at extract_requires_asserts / contract_assert_kind still
# classify the assert as contract-derived.
fn build_violation_msg_span(kind: String, fn_name: String, p: Expr) : String {
  let pred_text = escape_str_body_for_c(expr_show_pred(p))
  let fn_text = escape_str_body_for_c(fn_name)
  concat_all([
    "\"", kind, " violated in `", fn_text, "`",
    "\\nrequired: ", pred_text,
    "\\ndeclared at line ", int_to_string(p.line),
    ", col ", int_to_string(p.col), "\""
  ])
}

# m12.6.x #2: collect every refinement predicate that appears on a
# fn parameter's TypeExpr, paired with the owning parameter's name.
# Used by preds_to_asserts to omit a `requires` clause that just
# restates a param's refinement. The owning name lets the regex
# subsumption check (m12.6.x #7b) tie a param-side `self` reference
# back to the user-written param name on the requires side, and lets
# Issue #83's alpha + operator + interval entailment rewrite `self`
# to the param name on the fly before comparing canonical forms.
type ParamPred = PPair(String, Expr)
#                       ^pname  ^pred ast

fn collect_param_preds(params: [Param], acc: [ParamPred]) : [ParamPred] {
  match params {
    [] -> list_reverse(acc)
    [p, ...rest] -> match p.ptype {
      Some(t) -> match t.tkind {
        TyRefine(_, pred) -> collect_param_preds(rest, [PPair(p.pname, pred), ...acc])
        _ -> collect_param_preds(rest, acc)
      }
      None -> collect_param_preds(rest, acc)
    }
  }
}

# Issue #83: a `requires P` predicate is entailed by a refined-param
# predicate when any of the following discharges fires:
#   - bare structural equality (legacy m12.6.x #2 v1 case);
#   - regex subsumption (m12.6.x #7b — closes #157);
#   - canonical comparison + `self ↦ pname` substitution
#     (Issue #83 sub-cases 1 alpha + 2 operator);
#   - interval lattice (Issue #83, e.g. `requires x > 0` discharged
#     by `Int where x >= 1`).
# Sound by construction: every arm only returns `true` when the
# requires-side predicate is provably implied by the param-side one.
# When in doubt the runtime assert is preserved.
fn pred_entailed_by_params(pred: Expr, param_preds: [ParamPred]) : Bool {
  match param_preds {
    [] -> false
    [pp, ...rest] -> match pp {
      PPair(pname, pp_expr) -> {
        if expr_struct_eq(pred, pp_expr) { true }
        else if regex_pred_subsumed(pred, pname, pp_expr) { true }
        else {
          let canon_req = pred_canon(pred)
          let canon_ref = pred_canon(subst_self(pp_expr, pname))
          if expr_struct_eq(canon_req, canon_ref) { true }
          else if pred_entailed_by_refinement(canon_req, pname, canon_ref) { true }
          else { pred_entailed_by_params(pred, rest) }
        }
      }
    }
  }
}

# m12.6.x #7b — regex predicate subsumption (closes #157).
#
# When the requires-clause's `pred` is `matches(self, ~r/loose/)` and
# some param refinement `pp` is `matches(self, ~r/strict/)`, the
# requires assert is redundant iff L(strict) ⊆ L(loose). The full DFA-
# difference algorithm is decidable for the v1 regex subset (no
# backrefs, no lookaround); a future extension can lift the
# stdlib `regex_compile` engine into the typer for general
# containment.
#
# v1 ships a structural shape matcher: each side must match the
# anchored grammar `^ <atom> <quant>? $`, where atom is a single
# character class (or built-in escape) and quant is one of `+`, `*`,
# `?`, or `{n,m}`. Both sides must use the same quant. Containment
# then reduces to ASCII charset containment over 0..127. Anything
# outside this shape — alternation, concat, groups, anchored prefix
# `^acc_`, etc. — bails to false (the runtime assert is preserved,
# which is sound — we just don't drop it).
#
# The bound is the ~256-element shape (one ASCII charset per side);
# DFAs in the general algorithm are bounded at 1024 states. Since the
# structural matcher does no NFA->DFA construction, the bound never
# fires in v1 — but the entry point keeps the same fail-closed
# contract: `false` (= keep the assert) when in doubt.
fn regex_pred_subsumed(pred: Expr, pname: String, param_pred: Expr) : Bool {
  # Requires-side: the user-written receiver must equal the parameter
  # name. Param-side: the receiver is the parser-inserted `self`.
  match pred_regex_pattern_named(pred, pname) {
    None -> false
    Some(loose) -> match pred_regex_pattern_named(param_pred, "self") {
      None -> false
      Some(strict) -> regex_pattern_contains(loose, strict)
    }
  }
}


# Recognise an Expr of the shape `matches(<recv>, regex_compile_or_panic
# ("..."))` where `<recv>` is the bare ident `expected_recv`. Returns
# the raw pattern (sigil-body bytes) on a hit, None otherwise. The
# explicit receiver name keeps the regex-subsumption path sound when a
# function has multiple refined parameters: a param-side `self`
# refinement on `x` only entails a requires-side `matches(x, …)`,
# never `matches(y, …)`.
fn pred_regex_pattern_named(e: Expr, expected_recv: String) : Option[String] {
  match e.kind {
    ECall(callee, cargs) -> match callee.kind {
      EVar(name) ->
        if name == "matches" {
          match cargs {
            [recv, re] -> match recv.kind {
              EVar(rn) -> if rn == expected_recv { extract_regex_literal(re) } else { None }
              _ -> None
            }
            _ -> None
          }
        } else { None }
      _ -> None
    }
    _ -> None
  }
}

# `regex_compile_or_panic("...")` over a literal `EStr` pattern is the
# only shape the sigil desugar emits. Reach inside, strip the outer
# `"..."` quotes, and decode the two backslash escapes the sigil
# parser introduces (`\\` -> `\`, `\"` -> `"`).
fn extract_regex_literal(re: Expr) : Option[String] {
  match re.kind {
    ECall(callee, cargs) -> match callee.kind {
      EVar(name) ->
        if name == "regex_compile_or_panic" {
          match cargs {
            [arg0] -> match arg0.kind {
              EStr(span, false) -> Some(decode_regex_str_span(span))
              _ -> None
            }
            _ -> None
          }
        } else { None }
      _ -> None
    }
    _ -> None
  }
}

# Strip leading/trailing `"` and decode `\\`/`\"` back to literal `\`
# and `"`. Mirrors the encoding done by `regex_pattern_to_kai_str_body`
# in the sigil parser. Returns the empty string when the span is
# malformed (which `EStr(_, false)` never is in practice — the
# parser would have rejected it).
fn decode_regex_str_span(span: String) : String {
  let n = string_length(span)
  if n < 2 { "" } else { decode_regex_loop(span, 1, n - 1, "") }
}

fn decode_regex_loop(span: String, i: Int, end: Int, acc: String) : String {
  if i >= end { acc } else {
    let c = char_at_or_zero(span, i)
    if c == '\\' and i + 1 < end {
      let c2 = char_at_or_zero(span, i + 1)
      decode_regex_loop(span, i + 2, end, string_concat(acc, "#{c2}"))
    } else {
      decode_regex_loop(span, i + 1, end, string_concat(acc, "#{c}"))
    }
  }
}

# Top-level containment on raw pattern strings. Returns true iff
# every string accepted by `strict` is also accepted by `loose`.
# Conservative: returns false when either side falls outside the
# anchored-class shape the typer recognises in v1.
fn regex_pattern_contains(loose: String, strict: String) : Bool {
  match parse_anchored_class(loose) {
    None -> false
    Some(la) -> match parse_anchored_class(strict) {
      None -> false
      Some(sa) -> ac_contains(la, sa)
    }
  }
}

# Anchored-class shape: `^ <class> <quant>? $`. The class is a
# 128-bool ASCII mask (string of '0'/'1'). The quant is one of "+",
# "*", "?", "1" (no quant — must match exactly one char), or a
# `{n,m}` rendered as "n,m" (or "n," for unbounded). For v1 the
# matcher only proves containment when both sides share an
# *identical* quant string — strictly the same shape.
type AnchoredClass = RxAC(String, String)
#                       ^mask  ^quant

fn parse_anchored_class(pat: String) : Option[AnchoredClass] {
  let n = string_length(pat)
  # Require leading `^` and trailing `$`.
  if n < 2 { None }
  else if char_at_or_zero(pat, 0) != '^' { None }
  else if char_at_or_zero(pat, n - 1) != '$' { None }
  else {
    # Parse the class atom starting at position 1.
    match parse_class_atom(pat, 1, n - 1) {
      None -> None
      Some(atom) -> match atom {
        # PCA(mask, after) = mask, position after the atom
        PCA(mask, after) -> {
          let q = parse_quant(pat, after, n - 1)
          match q {
            QErr -> None
            QShape(quant, after_q) ->
              if after_q == n - 1 { Some(RxAC(mask, quant)) }
              else { None }
          }
        }
      }
    }
  }
}

# Parse a single class atom: either `[...]` (with optional `^`
# negation), or one of the built-in escapes `\d \w \s \D \W \S`, or a
# bare ASCII printable that is not a regex metachar. Returns the
# resulting 128-byte mask and the byte offset just past the atom.
type ParsedClassAtom = PCA(String, Int)

fn parse_class_atom(pat: String, i: Int, end: Int) : Option[ParsedClassAtom] {
  if i >= end { None } else {
    let c = char_at_or_zero(pat, i)
    if c == '[' { parse_bracket_class(pat, i + 1, end) }
    else if c == '\\' { parse_escape_atom(pat, i + 1, end) }
    else if c == '.' { Some(PCA(mask_dot(), i + 1)) }
    else if is_regex_meta(c) { None }
    else { Some(PCA(mask_single(c), i + 1)) }
  }
}

fn is_regex_meta(c: Char) : Bool =
  c == '^' or c == '$' or c == '|' or c == '(' or c == ')' or
  c == '[' or c == ']' or c == '{' or c == '}' or
  c == '*' or c == '+' or c == '?' or c == '.' or c == '\\'

# Parse the body of `[...]`, beginning at position `i` (just past the
# `[`). Returns the assembled mask and the position just past the
# closing `]`. Bails on malformed classes or anything beyond
# `[abc]` / `[^abc]` / `[a-z0-9]` shapes.
fn parse_bracket_class(pat: String, i: Int, end: Int) : Option[ParsedClassAtom] {
  let neg = if i < end and char_at_or_zero(pat, i) == '^' { true } else { false }
  let i1 = if neg { i + 1 } else { i }
  parse_bracket_body(pat, i1, end, mask_empty(), neg)
}

fn parse_bracket_body(pat: String, i: Int, end: Int, acc: String, neg: Bool) : Option[ParsedClassAtom] {
  if i >= end { None } else {
    let c = char_at_or_zero(pat, i)
    if c == ']' {
      let final_mask = if neg { mask_invert(acc) } else { acc }
      Some(PCA(final_mask, i + 1))
    } else {
      match parse_bracket_item(pat, i, end) {
        None -> None
        Some(item) -> match item {
          BItem(item_mask, after) ->
            parse_bracket_body(pat, after, end, mask_or(acc, item_mask), neg)
        }
      }
    }
  }
}

# A single item inside `[...]`: a char, an escape, or a range `a-z`.
type BracketItem = BItem(String, Int)

fn parse_bracket_item(pat: String, i: Int, end: Int) : Option[BracketItem] {
  if i >= end { None } else {
    let c = char_at_or_zero(pat, i)
    let first = if c == '\\' {
      match parse_class_escape(pat, i + 1, end) {
        None -> None
        Some(esc) -> Some(esc)
      }
    } else if c == ']' or c == '[' { None }
    else { Some(BFirst(mask_single(c), i + 1, c)) }
    match first {
      None -> None
      Some(f) -> match f {
        BFirst(m1, after1, lo) ->
          if after1 < end and char_at_or_zero(pat, after1) == '-' and
             after1 + 1 < end and char_at_or_zero(pat, after1 + 1) != ']' {
            let c2 = char_at_or_zero(pat, after1 + 1)
            if c2 == '\\' { None }
            else if char_to_int(c2) < char_to_int(lo) { None }
            else { Some(BItem(mask_range(lo, c2), after1 + 2)) }
          } else { Some(BItem(m1, after1)) }
        BClass(m1, after1) -> Some(BItem(m1, after1))
      }
    }
  }
}

# Wrapper for a parsed first-token inside a class. Either a single
# char (which may extend into a range) or a `\d`/`\w`/`\s` class
# (which never extends). The `Char` field is meaningful only for
# `BFirst` and is ignored for `BClass`.
type BracketFirst
  = BFirst(String, Int, Char)
  | BClass(String, Int)

fn parse_class_escape(pat: String, i: Int, end: Int) : Option[BracketFirst] {
  if i >= end { None } else {
    let c = char_at_or_zero(pat, i)
    match c {
      'd' -> Some(BClass(mask_digit(), i + 1))
      'D' -> Some(BClass(mask_invert(mask_digit()), i + 1))
      'w' -> Some(BClass(mask_word(), i + 1))
      'W' -> Some(BClass(mask_invert(mask_word()), i + 1))
      's' -> Some(BClass(mask_space(), i + 1))
      'S' -> Some(BClass(mask_invert(mask_space()), i + 1))
      'n' -> Some(BFirst(mask_single('\n'), i + 1, '\n'))
      't' -> Some(BFirst(mask_single('\t'), i + 1, '\t'))
      'r' -> Some(BFirst(mask_single('\r'), i + 1, '\r'))
      _ -> Some(BFirst(mask_single(c), i + 1, c))
    }
  }
}

# Outside a class: `\d \w \s` etc. produce a class atom with no
# follow-on range. Other escape chars produce a single-char atom.
fn parse_escape_atom(pat: String, i: Int, end: Int) : Option[ParsedClassAtom] {
  if i >= end { None } else {
    let c = char_at_or_zero(pat, i)
    match c {
      'd' -> Some(PCA(mask_digit(), i + 1))
      'D' -> Some(PCA(mask_invert(mask_digit()), i + 1))
      'w' -> Some(PCA(mask_word(), i + 1))
      'W' -> Some(PCA(mask_invert(mask_word()), i + 1))
      's' -> Some(PCA(mask_space(), i + 1))
      'S' -> Some(PCA(mask_invert(mask_space()), i + 1))
      'n' -> Some(PCA(mask_single('\n'), i + 1))
      't' -> Some(PCA(mask_single('\t'), i + 1))
      'r' -> Some(PCA(mask_single('\r'), i + 1))
      _ -> Some(PCA(mask_single(c), i + 1))
    }
  }
}

# Parse an optional quantifier just past a class atom. Returns
# QErr on a malformed `{n,m}`, QShape("1", i) when no quant is
# present (the atom matches exactly one occurrence), and
# QShape("+"|"*"|"?"|"n,m"|"n,", i + width) for the supported forms.
type QuantParse
  = QShape(String, Int)
  | QErr

fn parse_quant(pat: String, i: Int, end: Int) : QuantParse {
  if i >= end { QShape("1", i) } else {
    let c = char_at_or_zero(pat, i)
    match c {
      '+' -> QShape("+", i + 1)
      '*' -> QShape("*", i + 1)
      '?' -> QShape("?", i + 1)
      '{' -> parse_repeat_quant(pat, i + 1, end)
      _ -> QShape("1", i)
    }
  }
}

fn parse_repeat_quant(pat: String, i: Int, end: Int) : QuantParse {
  match parse_pat_int(pat, i, end) {
    None -> QErr
    Some(lo_p) -> match lo_p {
      IntParse(lo, after_lo) ->
        if after_lo >= end { QErr } else {
          let c = char_at_or_zero(pat, after_lo)
          match c {
            '}' -> QShape(concat_all([int_to_string(lo), ",", int_to_string(lo)]), after_lo + 1)
            ',' -> {
              if after_lo + 1 < end and char_at_or_zero(pat, after_lo + 1) == '}' {
                QShape(concat_all([int_to_string(lo), ","]), after_lo + 2)
              } else { match parse_pat_int(pat, after_lo + 1, end) {
                None -> QErr
                Some(hi_p) -> match hi_p {
                  IntParse(hi, after_hi) ->
                    if hi < lo { QErr }
                    else if after_hi >= end { QErr }
                    else if char_at_or_zero(pat, after_hi) != '}' { QErr }
                    else { QShape(concat_all([int_to_string(lo), ",", int_to_string(hi)]), after_hi + 1) }
                }
              } }
            }
            _ -> QErr
          }
        }
    }
  }
}

type IntParse = IntParse(Int, Int)

fn parse_pat_int(pat: String, i: Int, end: Int) : Option[IntParse] {
  parse_pat_int_loop(pat, i, end, 0, false)
}

fn parse_pat_int_loop(pat: String, i: Int, end: Int, acc: Int, any: Bool) : Option[IntParse] {
  if i >= end {
    if any { Some(IntParse(acc, i)) } else { None }
  } else {
    let c = char_at_or_zero(pat, i)
    if ch_is_digit(c) {
      parse_pat_int_loop(pat, i + 1, end, acc * 10 + char_to_int(c) - char_to_int('0'), true)
    } else {
      if any { Some(IntParse(acc, i)) } else { None }
    }
  }
}

# ASCII charset masks. Stored as a string of length 128 — '1' at
# position k means code point k is in the set.
fn mask_empty() : String = mask_const_loop(0, '0', "")
fn mask_full() : String = mask_const_loop(0, '1', "")

fn mask_const_loop(i: Int, ch: Char, acc: String) : String {
  if i >= 128 { acc }
  else { mask_const_loop(i + 1, ch, string_concat(acc, "#{ch}")) }
}

fn mask_single(c: Char) : String {
  let cp = char_to_int(c)
  if cp < 0 or cp >= 128 { mask_empty() }
  else { mask_set_bit(mask_empty(), cp) }
}

fn mask_range(lo: Char, hi: Char) : String {
  let lo_i = char_to_int(lo)
  let hi_i = char_to_int(hi)
  mask_range_loop(mask_empty(), lo_i, hi_i)
}

fn mask_range_loop(acc: String, i: Int, hi: Int) : String {
  if i > hi or i >= 128 { acc }
  else if i < 0 { mask_range_loop(acc, i + 1, hi) }
  else { mask_range_loop(mask_set_bit(acc, i), i + 1, hi) }
}

fn mask_set_bit(m: String, pos: Int) : String {
  if pos < 0 or pos >= 128 { m }
  else {
    let prefix = string_slice(m, 0, pos)
    let suffix = string_slice(m, pos + 1, 128 - pos - 1)
    concat_all([prefix, "1", suffix])
  }
}

fn mask_or(a: String, b: String) : String = mask_or_loop(a, b, 0, "")

fn mask_or_loop(a: String, b: String, i: Int, acc: String) : String {
  if i >= 128 { acc }
  else {
    let ca = char_at_or_zero(a, i)
    let cb = char_at_or_zero(b, i)
    let merged = if ca == '1' or cb == '1' { '1' } else { '0' }
    mask_or_loop(a, b, i + 1, string_concat(acc, "#{merged}"))
  }
}

fn mask_invert(m: String) : String = mask_invert_loop(m, 0, "")

fn mask_invert_loop(m: String, i: Int, acc: String) : String {
  if i >= 128 { acc }
  else {
    let c = char_at_or_zero(m, i)
    let flipped = if c == '1' { '0' } else { '1' }
    mask_invert_loop(m, i + 1, string_concat(acc, "#{flipped}"))
  }
}

# `[a-z]` ⊆ `[a-z0-9]` iff every '1' in the strict mask is also '1'
# in the loose mask. Linear scan over 128 positions.
fn mask_subset(strict: String, loose: String) : Bool = mask_subset_loop(strict, loose, 0)

fn mask_subset_loop(strict: String, loose: String, i: Int) : Bool {
  if i >= 128 { true }
  else {
    let s = char_at_or_zero(strict, i)
    let l = char_at_or_zero(loose, i)
    if s == '1' and l != '1' { false }
    else { mask_subset_loop(strict, loose, i + 1) }
  }
}

# `\d` -> [0-9].
fn mask_digit() : String = mask_range('0', '9')

# `\w` -> [A-Za-z0-9_].
fn mask_word() : String =
  mask_set_bit(mask_or(mask_or(mask_range('A', 'Z'), mask_range('a', 'z')),
                       mask_range('0', '9')),
               char_to_int('_'))

# `\s` -> [ \t\n\r\v\f]. We only mask the ASCII ones the v1 engine
# actually recognises (`rx_space_ranges` in stdlib/regexp.kai).
fn mask_space() : String =
  mask_set_bit(mask_set_bit(mask_set_bit(mask_set_bit(mask_empty(),
                                                       char_to_int(' ')),
                                          char_to_int('\t')),
                            char_to_int('\n')),
               char_to_int('\r'))

# `.` matches any non-newline ASCII char (RE2 default semantics).
fn mask_dot() : String = mask_invert(mask_single('\n'))

# Containment of two parsed AnchoredClass shapes. v1: identical
# quantifier strings + strict charset ⊆ loose charset is the
# only path that returns true. Anything else is conservative.
fn ac_contains(loose: AnchoredClass, strict: AnchoredClass) : Bool {
  match loose {
    RxAC(loose_mask, loose_q) -> match strict {
      RxAC(strict_mask, strict_q) ->
        if loose_q != strict_q { false }
        else { mask_subset(strict_mask, loose_mask) }
    }
  }
}

# Substitute every free `self` in `e` with `EVar(name)`. The
# refinement grammar only uses `self` as a stand-in for the value
# being refined, so we do not chase shadowing — `self` is never
# rebound by `let` / lambda / match inside a predicate.
fn subst_self(e: Expr, name: String) : Expr = match e.kind {
  EVar(s) -> if s == "self" { mk_expr(EVar(name), e.line, e.col) } else { e }
  EBinop(op, a, b) -> mk_expr(EBinop(op, subst_self(a, name), subst_self(b, name)), e.line, e.col)
  EUnop(op, x) -> mk_expr(EUnop(op, subst_self(x, name)), e.line, e.col)
  ECall(f, xs) -> mk_expr(ECall(subst_self(f, name), subst_self_list(xs, name)), e.line, e.col)
  _ -> e
}

fn subst_self_list(es: [Expr], name: String) : [Expr] = match es {
  [] -> []
  [h, ...t] -> [subst_self(h, name), ...subst_self_list(t, name)]
}

# Issue #83 sub-case 2: predicate canonicaliser. Normalises a
# comparison Expr so structurally-different but semantically-equal
# forms compare equal: `0 < x` → `x > 0`, `<=` ↔ flipped `>=`,
# `==` / `!=` argument order normalised lexicographically. Any
# non-comparison Expr is recursed into so a top-level `and` / `or`
# of comparisons is canonicalised arm-wise.
fn pred_canon(e: Expr) : Expr = match e.kind {
  EBinop(op, a, b) -> {
    let ca = pred_canon(a)
    let cb = pred_canon(b)
    if op == "<" { mk_expr(EBinop(">", cb, ca), e.line, e.col) }
    else if op == "<=" { mk_expr(EBinop(">=", cb, ca), e.line, e.col) }
    else if op == "==" or op == "!=" {
      if cmp_lt(ca, cb) { mk_expr(EBinop(op, ca, cb), e.line, e.col) }
      else { mk_expr(EBinop(op, cb, ca), e.line, e.col) }
    }
    else if op == "and" or op == "or" {
      mk_expr(EBinop(op, ca, cb), e.line, e.col)
    }
    else { mk_expr(EBinop(op, ca, cb), e.line, e.col) }
  }
  EUnop(op, x) -> mk_expr(EUnop(op, pred_canon(x)), e.line, e.col)
  _ -> e
}

# Total ordering used by `pred_canon` to break ties on symmetric
# operators. Variables sort by name; literals sort by value. An
# EVar always sorts before an EInt so `x == 0` canonicalises to
# `x == 0` (variable on the LHS), and two variables sort
# alphabetically.
fn cmp_lt(a: Expr, b: Expr) : Bool = match a.kind {
  EVar(an) -> match b.kind {
    EVar(bn) -> string_lt(an, bn)
    _ -> true
  }
  EInt(av) -> match b.kind {
    EVar(_) -> false
    EInt(bv) -> av < bv
    _ -> true
  }
  _ -> false
}

# Issue #83 sub-case 3 partial: when both predicates compare the
# same variable to a literal, use the interval lattice to decide
# entailment. Captures `x > 0` ⊢ `x > -1`, `x >= 1` ⊢ `x > 0`,
# `x != 0` ⊢ `x != 0` (already covered by struct_eq), etc. Both
# inputs are in canonical form (variable on the LHS for ordered
# comparisons).
fn pred_entailed_by_refinement(req: Expr, pname: String, ref_pred: Expr) : Bool {
  match interval_of_pred(ref_pred, pname) {
    None -> false
    Some(iv) -> match check_pred_with_interval(req, pname, iv) {
      Some(true) -> true
      _ -> false
    }
  }
}

# Read a refinement predicate as an interval over `pname`. Only
# the closed shapes we care about — `pname OP literal` — produce
# a non-trivial interval; anything else collapses to `None` so the
# caller falls back to structural matching.
fn interval_of_pred(e: Expr, pname: String) : Option[Interval] = match e.kind {
  EBinop(op, a, b) -> match a.kind {
    EVar(n) -> if n == pname {
      match try_eval_int(b) {
        None -> None
        Some(k) -> interval_from_cmp(op, k)
      }
    } else { None }
    _ -> None
  }
  _ -> None
}

# Turn `x OP k` into the tightest Int interval that satisfies it.
# `!=` is not expressible as a single closed interval; we return
# `None` so the caller defers to structural / call-site checks.
fn interval_from_cmp(op: String, k: Int) : Option[Interval] {
  if op == ">"  { Some(Ival(k + 1, ival_int_max_const())) }
  else if op == ">=" { Some(Ival(k, ival_int_max_const())) }
  else if op == "<"  { Some(Ival(ival_int_min_const(), k - 1)) }
  else if op == "<=" { Some(Ival(ival_int_min_const(), k)) }
  else if op == "==" { Some(Ival(k, k)) }
  else { None }
}

# Saturating sentinels for the interval lattice. The lattice does
# not track unbounded ranges precisely; these constants stand in for
# `+∞` / `-∞` and are large enough that any realistic Int comparison
# folds before reaching them.
fn ival_int_max_const() : Int = 9223372036854775807
fn ival_int_min_const() : Int = 0 - 9223372036854775807 - 1

# Discharge a `requires` predicate against a known interval for the
# refined param. Returns `Some(true)` when the request is provable,
# `Some(false)` if the interval witnesses a contradiction (caller
# treats it as "not entailed" — a `false` requires would have been
# rejected at parse time), and `None` when the predicate's shape
# escapes our analysis.
fn check_pred_with_interval(req: Expr, pname: String, iv: Interval) : Option[Bool] = match req.kind {
  EBinop(op, a, b) -> match a.kind {
    EVar(n) -> if n == pname {
      match try_eval_int(b) {
        None -> None
        Some(k) -> {
          let kiv = Ival(k, k)
          if op == ">"  { ival_gt(iv, kiv) }
          else if op == ">=" { ival_ge(iv, kiv) }
          else if op == "<"  { ival_lt(iv, kiv) }
          else if op == "<=" { ival_le(iv, kiv) }
          else if op == "==" { ival_eq(iv, kiv) }
          else if op == "!=" { ival_ne(iv, kiv) }
          else { None }
        }
      }
    } else { None }
    _ -> None
  }
  _ -> None
}


# Structural equality on Expr, ignoring line/col. Conservative: only
# the shapes the predicate-pure subset can produce are compared in
# detail; everything else falls back to false (so a future feature
# that produces a new ExprKind in predicate position is treated as
# "definitely not equal" rather than wrongly entailed).
fn expr_struct_eq(a: Expr, b: Expr) : Bool {
  match a.kind {
    EInt(av) -> match b.kind { EInt(bv) -> av == bv _ -> false }
    EReal(av) -> match b.kind { EReal(bv) -> av == bv _ -> false }
    EBool(av) -> match b.kind { EBool(bv) -> av == bv _ -> false }
    EChar(av) -> match b.kind { EChar(bv) -> av == bv _ -> false }
    EStr(av, _) -> match b.kind { EStr(bv, _) -> av == bv _ -> false }
    EUnit -> match b.kind { EUnit -> true _ -> false }
    EVar(an) -> match b.kind { EVar(bn) -> an == bn _ -> false }
    EBinop(aop, al, ar) -> match b.kind {
      EBinop(bop, bl, br) -> aop == bop and expr_struct_eq(al, bl) and expr_struct_eq(ar, br)
      _ -> false
    }
    EUnop(aop, ai) -> match b.kind {
      EUnop(bop, bi) -> aop == bop and expr_struct_eq(ai, bi)
      _ -> false
    }
    EField(ab, an) -> match b.kind {
      EField(bb, bn) -> an == bn and expr_struct_eq(ab, bb)
      _ -> false
    }
    ECall(af, aa) -> match b.kind {
      ECall(bf, ba) -> expr_struct_eq(af, bf) and expr_list_struct_eq(aa, ba)
      _ -> false
    }
    _ -> false
  }
}

fn expr_list_struct_eq(a: [Expr], b: [Expr]) : Bool {
  match a {
    [] -> match b { [] -> true _ -> false }
    [ah, ...arest] -> match b {
      [] -> false
      [bh, ...brest] -> expr_struct_eq(ah, bh) and expr_list_struct_eq(arest, brest)
    }
  }
}

# m12.6.d: best-effort static evaluator for refinement / contract
# predicates. Returns Some(b) when the expression is a closed boolean
# expression reducible to a literal, None otherwise. Deliberately
# narrow: no symbolic reasoning, no SMT, no propagation through
# refined arguments — that's the next step (and the cliff the spec
# forbids in v1).
fn try_eval_pred(e: Expr) : Option[Bool] {
  match e.kind {
    EBool(b) -> Some(b)
    EUnop(op, x) -> if op == "not" {
      match try_eval_pred(x) {
        Some(b) -> Some(not b)
        None    -> None
      }
    } else { None }
    EBinop(op, a, b) -> {
      if op == "and" {
        match try_eval_pred(a) {
          Some(false) -> Some(false)
          Some(true)  -> try_eval_pred(b)
          None        -> None
        }
      } else if op == "or" {
        match try_eval_pred(a) {
          Some(true)  -> Some(true)
          Some(false) -> try_eval_pred(b)
          None        -> None
        }
      } else if op == "==" or op == "!=" or op == "<" or op == "<=" or op == ">" or op == ">=" {
        match try_eval_int(a) {
          None    -> None
          Some(ai) -> match try_eval_int(b) {
            None    -> None
            Some(bi) -> Some(eval_int_cmp(op, ai, bi))
          }
        }
      } else { None }
    }
    _ -> None
  }
}

# Evaluate an Int-typed closed expression to a literal value.
fn try_eval_int(e: Expr) : Option[Int] {
  match e.kind {
    EInt(n) -> Some(n)
    EUnop(op, x) -> if op == "-" {
      match try_eval_int(x) {
        Some(v) -> Some(0 - v)
        None    -> None
      }
    } else { None }
    EBinop(op, a, b) -> match try_eval_int(a) {
      None    -> None
      Some(av) -> match try_eval_int(b) {
        None    -> None
        Some(bv) -> eval_int_op(op, av, bv)
      }
    }
    _ -> None
  }
}

fn eval_int_op(op: String, a: Int, b: Int) : Option[Int] {
  if op == "+" { Some(a + b) }
  else if op == "-" { Some(a - b) }
  else if op == "*" { Some(a * b) }
  else if op == "/" { if b == 0 { None } else { Some(a / b) } }
  else if op == "%" { if b == 0 { None } else { Some(a % b) } }
  else { None }
}

fn eval_int_cmp(op: String, a: Int, b: Int) : Bool {
  if op == "==" { a == b }
  else if op == "!=" { a != b }
  else if op == "<" { a < b }
  else if op == "<=" { a <= b }
  else if op == ">" { a > b }
  else if op == ">=" { a >= b }
  else { false }
}

# ====================================================================
# m12.6.x #2 (sub-step 1) — Integer interval lattice
# ====================================================================
#
# Foundation for the post-typing interval-propagation pass. Computes
# bounded `[lo, hi]` ranges for `Int`-typed expressions so a future
# unifier reshape can decide refinement predicates statically. This
# step adds only the lattice; no compiler integration yet (the pass
# that consumes these intervals lands in the next sub-step). Keeping
# the lattice self-contained makes it independently testable and
# avoids touching the typer / Perceus path while those lanes are in
# flight.
#
# Interval values:
#   - `IBot`: empty / unreachable / contradiction. Bottom of the
#             lattice.
#   - `Ival(lo, hi)`: inclusive `[lo, hi]` range, `lo <= hi`. Singletons
#                     (literals) use `lo == hi`.
#   - `ITop`: unbounded; "any Int". Top of the lattice. Saturating
#             arithmetic that overflows the conservative bounds we
#             use elsewhere returns ITop instead of fabricating a
#             made-up range.
#
# Operations are deliberately conservative — overestimating the
# range never makes the analysis unsound (it just leaves more
# refinements to runtime), while underestimating would let us
# reject valid programs at compile time. When in doubt: ITop.

type Interval = ITop | IBot | Ival(Int, Int)

# Locally-scoped Int helpers. stdlib/math/int.kai exports the same
# names but the compiler does not load it as a prelude — these are
# self-contained inline so the lattice is bootstrap-safe.
fn ival_int_min(a: Int, b: Int) : Int = if a < b { a } else { b }
fn ival_int_max(a: Int, b: Int) : Int = if a > b { a } else { b }

fn ival_top() : Interval = ITop

fn ival_bot() : Interval = IBot

fn ival_const(n: Int) : Interval = Ival(n, n)

# Smart constructor: if `lo > hi` the range is empty — return IBot.
# Used by intersect and by the comparison-narrow paths once they
# land.
fn ival_range(lo: Int, hi: Int) : Interval =
  if lo > hi { IBot } else { Ival(lo, hi) }

fn ival_show(iv: Interval) : String = match iv {
  ITop -> "T"
  IBot -> "_|_"
  Ival(lo, hi) ->
    if lo == hi { string_concat_all(["{", int_to_string(lo), "}"]) }
    else { string_concat_all(["[", int_to_string(lo), ", ", int_to_string(hi), "]"]) }
}

# Lattice join (least upper bound). Used by EIf to merge branches
# and by EMatch to merge arm results — the inferred interval after
# the join covers either branch.
fn ival_join(a: Interval, b: Interval) : Interval = match a {
  IBot -> b
  ITop -> ITop
  Ival(alo, ahi) -> match b {
    IBot -> a
    ITop -> ITop
    Ival(blo, bhi) -> Ival(ival_int_min(alo, blo), ival_int_max(ahi, bhi))
  }
}

# Lattice meet (greatest lower bound). Used by control-flow
# narrowing (e.g. inside an `if x > 0 { ... }` branch the body sees
# `x.interval ⊓ [1, +∞]`). The next sub-step adds the narrowing
# walker; this helper is the primitive it consumes.
fn ival_intersect(a: Interval, b: Interval) : Interval = match a {
  IBot -> IBot
  ITop -> b
  Ival(alo, ahi) -> match b {
    IBot -> IBot
    ITop -> a
    Ival(blo, bhi) -> ival_range(ival_int_max(alo, blo), ival_int_min(ahi, bhi))
  }
}

# Saturating arithmetic. We do not track Int overflow precisely;
# any operation that COULD overflow returns ITop. This trades
# precision for safety: code that genuinely depends on overflow
# semantics will fall back to runtime asserts, which is the worst
# case anyway.
fn ival_add(a: Interval, b: Interval) : Interval = match a {
  IBot -> IBot
  ITop -> match b { IBot -> IBot _ -> ITop }
  Ival(alo, ahi) -> match b {
    IBot -> IBot
    ITop -> ITop
    Ival(blo, bhi) -> Ival(alo + blo, ahi + bhi)
  }
}

fn ival_sub(a: Interval, b: Interval) : Interval = match a {
  IBot -> IBot
  ITop -> match b { IBot -> IBot _ -> ITop }
  Ival(alo, ahi) -> match b {
    IBot -> IBot
    ITop -> ITop
    Ival(blo, bhi) -> Ival(alo - bhi, ahi - blo)
  }
}

# Multiplication: cross-product of bounds, take min/max. Catches
# the [-1, 1] * [-1, 1] = [-1, 1] case correctly (vs the naive
# alo*blo..ahi*bhi which would give [-1, 1] too, but only by luck).
fn ival_mul(a: Interval, b: Interval) : Interval = match a {
  IBot -> IBot
  ITop -> match b { IBot -> IBot _ -> ITop }
  Ival(alo, ahi) -> match b {
    IBot -> IBot
    ITop -> ITop
    Ival(blo, bhi) -> {
      let p1 = alo * blo
      let p2 = alo * bhi
      let p3 = ahi * blo
      let p4 = ahi * bhi
      let m1 = ival_int_min(p1, p2)
      let m2 = ival_int_min(p3, p4)
      let lo = ival_int_min(m1, m2)
      let h1 = ival_int_max(p1, p2)
      let h2 = ival_int_max(p3, p4)
      let hi = ival_int_max(h1, h2)
      Ival(lo, hi)
    }
  }
}

# Provability helpers: each comparison returns
#   Some(true)  — provably true given the intervals,
#   Some(false) — provably false,
#   None        — undecidable, defer to runtime.
# Mirrors the three-valued logic that the unifier reshape will
# consume in the next sub-step.

fn ival_lt(a: Interval, b: Interval) : Option[Bool] = match a {
  IBot -> Some(true)        # vacuously true on an empty domain
  ITop -> match b { IBot -> Some(true) ITop -> None Ival(_, _) -> None }
  Ival(alo, ahi) -> match b {
    IBot -> Some(true)
    ITop -> None
    Ival(blo, bhi) ->
      if ahi < blo { Some(true) }
      else if alo >= bhi { Some(false) }
      else { None }
  }
}

fn ival_le(a: Interval, b: Interval) : Option[Bool] = match a {
  IBot -> Some(true)
  ITop -> match b { IBot -> Some(true) ITop -> None Ival(_, _) -> None }
  Ival(alo, ahi) -> match b {
    IBot -> Some(true)
    ITop -> None
    Ival(blo, bhi) ->
      if ahi <= blo { Some(true) }
      else if alo > bhi { Some(false) }
      else { None }
  }
}

fn ival_gt(a: Interval, b: Interval) : Option[Bool] = ival_lt(b, a)

fn ival_ge(a: Interval, b: Interval) : Option[Bool] = ival_le(b, a)

fn ival_eq(a: Interval, b: Interval) : Option[Bool] = match a {
  IBot -> Some(true)
  ITop -> match b { IBot -> Some(true) ITop -> None Ival(_, _) -> None }
  Ival(alo, ahi) -> match b {
    IBot -> Some(true)
    ITop -> None
    Ival(blo, bhi) ->
      if alo == ahi and blo == bhi and alo == blo { Some(true) }
      else if ahi < blo or alo > bhi { Some(false) }
      else { None }
  }
}

fn ival_ne(a: Interval, b: Interval) : Option[Bool] = match ival_eq(a, b) {
  Some(b1) -> Some(not b1)
  None     -> None
}

# ====================================================================
# m12.6.x #2 (sub-step 2) — Post-typing interval propagation
# ====================================================================
#
# Walks a typed Expr and infers an Interval for every node. Bindings
# learned at SLet propagate through the rest of the block; EIf and
# EMatch join branches; EBinop on Int dispatches to the lattice ops;
# every other shape collapses to ITop (we are not in the business of
# inferring `Real` ranges, `String` properties, etc. — only Int).
#
# This step adds the WALKER ONLY. The unifier still ignores
# refinements; the assert path still emits runtime checks. The next
# sub-step adds a `--dump-intervals` flag so fixtures can pin the
# walker's output before the unifier reshape consumes it.
#
# Intentionally not threaded through the typer's InferState — the
# walker runs after typing finalises, reading types off
# `Expr.ty` to decide whether a node is Int-shaped at all.

# Per-name interval table. Keyed by binding name; missing names
# default to ITop. Uses a flat assoc-list because the typical
# function body has a handful of bindings — a hashmap would be
# overkill.
type IntervalEnv = IE([IntervalBinding])

type IntervalBinding = IB(String, Interval)

fn ie_empty() : IntervalEnv = IE([])

fn ie_lookup(env: IntervalEnv, name: String) : Interval = match env {
  IE(bs) -> ie_lookup_loop(bs, name)
}

fn ie_lookup_loop(bs: [IntervalBinding], name: String) : Interval = match bs {
  [] -> ITop
  [b, ...rest] -> match b {
    IB(nm, iv) -> if nm == name { iv } else { ie_lookup_loop(rest, name) }
  }
}

fn ie_extend(env: IntervalEnv, name: String, iv: Interval) : IntervalEnv = match env {
  IE(bs) -> IE([IB(name, iv), ...bs])
}

# Walk an Expr, returning its interval. The caller passes in the
# current `env`; bindings introduced by sub-Exprs (via SLet inside
# blocks) do NOT escape — their scope ends with the block.
fn ival_of_expr(e: Expr, env: IntervalEnv) : Interval = match e.kind {
  EInt(n)    -> Ival(n, n)
  EBool(_)   -> ITop
  EReal(_)   -> ITop
  EChar(_)   -> ITop
  EStr(_, _) -> ITop
  EUnit      -> ITop
  EVar(nm)   -> ie_lookup(env, nm)
  EUnder     -> ITop
  EPlaceholder -> ITop
  EHole(_)   -> ITop
  ETodo(_)   -> ITop
  EVariantsOf(_, _) -> ITop
  EModCall(_, _)    -> ITop
  ECall(_, _)       -> ITop
  EField(_, _)      -> ITop
  EIndex(_, _)      -> ITop
  EBinop(op, a, b)  -> ival_of_binop(op, a, b, env)
  EUnop(op, x)      -> ival_of_unop(op, x, env)
  EIf(c, t, eo)     -> ival_of_if(c, t, eo, env)
  EMatch(scr, arms) -> ival_of_match(scr, arms, env)
  ELambda(_, _)     -> ITop
  ERecordLit(_, _)  -> ITop
  EList(_)          -> ITop
  ERange(_, _, _)   -> ITop
  EBlock(stmts, tail) -> ival_of_block(stmts, tail, env)
  EPipe(_, _)       -> ITop
  EMapPipe(_, _)     -> ITop
  EFlatMapPipe(_, _) -> ITop
  EFilterPipe(_, _)  -> ITop
  EBang(_)          -> ITop
  EHandle(_, _, _, _, _, _, _) -> ITop
  ELitUnit(_, _)    -> ITop
}

fn ival_of_binop(op: String, a: Expr, b: Expr, env: IntervalEnv) : Interval = {
  let ia = ival_of_expr(a, env)
  let ib = ival_of_expr(b, env)
  if op == "+" { ival_add(ia, ib) }
  else if op == "-" { ival_sub(ia, ib) }
  else if op == "*" { ival_mul(ia, ib) }
  else { ITop }
}

# Unary minus narrows: -[lo, hi] = [-hi, -lo]. `not` is Bool, so it
# falls through. Anything else (e.g. parser-only ops) — ITop.
fn ival_of_unop(op: String, x: Expr, env: IntervalEnv) : Interval = {
  if op == "-" {
    match ival_of_expr(x, env) {
      IBot -> IBot
      ITop -> ITop
      Ival(lo, hi) -> Ival(0 - hi, 0 - lo)
    }
  } else { ITop }
}

# Conditional: when `eo == None` the if-without-else returns Unit on
# the false branch, so the result is the join of the then-branch
# interval and ITop (= ITop). When eo is present, join both arms.
fn ival_of_if(c: Expr, t: Expr, eo: Option[Expr], env: IntervalEnv) : Interval = {
  let it = ival_of_expr(t, env)
  match eo {
    None -> ITop
    Some(e) -> ival_join(it, ival_of_expr(e, env))
  }
}

# match: join over all arm bodies. Pattern bindings are not
# narrowed in v1 — every arm body sees the same env. Adding pattern-
# narrowing (e.g. `Some(x) -> ...` reveals `x` is non-None) is a
# follow-up sub-step alongside the unifier reshape.
fn ival_of_match(scr: Expr, arms: [Arm], env: IntervalEnv) : Interval = {
  let _ = scr  # walked for side-effects when the pass becomes intervalize
  ival_of_match_loop(arms, env, IBot)
}

fn ival_of_match_loop(arms: [Arm], env: IntervalEnv, acc: Interval) : Interval = match arms {
  [] -> if match_is_total(acc) { acc } else { acc }
  [a, ...rest] -> match a {
    Arm(_, _, body) -> ival_of_match_loop(rest, env, ival_join(acc, ival_of_expr(body, env)))
  }
}

# Placeholder for "every variant of the scrutinee is covered" so we
# can drop the IBot fallback. Without this we would over-approximate
# to ITop on any match (the IBot starts polluting the join). Total
# match analysis lives in the typer for exhaustiveness; for v1 we
# trust the typer's exhaustiveness check has already run.
fn match_is_total(_acc: Interval) : Bool = true

fn ival_of_block(stmts: [Stmt], tail: Option[Expr], env: IntervalEnv) : Interval = {
  let env1 = ival_thread_stmts(stmts, env)
  match tail {
    None    -> ITop
    Some(e) -> ival_of_expr(e, env1)
  }
}

# Thread the env through SLet bindings. Each SLet of `pat = e`
# extends the env when `pat` is a single name (PBind) — destructuring
# patterns are out of scope for v1; they bind to ITop. SAssert /
# SExprStmt / SUse / SVar / SIndexAssign do not introduce Int
# bindings worth tracking here (SVar's State desugar fires before
# the typer; if it ever survives, treat as ITop binding).
fn ival_thread_stmts(stmts: [Stmt], env: IntervalEnv) : IntervalEnv = match stmts {
  [] -> env
  [s, ...rest] -> match s {
    SLet(pat, _, e) -> {
      let iv = ival_of_expr(e, env)
      let env1 = ival_bind_pat(pat, iv, env)
      ival_thread_stmts(rest, env1)
    }
    _ -> ival_thread_stmts(rest, env)
  }
}

# Bind a pattern to an interval. Only the simple PBind(name) case
# adds a useful entry; everything else falls through.
fn ival_bind_pat(pat: Pattern, iv: Interval, env: IntervalEnv) : IntervalEnv = match pat.pkind {
  PBind(nm) -> ie_extend(env, nm, iv)
  _ -> env
}

# Convenience entry: walk an entire DFn body, returning the
# inferred interval for the whole expression. Used by the dump
# flag and by the (future) unifier reshape that needs to consult
# intervals at the body's tail expression.
fn ival_of_decl(d: Decl) : Interval = match d {
  DFn(_, _, _, params, _, _, body, _, _, _) ->
    ival_of_expr(body, ival_seed_params(params, ie_empty()))
  _ -> ITop
}

# Seed the env with each parameter mapped to ITop (no narrowing
# from refinement types yet — the unifier reshape will refine
# this when refined params land).
fn ival_seed_params(params: [Param], env: IntervalEnv) : IntervalEnv = match params {
  [] -> env
  [p, ...rest] -> ival_seed_params(rest, ie_extend(env, p.pname, ITop))
}

# ====================================================================
# Issue #83 sub-case 3 — call-site substitution analysis
# ====================================================================
#
# Walks every user fn looking for `ECall(EVar(callee), args)` whose
# callee's `requires` clauses (or refined-param predicates) can be
# discharged at compile time from what we know about the args:
#
#   1. **Literal arg**: substitute the integer into the callee's
#      predicate and run `try_eval_pred`.
#   2. **Refined-binding arg**: when the arg is an `EVar(x)` whose
#      type is `TyRefine` in the caller's signature, the caller's
#      refinement (with `self ↦ x`) is checked against the callee's
#      predicate (with `param ↦ x`) using the same canonical /
#      interval-based entailment as the in-callee path.
#   3. **Unrefined-binding arg**: no info, leave the runtime assert
#      in place. Status quo.
#
# The analysis is intentionally a syntactic AST pass — it sees the
# parser's `TyRefine` shape directly, with no need for the
# `infer_program` substitution. Two outputs:
#
#   - `--dump-call-elision`: per call-site report, useful for
#     fixtures.
#   - `check_call_site_refinements`: when the caller passes a refined
#     binding whose refinement is strictly weaker than the callee's
#     pre, that's a static error pointing at the call site. No flag
#     needed; refining a parameter is opt-in already.

# A callee's contract entry: param name + predicate the caller must
# discharge for that param. For `requires P` the param is the special
# `__contract` (P uses param names directly); for refined params the
# param's name is the refinement's `self` stand-in.
type CalleeReq = CR(String, Expr)

type CalleeSig = CSig(String, [String], [CalleeReq])  # name, param names, requirements

# Build the table of fns with non-empty contracts. Tparam-rewritten
# fns (`with_protocol_tparams`) are skipped — protocol impls are
# resolved later in the pipeline and their contracts get re-emitted
# at that point.
fn collect_callee_sigs(decls: [Decl]) : [CalleeSig] {
  collect_callee_sigs_loop(decls, [])
}

fn collect_callee_sigs_loop(decls: [Decl], acc: [CalleeSig]) : [CalleeSig] {
  match decls {
    [] -> list_reverse(acc)
    [d, ...rest] -> match d {
      DFn(_, name, _, params, _, _, body, _, _, _) -> {
        let reqs = extract_callee_reqs(params, body)
        if list_is_empty(reqs) { collect_callee_sigs_loop(rest, acc) }
        else {
          let pnames = collect_param_names(params, [])
          collect_callee_sigs_loop(rest, [CSig(name, pnames, reqs), ...acc])
        }
      }
      _ -> collect_callee_sigs_loop(rest, acc)
    }
  }
}

fn collect_param_names(params: [Param], acc: [String]) : [String] = match params {
  [] -> list_reverse(acc)
  [p, ...rest] -> collect_param_names(rest, [p.pname, ...acc])
}

# Walk the body's leading asserts to recover the original `requires`
# predicates `wrap_with_contracts` desugared. They live at the front
# of an EBlock as `SAssert(pred, Some("requires violated..."))`. We
# stop at the first non-`requires` assert (so `ensures` asserts after
# `let result = body` aren't picked up). Refined-param predicates
# also produce a CalleeReq (with `self ↦ pname` already applied so
# downstream entailment treats them as ordinary predicates over the
# parameter).
fn extract_callee_reqs(params: [Param], body: Expr) : [CalleeReq] {
  let from_params = extract_param_refinement_reqs(params, [])
  let from_asserts = extract_requires_asserts(body)
  list_append(from_asserts, from_params)
}

fn extract_param_refinement_reqs(params: [Param], acc: [CalleeReq]) : [CalleeReq] {
  match params {
    [] -> list_reverse(acc)
    [p, ...rest] -> match p.ptype {
      Some(t) -> match t.tkind {
        TyRefine(_, pred) ->
          extract_param_refinement_reqs(rest, [CR(p.pname, subst_self(pred, p.pname)), ...acc])
        _ -> extract_param_refinement_reqs(rest, acc)
      }
      None -> extract_param_refinement_reqs(rest, acc)
    }
  }
}

fn extract_requires_asserts(body: Expr) : [CalleeReq] = match body.kind {
  EBlock(stmts, _) -> extract_requires_loop(stmts, [])
  _ -> []
}

fn extract_requires_loop(stmts: [Stmt], acc: [CalleeReq]) : [CalleeReq] {
  match stmts {
    [] -> list_reverse(acc)
    [s, ...rest] -> match s {
      SAssert(pred, Some(msg)) -> if assert_msg_is_requires(msg) {
        extract_requires_loop(rest, [CR("__requires", pred), ...acc])
      } else { list_reverse(acc) }
      _ -> list_reverse(acc)
    }
  }
}

fn assert_msg_is_requires(msg: Expr) : Bool = match msg.kind {
  EStr(s, _) -> string_starts_with_requires(s)
  _ -> false
}

# The desugared message is a quoted string of the form
# `"requires violated at line N"` (quotes included in EStr's raw
# span). Match the prefix `"requires` rather than calling
# string_starts_with_q which is defined later in the file but is
# semantically what we want.
fn string_starts_with_requires(s: String) : Bool {
  let n = string_length(s)
  if n < 10 { false } else {
    let c0 = char_at(s, 0)
    let c1 = char_at(s, 1)
    match c0 { Some(q) -> match c1 {
      Some(r) -> q == '"' and r == 'r' and starts_with_after_quote(s, 1, "requires")
      None -> false
    } None -> false }
  }
}

fn starts_with_after_quote(s: String, off: Int, prefix: String) : Bool {
  let n = string_length(prefix)
  pred_starts_with_loop(s, off, prefix, 0, n)
}

fn pred_starts_with_loop(s: String, soff: Int, prefix: String, poff: Int, n: Int) : Bool {
  if poff >= n { true }
  else {
    match char_at(s, soff) {
      Some(cs) -> match char_at(prefix, poff) {
        Some(cp) -> if cs == cp { pred_starts_with_loop(s, soff + 1, prefix, poff + 1, n) } else { false }
        None -> false
      }
      None -> false
    }
  }
}

# Refinement bindings visible inside a function body: each entry
# pairs a binding name with the (canonicalised, self-substituted)
# predicate the typer would attach to its TyRefine. Built from the
# enclosing fn's parameter list; `let` bindings without explicit
# refinement annotations contribute nothing (interval inference is
# the lattice's job, not this analysis).
type RefBinding = RBind(String, Expr)

fn collect_caller_refinements(params: [Param], acc: [RefBinding]) : [RefBinding] {
  match params {
    [] -> list_reverse(acc)
    [p, ...rest] -> match p.ptype {
      Some(t) -> match t.tkind {
        TyRefine(_, pred) ->
          collect_caller_refinements(rest, [RBind(p.pname, subst_self(pred, p.pname)), ...acc])
        _ -> collect_caller_refinements(rest, acc)
      }
      None -> collect_caller_refinements(rest, acc)
    }
  }
}

fn lookup_caller_refinement(refs: [RefBinding], name: String) : Option[Expr] {
  match refs {
    [] -> None
    [r, ...rest] -> match r {
      RBind(n, p) -> if n == name { Some(p) } else { lookup_caller_refinement(rest, name) }
    }
  }
}

# A single classification of a call-site relative to one of the
# callee's requirements. Fixtures pin these via `--dump-call-elision`.
type CallSiteStatus = CSElided | CSRuntime | CSLoose(String)

# Outcome record: callee name, param name (or "__requires"), the
# discharged predicate as it was tested, and the status.
type CallSiteReport = CSR(String, String, Expr, CallSiteStatus, Int, Int)

# Classify one (callee_param, caller_arg) discharge attempt.
#
# `req_pred` is the callee's predicate with the formal parameter
# name baked in (already substituted from `self`). `arg` is the AST
# expression at the call site. `caller_refs` is the refinement
# environment built from the enclosing fn's parameters.
fn classify_arg_vs_pred(req_pred: Expr, pname: String, arg: Expr,
                        caller_refs: [RefBinding]) : CallSiteStatus {
  match try_eval_int(arg) {
    Some(k) -> {
      let folded = pred_canon(subst_var(req_pred, pname, mk_int(k, arg.line, arg.col)))
      match try_eval_pred(folded) {
        Some(true) -> CSElided
        Some(false) -> CSLoose(concat_all(["literal ", int_to_string(k), " violates `", expr_show_pred(req_pred), "`"]))
        None -> CSRuntime
      }
    }
    None -> match arg.kind {
      EVar(arg_name) -> match lookup_caller_refinement(caller_refs, arg_name) {
        Some(caller_pred) -> {
          # Substitute both predicates to talk about the same name
          # (the arg's name) so structural / interval entailment
          # works without per-pair alpha matching.
          let req_in_arg = pred_canon(subst_var(req_pred, pname, mk_var(arg_name, arg.line, arg.col)))
          let caller_in_arg = pred_canon(caller_pred)
          if expr_struct_eq(req_in_arg, caller_in_arg) { CSElided }
          else if pred_entailed_by_refinement(req_in_arg, arg_name, caller_in_arg) { CSElided }
          else { CSLoose(concat_all([
                  "caller refinement `", expr_show_pred(caller_pred),
                  "` does not entail callee precondition `",
                  expr_show_pred(req_pred), "`"])) }
        }
        None -> CSRuntime
      }
      _ -> CSRuntime
    }
  }
}

fn mk_int(n: Int, line: Int, col: Int) : Expr = mk_expr(EInt(n), line, col)
fn mk_var(s: String, line: Int, col: Int) : Expr = mk_expr(EVar(s), line, col)

# Substitute every free `EVar(from)` in `e` with `to`. Mirrors
# `subst_self` but for an arbitrary name. Used to push a literal /
# binding into a callee's predicate before discharging it.
fn subst_var(e: Expr, from: String, to: Expr) : Expr = match e.kind {
  EVar(s) -> if s == from { to } else { e }
  EBinop(op, a, b) -> mk_expr(EBinop(op, subst_var(a, from, to), subst_var(b, from, to)), e.line, e.col)
  EUnop(op, x) -> mk_expr(EUnop(op, subst_var(x, from, to)), e.line, e.col)
  ECall(f, xs) -> mk_expr(ECall(subst_var(f, from, to), subst_var_list(xs, from, to)), e.line, e.col)
  _ -> e
}

fn subst_var_list(es: [Expr], from: String, to: Expr) : [Expr] = match es {
  [] -> []
  [h, ...t] -> [subst_var(h, from, to), ...subst_var_list(t, from, to)]
}

# Pretty-print a predicate Expr in the canonical comparison form used
# by `--dump-call-elision`. Falls back to `<expr>` for shapes outside
# the decidable subset so the output stays grep-friendly.
fn expr_show_pred(e: Expr) : String = match e.kind {
  EInt(n) -> int_to_string(n)
  EVar(s) -> s
  EBool(b) -> if b { "true" } else { "false" }
  EBinop(op, a, b) -> concat_all([expr_show_pred(a), " ", op, " ", expr_show_pred(b)])
  EUnop(op, x) -> concat_all([op, " ", expr_show_pred(x)])
  _ -> "<expr>"
}

# Walk a body expression collecting reports for every ECall(EVar, ...).
# Calls into anonymous lambdas, method calls, etc. are skipped — the
# entailment table is keyed by fn name and we don't track higher-order
# values.
fn analyze_calls(e: Expr, sigs: [CalleeSig], caller_refs: [RefBinding],
                 acc: [CallSiteReport]) : [CallSiteReport] = match e.kind {
  ECall(callee, call_args) -> {
    let acc1 = analyze_calls_in_args(call_args, sigs, caller_refs, acc)
    match callee.kind {
      EVar(fname) -> match lookup_callee_sig(sigs, fname) {
        None -> acc1
        Some(cs) -> match cs {
          CSig(_, pnames, reqs) -> classify_call(fname, pnames, call_args, reqs, caller_refs, acc1, callee.line, callee.col)
        }
      }
      _ -> analyze_calls(callee, sigs, caller_refs, acc1)
    }
  }
  EBinop(_, a, b) -> analyze_calls(b, sigs, caller_refs, analyze_calls(a, sigs, caller_refs, acc))
  EUnop(_, x) -> analyze_calls(x, sigs, caller_refs, acc)
  EIf(c, t, eo) -> {
    let a1 = analyze_calls(c, sigs, caller_refs, acc)
    let a2 = analyze_calls(t, sigs, caller_refs, a1)
    match eo { None -> a2 Some(el) -> analyze_calls(el, sigs, caller_refs, a2) }
  }
  EBlock(stmts, tail) -> {
    let a1 = analyze_calls_in_stmts(stmts, sigs, caller_refs, acc)
    match tail { None -> a1 Some(t) -> analyze_calls(t, sigs, caller_refs, a1) }
  }
  EMatch(scr, arms) -> analyze_calls_in_arms(arms, sigs, caller_refs, analyze_calls(scr, sigs, caller_refs, acc))
  EField(b, _) -> analyze_calls(b, sigs, caller_refs, acc)
  EIndex(a, i) -> analyze_calls(i, sigs, caller_refs, analyze_calls(a, sigs, caller_refs, acc))
  EPipe(a, b) -> analyze_calls(b, sigs, caller_refs, analyze_calls(a, sigs, caller_refs, acc))
  EMapPipe(a, b) -> analyze_calls(b, sigs, caller_refs, analyze_calls(a, sigs, caller_refs, acc))
  EFlatMapPipe(a, b) -> analyze_calls(b, sigs, caller_refs, analyze_calls(a, sigs, caller_refs, acc))
  EFilterPipe(a, b) -> analyze_calls(b, sigs, caller_refs, analyze_calls(a, sigs, caller_refs, acc))
  EBang(x) -> analyze_calls(x, sigs, caller_refs, acc)
  ELambda(_, body) -> analyze_calls(body, sigs, caller_refs, acc)
  EList(elems) -> analyze_calls_in_list_elems(elems, sigs, caller_refs, acc)
  ERange(a, b, _) -> analyze_calls(b, sigs, caller_refs, analyze_calls(a, sigs, caller_refs, acc))
  ELitUnit(inner, _) -> analyze_calls(inner, sigs, caller_refs, acc)
  _ -> acc
}

fn analyze_calls_in_args(call_args: [Expr], sigs: [CalleeSig], caller_refs: [RefBinding],
                          acc: [CallSiteReport]) : [CallSiteReport] = match call_args {
  [] -> acc
  [a, ...rest] -> analyze_calls_in_args(rest, sigs, caller_refs, analyze_calls(a, sigs, caller_refs, acc))
}

fn analyze_calls_in_stmts(stmts: [Stmt], sigs: [CalleeSig], caller_refs: [RefBinding],
                           acc: [CallSiteReport]) : [CallSiteReport] = match stmts {
  [] -> acc
  [s, ...rest] -> {
    let acc1 = match s {
      SLet(_, _, e) -> analyze_calls(e, sigs, caller_refs, acc)
      SExprStmt(e) -> analyze_calls(e, sigs, caller_refs, acc)
      SAssert(c, opt_m) -> {
        let a1 = analyze_calls(c, sigs, caller_refs, acc)
        match opt_m { None -> a1 Some(m) -> analyze_calls(m, sigs, caller_refs, a1) }
      }
      _ -> acc
    }
    analyze_calls_in_stmts(rest, sigs, caller_refs, acc1)
  }
}

fn analyze_calls_in_arms(arms: [Arm], sigs: [CalleeSig], caller_refs: [RefBinding],
                          acc: [CallSiteReport]) : [CallSiteReport] = match arms {
  [] -> acc
  [a, ...rest] -> match a {
    Arm(_, _, body) -> analyze_calls_in_arms(rest, sigs, caller_refs, analyze_calls(body, sigs, caller_refs, acc))
  }
}

fn analyze_calls_in_list_elems(elems: [ListElem], sigs: [CalleeSig], caller_refs: [RefBinding],
                                acc: [CallSiteReport]) : [CallSiteReport] = match elems {
  [] -> acc
  [el, ...rest] -> {
    let acc1 = match el {
      ElPlain(e) -> analyze_calls(e, sigs, caller_refs, acc)
      ElSpread(e) -> analyze_calls(e, sigs, caller_refs, acc)
    }
    analyze_calls_in_list_elems(rest, sigs, caller_refs, acc1)
  }
}

fn lookup_callee_sig(sigs: [CalleeSig], name: String) : Option[CalleeSig] = match sigs {
  [] -> None
  [s, ...rest] -> match s {
    CSig(n, _, _) -> if n == name { Some(s) } else { lookup_callee_sig(rest, name) }
  }
}

# Drive the per-arg classification. For each requirement, find the
# arg the callee param it refers to maps to (positional, by name) and
# classify. `__requires` predicates are checked by substituting EVERY
# param name in the predicate with its corresponding arg before
# folding.
fn classify_call(fname: String, pnames: [String], call_args: [Expr], reqs: [CalleeReq],
                 caller_refs: [RefBinding], acc: [CallSiteReport],
                 line: Int, col: Int) : [CallSiteReport] = match reqs {
  [] -> acc
  [r, ...rest] -> match r {
    CR(pname, pred) -> {
      let status = if pname == "__requires" {
        classify_requires_clause(pred, pnames, call_args, caller_refs)
      } else {
        match arg_for_param(pnames, call_args, pname) {
          Some(arg) -> classify_arg_vs_pred(pred, pname, arg, caller_refs)
          None -> CSRuntime
        }
      }
      let rep = CSR(fname, pname, pred, status, line, col)
      classify_call(fname, pnames, call_args, rest, caller_refs, [rep, ...acc], line, col)
    }
  }
}

# A `requires` predicate may mention any param; substitute each param
# name with the corresponding arg expression (literal or refined
# binding) and either fold or check entailment.
fn classify_requires_clause(pred: Expr, pnames: [String], call_args: [Expr],
                             caller_refs: [RefBinding]) : CallSiteStatus {
  let subst = subst_params(pred, pnames, call_args)
  let folded = pred_canon(subst)
  match try_eval_pred(folded) {
    Some(true) -> CSElided
    Some(false) -> CSLoose(concat_all(["literal args violate `", expr_show_pred(pred), "`"]))
    None -> {
      # Try refinement-based discharge: if the substituted predicate
      # is a comparison whose only free var is a refined caller
      # binding, ask the lattice.
      match free_var_of_pred(folded) {
        Some(vname) -> match lookup_caller_refinement(caller_refs, vname) {
          Some(caller_pred) -> {
            let caller_canon = pred_canon(caller_pred)
            if expr_struct_eq(folded, caller_canon) { CSElided }
            else if pred_entailed_by_refinement(folded, vname, caller_canon) { CSElided }
            else { CSLoose(concat_all([
                    "caller refinement `", expr_show_pred(caller_pred),
                    "` does not entail callee precondition `",
                    expr_show_pred(pred), "`"])) }
          }
          None -> CSRuntime
        }
        None -> CSRuntime
      }
    }
  }
}

fn subst_params(pred: Expr, pnames: [String], call_args: [Expr]) : Expr = match pnames {
  [] -> pred
  [n, ...rest_n] -> match call_args {
    [] -> pred
    [a, ...rest_a] -> subst_params(subst_var(pred, n, a), rest_n, rest_a)
  }
}

fn arg_for_param(pnames: [String], call_args: [Expr], target: String) : Option[Expr] = match pnames {
  [] -> None
  [n, ...rest_n] -> match call_args {
    [] -> None
    [a, ...rest_a] -> if n == target { Some(a) } else { arg_for_param(rest_n, rest_a, target) }
  }
}

# Find the unique free variable of a comparison predicate, or None
# if it has zero or more than one. Used by classify_requires_clause
# to decide which caller refinement to consult.
fn free_var_of_pred(e: Expr) : Option[String] = match e.kind {
  EBinop(_, a, b) -> match free_var_of_pred(a) {
    Some(an) -> match free_var_of_pred(b) {
      Some(bn) -> if an == bn { Some(an) } else { None }
      None -> Some(an)
    }
    None -> free_var_of_pred(b)
  }
  EUnop(_, x) -> free_var_of_pred(x)
  EVar(s) -> Some(s)
  _ -> None
}

# Drive analyze_calls over a whole program. Each fn body is walked
# with the fn's own param refinements as the caller environment.
fn analyze_program_calls(decls: [Decl], sigs: [CalleeSig]) : [CallSiteReport] {
  analyze_program_calls_loop(decls, sigs, [])
}

fn analyze_program_calls_loop(decls: [Decl], sigs: [CalleeSig],
                                acc: [CallSiteReport]) : [CallSiteReport] = match decls {
  [] -> list_reverse(acc)
  [d, ...rest] -> match d {
    DFn(_, _, _, params, _, _, body, _, _, _) -> {
      let refs = collect_caller_refinements(params, [])
      let acc1 = analyze_calls(body, sigs, refs, acc)
      analyze_program_calls_loop(rest, sigs, acc1)
    }
    _ -> analyze_program_calls_loop(rest, sigs, acc)
  }
}

# `--dump-call-elision`: per-call-site report, one line per
# (callee, param) pair, in source order. Format mirrors
# `--dump-intervals`: `callee.param @line:col -> status`.
fn dump_call_elision(file: String, decls: [Decl]) : Int / Console {
  let sigs = collect_callee_sigs(decls)
  let reports = analyze_program_calls(decls, sigs)
  reports |> each(dump_call_elision_one)
  0
}

fn dump_call_elision_one(r: CallSiteReport) : Unit / Console = match r {
  CSR(fname, pname, pred, status, line, col) -> {
    let prefix = concat_all([fname, ".", pname, " @", int_to_string(line), ":",
                             int_to_string(col), " `", expr_show_pred(pred), "`"])
    match status {
      CSElided -> print("#{prefix} -> elided")
      CSRuntime -> print("#{prefix} -> runtime")
      CSLoose(reason) -> print("#{prefix} -> loose (#{reason})")
    }
  }
}

# Compile-time strictness: a refined binding passed where the callee
# wants a strictly stronger predicate is a static error. The reason
# string surfaces via the diagnostic so the user sees `>= 0 doesn't
# entail > 0`. Returns the number of errors emitted.
fn check_call_site_refinements(file: String, decls: [Decl]) : Int / Console {
  let sigs = collect_callee_sigs(decls)
  let reports = analyze_program_calls(decls, sigs)
  check_call_site_loop(file, reports, 0)
}

fn check_call_site_loop(file: String, reports: [CallSiteReport], errs: Int) : Int / Console = match reports {
  [] -> errs
  [r, ...rest] -> match r {
    CSR(fname, _, _, status, line, col) -> match status {
      CSLoose(reason) -> {
        eprint("#{file}:#{int_to_string(line)}:#{int_to_string(col)}: error: call to `#{fname}`: #{reason}\n")
        check_call_site_loop(file, rest, errs + 1)
      }
      _ -> check_call_site_loop(file, rest, errs)
    }
  }
}

# `effect Eff[T1, T2] { op_decl ... }` — m7a #3a + m7b #11.
# No name resolution and no evidence-type emission live here; those are
# #3c and #3d. Each op_decl is `name(params) : ReturnType`, body-less;
# per docs/effects-impl.md §*Evidence types*. Per-op type generics are
# m7b #2 (separate sub-task). m7b #11 adds the optional `[T1, T2]`
# tparam list after the effect name; tparams are in scope inside every
# op signature's parameter and return types.
fn parse_effect_decl(p: Parser, is_pub: Bool, t: Token) : PDecl / Console {

  let id = p_peek(p)
  if not tk_is(id.kind, TkIdent) {
    err_d(p_error(p, id, "expected effect name"))
  } else {
    let name = tok_source(p.src, id)
    let p1 = p_advance(p)
    let p1n = p_skip_newlines(p1)
    let tparams_r =
      if p_at(p1n, TkLbracket) {
        parse_type_params_loop(p_skip_newlines(p_advance(p1n)), [])
      } else {
        PTParams { p: p1n, r: Some([]) }
      }
    match tparams_r.r {
      None -> err_d(tparams_r.p)
      Some(tparams) -> {
        let p2 = p_skip_newlines(tparams_r.p)
        if not p_at(p2, TkLbrace) {
          err_d(p_error_here(p2, "expected `{` to start effect body"))
        } else {
          let p3 = p_skip_newlines(p_advance(p2))
          let ops_r = parse_effect_ops(p3, [])
          match ops_r.r {
            None -> err_d(ops_r.p)
            Some(ops) -> ok_d(ops_r.p, DEffect(is_pub, name, tparams, ops, t.line, t.col))
          }
        }
      }
    }
  }
}

type PEffectOps = { p: Parser, r: Option[[EffectOp]] }

fn parse_effect_ops(p: Parser, acc: [EffectOp]) : PEffectOps / Console {

  let p0 = p_skip_newlines(p)
  if p_at(p0, TkRbrace) {
    PEffectOps { p: p_advance(p0), r: Some(list_reverse(acc)) }
  } else {
    let id = p_peek(p0)
    if not tk_is(id.kind, TkIdent) {
      PEffectOps { p: p_error(p0, id, "expected operation name"), r: None }
    } else {
      let opname = tok_source(p0.src, id)
      let p1 = p_advance(p0)
      # m7b #2: optional `[T1, T2]` op-level tparams before `(args)`.
      # Reuses parse_type_params_loop (m7b #11 / m7a effects). Empty
      # when omitted; the op signature is then monomorphic.
      let op_tparams_r =
        if p_at(p1, TkLbracket) {
          parse_type_params_loop(p_skip_newlines(p_advance(p1)), [])
        } else {
          PTParams { p: p1, r: Some([]) }
        }
      match op_tparams_r.r {
        None -> PEffectOps { p: op_tparams_r.p, r: None }
        Some(op_tparams) -> {
          let pp = op_tparams_r.p
          if not p_at(pp, TkLparen) {
            PEffectOps { p: p_error_here(pp, "expected `(` after operation name"), r: None }
          } else {
        let p2 = p_skip_newlines(p_advance(pp))
        let params_r = parse_fn_params(p2, [])
        match params_r.r {
          None -> PEffectOps { p: params_r.p, r: None }
          Some(params) -> {
            let p3 = p_skip_newlines(params_r.p)
            if not p_at(p3, TkColon) {
              PEffectOps { p: p_error_here(p3, "expected `:` before operation return type"), r: None }
            } else {
              let rt = parse_type(p_advance(p3))
              match rt.r {
                None -> PEffectOps { p: rt.p, r: None }
                Some(ty) -> {
                  let op = EOp(opname, op_tparams, params, ty, id.line, id.col)
                  parse_effect_ops(rt.p, [op, ...acc])
                }
              }
            }
          }
        }
          }
        }
      }
    }
  }
}

type PParams = { p: Parser, r: Option[[Param]] }

fn parse_fn_params(p: Parser, acc: [Param]) : PParams / Console {

  if p_at(p, TkRparen) { PParams { p: p_advance(p), r: Some(list_reverse(acc)) } }
  else {
    let t = p_peek(p)
    if not tk_is(t.kind, TkIdent) {
      PParams { p: p_error(p, t, "expected parameter name"), r: None }
    } else {
      let name = tok_source(p.src, t)
      let p1 = p_advance(p)
      if not p_at(p1, TkColon) {
        PParams { p: p_error_here(p1, "expected `:` after parameter name"), r: None }
      } else {
        let rt = parse_type(p_advance(p1))
        match rt.r {
          None -> PParams { p: rt.p, r: None }
          Some(ty) -> {
            let param = Param { pname: name, ptype: Some(ty), pline: t.line, pcol: t.col }
            let p2 = p_skip_newlines(rt.p)
            if p_at(p2, TkComma) {
              parse_fn_params(p_skip_newlines(p_advance(p2)), [param, ...acc])
            } else if p_at(p2, TkRparen) {
              PParams { p: p_advance(p2), r: Some(list_reverse([param, ...acc])) }
            } else {
              PParams { p: p_error_here(p2, "expected `,` or `)` in parameter list"), r: None }
            }
          }
        }
      }
    }
  }
}

# m12.8: `protocol P { op_decls }`. Each op_decl is `name(params) :
# ReturnType`, body-less, mirroring effect-op shape. The first param
# may use `Self` as its type to indicate the dispatch site; the
# resolver / typer treats `Self` as a fresh type variable.
fn parse_protocol_decl(p: Parser, is_pub: Bool, t: Token) : PDecl / Console {

  let id = p_peek(p)
  if not tk_is(id.kind, TkIdent) or not is_upper_ident(p.src, id) {
    err_d(p_error(p, id, "expected an uppercase protocol name"))
  } else {
    let name = tok_source(p.src, id)
    let p1 = p_advance(p)
    # Issue #180: optional `[A1, A2, ...]` type-parameter list bound at
    # protocol declaration scope. Reuses the standard tparam parser
    # (same shape as `effect Reader[T]` and `fn[T]`).
    let proto_tps_r =
      if p_at(p1, TkLbracket) {
        parse_type_params_loop(p_skip_newlines(p_advance(p1)), [])
      } else {
        PTParams { p: p1, r: Some([]) }
      }
    match proto_tps_r.r {
      None -> err_d(proto_tps_r.p)
      Some(proto_tparams) -> {
        let p1n = p_skip_newlines(proto_tps_r.p)
        if not p_at(p1n, TkLbrace) {
          err_d(p_error_here(p1n, "expected `{` to start protocol body"))
        } else {
          let p2 = p_skip_newlines(p_advance(p1n))
          let ops_r = parse_protocol_ops(p2, [])
          match ops_r.r {
            None -> err_d(ops_r.p)
            Some(ops) -> ok_d(ops_r.p, DProtocol(is_pub, name, proto_tparams, ops, t.line, t.col))
          }
        }
      }
    }
  }
}

type PProtoOps = { p: Parser, r: Option[[ProtoOp]] }

fn parse_protocol_ops(p: Parser, acc: [ProtoOp]) : PProtoOps / Console {

  let p0 = p_skip_newlines(p)
  if p_at(p0, TkRbrace) {
    PProtoOps { p: p_advance(p0), r: Some(list_reverse(acc)) }
  } else {
    let id = p_peek(p0)
    if not tk_is(id.kind, TkIdent) {
      PProtoOps { p: p_error(p0, id, "expected operation name"), r: None }
    } else {
      let opname = tok_source(p0.src, id)
      let p1 = p_advance(p0)
      let op_tparams_r =
        if p_at(p1, TkLbracket) {
          parse_type_params_loop(p_skip_newlines(p_advance(p1)), [])
        } else {
          PTParams { p: p1, r: Some([]) }
        }
      match op_tparams_r.r {
        None -> PProtoOps { p: op_tparams_r.p, r: None }
        Some(op_tparams) -> {
          let pp = op_tparams_r.p
          if not p_at(pp, TkLparen) {
            PProtoOps { p: p_error_here(pp, "expected `(` after operation name"), r: None }
          } else {
            let p2 = p_skip_newlines(p_advance(pp))
            let params_r = parse_fn_params(p2, [])
            match params_r.r {
              None -> PProtoOps { p: params_r.p, r: None }
              Some(params) -> {
                let p3 = p_skip_newlines(params_r.p)
                if not p_at(p3, TkColon) {
                  PProtoOps { p: p_error_here(p3, "expected `:` before operation return type"), r: None }
                } else {
                  let rt = parse_type(p_advance(p3))
                  match rt.r {
                    None -> PProtoOps { p: rt.p, r: None }
                    Some(ty) -> {
                      let op = POp(opname, op_tparams, params, ty, id.line, id.col)
                      parse_protocol_ops(rt.p, [op, ...acc])
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}

# m12.8: `impl P for T { fn op(args) = body ... }`. Each method is a
# regular DFn whose name matches a protocol op name. The body
# inherits the parser's full feature set (any expression form).
#
# m12.8 phase 2: an optional impl-level tparam list `[u: Measure, ...]`
# may follow `impl` (mirrors the `fn[T1, T2]` shape). The bound names
# are prepended to each method's own tparams so the typer sees them
# as ordinary fn tparams in scope inside parameter and body types
# (e.g. `impl[u: Measure] Show for Real<u> { fn show(x: Real<u>) ... }`).
fn parse_impl_decl(p: Parser, t: Token) : PDecl / Console {

  let imp_tps_r =
    if p_at(p, TkLbracket) {
      # Issue #174: impl-site tparams accept protocol bounds
      # (`[T : Show + Eq, U]`) in addition to the legacy `Measure`
      # kind annotation. Bounds are encoded as `T#b:Show,Eq` in the
      # stored tparam string; see `tp_bounds_of` / `tp_strip_bounds`.
      parse_impl_type_params_loop(p_skip_newlines(p_advance(p)), [])
    } else {
      PTParams { p: p, r: Some([]) }
    }
  match imp_tps_r.r {
    None -> err_d(imp_tps_r.p)
    Some(impl_tparams) -> {
      let p_after_tps = p_skip_newlines(imp_tps_r.p)
      let id = p_peek(p_after_tps)
      if not tk_is(id.kind, TkIdent) or not is_upper_ident(p_after_tps.src, id) {
        err_d(p_error(p_after_tps, id, "expected an uppercase protocol name after `impl`"))
      } else {
        let pname = tok_source(p_after_tps.src, id)
        let p1 = p_advance(p_after_tps)
        # Issue #180: optional `[T1, T2, ...]` after the protocol name
        # binds the protocol's type-parameters at this impl-site
        # (`impl Add[Real] for Complex`). Each Ti is a concrete
        # TypeExpr — polymorphism in `Ai` is out of scope (see #174).
        let pa_args_r =
          if p_at(p1, TkLbracket) {
            parse_impl_proto_args(p_skip_newlines(p_advance(p1)), [])
          } else {
            PImplArgs { p: p1, r: Some([]) }
          }
        match pa_args_r.r {
          None -> err_d(pa_args_r.p)
          Some(proto_args) -> {
            let p1b = pa_args_r.p
            let p1n = p_skip_newlines(p1b)
            if not p_at(p1n, TkFor) {
              err_d(p_error_here(p1n, "expected `for` after protocol name in `impl`"))
            } else {
              let p2 = p_skip_newlines(p_advance(p1n))
              let target_r = parse_type(p2)
              match target_r.r {
                None -> err_d(target_r.p)
                Some(target_ty) -> {
                  let p3 = p_skip_newlines(target_r.p)
                  if not p_at(p3, TkLbrace) {
                    err_d(p_error_here(p3, "expected `{` to start impl body"))
                  } else {
                    let p4 = p_skip_newlines(p_advance(p3))
                    let methods_r = parse_impl_methods(p4, [])
                    match methods_r.r {
                      None -> err_d(methods_r.p)
                      Some(ms) -> {
                        let ms2 = prepend_impl_tparams_to_methods(impl_tparams, ms)
                        ok_d(methods_r.p, DImpl(pname, proto_args, target_ty, ms2, t.line, t.col))
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}

# m12.8 phase 2: prepend the impl-level tparams to each method's own
# tparams. Caller has already validated method shape (parse_impl_methods
# only emits DFn nodes).
fn prepend_impl_tparams_to_methods(impl_tps: [String], ms: [Decl]) : [Decl] {
  match impl_tps {
    [] -> ms
    _  -> {
      # Issue #174: tparams may carry bound suffixes (`T#b:Show`).
      # Strip them before injecting into the method's tparam list so
      # the rest of the pipeline (which uses these strings as plain
      # ident keys) sees only `T`. Bounds inform compile-time
      # diagnostics through a separate mechanism — they do not
      # change the method's typing.
      let stripped = map(impl_tps, tp_strip_bounds)
      map(ms, (d) => prepend_impl_tparams_to_method(stripped, d))
    }
  }
}

fn prepend_impl_tparams_to_method(impl_tps: [String], d: Decl) : Decl {
  match d {
    DFn(pub_, n, tps, ps, ret, row, body, l, c, mo) ->
      DFn(pub_, n, list_append(impl_tps, tps), ps, ret, row, body, l, c, mo)
    _ -> d
  }
}

type PImplArgs = { p: Parser, r: Option[[TypeExpr]] }

# Issue #180: parse comma-separated TypeExpr list inside `[...]` after
# the protocol name in `impl P[T1, T2, ...] for U`. Each Ti is a
# fully-elaborated TypeExpr (including `Money[USD]`, `Real<m>`, etc.).
fn parse_impl_proto_args(p: Parser, acc: [TypeExpr]) : PImplArgs / Console {

  let p0 = p_skip_newlines(p)
  if p_at(p0, TkRbracket) {
    PImplArgs { p: p_advance(p0), r: Some(list_reverse(acc)) }
  } else {
    let ty_r = parse_type(p0)
    match ty_r.r {
      None -> PImplArgs { p: ty_r.p, r: None }
      Some(ty) -> {
        let p1 = p_skip_newlines(ty_r.p)
        if p_at(p1, TkComma) {
          parse_impl_proto_args(p_advance(p1), [ty, ...acc])
        } else if p_at(p1, TkRbracket) {
          PImplArgs { p: p_advance(p1), r: Some(list_reverse([ty, ...acc])) }
        } else {
          PImplArgs { p: p_error_here(p1, "expected `,` or `]` in impl protocol arguments"), r: None }
        }
      }
    }
  }
}

type PImplMethods = { p: Parser, r: Option[[Decl]] }

fn parse_impl_methods(p: Parser, acc: [Decl]) : PImplMethods / Console {

  let p0 = p_skip_newlines(p)
  if p_at(p0, TkRbrace) {
    PImplMethods { p: p_advance(p0), r: Some(list_reverse(acc)) }
  } else {
    if not p_at(p0, TkFn) {
      PImplMethods { p: p_error_here(p0, "expected `fn` to start an impl method"), r: None }
    } else {
      let fn_tok = p_peek(p0)
      let p1 = p_advance(p0)
      let dr = parse_fn_decl(p1, false, fn_tok)
      match dr.r {
        None -> PImplMethods { p: dr.p, r: None }
        Some(d) -> parse_impl_methods(dr.p, [d, ...acc])
      }
    }
  }
}

# m12.8: `#derive(P1, P2, ...)` immediately followed by a `type` decl.
# The annotation list is attached to the wrapped DType so the lower
# pass can synthesise structural impls.
fn parse_derive_decl(p: Parser, t: Token) : PDecl / Console {

  if not p_at(p, TkLparen) {
    err_d(p_error_here(p, "expected `(` after `#derive`"))
  } else {
    let p1 = p_skip_newlines(p_advance(p))
    let names_r = parse_derive_names(p1, [])
    match names_r.r {
      None -> err_d(names_r.p)
      Some(names) -> {
        let p2 = p_skip_newlines(names_r.p)
        let p2_pub_r =
          if tk_is(p_peek(p2).kind, TkPub) { PTy { p: p_advance(p2), r: Some(mk_ty(TyName("", []), 0, 0)) } }
          else { PTy { p: p2, r: None } }
        let inner_pub = match p2_pub_r.r { Some(_) -> true None -> false }
        let p3 = p2_pub_r.p
        let hd = p_peek(p3)
        if not tk_is(hd.kind, TkType) {
          err_d(p_error(p3, hd, "`#derive` must precede a `type` declaration"))
        } else {
          let inner = parse_type_decl(p_advance(p3), inner_pub, hd)
          match inner.r {
            None -> err_d(inner.p)
            Some(d) -> ok_d(inner.p, DDerive(names, d, t.line, t.col))
          }
        }
      }
    }
  }
}

type PDeriveNames = { p: Parser, r: Option[[String]] }

fn parse_derive_names(p: Parser, acc: [String]) : PDeriveNames / Console {

  let id = p_peek(p)
  if not tk_is(id.kind, TkIdent) or not is_upper_ident(p.src, id) {
    PDeriveNames { p: p_error(p, id, "expected a protocol name in `#derive(...)`"), r: None }
  } else {
    let name = tok_source(p.src, id)
    let p1 = p_skip_newlines(p_advance(p))
    if p_at(p1, TkComma) {
      parse_derive_names(p_skip_newlines(p_advance(p1)), [name, ...acc])
    } else if p_at(p1, TkRparen) {
      PDeriveNames { p: p_advance(p1), r: Some(list_reverse([name, ...acc])) }
    } else {
      PDeriveNames { p: p_error_here(p1, "expected `,` or `)` in `#derive(...)`"), r: None }
    }
  }
}

fn parse_type_decl(p: Parser, is_pub: Bool, t: Token) : PDecl / Console {

  let id = p_peek(p)
  if not tk_is(id.kind, TkIdent) or not is_upper_ident(p.src, id) {
    err_d(p_error(p, id, "expected an uppercase type name after `type`"))
  } else {
    let name = tok_source(p.src, id)
    let p1 = p_advance(p)
    let p1n = p_skip_newlines(p1)
    # Optional type params `[a, b, c]`.
    let tparams_r =
      if p_at(p1n, TkLbracket) {
        parse_type_params_loop(p_skip_newlines(p_advance(p1n)), [])
      } else {
        PTParams { p: p1n, r: Some([]) }
      }
    match tparams_r.r {
      None -> err_d(tparams_r.p)
      Some(tparams) -> {
        let p2 = p_skip_newlines(tparams_r.p)
        if not p_at(p2, TkEq) {
          err_d(p_error_here(p2, "expected `=` in type declaration"))
        } else {
          let p3 = p_skip_newlines(p_advance(p2))
          parse_type_body(p3, is_pub, name, tparams, t)
        }
      }
    }
  }
}

type PTParams = { p: Parser, r: Option[[String]] }

fn parse_type_params_loop(p: Parser, acc: [String]) : PTParams / Console {

  let t = p_peek(p)
  if not tk_is(t.kind, TkIdent) {
    PTParams { p: p_error(p, t, "expected type parameter name"), r: None }
  } else {
    let raw_name = tok_source(p.src, t)
    let p1 = p_skip_newlines(p_advance(p))
    # m12.5: optional `: Measure` (or `: Type`) kind annotation.
    # Stored by suffixing the param name with "#Unit" for unit-kind
    # params (legacy internal name; surface keyword renamed in #253).
    let kr = parse_optional_kind_annotation(p1)
    let stored = tp_make(raw_name, kr.kind)
    let p2 = p_skip_newlines(kr.p)
    if p_at(p2, TkComma) {
      parse_type_params_loop(p_skip_newlines(p_advance(p2)), [stored, ...acc])
    } else if p_at(p2, TkRbracket) {
      PTParams { p: p_advance(p2), r: Some(list_reverse([stored, ...acc])) }
    } else {
      PTParams { p: p_error_here(p2, "expected `,` or `]` after type parameter"), r: None }
    }
  }
}

# Issue #174: impl-site variant of parse_type_params_loop. Accepts the
# same `Measure` kind annotation as before AND, additionally, a list
# of uppercase protocol-name bounds: `T : Show`, `T : Show + Eq`. The
# bound list is encoded as a `#b:Name1,Name2` suffix in the stored
# tparam string. The `#` is collision-free against kaikai identifiers
# (lexer rejects `#` inside ident).
fn parse_impl_type_params_loop(p: Parser, acc: [String]) : PTParams / Console {

  let t = p_peek(p)
  if not tk_is(t.kind, TkIdent) {
    PTParams { p: p_error(p, t, "expected type parameter name"), r: None }
  } else {
    let raw_name = tok_source(p.src, t)
    let p1 = p_skip_newlines(p_advance(p))
    let kbr = parse_optional_kind_or_bounds(p1)
    let stored = tp_make_with_bounds(raw_name, kbr.kind, kbr.bounds)
    let p2 = p_skip_newlines(kbr.p)
    if p_at(p2, TkComma) {
      parse_impl_type_params_loop(p_skip_newlines(p_advance(p2)), [stored, ...acc])
    } else if p_at(p2, TkRbracket) {
      PTParams { p: p_advance(p2), r: Some(list_reverse([stored, ...acc])) }
    } else {
      PTParams { p: p_error_here(p2, "expected `,` or `]` after type parameter"), r: None }
    }
  }
}

# Issue #174: impl-site colon-suffix parser. Distinguishes:
#   `: Measure`              → kind annotation (legacy)
#   `: Type`                 → kind annotation (legacy, no-op default)
#   `: Show`                 → bound list `[Show]`
#   `: Show + Eq + Ord`      → multi-bound list
# Mixing kinds and bounds is rejected: `: Measure + Show` makes no
# sense since `Measure` is a kind, not a protocol.
type PKindBounds = { p: Parser, kind: Kind, bounds: [String] }

fn parse_optional_kind_or_bounds(p: Parser) : PKindBounds / Console {

  if p_at(p, TkColon) {
    let p1 = p_skip_newlines(p_advance(p))
    let t = p_peek(p1)
    if not tk_is(t.kind, TkIdent) {
      PKindBounds { p: p_error_here(p1, "expected protocol name, `Type`, or `Measure` after `:` in type parameter"),
                    kind: KType, bounds: [] }
    } else {
      let kw = tok_source(p1.src, t)
      let p2 = p_advance(p1)
      if kw == "Measure" { PKindBounds { p: p2, kind: KUnit, bounds: [] } }
      else if kw == "Type" { PKindBounds { p: p2, kind: KType, bounds: [] } }
      else if kw == "Unit" {
        PKindBounds { p: p_error(p1, t, "expected kind `Measure`; `Unit` is the void return type, not a kind (renamed in #253)"),
                      kind: KType, bounds: [] }
      } else if is_upper_ident(p1.src, t) {
        # First bound — accumulate further `+ Bound` entries.
        parse_more_bounds_loop(p2, [kw])
      } else {
        PKindBounds { p: p_error(p1, t, "type-parameter annotation must be `Type`, `Measure`, or an uppercase protocol name"),
                      kind: KType, bounds: [] }
      }
    }
  } else {
    PKindBounds { p: p, kind: KType, bounds: [] }
  }
}

fn parse_more_bounds_loop(p: Parser, acc: [String]) : PKindBounds / Console {

  let p_n = p_skip_newlines(p)
  if p_at(p_n, TkPlus) {
    let p1 = p_skip_newlines(p_advance(p_n))
    let t = p_peek(p1)
    if not tk_is(t.kind, TkIdent) or not is_upper_ident(p1.src, t) {
      PKindBounds { p: p_error_here(p1, "expected uppercase protocol name after `+` in bound list"),
                    kind: KType, bounds: list_reverse(acc) }
    } else {
      let nm = tok_source(p1.src, t)
      parse_more_bounds_loop(p_advance(p1), [nm, ...acc])
    }
  } else {
    PKindBounds { p: p, kind: KType, bounds: list_reverse(acc) }
  }
}

# Issue #174: encode a tparam name plus optional protocol bound list
# into the legacy `String` slot. Format:
#   "T"               (no kind, no bounds)
#   "T#Unit"          (kind = Measure, no bounds)
#   "T#b:Show"        (no kind, single bound)
#   "T#b:Show,Eq"     (no kind, multi-bound)
# Kind and bounds never coexist (parser rejects the combo), so a
# tparam string contains at most one of `#Unit` or `#b:...`.
fn tp_make_with_bounds(name: String, k: Kind, bounds: [String]) : String {
  let with_kind = tp_make(name, k)
  match bounds {
    [] -> with_kind
    _  -> concat_all([with_kind, "#b:", tp_bounds_join(bounds)])
  }
}

fn tp_bounds_join(bs: [String]) : String = match bs {
  [] -> ""
  [b] -> b
  [b, ...rest] -> concat_all([b, ",", tp_bounds_join(rest)])
}

# Decoder helpers — used by lower_protocols / monomorpher to walk an
# impl's tparam list and extract bounds.
fn tp_bounds_marker_index(s: String) : Int =
  tp_bounds_marker_loop(s, 0, string_length(s))

fn tp_bounds_marker_loop(s: String, i: Int, n: Int) : Int {
  if i + 3 > n { -1 }
  else {
    match char_at(s, i) {
      Some(c0) -> if c0 == '#' {
        match char_at(s, i + 1) {
          Some(c1) -> if c1 == 'b' {
            match char_at(s, i + 2) {
              Some(c2) -> if c2 == ':' { i }
                          else { tp_bounds_marker_loop(s, i + 1, n) }
              None -> -1
            }
          } else { tp_bounds_marker_loop(s, i + 1, n) }
          None -> -1
        }
      } else { tp_bounds_marker_loop(s, i + 1, n) }
      None -> -1
    }
  }
}

fn tp_has_bounds(stored: String) : Bool = tp_bounds_marker_index(stored) >= 0

fn tp_strip_bounds(stored: String) : String {
  let i = tp_bounds_marker_index(stored)
  if i < 0 { stored } else { string_slice(stored, 0, i) }
}

fn tp_bounds_of(stored: String) : [String] {
  let i = tp_bounds_marker_index(stored)
  if i < 0 { [] }
  else {
    let start = i + 3
    let suf = string_slice(stored, start, string_length(stored) - start)
    split_csv(suf, [])
  }
}

fn split_csv_index(s: String, i: Int, n: Int) : Int {
  if i >= n { -1 }
  else {
    match char_at(s, i) {
      Some(c) -> if c == ',' { i } else { split_csv_index(s, i + 1, n) }
      None -> -1
    }
  }
}

fn split_csv(s: String, acc: [String]) : [String] {
  let n = string_length(s)
  if n == 0 { list_reverse(acc) }
  else {
    let i = split_csv_index(s, 0, n)
    if i < 0 { list_reverse([s, ...acc]) }
    else {
      let head = string_slice(s, 0, i)
      let rest = string_slice(s, i + 1, n - i - 1)
      split_csv(rest, [head, ...acc])
    }
  }
}

# m12.5: helper — consume an optional `: Type` / `: Measure` kind
# suffix. Defaults to KType when absent, preserving existing
# behaviour. Issue #253: the surface keyword is `Measure` (was
# `Unit` in m12.5–m12.8); the legacy `Unit` produces a targeted
# diagnostic distinguishing it from `Unit` the void-return type.
type PKind = { p: Parser, kind: Kind }

fn parse_optional_kind_annotation(p: Parser) : PKind / Console {

  if p_at(p, TkColon) {
    let p1 = p_skip_newlines(p_advance(p))
    let t = p_peek(p1)
    if not tk_is(t.kind, TkIdent) {
      PKind { p: p_error_here(p1, "expected `Type` or `Measure` after `:` in type parameter"), kind: KType }
    } else {
      let kw = tok_source(p1.src, t)
      let p2 = p_advance(p1)
      if kw == "Measure" { PKind { p: p2, kind: KUnit } }
      else if kw == "Type" { PKind { p: p2, kind: KType } }
      else if kw == "Unit" { PKind { p: p_error(p1, t, "expected kind `Measure`; `Unit` is the void return type, not a kind (renamed in #253)"), kind: KType } }
      else { PKind { p: p_error(p1, t, "type-parameter kind must be `Type` or `Measure`"), kind: KType } }
    }
  } else {
    PKind { p: p, kind: KType }
  }
}

fn parse_type_body(p: Parser, is_pub: Bool, name: String, tparams: [String], t: Token) : PDecl / Console {

  if p_at(p, TkLbrace) {
    let p1 = p_skip_newlines(p_advance(p))
    parse_record_body(p1, [], is_pub, name, tparams, t)
  } else {
    # Sum or alias: check for an uppercase ident followed by `(` OR
    # followed eventually by `|` to decide. Simpler approach: try to
    # parse as sum; if the first variant is followed by `|`, continue
    # as sum; otherwise, fall back to alias. But stage 1 mirrors stage
    # 0: use the same heuristic — if the first token is Uppercase and
    # the next is `(` OR further along we see `|`, treat as sum.
    let hd = p_peek(p)
    if tk_is(hd.kind, TkIdent) and is_upper_ident(p.src, hd) {
      # Effect alias body has the form `Eff1 + Eff2 + ...`. The `+`
      # immediately after the first uppercase ident is the unambiguous
      # signal: type aliases never use `+`, sums use `|`. Single-effect
      # aliases (`type Foo = Console`) parse as TBAlias and are
      # recognised at resolve time. (m7b #1a)
      let nxt = p_peek1(p)
      if tk_is(nxt.kind, TkPlus) {
        let nm = tok_source(p.src, hd)
        parse_effect_alias_body(p_advance(p_advance(p)), [nm], is_pub, name, tparams, t)
      } else {
        let is_sum = looks_like_sum(p)
        if is_sum {
          parse_sum_body(p, [], is_pub, name, tparams, t)
        } else {
          let rt = parse_type(p)
          match rt.r {
            None -> err_d(rt.p)
            Some(aliased) -> ok_d(rt.p, DType(is_pub, name, tparams, TBAlias(aliased), t.line, t.col))
          }
        }
      }
    } else {
      let rt = parse_type(p)
      match rt.r {
        None -> err_d(rt.p)
        Some(aliased) -> ok_d(rt.p, DType(is_pub, name, tparams, TBAlias(aliased), t.line, t.col))
      }
    }
  }
}

# Mirror of stage 0's looks_like_sum heuristic: scan ahead for `|` or
# for `Uppercase(` indicating a variant with payload.
fn looks_like_sum(p: Parser) : Bool {
  let hd = p_peek(p)
  let nxt = p_peek1(p)
  if is_upper_ident(p.src, hd) and tk_is(nxt.kind, TkLparen) { true }
  else { looks_like_sum_scan(p.rest, 0) }
}

fn looks_like_sum_scan(toks: [Token], depth: Int) : Bool {
  match toks {
    [] -> false
    [t, ...rs] -> {
      match t.kind {
        TkEof -> false
        TkLparen -> looks_like_sum_scan(rs, depth + 1)
        TkLbracket -> looks_like_sum_scan(rs, depth + 1)
        TkLbrace -> looks_like_sum_scan(rs, depth + 1)
        TkRparen -> looks_like_sum_scan(rs, depth - 1)
        TkRbracket -> looks_like_sum_scan(rs, depth - 1)
        TkRbrace -> looks_like_sum_scan(rs, depth - 1)
        TkPipe -> if depth == 0 { true } else { looks_like_sum_scan(rs, depth) }
        TkNewline -> if depth == 0 { looks_like_sum_after_nl(rs) }
                     else { looks_like_sum_scan(rs, depth) }
        _ -> looks_like_sum_scan(rs, depth)
      }
    }
  }
}

fn looks_like_sum_after_nl(toks: [Token]) : Bool {
  match toks {
    [] -> false
    [t, ...rs] -> {
      match t.kind {
        TkNewline -> looks_like_sum_after_nl(rs)
        TkPipe -> true
        _ -> false
      }
    }
  }
}

fn parse_record_body(p: Parser, acc: [FieldDecl], is_pub: Bool, name: String, tparams: [String], t: Token) : PDecl / Console {

  let p0 = p_skip_newlines(p)
  if p_at(p0, TkRbrace) {
    ok_d(p_advance(p0), DType(is_pub, name, tparams, TBRecord(list_reverse(acc)), t.line, t.col))
  } else {
    let ft = p_peek(p0)
    if not tk_is(ft.kind, TkIdent) {
      err_d(p_error(p0, ft, "expected field name in record type"))
    } else {
      let fname = tok_source(p0.src, ft)
      let p1 = p_advance(p0)
      if not p_at(p1, TkColon) {
        err_d(p_error_here(p1, "expected `:` after field name"))
      } else {
        let rt = parse_type(p_advance(p1))
        match rt.r {
          None -> err_d(rt.p)
          Some(ty) -> {
            let fd = FD(fname, ty)
            let p2 = p_skip_newlines(rt.p)
            if p_at(p2, TkComma) {
              parse_record_body(p_skip_newlines(p_advance(p2)), [fd, ...acc], is_pub, name, tparams, t)
            } else if p_at(p2, TkRbrace) {
              ok_d(p_advance(p2), DType(is_pub, name, tparams, TBRecord(list_reverse([fd, ...acc])), t.line, t.col))
            } else {
              err_d(p_error_here(p2, "expected `,` or `}` in record type"))
            }
          }
        }
      }
    }
  }
}

# m7b #1a — closed effect-alias body. Caller has consumed the first
# label and the `+` separator; `acc` holds the labels parsed so far in
# reverse order. Subsequent labels must be uppercase idents separated
# by `+`. Validation that each label refers to a declared effect, plus
# cycle detection, is m7b #1c at resolve time.
fn parse_effect_alias_body(p: Parser, acc: [String], is_pub: Bool, name: String, tparams: [String], t: Token) : PDecl / Console {

  let hd = p_peek(p)
  if not tk_is(hd.kind, TkIdent) or not is_upper_ident(p.src, hd) {
    err_d(p_error(p, hd, "expected uppercase effect name in effect alias"))
  } else {
    let nm = tok_source(p.src, hd)
    let p1 = p_advance(p)
    let acc1 = [nm, ...acc]
    if p_at(p1, TkPlus) {
      parse_effect_alias_body(p_advance(p1), acc1, is_pub, name, tparams, t)
    } else {
      ok_d(p1, DType(is_pub, name, tparams, TBEffectAlias(list_reverse(acc1)), t.line, t.col))
    }
  }
}

fn parse_sum_body(p: Parser, acc: [Variant], is_pub: Bool, name: String, tparams: [String], t: Token) : PDecl / Console {

  let p0 = p_skip_newlines(p)
  let vt = p_peek(p0)
  if not tk_is(vt.kind, TkIdent) or not is_upper_ident(p0.src, vt) {
    err_d(p_error(p0, vt, "expected variant constructor name"))
  } else {
    let vname = tok_source(p0.src, vt)
    let p1 = p_advance(p0)
    let args_r =
      if p_at(p1, TkLparen) {
        parse_variant_args(p_skip_newlines(p_advance(p1)), [])
      } else {
        PVariantArgs { p: p1, r: Some([]) }
      }
    match args_r.r {
      None -> err_d(args_r.p)
      Some(vargs) -> {
        let vnode = Var(vname, vargs)
        let p2 = p_skip_newlines(args_r.p)
        if p_at(p2, TkPipe) {
          parse_sum_body(p_skip_newlines(p_advance(p2)), [vnode, ...acc], is_pub, name, tparams, t)
        } else {
          ok_d(p2, DType(is_pub, name, tparams, TBSum(list_reverse([vnode, ...acc])), t.line, t.col))
        }
      }
    }
  }
}

type PVariantArgs = { p: Parser, r: Option[[TypeExpr]] }

fn parse_variant_args(p: Parser, acc: [TypeExpr]) : PVariantArgs / Console {

  if p_at(p, TkRparen) { PVariantArgs { p: p_advance(p), r: Some(list_reverse(acc)) } }
  else {
    let r = parse_type(p)
    match r.r {
      None -> PVariantArgs { p: r.p, r: None }
      Some(ty) -> {
        let p1 = p_skip_newlines(r.p)
        if p_at(p1, TkComma) {
          parse_variant_args(p_skip_newlines(p_advance(p1)), [ty, ...acc])
        } else if p_at(p1, TkRparen) {
          PVariantArgs { p: p_advance(p1), r: Some(list_reverse([ty, ...acc])) }
        } else {
          PVariantArgs { p: p_error_here(p1, "expected `,` or `)` in variant payload"), r: None }
        }
      }
    }
  }
}

fn parse_test_decl(p: Parser, t: Token) : PDecl / Console {

  let desc_t = p_peek(p)
  if not tk_is(desc_t.kind, TkString) {
    err_d(p_error(p, desc_t, "expected string description after `test`"))
  } else {
    let desc_span = tok_source(p.src, desc_t)
    let p1 = p_skip_newlines(p_advance(p))
    if not p_at(p1, TkLbrace) {
      err_d(p_error_here(p1, "expected `{` for test body"))
    } else {
      let tb = p_peek(p1)
      let rb = parse_block(p1, tb)
      match rb.r {
        None -> err_d(rb.p)
        Some(body) -> ok_d(rb.p, DTest(desc_span, body, t.line, t.col))
      }
    }
  }
}

# bench v1 (issue #40): structural mirror of parse_test_decl. The
# runner times the body N=1000 times and reports mean ns/iter.
fn parse_bench_decl(p: Parser, t: Token) : PDecl / Console {

  let desc_t = p_peek(p)
  if not tk_is(desc_t.kind, TkString) {
    err_d(p_error(p, desc_t, "expected string description after `bench`"))
  } else {
    let desc_span = tok_source(p.src, desc_t)
    let p1 = p_skip_newlines(p_advance(p))
    if not p_at(p1, TkLbrace) {
      err_d(p_error_here(p1, "expected `{` for bench body"))
    } else {
      let tb = p_peek(p1)
      let rb = parse_block(p1, tb)
      match rb.r {
        None -> err_d(rb.p)
        Some(body) -> ok_d(rb.p, DBench(desc_span, body, t.line, t.col))
      }
    }
  }
}

# check v1 (issue #44): property-based test block.
# Syntax:
#   check "<description>" [with name: T, name: T, ...] { body }
# The body is evaluated KAI_CHECK_ITERS times (default 100). Each
# iteration generates random values for the `with`-clause params via
# arbitrary[T]() runtime helpers and runs the body. The body must
# produce a Bool — true means the property holds for that input,
# false records a counterexample and exits the check early. v1 only
# reports the counterexample that triggered the failure (no
# shrinking).
fn parse_check_with_params(p: Parser, acc: [Param]) : PParams / Console {

  let t = p_peek(p)
  if not tk_is(t.kind, TkIdent) {
    PParams { p: p_error(p, t, "expected parameter name in `with` clause"), r: None }
  } else {
    let name = tok_source(p.src, t)
    let p1 = p_advance(p)
    if not p_at(p1, TkColon) {
      PParams { p: p_error_here(p1, "expected `:` after `with` parameter name"), r: None }
    } else {
      let rt = parse_type(p_advance(p1))
      match rt.r {
        None -> PParams { p: rt.p, r: None }
        Some(ty) -> {
          let param = Param { pname: name, ptype: Some(ty), pline: t.line, pcol: t.col }
          let p2 = p_skip_newlines(rt.p)
          if p_at(p2, TkComma) {
            parse_check_with_params(p_skip_newlines(p_advance(p2)), [param, ...acc])
          } else {
            PParams { p: p2, r: Some(list_reverse([param, ...acc])) }
          }
        }
      }
    }
  }
}

fn parse_check_decl(p: Parser, t: Token) : PDecl / Console {

  let desc_t = p_peek(p)
  if not tk_is(desc_t.kind, TkString) {
    err_d(p_error(p, desc_t, "expected string description after `check`"))
  } else {
    let desc_span = tok_source(p.src, desc_t)
    let p1 = p_skip_newlines(p_advance(p))
    let pwith = if p_at(p1, TkWith) {
      parse_check_with_params(p_skip_newlines(p_advance(p1)), [])
    } else {
      PParams { p: p1, r: Some([]) }
    }
    match pwith.r {
      None -> err_d(pwith.p)
      Some(params) -> {
        let p2 = p_skip_newlines(pwith.p)
        if not p_at(p2, TkLbrace) {
          err_d(p_error_here(p2, "expected `{` for check body"))
        } else {
          let tb = p_peek(p2)
          let rb = parse_block(p2, tb)
          match rb.r {
            None -> err_d(rb.p)
            Some(body) -> ok_d(rb.p, DCheck(desc_span, params, body, t.line, t.col))
          }
        }
      }
    }
  }
}

fn parse_import_decl(p: Parser, t: Token) : PDecl / Console {

  # For stage 1 MVP, imports are structurally parsed but not resolved.
  # Accept: `import a.b.c`, `import a.b.c as X`, `import a.b.c.{f, g}`.
  # m7f §7: `import ?name` — dependency hole. Symbol-index resolver
  # runs after normal imports and reports candidates.
  let first = p_peek(p)
  if match first.kind { TkHoleName(_) -> true _ -> false } {
    let nm = match first.kind { TkHoleName(n) -> n _ -> "" }
    ok_d(p_advance(p), DImport(IkHole(nm), t.line, t.col))
  } else if tk_is(first.kind, TkHole) {
    err_d(p_error(p, first, "`import ?` requires a name; write `import ?some_symbol`"))
  } else if not tk_is(first.kind, TkIdent) {
    err_d(p_error(p, first, "expected module name after `import`"))
  } else {
    parse_import_path(p_advance(p), tok_source(p.src, first), t)
  }
}

fn parse_import_path(p: Parser, acc_path: String, t: Token) : PDecl / Console {

  if p_at(p, TkDot) {
    let p1 = p_advance(p)
    let nxt = p_peek(p1)
    if tk_is(nxt.kind, TkIdent) {
      let seg = tok_source(p1.src, nxt)
      parse_import_path(p_advance(p1), string_concat(string_concat(acc_path, "."), seg), t)
    } else if tk_is(nxt.kind, TkLbrace) {
      # Selective: `.{a, b}`
      parse_import_selectives(p_skip_newlines(p_advance(p1)), [], acc_path, t)
    } else {
      err_d(p_error_here(p1, "expected identifier or `{` after `.`"))
    }
  } else if p_at(p, TkAs) {
    let p1 = p_advance(p)
    let nxt = p_peek(p1)
    if not tk_is(nxt.kind, TkIdent) {
      err_d(p_error(p1, nxt, "expected alias name after `as`"))
    } else {
      let alias = tok_source(p1.src, nxt)
      ok_d(p_advance(p1), DImport(IkAlias(acc_path, alias), t.line, t.col))
    }
  } else {
    ok_d(p, DImport(IkPath(acc_path), t.line, t.col))
  }
}

fn parse_import_selectives(p: Parser, acc: [String], path: String, t: Token) : PDecl / Console {

  let p0 = p_skip_newlines(p)
  let nxt = p_peek(p0)
  if not tk_is(nxt.kind, TkIdent) {
    err_d(p_error(p0, nxt, "expected identifier in selective import"))
  } else {
    let name = tok_source(p0.src, nxt)
    let p1 = p_skip_newlines(p_advance(p0))
    if p_at(p1, TkComma) {
      parse_import_selectives(p_skip_newlines(p_advance(p1)), [name, ...acc], path, t)
    } else if p_at(p1, TkRbrace) {
      ok_d(p_advance(p1), DImport(IkSelective(path, list_reverse([name, ...acc])), t.line, t.col))
    } else {
      err_d(p_error_here(p1, "expected `,` or `}` in selective import"))
    }
  }
}

# ====================================================================
# program
# ====================================================================

fn parse_program_loop(p: Parser, acc: [Decl]) : PParser / Console {

  let p0 = p_skip_newlines(p)
  if p_at(p0, TkEof) {
    # m12.6.x #6: a parser that accumulated errors (e.g. via
    # check_pred_not_false in parse_contracts_loop) must not let
    # the driver claim success. Surface had_error as `decls: None`
    # so the entry point exits non-zero, even when every decl
    # parsed in shape.
    if p0.had_error { PParser { p: p0, decls: None } }
    else { PParser { p: p0, decls: Some(list_reverse(acc)) } }
  }
  else {
    let r = parse_decl(p0)
    match r.r {
      None -> PParser { p: r.p, decls: None }
      Some(d) -> parse_program_loop(r.p, [d, ...acc])
    }
  }
}

type PParser = { p: Parser, decls: Option[[Decl]] }

fn parse_program(file: String, src: String, toks: [Token]) : PParser / Console {

  parse_program_loop(parser_new(file, src, toks), [])
}

# ====================================================================
# AST dumper (for --ast)
# ====================================================================
#
# The format is indented nesting, one node per line. It does not try
# to match stage 0's kai_dump_ast byte-for-byte; the value here is to
# help visually inspect stage 1's parser while the emitter is being
# written.

fn indent_of(depth: Int) : String {
  if depth == 0 { "" } else { string_concat("  ", indent_of(depth - 1)) }
}

fn emit_line(depth: Int, s: String) : Unit / Console = print("#{indent_of(depth)}#{s}")

fn dump_expr(e: Expr, depth: Int) : Unit / Console {

  match e.kind {
    EInt(n) -> emit_line(depth, "int #{int_to_string(n)} @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
    EReal(r) -> emit_line(depth, "real #{real_to_string(r)} @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
    EBool(b) -> {
      let s = if b { "true" } else { "false" }
      emit_line(depth, "bool #{s} @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
    }
    EChar(c) -> emit_line(depth, "char '#{c}' @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
    EStr(s, _) -> emit_line(depth, "string #{s} @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
    EUnit -> emit_line(depth, "unit @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
    EVar(name) -> emit_line(depth, "ident #{name} @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
    EUnder -> emit_line(depth, "_ @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
    EPlaceholder -> emit_line(depth, ". @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
    ECall(callee, xs) -> {
      emit_line(depth, "call @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      dump_expr(callee, depth + 1)
      xs |> each((a) => dump_expr(a, depth + 1))
    }
    EField(base, name) -> {
      emit_line(depth, "field .#{name} @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      dump_expr(base, depth + 1)
    }
    EIndex(base, idx) -> {
      emit_line(depth, "index @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      dump_expr(base, depth + 1)
      dump_expr(idx, depth + 1)
    }
    EBinop(op, a, b) -> {
      emit_line(depth, "binop #{op} @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      dump_expr(a, depth + 1)
      dump_expr(b, depth + 1)
    }
    EUnop(op, x) -> {
      emit_line(depth, "unop #{op} @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      dump_expr(x, depth + 1)
    }
    EIf(c, a, opt_b) -> {
      emit_line(depth, "if @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      dump_expr(c, depth + 1)
      dump_expr(a, depth + 1)
      match opt_b { Some(b) -> dump_expr(b, depth + 1) None -> () }
    }
    EMatch(scrut, arms) -> {
      emit_line(depth, "match @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      dump_expr(scrut, depth + 1)
      arms |> each((a) => dump_arm(a, depth + 1))
    }
    ELambda(params, body) -> {
      emit_line(depth, "lambda @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      params |> each((pm) => emit_line(depth + 1, "param #{pm.pname}"))
      dump_expr(body, depth + 1)
    }
    ERecordLit(name, fields) -> {
      emit_line(depth, "record #{name} @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      fields |> each((fi) => dump_field_init(fi, depth + 1))
    }
    EList(elems) -> {
      emit_line(depth, "list @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      elems |> each((el) => dump_list_elem(el, depth + 1))
    }
    ERange(a, b, opt_step) -> {
      emit_line(depth, "range @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      dump_expr(a, depth + 1)
      dump_expr(b, depth + 1)
      match opt_step { Some(s) -> dump_expr(s, depth + 1) None -> () }
    }
    EBlock(stmts, opt_final) -> {
      emit_line(depth, "block @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      stmts |> each((s) => dump_stmt(s, depth + 1))
      match opt_final { Some(fe) -> dump_expr(fe, depth + 1) None -> () }
    }
    EPipe(a, b) -> {
      emit_line(depth, "pipe @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      dump_expr(a, depth + 1)
      dump_expr(b, depth + 1)
    }
    EMapPipe(a, b) -> {
      emit_line(depth, "map_pipe @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      dump_expr(a, depth + 1)
      dump_expr(b, depth + 1)
    }
    EFlatMapPipe(a, b) -> {
      emit_line(depth, "flat_map_pipe @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      dump_expr(a, depth + 1)
      dump_expr(b, depth + 1)
    }
    EFilterPipe(a, b) -> {
      emit_line(depth, "filter_pipe @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      dump_expr(a, depth + 1)
      dump_expr(b, depth + 1)
    }
    EHole(nm_opt) -> {
      let label = match nm_opt { Some(nm) -> cat2("?", nm) None -> "?" }
      emit_line(depth, "hole #{label} @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
    }
    ETodo(msg) ->
      emit_line(depth, "todo \"#{msg}\" @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
    EBang(inner) -> {
      emit_line(depth, "bang @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      dump_expr(inner, depth + 1)
    }
    EHandle(body, eff_name, eff_tyargs, init_opt, alias_opt, clauses, ret_opt) -> {
      let alias_s = match alias_opt { Some(a) -> string_concat(" as ", a) None -> "" }
      let targs_s = match eff_tyargs {
        [] -> ""
        _ -> concat_all(["[", join_with(map(eff_tyargs, type_expr_display), ", "), "]"])
      }
      emit_line(depth, "handle #{eff_name}#{targs_s}#{alias_s} @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      match init_opt {
        Some(ie) -> { emit_line(depth + 1, "init") dump_expr(ie, depth + 2) }
        None -> ()
      }
      emit_line(depth + 1, "body")
      dump_expr(body, depth + 2)
      clauses |> each((c) => dump_hclause(c, depth + 1))
      match ret_opt { Some(r) -> dump_hreturn(r, depth + 1) None -> () }
    }
    ELitUnit(inner, u) -> {
      emit_line(depth, "lit-unit <#{unit_expr_display(u)}> @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      dump_expr(inner, depth + 1)
    }
    EVariantsOf(ty, _) ->
      emit_line(depth, "variants-of #{type_expr_display(ty)} @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
    # m6.2: qualified module call. Two strings (module + fn).
    EModCall(m, fname) ->
      emit_line(depth, "modcall #{m}.#{fname} @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
  }
}

fn dump_hclause(c: HClause, depth: Int) : Unit / Console {

  match c {
    HC(name, params, body, line, col) -> {
      emit_line(depth, "clause #{name} @#{int_to_string(line)}:#{int_to_string(col)}")
      params |> each((pm) => dump_param(pm, depth + 1))
      dump_expr(body, depth + 1)
    }
  }
}

fn dump_hreturn(r: HReturn, depth: Int) : Unit / Console {

  match r {
    HR(name, body, line, col) -> {
      emit_line(depth, "return #{name} @#{int_to_string(line)}:#{int_to_string(col)}")
      dump_expr(body, depth + 1)
    }
  }
}

fn dump_arm(a: Arm, depth: Int) : Unit / Console {

  emit_line(depth, "arm")
  match a {
    Arm(pat, guard, body) -> {
      dump_pat(pat, depth + 1)
      match guard { Some(g) -> { emit_line(depth + 1, "guard"); dump_expr(g, depth + 2) } None -> () }
      dump_expr(body, depth + 1)
    }
  }
}

fn dump_field_init(fi: FieldInit, depth: Int) : Unit / Console {

  match fi {
    FI(name, val) -> {
      emit_line(depth, "field_init #{name}")
      dump_expr(val, depth + 1)
    }
  }
}

fn dump_list_elem(el: ListElem, depth: Int) : Unit / Console {

  match el {
    ElPlain(e) -> dump_expr(e, depth)
    ElSpread(e) -> {
      emit_line(depth, "spread")
      dump_expr(e, depth + 1)
    }
  }
}

fn dump_stmt(s: Stmt, depth: Int) : Unit / Console {

  match s {
    SLet(pat, opt_ty, rhs) -> {
      emit_line(depth, "let")
      dump_pat(pat, depth + 1)
      match opt_ty { Some(ty) -> dump_type(ty, depth + 1) None -> () }
      dump_expr(rhs, depth + 1)
    }
    SAssert(cond, opt_msg) -> {
      emit_line(depth, "assert")
      dump_expr(cond, depth + 1)
      match opt_msg { Some(m) -> dump_expr(m, depth + 1) None -> () }
    }
    SExprStmt(e) -> dump_expr(e, depth)
    SIndexAssign(base, idx, val, line, col) -> {
      emit_line(depth, "index-assign @#{int_to_string(line)}:#{int_to_string(col)}")
      dump_expr(base, depth + 1)
      dump_expr(idx, depth + 1)
      dump_expr(val, depth + 1)
    }
    SVar(name, opt_ty, rhs, line, col) -> {
      emit_line(depth, "var #{name} @#{int_to_string(line)}:#{int_to_string(col)}")
      match opt_ty { Some(ty) -> dump_type(ty, depth + 1) None -> () }
      dump_expr(rhs, depth + 1)
    }
    SUse(name, line, col) ->
      emit_line(depth, "use #{name} @#{int_to_string(line)}:#{int_to_string(col)}")
  }
}

fn dump_pat(pat: Pattern, depth: Int) : Unit / Console {

  match pat.pkind {
    PWild -> emit_line(depth, "pat _ @#{int_to_string(pat.line)}:#{int_to_string(pat.col)}")
    PLit(e) -> {
      emit_line(depth, "pat_lit @#{int_to_string(pat.line)}:#{int_to_string(pat.col)}")
      dump_expr(e, depth + 1)
    }
    PBind(name) -> emit_line(depth, "pat_bind #{name} @#{int_to_string(pat.line)}:#{int_to_string(pat.col)}")
    PList(pats, opt_rest) -> {
      emit_line(depth, "pat_list @#{int_to_string(pat.line)}:#{int_to_string(pat.col)}")
      pats |> each((pp) => dump_pat(pp, depth + 1))
      match opt_rest { Some(r) -> emit_line(depth + 1, "...#{r}") None -> () }
    }
    PVariant(name, subs) -> {
      emit_line(depth, "pat_variant #{name} @#{int_to_string(pat.line)}:#{int_to_string(pat.col)}")
      subs |> each((pp) => dump_pat(pp, depth + 1))
    }
    PVariantRecord(name, fields) -> {
      emit_line(depth, "pat_variant_record #{name} @#{int_to_string(pat.line)}:#{int_to_string(pat.col)}")
      fields |> each((pf) => dump_pfield(pf, depth + 1))
    }
    PRecord(fields) -> {
      emit_line(depth, "pat_record @#{int_to_string(pat.line)}:#{int_to_string(pat.col)}")
      fields |> each((pf) => dump_pfield(pf, depth + 1))
    }
    PHole(nm_opt) -> {
      let label = match nm_opt { Some(nm) -> cat2("?", nm) None -> "?" }
      emit_line(depth, "pat_hole #{label} @#{int_to_string(pat.line)}:#{int_to_string(pat.col)}")
    }
    PAs(name, sub) -> {
      emit_line(depth, "pat_as #{name} @#{int_to_string(pat.line)}:#{int_to_string(pat.col)}")
      dump_pat(sub, depth + 1)
    }
    PNarrow(name, ty) -> {
      emit_line(depth, "pat_narrow #{name} @#{int_to_string(pat.line)}:#{int_to_string(pat.col)}")
      dump_type(ty, depth + 1)
    }
  }
}

fn dump_pfield(pf: PField, depth: Int) : Unit / Console {

  match pf {
    PField(name, sub, short) -> {
      let suffix = if short { " (shorthand)" } else { "" }
      emit_line(depth, "pat_field #{name}#{suffix}")
      dump_pat(sub, depth + 1)
    }
  }
}

fn dump_type(ty: TypeExpr, depth: Int) : Unit / Console {

  match ty.tkind {
    TyName(name, targs) -> {
      emit_line(depth, "ty_name #{name} @#{int_to_string(ty.line)}:#{int_to_string(ty.col)}")
      targs |> each((a) => dump_type(a, depth + 1))
    }
    TyList(inner) -> {
      emit_line(depth, "ty_list @#{int_to_string(ty.line)}:#{int_to_string(ty.col)}")
      dump_type(inner, depth + 1)
    }
    TyFn(targs, ret, row) -> {
      emit_line(depth, "ty_fn @#{int_to_string(ty.line)}:#{int_to_string(ty.col)}")
      targs |> each((a) => dump_type(a, depth + 1))
      dump_type(ret, depth + 1)
      dump_row_expr(row, depth + 1)
    }
    TyDim(base, u) -> {
      emit_line(depth, "ty_dim <#{unit_expr_display(u)}> @#{int_to_string(ty.line)}:#{int_to_string(ty.col)}")
      dump_type(base, depth + 1)
    }
    TyRefine(base, _) -> {
      emit_line(depth, "ty_refine @#{int_to_string(ty.line)}:#{int_to_string(ty.col)}")
      dump_type(base, depth + 1)
    }
  }
}

fn dump_row_expr(r: RowExpr, depth: Int) : Unit / Console {

  match r {
    REmpty -> ()
    RClosed(labels) -> {
      let s = if labels == [] { "row (empty)" }
              else { string_concat("row ", join_with(map(labels, row_label_display), " + ")) }
      emit_line(depth, s)
    }
    ROpen(rv, labels) -> {
      let s = if labels == [] { string_concat("row ", rv) }
              else { string_concat("row ",
                       string_concat(join_with(map(labels, row_label_display), " + "),
                         string_concat(" + ", rv))) }
      emit_line(depth, s)
    }
  }
}

# m7b #11 — render `RowLabel` for diagnostics and dumps. Effect names
# without type args render as the bare name; parameterised effects
# render as `Eff[T1, T2]`. The rendered TypeExpr arguments use the
# coarse `type_expr_display` helper — fine for diagnostics, not a
# canonical pretty-printer.
fn row_label_display(rl: RowLabel) : String {
  match rl {
    RL(name, []) -> name
    RL(name, args) -> concat_all([name, "[", join_with(map(args, type_expr_display), ", "), "]"])
  }
}

fn type_expr_display(t: TypeExpr) : String {
  match t.tkind {
    TyName(name, []) -> name
    TyName(name, ts) -> concat_all([name, "[", join_with(map(ts, type_expr_display), ", "), "]"])
    TyList(inner) -> concat_all(["[", type_expr_display(inner), "]"])
    TyFn(ps, ret, _) -> concat_all([
      "(", join_with(map(ps, type_expr_display), ", "), ") -> ", type_expr_display(ret)
    ])
    TyDim(base, u) -> concat_all([type_expr_display(base), "<", unit_expr_display(u), ">"])
    TyRefine(base, _) -> concat_all([type_expr_display(base), " where <pred>"])
  }
}

# m12.5: render a UnitExprT as user-readable text. The display is *not*
# the canonical form (which lives as Map[Sym,Int]); it's the tree shape
# the parser produced, with light cleanup. Use unit_canon_display for
# canonical output.
#
# Style: scientific notation. Multiplication renders as a single space
# (`kg m`), division renders with `/` and no surrounding spaces
# (`m/s`, `kg m/s^2`). Powers use `^` with the integer literal
# (`m^2`, `s^-1`). `UOne` factors are dropped.
fn unit_expr_display(u: UnitExprT) : String {
  match u {
    UOne -> "1"
    USym(s) -> s
    UMul(a, b) -> match b {
      UInv(b_inner) -> match a {
        UOne -> concat_all(["1/", unit_expr_display(b_inner)])
        _    -> concat_all([unit_expr_display(a), "/", unit_expr_display(b_inner)])
      }
      UOne -> unit_expr_display(a)
      _ -> match a {
        UOne -> unit_expr_display(b)
        UInv(a_inner) -> concat_all([unit_expr_display(b), "/", unit_expr_display(a_inner)])
        _ -> concat_all([unit_expr_display(a), " ", unit_expr_display(b)])
      }
    }
    UInv(a) -> concat_all(["1/", unit_expr_display(a)])
    UPow(a, n) -> concat_all([unit_expr_display(a), "^", int_to_string(n)])
    UVar(n) -> cat2("?u", int_to_string(n))
  }
}

# Extract just the eff names from a row's labels — useful for the
# many string-based passes in the resolver that don't need the type
# args. Parametric effects are projected to their bare name (so
# `Reader[Int]` and `Reader[String]` both yield `Reader`); callers
# that need to distinguish instantiations work on the full label list.
fn row_label_names(labels: [RowLabel]) : [String] {
  match labels {
    [] -> []
    [l, ...rest] -> match l {
      RL(name, _) -> [name, ...row_label_names(rest)]
    }
  }
}

fn dump_decl(d: Decl, depth: Int) : Unit / Console {

  match d {
    DFn(is_pub, name, tparams, params, opt_ret, row, body, line, col, _) -> {
      let pub_s = if is_pub { "pub " } else { "" }
      emit_line(depth, "fn #{pub_s}\"#{name}\" @#{int_to_string(line)}:#{int_to_string(col)}")
      tparams |> each((tp) => emit_line(depth + 1, "tparam #{tp}"))
      params |> each((pm) => dump_param(pm, depth + 1))
      match opt_ret { Some(ty) -> dump_type(ty, depth + 1) None -> () }
      dump_row_expr(row, depth + 1)
      dump_expr(body, depth + 1)
    }
    DAxiom(is_pub, extern_c, name, c_sym_over, tparams, params, ret_ty, row, line, col) -> {
      let pub_s = if is_pub { "pub " } else { "" }
      let ext_s = if extern_c {
        if string_length(c_sym_over) > 0 {
          string_concat("extern_c(\"", string_concat(c_sym_over, "\") "))
        } else { "extern_c " }
      } else { "" }
      emit_line(depth, "axiom #{ext_s}#{pub_s}\"#{name}\" @#{int_to_string(line)}:#{int_to_string(col)}")
      tparams |> each((tp) => emit_line(depth + 1, "tparam #{tp}"))
      params |> each((pm) => dump_param(pm, depth + 1))
      dump_type(ret_ty, depth + 1)
      dump_row_expr(row, depth + 1)
    }
    DConst(is_pub, name, ty, body, line, col) -> {
      let pub_s = if is_pub { "pub " } else { "" }
      emit_line(depth, "const #{pub_s}\"#{name}\" @#{int_to_string(line)}:#{int_to_string(col)}")
      dump_type(ty, depth + 1)
      dump_expr(body, depth + 1)
    }
    DType(is_pub, name, tparams, body, line, col) -> {
      let pub_s = if is_pub { "pub " } else { "" }
      emit_line(depth, "type #{pub_s}\"#{name}\" @#{int_to_string(line)}:#{int_to_string(col)}")
      tparams |> each((tp) => emit_line(depth + 1, "tparam #{tp}"))
      dump_type_body(body, depth + 1)
    }
    DTest(desc, body, line, col) -> {
      emit_line(depth, "test #{desc} @#{int_to_string(line)}:#{int_to_string(col)}")
      dump_expr(body, depth + 1)
    }
    DBench(desc, body, line, col) -> {
      emit_line(depth, "bench #{desc} @#{int_to_string(line)}:#{int_to_string(col)}")
      dump_expr(body, depth + 1)
    }
    DCheck(desc, params, body, line, col) -> {
      emit_line(depth, "check #{desc} @#{int_to_string(line)}:#{int_to_string(col)}")
      params |> each((pm) => dump_param(pm, depth + 1))
      dump_expr(body, depth + 1)
    }
    DImport(ik, line, col) -> {
      match ik {
        IkPath(path) -> emit_line(depth, "import #{path} @#{int_to_string(line)}:#{int_to_string(col)}")
        IkAlias(path, a) -> emit_line(depth, "import #{path} as #{a} @#{int_to_string(line)}:#{int_to_string(col)}")
        IkSelective(path, names) -> {
          emit_line(depth, "import #{path} @#{int_to_string(line)}:#{int_to_string(col)}")
          names |> each((n) => emit_line(depth + 1, "sel #{n}"))
        }
        IkHole(name) -> emit_line(depth, "import ?#{name} @#{int_to_string(line)}:#{int_to_string(col)}")
      }
    }
    DEffect(is_pub, name, tparams, ops, line, col) -> {
      let pub_s = if is_pub { "pub " } else { "" }
      emit_line(depth, "effect #{pub_s}\"#{name}\" @#{int_to_string(line)}:#{int_to_string(col)}")
      tparams |> each((tp) => emit_line(depth + 1, "tparam #{tp}"))
      ops |> each((op) => dump_effect_op(op, depth + 1))
    }
    DProtocol(is_pub, name, tparams, ops, line, col) -> {
      let pub_s = if is_pub { "pub " } else { "" }
      emit_line(depth, "protocol #{pub_s}\"#{name}\" @#{int_to_string(line)}:#{int_to_string(col)}")
      tparams |> each((tp) => emit_line(depth + 1, "tparam #{tp}"))
      ops |> each((op) => dump_proto_op(op, depth + 1))
    }
    DImpl(pname, proto_args, target, ms, line, col) -> {
      emit_line(depth, "impl \"#{pname}\" for @#{int_to_string(line)}:#{int_to_string(col)}")
      proto_args |> each((pa) => dump_type(pa, depth + 1))
      dump_type(target, depth + 1)
      ms |> each((m) => dump_decl(m, depth + 1))
    }
    DDerive(names, inner, line, col) -> {
      let names_s = join_with(names, ", ")
      emit_line(depth, "#derive(#{names_s}) @#{int_to_string(line)}:#{int_to_string(col)}")
      dump_decl(inner, depth + 1)
    }
    DUnit(is_pub, name, alias_opt, line, col) -> {
      let pub_s = if is_pub { "pub " } else { "" }
      let body_s = match alias_opt {
        None -> ""
        Some(u) -> string_concat(" = ", unit_expr_display(u))
      }
      emit_line(depth, "unit #{pub_s}\"#{name}\"#{body_s} @#{int_to_string(line)}:#{int_to_string(col)}")
    }
    DUse(name, line, col) ->
      emit_line(depth, "use #{name} @#{int_to_string(line)}:#{int_to_string(col)}")
    # m12.6.x #5(a): unwrap and recurse so --ast shows the inner DFn
    # alongside an attribute marker line.
    DAttribPure(inner, line, col) -> {
      emit_line(depth, "attrib refinement_pure @#{int_to_string(line)}:#{int_to_string(col)}")
      dump_decl(inner, depth + 1)
    }
  }
}

fn dump_proto_op(op: ProtoOp, depth: Int) : Unit / Console {

  match op {
    POp(name, op_tparams, params, ret, line, col) -> {
      emit_line(depth, "op \"#{name}\" @#{int_to_string(line)}:#{int_to_string(col)}")
      op_tparams |> each((tp) => emit_line(depth + 1, "op_tparam #{tp}"))
      params |> each((pm) => dump_param(pm, depth + 1))
      dump_type(ret, depth + 1)
    }
  }
}

fn dump_effect_op(op: EffectOp, depth: Int) : Unit / Console {

  match op {
    EOp(name, op_tparams, params, ret, line, col) -> {
      emit_line(depth, "op \"#{name}\" @#{int_to_string(line)}:#{int_to_string(col)}")
      op_tparams |> each((tp) => emit_line(depth + 1, "op_tparam #{tp}"))
      params |> each((pm) => dump_param(pm, depth + 1))
      dump_type(ret, depth + 1)
    }
  }
}

fn dump_param(pm: Param, depth: Int) : Unit / Console {

  emit_line(depth, "param #{pm.pname} @#{int_to_string(pm.pline)}:#{int_to_string(pm.pcol)}")
  match pm.ptype { Some(ty) -> dump_type(ty, depth + 1) None -> () }
}

fn dump_type_body(tb: TypeBody, depth: Int) : Unit / Console {

  match tb {
    TBAlias(ty) -> {
      emit_line(depth, "ty_alias")
      dump_type(ty, depth + 1)
    }
    TBRecord(fields) -> {
      emit_line(depth, "ty_record")
      fields |> each((fd) => dump_field_decl(fd, depth + 1))
    }
    TBSum(variants) -> {
      emit_line(depth, "ty_sum")
      variants |> each((v) => dump_variant(v, depth + 1))
    }
    TBEffectAlias(labels) -> {
      let s = if labels == [] { "ty_effect_alias (empty)" }
              else { string_concat("ty_effect_alias ", join_with(labels, " + ")) }
      emit_line(depth, s)
    }
  }
}

fn dump_field_decl(fd: FieldDecl, depth: Int) : Unit / Console {

  match fd {
    FD(name, ty) -> {
      emit_line(depth, "field_decl #{name}")
      dump_type(ty, depth + 1)
    }
  }
}

fn dump_variant(v: Variant, depth: Int) : Unit / Console {

  match v {
    Var(name, vargs) -> {
      emit_line(depth, "variant #{name}")
      vargs |> each((a) => dump_type(a, depth + 1))
    }
  }
}

fn dump_program(decls: [Decl]) : Unit / Console {
  print("program")
  decls |> each((d) => dump_decl(d, 1))
}

# ====================================================================
# checker: name resolution
# ====================================================================
#
# Mirrors stage 0's `check.c`. No type inference, no exhaustiveness —
# just "every identifier is bound somewhere in scope." Top-level names
# (fns, type constructors, imported names) are pre-registered so
# forward references work. Each scope introduced by a block, match
# arm, lambda, or function body is pushed and popped as the walker
# enters and leaves. Errors accumulate into `had_error`; the driver
# returns 1 when that flag is set.

type Env = { scopes: [[String]], had_error: Bool, file: String,
              # Issue #487: structured diagnostic collection for T3
              # (`cannot find <name> in this scope`). Mirrors
              # `InferState.diags` semantics (reverse order, flipped at
              # the entry point).
              diags: [Diagnostic] }

fn env_new(file: String) : Env = Env { scopes: [[]], had_error: false, file: file, diags: [] }

fn env_push(e: Env) : Env =
  Env { scopes: [[], ...e.scopes], had_error: e.had_error, file: e.file, diags: e.diags }

fn env_pop(e: Env) : Env {
  match e.scopes {
    [_, ...rest] -> Env { scopes: rest, had_error: e.had_error, file: e.file, diags: e.diags }
    _ -> e
  }
}

fn env_add(e: Env, name: String) : Env {
  match e.scopes {
    [top, ...rest] ->
      Env { scopes: [[name, ...top], ...rest], had_error: e.had_error, file: e.file, diags: e.diags }
    _ -> e
  }
}

fn list_has(names: [String], target: String) : Bool {
  match names {
    [] -> false
    [n, ...rest] -> if n == target { true } else { list_has(rest, target) }
  }
}

fn scopes_has(scopes: [[String]], target: String) : Bool {
  match scopes {
    [] -> false
    [top, ...rest] -> if list_has(top, target) { true } else { scopes_has(rest, target) }
  }
}

fn env_has(e: Env, name: String) : Bool = scopes_has(e.scopes, name)

fn env_all_names(e: Env) : [String] = concat_scopes(e.scopes, [])

fn concat_scopes(ss: [[String]], acc: [String]) : [String] {
  match ss {
    [] -> acc
    [scope, ...rest] -> concat_scopes(rest, list_append(acc, scope))
  }
}

fn env_mark_err(e: Env) : Env =
  Env { scopes: e.scopes, had_error: true, file: e.file, diags: e.diags }

# Issue #487: push a Diagnostic onto the Env accumulator. Used by the
# T3 emit site in parallel with its existing `diag_error` call.
fn env_push_diag(e: Env, d: Diagnostic) : Env =
  Env { scopes: e.scopes, had_error: e.had_error, file: e.file,
        diags: [d, ...e.diags] }

fn chk_error(e: Env, line: Int, col: Int, msg: String) : Env / Console + File {


  diag_error(e.file, line, col, msg)
  env_mark_err(e)
}

# ---- prelude seeding (kept in sync with stage 0's PRELUDE) ----

fn prelude_names() : [String] {
  [
    "print", "eprint", "read_file", "write_file",
    "file_exists", "file_delete", "file_rename",
    # Issue #482: binary file IO.
    "file_read_bytes", "file_write_bytes",
    # Issue #344: fs/dir operations.
    "dir_list_dir", "dir_create_dir", "dir_remove_dir", "dir_walk",
    "read_line", "read_bytes", "args",
    "program_name",
    "exit", "panic",
    "int_to_string", "real_to_string", "string_to_int", "string_to_real",
    "int_to_real", "real_to_int",
    # Lane 4 (#473): Byte nominal primitive surface.
    "int_to_byte", "byte_to_int", "byte_add", "byte_sub", "byte_eq", "byte_lt", "byte_to_string",
    # libm bindings (issue #343)
    "real_sqrt", "real_cbrt", "real_exp", "real_log", "real_log2", "real_log10",
    "real_sin", "real_cos", "real_tan",
    "real_asin", "real_acos", "real_atan",
    "real_sinh", "real_cosh", "real_tanh",
    "real_signum", "real_is_nan", "real_is_inf",
    "real_pow", "real_atan2", "real_rem",
    "string_length", "string_concat", "string_concat_all", "string_join",
    "string_split", "string_contains", "char_at",
    "string_slice", "char_to_int", "int_to_char",
    "list_length", "list_append", "list_reverse",
    "map", "filter", "reduce", "each",
    "array_make", "array_length", "array_get", "array_set", "array_grow",
    # m13: bit operations on Int. Compiler intrinsics — each call lowers
    # to the corresponding C operator (`<<`, `>>`, `&`, `|`, `^`, `~`)
    # in `emit_call_value`, mirroring the `unit_name` / `__strip_unit`
    # pattern. Listed here so the closure-capture analyser does not
    # promote them to free vars when used inside a lambda body.
    "bit_and", "bit_or", "bit_xor", "bit_not",
    "bit_shl", "bit_shr", "bit_ushr",
    "bit_count", "bit_test",
    "bit_set", "bit_clear", "bit_toggle",
    # m8 #7: mailbox runtime exposed as prelude functions; user-facing
    # API lives in stdlib/actor.kai's `with_mailbox` helper.
    # m8 #8: bounded variant takes (cap: Int, overflow_code: Int).
    "mailbox_alloc", "mailbox_alloc_bounded",
    "mailbox_send", "mailbox_recv", "mailbox_free",
    # Tier 2 spawn_actor primitives — alloc-without-owner-stamp +
    # owner reassignment so a parent fiber can hand a mailbox to
    # the spawned fiber and have it observably owned by the child.
    "mailbox_alloc_unowned", "mailbox_assign_owner",
    "Some", "None", "Ok", "Err",
    # m5 #4 — Perceus dup/drop magic names. The pass synthesises
    # ECall(EVar("__perceus_dup"), [...]) and ECall(EVar("__perceus_drop"),
    # [...]) AFTER inference; the emitter handles them via special cases
    # in emit_call_expr. They're listed here so the closure-capture
    # analyser does not treat them as free vars to capture inside lambda
    # bodies (which would emit invalid C: `kai___perceus_dup` is undeclared).
    "__perceus_dup", "__perceus_drop",
    # issue #118 — Perceus reuse-in-place magic names. The recogniser
    # `pcs_recognise_reuse_*` synthesises calls to these from
    # constructor-after-deconsume patterns. The emitter lowers them to
    # `kai_reuse_or_alloc_<shape>` runtime helpers that branch on the
    # consumed cell's RC: in-place rewrite when unique, fall back to a
    # fresh allocation when shared.
    "__perceus_reuse_cons",
    "__perceus_reuse_record",
    "__perceus_reuse_variant",
    # Bug 8 (docs/m12.8-followup.md): `unitless` removed from the
    # user-visible prelude. It was implemented as an emit-time
    # identity special case (no kai_prelude_unitless runtime fn),
    # which made first-class use (`x |> unitless`, `let f = unitless`)
    # crash at C compile. The emit special cases below were repurposed
    # for `__strip_unit`, the typer-internal erasure intrinsic that
    # the parametric `impl Show for Real[u: Measure]` body uses to feed
    # `Real<u>` into `real_to_string : Real -> String`.
    # m12.8.x phase 2 (Gap 1): compile-time unit reflection;
    # emitter lowers to a constant String literal.
    "unit_name",
    # m12.8 phase 2: typer-internal erasure of the unit annotation on a
    # dimensioned Real. NOT for user code — the `__` prefix marks it as
    # a compiler-generated name. Used by the parametric Show impl in
    # stdlib/protocols.kai to revive the dead `unitless` emit identity.
    "__strip_unit"
  ]
}

fn add_all(e: Env, names: [String]) : Env =
  reduce(names, e, (acc, n) => env_add(acc, n))

# ---- pattern bindings: walk a pattern and add its bound names ----

fn bind_pat(e: Env, pat: Pattern) : Env {
  match pat.pkind {
    PWild -> e
    PLit(_) -> e
    PBind(name) -> env_add(e, name)
    PList(pats, opt_rest) -> {
      let e1 = bind_pats_loop(e, pats)
      match opt_rest {
        Some(rname) -> env_add(e1, rname)
        None -> e1
      }
    }
    PVariant(_, subs) -> bind_pats_loop(e, subs)
    PVariantRecord(_, fields) -> bind_pfields_loop(e, fields)
    PRecord(fields) -> bind_pfields_loop(e, fields)
    PHole(_) -> e
    PAs(name, sub) -> bind_pat(env_add(e, name), sub)
    PNarrow(name, _) -> env_add(e, name)
  }
}

fn bind_pats_loop(e: Env, ps: [Pattern]) : Env {
  match ps {
    [] -> e
    [p, ...rest] -> bind_pats_loop(bind_pat(e, p), rest)
  }
}

fn bind_pfields_loop(e: Env, fs: [PField]) : Env {
  match fs {
    [] -> e
    [pf, ...rest] -> bind_pfields_loop(bind_pfield(e, pf), rest)
  }
}

fn bind_pfield(e: Env, pf: PField) : Env {
  match pf {
    # Shorthand `{ x }` binds `x` directly; the parser already builds the
    # equivalent of `{ x: x }` so bind_pat handles both cases uniformly.
    PField(_, sub, _) -> bind_pat(e, sub)
  }
}

# ---- expression walker ----

fn chk_expr(e: Env, x: Expr) : Env / Console + File {


  match x.kind {
    EInt(_)    -> e
    EReal(_)   -> e
    EBool(_)   -> e
    EChar(_)   -> e
    EStr(_, _) -> e
    EUnit      -> e
    EUnder     -> e
    EPlaceholder -> e
    EVar(name) -> {
      if env_has(e, name) { e }
      else {
        # m11 v1 Template 3 — canonical Rust/Elm-style diagnostic.
        # Error line stays terse; the did-you-mean suggestion moves
        # to a separate `help:` line and is suppressed when no name
        # is within Levenshtein distance 3 (closest_name's threshold).
        diag_error(e.file, x.line, x.col, "cannot find `#{name}` in this scope")
        let msg = "cannot find `#{name}` in this scope"
        let sug = closest_name(name, env_all_names(e))
        match sug {
          Some(s) -> diag_help("a similar name exists in scope: `#{s}` (did you mean this?)")
          None    -> ()
        }
        # Issue #487 — T3 collected diagnostic. Stderr above remains
        # byte-identical; the structured Diagnostic carries the same
        # message + optional did-you-mean help.
        let related = match sug {
          Some(s) -> [ri_help(e.file, x.line, x.col,
                              "a similar name exists in scope: `#{s}` (did you mean this?)")]
          None    -> []
        }
        let e1 = env_push_diag(e, mk_diag(SevError, e.file, x.line, x.col, msg, related))
        env_mark_err(e1)
      }
    }
    ECall(f, xs) -> {
      let e1 = chk_expr(e, f)
      chk_exprs(e1, xs)
    }
    EField(base, _) -> chk_expr(e, base)
    EIndex(base, idx) -> chk_expr(chk_expr(e, base), idx)
    EBinop(_, a, b) -> chk_expr(chk_expr(e, a), b)
    EUnop(_, inner) -> chk_expr(e, inner)
    EIf(c, a, opt_b) -> {
      let e1 = chk_expr(chk_expr(e, c), a)
      match opt_b {
        Some(b) -> chk_expr(e1, b)
        None -> e1
      }
    }
    EMatch(scrut, arms) -> {
      let e1 = chk_expr(e, scrut)
      chk_arms(e1, arms)
    }
    ELambda(params, body) -> {
      let e1 = env_push(e)
      let e2 = add_params(e1, params)
      let e3 = chk_expr(e2, body)
      env_pop(e3)
    }
    ERecordLit(_, fields) -> chk_field_inits(e, fields)
    EList(elems) -> chk_list_elems(e, elems)
    ERange(a, b, opt_step) -> {
      let e1 = chk_expr(chk_expr(e, a), b)
      match opt_step { Some(s) -> chk_expr(e1, s) None -> e1 }
    }
    EBlock(stmts, opt_final) -> {
      let e1 = env_push(e)
      let e2 = chk_stmts(e1, stmts)
      let e3 = match opt_final { Some(f) -> chk_expr(e2, f) None -> e2 }
      env_pop(e3)
    }
    EPipe(a, b) -> chk_expr(chk_expr(e, a), b)
    EMapPipe(a, b) -> chk_expr(chk_expr(e, a), b)
    EFlatMapPipe(a, b) -> chk_expr(chk_expr(e, a), b)
    EFilterPipe(a, b) -> chk_expr(chk_expr(e, a), b)
    EHole(_) -> e          # holes bind no names; checker lets them pass silently
    ETodo(_) -> e          # m7d §1: same posture as a hole
    EBang(inner) -> chk_expr(e, inner)   # m7e §13: scope-walk the operand
    EHandle(body, _, _, init_opt, alias_opt, clauses, ret_opt) -> {
      # m7a #4e: `Eff as log` makes `log` a binding that names
      # the capability inside the body. We push a scope so the
      # name disappears once the body is done.
      # m7b #11: the init expression (`with State[T](init)`) lives
      # in the outer scope — its free vars are the surrounding env.
      let stateful = match init_opt { Some(_) -> true None -> false }
      let after_init = match init_opt {
        Some(ie) -> chk_expr(e, ie)
        None     -> e
      }
      let body_env = match alias_opt {
        Some(alias) -> env_add(env_push(after_init), alias)
        None        -> after_init
      }
      let e1 = chk_expr(body_env, body)
      let restored = match alias_opt {
        Some(_) -> env_pop(e1)
        None    -> e1
      }
      let e2 = chk_handler_clauses(restored, clauses, stateful)
      match ret_opt {
        Some(r) -> chk_handler_return(e2, r, stateful)
        None    -> e2
      }
    }
    # m12.5: literal carrying a unit annotation. Recurse into the inner
    # numeric literal; the unit symbols themselves are validated at
    # type-resolution time, not here.
    ELitUnit(inner, _) -> chk_expr(e, inner)
    # m7e §11: `variants[T]()` carries no value-level sub-expressions.
    # The TypeExpr is validated by the resolver (sum + nullary-only)
    # in a later pass, not here.
    EVariantsOf(_, _) -> e
    # m6.2 Phase 2.1: qualified module call carries no sub-expressions
    # and binds no names — the resolver fills it in once everything
    # is in scope, so the checker has nothing to verify here.
    EModCall(_, _) -> e
  }
}

fn chk_handler_clauses(e: Env, cs: [HClause], stateful: Bool) : Env / Console + File {


  match cs {
    [] -> e
    [c, ...rest] -> match c {
      HC(_, params, body, _, _) -> {
        let e1 = env_push(e)
        # m7b #11: parameterised handlers (`with State[T](init)`)
        # expose the current handler-state inside every clause as
        # `state` (and the alias `log` for accumulator-shaped handlers
        # like `Writer[W]`). They are aliases of the same slot — the
        # codegen layer resolves both to `self->state`.
        let e1s = if stateful { env_add(env_add(e1, "state"), "log") } else { e1 }
        let e2 = add_params(e1s, params)
        let e3 = chk_expr(e2, body)
        chk_handler_clauses(env_pop(e3), rest, stateful)
      }
    }
  }
}

fn chk_handler_return(e: Env, r: HReturn, stateful: Bool) : Env / Console + File {


  match r {
    HR(name, body, _, _) -> {
      let e1 = env_push(e)
      let e2 = env_add(e1, name)
      let e2s = if stateful { env_add(env_add(e2, "state"), "log") } else { e2 }
      let e3 = chk_expr(e2s, body)
      env_pop(e3)
    }
  }
}

fn chk_exprs(e: Env, xs: [Expr]) : Env / Console + File {


  match xs {
    [] -> e
    [h, ...rest] -> chk_exprs(chk_expr(e, h), rest)
  }
}

fn chk_field_inits(e: Env, fs: [FieldInit]) : Env / Console + File {


  match fs {
    [] -> e
    [f, ...rest] -> match f {
      FI(_, val) -> chk_field_inits(chk_expr(e, val), rest)
    }
  }
}

fn chk_list_elems(e: Env, es: [ListElem]) : Env / Console + File {


  match es {
    [] -> e
    [el, ...rest] -> match el {
      ElPlain(x)  -> chk_list_elems(chk_expr(e, x), rest)
      ElSpread(x) -> chk_list_elems(chk_expr(e, x), rest)
    }
  }
}

fn chk_arms(e: Env, arms: [Arm]) : Env / Console + File {


  match arms {
    [] -> e
    [a, ...rest] -> chk_arms(chk_arm(e, a), rest)
  }
}

fn chk_arm(e: Env, a: Arm) : Env / Console + File {


  match a {
    Arm(pat, guard, body) -> {
      let e1 = env_push(e)
      let e2 = bind_pat(e1, pat)
      let e3 = match guard { Some(g) -> chk_expr(e2, g) None -> e2 }
      let e4 = chk_expr(e3, body)
      env_pop(e4)
    }
  }
}

fn chk_stmts(e: Env, ss: [Stmt]) : Env / Console + File {


  match ss {
    [] -> e
    [s, ...rest] -> chk_stmts(chk_stmt(e, s), rest)
  }
}

fn chk_stmt(e: Env, s: Stmt) : Env / Console + File {


  match s {
    SLet(pat, _, rhs) -> {
      let e1 = chk_expr(e, rhs)
      bind_pat(e1, pat)
    }
    SAssert(cond, opt_msg) -> {
      let e1 = chk_expr(e, cond)
      match opt_msg { Some(m) -> chk_expr(e1, m) None -> e1 }
    }
    SExprStmt(x) -> chk_expr(e, x)
    # m7b #6: index-assign sugar — desugared away before this pass runs,
    # but kept arm here so the match stays exhaustive if name resolution
    # is invoked on the raw AST (e.g. from a future debug dump).
    SIndexAssign(base, idx, val, _, _) -> {
      let e1 = chk_expr(e, base)
      let e2 = chk_expr(e1, idx)
      chk_expr(e2, val)
    }
    # m7b #5b: `var name = init` is desugared away pre-resolve by
    # `desugar_var_decls`. This arm is dead code in normal compilation;
    # if a future debug mode skips the desugar, treat the binding like
    # `let` so the match stays exhaustive and follow-on resolution
    # still produces useful diagnostics.
    SVar(name, _, rhs, _line, _col) -> {
      let e1 = chk_expr(e, rhs)
      env_add(e1, name)
    }
    # m7e §25: `use Effect` stmt is stripped by desugar_use_decls
    # before chk runs. Arm kept so the match is exhaustive in case
    # of a future debug-only path that skips the desugar.
    SUse(_, _, _) -> e
  }
}

fn add_params(e: Env, ps: [Param]) : Env {
  match ps {
    [] -> e
    [p, ...rest] -> add_params(env_add(e, p.pname), rest)
  }
}

# ---- declaration walkers ----

fn chk_decl(e: Env, d: Decl) : Env / Console + File {


  match d {
    DFn(_, _, _, params, _, _, body, _, _, _) -> {
      let e1 = env_push(e)
      let e2 = add_params(e1, params)
      let e3 = chk_expr(e2, body)
      env_pop(e3)
    }
    DType(_, _, _, _, _, _) -> e
    DTest(_, body, _, _) -> {
      let e1 = env_push(e)
      let e2 = chk_expr(e1, body)
      env_pop(e2)
    }
    DBench(_, body, _, _) -> {
      let e1 = env_push(e)
      let e2 = chk_expr(e1, body)
      env_pop(e2)
    }
    DCheck(_, params, body, _, _) -> {
      let e1 = env_push(e)
      let e2 = add_params(e1, params)
      let e3 = chk_expr(e2, body)
      env_pop(e3)
    }
    DImport(_, _, _) -> e
    DEffect(_, _, _, _, _, _) -> e          # m7a #3c will register effect names
    # m12.8: protocol / impl / derive decls are stripped by
    # `lower_protocols` before `check_program` runs, so reaching one
    # here means the pipeline was driven directly into `chk_decl` (e.g.
    # via `--check` on a file that bypassed lowering, or a future
    # caller that forgot to lower first). Treat as a no-op rather than
    # a fatal error so the selfhost path continues to validate the
    # post-lowering decl stream.
    DProtocol(_, _, _, _, _, _) -> e
    DImpl(_, _, _, _, _, _) -> e
    DDerive(_, _, _, _) -> e
    DUnit(_, _, _, _, _) -> e               # m12.5: unit declarations introduce no value bindings
    DUse(_, _, _) -> e                       # m7e §25: stripped by desugar_use_decls before chk runs
    DAxiom(_, _, _, _, _, _, _, _, _, _) -> e     # m12.7: rewritten to DFn by lower_axioms before chk runs
    DAttribPure(inner, _, _) -> chk_decl(e, inner)  # m12.6.x #5(a)
    DConst(_, name, _, body, _, _) -> {           # issue #269
      let e1 = env_add(e, name)
      chk_expr(e1, body)
    }
  }
}

fn chk_decls(e: Env, ds: [Decl]) : Env / Console + File {


  match ds {
    [] -> e
    [d, ...rest] -> chk_decls(chk_decl(e, d), rest)
  }
}

# ---- top-level pre-registration ----

fn register_decls(e: Env, ds: [Decl]) : Env {
  match ds {
    [] -> e
    [d, ...rest] -> register_decls(register_one(e, d), rest)
  }
}

fn register_one(e: Env, d: Decl) : Env {
  match d {
    DFn(_, name, _, _, _, _, _, _, _, _) -> env_add(e, name)
    DType(_, name, _, body, _, _) -> {
      let e1 = env_add(e, name)
      match body {
        TBSum(variants) -> register_variants_env(e1, variants)
        _ -> e1
      }
    }
    DTest(_, _, _, _) -> e
    DBench(_, _, _, _) -> e
    DCheck(_, _, _, _, _) -> e
    DImport(ik, _, _) -> register_import(e, ik)
    DEffect(_, name, _, _, _, _) -> env_add(e, name)
    # m12.8: stripped pre-resolve; never reaches register_one in
    # practice. No-op for completeness so the match stays exhaustive.
    DProtocol(_, _, _, _, _, _) -> e
    DImpl(_, _, _, _, _, _) -> e
    DDerive(_, _, _, _) -> e
    DUnit(_, _, _, _, _) -> e               # m12.5: unit names live in their own namespace, validated at type-resolve time
    DUse(_, _, _) -> e                       # m7e §25: stripped by desugar_use_decls before register_one runs
    DAxiom(_, _, name, _, _, _, _, _, _, _) -> env_add(e, name)  # m12.7: also rewritten to DFn by lower_axioms; case kept for completeness
    DAttribPure(inner, _, _) -> register_one(e, inner)  # m12.6.x #5(a)
    DConst(_, name, _, _, _, _) -> env_add(e, name)  # issue #269
  }
}

fn register_variants_env(e: Env, vs: [Variant]) : Env {
  match vs {
    [] -> e
    [v, ...rest] -> match v {
      Var(name, _) -> register_variants_env(env_add(e, name), rest)
    }
  }
}

# For imports we add just the surface name: the last segment of the
# dotted path, the alias, or each selected name. Stage 0 does the
# same; deeper module resolution is a stage 2 concern.
fn last_segment(path: String) : String {
  last_segment_loop(path, string_length(path) - 1, string_length(path))
}

fn last_segment_loop(s: String, i: Int, end: Int) : String {
  if i < 0 { string_slice(s, 0, end) }
  else {
    match char_at(s, i) {
      Some(c) -> if c == '.' { string_slice(s, i + 1, end - i - 1) }
                 else { last_segment_loop(s, i - 1, end) }
      None -> string_slice(s, 0, end)
    }
  }
}

fn register_import(e: Env, ik: ImportKind) : Env {
  match ik {
    IkPath(path) -> env_add(e, last_segment(path))
    IkAlias(_, alias) -> env_add(e, alias)
    IkSelective(_, names) -> add_all(e, names)
    # m7f §7: import holes don't bind anything in the value
    # namespace — they are diagnostic-only. Skip for env-binding
    # purposes; the symbol-index pass handles the diagnostic.
    IkHole(_) -> e
  }
}

# ---- entry point ----

fn check_program(file: String, decls: [Decl]) : Int / Console + File {

  let e0 = env_new(file)
  let e1 = add_all(e0, prelude_names())
  let e2 = register_decls(e1, decls)
  let e3 = chk_decls(e2, decls)
  let eff_names = collect_effect_names(decls)
  let arities = collect_effect_arities(decls)
  let row_errs = check_row_labels(decls, file, eff_names, arities)
  let strict_errs = check_call_site_refinements(file, decls)
  if e3.had_error or row_errs > 0 or strict_errs > 0 { 1 } else { 0 }
}

# m7b #11j — arity table built from every DEffect in the program.
# `inject_builtin_effects` runs before `check_program`, so the
# parametric stdlib effects (State, Reader, Writer) and any used
# default-handler effects are already in `decls`. Any builtin not
# yet injected (the user's main doesn't reference it) is filled in
# from `builtin_effect_arities()` so a helper can still use the
# effect with the right tparam count.
type EffArity = EA(String, Int)

fn collect_effect_arities(decls: [Decl]) : [EffArity] {
  let from_decls = collect_effect_arities_loop(decls)
  list_append(from_decls, builtin_effect_arities_filtered(from_decls))
}

fn collect_effect_arities_loop(decls: [Decl]) : [EffArity] {
  match decls {
    [] -> []
    [d, ...rest] -> match d {
      DEffect(_, name, tparams, _, _, _) ->
        [EA(name, list_length(tparams)), ...collect_effect_arities_loop(rest)]
      _ -> collect_effect_arities_loop(rest)
    }
  }
}

# Names known to `builtin_effect_names()` that the program did not
# declare or inject. Tparam counts are the canonical Doc B values
# (Console/Fail/Stdin/Env/File: 0; State/Reader/Writer: 1).
fn builtin_effect_arities_filtered(known: [EffArity]) : [EffArity] {
  let all = [
    EA("Console", 0), EA("Fail", 0), EA("Stdin", 0),
    EA("Env", 0), EA("File", 0),
    EA("State", 1), EA("Reader", 1), EA("Writer", 1),
    EA("Mutable", 0),
    # m12.7.x FFI v1: `Ffi` is the capability tag carried by every
    # `[<extern_c>]` axiom row. The runtime has no handler for it —
    # the codegen lowers extern_c calls to direct C symbols, which
    # never trap into the effect dispatcher — so the row label
    # exists only to keep public signatures honest.
    EA("Ffi", 0)
  ]
  filter_unknown_arities(all, known)
}

fn filter_unknown_arities(all: [EffArity], known: [EffArity]) : [EffArity] {
  match all {
    [] -> []
    [a, ...rest] -> match a {
      EA(n, _) ->
        if has_arity(known, n) { filter_unknown_arities(rest, known) }
        else { [a, ...filter_unknown_arities(rest, known)] }
    }
  }
}

fn has_arity(arities: [EffArity], target: String) : Bool {
  match arities {
    [] -> false
    [a, ...rest] -> match a {
      EA(n, _) -> if n == target { true } else { has_arity(rest, target) }
    }
  }
}

fn lookup_arity(arities: [EffArity], target: String) : Option[Int] {
  match arities {
    [] -> None
    [a, ...rest] -> match a {
      EA(n, k) -> if n == target { Some(k) } else { lookup_arity(rest, target) }
    }
  }
}

# ---- m7a #3c: name resolution for effect labels in rows ----
# Every label that appears in a `T / Eff + ...` suffix must refer to
# a declared effect. Anything else is a compile error. m7a #3 does
# not yet build evidence types or check the body's row against the
# declared row — those are #3d and #8.

fn collect_effect_names(decls: [Decl]) : [String] {
  match decls {
    [] -> []
    [d, ...rest] -> match d {
      DEffect(_, name, _, _, _, _) -> [name, ...collect_effect_names(rest)]
      _ -> collect_effect_names(rest)
    }
  }
}

# Issue #308: look up the in-scope decl for an effect by name and
# return its op-name list. None if no DEffect with that name is
# present.
fn lookup_effect_op_names(decls: [Decl], name: String) : Option[[String]] {
  match decls {
    [] -> None
    [d, ...rest] -> match d {
      DEffect(_, dname, _, ops, _, _) ->
        if dname == name { Some(effect_op_names(ops)) }
        else { lookup_effect_op_names(rest, name) }
      _ -> lookup_effect_op_names(rest, name)
    }
  }
}

fn effect_op_names(ops: [EffectOp]) : [String] {
  match ops {
    [] -> []
    [o, ...rest] -> match o {
      EOp(n, _, _, _, _, _) -> [n, ...effect_op_names(rest)]
    }
  }
}

# Issue #308: per-effect expected op shape for the runtime's default
# handler. The `EvX` struct field layout in stage0/runtime.h is
# co-designed with these op lists; if a user `effect X { ... }`
# shadows the canonical decl with a different shape, the
# `_kai_default_ev_x.<op> = ...` wiring would assign through fields
# that do not exist (or sit at the wrong offset). Returning false
# from `effect_default_compatible` makes the C and LLVM backends
# skip wiring for that effect, just as if it were absent from
# `main_row`.
fn effect_default_compatible(decls: [Decl], name: String) : Bool = {
  let expected = expected_default_op_names(name)
  match expected {
    None -> true                          # not a default-handler effect
    Some(exp_ops) -> match lookup_effect_op_names(decls, name) {
      None -> true                        # no decl in scope; pass-through
      Some(found_ops) -> eff_op_names_eq(found_ops, exp_ops)
    }
  }
}

# Op-name shape expected by the runtime's default handler for each
# effect. Order must match the stage0 `EvX` struct field order. Names
# that have no default handler (or no shadowing risk) return None and
# pass through unchanged.
fn expected_default_op_names(name: String) : Option[[String]] {
  if      name == "Stdout"       { Some(["print"]) }
  else if name == "Stderr"       { Some(["eprint"]) }
  else if name == "Fail"         { Some(["fail"]) }
  else if name == "Stdin"        { Some(["read_line", "read_bytes"]) }
  else if name == "Env"          { Some(["args", "var", "set_var", "unset_var", "vars"]) }
  else if name == "File"         { Some(["read_file", "write_file"]) }
  else if name == "Clock"        { Some(["wall_now", "monotonic_now", "sleep_ns"]) }
  else if name == "Random"       { Some(["int_range"]) }
  else if name == "SecureRandom" { Some(["int_range", "bytes"]) }
  else if name == "NetTcp"       { Some(["connect", "listen", "accept", "send", "recv", "close"]) }
  else if name == "Signal"       { Some(["on", "off", "await"]) }
  else if name == "Process"      { Some(["start", "wait", "kill", "exit"]) }
  else if name == "Log"          { Some(["debug", "info", "warn", "error"]) }
  else if name == "Mutable"      { Some(["array_make", "array_length", "array_get", "array_set", "array_grow", "ref_make", "ref_get", "ref_set"]) }
  else if name == "Cancel"       { Some(["raise"]) }
  else if name == "Link"         { Some(["link"]) }
  else if name == "Monitor"      { Some(["monitor", "demonitor"]) }
  else if name == "Spawn"        { Some(["yield", "spawn", "await", "select", "cancel", "set_trap_exit"]) }
  else { None }
}

# Issue #308: filter `main_row` to drop effects whose in-scope decl
# does not match the runtime's expected op shape for that name. The
# default-handler wiring (setup/shim/pop emit + LLVM mirror) keys on
# builtin EvX struct layout; emitting it for a user-shadowed effect
# whose ops differ produces invalid C (e.g.
# `_kai_default_ev_log.debug = ...` against a user EvLog that only
# has `.log`).
fn row_minus_user_effects(main_row: [String], decls: [Decl]) : [String] {
  match main_row {
    [] -> []
    [x, ...rest] ->
      if effect_default_compatible(decls, x) {
        [x, ...row_minus_user_effects(rest, decls)]
      } else {
        row_minus_user_effects(rest, decls)
      }
  }
}

# net-tcp-v1: walk the declared types so the NetTcp / Conn / Listener
# / Byte builtin injection in `inject_builtin_effects` can defer to
# any user-supplied decl with the same name. Mirrors
# `collect_effect_names` for DType.
fn collect_type_names(decls: [Decl]) : [String] {
  match decls {
    [] -> []
    [d, ...rest] -> match d {
      DType(_, name, _, _, _, _) -> [name, ...collect_type_names(rest)]
      _ -> collect_type_names(rest)
    }
  }
}

fn check_row_labels(decls: [Decl], file: String, eff_names: [String],
                     arities: [EffArity]) : Int / Console + File {


  match decls {
    [] -> 0
    [d, ...rest] ->
      check_decl_row_labels(d, file, eff_names, arities) +
      check_row_labels(rest, file, eff_names, arities)
  }
}

fn check_decl_row_labels(d: Decl, file: String, eff_names: [String],
                          arities: [EffArity]) : Int / Console + File {


  match d {
    DFn(_, _, _, _, _, rexpr, _, line, col, _) ->
      check_row_expr(rexpr, file, line, col, eff_names, arities)
    _ -> 0
  }
}

fn check_row_expr(re: RowExpr, file: String, line: Int, col: Int,
                   eff_names: [String], arities: [EffArity]) : Int / Console + File {


  match re {
    REmpty -> 0
    RClosed(labels) -> check_row_labels_loop(labels, file, line, col, eff_names, arities)
    # m7b #12: row variables in tail position carry the same labels;
    # apply the same name + arity check.
    ROpen(_, labels) -> check_row_labels_loop(labels, file, line, col, eff_names, arities)
  }
}

# m7b #11j — per-label name + arity check. Unknown effect → "unknown
# effect: X". Arity mismatch → "effect 'X' expects N type
# argument(s), got M".
fn check_row_labels_loop(labels: [RowLabel], file: String, line: Int, col: Int,
                          eff_names: [String], arities: [EffArity]) : Int / Console + File {


  match labels {
    [] -> 0
    [l, ...rest] -> match l {
      RL(name, ts) -> {
        let got = list_length(ts)
        let here =
          if not list_has(eff_names, name) {
            let _ = diag_error(file, line, col,
              string_concat("unknown effect: ", name))
            let _ = diag_note("only declared `effect Foo { ... }` names and the catalog (Console, Fail, Stdin, Env, File, State, Reader, Writer, Mutable, Ffi) are valid in a row")
            let _ = diag_help("declare `effect #{name} { ... }` first, or fix the spelling")
            1
          } else {
            match lookup_arity(arities, name) {
              None -> 0     # declared without arity — should not happen given collect_effect_arities covers all
              Some(want) ->
                if want == got { 0 }
                else {
                  let _ = diag_error(file, line, col,
                    concat_all(["effect '", name, "' expects ",
                                int_to_string(want),
                                " type argument(s), got ",
                                int_to_string(got)]))
                  let _ = diag_note("the parametric label must match the effect's `[...]` declaration")
                  let _ = diag_help(
                    if got > want {
                      concat_all(["drop ", int_to_string(got - want), " type argument(s) from `", name, "[...]`"])
                    } else {
                      concat_all(["add ", int_to_string(want - got), " more type argument(s) to `", name, "[...]`"])
                    })
                  1
                }
            }
          }
        here + check_row_labels_loop(rest, file, line, col, eff_names, arities)
      }
    }
  }
}

# ====================================================================
# emitter
# ====================================================================
#
# Produces C source that links against stage 0's runtime.h. This
# milestone (6) only covers what hello.kai needs — enough of expressions
# to emit a call, a string literal, a block body, and the top-level
# scaffolding (forward decls, thunks, int main). Subsequent milestones
# extend emit_expr to cover the rest of ExprKind.

# ---- small string helpers ----

fn cat2(a: String, b: String) : String = string_concat(a, b)
fn cat3(a: String, b: String, c: String) : String =
  string_concat(a, string_concat(b, c))
fn cat4(a: String, b: String, c: String, d: String) : String =
  string_concat(a, string_concat(b, string_concat(c, d)))
fn cat5(a: String, b: String, c: String, d: String, ee: String) : String =
  string_concat(a, string_concat(b, string_concat(c, string_concat(d, ee))))

fn concat_all(xs: [String]) : String = string_concat_all(xs)

fn join_with(xs: [String], sep: String) : String = string_join(xs, sep)

# ---- tables: user function arities, variant arities ----
#
# Stage 0 emit keeps parallel tables of user-defined function names and
# variant constructors; the ident dispatcher looks into both before
# falling back to a local. Stage 1 does the same; both tables are
# lists of sum-variant pairs.

# m6.2 v2: EFn now carries the decl's module of origin. None for
# decls authored in the root file; Some(m) for decls imported from
# module `m` (or pulled in via --prelude, see expand_imports +
# load_prelude). Codegen reads the field to mint `kai_<m>__<name>`
# vs `kai_<name>`, and to disambiguate two-modules-export-same-name
# at bare-name call sites.
#
# Phase 3 unboxing (issue #383): the fourth slot is the unboxed-
# signature classification. `None` means the classical
# `static KaiValue *kai_<name>(KaiValue *...)` calling convention.
# `Some(US([Ty], Ty))` means the fn was classified by `unbox_classify`
# as taking + returning raw C scalars (`int64_t` / `double` /
# `int` / `uint32_t`); the emitter mints a raw signature, EVar reads
# of the fn's parameters resolve to `kair_<name>`, and call sites
# emit raw arguments via `emit_expr_raw`. The classifier requires
# every param ty + return ty to be in {Int, Bool, Char, Real}
# (concretely; not parametric T), no FFI shim, no protocol-impl
# child, no effect row, no closure parameters. See
# `unbox_classify_decl`.
type UFnSig = US([Ty], Ty)
type EFn  = EFn(String, Int, Option[String], Option[UFnSig])
type EVar = EV(String, Int)

fn efn_find(fns: [EFn], target: String) : Option[EFn] {
  match fns {
    [] -> None
    [h, ...rest] -> match h {
      EFn(n, _, _, _) -> if n == target { Some(h) } else { efn_find(rest, target) }
    }
  }
}

# m6.2 v2: bare-name lookup with the disambiguation rule. Returns:
#   - the unique entry, when there is exactly one;
#   - the root-file entry (module_origin = None) when present, even
#     if other modules also export the same name (locals-shadow rule
#     applied at top-level scope);
#   - None when zero matches OR when there are multiple module-origin
#     matches and no root-file entry (ambiguity — the codegen
#     emit_named_call_lookup falls back to a closure thunk lookup
#     against `kai_<name>` plain, which lets the linker fail with a
#     clear undefined-symbol error in the rare unhandled case; the
#     proper diagnostic ("ambiguous reference to ...") fires from
#     check_efn_ambiguity at decl-registration time).
fn efn_resolve(fns: [EFn], target: String) : Option[EFn] {
  let candidates = efn_collect_matching(fns, target, [])
  match candidates {
    []     -> None
    [one]  -> Some(one)
    [first, ..._rest] -> match efn_pick_root(candidates) {
                Some(r) -> Some(r)
                # Same-module preference: when several modules export
                # the same name AND no root-file shadow exists, fall
                # back to the FIRST match. Callers that emit a DFn
                # body (`emit_fn_body`, `llvm_emit_fn_body`) reorder
                # the `fns` table with `fns_prefer_module(fns, mo)`
                # before recursing so the same-module entry wins
                # over imported modules. This is what unblocks
                # `stdlib/loop.repeat` recursing on its own name when
                # `stdlib/core/list.repeat` is also in scope.
                None    -> Some(first)
              }
  }
}

# m6.2 v2 + same-module preference: project the EFn table so entries
# whose `module_origin` equals `mo` come first. Stable on the rest.
# Called from emit_fn_body / llvm_emit_fn_body before the body walk
# so `efn_resolve`'s "first-match" fallback resolves to the local
# module. With `mo == None` (root file) the table is returned
# unchanged — root-file fns already win via `efn_pick_root`.
fn fns_prefer_module(fns: [EFn], mo: Option[String]) : [EFn] = match mo {
  None    -> fns
  Some(m) -> list_append(fns_filter_same_module(fns, m, []),
                          fns_filter_other_module(fns, m, []))
}

fn fns_filter_same_module(fns: [EFn], m: String, acc: [EFn]) : [EFn] {
  match fns {
    [] -> list_reverse(acc)
    [h, ...rest] -> match h {
      EFn(_, _, Some(em), _) ->
        if em == m { fns_filter_same_module(rest, m, [h, ...acc]) }
        else       { fns_filter_same_module(rest, m, acc) }
      _ -> fns_filter_same_module(rest, m, acc)
    }
  }
}

fn fns_filter_other_module(fns: [EFn], m: String, acc: [EFn]) : [EFn] {
  match fns {
    [] -> list_reverse(acc)
    [h, ...rest] -> match h {
      EFn(_, _, Some(em), _) ->
        if em == m { fns_filter_other_module(rest, m, acc) }
        else       { fns_filter_other_module(rest, m, [h, ...acc]) }
      _ -> fns_filter_other_module(rest, m, [h, ...acc])
    }
  }
}

fn efn_collect_matching(fns: [EFn], target: String, acc: [EFn]) : [EFn] {
  match fns {
    [] -> list_reverse(acc)
    [h, ...rest] -> match h {
      EFn(n, _, _, _) ->
        if n == target { efn_collect_matching(rest, target, [h, ...acc]) }
        else           { efn_collect_matching(rest, target, acc) }
    }
  }
}

fn efn_pick_root(cands: [EFn]) : Option[EFn] {
  match cands {
    [] -> None
    [h, ...rest] -> match h {
      EFn(_, _, None, _) -> Some(h)
      _ -> efn_pick_root(rest)
    }
  }
}

# m6.2 v2: arity helper that wraps the new resolver. Codegen call
# sites that previously consumed `Option[Int]` keep working unchanged.
fn efn_find_arity(fns: [EFn], target: String) : Option[Int] = match efn_resolve(fns, target) {
  Some(EFn(_, ar, _, _)) -> Some(ar)
  None                   -> None
}

# m6.2 v2: produce the C-symbol suffix (everything after the `kai_`
# prefix) for a named function. None → just the bare name; Some(m) →
# the module-prefixed `<m>__<name>`. Used to mint the symbol at decl
# emission, in call sites, and in closure-thunk forward decls so all
# three stay in sync.
fn c_sym(name: String, mo: Option[String]) : String = match mo {
  None    -> name
  Some(m) -> string_concat(m, string_concat("__", name))
}

# m6.2 v2: mint the C-symbol suffix for a callee resolved via the
# EFn table. Falls back to the bare name when the lookup misses (e.g.
# the callee is a closure variable held in a local that gets routed
# through `kai_apply` instead).
fn c_sym_of_callee(fns: [EFn], callee: String) : String = match efn_resolve(fns, callee) {
  Some(EFn(_, _, mo, _)) -> c_sym(callee, mo)
  None                   -> callee
}

fn evar_find(vs: [EVar], target: String) : Option[Int] {
  match vs {
    [] -> None
    [h, ...rest] -> match h {
      EV(n, ar) -> if n == target { Some(ar) } else { evar_find(rest, target) }
    }
  }
}

fn fn_of_decl(d: Decl) : Option[EFn] {
  match d {
    DFn(_, name, tparams, params, opt_ret, row, body, _, _, mo) ->
      Some(EFn(name, list_length(params), mo, classify_unbox_sig(name, mo, tparams, params, opt_ret, row, body)))
    _ -> None
  }
}

# Phase 3 unboxing (issue #383): classify a top-level DFn as
# unboxed-signature candidate. Returns `Some(US(param_tys, ret_ty))`
# when every param + return is in {Int, Bool, Char, Real} concretely
# (post-Dim / Refinement strip), with no parametric type variables,
# no declared effect row, and no FFI-shim body. Otherwise returns
# None — the callee keeps the classical `KaiValue *` calling
# convention.
#
# Excluded:
#   - Generic functions (`tparams != []`): the parametric T cannot
#     be unboxed without monomorphisation tweaks (post-1.0).
#   - FFI shims: `body_is_ffi_extern(body)` already produces the
#     unbox/box dance internally; the shim signature is fixed.
#   - Functions with non-empty effect row (e.g. `Console`, `Mutable`,
#     `State[T]`): op call sites + handler clauses pass `KaiValue *`,
#     and the kaic1-emitted closure thunk shape relies on boxed
#     args. v1 keeps these boxed; the call-site cost there is
#     amortised by the handler-dispatch path itself.
#   - Functions with closure-typed or non-primitive params /
#     returns: not in the classify set; stays boxed.
fn classify_unbox_sig(name: String, mo: Option[String], tparams: [String], params: [Param],
                      opt_ret: Option[TypeExpr], row: RowExpr, body: Expr) : Option[UFnSig] {
  # Top-level `main` keeps its boxed signature: the runtime
  # entry-point shim `int main(argc, argv)` calls `kai_main()` and
  # casts the result to `KaiValue *` for the closing decref. A
  # raw-Int main would clash with that ABI.
  if name == "main" and (match mo { None -> true _ -> false }) { None }
  else if list_length(tparams) > 0 { None }
  else if body_is_ffi_extern(body) { None }
  else if not row_is_empty(row_of_expr(row)) { None }
  else if body_is_effectful(body) { None }
  else if not all_params_unboxable(params) { None }
  else {
    match opt_ret {
      None -> None
      Some(rty) -> {
        let ret_t = resolve_ty(rty)
        if ty_is_unboxable_t(ret_t) {
          Some(US(map(params, param_ty), ret_t))
        } else { None }
      }
    }
  }
}

# Phase 3 unboxing — recognise body shapes that pull in handler
# evidence even when the user did not declare an effect row. v1
# is conservative: any `EHandle`, `var` desugar (SVar), or
# `Eff.op(...)` call (EModCall to a known effect, or EVar to a
# qualified op name) disqualifies the fn. This catches the
# `fn run(b: Bool) : Int { var inner = 100; ... }` shape where
# the row is empty syntactically but the body installs a
# `State[Int]` handler at run time.
fn body_is_effectful(e: Expr) : Bool = body_kind_is_effectful(e.kind)

fn body_kind_is_effectful(k: ExprKind) : Bool {
  match k {
    EHandle(_, _, _, _, _, _, _) -> true
    EBang(_) -> true
    EVar(nm) -> string_contains_dot(nm) or is_mutable_intrinsic_name(nm)
    ECall(callee, args_) -> {
      if body_is_effectful(callee) { true }
      else { any_arg_effectful(args_) }
    }
    EBinop(_, a, b) -> body_is_effectful(a) or body_is_effectful(b)
    EUnop(_, x) -> body_is_effectful(x)
    EIf(c, t_, eo) -> body_is_effectful(c) or body_is_effectful(t_) or body_opt_is_effectful(eo)
    EMatch(scr, arms) -> body_is_effectful(scr) or any_arm_effectful(arms)
    EBlock(stmts, tail) -> any_stmt_effectful(stmts) or body_opt_is_effectful(tail)
    ELambda(_, _) -> false
    EField(b, _) -> body_is_effectful(b)
    EIndex(a, b) -> body_is_effectful(a) or body_is_effectful(b)
    ERecordLit(_, fs) -> any_field_effectful(fs)
    EList(els) -> any_elem_effectful(els)
    ERange(a, b, opt_step) -> body_is_effectful(a) or body_is_effectful(b) or body_opt_is_effectful(opt_step)
    EPipe(a, b) -> body_is_effectful(a) or body_is_effectful(b)
    EMapPipe(a, b) -> body_is_effectful(a) or body_is_effectful(b)
    EFlatMapPipe(a, b) -> body_is_effectful(a) or body_is_effectful(b)
    EFilterPipe(a, b) -> body_is_effectful(a) or body_is_effectful(b)
    ELitUnit(inner, _) -> body_is_effectful(inner)
    EModCall(_, _) -> true
    _ -> false
  }
}

fn body_opt_is_effectful(opt: Option[Expr]) : Bool {
  match opt {
    Some(e) -> body_is_effectful(e)
    None    -> false
  }
}

fn any_arg_effectful(es: [Expr]) : Bool {
  match es {
    [] -> false
    [h, ...rest] -> if body_is_effectful(h) { true } else { any_arg_effectful(rest) }
  }
}

fn any_arm_effectful(arms: [Arm]) : Bool {
  match arms {
    [] -> false
    [Arm(_, g, b), ...rest] -> {
      if body_opt_is_effectful(g) { true }
      else if body_is_effectful(b) { true }
      else { any_arm_effectful(rest) }
    }
  }
}

fn any_field_effectful(fs: [FieldInit]) : Bool {
  match fs {
    [] -> false
    [FI(_, v), ...rest] -> if body_is_effectful(v) { true } else { any_field_effectful(rest) }
  }
}

fn any_elem_effectful(els: [ListElem]) : Bool {
  match els {
    [] -> false
    [ElPlain(x), ...rest] -> if body_is_effectful(x) { true } else { any_elem_effectful(rest) }
    [ElSpread(x), ...rest] -> if body_is_effectful(x) { true } else { any_elem_effectful(rest) }
  }
}

fn any_stmt_effectful(ss: [Stmt]) : Bool {
  match ss {
    [] -> false
    [s, ...rest] -> if stmt_is_effectful(s) { true } else { any_stmt_effectful(rest) }
  }
}

fn stmt_is_effectful(s: Stmt) : Bool {
  match s {
    SLet(_, _, rhs) -> body_is_effectful(rhs)
    # `var x = init` desugars into a `State[T]` handler at codegen.
    # That handler installs evidence at run time even when the
    # declared row is empty, so any SVar disqualifies the enclosing
    # fn from raw-signature classification.
    SVar(_, _, _, _, _) -> true
    SAssert(cond, m) -> body_is_effectful(cond) or body_opt_is_effectful(m)
    SExprStmt(x) -> body_is_effectful(x)
    SIndexAssign(b, i, v, _, _) -> body_is_effectful(b) or body_is_effectful(i) or body_is_effectful(v)
    SUse(_, _, _) -> false
  }
}

# Phase 3 unboxing — `array_*` and `ref_*` are post-desugar
# remnants of `var x = init` (m7b #5b). The desugar lowers `var`
# into a let-bound slot (`let x__slot = array_make(1, init)`)
# whose subsequent `x.get()`/`x.set()` reads become
# `array_get(slot, 0)` / `array_set(slot, 0, v)`. Detecting any
# of these names in the body of an otherwise-empty-row fn guards
# against a UFn classification that would mishandle the slot's
# RC + handler installation.
fn is_mutable_intrinsic_name(nm: String) : Bool =
  nm == "array_make" or nm == "array_get" or nm == "array_set" or
  nm == "array_length" or nm == "array_grow" or
  nm == "ref_make" or nm == "ref_get" or nm == "ref_set"

fn row_is_empty(r: Row) : Bool =
  list_length(r.labels) == 0 and (match r.tail { None -> true _ -> false })

fn all_params_unboxable(ps: [Param]) : Bool {
  match ps {
    [] -> true
    [p, ...rest] -> {
      let pt = param_ty(p)
      if ty_is_unboxable_t(pt) { all_params_unboxable(rest) }
      else { false }
    }
  }
}

fn register_fn_decls(decls: [Decl]) : [EFn] {
  match decls {
    [] -> []
    [d, ...rest] -> match fn_of_decl(d) {
      Some(fs) -> [fs, ...register_fn_decls(rest)]
      None -> register_fn_decls(rest)
    }
  }
}

# m6.2 v2: a pair of an ambiguous bare-name and the surface names of
# the modules that export it. Constructed by `find_ambig_efns` and
# consumed by `report_ambig_efns` (compile-time warning) and
# `is_ambig_name` (codegen-time short-circuit).
type AmbigEntry = AmbE(String, [String])

# m6.2 v2: return one AmbigEntry per name N that is exported by two
# or more modules and has no root-file definition. Only such names
# are ambiguous at a bare-name call site — when a root entry exists,
# the locals-shadow-imports rule (efn_pick_root) picks the root
# silently; when only one module exports the name, the resolution
# is unique. Iteration is O(|fns|^2) — fine, |fns| stays in the
# low thousands even with the full prelude chain loaded.
fn find_ambig_efns(fns: [EFn], target_origin: Option[String]) : [AmbigEntry] =
  find_ambig_loop(fns, target_origin, [], [])

fn find_ambig_loop(fns: [EFn], target_origin: Option[String], seen: [String], acc: [AmbigEntry]) : [AmbigEntry] {
  match fns {
    [] -> list_reverse(acc)
    [h, ...rest] -> match h {
      EFn(n, _, _, _) ->
        if list_has(seen, n) { find_ambig_loop(rest, target_origin, seen, acc) }
        else {
          let cands = efn_collect_matching(fns, n, [])
          let count = list_length(cands)
          if count <= 1 { find_ambig_loop(rest, target_origin, [n, ...seen], acc) }
          else {
            match efn_pick_root(cands) {
              Some(_) -> find_ambig_loop(rest, target_origin, [n, ...seen], acc)
              None    -> {
                let mods = ambig_mods_of(cands, [])
                # Issue #335: if the calling file (the target) exports
                # this name itself, the file-local rule resolves the
                # ambiguity inside that file's bodies — no warning.
                if mods_contain_target(mods, target_origin) {
                  find_ambig_loop(rest, target_origin, [n, ...seen], acc)
                } else {
                  let entry = AmbE(n, mods)
                  find_ambig_loop(rest, target_origin, [n, ...seen], [entry, ...acc])
                }
              }
            }
          }
        }
    }
  }
}

fn mods_contain_target(mods: [String], target_origin: Option[String]) : Bool =
  match target_origin {
    None    -> false
    Some(m) -> list_has(mods, m)
  }

fn ambig_mods_of(cands: [EFn], acc: [String]) : [String] {
  match cands {
    [] -> list_reverse(acc)
    [h, ...rest] -> match h {
      EFn(_, _, None, _)    -> ambig_mods_of(rest, acc)
      EFn(_, _, Some(m), _) ->
        if list_has(acc, m) { ambig_mods_of(rest, acc) }
        else                { ambig_mods_of(rest, [m, ...acc]) }
    }
  }
}

# issue #243: emit a stderr warning for each ambiguous bare-name
# that the user's root file ACTUALLY calls without a qualifier. The
# m6.2 v2 design fired one warning per ambiguous export regardless
# of usage; that produced 9 spurious warnings on hello-world after
# the prelude grew to two modules exporting `map`/`repeat`/etc.
# (PR #241 retired the colliding aliases, but two-module overlaps
# remain by design — `option.map` and `result.map` are intentionally
# both exported). The body walk we now perform is bounded by the
# root file's AST, not the prelude, so it stays cheap.
fn report_ambig_efns(amb: [AmbigEntry], used: [String]) : Unit / Console = match amb {
  [] -> ()
  [a, ...rest] -> match a {
    AmbE(name, mods) -> {
      if list_has(used, name) {
        eprint(concat_all([
          "warning: bare name '", name,
          "' is exported by multiple modules with no root-file shadow: ",
          join_with(mods, ", "),
          "; use a qualified call (e.g. ", list_head_or(mods, "<mod>"),
          ".", name, "(...)) to disambiguate"
        ]))
      } else { () }
      report_ambig_efns(rest, used)
    }
  }
}

# issue #243: collect the set of bare-name callees used in the root
# file's decls. A "bare-name callee" is `ECall(callee, _)` where the
# callee node is `EVar(name)` — i.e. an unqualified function call.
# Qualified calls (`m.f(...)`) parse as `ECall(EField(EVar(m), f), _)`
# or are rewritten to `EModCall` post-resolution; both are skipped.
# Module-origin filtering happens at the caller (only root decls are
# walked), so this returns the nameset for the active root file alone.
fn collect_root_bare_callees(decls: [Decl], acc: [String]) : [String] = match decls {
  []           -> acc
  [d, ...rest] -> collect_root_bare_callees(rest, collect_root_bare_callees_decl(d, acc))
}

fn collect_root_bare_callees_decl(d: Decl, acc: [String]) : [String] = match d {
  DFn(_, _, _, _, _, _, body, _, _, mo) -> match mo {
    None    -> walk_bare_callees(body, acc)
    Some(_) -> acc
  }
  DTest(_, body, _, _)        -> walk_bare_callees(body, acc)
  DBench(_, body, _, _)       -> walk_bare_callees(body, acc)
  DCheck(_, _, body, _, _)    -> walk_bare_callees(body, acc)
  _ -> acc
}

fn walk_bare_callees(e: Expr, acc: [String]) : [String] = match e.kind {
  EInt(_)             -> acc
  EReal(_)            -> acc
  EBool(_)            -> acc
  EChar(_)            -> acc
  EStr(_, _)          -> acc
  EUnit               -> acc
  EVar(_)             -> acc
  EUnder              -> acc
  EPlaceholder        -> acc
  EHole(_)            -> acc
  ETodo(_)            -> acc
  EVariantsOf(_, _)   -> acc
  EModCall(_, _)      -> acc
  ECall(callee, args_) -> {
    let acc1 = match callee.kind {
      EVar(name) -> if list_has(acc, name) { acc } else { [name, ...acc] }
      _          -> walk_bare_callees(callee, acc)
    }
    walk_bare_callees_list(args_, acc1)
  }
  EField(base, _)     -> walk_bare_callees(base, acc)
  EIndex(a, b)        -> walk_bare_callees(b, walk_bare_callees(a, acc))
  EBinop(_, a, b)     -> walk_bare_callees(b, walk_bare_callees(a, acc))
  EUnop(_, x)         -> walk_bare_callees(x, acc)
  EIf(c, t, eo)       -> {
    let a1 = walk_bare_callees(t, walk_bare_callees(c, acc))
    match eo { Some(b) -> walk_bare_callees(b, a1) None -> a1 }
  }
  EMatch(scr, arms)   -> walk_bare_callees_arms(arms, walk_bare_callees(scr, acc))
  ELambda(_, body)    -> walk_bare_callees(body, acc)
  ERecordLit(_, fs)   -> walk_bare_callees_fields(fs, acc)
  EList(els)          -> walk_bare_callees_elems(els, acc)
  ERange(a, b, opt)   -> {
    let a1 = walk_bare_callees(b, walk_bare_callees(a, acc))
    match opt { Some(s) -> walk_bare_callees(s, a1) None -> a1 }
  }
  EBlock(stmts, tail) -> {
    let a1 = walk_bare_callees_stmts(stmts, acc)
    match tail { Some(t) -> walk_bare_callees(t, a1) None -> a1 }
  }
  EPipe(a, b)         -> walk_bare_callees(b, walk_bare_callees(a, acc))
  EMapPipe(a, b)      -> walk_bare_callees(b, walk_bare_callees(a, acc))
  EFlatMapPipe(a, b)  -> walk_bare_callees(b, walk_bare_callees(a, acc))
  EFilterPipe(a, b)   -> walk_bare_callees(b, walk_bare_callees(a, acc))
  EBang(inner)        -> walk_bare_callees(inner, acc)
  ELitUnit(inner, _)  -> walk_bare_callees(inner, acc)
  EHandle(body, _, _, init_opt, _, clauses, ret_opt) -> {
    let a1 = walk_bare_callees(body, acc)
    let a2 = match init_opt { Some(i) -> walk_bare_callees(i, a1) None -> a1 }
    let a3 = walk_bare_callees_clauses(clauses, a2)
    match ret_opt {
      Some(r) -> match r { HR(_, b, _, _) -> walk_bare_callees(b, a3) }
      None    -> a3
    }
  }
}

fn walk_bare_callees_list(es: [Expr], acc: [String]) : [String] = match es {
  []           -> acc
  [h, ...rest] -> walk_bare_callees_list(rest, walk_bare_callees(h, acc))
}

fn walk_bare_callees_arms(arms: [Arm], acc: [String]) : [String] = match arms {
  []           -> acc
  [a, ...rest] -> match a {
    Arm(_, opt_guard, body) -> {
      let a1 = match opt_guard { Some(g) -> walk_bare_callees(g, acc) None -> acc }
      walk_bare_callees_arms(rest, walk_bare_callees(body, a1))
    }
  }
}

fn walk_bare_callees_fields(fs: [FieldInit], acc: [String]) : [String] = match fs {
  []           -> acc
  [f, ...rest] -> match f {
    FI(_, e) -> walk_bare_callees_fields(rest, walk_bare_callees(e, acc))
  }
}

fn walk_bare_callees_elems(els: [ListElem], acc: [String]) : [String] = match els {
  []           -> acc
  [el, ...rest] -> match el {
    ElPlain(e)  -> walk_bare_callees_elems(rest, walk_bare_callees(e, acc))
    ElSpread(e) -> walk_bare_callees_elems(rest, walk_bare_callees(e, acc))
  }
}

fn walk_bare_callees_stmts(ss: [Stmt], acc: [String]) : [String] = match ss {
  []           -> acc
  [s, ...rest] -> match s {
    SLet(_, _, e)        -> walk_bare_callees_stmts(rest, walk_bare_callees(e, acc))
    SVar(_, _, e, _, _)  -> walk_bare_callees_stmts(rest, walk_bare_callees(e, acc))
    SAssert(e, og)       -> {
      let a1 = walk_bare_callees(e, acc)
      let a2 = match og { Some(g) -> walk_bare_callees(g, a1) None -> a1 }
      walk_bare_callees_stmts(rest, a2)
    }
    SExprStmt(e)         -> walk_bare_callees_stmts(rest, walk_bare_callees(e, acc))
    SIndexAssign(a, b, c, _, _) -> {
      let a1 = walk_bare_callees(c, walk_bare_callees(b, walk_bare_callees(a, acc)))
      walk_bare_callees_stmts(rest, a1)
    }
    SUse(_, _, _)        -> walk_bare_callees_stmts(rest, acc)
  }
}

fn walk_bare_callees_clauses(cs: [HClause], acc: [String]) : [String] = match cs {
  []           -> acc
  [c, ...rest] -> match c {
    HC(_, _, body, _, _) -> walk_bare_callees_clauses(rest, walk_bare_callees(body, acc))
  }
}

# issue #381: warn on unused local `let` and pattern bindings.
#
# Policy (validated in the issue body):
#   - Local `let name = …` whose `name` is never referenced inside its
#     lexical scope: warn.
#   - Pattern binding (e.g. `Some(v) -> body` without `v` in body): warn.
#   - Function parameter unused: never warn (interface / protocol /
#     contract with caller).
#   - Any binder whose name starts with `_` (including `__`-prefixed
#     compiler-internal names like `__cv_*`, `__pcs_ret`): never warn.
#     `name_is_unused` already encodes the user-facing convention; we
#     extend the silence to `__`-prefixed names here because every
#     desugar that synthesises locals uses that namespace.
#
# The walker runs post-typer / pre-monomorphise (alongside
# `report_ambig_efns`). Running pre-mono avoids duplicate diagnostics
# from per-spec body copies; running post-typer means the AST has
# already been resolved (no spurious "use" via alias names).
#
# Reference detection uses `fv_expr` with empty `own` and `globals`,
# which yields the set of every free `EVar(name)` reachable from the
# sub-AST modulo scope rules already encoded in `fv_stmts_scoped`
# (so a re-binding of `name` inside the rest correctly shadows our
# binder for refs after the shadow). This is over-approximating in
# the conservative direction — when in doubt we mark the binding
# *used*, not unused.

fn diag_warning(file: String, line: Int, col: Int, msg: String) : Unit / Console + File {

  eprint("warning: #{msg}")
  eprint("  --> #{file}:#{int_to_string(line)}:#{int_to_string(col)}")
  emit_source_caret(file, line, col)
}

fn name_is_silenced(name: String) : Bool {
  # `_`-prefixed (including `__`-prefixed compiler-internal names) =
  # intentionally unused. `name_is_unused` only matches `_x` (not
  # `__x`); for diagnostics we silence the broader `_*` family.
  match char_at(name, 0) {
    Some(c0) -> c0 == '_'
    None -> false
  }
}

# Collect (name, line, col) triples for every binder a pattern
# introduces. Uses the pattern's own line/col — for destructuring
# patterns (`(x, y)`, `Some(v)`) all sub-binders share the outer
# pattern's location, which is the closest stable anchor stage 1
# preserves.
type UBind = UB(String, Int, Int)

fn pat_ubinds(pat: Pattern, acc: [UBind]) : [UBind] {
  let line = pat.line
  let col = pat.col
  match pat.pkind {
    PWild -> acc
    PLit(_) -> acc
    PBind(name) -> [UB(name, line, col), ...acc]
    PList(pats, opt_rest) -> {
      let acc1 = pat_ubinds_loop(pats, acc)
      match opt_rest {
        Some(rname) -> [UB(rname, line, col), ...acc1]
        None -> acc1
      }
    }
    PVariant(_, subs) -> pat_ubinds_loop(subs, acc)
    PVariantRecord(_, fields) -> pfield_ubinds_loop(fields, acc)
    PRecord(fields) -> pfield_ubinds_loop(fields, acc)
    PHole(_) -> acc
    PAs(name, sub) -> pat_ubinds(sub, [UB(name, line, col), ...acc])
    PNarrow(name, _) -> [UB(name, line, col), ...acc]
  }
}

fn pat_ubinds_loop(ps: [Pattern], acc: [UBind]) : [UBind] {
  match ps {
    [] -> acc
    [p, ...rest] -> pat_ubinds_loop(rest, pat_ubinds(p, acc))
  }
}

fn pfield_ubinds_loop(fs: [PField], acc: [UBind]) : [UBind] {
  match fs {
    [] -> acc
    [f, ...rest] -> match f {
      PField(_, sub, _) -> pfield_ubinds_loop(rest, pat_ubinds(sub, acc))
    }
  }
}

fn report_unused_ubinds(file: String, ubs: [UBind], refs: [String]) : Unit / Console + File {

  match ubs {
    [] -> ()
    [u, ...rest] -> match u {
      UB(name, line, col) -> {
        if name_is_silenced(name) { () }
        else if list_has(refs, name) { () }
        else {
          diag_warning(file, line, col,
            concat_all(["unused binding `", name, "`"]))
          diag_help("prefix with `_` to mark as intentionally unused")
        }
        report_unused_ubinds(file, rest, refs)
      }
    }
  }
}

# Walk a decl looking for unused local bindings. Skips parameter
# names entirely — interface compliance, protocol dispatch, and
# axiom signatures all justify silent unused params.
fn report_unused_in_decls(file: String, decls: [Decl]) : Unit / Console + File {

  match decls {
    [] -> ()
    [d, ...rest] -> {
      report_unused_in_decl(file, d)
      report_unused_in_decls(file, rest)
    }
  }
}

fn report_unused_in_decl(file: String, d: Decl) : Unit / Console + File {

  match d {
    DFn(_, _, _, _, _, _, body, _, _, mo) -> match mo {
      None    -> report_unused_in_expr(file, body)
      Some(_) -> ()
    }
    DTest(_, body, _, _)        -> report_unused_in_expr(file, body)
    DBench(_, body, _, _)       -> report_unused_in_expr(file, body)
    DCheck(_, _, body, _, _)    -> report_unused_in_expr(file, body)
    _ -> ()
  }
}

fn report_unused_in_expr(file: String, e: Expr) : Unit / Console + File {

  match e.kind {
    EInt(_) -> ()
    EReal(_) -> ()
    EBool(_) -> ()
    EChar(_) -> ()
    EStr(_, _) -> ()
    EUnit -> ()
    EVar(_) -> ()
    EUnder -> ()
    EPlaceholder -> ()
    EHole(_) -> ()
    ETodo(_) -> ()
    EVariantsOf(_, _) -> ()
    EModCall(_, _) -> ()
    ECall(f, xs) -> {
      report_unused_in_expr(file, f)
      report_unused_in_exprs(file, xs)
    }
    EField(base, _) -> report_unused_in_expr(file, base)
    EIndex(a, b) -> {
      report_unused_in_expr(file, a)
      report_unused_in_expr(file, b)
    }
    EBinop(_, a, b) -> {
      report_unused_in_expr(file, a)
      report_unused_in_expr(file, b)
    }
    EUnop(_, x) -> report_unused_in_expr(file, x)
    EIf(c, t, eo) -> {
      report_unused_in_expr(file, c)
      report_unused_in_expr(file, t)
      match eo { Some(b) -> report_unused_in_expr(file, b) None -> () }
    }
    EMatch(scr, arms) -> {
      report_unused_in_expr(file, scr)
      report_unused_in_arms(file, arms)
    }
    ELambda(_, body) -> report_unused_in_expr(file, body)
    ERecordLit(_, fs) -> report_unused_in_field_inits(file, fs)
    EList(els) -> report_unused_in_list_elems(file, els)
    ERange(a, b, opt) -> {
      report_unused_in_expr(file, a)
      report_unused_in_expr(file, b)
      match opt { Some(s) -> report_unused_in_expr(file, s) None -> () }
    }
    EBlock(stmts, tail) -> report_unused_in_block(file, stmts, tail)
    EPipe(a, b) -> {
      report_unused_in_expr(file, a)
      report_unused_in_expr(file, b)
    }
    EMapPipe(a, b) -> {
      report_unused_in_expr(file, a)
      report_unused_in_expr(file, b)
    }
    EFlatMapPipe(a, b) -> {
      report_unused_in_expr(file, a)
      report_unused_in_expr(file, b)
    }
    EFilterPipe(a, b) -> {
      report_unused_in_expr(file, a)
      report_unused_in_expr(file, b)
    }
    EBang(inner) -> report_unused_in_expr(file, inner)
    ELitUnit(inner, _) -> report_unused_in_expr(file, inner)
    EHandle(body, _, _, init_opt, _, clauses, ret_opt) -> {
      report_unused_in_expr(file, body)
      match init_opt { Some(i) -> report_unused_in_expr(file, i) None -> () }
      report_unused_in_hclauses(file, clauses)
      match ret_opt {
        Some(r) -> match r { HR(_, b, _, _) -> report_unused_in_expr(file, b) }
        None -> ()
      }
    }
  }
}

fn report_unused_in_exprs(file: String, es: [Expr]) : Unit / Console + File {

  match es {
    [] -> ()
    [h, ...rest] -> {
      report_unused_in_expr(file, h)
      report_unused_in_exprs(file, rest)
    }
  }
}

fn report_unused_in_arms(file: String, arms: [Arm]) : Unit / Console + File {

  match arms {
    [] -> ()
    [a, ...rest] -> match a {
      Arm(pat, opt_g, body) -> {
        # An arm's pattern binders are visible in the (optional)
        # guard and the body. Collect references from both, then
        # warn on any binder absent from the union.
        let ubs = pat_ubinds(pat, [])
        let refs0 = match opt_g {
          Some(g) -> fv_expr(g, [], [], [])
          None    -> []
        }
        let refs = fv_expr(body, [], [], refs0)
        report_unused_ubinds(file, ubs, refs)
        match opt_g { Some(g) -> report_unused_in_expr(file, g) None -> () }
        report_unused_in_expr(file, body)
        report_unused_in_arms(file, rest)
      }
    }
  }
}

fn report_unused_in_field_inits(file: String, fs: [FieldInit]) : Unit / Console + File {

  match fs {
    [] -> ()
    [f, ...rest] -> match f {
      FI(_, e) -> {
        report_unused_in_expr(file, e)
        report_unused_in_field_inits(file, rest)
      }
    }
  }
}

fn report_unused_in_list_elems(file: String, els: [ListElem]) : Unit / Console + File {

  match els {
    [] -> ()
    [el, ...rest] -> {
      match el {
        ElPlain(e)  -> report_unused_in_expr(file, e)
        ElSpread(e) -> report_unused_in_expr(file, e)
      }
      report_unused_in_list_elems(file, rest)
    }
  }
}

fn report_unused_in_hclauses(file: String, cs: [HClause]) : Unit / Console + File {

  match cs {
    [] -> ()
    [c, ...rest] -> match c {
      HC(_, _, body, _, _) -> {
        report_unused_in_expr(file, body)
        report_unused_in_hclauses(file, rest)
      }
    }
  }
}

# Walk a block in source order. For each `SLet(pat, _, rhs)`:
#   1. Recurse into `rhs` (its body cannot reference the pattern's
#      binders — they aren't in scope yet).
#   2. Compute the set of free names referenced in the rest of the
#      block (subsequent stmts + optional tail). `fv_stmts_scoped`
#      respects shadowing — a later `SLet` of the same name kicks
#      that name out of `acc` for refs after the shadow point.
#   3. Warn on any pat-binder absent from that ref set.
fn report_unused_in_block(file: String, stmts: [Stmt], tail: Option[Expr]) : Unit / Console + File {

  match stmts {
    [] -> match tail {
      Some(t) -> report_unused_in_expr(file, t)
      None    -> ()
    }
    [s, ...rest] -> {
      match s {
        SLet(pat, _, rhs) -> {
          report_unused_in_expr(file, rhs)
          let ubs = pat_ubinds(pat, [])
          let rest_refs = fv_stmts(rest, [], [], [])
          let refs = match tail {
            Some(t) -> fv_expr(t, [], [], rest_refs)
            None    -> rest_refs
          }
          report_unused_ubinds(file, ubs, refs)
        }
        SVar(_, _, rhs, _, _) -> report_unused_in_expr(file, rhs)
        SAssert(c, opt_m) -> {
          report_unused_in_expr(file, c)
          match opt_m { Some(m) -> report_unused_in_expr(file, m) None -> () }
        }
        SExprStmt(x) -> report_unused_in_expr(file, x)
        SIndexAssign(b, i, v, _, _) -> {
          report_unused_in_expr(file, b)
          report_unused_in_expr(file, i)
          report_unused_in_expr(file, v)
        }
        SUse(_, _, _) -> ()
      }
      report_unused_in_block(file, rest, tail)
    }
  }
}

fn list_head_or(xs: [String], fallback: String) : String = match xs {
  [] -> fallback
  [h, ..._rest] -> h
}

fn builtin_variants() : [EVar] =
  [EV("Some", 1), EV("None", 0), EV("Ok", 1), EV("Err", 1)]

fn collect_user_variants_loop(ds: [Decl], acc: [EVar]) : [EVar] {
  match ds {
    [] -> acc
    [d, ...rest] -> match d {
      DType(_, _, _, body, _, _) -> match body {
        TBSum(vs) -> collect_user_variants_loop(rest, vs_to_evars(vs, acc))
        _ -> collect_user_variants_loop(rest, acc)
      }
      _ -> collect_user_variants_loop(rest, acc)
    }
  }
}

fn vs_to_evars(vs: [Variant], acc: [EVar]) : [EVar] {
  match vs {
    [] -> acc
    [v, ...rest] -> match v {
      Var(n, tys) -> vs_to_evars(rest, [EV(n, list_length(tys)), ...acc])
    }
  }
}

fn register_variants(decls: [Decl]) : [EVar] =
  collect_user_variants_loop(decls, builtin_variants())

# ---- prelude mapping for emission ----
#
# For user-facing builtins, we map to their runtime C symbol and arity.
# Stage 1 mirrors stage 0's table 1:1.

type EPrelude = EP(String, String, Int)     # kai name, c name, arity

fn prelude_table() : [EPrelude] {
  [
    EP("print",            "kai_prelude_print",            1),
    EP("eprint",           "kai_prelude_eprint",           1),
    EP("panic",            "kai_prelude_panic",            1),
    EP("exit",             "kai_prelude_exit",             1),
    EP("int_to_string",    "kai_prelude_int_to_string",    1),
    EP("real_to_string",   "kai_prelude_real_to_string",   1),
    EP("int_to_real",      "kai_prelude_int_to_real",      1),
    EP("real_to_int",      "kai_prelude_real_to_int",      1),
    # libm bindings (issue #343) — pass-through NaN/Inf semantics.
    EP("real_sqrt",        "kai_prelude_real_sqrt",        1),
    EP("real_cbrt",        "kai_prelude_real_cbrt",        1),
    EP("real_exp",         "kai_prelude_real_exp",         1),
    EP("real_log",         "kai_prelude_real_log",         1),
    EP("real_log2",        "kai_prelude_real_log2",        1),
    EP("real_log10",       "kai_prelude_real_log10",       1),
    EP("real_sin",         "kai_prelude_real_sin",         1),
    EP("real_cos",         "kai_prelude_real_cos",         1),
    EP("real_tan",         "kai_prelude_real_tan",         1),
    EP("real_asin",        "kai_prelude_real_asin",        1),
    EP("real_acos",        "kai_prelude_real_acos",        1),
    EP("real_atan",        "kai_prelude_real_atan",        1),
    EP("real_sinh",        "kai_prelude_real_sinh",        1),
    EP("real_cosh",        "kai_prelude_real_cosh",        1),
    EP("real_tanh",        "kai_prelude_real_tanh",        1),
    EP("real_signum",      "kai_prelude_real_signum",      1),
    EP("real_is_nan",      "kai_prelude_real_is_nan",      1),
    EP("real_is_inf",      "kai_prelude_real_is_inf",      1),
    EP("real_pow",         "kai_prelude_real_pow",         2),
    EP("real_atan2",       "kai_prelude_real_atan2",       2),
    EP("real_rem",         "kai_prelude_real_rem",         2),
    EP("string_length",    "kai_prelude_string_length",    1),
    EP("string_concat",    "kai_prelude_string_concat",    2),
    EP("string_concat_all","kai_prelude_string_concat_all",1),
    EP("string_join",      "kai_prelude_string_join",      2),
    EP("list_length",      "kai_prelude_list_length",      1),
    EP("list_append",      "kai_prelude_list_append",      2),
    EP("list_reverse",     "kai_prelude_list_reverse",     1),
    EP("map",              "kai_prelude_map",              2),
    # issue #201: paired runtime entry for the `||` flat-map pipe.
    # Same shape as `map`; head-type-to-module dispatch in
    # `synth_flat_map_pipe` resolves to `<module>.flat_map`, and the
    # module bound to head-type `List` is `list` whose `flat_map` lands
    # on this prelude symbol so `[T]` works without an explicit import.
    EP("flat_map",         "kai_prelude_flat_map",         2),
    EP("filter",           "kai_prelude_filter",           2),
    EP("reduce",           "kai_prelude_reduce",           3),
    EP("each",             "kai_prelude_each",             2),
    EP("args",             "kai_prelude_args",             0),
    # Issue #127: argv[0] as a flat prelude (path (a) in the issue
    # body, mirroring how `args()` is also a prelude even though
    # `Env.args()` exists as an op). `stdlib/os/args.kai` re-exports
    # this as `program_name()` so the dotted-call surface stays
    # uniform with the rest of `os.args`.
    EP("program_name",     "kai_prelude_program_name",     0),
    EP("read_file",        "kai_prelude_read_file",        1),
    EP("write_file",       "kai_prelude_write_file",       2),
    # Issue #345: fs/file expansion (exists/delete/rename).
    EP("file_exists",      "kai_prelude_file_exists",      1),
    EP("file_delete",      "kai_prelude_file_delete",      1),
    EP("file_rename",      "kai_prelude_file_rename",      2),
    # Issue #482: binary file IO (deferred from #345).
    EP("file_read_bytes",  "kai_prelude_file_read_bytes",  1),
    EP("file_write_bytes", "kai_prelude_file_write_bytes", 2),
    # Issue #344: fs/dir surface (list/create/remove/walk).
    EP("dir_list_dir",     "kai_prelude_dir_list_dir",     1),
    EP("dir_create_dir",   "kai_prelude_dir_create_dir",   1),
    EP("dir_remove_dir",   "kai_prelude_dir_remove_dir",   1),
    EP("dir_walk",         "kai_prelude_dir_walk",         1),
    EP("read_line",        "kai_prelude_read_line",        0),
    # Issue #453: byte-oriented stdin (LSP framing precursor).
    EP("read_bytes",       "kai_prelude_read_bytes",       1),
    EP("string_to_int",    "kai_prelude_string_to_int",    1),
    EP("string_to_real",   "kai_prelude_string_to_real",   1),
    EP("char_at",          "kai_prelude_char_at",          2),
    EP("string_split",     "kai_prelude_string_split",     2),
    EP("string_contains",  "kai_prelude_string_contains",  2),
    EP("string_slice",     "kai_prelude_string_slice",     3),
    EP("char_to_int",      "kai_prelude_char_to_int",      1),
    EP("int_to_char",      "kai_prelude_int_to_char",      1),
    # Lane 4 (#473): Byte nominal primitive. See add_prelude_sigs above
    # for the type-level surface; C bodies live in stage0/runtime.h.
    EP("int_to_byte",        "kai_prelude_int_to_byte",        1),
    EP("byte_to_int",        "kai_prelude_byte_to_int",        1),
    EP("byte_add",           "kai_prelude_byte_add",           2),
    EP("byte_sub",           "kai_prelude_byte_sub",           2),
    EP("byte_eq",            "kai_prelude_byte_eq",            2),
    EP("byte_lt",            "kai_prelude_byte_lt",            2),
    EP("byte_to_string",     "kai_prelude_byte_to_string",     1),
    EP("array_make",       "kai_prelude_array_make",       2),
    EP("array_length",     "kai_prelude_array_length",     1),
    EP("array_get",        "kai_prelude_array_get",        2),
    EP("array_set",        "kai_prelude_array_set",        3),
    EP("array_grow",       "kai_prelude_array_grow",       3),
    # m8 #7: mailbox runtime
    EP("mailbox_alloc",         "kai_prelude_mailbox_alloc",         0),
    EP("mailbox_alloc_bounded", "kai_prelude_mailbox_alloc_bounded", 2),
    EP("mailbox_send",          "kai_prelude_mailbox_send",          2),
    EP("mailbox_recv",          "kai_prelude_mailbox_recv",          1),
    EP("mailbox_free",          "kai_prelude_mailbox_free",          1),
    # Tier 2 spawn_actor — alloc-without-stamp + reassign owner to a
    # spawned fiber. Used by stdlib/actor.kai's `spawn_actor`.
    EP("mailbox_alloc_unowned",  "kai_prelude_mailbox_alloc_unowned",  0),
    EP("mailbox_assign_owner",   "kai_prelude_mailbox_assign_owner",   2)
  ]
}

fn prelude_find(target: String) : Option[EPrelude] {
  prelude_find_loop(prelude_table(), target)
}

fn prelude_find_loop(table: [EPrelude], target: String) : Option[EPrelude] {
  match table {
    [] -> None
    [ep, ...rest] -> match ep {
      EP(name, _, _) -> if name == target { Some(ep) } else { prelude_find_loop(rest, target) }
    }
  }
}

# ---- expression emission ----

fn emit_ident_callee(name: String) : String {
  match prelude_find(name) {
    Some(ep) -> match ep { EP(_, cname, _) -> cname }
    None -> cat2("kai_", name)
  }
}

# Emit an ident used as a value (not a call target).
#
# `lcs` is the lexical scope at this site — the list of local
# names currently bound by an enclosing fn param, lambda param,
# `let` / `var`, match-arm pattern, `use` desugar, or handle
# alias. Locals always win over a same-named top-level fn or
# prelude builtin: the user wrote `let drop = 5; drop` and the
# typer accepted it as a local read, so emit `kai_drop` (the C
# variable holding the local) rather than the top-level `drop`
# fn's closure thunk. Without this guard, `efn_find` matches the
# top-level fn and the local read silently hands back the wrong
# value (a closure pointer where the user expected an Int). The
# LLVM backend has had this guard since m3d (`llvm_local_find`
# in `llvm_emit_expr`); the C backend was missing it until m14
# v1.x.
fn emit_ident_value(name: String, lcs: [String], fns: [EFn], variants: [EVar]) : String {
  if list_has(lcs, name) { cat2("kai_", name) }
  else { match evar_find(variants, name) {
    Some(_) -> cat3("kai_variant(0, \"", name, "\", 0, NULL)")
    None -> match prelude_find(name) {
      Some(ep) -> match ep {
        EP(_, cname, ar) ->
          cat5("kai_closure(&_", cname, "_thunk, ", int_to_string(ar), ", 0, NULL)")
      }
      None -> match efn_resolve(fns, name) {
        Some(EFn(_, ar, mo, _)) ->
          cat5("kai_closure(&_kai_", c_sym(name, mo), "_thunk, ", int_to_string(ar), ", 0, NULL)")
        None -> cat2("kai_", name)
      }
    }
  } }
}

# Emit a raw string literal's *body* as a C string literal. For now this
# only handles hello-style cases: no #{...} interpolation, no \u{HHHH},
# the escapes that kaikai and C share are passed through unchanged.
# Later milestones extend this to full interpolation.
fn emit_string_lit_body(span: String) : String {
  # span includes opening and closing quotes; C literal syntax matches.
  span
}

# m7d §23: pick the runtime helper a `++` lowers to. The typer
# pins the binop's result type to `String` or `[T]`; anything else
# means we lost the annotation somewhere upstream.
fn concat_helper_of(opt_ty: Option[Ty]) : String {
  match opt_ty {
    Some(t) -> match t {
      TyString    -> "kai_prelude_string_concat"
      TyListT(_)  -> "kai_prelude_list_append"
      _           -> "kai_prelude_string_concat /* m7d §23: unexpected type */"
    }
    None -> "kai_prelude_string_concat /* m7d §23: missing type */"
  }
}

fn binop_cname(op: String) : Option[String] {
  if op == "+" { Some("kai_op_add") }
  else if op == "-" { Some("kai_op_sub") }
  else if op == "*" { Some("kai_op_mul") }
  else if op == "/" { Some("kai_op_div") }
  else if op == "%" { Some("kai_op_mod") }
  else if op == "^" { Some("kai_op_pow_int") }
  else if op == "<" { Some("kai_op_lt") }
  else if op == ">" { Some("kai_op_gt") }
  else if op == "<=" { Some("kai_op_le") }
  else if op == ">=" { Some("kai_op_ge") }
  else if op == "==" { Some("kai_op_eq_v") }
  else if op == "!=" { Some("kai_op_ne_v") }
  else { None }
}

fn unop_cname(op: String) : Option[String] {
  if op == "-" { Some("kai_op_neg") }
  else if op == "not" { Some("kai_op_boolnot") }
  else { None }
}

fn emit_call_args(src: String, args_e: [Expr], lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : String / Console =

  join_with(map(args_e, (a) => emit_expr(src, a, lcs, fns, variants, lams, cls)), ", ")

# Phase 3 unboxing — emit each call argument as a raw C scalar
# matching the UFn signature's slot ty. `emit_expr_raw` falls back
# to the boxed-then-unbox boundary form if the arg is MBoxed; for
# raw children (literal / EVar to a raw param / nested UFn call /
# raw arith) it emits the native scalar directly. The result is
# the comma-joined argument list ready for the call site.
fn emit_call_args_raw(src: String, args_e: [Expr], lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : String / Console =

  join_with(map(args_e, (a) => emit_expr_raw(src, a, lcs, fns, variants, lams, cls)), ", ")

# m8.x bug #12: emit `KaiValue *_op_arg_<i> = <expr>; ` for each
# arg of an op call. The args are evaluated *before* the
# `in_dispatch` flag is set, so any inner op call to the same
# handler still finds the live node.
fn emit_op_arg_bindings(src: String, args_e: [Expr], i: Int,
                          lcs: [String], fns: [EFn],
                          variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : String / Console {

  match args_e {
    [] -> ""
    [a, ...rest] -> {
      let expr_c = emit_expr(src, a, lcs, fns, variants, lams, cls)
      let head = concat_all(["KaiValue *_op_arg_", int_to_string(i), " = ", expr_c, "; "])
      let tail = emit_op_arg_bindings(src, rest, i + 1, lcs, fns, variants, lams, cls)
      string_concat(head, tail)
    }
  }
}

# Comma-separated list `_op_arg_0, _op_arg_1, ...` that gets
# spliced into the dispatch call site after `_ev_op`.
fn emit_op_arg_pass_list(args_e: [Expr], i: Int) : String {
  match args_e {
    [] -> ""
    [_, ...rest] -> {
      let head = concat_all(["_op_arg_", int_to_string(i)])
      match rest {
        [] -> head
        _  -> concat_all([head, ", ", emit_op_arg_pass_list(rest, i + 1)])
      }
    }
  }
}

fn emit_variant_call(name: String, n_args: Int, arg_out: String) : String {
  if n_args == 0 {
    cat3("kai_variant(0, \"", name, "\", 0, NULL)")
  } else {
    concat_all([
      "kai_variant(0, \"", name, "\", ", int_to_string(n_args),
      ", (KaiValue *[]){", arg_out, "})"
    ])
  }
}

fn emit_call_expr(src: String, f: Expr, args_e: [Expr], lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : String / Console {

  # Phase 3 unboxing — when the callee resolves to a UFn (raw C
  # signature), emit the call against raw args and wrap the
  # result with `kai_int` / `kai_bool` / `kai_char` / `kai_real`
  # so the boxed-context caller still sees a `KaiValue *`. This
  # short-circuits the regular dispatch chain (variant / prelude /
  # closure-thunk fallback) because UFns are exclusively
  # user-declared top-level fns and cannot be overridden by an
  # `lcs` shadow with the same name (a let-bound closure shadowing
  # a UFn keeps the boxed call site — `lcs.has(name)` test wins).
  match emit_ufn_boxed_call(src, f, args_e, lcs, fns, variants, lams, cls) {
    Some(s) -> s
    None    -> emit_call_expr_default(src, f, args_e, lcs, fns, variants, lams, cls)
  }
}

# Phase 3 unboxing — try to emit the call as a raw-call boxed
# (`kai_<T>(callee(raw_args))`). Returns None when the callee
# does not resolve to a UFn; the caller falls back to the
# original boxed-only dispatch.
fn emit_ufn_boxed_call(src: String, f: Expr, args_e: [Expr], lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : Option[String] / Console {

  match f.kind {
    EVar(callee) ->
      if list_has(lcs, callee) { None }
      else { match efn_resolve(fns, callee) {
        Some(EFn(_, _, mo, Some(US(_, rt)))) -> {
          let raw_args = emit_call_args_raw(src, args_e, lcs, fns, variants, lams, cls)
          let raw_call = cat5("kai_", c_sym(callee, mo), "(", raw_args, ")")
          Some(box_wrap(Some(rt), raw_call))
        }
        _ -> None
      } }
    EModCall(mod, fname) -> match lookup_ufn_sig(fns, fname, Some(mod)) {
      Some(US(_, rt)) -> {
        let raw_args = emit_call_args_raw(src, args_e, lcs, fns, variants, lams, cls)
        let raw_call = cat5("kai_", c_sym(fname, Some(mod)), "(", raw_args, ")")
        Some(box_wrap(Some(rt), raw_call))
      }
      None -> None
    }
    _ -> None
  }
}

fn emit_call_expr_default(src: String, f: Expr, args_e: [Expr], lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : String / Console {

  let call_args = emit_call_args(src, args_e, lcs, fns, variants, lams, cls)
  match f.kind {
    EVar(callee) -> {
      # m7a #6d: `resume(v)` lowers to a runtime call that performs
      # the one-shot status check, flips the status, and tail-calls
      # the continuation's `fn` (currently kai_cont_identity, until
      # the full CPS transform reifies the rest of the caller's
      # body). Doc C §*resume representation*.
      if tcrec_is_sentinel(callee) {
        # Issue #37: self-tail-call site, planted by `tcrec_rewrite_decl`.
        # The callee carries `__kai_tcrec|<c_sym>|<dropmask>|<p0>|<p1>|...`;
        # split, parse, and emit the rebind+goto block. The label
        # `_kai_<c_sym>_entry` is planted by `emit_fn_body`.
        let parts = tcrec_split_pipe(callee)
        match parts {
          [_, sym, dropmask_str, ...pnames] -> {
            let dropmask = tcrec_parse_decimal(dropmask_str)
            tcrec_emit_goto(src, sym, dropmask, pnames, args_e,
                            lcs, fns, variants, lams, cls)
          }
          _ -> "kai_unit() /* tcrec: malformed sentinel */"
        }
      } else if callee == "resume" {
        match args_e {
          [a] -> concat_all([
            "kai_cont_resume(k, ", emit_expr(src, a, lcs, fns, variants, lams, cls), ")"
          ])
          # m7b #11: 2-arg resume `resume(v, new_state)` — used in
          # parameterised handler clauses (`State[T]` / `Writer[W]`).
          # Writes the new state into the enclosing Ev's `state` slot
          # before resuming. `self` is the clause's first argument.
          [a, ns] -> concat_all([
            "({ self->state = ",
            emit_expr(src, ns, lcs, fns, variants, lams, cls),
            "; kai_cont_resume(k, ",
            emit_expr(src, a, lcs, fns, variants, lams, cls),
            "); })"
          ])
          _   -> "kai_unit() /* resume: arity mismatch (expected 1 or 2 args) */"
        }
      } else if callee == "__perceus_dup" {
        # m5 #4 — AST-level dup, lowered to runtime `kai_incref`.
        # Inserted by `perceus_pass` around every non-last EVar read of
        # a binding that lives long enough to need an extra reference.
        match args_e {
          [a] -> concat_all([
            "kai_internal_dup(", emit_expr(src, a, lcs, fns, variants, lams, cls), ")"
          ])
          _   -> "kai_unit() /* __perceus_dup: arity mismatch */"
        }
      } else if callee == "__strip_unit" {
        # m12.8 phase 2: typer-internal erasure of the unit annotation
        # on `Real<u>`. At runtime it is identity — units carry no
        # representation, so the lowered call is exactly the inner
        # expression. Inherits the original `unitless` emit shape
        # (Bug 8 retired the user-visible name; the parametric Show
        # impl in stdlib/protocols.kai now uses this intrinsic to feed
        # `Real<u>` into `real_to_string : Real -> String`).
        match args_e {
          [a] -> emit_expr(src, a, lcs, fns, variants, lams, cls)
          _   -> "kai_unit() /* __strip_unit: expected 1 arg */"
        }
      } else if callee == "unit_name" {
        # m12.8.x phase 2 (Gap 1, partial): compile-time reflection
        # on the dimensioned argument. Inlines the canonical unit
        # symbol as a String literal. Reads the arg's `.ty` (which
        # the typed-AST finalisation pass populated with the fully
        # substituted type). When the unit is still a UVar (e.g.
        # the protocol-impl-generic case) or the arg type is bare
        # `Real` with no dimension, an empty string literal is
        # emitted instead of failing — keeps user code that calls
        # `unit_name` defensively well-defined.
        match args_e {
          [a] -> {
            let nm = unit_name_of_ty(a.ty)
            concat_all(["kai_str(\"", nm, "\")"])
          }
          _ -> "kai_unit() /* unit_name: expected 1 arg */"
        }
      } else if callee == "__perceus_drop" {
        # m5 #4 — AST-level drop, lowered to runtime `kai_decref`
        # (returns Unit so the call site type-checks as KaiValue *).
        match args_e {
          [a] -> concat_all([
            "kai_internal_drop(", emit_expr(src, a, lcs, fns, variants, lams, cls), ")"
          ])
          _   -> "kai_unit() /* __perceus_drop: arity mismatch */"
        }
      } else if callee == "__perceus_reuse_cons" {
        # issue #118 — reuse-in-place for cons cells. The recogniser
        # synthesises calls of the form
        #   `__perceus_reuse_cons(__pcs_scr, head, tail)`
        # inside a `match SCRUT { [h, ...t] -> ... }` arm body.
        # `__pcs_scr` is a synthetic identifier that lowers to the
        # match emitter's local `_scr` — sidestepping the need to
        # teach `emit_match_default` about reuse-aware decref. The
        # runtime helper reads `_scr->rc`: when unique, it rewrites
        # the cell in place + `kai_incref`s the cell so it survives
        # the `kai_decref(_scr)` at match exit; otherwise it falls
        # back to `kai_cons` and leaves `_scr` intact for the match
        # exit to reclaim.
        match args_e {
          [_scr, h, t] -> concat_all([
            "kai_reuse_or_alloc_cons(_scr, ",
            emit_expr(src, h, lcs, fns, variants, lams, cls), ", ",
            emit_expr(src, t, lcs, fns, variants, lams, cls), ")"
          ])
          _ -> "kai_unit() /* __perceus_reuse_cons: arity mismatch (expected 3 args) */"
        }
      } else if callee == "__perceus_reuse_record" {
        # issue #118 — reuse-in-place for record cells. The recogniser
        # synthesises `__perceus_reuse_record(__pcs_scr, {field: val, ...})`
        # where the literal record arg is a same-arity rebuild. We
        # extract its field exprs + names from the ERecordLit and
        # forward them in the same shape `kai_record` expects.
        match args_e {
          [_scr, lit] -> match lit.kind {
            ERecordLit(_rec_name, fis) -> {
              let n = list_length(fis)
              let vals  = join_with(map(fis, (fi) => emit_field_init_val(src, fi, lcs, fns, variants, lams, cls)), ", ")
              let names = join_with(map(fis, emit_field_init_name), ", ")
              concat_all([
                "kai_reuse_or_alloc_record(_scr, ",
                int_to_string(n),
                ", (KaiValue *[]){", vals, "}, (const char *[]){", names, "})"
              ])
            }
            _ -> "kai_unit() /* __perceus_reuse_record: 2nd arg must be a record literal */"
          }
          _ -> "kai_unit() /* __perceus_reuse_record: arity mismatch (expected 2 args) */"
        }
      } else if callee == "__perceus_reuse_variant" {
        # issue #118 — reuse-in-place for variant cells. Recogniser
        # synthesises `__perceus_reuse_variant(__pcs_scr, Ctor(args...))`
        # where the second arg is a variant constructor call of the
        # same arity. We unpack the constructor's name + args and
        # lower to `kai_reuse_or_alloc_variant`.
        match args_e {
          [_scr, ctor] -> match ctor.kind {
            ECall(cf, cargs) -> match cf.kind {
              EVar(cname) -> {
                let n = list_length(cargs)
                let arg_strs = emit_call_args(src, cargs, lcs, fns, variants, lams, cls)
                if n == 0 {
                  concat_all([
                    "kai_reuse_or_alloc_variant(_scr, 0, \"", cname,
                    "\", 0, NULL)"
                  ])
                } else {
                  concat_all([
                    "kai_reuse_or_alloc_variant(_scr, 0, \"", cname,
                    "\", ", int_to_string(n),
                    ", (KaiValue *[]){", arg_strs, "})"
                  ])
                }
              }
              _ -> "kai_unit() /* __perceus_reuse_variant: 2nd arg must be a variant constructor call */"
            }
            _ -> "kai_unit() /* __perceus_reuse_variant: 2nd arg must be a variant constructor call */"
          }
          _ -> "kai_unit() /* __perceus_reuse_variant: arity mismatch (expected 2 args) */"
        }
      } else if callee == "bit_and" {
        # m13: bit ops are compiler intrinsics — each lowers inline to
        # the matching C operator. The shape is consistent across the
        # binary ops: read both KaiInts, apply the operator on `as.i`,
        # box the result, decref the inputs. Refcounting matches
        # `kai_op_add` in stage0/runtime.h: caller hands us values we own
        # and must release exactly once.
        match args_e {
          [a, b] -> concat_all([
            "({ KaiValue *_a = ", emit_expr(src, a, lcs, fns, variants, lams, cls),
            "; KaiValue *_b = ", emit_expr(src, b, lcs, fns, variants, lams, cls),
            "; KaiValue *_r = kai_int(_a->as.i & _b->as.i); ",
            "kai_decref(_a); kai_decref(_b); _r; })"
          ])
          _ -> "kai_unit() /* bit_and: expected 2 args */"
        }
      } else if callee == "bit_or" {
        match args_e {
          [a, b] -> concat_all([
            "({ KaiValue *_a = ", emit_expr(src, a, lcs, fns, variants, lams, cls),
            "; KaiValue *_b = ", emit_expr(src, b, lcs, fns, variants, lams, cls),
            "; KaiValue *_r = kai_int(_a->as.i | _b->as.i); ",
            "kai_decref(_a); kai_decref(_b); _r; })"
          ])
          _ -> "kai_unit() /* bit_or: expected 2 args */"
        }
      } else if callee == "bit_xor" {
        match args_e {
          [a, b] -> concat_all([
            "({ KaiValue *_a = ", emit_expr(src, a, lcs, fns, variants, lams, cls),
            "; KaiValue *_b = ", emit_expr(src, b, lcs, fns, variants, lams, cls),
            "; KaiValue *_r = kai_int(_a->as.i ^ _b->as.i); ",
            "kai_decref(_a); kai_decref(_b); _r; })"
          ])
          _ -> "kai_unit() /* bit_xor: expected 2 args */"
        }
      } else if callee == "bit_not" {
        # Unary: a single `~`. Refcount matches `bit_count`.
        match args_e {
          [a] -> concat_all([
            "({ KaiValue *_a = ", emit_expr(src, a, lcs, fns, variants, lams, cls),
            "; KaiValue *_r = kai_int(~ _a->as.i); ",
            "kai_decref(_a); _r; })"
          ])
          _ -> "kai_unit() /* bit_not: expected 1 arg */"
        }
      } else if callee == "bit_shl" {
        match args_e {
          [a, b] -> concat_all([
            "({ KaiValue *_a = ", emit_expr(src, a, lcs, fns, variants, lams, cls),
            "; KaiValue *_b = ", emit_expr(src, b, lcs, fns, variants, lams, cls),
            "; KaiValue *_r = kai_int(_a->as.i << _b->as.i); ",
            "kai_decref(_a); kai_decref(_b); _r; })"
          ])
          _ -> "kai_unit() /* bit_shl: expected 2 args */"
        }
      } else if callee == "bit_shr" {
        # Arithmetic shift: signed `>>` preserves the sign bit. The
        # spec'd contrast with `bit_ushr` rests on `_a->as.i` staying
        # `int64_t`.
        match args_e {
          [a, b] -> concat_all([
            "({ KaiValue *_a = ", emit_expr(src, a, lcs, fns, variants, lams, cls),
            "; KaiValue *_b = ", emit_expr(src, b, lcs, fns, variants, lams, cls),
            "; KaiValue *_r = kai_int(_a->as.i >> _b->as.i); ",
            "kai_decref(_a); kai_decref(_b); _r; })"
          ])
          _ -> "kai_unit() /* bit_shr: expected 2 args */"
        }
      } else if callee == "bit_ushr" {
        # Logical shift: cast through `uint64_t` to zero-fill, then
        # back to `int64_t` so the result fits the KaiInt slot.
        match args_e {
          [a, b] -> concat_all([
            "({ KaiValue *_a = ", emit_expr(src, a, lcs, fns, variants, lams, cls),
            "; KaiValue *_b = ", emit_expr(src, b, lcs, fns, variants, lams, cls),
            "; KaiValue *_r = kai_int((int64_t)(((uint64_t) _a->as.i) >> _b->as.i)); ",
            "kai_decref(_a); kai_decref(_b); _r; })"
          ])
          _ -> "kai_unit() /* bit_ushr: expected 2 args */"
        }
      } else if callee == "bit_count" {
        # `__builtin_popcountll` is GCC/Clang. Cast through `uint64_t`
        # so the count semantics don't depend on signed-bit handling.
        match args_e {
          [a] -> concat_all([
            "({ KaiValue *_a = ", emit_expr(src, a, lcs, fns, variants, lams, cls),
            "; KaiValue *_r = kai_int((int64_t) __builtin_popcountll((uint64_t) _a->as.i)); ",
            "kai_decref(_a); _r; })"
          ])
          _ -> "kai_unit() /* bit_count: expected 1 arg */"
        }
      } else if callee == "bit_test" {
        # Returns Bool — boxed via `kai_bool`.
        match args_e {
          [a, b] -> concat_all([
            "({ KaiValue *_a = ", emit_expr(src, a, lcs, fns, variants, lams, cls),
            "; KaiValue *_b = ", emit_expr(src, b, lcs, fns, variants, lams, cls),
            "; KaiValue *_r = kai_bool(((_a->as.i >> _b->as.i) & 1) != 0); ",
            "kai_decref(_a); kai_decref(_b); _r; })"
          ])
          _ -> "kai_unit() /* bit_test: expected 2 args */"
        }
      } else if callee == "bit_set" {
        match args_e {
          [a, b] -> concat_all([
            "({ KaiValue *_a = ", emit_expr(src, a, lcs, fns, variants, lams, cls),
            "; KaiValue *_b = ", emit_expr(src, b, lcs, fns, variants, lams, cls),
            "; KaiValue *_r = kai_int(_a->as.i | ((int64_t)1 << _b->as.i)); ",
            "kai_decref(_a); kai_decref(_b); _r; })"
          ])
          _ -> "kai_unit() /* bit_set: expected 2 args */"
        }
      } else if callee == "bit_clear" {
        match args_e {
          [a, b] -> concat_all([
            "({ KaiValue *_a = ", emit_expr(src, a, lcs, fns, variants, lams, cls),
            "; KaiValue *_b = ", emit_expr(src, b, lcs, fns, variants, lams, cls),
            "; KaiValue *_r = kai_int(_a->as.i & ~((int64_t)1 << _b->as.i)); ",
            "kai_decref(_a); kai_decref(_b); _r; })"
          ])
          _ -> "kai_unit() /* bit_clear: expected 2 args */"
        }
      } else if callee == "bit_toggle" {
        match args_e {
          [a, b] -> concat_all([
            "({ KaiValue *_a = ", emit_expr(src, a, lcs, fns, variants, lams, cls),
            "; KaiValue *_b = ", emit_expr(src, b, lcs, fns, variants, lams, cls),
            "; KaiValue *_r = kai_int(_a->as.i ^ ((int64_t)1 << _b->as.i)); ",
            "kai_decref(_a); kai_decref(_b); _r; })"
          ])
          _ -> "kai_unit() /* bit_toggle: expected 2 args */"
        }
      } else if string_contains_dot(callee) {
        # m7a #6c/#6d/#6e: op call `Eff.op(args)`. Look up the
        # innermost EvEff node, allocate a KaiCont on the stack
        # (identity continuation for one-shot resume), and indirect-
        # call the op fn ptr. After the clause returns, if it never
        # called resume (status stays UNRESUMED), pop the evidence
        # and longjmp to the enclosing handle's setjmp landing pad
        # — Doc A §*Discarding the continuation*. The default
        # handlers (m7a #7) always resume, so the longjmp branch is
        # a no-op for them; the node's handle_jmp is NULL there.
        let eff_n = dotted_prefix(callee)
        let op_n_tagged = dotted_suffix(callee)
        # m7b #15 (compiler integration, scope-limited): the alias
        # rewrite tags op names with `@<alias>` when the original
        # callee was an `as`-bound capability. Split here: when
        # tagged, dispatch via the handle's local
        # `kai_alias_<alias>_id` (kai_evidence_lookup_node_by_id);
        # otherwise the standard innermost-by-name lookup.
        let at_pos = string_index_of_at(op_n_tagged)
        let op_n = if at_pos >= 0 { string_slice(op_n_tagged, 0, at_pos) } else { op_n_tagged }
        let alias_n = if at_pos >= 0 { string_slice(op_n_tagged, at_pos + 1, string_length(op_n_tagged)) } else { "" }
        let lookup_c =
          if at_pos >= 0 {
            concat_all(["kai_evidence_lookup_node_by_id(kai_alias_", alias_n, "_id)"])
          } else {
            concat_all(["kai_evidence_lookup_node(\"", eff_n, "\")"])
          }
        # m8.x bug #12: mark the handler's evidence node as
        # in-dispatch across the clause invocation. The
        # `kai_evidence_lookup_node` walk skips flagged nodes, so
        # a recursive `Eff.op(...)` inside the clause resolves to
        # the *outer* handler and not back into ourselves.
        #
        # Args MUST be evaluated *before* the flag is set — they
        # may themselves invoke the same op (e.g.
        # `State.set(State.get() + 1)` evaluates `State.get()`
        # while constructing `set`'s argument). Setting the flag
        # before the args would make the inner `lookup_node` walk
        # past the live handler and crash. Bind each arg to a
        # `_op_arg_<i>` C local first; then flip the flag right
        # before invoking the clause.
        let arg_bindings = emit_op_arg_bindings(src, args_e, 0, lcs, fns, variants, lams, cls)
        let arg_passes   = emit_op_arg_pass_list(args_e, 0)
        let pass_str     = match args_e {
          [] -> ""
          _  -> cat2(", ", arg_passes)
        }
        concat_all([
          "({ KaiEvidence *_node_op = ", lookup_c, "; ",
          "Ev", eff_n, " *_ev_op = (Ev", eff_n, " *) _node_op->handler; ",
          "KaiCont _k; kai_cont_init_identity(&_k, _ev_op->handler_id); ",
          arg_bindings,
          "KaiFiber *_disp_fib = kai_current_fiber(); ",
          "KaiEvidence *_saved_disp = _disp_fib->in_dispatch_node; ",
          "_disp_fib->in_dispatch_node = _node_op; ",
          "KaiValue *_op_r = _ev_op->", op_n, "(_ev_op", pass_str, ", &_k); ",
          "_disp_fib->in_dispatch_node = _saved_disp; ",
          "if (_k.status == KAI_CONT_UNRESUMED && _node_op->handle_jmp != NULL) { ",
            "*_node_op->discard_slot = _op_r; ",
            "kai_evidence_pop(); ",
            "longjmp(*_node_op->handle_jmp, 1); ",
          "} ",
          "_op_r; })"
        ])
      } else {
        emit_named_call_lookup(callee, args_e, call_args, lcs, fns, variants)
      }
    }
    # m6.2 Phase 3 / v2: qualified call `mod.fname(args)`. v2 mints
    # `kai_<mod>__<fname>` directly from the EModCall payload — the
    # resolver already verified `fname` is exported by `mod`, so we
    # do not need to round-trip through emit_named_call_lookup (which
    # would lose the qualified context and pick the wrong entry when
    # two modules export the same bare name).
    EModCall(mod, fname) ->
      cat5("kai_", c_sym(fname, Some(mod)), "(", call_args, ")")
    _ -> {
      let fc = emit_expr(src, f, lcs, fns, variants, lams, cls)
      concat_all([
        "kai_apply(", fc, ", ", int_to_string(list_length(args_e)),
        ", (KaiValue *[]){", call_args, "})"
      ])
    }
  }
}

# Shared by emit_pipe_expr's EVar / EModCall branches. Same lookup
# chain as emit_named_call_lookup but parameterised on a pre-built
# args string (the pipe LHS is already the first argument).
#
# `lcs` makes a local closure shadow a same-named top-level fn: the
# user wrote `let take = ...` and pipe-called `xs |> take(1)`, the
# local has to win. When `callee` is in lcs we drop straight to the
# kai_apply branch over the local C variable; the variant / prelude
# / efn lookups only fire for genuinely-global names.
# Phase 3 unboxing — when `callee` resolves to a UFn entry in the
# EFn table, the call site swaps to the raw calling convention.
# `emit_pipe_named_lookup` (and its sibling `emit_named_call_lookup`)
# stay the gateway for both raw and boxed paths so the lookup
# discipline (lcs shadowing, variant dispatch, prelude inlining) is
# centralised. The raw arg string is built lazily inside the UFn
# arm via `emit_call_args_raw_pipe` (LHS already raw + the rest).
# The result of the raw call is itself a raw scalar; the parent
# emit_expr already wraps it via `box_wrap` when it sees the ECall
# node tagged MUnboxed (set in `ufn_promote_calls`). We re-wrap
# here as a defensive identity-on-raw boundary because the pipe
# path may inline through emit_pipe_expr's match without first
# going through `emit_expr`.
fn emit_pipe_named_lookup(callee: String, arity: Int, args_all: String, lcs: [String], fns: [EFn], variants: [EVar]) : String =
  if list_has(lcs, callee) {
    concat_all([
      "kai_apply(kai_", callee, ", ", int_to_string(arity),
      ", (KaiValue *[]){", args_all, "})"
    ])
  } else { match evar_find(variants, callee) {
    Some(_) -> emit_variant_call(callee, arity, args_all)
    None -> match prelude_find(callee) {
      Some(ep) -> match ep {
        EP(_, cname, _) -> cat4(cname, "(", args_all, ")")
      }
      None -> match efn_resolve(fns, callee) {
        Some(EFn(_, _, mo, _)) -> cat5("kai_", c_sym(callee, mo), "(", args_all, ")")
        None -> concat_all([
          "kai_apply(kai_", callee, ", ", int_to_string(arity),
          ", (KaiValue *[]){", args_all, "})"
        ])
      }
    }
  } }

# Shared by emit_call_expr's EVar non-special branch and its
# EModCall (m6.2) branch. Picks variant / prelude / user-fn /
# closure-thunk emission from the same lookup chain. `lcs` lets a
# local closure shadow a same-named top-level fn (see
# emit_pipe_named_lookup).
fn emit_named_call_lookup(callee: String, args_e: [Expr], call_args: String, lcs: [String], fns: [EFn], variants: [EVar]) : String =
  if list_has(lcs, callee) {
    concat_all([
      "kai_apply(kai_", callee, ", ", int_to_string(list_length(args_e)),
      ", (KaiValue *[]){", call_args, "})"
    ])
  } else { match evar_find(variants, callee) {
    Some(_) -> emit_variant_call(callee, list_length(args_e), call_args)
    None -> match prelude_find(callee) {
      Some(ep) -> match ep {
        EP(_, cname, _) -> cat4(cname, "(", call_args, ")")
      }
      None -> match efn_resolve(fns, callee) {
        Some(EFn(_, _, mo, _)) -> cat5("kai_", c_sym(callee, mo), "(", call_args, ")")
        None -> concat_all([
          "kai_apply(kai_", callee, ", ", int_to_string(list_length(args_e)),
          ", (KaiValue *[]){", call_args, "})"
        ])
      }
    }
  } }

fn emit_pipe_expr(src: String, lhs: Expr, rhs: Expr, lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : String / Console {

  match rhs.kind {
    ECall(f, args_e) -> match f.kind {
      # Phase 3 unboxing — pipe into a UFn callee. The piped LHS
      # becomes the first arg; both LHS and the trailing args are
      # emitted raw via `emit_expr_raw`. Without this branch the
      # default `emit_call_args` produces boxed args and the
      # `kai_<sym>` call site (which has the raw signature post-
      # Phase-3) takes `KaiValue *` — a hard C type error caught
      # by tier1 on `m7d_21_pipe_placeholder_basic`.
      EVar(callee) -> {
        if list_has(lcs, callee) {
          let lhs_c = emit_expr(src, lhs, lcs, fns, variants, lams, cls)
          let rest_args = emit_call_args(src, args_e, lcs, fns, variants, lams, cls)
          let args_all = if list_length(args_e) == 0 { lhs_c } else { cat3(lhs_c, ", ", rest_args) }
          emit_pipe_named_lookup(callee, list_length(args_e) + 1, args_all, lcs, fns, variants)
        } else { match efn_resolve(fns, callee) {
          Some(EFn(_, _, mo, Some(US(_, rt)))) -> {
            let lhs_raw = emit_expr_raw(src, lhs, lcs, fns, variants, lams, cls)
            let rest_raw = emit_call_args_raw(src, args_e, lcs, fns, variants, lams, cls)
            let args_all = if list_length(args_e) == 0 { lhs_raw } else { cat3(lhs_raw, ", ", rest_raw) }
            let raw_call = cat5("kai_", c_sym(callee, mo), "(", args_all, ")")
            box_wrap(Some(rt), raw_call)
          }
          _ -> {
            let lhs_c = emit_expr(src, lhs, lcs, fns, variants, lams, cls)
            let rest_args = emit_call_args(src, args_e, lcs, fns, variants, lams, cls)
            let args_all = if list_length(args_e) == 0 { lhs_c } else { cat3(lhs_c, ", ", rest_args) }
            emit_pipe_named_lookup(callee, list_length(args_e) + 1, args_all, lcs, fns, variants)
          }
        } }
      }
      # m6.2 Phase 3 / v2: piped qualified call `x |> mod.f(args)`.
      # Mint the prefixed symbol directly — same logic as the
      # non-piped EModCall branch in emit_call_expr. Phase 3
      # routes UFn-classified targets through the raw shape too.
      EModCall(mod, fname) -> match lookup_ufn_sig(fns, fname, Some(mod)) {
        Some(US(_, rt)) -> {
          let lhs_raw = emit_expr_raw(src, lhs, lcs, fns, variants, lams, cls)
          let rest_raw = emit_call_args_raw(src, args_e, lcs, fns, variants, lams, cls)
          let args_all = if list_length(args_e) == 0 { lhs_raw } else { cat3(lhs_raw, ", ", rest_raw) }
          let raw_call = cat5("kai_", c_sym(fname, Some(mod)), "(", args_all, ")")
          box_wrap(Some(rt), raw_call)
        }
        None -> {
          let lhs_c = emit_expr(src, lhs, lcs, fns, variants, lams, cls)
          let rest_args = emit_call_args(src, args_e, lcs, fns, variants, lams, cls)
          let args_all = if list_length(args_e) == 0 { lhs_c } else { cat3(lhs_c, ", ", rest_args) }
          cat5("kai_", c_sym(fname, Some(mod)), "(", args_all, ")")
        }
      }
      _ -> {
        let lhs_c = emit_expr(src, lhs, lcs, fns, variants, lams, cls)
        let fc = emit_expr(src, f, lcs, fns, variants, lams, cls)
        let rest_args = emit_call_args(src, args_e, lcs, fns, variants, lams, cls)
        let args_all = if list_length(args_e) == 0 { lhs_c } else { cat3(lhs_c, ", ", rest_args) }
        concat_all([
          "kai_apply(", fc, ", ", int_to_string(list_length(args_e) + 1),
          ", (KaiValue *[]){", args_all, "})"
        ])
      }
    }
    EVar(callee) -> {
      if list_has(lcs, callee) {
        let lhs_c = emit_expr(src, lhs, lcs, fns, variants, lams, cls)
        emit_pipe_named_lookup(callee, 1, lhs_c, lcs, fns, variants)
      } else { match efn_resolve(fns, callee) {
        Some(EFn(_, _, mo, Some(US(_, rt)))) -> {
          let lhs_raw = emit_expr_raw(src, lhs, lcs, fns, variants, lams, cls)
          let raw_call = cat5("kai_", c_sym(callee, mo), "(", lhs_raw, ")")
          box_wrap(Some(rt), raw_call)
        }
        _ -> {
          let lhs_c = emit_expr(src, lhs, lcs, fns, variants, lams, cls)
          emit_pipe_named_lookup(callee, 1, lhs_c, lcs, fns, variants)
        }
      } }
    }
    # m6.2 Phase 3 / v2: piped qualified-call shorthand `x |> mod.f`
    # (no parens) — same direct mint as the parens form.
    EModCall(mod, fname) -> match lookup_ufn_sig(fns, fname, Some(mod)) {
      Some(US(_, rt)) -> {
        let lhs_raw = emit_expr_raw(src, lhs, lcs, fns, variants, lams, cls)
        let raw_call = cat5("kai_", c_sym(fname, Some(mod)), "(", lhs_raw, ")")
        box_wrap(Some(rt), raw_call)
      }
      None -> {
        let lhs_c = emit_expr(src, lhs, lcs, fns, variants, lams, cls)
        cat5("kai_", c_sym(fname, Some(mod)), "(", lhs_c, ")")
      }
    }
    _ -> {
      let lhs_c = emit_expr(src, lhs, lcs, fns, variants, lams, cls)
      concat_all([
        "kai_apply(", emit_expr(src, rhs, lcs, fns, variants, lams, cls),
        ", 1, (KaiValue *[]){", lhs_c, "})"
      ])
    }
  }
}

fn emit_range_expr(src: String, from: Expr, to: Expr, opt_step: Option[Expr],
                   lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : String / Console {

  let a = emit_expr(src, from, lcs, fns, variants, lams, cls)
  let b = emit_expr(src, to, lcs, fns, variants, lams, cls)
  match opt_step {
    None -> cat5("kai_range(", a, ", ", b, ")")
    Some(s) -> {
      let sc = emit_expr(src, s, lcs, fns, variants, lams, cls)
      concat_all(["kai_range_step(", a, ", ", b, ", ", sc, ")"])
    }
  }
}

# ---- list literal emission ----

# issue #212 — when the spread argument is already wrapped in a
# `__perceus_dup` (e.g. on a non-last-use read of a list-typed
# parameter), the dup already incref'd the value. Wrapping that in
# the structural `kai_incref` of the tail-spread emit double-incref's
# the cell, blocking `kai_check_unique` on the recursive accumulator
# spine and leaking +1 reference per iteration.
fn is_perceus_dup_call(e: Expr) : Bool = match e.kind {
  ECall(callee, _) -> match callee.kind {
    EVar(nm) -> nm == "__perceus_dup"
    _ -> false
  }
  _ -> false
}

fn emit_list_tail(src: String, elems: [ListElem], lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : String / Console {

  match elems {
    [] -> "kai_nil()"
    # Tail spread `[..., ...xs]`: `kai_incref(xs)` gives the caller
    # a result whose RC is 1 and leaves xs untouched, matching the
    # ownership contract list_append used to provide via spine copy
    # — but in O(1) instead of O(|xs|). This collapses the O(n²)
    # blowup of the `[x, ...acc]` parser prepend pattern.
    [el] -> match el {
      ElPlain(x) -> concat_all(["kai_cons(", emit_expr(src,x, lcs, fns, variants, lams, cls), ", kai_nil())"])
      ElSpread(x) ->
        # issue #212: if `x` is `__perceus_dup(...)`, the dup already
        # produces an owned reference; an outer `kai_incref` would
        # double-bump. Emit the dup's lowering on its own.
        if is_perceus_dup_call(x) {
          emit_expr(src, x, lcs, fns, variants, lams, cls)
        } else {
          concat_all(["kai_incref(", emit_expr(src, x, lcs, fns, variants, lams, cls), ")"])
        }
    }
    [el, ...rest] -> match el {
      ElPlain(x) -> concat_all([
        "kai_cons(", emit_expr(src,x, lcs, fns, variants, lams, cls), ", ",
        emit_list_tail(src, rest, lcs, fns, variants, lams, cls), ")"
      ])
      ElSpread(x) -> concat_all([
        "kai_prelude_list_append(", emit_expr(src,x, lcs, fns, variants, lams, cls), ", ",
        emit_list_tail(src, rest, lcs, fns, variants, lams, cls), ")"
      ])
    }
  }
}

fn emit_list_expr(src: String, elems: [ListElem], lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : String / Console =

  emit_list_tail(src, elems, lcs, fns, variants, lams, cls)

# ---- record literal emission ----

fn emit_field_init_val(src: String, fi: FieldInit, lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : String / Console {

  match fi { FI(_, val) -> emit_expr(src,val, lcs, fns, variants, lams, cls) }
}

fn emit_field_init_name(fi: FieldInit) : String {
  match fi { FI(name, _) -> cat3("\"", name, "\"") }
}

fn emit_record_lit(src: String, fields: [FieldInit], lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : String / Console {

  let n = list_length(fields)
  let vals = join_with(map(fields, (fi) => emit_field_init_val(src, fi, lcs, fns, variants, lams, cls)), ", ")
  let names = join_with(map(fields, emit_field_init_name), ", ")
  concat_all([
    "kai_record(", int_to_string(n),
    ", (KaiValue *[]){", vals, "}, (const char *[]){", names, "})"
  ])
}

# ---- match: pattern test + bind emission ----

fn emit_pat_test(src: String, pat: Pattern, scr: String, lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : String / Console {

  match pat.pkind {
    PWild -> "1"
    PBind(_) -> "1"
    PLit(e) -> concat_all(["kai_op_eq(", scr, ", ", emit_expr(src,e, lcs, fns, variants, lams, cls), ")"])
    PList(pats, opt_rest) -> emit_pat_test_list(src, pats, opt_rest, scr, lcs, fns, variants, lams, cls)
    PVariant(name, subs) -> emit_pat_test_variant(src, name, subs, scr, lcs, fns, variants, lams, cls)
    PVariantRecord(name, fields) -> emit_pat_test_variant_record(src, name, fields, scr, lcs, fns, variants, lams, cls)
    PRecord(fields) -> emit_pat_test_record(src, fields, scr, lcs, fns, variants, lams, cls)
    PHole(_) -> "1"
    # m7d §14: `name @ sub` matches iff `sub` matches; the binding
    # is performed by emit_pat_binds.
    PAs(_, sub) -> emit_pat_test(src, sub, scr, lcs, fns, variants, lams, cls)
    # issue #187 phase 3: PNarrow is rewritten to PAs+PVariant in
    # synth_match before codegen runs; this arm only fires if a
    # `match` outside the typer's scope reaches codegen with a raw
    # narrowing pattern. Treat as unconditional match (no test).
    PNarrow(_, _) -> "1"
  }
}

fn emit_pat_test_list(src: String, pats: [Pattern], opt_rest: Option[String],
                      scr: String, lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : String / Console {

  let n_fixed = list_length(pats)
  let has_rest = match opt_rest { Some(_) -> true None -> false }
  if n_fixed == 0 and not has_rest {
    concat_all(["(", scr, " && ", scr, "->tag == KAI_NIL)"])
  } else {
    cat3("(", emit_pat_test_list_loop(src, pats, has_rest, scr, 0, n_fixed, lcs, fns, variants, lams, cls), ")")
  }
}

fn emit_pat_test_list_loop(src: String, pats: [Pattern], has_rest: Bool,
                            cur: String, i: Int, n_fixed: Int,
                            lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : String / Console {

  if i >= n_fixed {
    if has_rest { "1" }
    else { concat_all([cur, " && ", cur, "->tag == KAI_NIL"]) }
  } else {
    let head = cat2(cur, "->as.cons.head")
    let tail = cat2(cur, "->as.cons.tail")
    let pi = list_nth(pats, i)
    let head_test = emit_pat_test(src, pi, head, lcs, fns, variants, lams, cls)
    let cons_guard = concat_all([cur, " && ", cur, "->tag == KAI_CONS"])
    concat_all([
      cons_guard, " && ", head_test, " && ",
      emit_pat_test_list_loop(src, pats, has_rest, tail, i + 1, n_fixed, lcs, fns, variants, lams, cls)
    ])
  }
}

fn list_nth(xs: [Pattern], i: Int) : Pattern {
  match xs {
    [] -> mk_pat(PWild, 0, 0)
    [h, ...rest] -> if i == 0 { h } else { list_nth(rest, i - 1) }
  }
}

fn emit_pat_test_variant(src: String, name: String, subs: [Pattern],
                         scr: String, lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : String / Console {

  let base = concat_all([
    "(", scr, " && ", scr, "->tag == KAI_VARIANT && strcmp(",
    scr, "->as.var.variant_name, \"", name, "\") == 0"
  ])
  cat3(base, emit_pat_test_variant_subs(src, subs, scr, 0, lcs, fns, variants, lams, cls), ")")
}

fn emit_pat_test_variant_subs(src: String, subs: [Pattern], scr: String, i: Int,
                              lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : String / Console {

  match subs {
    [] -> ""
    [sp, ...rest] -> {
      let sub_scr = concat_all([scr, "->as.var.args[", int_to_string(i), "]"])
      let t = emit_pat_test(src, sp, sub_scr, lcs, fns, variants, lams, cls)
      concat_all([" && ", t, emit_pat_test_variant_subs(src, rest, scr, i + 1, lcs, fns, variants, lams, cls)])
    }
  }
}

fn emit_pat_test_record(src: String, fields: [PField], scr: String,
                        lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : String / Console {

  let base = concat_all(["(", scr, " && ", scr, "->tag == KAI_RECORD"])
  cat3(base, emit_pat_test_record_fields(src, fields, scr, lcs, fns, variants, lams, cls), ")")
}

fn emit_pat_test_record_fields(src: String, fields: [PField], scr: String,
                               lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : String / Console {

  match fields {
    [] -> ""
    [pf, ...rest] -> match pf {
      PField(name, sub, _) -> {
        # m5.x §4b: pat_test only reads the field's tag / value — use
        # the borrowing variant so a failing arm doesn't leak one ref
        # per field tested. emit_pat_binds (below, line 8334) still
        # uses kai_op_field; matched arms keep owned bindings.
        let tmp = concat_all(["kai_op_field_borrow(", scr, ", \"", name, "\")"])
        let t = emit_pat_test(src, sub, tmp, lcs, fns, variants, lams, cls)
        concat_all([" && (", t, ")", emit_pat_test_record_fields(src, rest, scr, lcs, fns, variants, lams, cls)])
      }
    }
  }
}

fn emit_pat_test_variant_record(src: String, name: String, fields: [PField], scr: String,
                                 lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : String / Console {

  # Variant with record destructuring: first check variant tag, then
  # record fields are accessed via kai_op_field on the scrutinee itself
  # because the emit side stores records directly in variants.
  let base = concat_all([
    "(", scr, " && ", scr, "->tag == KAI_VARIANT && strcmp(",
    scr, "->as.var.variant_name, \"", name, "\") == 0"
  ])
  cat3(base, emit_pat_test_record_fields(src, fields, scr, lcs, fns, variants, lams, cls), ")")
}

# `is_alias` = the scrutinee shares storage with its producer (variant args,
# cons head/tail). PBind/PAs emit `kai_incref(scr)` so the binding has its
# own owned reference. When false, scr is already owned (top-level _scr /
# _letv from a transferred RHS, or `kai_op_field` which already increfs its
# return) and the binding takes the ref directly. The producer-side incref
# is the prerequisite for runtime-flip exit drops: a multi-use param
# decref'd at exit must not free a value still pointed at by the original
# scrutinee's variant slot — landed in the m5.x runtime flip
# (atomic A+B+C+D, 2026-04-28); see `git log` if archaeology is needed.
fn emit_pat_binds(src: String, pat: Pattern, scr: String, is_alias: Bool,
                  lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : String {
  match pat.pkind {
    PWild ->
      # #293 Phase 2.3/2.4: when scr is an owned (non-alias) ref the
      # value would otherwise leak. Drop it. For alias paths the
      # parent's decref reclaims it.
      if is_alias { "" }
      else { concat_all(["kai_decref(", scr, "); "]) }
    PLit(_) -> ""
    PBind(name) ->
      # #293 Phase 2.3/2.4: `_`-prefixed names are unused-by-convention.
      # Treat them as wildcards so cons head / variant arg / record
      # field allocations balance.
      if name_is_unused(name) {
        if is_alias { "" }
        else { concat_all(["kai_decref(", scr, "); "]) }
      } else if is_alias {
        concat_all(["KaiValue *kai_", name, " = kai_incref(", scr, "); "])
      } else {
        concat_all(["KaiValue *kai_", name, " = ", scr, "; "])
      }
    PList(pats, opt_rest) -> emit_pat_binds_list(src, pats, opt_rest, scr, 0, lcs, fns, variants, lams, cls)
    PVariant(_, subs) -> emit_pat_binds_variant(src, subs, scr, 0, lcs, fns, variants, lams, cls)
    PVariantRecord(_, fields) -> emit_pat_binds_record(src, fields, scr, lcs, fns, variants, lams, cls)
    PRecord(fields) -> emit_pat_binds_record(src, fields, scr, lcs, fns, variants, lams, cls)
    PHole(_) -> ""
    # m7d §14: bind the as-name to the whole scrutinee, then descend
    # into the inner pattern's bindings on the same scrutinee. The
    # bound name follows the outer is_alias; the sub-pattern always
    # treats scr as alias because the as-bound name is now sharing
    # storage with the sub-bindings even when scr was originally owned.
    PAs(name, sub) -> {
      let head_bind = if is_alias {
        concat_all(["KaiValue *kai_", name, " = kai_incref(", scr, "); "])
      } else {
        concat_all(["KaiValue *kai_", name, " = ", scr, "; "])
      }
      cat2(head_bind, emit_pat_binds(src, sub, scr, true, lcs, fns, variants, lams, cls))
    }
    # issue #187 phase 3: defensive arm; PNarrow is rewritten to
    # PAs+PVariant before codegen. If reached, bind the name like
    # PBind so the body sees the scrutinee under its narrow name.
    PNarrow(name, _) ->
      if is_alias {
        concat_all(["KaiValue *kai_", name, " = kai_incref(", scr, "); "])
      } else {
        concat_all(["KaiValue *kai_", name, " = ", scr, "; "])
      }
  }
}

fn emit_pat_binds_list(src: String, pats: [Pattern], opt_rest: Option[String],
                       cur: String, i: Int, lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : String {
  match pats {
    [] -> match opt_rest {
      Some(name) -> concat_all(["KaiValue *kai_", name, " = kai_incref(", cur, "); "])
      None -> ""
    }
    [p, ...rest] -> {
      let head = cat2(cur, "->as.cons.head")
      let tail = cat2(cur, "->as.cons.tail")
      # cons.head / cons.tail are aliases of cur's storage.
      cat2(emit_pat_binds(src, p, head, true, lcs, fns, variants, lams, cls),
           emit_pat_binds_list(src, rest, opt_rest, tail, i + 1, lcs, fns, variants, lams, cls))
    }
  }
}

fn emit_pat_binds_variant(src: String, subs: [Pattern], scr: String, i: Int,
                          lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : String {
  match subs {
    [] -> ""
    [sp, ...rest] -> {
      let sub_scr = concat_all([scr, "->as.var.args[", int_to_string(i), "]"])
      # variant arg slot is alias of scr's storage.
      cat2(emit_pat_binds(src, sp, sub_scr, true, lcs, fns, variants, lams, cls),
           emit_pat_binds_variant(src, rest, scr, i + 1, lcs, fns, variants, lams, cls))
    }
  }
}

fn emit_pat_binds_record(src: String, fields: [PField], scr: String,
                          lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : String {
  match fields {
    [] -> ""
    [pf, ...rest] -> match pf {
      PField(name, sub, _) -> {
        # #293 Phase 1.3 — nested destructuring needs a temp drop on
        # the intermediate field. See the matching comment in
        # stage1/compiler.kai's emit_pat_binds_record for the rationale.
        if pat_is_destructuring(sub) {
          let tname = concat_all(["_pf_", int_to_string(sub.line), "_",
                                    int_to_string(sub.col)])
          let inner = emit_pat_binds(src, sub, tname, true, lcs, fns, variants, lams, cls)
          cat2(
            concat_all([
              "KaiValue *", tname, " = kai_op_field(", scr, ", \"", name, "\"); ",
              inner, "kai_decref(", tname, "); "
            ]),
            emit_pat_binds_record(src, rest, scr, lcs, fns, variants, lams, cls)
          )
        } else {
          let tmp = concat_all(["kai_op_field(", scr, ", \"", name, "\")"])
          # kai_op_field returns an incref'd value; child is owned.
          cat2(emit_pat_binds(src, sub, tmp, false, lcs, fns, variants, lams, cls),
               emit_pat_binds_record(src, rest, scr, lcs, fns, variants, lams, cls))
        }
      }
    }
  }
}

fn name_is_unused(name: String) : Bool {
  # `_`-prefixed user-facing names signal "unused" by convention.
  # Excludes `__`-prefixed compiler-internal names (e.g. `__cv_*` from
  # m12.6 const-pattern desugar, `__pcs_ret` / `__perceus_*` from
  # perceus_pass) which the body still references.
  match char_at(name, 0) {
    Some(c0) -> c0 == '_' and match char_at(name, 1) {
      Some(c1) -> c1 != '_'
      None -> true
    }
    None -> false
  }
}

fn pat_is_destructuring(p: Pattern) : Bool {
  match p.pkind {
    PBind(_) -> false
    PWild -> false
    PLit(_) -> false
    PRecord(_) -> true
    PVariant(_, _) -> true
    PVariantRecord(_, _) -> true
    PList(_, _) -> true
    PNarrow(_, _) -> false
    PAs(_, sub) -> pat_is_destructuring(sub)
    PHole(_) -> false
  }
}

fn emit_match_arms(src: String, arms: [Arm], lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : String / Console =

  concat_all(map(arms, (a) => emit_match_arm(src, a, lcs, fns, variants, lams, cls)))

# Issue #209 — detect a cons reuse-arm whose body is the synthetic
# `__perceus_reuse_cons(__pcs_scr, h_new, t_new)` produced by
# `pcs_recognise_reuse_*`. When detected, the arm is emitted via the
# dual-path layout in `emit_match_arm_reuse_cons` instead of the
# default incref-the-binds layout: the unique branch borrows head/tail
# (no incref) so the recursive consumer sees the children at their
# actual RC, enabling spine-deep reuse instead of one-cell-only.
fn try_reuse_cons_arm(pat: Pattern, body: Expr) : Option[ReuseConsArm] {
  match pat.pkind {
    PList(pats, opt_rest) -> match opt_rest {
      Some(rest_name) -> match pats {
        [head_pat] -> match body.kind {
          ECall(callee, call_args) -> match callee.kind {
            EVar(callee_name) ->
              if callee_name == "__perceus_reuse_cons" {
                match call_args {
                  [_scr_arg, h_new, t_new] -> Some(ReuseConsArm(head_pat, rest_name, h_new, t_new))
                  _ -> None
                }
              } else { None }
            _ -> None
          }
          _ -> None
        }
        _ -> None
      }
      None -> None
    }
    _ -> None
  }
}

type ReuseConsArm = ReuseConsArm(Pattern, String, Expr, Expr)

# Emit a single reuse-arm with the dual-path layout. Pre-condition: the
# scrutinee value is in the C local `_scr`, and the test
# `_scr->tag == KAI_CONS` already passed (encoded by `emit_pat_test`).
#
# Unique branch (kai_check_unique(_scr) == 1):
#   - bind head/tail by *borrow* (no incref). The body's consumer of
#     each binding (e.g. `f(h)`, `recur(t)`) sees the child at its
#     real RC — typically 1 for a fresh spine — so the recursive call
#     also enters its own unique branch. This is what amplifies the
#     reuse from "outermost cell only" to L-per-call.
#   - evaluate `h_new` / `t_new` (which consume the borrowed binds).
#     After this point the slots `_scr->cons.{head,tail}` point at
#     freed memory, so the path is committed.
#   - overwrite the slots in place, incref `_scr` so it survives the
#     match-exit `kai_decref(_scr)`, return `_scr`.
#
# Fallback branch (cell shared, not unique):
#   - bind head/tail by `kai_incref` (the standard pat-binds path).
#   - evaluate `h_new` / `t_new` and allocate a fresh cell via
#     `kai_cons`. The original `_scr` and its children remain intact;
#     match exit's `kai_decref(_scr)` reclaims them normally.
#
# The body's `h_new` / `t_new` are emitted under bindings keyed on the
# pattern names (head_pat's PBind, rest_name); each branch issues its
# own bindings before the same body emit, so the body code is
# duplicated textually but evaluated exactly once at runtime.
fn emit_match_arm_reuse_cons(src: String, arm_lcs: [String], rca: ReuseConsArm,
                             lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : String / Console {

  match rca {
    ReuseConsArm(head_pat, rest_name, h_new, t_new) -> {
      # Borrowed-binds path: emit pat_binds with raw cons child slots
      # and *no* incref wrappers.
      let head_borrow = match head_pat.pkind {
        PBind(hn) -> concat_all(["KaiValue *kai_", hn, " = _scr->as.cons.head; "])
        PWild     -> ""
        _         -> emit_pat_binds(src, head_pat, "_scr->as.cons.head", true, lcs, fns, variants, lams, cls)
      }
      let tail_borrow = concat_all(["KaiValue *kai_", rest_name, " = _scr->as.cons.tail; "])
      # Owned-binds path (fallback / shared): same shape as the
      # default `emit_pat_binds_list` produces.
      let head_owned = match head_pat.pkind {
        PBind(hn) -> concat_all(["KaiValue *kai_", hn, " = kai_incref(_scr->as.cons.head); "])
        PWild     -> ""
        _         -> emit_pat_binds(src, head_pat, "_scr->as.cons.head", true, lcs, fns, variants, lams, cls)
      }
      let tail_owned = concat_all(["KaiValue *kai_", rest_name, " = kai_incref(_scr->as.cons.tail); "])
      let h_new_c = emit_expr(src, h_new, arm_lcs, fns, variants, lams, cls)
      let t_new_c = emit_expr(src, t_new, arm_lcs, fns, variants, lams, cls)
      concat_all([
        "if (kai_check_unique(_scr)) { ",
        head_borrow, tail_borrow,
        "KaiValue *_h_new = ", h_new_c, "; ",
        "KaiValue *_t_new = ", t_new_c, "; ",
        "_scr->as.cons.head = _h_new; _scr->as.cons.tail = _t_new; ",
        "kai_rc_reuse_total++; ",
        "_r = kai_incref(_scr); ",
        "} else { ",
        head_owned, tail_owned,
        "KaiValue *_h_new2 = ", h_new_c, "; ",
        "KaiValue *_t_new2 = ", t_new_c, "; ",
        "_r = kai_cons(_h_new2, _t_new2); ",
        "}"
      ])
    }
  }
}

fn emit_match_arm(src: String, a: Arm, lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : String / Console {

  match a {
    Arm(pat, opt_guard, body) -> {
      let pt = emit_pat_test(src, pat, "_scr", lcs, fns, variants, lams, cls)
      # The arm's guard and body see this pattern's bound names as
      # locals, so an `EVar(p)` with `p` matching a pattern binder
      # (e.g. `match xs { [drop, ...rest] -> drop }` where `drop` is
      # also a top-level fn name) emits a local read instead of a
      # closure-thunk reference.
      let arm_lcs = list_append(lcs, pat_binders(pat, []))
      # Issue #209 — reuse-arm dual-path emit. Only viable when there
      # is no guard (a guard might reject the unique branch after we
      # already committed to overwriting `_scr`'s slots).
      match opt_guard {
        None -> match try_reuse_cons_arm(pat, body) {
          Some(rca) -> {
            let arm_body = emit_match_arm_reuse_cons(src, arm_lcs, rca, lcs, fns, variants, lams, cls)
            concat_all(["    if (", pt, ") { ", arm_body, " break; }\n"])
          }
          None -> {
            # _scr is shared across all match arms — subsequent arms re-read
            # it after this one's pat_test/guard rejects, and a guard inside
            # this arm may consume the binding (e.g. const-pattern desugar's
            # `__cv_NAME == NAME()`). Treat as alias so PBind increfs.
            let binds = emit_pat_binds(src, pat, "_scr", true, lcs, fns, variants, lams, cls)
            let body_c = emit_expr(src, body, arm_lcs, fns, variants, lams, cls)
            # Issue #309 — when every tail leaf of `body` is a tcrec
            # sentinel call, the goto leaves the enclosing
            # statement-expression and the post-do-while
            # `kai_decref(_scr)` is unreachable. Pre-inject the drop
            # inside the body's statement-expression so it executes
            # before the goto fires. Safe because the predicate
            # guarantees control NEVER reaches the post-do-while
            # decref via this arm — no double-decref is possible.
            if tcrec_tail_always_sentinel(body) {
              concat_all([
                "    if (", pt, ") { ", binds,
                "_r = ({ kai_decref(_scr); ", body_c, "; }); break; }\n"
              ])
            } else {
              concat_all(["    if (", pt, ") { ", binds, "_r = ", body_c, "; break; }\n"])
            }
          }
        }
        Some(g) -> {
          let binds = emit_pat_binds(src, pat, "_scr", true, lcs, fns, variants, lams, cls)
          let body_c = emit_expr(src, body, arm_lcs, fns, variants, lams, cls)
          let gc = emit_expr(src, g, arm_lcs, fns, variants, lams, cls)
          concat_all([
            "    if (", pt, ") { ", binds,
            "if (kai_op_truthy(", gc, ")) { _r = ", body_c, "; break; } }\n"
          ])
        }
      }
    }
  }
}

# M5 fast-path predicate. True iff every arm in `arms` is a
# literal pattern (Int / Bool / Char) or a wildcard (PWild /
# PBind), and no arm carries a guard. Strings are intentionally
# excluded — the C `switch` only works on integral types.
fn arms_all_literal_or_wild(arms: [Arm]) : Bool {
  match arms {
    [] -> false   # need at least one arm to dispatch on
    _  -> arms_all_literal_or_wild_loop(arms)
  }
}

fn arms_all_literal_or_wild_loop(arms: [Arm]) : Bool {
  match arms {
    [] -> true
    [Arm(p, g, _), ...rest] -> match g {
      Some(_) -> false
      None    -> if pat_is_unboxable_lit_or_wild(p) {
        arms_all_literal_or_wild_loop(rest)
      } else { false }
    }
  }
}

# Issue #91 — fast-path eligibility check for `PBind(name)`
# catch-all arms. When the body of a PBind catch-all reads
# `name` from inside a `#{...}` interp slot OR from inside a
# captured ELambda body, the read site bypasses the unbox
# pass's alias map and resolves to `kai_<name>` — but the
# fast path only binds `kair_<name>`. Disqualify the whole
# match in that case so it routes through the boxed path
# (which always binds `kai_<name>`). Mirrors the R8 / lambda-
# capture guards in `unbox_stmt` SLet.
fn arms_pbind_safe_for_fast_path(arms: [Arm]) : Bool / Console {

  match arms {
    [] -> true
    [Arm(p, _, b), ...rest] -> {
      let ok = match p.pkind {
        PBind(nm) ->
          not expr_has_interp_use(b, nm) and
          not uses_have_in_lam(scan_uses_expr(b, false), nm)
        _ -> true
      }
      if ok { arms_pbind_safe_for_fast_path(rest) } else { false }
    }
  }
}

fn pat_is_unboxable_lit_or_wild(p: Pattern) : Bool {
  match p.pkind {
    PWild     -> true
    # Issue #91 — PBind catch-all is now in the fast path. The
    # unbox pass marks the body's EVar reads of the bound name as
    # MUnboxed (see `unbox_arm_with_scr`); the C / LLVM emit
    # binds `kair_<name>` in the default block before the body.
    PBind(_)  -> true
    PLit(lit) -> match lit.kind {
      EInt(_)  -> true
      EBool(_) -> true
      EChar(_) -> true
      _ -> false
    }
    _ -> false
  }
}

# Emit the raw C scalar that goes inside `switch (...)` for a
# literal pattern. `EInt` → `<n>LL`, `EBool` → `0`/`1`,
# `EChar` → numeric codepoint.
fn pat_lit_raw(p: Pattern) : String {
  match p.pkind {
    PLit(lit) -> match lit.kind {
      EInt(n)  -> cat2(int_to_string(n), "LL")
      EBool(b) -> if b { "1" } else { "0" }
      EChar(c) -> int_to_string(char_to_int(c))
      _ -> "0LL /* pat_lit_raw: unexpected lit */"
    }
    _ -> "0LL /* pat_lit_raw: not a literal pattern */"
  }
}

# Lower a `match` whose scrutinee is `MUnboxed` and whose arms
# are all literal-or-wild into a C `switch`. The wildcard /
# bind arm becomes the `default:` clause; if no wildcard is
# present, `default:` panics with "non-exhaustive match".
fn emit_match_switch(src: String, scrut: Expr, arms: [Arm], lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : String / Console {

  let raw = emit_expr_raw(src, scrut, lcs, fns, variants, lams, cls)
  let cty = raw_c_type(scrut.ty)
  concat_all([
    "({ ", cty, " _scr = ", raw, "; KaiValue *_r = kai_unit(); switch (_scr) {\n",
    emit_switch_arms(src, arms, cty, lcs, fns, variants, lams, cls, false),
    "} _r; })"
  ])
}

fn emit_switch_arms(src: String, arms: [Arm], scr_cty: String, lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo], saw_default: Bool) : String / Console {

  match arms {
    [] -> if saw_default { "" }
          else { "    default: kai_prelude_panic(kai_str(\"non-exhaustive match\")); break;\n" }
    [a, ...rest] -> match a {
      Arm(p, _, body) -> {
        # Each arm's body sees the scrutinee binding as a local
        # name when the pattern is `PBind(name)`.
        let arm_lcs = list_append(lcs, pat_binders(p, []))
        let body_c = emit_expr(src, body, arm_lcs, fns, variants, lams, cls)
        match p.pkind {
          PWild -> {
            let head = concat_all(["    default: _r = ", body_c, "; break;\n"])
            cat2(head, emit_switch_arms(src, rest, scr_cty, lcs, fns, variants, lams, cls, true))
          }
          # Issue #91 — `PBind(name)` catch-all binds the raw
          # scalar `_scr` as `kair_<name>` for the body. Body
          # EVar reads of `name` resolve raw via the env extension
          # in `unbox_arm_with_scr`.
          PBind(name) -> {
            let head = concat_all([
              "    default: { ", scr_cty, " kair_", name, " = _scr; _r = ",
              body_c, "; } break;\n"
            ])
            cat2(head, emit_switch_arms(src, rest, scr_cty, lcs, fns, variants, lams, cls, true))
          }
          _ -> {
            # PLit literal arm.
            let head = concat_all(["    case ", pat_lit_raw(p), ": _r = ", body_c, "; break;\n"])
            cat2(head, emit_switch_arms(src, rest, scr_cty, lcs, fns, variants, lams, cls, saw_default))
          }
        }
      }
    }
  }
}

fn cty_for_bind(opt_ty: Option[Ty]) : String = raw_c_type(opt_ty)

fn emit_match_expr(src: String, scrut: Expr, arms: [Arm], lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : String / Console {

  # Tier 2.5 M5 — match scrutinee fast path. When the scrutinee is
  # `MUnboxed` (raw int / char) and every arm is a literal-or-wild
  # pattern of the same unboxable type with no guard, lower the
  # match to a C `switch` on the raw scalar. Avoids the `_scr`
  # boxed alias + per-arm `kai_op_eq(...)` chain. The Real-unboxing
  # extension restricts this fast path to integral scrutinee types
  # — `double` is not a valid `switch` operand in C, so a raw Real
  # scrutinee routes through the boxed path (re-boxing once at the
  # boundary).
  match scrut.mode {
    MUnboxed -> {
      if ty_is_integral_raw(scrut.ty) and arms_all_literal_or_wild(arms) and arms_pbind_safe_for_fast_path(arms) {
        emit_match_switch(src, scrut, arms, lcs, fns, variants, lams, cls)
      } else {
        emit_match_default(src, scrut, arms, lcs, fns, variants, lams, cls)
      }
    }
    _ -> emit_match_default(src, scrut, arms, lcs, fns, variants, lams, cls)
  }
}

fn emit_match_default(src: String, scrut: Expr, arms: [Arm], lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : String / Console {

  let sc = emit_expr(src,scrut, lcs, fns, variants, lams, cls)
  # m5.x flip Phase 3 closeout (original 9fe6f6d shape, restored after
  # §4b landed): consume the scrutinee linearly. `_scr` takes the value
  # `sc` returns and is decrefed on exit. Multi-read let-bound names
  # arrive pre-wrapped in `__perceus_dup` from the perceus_pass EStr +
  # AST rewrite, so a bare read of the binding is single-use by the
  # time the match sees it; the match decref consumes the ref it owns
  # without touching the producer's slot.
  concat_all([
    "({ KaiValue *_scr = ", sc, "; KaiValue *_r = kai_unit(); do {\n",
    emit_match_arms(src, arms, lcs, fns, variants, lams, cls),
    "    kai_prelude_panic(kai_str(\"non-exhaustive match\"));\n",
    "} while (0); kai_decref(_scr); _r; })"
  ])
}

# ---- string interpolation ----
#
# The raw span includes quotes: either 1 quote on each side for single-
# or 3 quotes for triple. We walk the body (between the quotes) and
# split into literal / expression parts at each `#{...}` boundary, then
# chain them via kai_string_concat wrapping each expression in
# kai_to_string.

type IPart = IpLit(String, String) | IpExp(String)   # lit: body_slice, raw_literal; exp: body_slice

fn interp_is_triple(span: String) : Bool {
  let n = string_length(span)
  if n < 6 { false }
  else {
    match char_at(span, 0) {
      Some(c) -> c == '"' and match char_at(span, 1) {
        Some(c2) -> c2 == '"' and match char_at(span, 2) {
          Some(c3) -> c3 == '"'
          None -> false
        }
        None -> false
      }
      None -> false
    }
  }
}

# Walk the inner body of a string span between (start, end), accumulating
# parts. At `#{`, open a new IpExp until the balanced `}`; otherwise
# grow the current literal span.
type IScan = { parts: [IPart], lit_start: Int, i: Int }

# issue #311: triple-quote bodies may carry literal newlines / tabs /
# unescaped `"`; emitting the raw slice produces invalid C. The lit
# pieces between `#{...}` boundaries are routed through the same
# `escape_str_body_for_c` helper as the non-interp fast path. For a
# regular string the helper is identity, so behavior is unchanged.
fn raw_lit_for_c(piece: String) : String =
  cat3("\"", escape_str_body_for_c(piece), "\"")

# `st.parts` accumulates in REVERSE here for O(1) prepend; the public
# iscan_collect entry point reverses once at the end.
fn iscan_collect_rev(span: String, end: Int, st: IScan) : [IPart] {
  if st.i >= end { finish_iscan_rev(span, end, st) }
  else {
    match char_at(span, st.i) {
      None -> finish_iscan_rev(span, end, st)
      Some(c) -> {
        let nxt = match char_at(span, st.i + 1) { Some(c2) -> c2 None -> ' ' }
        if c == '#' and nxt == '{' and st.i + 1 < end {
          let with_lit =
            if st.i > st.lit_start {
              let piece = string_slice(span, st.lit_start, st.i - st.lit_start)
              [IpLit(piece, raw_lit_for_c(piece)), ...st.parts]
            } else { st.parts }
          let expr_start = st.i + 2
          let expr_end = iscan_expr_end(span, expr_start, end, 1)
          let expr_src = string_slice(span, expr_start, expr_end - expr_start)
          let new_parts = [IpExp(expr_src), ...with_lit]
          let next_i = if expr_end < end { expr_end + 1 } else { expr_end }
          iscan_collect_rev(span, end, IScan { parts: new_parts, lit_start: next_i, i: next_i })
        } else {
          iscan_collect_rev(span, end, IScan { parts: st.parts, lit_start: st.lit_start, i: st.i + 1 })
        }
      }
    }
  }
}

fn iscan_collect(span: String, end: Int, st: IScan) : [IPart] =
  list_reverse(iscan_collect_rev(span, end, st))

fn iscan_expr_end(span: String, i: Int, end: Int, depth: Int) : Int {
  if depth == 0 or i >= end { i }
  else {
    match char_at(span, i) {
      None -> i
      Some(c) -> {
        match c {
          '{' -> iscan_expr_end(span, i + 1, end, depth + 1)
          '}' -> {
            if depth == 1 { i }
            else { iscan_expr_end(span, i + 1, end, depth - 1) }
          }
          _ -> iscan_expr_end(span, i + 1, end, depth)
        }
      }
    }
  }
}

fn finish_iscan_rev(span: String, end: Int, st: IScan) : [IPart] {
  if st.lit_start < end {
    let piece = string_slice(span, st.lit_start, end - st.lit_start)
    [IpLit(piece, raw_lit_for_c(piece)), ...st.parts]
  } else {
    st.parts
  }
}

fn emit_interp_parts(src: String, parts: [IPart], lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : String / Console {

  match parts {
    [] -> "kai_str(\"\")"
    [p] -> emit_interp_part(src, p, lcs, fns, variants, lams, cls)
    [p, ...rest] -> concat_all([
      "kai_string_concat(",
      emit_interp_part(src, p, lcs, fns, variants, lams, cls),
      ", ",
      emit_interp_parts(src, rest, lcs, fns, variants, lams, cls),
      ")"
    ])
  }
}

fn emit_interp_part(src: String, p: IPart, lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : String / Console {

  match p {
    IpLit(_, raw) -> cat3("kai_str(", raw, ")")
    IpExp(expr_src) -> {
      let toks = tokenize(expr_src)
      let prs = parser_new("<interp>", expr_src, toks)
      let r = parse_expr(prs)
      match r.r {
        Some(e) -> cat3("kai_to_string(", emit_expr(src,e, lcs, fns, variants, lams, cls), ")")
        None -> "kai_str(\"\")"
      }
    }
  }
}

# issue #311: triple-quote string spans contain unescaped chars
# (literal newline, tab, `"`) that the C preprocessor can't handle.
# Walk the body once, emitting a C-escape for each problem char.
# Source-level escapes (`\\<x>`) pass through verbatim, matching the
# lexer's treatment in `lex_string_body`. For regular strings the
# lexer guarantees no literal newline / `\r` / `\t` / unescaped `"`,
# so the output is identical to the input — safe to apply uniformly.
fn escape_str_body_for_c(body: String) : String =
  esc_body_loop(body, string_length(body), 0, "")

fn esc_body_loop(body: String, n: Int, i: Int, acc: String) : String {
  if i >= n { acc }
  else {
    match char_at(body, i) {
      None -> acc
      Some(c) -> {
        if c == '\\' and i + 1 < n {
          match char_at(body, i + 1) {
            None -> esc_body_loop(body, n, i + 1, append_char(acc, c))
            Some(nx) -> esc_body_loop(body, n, i + 2, append_char(append_char(acc, c), nx))
          }
        }
        else if char_to_int(c) == 10 { esc_body_loop(body, n, i + 1, cat2(acc, "\\n")) }
        else if char_to_int(c) == 13 { esc_body_loop(body, n, i + 1, cat2(acc, "\\r")) }
        else if char_to_int(c) == 9  { esc_body_loop(body, n, i + 1, cat2(acc, "\\t")) }
        else if c == '"'             { esc_body_loop(body, n, i + 1, cat2(acc, "\\\"")) }
        else                         { esc_body_loop(body, n, i + 1, append_char(acc, c)) }
      }
    }
  }
}

fn emit_string_expr(src: String, span: String, is_triple: Bool, lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : String / Console {

  let n = string_length(span)
  let body_start = if is_triple { 3 } else { 1 }
  let body_end = if is_triple { n - 3 } else { n - 1 }
  # Fast path: if no `#{` appears, emit as a plain C literal.
  if not has_interp(span, body_start, body_end) {
    if is_triple {
      let body = string_slice(span, body_start, body_end - body_start)
      cat3("kai_str(\"", escape_str_body_for_c(body), "\")")
    } else {
      cat3("kai_str(", span, ")")
    }
  } else {
    let parts = iscan_collect(span, body_end, IScan { parts: [], lit_start: body_start, i: body_start })
    emit_interp_parts(src, parts, lcs, fns, variants, lams, cls)
  }
}

fn has_interp(span: String, i: Int, end: Int) : Bool {
  if i + 1 >= end { false }
  else {
    match char_at(span, i) {
      Some(c) -> {
        if c == '#' {
          match char_at(span, i + 1) {
            Some(c2) -> if c2 == '{' { true } else { has_interp(span, i + 1, end) }
            None -> false
          }
        } else { has_interp(span, i + 1, end) }
      }
      None -> false
    }
  }
}

# ---- lambda collection + emission ----
#
# We pre-walk the program building a list of LamInfo entries; each entry
# gets a unique id and records the lambda's params, its free variables
# (its closure captures), and its body. At emit time the lambda
# expression is replaced with `kai_closure(&_kai_lam_<id>, arity,
# n_caps, captures)`; the body is emitted as a separate function later.

type LamInfo = LamInfo(Int, Int, Int, [Param], [String], Expr)

# m7a #6c: each handler op clause becomes a top-level C function.
# The id pair (handle_line, handle_col) plus op_name uniquely names
# the clause (HCs do not nest within the same handle, and two
# handles cannot share both line and column). `params` is the
# clause's surface param list — the last one is the conventional
# `resume` binding (Doc A §*resume: one-shot, explicit*); m7a #6c
# treats `resume(v)` as direct-style identity and does not need to
# distinguish args from resume in the C signature beyond skipping
# the trailing slot.
# m7b #11: a clause is `stateful` (the trailing Bool) when its
# enclosing `handle` carries a state initializer (`with State[T](init)`
# / `with Writer[W]([])`). The codegen layer prepends a `kai_state` /
# `kai_log` alias of `self->state` to the clause body and emits the
# 2-arg `resume(v, ns)` form as a state write before resume.
# m4c #4 (2026-04-29): trailing `String` is the **enclosing fn name** —
# the post-monomorph C symbol for the fn / lambda / test that contains
# this `EHandle`. Pre-m4c #4 clause symbols were keyed on (line, col,
# op) only and collided across monomorphisation copies; the enc_fn
# prefix lets two specialisations of one polymorphic body produce
# distinct C symbols (`_kai_<enc>__clause_<l>_<c>_<op>`). The collect
# pass populates this from `LamCollect.cur_enc_fn`; emit and install
# paths read it back so both ends mint the same name.
# R9 (issue #60, 2026-05-02): trailing `[String]` is the per-clause
# closure-capture set — surface names that are free in the clause body
# given (clause params + `state` + `log`) as the local scope. The list
# travels through the EvE's `env` slot per `docs/effects-impl.md`
# §"Op clause as ordinary function": at install time the handle
# allocates a per-(line,col) env struct on its frame and populates one
# field per captured name; the clause prologue rebinds each `kai_<name>`
# alias from `((env*) self->env)->kai_<name>`. Without this channel,
# any clause body that names an enclosing-fn parameter triggered the
# `use of undeclared identifier 'kai_<param>'` C error tracked as R9.
type ClauseInfo = CI(Int, Int, String, String, [Param], Expr, Bool, String, [String])

fn find_lam(lams: [LamInfo], line: Int, col: Int) : Option[LamInfo] {
  match lams {
    [] -> None
    [l, ...rest] -> match l {
      LamInfo(_, ln, cl, _, _, _) ->
        if ln == line and cl == col { Some(l) }
        else { find_lam(rest, line, col) }
    }
  }
}

# Free variables of an expression, given the lambda's own params and the
# program's globals. We skip descent into nested ELambdas (each gets its
# own capture set), and re-parse string interpolations so identifiers
# hidden inside #{...} get captured too.
fn fv_expr(x: Expr, own: [String], globals: [String], acc: [String]) : [String] / Console {

  match x.kind {
    EInt(_)  -> acc
    EReal(_) -> acc
    EBool(_) -> acc
    EChar(_) -> acc
    EStr(span, is_triple) -> fv_interp(span, is_triple, own, globals, acc)
    EUnit -> acc
    EVar(name) -> {
      # m7b #15 closure-capture: a tagged op call like
      # `Eff.op@<alias>` rewrites to `EVar("Eff.op@alias")`. The
      # name is *not* a real identifier — emit_call_expr splits the
      # `@` and dispatches via `kai_alias_<alias>_id`. For closure
      # capture purposes we record the alias under the sentinel
      # name `__alias_id__<alias>`; the lambda emit decodes it back
      # to `KaiHandlerId kai_alias_<alias>_id` in the body prologue.
      let at_pos = string_index_of_at(name)
      if at_pos >= 0 {
        let alias = string_slice(name, at_pos + 1, string_length(name))
        let cap_name = string_concat("__alias_id__", alias)
        if list_has(own, alias) { acc }
        else if list_has(acc, cap_name) { acc }
        else { [cap_name, ...acc] }
      }
      else if list_has(own, name) { acc }
      else if list_has(globals, name) { acc }
      else if list_has(acc, name) { acc }
      else { [name, ...acc] }
    }
    EUnder -> acc
    EPlaceholder -> acc
    ECall(f, xs) -> fv_exprs(xs, own, globals, fv_expr(f, own, globals, acc))
    EField(base, _) -> fv_expr(base, own, globals, acc)
    EIndex(a, b) -> fv_expr(b, own, globals, fv_expr(a, own, globals, acc))
    EBinop(_, a, b) -> fv_expr(b, own, globals, fv_expr(a, own, globals, acc))
    EUnop(_, inner) -> fv_expr(inner, own, globals, acc)
    EIf(c, a, opt_b) -> {
      let acc1 = fv_expr(a, own, globals, fv_expr(c, own, globals, acc))
      match opt_b { Some(b) -> fv_expr(b, own, globals, acc1) None -> acc1 }
    }
    EMatch(scr, arms) -> fv_arms(arms, own, globals, fv_expr(scr, own, globals, acc))
    ELambda(ps, body) -> {
      # m7b #15 closure-capture: a nested lambda computes its own
      # capture list independently, but every free var that
      # nested body references AND that is not bound by the
      # nested params still has to be visible at the *outer*
      # lambda's body — that body is where the nested
      # `kai_closure(...)` literal evaluates its capture array.
      # Pre-fix, an outer lambda whose body contained
      # `while(() => @i < dim, () => ...)` failed to pick up
      # `kai_dim` / `kai_alias_i_id` as outer captures, so the
      # generated C referenced undeclared identifiers when
      # building the inner closure.
      let nested_own = list_append(own, params_to_names(ps))
      fv_expr(body, nested_own, globals, acc)
    }
    ETodo(_) -> acc
    EBang(inner) -> fv_expr(inner, own, globals, acc)
    ERecordLit(_, fields) -> fv_field_inits(fields, own, globals, acc)
    EList(elems) -> fv_list_elems(elems, own, globals, acc)
    ERange(a, b, opt_step) -> {
      let acc1 = fv_expr(b, own, globals, fv_expr(a, own, globals, acc))
      match opt_step { Some(s) -> fv_expr(s, own, globals, acc1) None -> acc1 }
    }
    EBlock(stmts, opt_final) -> {
      # m7b #18: track the scope as it grows through SLet / SVar so
      # the optional trailing expression sees the same bindings the
      # earlier statements introduced.
      let r = fv_stmts_scoped(stmts, own, globals, acc)
      match opt_final { Some(f) -> fv_expr(f, r.own, globals, r.acc) None -> r.acc }
    }
    EPipe(a, b) -> fv_expr(b, own, globals, fv_expr(a, own, globals, acc))
    EMapPipe(a, b) -> fv_expr(b, own, globals, fv_expr(a, own, globals, acc))
    EFlatMapPipe(a, b) -> fv_expr(b, own, globals, fv_expr(a, own, globals, acc))
    EFilterPipe(a, b) -> fv_expr(b, own, globals, fv_expr(a, own, globals, acc))
    EHole(_) -> acc
    EHandle(body, _, _, init_opt, alias_opt, clauses, ret_opt) -> {
      # m7b #11: free vars in the handler-state init expression
      # contribute to the surrounding scope.
      let acc0 = match init_opt {
        Some(ie) -> fv_expr(ie, own, globals, acc)
        None     -> acc
      }
      # m12.8.x phase 4 followup: when `with Eff(init) as name { body }`
      # binds an alias, treat that name as in-scope for the body —
      # references to it dispatch via the runtime evidence stack at
      # call time, not via a captured C local. Pre-fix the m7b #5b
      # desugar (`var top = 0` → `with State[Int](0) as top { ... }`)
      # caused inner lambdas to capture `top` as if it were a value;
      # the C emit then read `kai_top` against an undeclared
      # identifier. The alias is only in scope inside the body — not
      # in `init` (runs before the handler is installed) and not in
      # the clauses (which see `state` / `log` magic instead).
      let own_body = match alias_opt {
        Some(a) -> [a, ...own]
        None    -> own
      }
      let acc1 = fv_expr(body, own_body, globals, acc0)
      let acc2 = fv_hclauses(clauses, own, globals, acc1)
      match ret_opt { Some(r) -> fv_hreturn(r, own, globals, acc2) None -> acc2 }
    }
    # m12.5: literal-with-unit captures whatever the inner literal does
    # (always nothing in practice, since the inner is EInt/EReal).
    ELitUnit(inner, _) -> fv_expr(inner, own, globals, acc)
    # m7e §11: `variants[T]()` has no value-level sub-expressions, so
    # it captures nothing.
    EVariantsOf(_, _) -> acc
    # m6.2 Phase 2.1: qualified module call references no local
    # binding — module name and function name are both pure strings
    # resolved via the module table.
    EModCall(_, _) -> acc
  }
}

fn fv_hclauses(cs: [HClause], own: [String], globals: [String], acc: [String]) : [String] / Console {

  match cs {
    [] -> acc
    [c, ...rest] -> match c {
      HC(_, params, body, _, _) -> {
        # m7b #18: stateful handler clauses see two magic bindings —
        # `state` and `log` — that the codegen aliases to the
        # evidence struct's slot. Always include them in `own` so the
        # free-var collector does not promote them to lambda captures
        # when the whole `with State[T]` sits inside a closure body
        # (e.g. desugared `var` inside a lambda).
        let own_magic = ["state", "log", ...own]
        let own1 = list_concat_strings(map(params, (pm) => pm.pname), own_magic)
        let acc1 = fv_expr(body, own1, globals, acc)
        fv_hclauses(rest, own, globals, acc1)
      }
    }
  }
}

fn fv_hreturn(r: HReturn, own: [String], globals: [String], acc: [String]) : [String] / Console {

  match r {
    # m7b #18: same `state` / `log` magic bindings as in
    # `fv_hclauses` apply here (Doc C §m7b #11l: stateful return
    # clauses see the handler-state alias too).
    HR(name, body, _, _) -> fv_expr(body, [name, "state", "log", ...own], globals, acc)
  }
}

fn list_concat_strings(a: [String], b: [String]) : [String] {
  match a {
    [] -> b
    [h, ...rest] -> [h, ...list_concat_strings(rest, b)]
  }
}

fn fv_exprs(xs: [Expr], own: [String], globals: [String], acc: [String]) : [String] / Console {

  match xs {
    [] -> acc
    [h, ...rest] -> fv_exprs(rest, own, globals, fv_expr(h, own, globals, acc))
  }
}

fn fv_arms(arms: [Arm], own: [String], globals: [String], acc: [String]) : [String] / Console {

  match arms {
    [] -> acc
    [a, ...rest] -> match a {
      Arm(pat, opt_g, body) -> {
        # m7b #18: extend `own` with the pattern's bound names so the
        # guard and body don't treat them as free vars when the arm
        # sits inside a lambda body.
        let own1 = pat_bindings(pat, own)
        let acc1 = match opt_g { Some(g) -> fv_expr(g, own1, globals, acc) None -> acc }
        fv_arms(rest, own, globals, fv_expr(body, own1, globals, acc1))
      }
    }
  }
}

# m7b #18: collect every name a pattern would bind into the accumulator,
# mirroring `bind_pat` (resolver) but operating on a [String] instead of
# an Env. Used by `fv_arms` and `fv_stmts` to keep `let` / pattern-bound
# names out of a lambda's free-var capture set.
fn pat_bindings(pat: Pattern, acc: [String]) : [String] {
  match pat.pkind {
    PWild -> acc
    PLit(_) -> acc
    PBind(name) -> [name, ...acc]
    PList(pats, opt_rest) -> {
      let acc1 = pat_bindings_loop(pats, acc)
      match opt_rest {
        Some(rname) -> [rname, ...acc1]
        None -> acc1
      }
    }
    PVariant(_, subs) -> pat_bindings_loop(subs, acc)
    PVariantRecord(_, fields) -> pfield_bindings_loop(fields, acc)
    PRecord(fields) -> pfield_bindings_loop(fields, acc)
    PHole(_) -> acc
    PAs(name, sub) -> pat_bindings(sub, [name, ...acc])
    PNarrow(name, _) -> [name, ...acc]
  }
}

# Like `pat_bindings`, but if the pattern is a single `PBind` and
# the let's RHS is `MUnboxed`, the binding is a raw C scalar and
# must NOT enter the Perceus tracking scope. All other shapes —
# destructured lets, wildcards, literals — defer to the standard
# `pat_bindings` walker. See `docs/unboxing-phase2-design.md` §3
# (boundary tactic) for the coordination contract.
fn pat_bindings_skip_raw(pat: Pattern, rhs: Expr, acc: [String]) : [String] {
  match pat.pkind {
    PBind(name) -> match rhs.mode {
      MUnboxed -> acc
      _        -> [name, ...acc]
    }
    _ -> pat_bindings(pat, acc)
  }
}

fn pat_bindings_loop(ps: [Pattern], acc: [String]) : [String] {
  match ps {
    [] -> acc
    [p, ...rest] -> pat_bindings_loop(rest, pat_bindings(p, acc))
  }
}

fn pfield_bindings_loop(fs: [PField], acc: [String]) : [String] {
  match fs {
    [] -> acc
    [f, ...rest] -> match f {
      PField(_, sub, _) -> pfield_bindings_loop(rest, pat_bindings(sub, acc))
    }
  }
}

fn fv_field_inits(fs: [FieldInit], own: [String], globals: [String], acc: [String]) : [String] / Console {

  match fs {
    [] -> acc
    [f, ...rest] -> match f {
      FI(_, val) -> fv_field_inits(rest, own, globals, fv_expr(val, own, globals, acc))
    }
  }
}

fn fv_list_elems(es: [ListElem], own: [String], globals: [String], acc: [String]) : [String] / Console {

  match es {
    [] -> acc
    [el, ...rest] -> match el {
      ElPlain(x) -> fv_list_elems(rest, own, globals, fv_expr(x, own, globals, acc))
      ElSpread(x) -> fv_list_elems(rest, own, globals, fv_expr(x, own, globals, acc))
    }
  }
}

fn fv_stmts(ss: [Stmt], own: [String], globals: [String], acc: [String]) : [String] / Console {

  let r = fv_stmts_scoped(ss, own, globals, acc)
  r.acc
}

# m7b #18: scoped variant of `fv_stmts` that also returns the scope as
# extended by every SLet / SVar in the list. Used by `EBlock` so the
# optional trailing expression sees the bindings introduced earlier in
# the block.
type FvScoped = { own: [String], acc: [String] }

fn fv_stmts_scoped(ss: [Stmt], own: [String], globals: [String], acc: [String]) : FvScoped / Console {

  match ss {
    [] -> FvScoped { own: own, acc: acc }
    [s, ...rest] -> match s {
      SLet(pat, _, rhs) -> {
        let acc1 = fv_expr(rhs, own, globals, acc)
        let own1 = pat_bindings(pat, own)
        fv_stmts_scoped(rest, own1, globals, acc1)
      }
      SVar(name, _, rhs, _, _) -> {
        let acc1 = fv_expr(rhs, own, globals, acc)
        fv_stmts_scoped(rest, [name, ...own], globals, acc1)
      }
      _ -> fv_stmts_scoped(rest, own, globals, fv_stmt(s, own, globals, acc))
    }
  }
}

fn fv_stmt(s: Stmt, own: [String], globals: [String], acc: [String]) : [String] / Console {

  match s {
    SLet(_, _, rhs) -> fv_expr(rhs, own, globals, acc)
    SAssert(c, opt_m) -> {
      let acc1 = fv_expr(c, own, globals, acc)
      match opt_m { Some(m) -> fv_expr(m, own, globals, acc1) None -> acc1 }
    }
    SExprStmt(x) -> fv_expr(x, own, globals, acc)
    SIndexAssign(b, i, v, _, _) -> {
      let acc1 = fv_expr(b, own, globals, acc)
      let acc2 = fv_expr(i, own, globals, acc1)
      fv_expr(v, own, globals, acc2)
    }
    # m7b #5: `var name = init` — desugared away pre-resolve. The free
    # variables of the init expression contribute; the bound name is a
    # local introduction (handled by the surrounding scope).
    SVar(_, _, rhs, _, _) -> fv_expr(rhs, own, globals, acc)
    # m7e §25: stripped by desugar_use_decls before fv runs.
    SUse(_, _, _) -> acc
  }
}

fn fv_interp(span: String, is_triple: Bool, own: [String], globals: [String], acc: [String]) : [String] / Console {

  let n = string_length(span)
  let body_start = if is_triple { 3 } else { 1 }
  let body_end = if is_triple { n - 3 } else { n - 1 }
  let parts = iscan_collect(span, body_end, IScan { parts: [], lit_start: body_start, i: body_start })
  fv_interp_parts(parts, own, globals, acc)
}

fn fv_interp_parts(parts: [IPart], own: [String], globals: [String], acc: [String]) : [String] / Console {

  match parts {
    [] -> acc
    [p, ...rest] -> match p {
      IpLit(_, _) -> fv_interp_parts(rest, own, globals, acc)
      IpExp(esrc) -> {
        let toks = tokenize(esrc)
        let prs = parser_new("<interp>", esrc, toks)
        let r = parse_expr(prs)
        let acc1 = match r.r {
          Some(e) -> fv_expr(e, own, globals, acc)
          None -> acc
        }
        fv_interp_parts(rest, own, globals, acc1)
      }
    }
  }
}

# ---- lambda collection pass ----

# m4c #4: `cur_enc_fn` carries the post-monomorph C symbol of the
# fn / lambda / test the walker is currently inside. Updated at scope
# boundaries (DFn / DTest entry, ELambda recursion); read by the
# EHandle case to stamp each `ClauseInfo` so install/emit paths can
# mint matching prefixed clause symbols.
type LamCollect = { next_id: Int, lams: [LamInfo], clauses: [ClauseInfo],
                    globals: [String], cur_enc_fn: String,
                    # issue #285: enclosing-fn parameter and let/var binding
                    # names visible at the current walk position. Shadows
                    # `globals` when computing a nested lambda's caps so a
                    # captured `Ref[T]` parameter named after a stdlib fn
                    # (e.g. `count`, colliding with `list.count`) is added
                    # to the closure's capture array instead of being
                    # silently re-resolved to the global function value.
                    local_scope: [String] }

fn lc_new(globals: [String]) : LamCollect =
  LamCollect { next_id: 0, lams: [], clauses: [], globals: globals,
                cur_enc_fn: "", local_scope: [] }

# issue #285: state-passing scope helpers. Snapshot at entry of a
# scope-introducing form (DFn body, EBlock, ELambda body); restore
# on exit. Kept tiny so the walker stays a one-line state-tweak per
# scope frame.
fn lc_set_locals(st: LamCollect, locals: [String]) : LamCollect =
  LamCollect { next_id: st.next_id, lams: st.lams,
                clauses: st.clauses, globals: st.globals,
                cur_enc_fn: st.cur_enc_fn, local_scope: locals }

fn lc_extend_locals(st: LamCollect, names: [String]) : LamCollect =
  lc_set_locals(st, list_append(st.local_scope, names))

# issue #285: filter names out of `globals` so `fv_expr` records them
# as captures. O(|globals| × |locals|) is acceptable: |locals| stays
# tiny (a handful per fn), and lambda lifting runs once per emit.
fn list_minus(xs: [String], ys: [String]) : [String] = list_minus_loop(xs, ys, [])

fn list_minus_loop(xs: [String], ys: [String], acc: [String]) : [String] {
  match xs {
    [] -> list_reverse(acc)
    [h, ...rest] ->
      if list_has(ys, h) { list_minus_loop(rest, ys, acc) }
      else               { list_minus_loop(rest, ys, [h, ...acc]) }
  }
}

fn params_to_names(ps: [Param]) : [String] =
  map(ps, (pm) => pm.pname)

fn collect_expr(x: Expr, st: LamCollect) : LamCollect / Console {

  match x.kind {
    EInt(_)  -> st
    EReal(_) -> st
    EBool(_) -> st
    EChar(_) -> st
    EStr(span, is_triple) -> collect_interp(span, is_triple, st)
    EUnit -> st
    EVar(_) -> st
    EUnder -> st
    EPlaceholder -> st
    ECall(f, xs) -> collect_exprs(xs, collect_expr(f, st))
    EField(base, _) -> collect_expr(base, st)
    EIndex(a, b) -> collect_expr(b, collect_expr(a, st))
    EBinop(_, a, b) -> collect_expr(b, collect_expr(a, st))
    EUnop(_, inner) -> collect_expr(inner, st)
    EIf(c, a, opt_b) -> {
      let s1 = collect_expr(a, collect_expr(c, st))
      match opt_b { Some(b) -> collect_expr(b, s1) None -> s1 }
    }
    EMatch(scr, arms) -> collect_arms(arms, collect_expr(scr, st))
    ELambda(params, body) -> {
      let id = st.next_id
      let own = params_to_names(params)
      # issue #285: an enclosing fn parameter or let/var binding whose
      # name happens to match a stdlib fn (e.g. a `count: Ref[Int]`
      # parameter while `list.count` is in scope) must be captured by
      # the lambda, not silently re-resolved to the global. Filter the
      # globals fed to `fv_expr` so any name shadowed by the current
      # `local_scope` is treated as a free variable and added to caps.
      let effective_globals = list_minus(st.globals, st.local_scope)
      let caps = fv_expr(body, own, effective_globals, [])
      let info = LamInfo(id, x.line, x.col, params, caps, body)
      # m4c #4: the lambda body is its own enclosing scope for clause
      # symbols (lifted to `_kai_lam_<id>` at emit). Push the new
      # enc_fn for the body walk; restore the outer enc_fn on the way
      # out so a sibling expression keeps stamping against its own
      # enclosing fn.
      let outer_enc_fn = st.cur_enc_fn
      let outer_locals = st.local_scope
      let lam_enc_fn = concat_all(["_kai_lam_", int_to_string(id)])
      # Inside the lambda body, the lambda's own params shadow outer
      # globals too — extend `local_scope` so a nested lambda nested
      # again inside this body sees the shadowing chain.
      let st1 = LamCollect { next_id: id + 1, lams: [info, ...st.lams],
                              clauses: st.clauses, globals: st.globals,
                              cur_enc_fn: lam_enc_fn,
                              local_scope: list_append(outer_locals, own) }
      let st2 = collect_expr(body, st1)
      LamCollect { next_id: st2.next_id, lams: st2.lams,
                    clauses: st2.clauses, globals: st2.globals,
                    cur_enc_fn: outer_enc_fn,
                    local_scope: outer_locals }
    }
    ERecordLit(_, fields) -> collect_field_inits(fields, st)
    EList(elems) -> collect_list_elems(elems, st)
    ERange(a, b, opt_step) -> {
      let s1 = collect_expr(b, collect_expr(a, st))
      match opt_step { Some(s) -> collect_expr(s, s1) None -> s1 }
    }
    EBlock(stmts, opt_final) -> {
      # issue #285: SLet / SVar inside the block extend `local_scope`;
      # restore the outer scope on exit so siblings (and the lambda
      # lifter's caller) don't see the block's bindings as still in
      # scope.
      let outer_locals = st.local_scope
      let s1 = collect_stmts(stmts, st)
      let s2 = match opt_final { Some(f) -> collect_expr(f, s1) None -> s1 }
      lc_set_locals(s2, outer_locals)
    }
    EPipe(a, b) -> collect_expr(b, collect_expr(a, st))
    EMapPipe(a, b) -> collect_expr(b, collect_expr(a, st))
    EFlatMapPipe(a, b) -> collect_expr(b, collect_expr(a, st))
    EFilterPipe(a, b) -> collect_expr(b, collect_expr(a, st))
    EHole(_) -> st
    ETodo(_) -> st
    EBang(inner) -> collect_expr(inner, st)
    EHandle(body, eff_name, _, init_opt, alias_opt, clauses, ret_opt) -> {
      let stateful = match init_opt { Some(_) -> true None -> false }
      let s_init = match init_opt { Some(ie) -> collect_expr(ie, st) None -> st }
      # m4c #4: stamp each clause with the current enclosing fn name
      # set by collect_decl (DFn / DTest) or the surrounding ELambda.
      # emit-time install code reads back the same string so install
      # and clause-body symbols agree.
      let s0 = lc_record_clauses(clauses, eff_name, stateful, x.line, x.col, s_init.cur_enc_fn, s_init)
      # m12.8.x phase 4 followup: when `with Eff(init) as name { body }`
      # binds an alias, mark `name` as an in-scope global for the body
      # walk so any inner lambda's free-var analysis treats references
      # to it as alias dispatches (resolved via the runtime evidence
      # stack), not as values that need capture in the closure
      # environment. Pre-fix the m7b #5b desugar (`var top = 0` →
      # `with State[Int](0) as top { ... }`) caused inner lambdas
      # passed to row-polymorphic helpers like `while` to capture
      # `top` as if it were a value, and the C emit then read
      # `kai_top` against an undeclared identifier. Surfaced via
      # `demos/spiral`. The alias is only in scope inside the body —
      # not in `init` (runs before the handler is installed) and not
      # in the clauses (which see `state` / `log` magic instead).
      let outer_globals = s0.globals
      let s_body_in = match alias_opt {
        Some(a) -> LamCollect {
          next_id: s0.next_id, lams: s0.lams,
          clauses: s0.clauses, globals: [a, ...outer_globals],
          cur_enc_fn: s0.cur_enc_fn, local_scope: s0.local_scope
        }
        None -> s0
      }
      let s1_ext = collect_expr(body, s_body_in)
      let s1 = LamCollect {
        next_id: s1_ext.next_id, lams: s1_ext.lams,
        clauses: s1_ext.clauses, globals: outer_globals,
        cur_enc_fn: s1_ext.cur_enc_fn, local_scope: s1_ext.local_scope
      }
      let s2 = collect_hclauses(clauses, s1)
      match ret_opt { Some(r) -> collect_hreturn(r, s2) None -> s2 }
    }
    # m12.5: literal-with-unit — the inner literal contributes nothing,
    # but recurse so future non-literal carriers stay covered.
    ELitUnit(inner, _) -> collect_expr(inner, st)
    # m7e §11: `variants[T]()` produces no lambdas / no clauses to
    # collect. The TypeExpr is not a lambda host.
    EVariantsOf(_, _) -> st
    # m6.2 Phase 2.1: qualified module call hosts no lambdas and
    # introduces no clauses — both fields are plain strings.
    EModCall(_, _) -> st
  }
}

# m7a #6c: append one ClauseInfo per HClause of this handle. The
# (line, col) of the EHandle node is reused as the clause's stable
# id; the op_name disambiguates among clauses of the same handle.
# m4c #4: the trailing `enc_fn` argument is the post-monomorph C
# symbol of the fn / lambda / test that physically contains this
# `EHandle`. It feeds CI's 8th field so emit_clause_body and the
# install path mint matching prefixed symbols
# (`_kai_<enc>__clause_<l>_<c>_<op>`).
fn lc_record_clauses(cs: [HClause], eff: String, stateful: Bool,
                     hline: Int, hcol: Int, enc_fn: String,
                     st: LamCollect) : LamCollect / Console {

  match cs {
    [] -> st
    [c, ...rest] -> match c {
      HC(op_name, params, body, _, _) -> {
        # R9: compute the clause's free-variable set, treating its own
        # params plus the magic `state` / `log` aliases as bound. The
        # resulting names are the captures the env channel must thread
        # in from the surrounding handle frame. Mirrors `fv_hclauses`.
        let own_for_fv = list_concat_strings(map(params, (pm) => pm.pname), ["state", "log"])
        # issue #285: filter globals shadowed by enclosing-fn / outer
        # let-var bindings, so a clause body capturing e.g. `count`
        # (parameter shadowing `list.count`) is added to env captures.
        let effective_globals = list_minus(st.globals, st.local_scope)
        let raw_caps = fv_expr(body, own_for_fv, effective_globals, [])
        let caps = filter_clause_captures(raw_caps)
        let info = CI(hline, hcol, eff, op_name, params, body, stateful, enc_fn, caps)
        let st1 = LamCollect {
          next_id: st.next_id, lams: st.lams,
          clauses: [info, ...st.clauses], globals: st.globals,
          cur_enc_fn: st.cur_enc_fn, local_scope: st.local_scope
        }
        lc_record_clauses(rest, eff, stateful, hline, hcol, enc_fn, st1)
      }
    }
  }
}

# R9: drop the `__alias_id__<a>` sentinels produced by `fv_expr` for
# tagged op calls (`Eff.op@<a>`). Lambda capture rebinds them via
# `kai_alias_<a>_id` reads in the lambda prologue; the clause env
# channel does not yet carry handler-id captures (a follow-up — for
# now an alias-id needed inside a clause body must be threaded
# through the parametric handler's `state` slot, the existing
# workaround). Plain value captures are everything else and travel
# through `self->env` per `docs/effects-impl.md` §"Op clause as
# ordinary function".
fn filter_clause_captures(caps: [String]) : [String] {
  match caps {
    [] -> []
    [c, ...rest] -> {
      let prefix = "__alias_id__"
      if string_starts_with_q(c, prefix) {
        filter_clause_captures(rest)
      } else {
        [c, ...filter_clause_captures(rest)]
      }
    }
  }
}

# R9: union the per-clause capture sets of every clause that belongs
# to a single handle (matched by hline/hcol). The handle allocates
# one env struct shared across all its clauses, so every clause's
# capture has to find a slot in the same struct.
fn handle_captures_at(cls: [ClauseInfo], hline: Int, hcol: Int) : [String] {
  match cls {
    [] -> []
    [c, ...rest] -> match c {
      CI(line, col, _, _, _, _, _, _, caps) ->
        if line == hline and col == hcol {
          merge_string_set(caps, handle_captures_at(rest, hline, hcol))
        } else {
          handle_captures_at(rest, hline, hcol)
        }
    }
  }
}

# Stable-order union of two string lists. Order matters because the
# install side (`emit_handle_env_assigns`) and the read side
# (`emit_clause_env_prologue`) must walk the same struct fields in
# the same sequence; we lean on the C struct's field order to align
# both.
fn merge_string_set(a: [String], b: [String]) : [String] {
  match a {
    [] -> b
    [h, ...rest] -> {
      if list_has(b, h) { merge_string_set(rest, b) }
      else { [h, ...merge_string_set(rest, b)] }
    }
  }
}

# R9: stable C symbol for a handle's env struct. Built from the same
# (enc_fn, line, col) triple as the clause-fn names; both ends mint
# matching identifiers off the matching `ClauseInfo` so the cast in
# the clause prologue resolves to the same type the install site
# allocated. `enc_fn` is the post-monomorph fn / lambda symbol.
fn handle_env_struct_name(enc_fn: String, line: Int, col: Int) : String =
  concat_all([
    "_kai_", enc_fn, "__env_",
    int_to_string(line), "_", int_to_string(col)
  ])

# Lookup the enc_fn stamped on any clause of this handle (all clauses
# of one handle share the same enc_fn). Returns "" when no matching
# clause is in the table — the same defensive fallback used by
# `lookup_clause_enc_fn`.
fn handle_enc_fn_at(cls: [ClauseInfo], hline: Int, hcol: Int) : String {
  match cls {
    [] -> ""
    [c, ...rest] -> match c {
      CI(line, col, _, _, _, _, _, enc_fn, _) ->
        if line == hline and col == hcol { enc_fn }
        else { handle_enc_fn_at(rest, hline, hcol) }
    }
  }
}

fn collect_hclauses(cs: [HClause], st: LamCollect) : LamCollect / Console {

  match cs {
    [] -> st
    [c, ...rest] -> match c {
      HC(_, _, body, _, _) -> collect_hclauses(rest, collect_expr(body, st))
    }
  }
}

fn collect_hreturn(r: HReturn, st: LamCollect) : LamCollect / Console {

  match r {
    HR(_, body, _, _) -> collect_expr(body, st)
  }
}

fn collect_exprs(xs: [Expr], st: LamCollect) : LamCollect / Console {

  match xs {
    [] -> st
    [h, ...rest] -> collect_exprs(rest, collect_expr(h, st))
  }
}

fn collect_arms(arms: [Arm], st: LamCollect) : LamCollect / Console {

  match arms {
    [] -> st
    [a, ...rest] -> match a {
      Arm(_, opt_g, body) -> {
        let s1 = match opt_g { Some(g) -> collect_expr(g, st) None -> st }
        collect_arms(rest, collect_expr(body, s1))
      }
    }
  }
}

fn collect_field_inits(fs: [FieldInit], st: LamCollect) : LamCollect / Console {

  match fs {
    [] -> st
    [f, ...rest] -> match f {
      FI(_, val) -> collect_field_inits(rest, collect_expr(val, st))
    }
  }
}

fn collect_list_elems(es: [ListElem], st: LamCollect) : LamCollect / Console {

  match es {
    [] -> st
    [el, ...rest] -> match el {
      ElPlain(x) -> collect_list_elems(rest, collect_expr(x, st))
      ElSpread(x) -> collect_list_elems(rest, collect_expr(x, st))
    }
  }
}

fn collect_stmts(ss: [Stmt], st: LamCollect) : LamCollect / Console {

  match ss {
    [] -> st
    [s, ...rest] -> collect_stmts(rest, collect_stmt(s, st))
  }
}

fn collect_stmt(s: Stmt, st: LamCollect) : LamCollect / Console {

  match s {
    SLet(pat, _, rhs) -> {
      # issue #285: walk RHS in the *outer* scope, then extend
      # `local_scope` with the pattern's bound names so subsequent
      # stmts and a trailing tail expression treat them as captures.
      let s1 = collect_expr(rhs, st)
      lc_set_locals(s1, pat_bindings(pat, s1.local_scope))
    }
    SAssert(c, opt_m) -> {
      let s1 = collect_expr(c, st)
      match opt_m { Some(m) -> collect_expr(m, s1) None -> s1 }
    }
    SExprStmt(x) -> collect_expr(x, st)
    SIndexAssign(b, i, v, _, _) -> {
      let s1 = collect_expr(b, st)
      let s2 = collect_expr(i, s1)
      collect_expr(v, s2)
    }
    # m7b #5: `var name = init` — desugared into `EHandle` upstream of
    # this walker (`desugar_var_block`), so an `SVar` reaching here is
    # rare; nonetheless mirror SLet so a lone surviving `var` still
    # shadows globals correctly (issue #285).
    SVar(name, _, rhs, _, _) -> {
      let s1 = collect_expr(rhs, st)
      lc_extend_locals(s1, [name])
    }
    # m7e §25: stripped by desugar_use_decls before lambda lift runs.
    SUse(_, _, _) -> st
  }
}

fn collect_interp(span: String, is_triple: Bool, st: LamCollect) : LamCollect / Console {

  let n = string_length(span)
  let body_start = if is_triple { 3 } else { 1 }
  let body_end = if is_triple { n - 3 } else { n - 1 }
  let parts = iscan_collect(span, body_end, IScan { parts: [], lit_start: body_start, i: body_start })
  collect_interp_parts(parts, st)
}

fn collect_interp_parts(parts: [IPart], st: LamCollect) : LamCollect / Console {

  match parts {
    [] -> st
    [p, ...rest] -> match p {
      IpLit(_, _) -> collect_interp_parts(rest, st)
      IpExp(esrc) -> {
        let toks = tokenize(esrc)
        let prs = parser_new("<interp>", esrc, toks)
        let r = parse_expr(prs)
        let st1 = match r.r { Some(e) -> collect_expr(e, st) None -> st }
        collect_interp_parts(rest, st1)
      }
    }
  }
}

# m4c #4: enter / leave helpers for the cur_enc_fn field. Functional
# state-passing — the walker swaps the enclosing fn name on the way
# in and restores the parent's name on the way out so siblings stamp
# their own clauses against the right scope.
fn enter_enc_fn(st: LamCollect, name: String) : LamCollect =
  LamCollect { next_id: st.next_id, lams: st.lams,
                clauses: st.clauses, globals: st.globals,
                cur_enc_fn: name, local_scope: st.local_scope }

fn restore_enc_fn(st: LamCollect, name: String) : LamCollect =
  LamCollect { next_id: st.next_id, lams: st.lams,
                clauses: st.clauses, globals: st.globals,
                cur_enc_fn: name, local_scope: st.local_scope }

fn collect_decl(d: Decl, st: LamCollect) : LamCollect / Console {

  match d {
    DFn(_, name, _, ps, _, _, body, _, _, mo) -> {
      let outer = st.cur_enc_fn
      let outer_locals = st.local_scope
      # issue #285: seed `local_scope` with the fn's parameter names so
      # any nested ELambda's free-variable analysis treats a parameter
      # whose name collides with a stdlib fn (e.g. `count` shadowing
      # `list.count`) as a captured local instead of a global.
      let st1 = enter_enc_fn(lc_set_locals(st, params_to_names(ps)),
                              c_sym(name, mo))
      let st2 = collect_expr(body, st1)
      lc_set_locals(restore_enc_fn(st2, outer), outer_locals)
    }
    DType(_, _, _, _, _, _) -> st
    DTest(_, body, line, col) -> {
      let outer = st.cur_enc_fn
      let outer_locals = st.local_scope
      # m4c #4: the synthesised name has to match the prefix
      # `emit_test_fn` will use so install code emitted inside a test
      # body's `EHandle` and the corresponding clause's top-level C
      # function agree on a single C symbol.
      let test_enc = concat_all([
        "__test__", int_to_string(line), "_", int_to_string(col)
      ])
      let st1 = enter_enc_fn(lc_set_locals(st, []), test_enc)
      let st2 = collect_expr(body, st1)
      lc_set_locals(restore_enc_fn(st2, outer), outer_locals)
    }
    DBench(_, body, line, col) -> {
      let outer = st.cur_enc_fn
      let outer_locals = st.local_scope
      let bench_enc = concat_all([
        "__bench__", int_to_string(line), "_", int_to_string(col)
      ])
      let st1 = enter_enc_fn(lc_set_locals(st, []), bench_enc)
      let st2 = collect_expr(body, st1)
      lc_set_locals(restore_enc_fn(st2, outer), outer_locals)
    }
    DCheck(_, ps, body, line, col) -> {
      let outer = st.cur_enc_fn
      let outer_locals = st.local_scope
      let check_enc = concat_all([
        "__check__", int_to_string(line), "_", int_to_string(col)
      ])
      let st1 = enter_enc_fn(lc_set_locals(st, params_to_names(ps)),
                              check_enc)
      let st2 = collect_expr(body, st1)
      lc_set_locals(restore_enc_fn(st2, outer), outer_locals)
    }
    DImport(_, _, _) -> st
    DEffect(_, _, _, _, _, _) -> st          # no expressions to walk
    # m12.8: stripped pre-resolve. No expressions to walk if one
    # somehow survives.
    DProtocol(_, _, _, _, _, _) -> st
    DImpl(_, _, _, _, _, _) -> st
    DDerive(_, _, _, _) -> st
    DUnit(_, _, _, _, _) -> st               # m12.5: no expressions in a unit decl
    DUse(_, _, _) -> st                       # m7e §25: stripped by desugar_use_decls; no expressions
    DAxiom(_, _, _, _, _, _, _, _, _, _) -> st     # m12.7: rewritten to DFn by lower_axioms; no expressions on the bare form
    DAttribPure(inner, _, _) -> collect_decl(inner, st)  # m12.6.x #5(a)
    DConst(_, _, _, body, _, _) -> {              # issue #269: literal-only body, but walk for safety
      collect_expr(body, st)
    }
  }
}

fn collect_decls(ds: [Decl], st: LamCollect) : LamCollect / Console {

  match ds {
    [] -> st
    [d, ...rest] -> collect_decls(rest, collect_decl(d, st))
  }
}

# Globals: prelude names + user fn names + variant ctor names. Used as a
# cheap "this ident does not need to be captured" test.
fn efn_name(e: EFn) : String = match e { EFn(n, _, _, _) -> n }
fn evar_name(v: EVar) : String = match v { EV(n, _) -> n }

fn build_globals(fns: [EFn], variants: [EVar], eff_names: [String], op_quals: [String]) : [String] {
  let p = prelude_names()
  let f = map(fns, efn_name)
  let v = map(variants, evar_name)
  # Effect names (e.g. `Console`) and qualified op references
  # (`Stdout.print`) are not runtime values; they are
  # name-resolved at op-call sites via the evidence stack.
  # `desugar_op_calls_callee` rewrites `EField(EVar(Eff), op)` into
  # `EVar("Eff.op")` (a single qualified ident), so without
  # including the qualified form in globals, `fv_expr` would treat
  # `Stdout.print` as a free variable inside a lambda body and the
  # lambda lifter would capture it, emitting invalid C
  # (`kai_Stdout.print` is not a valid C identifier).
  list_append(p,
    list_append(f,
      list_append(v,
        list_append(eff_names, op_quals))))
}

# For every `effect Eff { op_a(...) : T  op_b(...) : U }` decl,
# yield the qualified ident strings `"Eff.op_a"`, `"Eff.op_b"`.
# These match what `desugar_op_calls_callee` produces when it
# rewrites `Eff.op(args)` callees into `EVar("Eff.op")`.
fn op_qualified_names_for(eff_name: String, ops: [EffectOp], acc: [String]) : [String] {
  match ops {
    [] -> acc
    [o, ...rest] -> match o {
      EOp(op_name, _, _, _, _, _) ->
        op_qualified_names_for(eff_name, rest,
          [string_concat(eff_name, string_concat(".", op_name)), ...acc])
    }
  }
}

# m12.8 Phase 4b: (op_name, eff_name) pairs collected from every
# DEffect in the program. Used to resolve alias-qualified op calls
# (`Console.print` → `Stdout.print`, `Io.read_line` → `Stdin.read_line`).
type OpToEff = OEFP(String, String)

fn collect_op_to_eff(decls: [Decl]) : [OpToEff] {
  match decls {
    [] -> []
    [d, ...rest] -> match d {
      DEffect(_, eff_name, _, ops, _, _) ->
        list_append(ops_to_eff_pairs(eff_name, ops),
                    collect_op_to_eff(rest))
      _ -> collect_op_to_eff(rest)
    }
  }
}

fn ops_to_eff_pairs(eff_name: String, ops: [EffectOp]) : [OpToEff] {
  match ops {
    [] -> []
    [op, ...rest] -> match op {
      EOp(op_name, _, _, _, _, _) ->
        [OEFP(op_name, eff_name), ...ops_to_eff_pairs(eff_name, rest)]
    }
  }
}

# Returns Some(eff_name) if some component of the alias provides op_name.
# When multiple components share an op_name (currently impossible in
# the catalog — Stdout.print, Stderr.eprint, Stdin.read_line, etc., are
# disjoint), the leftmost component wins. The check is case-sensitive.
fn find_eff_for_alias_op(components: [String], op_to_eff: [OpToEff], op_name: String) : Option[String] {
  match components {
    [] -> None
    [c, ...rest] ->
      if eff_has_op(c, op_name, op_to_eff) { Some(c) }
      else { find_eff_for_alias_op(rest, op_to_eff, op_name) }
  }
}

fn eff_has_op(eff_name: String, op_name: String, op_to_eff: [OpToEff]) : Bool {
  match op_to_eff {
    [] -> false
    [oe, ...rest] -> match oe {
      OEFP(o, e) ->
        if o == op_name and e == eff_name { true }
        else { eff_has_op(eff_name, op_name, rest) }
    }
  }
}

# m12.8 Phase 4b: alias-aware op-call resolution lives inside
# `try_op_call` (typer) and `desugar_op_calls_callee` (emit) instead
# of as a standalone walker — a separate pre-pass blew the selfhost
# stack when traversing compiler.kai's deep AST. The helpers
# `find_alias` / `find_eff_for_alias_op` / `eff_has_op` (defined
# above) are consulted at each call site.

fn collect_op_qualified_names(decls: [Decl]) : [String] {
  match decls {
    [] -> []
    [d, ...rest] -> match d {
      DEffect(_, name, _, ops, _, _) ->
        list_append(op_qualified_names_for(name, ops, []),
                    collect_op_qualified_names(rest))
      _ -> collect_op_qualified_names(rest)
    }
  }
}

# ---- lambda helper emission ----

fn emit_lam_arg_reads(params: [Param], i: Int) : String {
  match params {
    [] -> ""
    [p, ...rest] -> concat_all([
      "    KaiValue *kai_", p.pname, " = args[", int_to_string(i), "];\n",
      emit_lam_arg_reads(rest, i + 1)
    ])
  }
}

fn emit_lam_cap_reads(caps: [String], i: Int) : String {
  match caps {
    [] -> ""
    [c, ...rest] -> {
      let prefix = "__alias_id__"
      let read_line = if string_starts_with_q(c, prefix) {
        # Handler-id sentinel: unpack the kai_int back to a
        # KaiHandlerId so the existing tagged-op emit
        # (`kai_evidence_lookup_node_by_id(kai_alias_<a>_id)`)
        # finds the local in scope.
        let alias = string_slice(c, string_length(prefix), string_length(c))
        concat_all([
          "    KaiHandlerId kai_alias_", alias,
          "_id = (KaiHandlerId) self->as.clo.captures[",
          int_to_string(i),
          "]->as.i;\n"
        ])
      } else {
        concat_all([
          "    KaiValue *kai_", c, " = self->as.clo.captures[", int_to_string(i), "];\n"
        ])
      }
      concat_all([read_line, emit_lam_cap_reads(rest, i + 1)])
    }
  }
}

fn emit_lam_helper(src: String, l: LamInfo, lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : String / Console {

  match l {
    LamInfo(id, _, _, params, caps, body) -> {
      let arg_reads = emit_lam_arg_reads(params, 0)
      let cap_reads = emit_lam_cap_reads(caps, 0)
      # Lambda body sees its params + captures as locals — same
      # contract as `emit_fn_body` for top-level fn params.
      let body_lcs = list_append(list_append(lcs, fn_param_names(params)), caps)
      let body_c = emit_expr(src,body, body_lcs, fns, variants, lams, cls)
      concat_all([
        "static KaiValue *_kai_lam_", int_to_string(id),
        "(KaiValue *self, KaiValue **args, int n) {\n",
        "    (void) self; (void) n;\n",
        arg_reads, cap_reads,
        "    return ", body_c, ";\n}\n\n"
      ])
    }
  }
}

fn emit_lam_helpers(src: String, lams: [LamInfo], fns: [EFn], variants: [EVar], cls: [ClauseInfo]) : String / Console =

  concat_all(map(lams, (l) => emit_lam_helper(src, l, [], fns, variants, lams, cls)))

fn emit_one_lam_forward(l: LamInfo) : String =
  match l {
    LamInfo(id, _, _, _, _, _) ->
      concat_all(["static KaiValue *_kai_lam_", int_to_string(id), "(KaiValue *, KaiValue **, int);\n"])
  }

fn emit_lam_forward_decls(lams: [LamInfo]) : String =
  concat_all(map(lams, emit_one_lam_forward))

# m7a #6c — clause body emission. Each HClause becomes a top-level
# C function whose name encodes the EHandle's source position plus
# the op name (collisions are impossible since two distinct HCs
# either belong to different handles or carry different op names).
# The signature matches the EvE field type pinned in #6a:
#   `static KaiValue *_kai_clause_<line>_<col>_<op>(EvE *self, args..., KaiCont *k)`.
# `resume` is the surface convention for the trailing param and is
# never part of the C signature — the body uses `resume(v)` as
# direct-style identity (m7a #6c only). m7a #6d will replace this
# with a reified continuation closure.

fn op_args_only(params: [Param]) : [Param] {
  match params {
    [] -> []
    [_] -> []                       # the lone trailing `resume`
    [p, ...rest] -> [p, ...op_args_only(rest)]
  }
}

# m4c #4: clause C-symbol minting takes the enclosing fn name as a
# prefix. Pre-fix the name was `_kai_clause_<l>_<c>_<op>` keyed only
# on source position; duplicating a polymorphic body that contains
# `EHandle` produced colliding C symbols and the linker rejected the
# binary, which is why `monomorphise` shipped as identity. The
# prefixed form `_kai_<enc>__clause_<l>_<c>_<op>` lets two
# specialisations of the same source fn (`foo__mono__Int` vs
# `foo__mono__String`) emit distinct symbols. The same prefix is
# minted both at the install site (`emit_clause_assignments`) and at
# the clause-body emit site, fed from `ClauseInfo.enc_fn`.
fn clause_fn_name(enc_fn: String, line: Int, col: Int, op: String) : String =
  concat_all([
    "_kai_", enc_fn, "__clause_",
    int_to_string(line), "_", int_to_string(col), "_", op
  ])

fn emit_clause_sig(c: ClauseInfo) : String {
  match c {
    CI(line, col, eff, op_name, params, _, _, enc_fn, _) -> {
      let op_args = op_args_only(params)
      let arg_str = match op_args {
        [] -> ""
        _  -> cat2(", ", join_with(map(op_args, (pm) => cat2("KaiValue *kai_", pm.pname)), ", "))
      }
      concat_all([
        "static KaiValue *", clause_fn_name(enc_fn, line, col, op_name),
        "(Ev", eff, " *self", arg_str, ", KaiCont *k)"
      ])
    }
  }
}

fn emit_clause_forward(c: ClauseInfo) : String =
  cat2(emit_clause_sig(c), ";\n")

fn emit_clause_forwards(cs: [ClauseInfo]) : String =
  concat_all(map(cs, emit_clause_forward))

# R9: per-handle env typedefs. One typedef per (line, col, enc_fn)
# triple, covering the union of every clause's captures. Emitted at
# top level (ahead of the clause forwards) so the install-site
# allocation in `emit_handle` and the read-side cast in
# `emit_clause_env_prologue` both resolve to the same struct type.
# Uses a "first occurrence wins" walk: the first ClauseInfo we meet
# for a (line, col) pair owns the typedef, later ones for the same
# handle skip emission. Captures are unioned across all clauses of
# the matching handle so the struct layout covers every clause body.
fn emit_handle_env_typedefs(cs: [ClauseInfo]) : String =
  emit_handle_env_typedefs_loop(cs, [])

fn emit_handle_env_typedefs_loop(cs: [ClauseInfo], seen: [String]) : String {
  match cs {
    [] -> ""
    [c, ...rest] -> match c {
      CI(line, col, _, _, _, _, _, enc_fn, _) -> {
        let key = handle_env_struct_name(enc_fn, line, col)
        if list_has(seen, key) {
          emit_handle_env_typedefs_loop(rest, seen)
        } else {
          let caps = handle_captures_at(cs, line, col)
          let decl = match caps {
            [] -> ""
            _ -> emit_handle_env_typedef(key, caps)
          }
          concat_all([decl, emit_handle_env_typedefs_loop(rest, [key, ...seen])])
        }
      }
    }
  }
}

fn emit_handle_env_typedef(env_name: String, caps: [String]) : String =
  concat_all([
    "typedef struct ", env_name, " ", env_name, ";\n",
    "struct ", env_name, " {\n",
    emit_handle_env_typedef_fields(caps),
    "};\n\n"
  ])

fn emit_handle_env_typedef_fields(caps: [String]) : String {
  match caps {
    [] -> ""
    [c, ...rest] -> concat_all([
      "    KaiValue *kai_", c, ";\n",
      emit_handle_env_typedef_fields(rest)
    ])
  }
}

# m7b #11: stateful-clause prologue. `state` and `log` are aliases of
# `self->state`. Both names are bound (the two are aliases of the same
# slot — the spec uses `state` for `State[T]` and `log` for `Writer[W]`,
# but at this layer they read the same field). The clause body is then
# emitted unchanged: any `state` / `log` reference falls through the
# normal ident lookup and resolves to the local C alias.
fn clause_state_prologue(stateful: Bool) : String {
  if stateful {
    "    KaiValue *kai_state = self->state; KaiValue *kai_log = self->state;\n"
  } else { "" }
}

fn emit_clause_body(src: String, c: ClauseInfo, lcs: [String], fns: [EFn], variants: [EVar],
                     lams: [LamInfo], cls: [ClauseInfo]) : String / Console {

  match c {
    CI(line, col, _, _, _, body, stateful, enc_fn, caps) -> {
      # Clause body sees `self` and `k` (always), `kai_state` /
      # `kai_log` (when stateful), the clause's params (params
      # come into scope through the surrounding handle's lcs),
      # and — R9 — every capture that travels through `self->env`.
      # `state` / `log` are spelled with `kai_` prefix in the
      # generated C, but the kaikai-side names are `state` / `log`.
      let stateful_locals = if stateful { ["state", "log"] } else { [] }
      let body_lcs = list_append(list_append(list_append(lcs, ["self", "k"]), stateful_locals), caps)
      let body_c = emit_expr_in_clause(src, body, body_lcs, fns, variants, lams, cls, stateful)
      let env_prologue = emit_clause_env_prologue(cls, line, col, enc_fn, caps)
      concat_all([
        emit_clause_sig(c), " {\n",
        "    (void) self; (void) k;\n",
        clause_state_prologue(stateful),
        env_prologue,
        "    return ", body_c, ";\n",
        "}\n\n"
      ])
    }
  }
}

# R9: rebind each captured `kai_<name>` from the handle's env struct
# into a clause-local C variable, so the body can reference enclosing
# bindings the same way it would inside the surrounding fn. The cast
# target is the per-handle env typedef minted by
# `emit_handle_env_typedefs`; field names match exactly the surface
# names listed in `caps`. Empty when the clause captures nothing —
# the env slot stays NULL and is never dereferenced.
#
# Each read goes through `kai_internal_dup` because perceus analyses
# every clause body in isolation and assumes its `kai_<name>` locals
# arrive with a private reference it may consume (e.g. by passing
# the value to `kai_prelude_string_concat`). The env struct itself
# holds a borrow scoped to the handle stmt-expression — the caller's
# `kai_<name>` outlives the handle's body and is dropped after the
# stmt-expr unwinds, which is the same scope the spec assigns to
# `EvE.env`. Without the dup, a single-use capture would be freed
# after the first clause invocation and the second would read a
# dangling pointer (the manifestation of "Perceus needs to incref
# captures at install / decref at pop" — solved here at clause
# entry, where it composes with perceus's per-clause analysis).
fn emit_clause_env_prologue(cls: [ClauseInfo], line: Int, col: Int,
                             enc_fn: String, caps: [String]) : String {
  match caps {
    [] -> ""
    _ -> {
      let env_name = handle_env_struct_name(enc_fn, line, col)
      concat_all([
        "    ", env_name, " *_env = (", env_name, " *) self->env;\n",
        emit_clause_env_reads(caps)
      ])
    }
  }
}

fn emit_clause_env_reads(caps: [String]) : String {
  match caps {
    [] -> ""
    [c, ...rest] -> concat_all([
      "    KaiValue *kai_", c, " = kai_internal_dup(_env->kai_", c, ");\n",
      emit_clause_env_reads(rest)
    ])
  }
}

# Wrapper around `emit_expr` that flips the in-clause flag, so that
# `resume(v, ns)` lowers to a state-write before the resume call.
# Defined further below near emit_expr.
fn emit_expr_in_clause(src: String, e: Expr, lcs: [String], fns: [EFn], variants: [EVar],
                        lams: [LamInfo], cls: [ClauseInfo], stateful: Bool) : String / Console =

  emit_expr(src, e, lcs, fns, variants, lams, cls)

fn emit_clause_bodies(src: String, cs: [ClauseInfo], lcs: [String], fns: [EFn], variants: [EVar],
                      lams: [LamInfo], cls: [ClauseInfo]) : String / Console =

  concat_all(map(cs, (c) => emit_clause_body(src, c, lcs, fns, variants, lams, cls)))

# m7c-d — emit each clause as a top-level LLVM function. Mirrors
# `emit_clause_body`/`emit_clause_sig` from the C backend. The
# function takes `(EvX *self, %KaiValue* %arg1, ..., i8* %k)`
# and returns `%KaiValue*`. Inside, `self` and `k` are bound as
# locals (literal register names `%self` / `%k` so the resume
# handler in `llvm_emit_call` can reference `%k` directly). For
# stateful clauses we load `self->state` once into a local
# `%kai_state` (also bound as `%kai_log`) so the body can
# reference `state`/`log` like any other ident.
fn llvm_emit_clause_body(c: ClauseInfo, fns: [EFn], vs: [EVar], lams: [LamInfo],
                          oo: [OpOffset], cls: [ClauseInfo],
                          start_id: Int) : LlvmDeclOut / Console {

  match c {
    # R9: the trailing `[String]` captures field is plumbed through
    # the C backend (`emit_clause_body`) but not yet wired into the
    # LLVM backend. The LLVM clause body still ignores it, so a
    # clause that names an enclosing-fn binding will fail to lower
    # under `selfhost-llvm` the same way it failed under the C
    # backend pre-fix. Mirror is a follow-up; see CHANGELOG entry
    # for R9 for the C-first staging note.
    CI(line, col, eff, op_name, params, body, stateful, enc_fn, _) -> {
      let sym = clause_fn_name(enc_fn, line, col, op_name)
      let op_args = op_args_only(params)
      let arg_sig = llvm_clause_arg_sig(op_args)
      let locals0 = llvm_clause_locals(op_args)
      let e0 = LlvmEmit { ids: LlvmIdGen { next: start_id },
                          globals: "", body: "",
                          last_val: "", cur_label: "entry",
                          locals: locals0, fns: fns, vars_: vs, lams: lams,
                          op_offsets: oo, cls: cls }
      # Stateful prologue: read self->state into a fresh value and
      # bind it under both `state` and `log` so the body resolves.
      let e_pro = if stateful {
        let st_p_reg = llvm_fresh_reg(e0)
        let st_p_gep = concat_all([
          "  ", st_p_reg.reg, " = getelementptr %Ev", eff,
          ", %Ev", eff, "* %self, i32 0, i32 2\n"
        ])
        let e_p1 = llvm_append_body(st_p_reg.e, st_p_gep)
        let st_v_reg = llvm_fresh_reg(e_p1)
        let st_load = concat_all([
          "  ", st_v_reg.reg, " = load %KaiValue*, %KaiValue** ", st_p_reg.reg, "\n"
        ])
        let e_p2 = llvm_append_body(st_v_reg.e, st_load)
        let bound_state = llvm_push_local(e_p2, "state", st_v_reg.reg)
        llvm_push_local(bound_state, "log", st_v_reg.reg)
      } else { e0 }
      let e1 = llvm_emit_expr(e_pro, body)
      let text = concat_all([
        e1.globals,
        "\n",
        "define %KaiValue* @", sym,
        "(%Ev", eff, "* %self", arg_sig, ", i8* %k) {\n",
        e1.body,
        "  ret %KaiValue* ", e1.last_val, "\n",
        "}\n\n"
      ])
      LlvmDeclOut { text: text, next_id: e1.ids.next }
    }
  }
}

fn llvm_clause_arg_sig(ps: [Param]) : String {
  match ps {
    [] -> ""
    [p, ...rest] ->
      concat_all([", %KaiValue* %kai_", p.pname, llvm_clause_arg_sig(rest)])
  }
}

fn llvm_clause_locals(ps: [Param]) : [LlvmLocal] {
  match ps {
    [] -> []
    [p, ...rest] -> [LL(p.pname, concat_all(["%kai_", p.pname])),
                      ...llvm_clause_locals(rest)]
  }
}

fn llvm_emit_clause_bodies(cs: [ClauseInfo], fns: [EFn], vs: [EVar],
                            lams: [LamInfo], oo: [OpOffset],
                            cls_all: [ClauseInfo],
                            start_id: Int, acc: String) : LlvmDeclOut / Console {

  match cs {
    [] -> LlvmDeclOut { text: acc, next_id: start_id }
    [c, ...rest] -> {
      let out = llvm_emit_clause_body(c, fns, vs, lams, oo, cls_all, start_id)
      llvm_emit_clause_bodies(rest, fns, vs, lams, oo, cls_all,
                              out.next_id, string_concat(acc, out.text))
    }
  }
}

# m7b #15 closure-capture: a regular cap reads the enclosing
# `kai_<name>` C local. A handler-id sentinel
# (`__alias_id__<alias>`) instead reads `kai_alias_<alias>_id` —
# a `KaiHandlerId` (unsigned long long) — and packs it as a
# `kai_int` so the closure capture array stays uniformly
# `KaiValue *`. The lambda body unpacks it on the way in.
fn emit_one_closure_cap(c: String) : String {
  let prefix = "__alias_id__"
  if string_starts_with_q(c, prefix) {
    let alias = string_slice(c, string_length(prefix), string_length(c))
    concat_all(["kai_int((int64_t) kai_alias_", alias, "_id)"])
  } else {
    cat2("kai_", c)
  }
}

fn emit_closure_caps(caps: [String]) : String =
  join_with(map(caps, emit_one_closure_cap), ", ")

fn emit_lambda_ref(x: Expr, lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : String {
  match find_lam(lams, x.line, x.col) {
    None -> "kai_unit() /* lambda: missing info */"
    Some(l) -> match l {
      LamInfo(id, _, _, params, caps, _) -> {
        let arity = list_length(params)
        let n_caps = list_length(caps)
        if n_caps == 0 {
          concat_all([
            "kai_closure(&_kai_lam_", int_to_string(id),
            ", ", int_to_string(arity), ", 0, NULL)"
          ])
        } else {
          concat_all([
            "kai_closure(&_kai_lam_", int_to_string(id),
            ", ", int_to_string(arity), ", ", int_to_string(n_caps),
            ", (KaiValue *[]){", emit_closure_caps(caps), "})"
          ])
        }
      }
    }
  }
}

# ---- full emit_expr (with lambda support) ----

# C type used for a raw local of an unboxable type. Matches the
# `as.*` field widths in `KaiValue` (see runtime.h).
fn raw_c_type(opt_ty: Option[Ty]) : String {
  match opt_ty {
    Some(t) -> match t {
      TyInt  -> "int64_t"
      TyReal -> "double"
      TyBool -> "int"
      TyChar -> "uint32_t"
      TyDimT(inner, _)    -> raw_c_type(Some(inner))
      TyRefineT(inner, _) -> raw_c_type(Some(inner))
      _ -> "int64_t /* raw_c_type: unexpected ty */"
    }
    None -> "int64_t /* raw_c_type: missing ty */"
  }
}

# Wrap a raw C scalar into its boxed `KaiValue *` form. Picks the
# constructor by `ty`. `kai_int` / `kai_bool` / `kai_char` are the
# Phase 1 cache-aware constructors so small ints and chars stay
# allocation-free at the boundary.
fn box_wrap(opt_ty: Option[Ty], raw: String) : String {
  match opt_ty {
    Some(t) -> match t {
      TyInt  -> cat3("kai_int(",  raw, ")")
      TyReal -> cat3("kai_real(", raw, ")")
      TyBool -> cat3("kai_bool(", raw, ")")
      TyChar -> cat3("kai_char(", raw, ")")
      TyDimT(inner, _)    -> box_wrap(Some(inner), raw)
      TyRefineT(inner, _) -> box_wrap(Some(inner), raw)
      _ -> cat3("kai_int(", raw, ") /* box_wrap: unexpected ty */")
    }
    None -> cat3("kai_int(", raw, ") /* box_wrap: missing ty */")
  }
}

# Unbox a boxed `KaiValue *` into its raw C scalar. Used at the
# `MBoxed → MUnboxed` boundary inside arithmetic operands.
fn unbox_field_for(opt_ty: Option[Ty]) : String {
  match opt_ty {
    Some(t) -> match t {
      TyInt  -> "->as.i"
      TyReal -> "->as.r"
      TyBool -> "->as.b"
      TyChar -> "->as.c"
      TyDimT(inner, _)    -> unbox_field_for(Some(inner))
      TyRefineT(inner, _) -> unbox_field_for(Some(inner))
      _ -> "->as.i /* unbox: unexpected ty */"
    }
    None -> "->as.i /* unbox: missing ty */"
  }
}

# Emit the raw C scalar form of `x`. Caller has already established
# that `x.ty` is unboxable; the result is `int64_t` / `int` /
# `uint32_t` (depending on ty), no `KaiValue *` wrapper.
#
# When `x.mode` is `MUnboxed` the kind is one of the natively-raw
# forms (literal, raw EVar, raw arith). When `x.mode` is `MBoxed`
# we fall back to emitting boxed and tacking on the unbox field —
# the boundary tactic from `docs/unboxing-phase2-design.md` §3.
fn emit_expr_raw(src: String, x: Expr, lcs: [String], fns: [EFn],
                  variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : String / Console {

  match x.mode {
    MUnboxed -> emit_kind_raw(src, x, lcs, fns, variants, lams, cls)
    _ -> {
      let boxed = emit_expr_boxed(src, x, lcs, fns, variants, lams, cls)
      cat3("(", boxed, cat2(")", unbox_field_for(x.ty)))
    }
  }
}

# Issue #90 — unroll `b ^ n` into `n` repeated multiplications.
# Caller has already gated `n` to `[0, 64]` and `base_c` is a pure
# raw C expression (literal / EVar / pure raw arith). For `n == 0`
# the result is `1` (matches `kai_op_pow_int`). For `n == 1`,
# emit just `(base_c)`. For `n >= 2`, emit `((base_c)*(base_c)*…)`
# with `n` factors. Squaring would emit fewer factors but produces
# the same constant-folded code under any optimizer; the linear
# form keeps the emitted IR easy to grep for in regression tests.
fn emit_pow_unroll(base_c: String, n: Int) : String {
  match n {
    0 -> "1LL"
    1 -> cat3("(", base_c, ")")
    _ -> cat3("(", emit_pow_unroll_loop(base_c, n, ""), ")")
  }
}

fn emit_pow_unroll_loop(base_c: String, k: Int, acc: String) : String {
  match k {
    0 -> acc
    1 -> {
      if acc == "" { cat3("(", base_c, ")") }
      else { concat_all([acc, " * (", base_c, ")"]) }
    }
    _ -> {
      let next = if acc == "" { cat3("(", base_c, ")") }
                 else { concat_all([acc, " * (", base_c, ")"]) }
      emit_pow_unroll_loop(base_c, k - 1, next)
    }
  }
}

fn emit_kind_raw(src: String, x: Expr, lcs: [String], fns: [EFn],
                  variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : String / Console {

  match x.kind {
    EInt(n)  -> cat2(int_to_string(n), "LL")
    EReal(r) -> real_c_lit(real_to_string(r))
    EBool(b) -> if b { "1" } else { "0" }
    EChar(c) -> int_to_string(char_to_int(c))
    EVar(name) -> cat2("kair_", name)
    EBinop(op, a, b) ->
      if op_is_raw_arith(op) or op_is_raw_cmp(op) or op_is_raw_logical(op) {
        concat_all(["(",
                    emit_expr_raw(src, a, lcs, fns, variants, lams, cls),
                    " ", raw_op_str(op), " ",
                    emit_expr_raw(src, b, lcs, fns, variants, lams, cls),
                    ")"])
      } else if op == "^" {
        # Issue #90 — integer power, exponent is a compile-time
        # literal in `[0, 64]` (gated by `pow_exp_is_inlinable`).
        # Unroll into repeated multiplications. Base is pure raw
        # (no calls) so duplication is safe.
        let n = match try_eval_int(b) { Some(v) -> v None -> 0 }
        let base_c = emit_expr_raw(src, a, lcs, fns, variants, lams, cls)
        emit_pow_unroll(base_c, n)
      } else {
        # Conservative fallback: boxed expression then unbox.
        let boxed = emit_expr_boxed(src, x, lcs, fns, variants, lams, cls)
        cat3("(", boxed, cat2(")", unbox_field_for(x.ty)))
      }
    EUnop(op, inner) ->
      if op == "-" {
        cat3("(-", emit_expr_raw(src, inner, lcs, fns, variants, lams, cls), ")")
      } else if op == "not" {
        cat3("(!", emit_expr_raw(src, inner, lcs, fns, variants, lams, cls), ")")
      } else {
        let boxed = emit_expr_boxed(src, x, lcs, fns, variants, lams, cls)
        cat3("(", boxed, cat2(")", unbox_field_for(x.ty)))
      }
    # Phase 3 unboxing — when the callee resolves to a UFn, emit
    # the raw call inline (`<callee>(<raw args>)`) so the result
    # stays a raw scalar without a kai_int wrap-and-unwrap. The
    # tcrec sentinel callee is special — it always lowers to the
    # `goto`-block which `tcrec_emit_goto` already produces in raw
    # form when the surrounding fn is UFn. Other callees fall back
    # to the boxed-then-unbox boundary form.
    ECall(callee_e, args_e) -> match callee_e.kind {
      EVar(callee) ->
        if tcrec_is_sentinel(callee) {
          let parts = tcrec_split_pipe(callee)
          match parts {
            [_, sym, dropmask_str, ...pnames] -> {
              let dropmask = tcrec_parse_decimal(dropmask_str)
              tcrec_emit_goto(src, sym, dropmask, pnames, args_e,
                              lcs, fns, variants, lams, cls)
            }
            _ -> "0 /* tcrec: malformed sentinel */"
          }
        } else { match emit_ufn_raw_call(src, callee_e, args_e, lcs, fns, variants, lams, cls) {
          Some(s) -> s
          None    -> {
            let boxed = emit_expr_boxed(src, x, lcs, fns, variants, lams, cls)
            cat3("(", boxed, cat2(")", unbox_field_for(x.ty)))
          }
        } }
      _ -> match emit_ufn_raw_call(src, callee_e, args_e, lcs, fns, variants, lams, cls) {
        Some(s) -> s
        None    -> {
          let boxed = emit_expr_boxed(src, x, lcs, fns, variants, lams, cls)
          cat3("(", boxed, cat2(")", unbox_field_for(x.ty)))
        }
      }
    }
    # Phase 3 unboxing — `if cond { a } else { b }` where every
    # branch is itself emit-raw-able lowers to the C ternary
    # `(cond ? a : b)`. Caller has already gated `x.mode = MUnboxed`
    # via `decide_mode`'s EIf clause (not yet enabled — kept boxed
    # for now). Defensive: when present, both arms must agree on
    # type and the cond must be raw-bool.
    EIf(cnd, ath, opt_eth) -> match opt_eth {
      Some(eth) -> {
        let cnd_c = emit_expr_raw(src, cnd, lcs, fns, variants, lams, cls)
        let a_c = emit_expr_raw(src, ath, lcs, fns, variants, lams, cls)
        let b_c = emit_expr_raw(src, eth, lcs, fns, variants, lams, cls)
        concat_all(["(", cnd_c, " ? ", a_c, " : ", b_c, ")"])
      }
      None -> {
        let boxed = emit_expr_boxed(src, x, lcs, fns, variants, lams, cls)
        cat3("(", boxed, cat2(")", unbox_field_for(x.ty)))
      }
    }
    # Phase 3 unboxing — single-tail EBlock with no preceding
    # statements simply wraps a raw tail expression. Emit the
    # tail directly without the surrounding `({ ... })`.
    EBlock(stmts, opt_tail) -> match stmts {
      [] -> match opt_tail {
        Some(t) -> emit_expr_raw(src, t, lcs, fns, variants, lams, cls)
        None -> {
          let boxed = emit_expr_boxed(src, x, lcs, fns, variants, lams, cls)
          cat3("(", boxed, cat2(")", unbox_field_for(x.ty)))
        }
      }
      _ -> {
        let boxed = emit_expr_boxed(src, x, lcs, fns, variants, lams, cls)
        cat3("(", boxed, cat2(")", unbox_field_for(x.ty)))
      }
    }
    _ -> {
      # Anything else: emit boxed and unwrap. The unbox_pass should
      # not have marked these MUnboxed in the first place — defensive.
      let boxed = emit_expr_boxed(src, x, lcs, fns, variants, lams, cls)
      cat3("(", boxed, cat2(")", unbox_field_for(x.ty)))
    }
  }
}

# Phase 3 unboxing — when the callee `f` resolves to a UFn entry
# in the EFn table, emit the call against raw args without any
# `kai_<T>` wrap. Returns None when the callee is not a UFn. The
# caller (emit_kind_raw ECall arm) falls back to the boxed-then-
# unbox boundary form.
fn emit_ufn_raw_call(src: String, f: Expr, args_e: [Expr], lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : Option[String] / Console {

  match f.kind {
    EVar(callee) ->
      if list_has(lcs, callee) { None }
      else { match efn_resolve(fns, callee) {
        Some(EFn(_, _, mo, Some(_))) -> {
          let raw_args = emit_call_args_raw(src, args_e, lcs, fns, variants, lams, cls)
          Some(cat5("kai_", c_sym(callee, mo), "(", raw_args, ")"))
        }
        _ -> None
      } }
    EModCall(mod, fname) -> match lookup_ufn_sig(fns, fname, Some(mod)) {
      Some(_) -> {
        let raw_args = emit_call_args_raw(src, args_e, lcs, fns, variants, lams, cls)
        Some(cat5("kai_", c_sym(fname, Some(mod)), "(", raw_args, ")"))
      }
      None -> None
    }
    _ -> None
  }
}

fn emit_expr(src: String, x: Expr, lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : String / Console {

  match x.mode {
    MUnboxed -> {
      # MUnboxed → MBoxed boundary: emit raw and wrap.
      let raw = emit_expr_raw(src, x, lcs, fns, variants, lams, cls)
      box_wrap(x.ty, raw)
    }
    _ -> emit_expr_boxed(src, x, lcs, fns, variants, lams, cls)
  }
}

fn emit_expr_boxed(src: String, x: Expr, lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : String / Console {

  match x.kind {
    # Fix B (bidirectional list literals): when an Int literal is
    # checked against a Byte-context (e.g. inside `let bs: [Byte] = [65, 66]`),
    # the typer rewrites the node's ty to TyByte. Emit a Byte
    # constructor directly rather than `kai_int`. The 0..255 range
    # check has already happened at type-check time.
    EInt(n)      -> match x.ty {
      Some(TyByte) -> cat3("kai_byte((uint8_t)", int_to_string(n), ")")
      _            -> cat3("kai_int(", int_to_string(n), "LL)")
    }
    EReal(r)     -> cat3("kai_real(", real_to_string(r), ")")
    EBool(b)     -> if b { "kai_bool(1)" } else { "kai_bool(0)" }
    EChar(c)     -> cat3("kai_char(", int_to_string(char_to_int(c)), ")")
    EStr(span, is_triple) -> emit_string_expr(src, span, is_triple, lcs, fns, variants, lams, cls)
    EUnit        -> "kai_unit()"
    EVar(name)   -> emit_ident_value(name, lcs, fns, variants)
    EUnder       -> "kai_unit() /* _ */"
    EPlaceholder -> "kai_unit() /* placeholder */"
    ECall(f, args_e) -> emit_call_expr(src, f, args_e, lcs, fns, variants, lams, cls)
    EField(base, fname) -> {
      # #293 Phase 1.2 — record field access RC discipline.
      # `base` is owned by the time it lands here: perceus_pass wraps
      # non-last reads of in-scope EVar in __perceus_dup, single-use
      # reads transfer their ref, and ctor/call expressions return
      # rc=1. `kai_op_field` increfs the field on read, so the base
      # is no longer reachable through the result. Drop it to balance.
      let b = emit_expr(src, base, lcs, fns, variants, lams, cls)
      concat_all([
        "({ KaiValue *_b = ", b,
        "; KaiValue *_f = kai_op_field(_b, \"", fname, "\"); kai_decref(_b); _f; })"
      ])
    }
    EIndex(_, _) -> "kai_unit() /* index: not used by bootstrap examples */"
    EBinop(op, a, b) -> {
      if op == "and" {
        # m5.x flip Phase 3 closeout: `_a` is freshly allocated in
        # most call sites; under the runtime flip it would otherwise
        # leak — `kai_op_truthy` is non-consuming (the LLVM short-
        # circuit phi needs the value alive on the skip path) and
        # the C ternary returns either `<RHS>` or `kai_bool(0)`,
        # both fresh, so `_a` is never reused. Drop it via the
        # comma operator inside each branch.
        concat_all([
          "({ KaiValue *_a = ", emit_expr(src, a, lcs, fns, variants, lams, cls),
          "; KaiValue *_r = kai_op_truthy(_a) ? ", emit_expr(src, b, lcs, fns, variants, lams, cls),
          " : kai_bool(0); kai_decref(_a); _r; })"
        ])
      } else if op == "or" {
        concat_all([
          "({ KaiValue *_a = ", emit_expr(src, a, lcs, fns, variants, lams, cls),
          "; KaiValue *_r = kai_op_truthy(_a) ? kai_bool(1) : ", emit_expr(src, b, lcs, fns, variants, lams, cls), "; kai_decref(_a); _r; })"
        ])
      } else if op == "++" {
        # m7d §23: lower `a ++ b` to either `string_concat(a, b)` or
        # `list_append(a, b)` depending on the binop's typed result.
        # The typer pins `x.ty` to `String` or `[T]` before we get
        # here; an untyped `++` is a typer bug we surface as a panic
        # stub so it shows up in fixtures.
        let helper = concat_helper_of(x.ty)
        concat_all([
          helper, "(",
          emit_expr(src, a, lcs, fns, variants, lams, cls), ", ",
          emit_expr(src, b, lcs, fns, variants, lams, cls), ")"
        ])
      } else {
        match binop_cname(op) {
          Some(cn) -> concat_all([
            cn, "(",
            emit_expr(src, a, lcs, fns, variants, lams, cls), ", ",
            emit_expr(src, b, lcs, fns, variants, lams, cls), ")"
          ])
          None -> cat3("kai_unit() /* unknown binop: ", op, " */")
        }
      }
    }
    EUnop(op, inner) -> {
      match unop_cname(op) {
        Some(cn) -> concat_all([cn, "(", emit_expr(src, inner, lcs, fns, variants, lams, cls), ")"])
        None -> cat3("kai_unit() /* unknown unop: ", op, " */")
      }
    }
    EIf(c, a, opt_b) -> {
      # Tier 2.5 M4 — if the condition is already raw bool, skip
      # the `kai_op_truthy` wrapper and use the C ternary directly.
      # Issue #82: when the cond is boxed, capture it in a local and
      # decref after the ternary. `kai_op_truthy` is non-consuming
      # (the LLVM short-circuit phi keeps lhs alive on the skip path,
      # so the runtime predicate cannot blindly consume), and the
      # branches return either the then- or else-arm fresh value —
      # never `_c` itself — so dropping `_c` after the ternary is
      # safe and balances the fresh allocation that fed it.
      match c.mode {
        MUnboxed -> {
          let cc = emit_expr_raw(src, c, lcs, fns, variants, lams, cls)
          let tc = emit_expr(src, a, lcs, fns, variants, lams, cls)
          let ec = match opt_b {
            Some(eb) -> emit_expr(src, eb, lcs, fns, variants, lams, cls)
            None -> "kai_unit()"
          }
          concat_all(["(", cc, " ? ", tc, " : ", ec, ")"])
        }
        _ -> {
          let cb = emit_expr(src, c, lcs, fns, variants, lams, cls)
          let tc = emit_expr(src, a, lcs, fns, variants, lams, cls)
          let ec = match opt_b {
            Some(eb) -> emit_expr(src, eb, lcs, fns, variants, lams, cls)
            None -> "kai_unit()"
          }
          concat_all([
            "({ KaiValue *_c = ", cb,
            "; KaiValue *_r = kai_op_truthy(_c) ? ", tc, " : ", ec,
            "; kai_decref(_c); _r; })"
          ])
        }
      }
    }
    EMatch(scr, arms) -> emit_match_expr(src, scr, arms, lcs, fns, variants, lams, cls)
    ELambda(_, _) -> emit_lambda_ref(x, lcs, fns, variants, lams, cls)
    ERecordLit(_, fields) -> emit_record_lit(src, fields, lcs, fns, variants, lams, cls)
    EList(elems) -> emit_list_expr(src, elems, lcs, fns, variants, lams, cls)
    ERange(a, b, opt_step) -> emit_range_expr(src, a, b, opt_step, lcs, fns, variants, lams, cls)
    EBlock(stmts, opt_final) -> {
      match stmts {
        [] -> match opt_final {
          Some(fe) -> emit_expr(src, fe, lcs, fns, variants, lams, cls)
          None -> "kai_unit()"
        }
        _ -> {
          # m5 #3 — drops for unused let-bindings whose RHS is a
          # fresh allocation. See `block_unused_lets`. The set is
          # computed once per block so each let-binding's drop
          # decision considers all subsequent stmts and the trailing
          # final expression.
          let drops = block_unused_lets(stmts, opt_final)
          # m14 v1.x — fold over stmts threading the local-name
          # scope: each `SLet(pat, _, _)` extends `lcs` with `pat`'s
          # binders so a later stmt or the final expression resolves
          # `EVar(name)` to the local read instead of a same-named
          # top-level fn.
          let stmt_acc = emit_block_stmts(src, stmts, drops, lcs, fns, variants, lams, cls)
          let stmt_out = match stmt_acc { EBSA(_, t) -> t }
          let lcs = match stmt_acc { EBSA(l, _) -> l }
          let final_out = match opt_final {
            Some(fe) -> cat2(emit_expr(src, fe, lcs, fns, variants, lams, cls), "; ")
            None -> "kai_unit(); "
          }
          cat4("({ ", stmt_out, final_out, "})")
        }
      }
    }
    EPipe(a, b) -> emit_pipe_expr(src, a, b, lcs, fns, variants, lams, cls)
    # issue #201: `|` and `||` are rewritten by the typer (synth_map_pipe /
    # synth_flat_map_pipe) into a `<module>.<op>(lhs, f)` ECall before
    # codegen runs, so these arms are unreachable in practice. They exist
    # to keep the exhaustive match valid; a fall-through here is a typer
    # bug — emit a panic so the regression is loud at runtime.
    EMapPipe(_, _)     -> "kai_prelude_panic(kai_str(\"unreachable: EMapPipe survived typer\"))"
    EFlatMapPipe(_, _) -> "kai_prelude_panic(kai_str(\"unreachable: EFlatMapPipe survived typer\"))"
    EFilterPipe(_, _)  -> "kai_prelude_panic(kai_str(\"unreachable: EFilterPipe survived typer\"))"
    EHole(nm_opt) -> {
      # Unfilled holes are runtime-panicky but syntactically valid:
      # the checker reports them and emission leaves a panic stub,
      # so a binary with holes is runnable — it just aborts loudly
      # on first reach.
      let label = match nm_opt { Some(nm) -> cat2("?", nm) None -> "?" }
      let msg = cat2("unfilled hole: ", label)
      concat_all(["kai_prelude_panic(kai_str(\"", msg, "\"))"])
    }
    ETodo(msg) -> {
      # m7d §1: `todo!(msg)` lowers to the same panic path as a hole
      # but with the user-supplied message, prefixed `todo: ` so the
      # binary's abort tag matches the source-form intent.
      let full = cat2("todo: ", msg)
      concat_all(["kai_prelude_panic(kai_str(\"", full, "\"))"])
    }
    EBang(inner) -> emit_bang(src, inner, lcs, fns, variants, lams, cls)
    EHandle(body, eff_name, _eff_tyargs, init_opt, alias_opt, clauses, ret_opt) ->
      emit_handle(src, body, eff_name, init_opt, alias_opt, clauses, ret_opt, x.line, x.col, lcs, fns, variants, lams, cls)
    # m12.5: codegen erasure — `1.0<USD>` emits the same C as `1.0`.
    # Units are typer-only; the generated value carries no unit tag.
    ELitUnit(inner, _) -> emit_expr(src, inner, lcs, fns, variants, lams, cls)
    # m7e §11: `variants[T]()`. The typer baked the resolved variant
    # names into the AST node (synth_variants_of); here we materialise
    # them as a kai_cons spine of nullary constructors. Each variant
    # was validated as nullary at typing time, so emit_variant_call
    # with arity 0 / empty arg array is correct.
    EVariantsOf(_, names) -> emit_variants_of_list(names)
    # m6.2 Phase 3 / v2: qualified call as an expression value
    # (callee of an ECall is handled in emit_call_expr; this branch
    # covers `let f = list.map`-style first-class references). Mint
    # the prefixed thunk symbol directly from the EModCall payload.
    # `emit_ident_value(fname, ...)` would lose the qualified context
    # and pick the wrong entry in the ambiguous-name case.
    EModCall(mod, fname) -> match efn_resolve(fns, fname) {
      Some(EFn(_, ar, _, _)) ->
        cat5("kai_closure(&_kai_", c_sym(fname, Some(mod)), "_thunk, ", int_to_string(ar), ", 0, NULL)")
      None -> cat2("kai_", fname)
    }
  }
}

# m7e §11: emit a `[V0, V1, ..., Vn]` C list of nullary variant
# constructors. Mirrors emit_list_tail's cons-spine shape; uses the
# same kai_variant signature emit_ident_value uses for a bare
# nullary constructor reference.
fn emit_variants_of_list(names: [String]) : String {
  match names {
    [] -> "kai_nil()"
    [n, ...rest] -> concat_all([
      "kai_cons(kai_variant(0, \"", n, "\", 0, NULL), ",
      emit_variants_of_list(rest), ")"
    ])
  }
}

# m7e §13 — lower `expr!` to a statement-expression that evaluates
# `inner`, returns the success payload, or short-circuits the
# enclosing C function with an early `return`. The discriminator
# (`Some` vs `Ok`) is chosen from `inner.ty`, which the typer
# stamped to `Option[_]` or `Result[_, _]` after substitution. Any
# other shape here is a typer bug — we fall back to a panic stub
# rather than emit silently-wrong C.
fn emit_bang(src: String, inner: Expr, lcs: [String], fns: [EFn], variants: [EVar],
             lams: [LamInfo], cls: [ClauseInfo]) : String / Console {

  let inner_c = emit_expr(src, inner, lcs, fns, variants, lams, cls)
  let success = bang_success_variant(inner.ty)
  match success {
    Some(name) -> concat_all([
      "({ KaiValue *_b = ", inner_c, "; ",
      "if (!(_b && _b->tag == KAI_VARIANT && strcmp(_b->as.var.variant_name, \"",
      name, "\") == 0)) return _b; ",
      "_b->as.var.args[0]; })"
    ])
    None -> concat_all([
      "kai_prelude_panic(kai_str(\"internal: `!` on non-Option/Result reached emitter\"))"
    ])
  }
}

fn bang_success_variant(opt_ty: Option[Ty]) : Option[String] {
  match opt_ty {
    None -> None
    Some(t) -> match t {
      TyCon(name, _) ->
        if name == "Option" { Some("Some") }
        else if name == "Result" { Some("Ok") }
        else { None }
      _ -> None
    }
  }
}

# m7a #6b/#6c: lower `handle { body } with Eff [as alias] { clauses }`
# to its prologue/body/epilogue. m7a #6b shipped the EvE alloca,
# the handler-id stamp, the kai_evidence_push/pop pair, and the
# optional return clause; m7a #6c populates each op fn-ptr with the
# top-level clause function emitted by emit_clause_body, so that op
# calls inside the body dispatch through the EvE.
# m7b #11: when `init_opt` is `Some(ie)`, write the init value into
# `_ev.state` after the handler-id and op-fn-ptr assignments. The
# clause body emitter exposes that slot inside clauses as `state` /
# `log` aliases of `self->state`.
fn emit_handle(src: String, body: Expr, eff_name: String, init_opt: Option[Expr],
               alias_opt: Option[String],
               clauses: [HClause],
               ret_opt: Option[HReturn], hline: Int, hcol: Int,
               lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : String / Console {

  let body_c = emit_expr(src, body, lcs, fns, variants, lams, cls)
  let assigns = emit_clause_assignments(eff_name, clauses, hline, hcol, cls)
  # R9: gather every name any clause body of this handle captures
  # from the surrounding scope. Filtered against `lcs` so a name that
  # is *not* in scope at the install site (e.g. a top-level fn that
  # `fv_expr` already excluded via `globals` — defensive) does not
  # produce an undefined assign.
  let env_caps = list_filter_in(handle_captures_at(cls, hline, hcol), lcs)
  let env_enc_fn = handle_enc_fn_at(cls, hline, hcol)
  let env_alloc = emit_handle_env_alloc(env_caps, env_enc_fn, hline, hcol)
  let env_assign = emit_handle_env_ev_assign(env_caps)
  # m7b #15 (compiler integration): expose the handle's
  # `handler_id` as a local C variable named `kai_alias_<a>_id`
  # whenever the handle declared an `as`-bound capability. The
  # op-call dispatch (emit_call_expr) emits a
  # `kai_evidence_lookup_node_by_id(kai_alias_<a>_id)` call
  # whenever the alias rewrite tagged the op name with
  # `@<a>`. The local lives in the same statement-expression
  # as the rest of the handle prologue, so it is in scope for
  # every op-call site inside `body_c`.
  let alias_id_c = match alias_opt {
    Some(a) -> concat_all([
      "KaiHandlerId kai_alias_", a, "_id = _ev.handler_id; "
    ])
    None -> ""
  }
  let init_c = match init_opt {
    Some(ie) -> concat_all(["_ev.state = ", emit_expr(src, ie, lcs, fns, variants, lams, cls), "; "])
    None     -> ""
  }
  let ret_c = match ret_opt {
    Some(r) -> match r {
      HR(pname, rexpr, _, _) -> {
        # m7b #11: when the handler is stateful, the return clause
        # also sees `state` / `log` (so `return(x) -> (x, state)` works).
        let stateful = match init_opt { Some(_) -> true None -> false }
        let prologue = if stateful {
          # _node is a KaiEvidence; its `handler` field is `&_ev`.
          "KaiValue *kai_state = _ev.state; KaiValue *kai_log = _ev.state; "
        } else { "" }
        concat_all([
          "KaiValue *kai_", pname, " = _body_result; ",
          prologue,
          emit_expr(src, rexpr, lcs, fns, variants, lams, cls), ";"
        ])
      }
    }
    None -> "_body_result;"
  }
  # m7a #6e: handle owns a jmp_buf and a discard-value slot. If a
  # clause discards `resume`, the op-call site pops the evidence
  # and longjmps here; the setjmp-else branch picks the discarded
  # value as `_body_result` and the return clause runs as usual.
  # Push uses the *_with_jmp variant so the op site can find the
  # jmp via the looked-up KaiEvidence node.
  # issue #501: `_discard` is volatile-qualified because it is a local
  # automatic written between `setjmp` and `longjmp` (the op-call
  # discard branch stores the clause's return value into
  # `*_node->discard_slot`, which aliases `&_discard`). Per C99
  # §7.13.2.1 such a local has indeterminate value after `longjmp`
  # unless it has volatile-qualified type — under `-O2` the else
  # branch otherwise reads a stale NULL and the consumer segfaults.
  concat_all([
    "({ Ev", eff_name, " _ev = {0}; ",
    "_ev.handler_id = kai_fresh_handler_id(); ",
    assigns,
    init_c,
    env_alloc,
    env_assign,
    "KaiEvidence _node; ",
    "jmp_buf _jmp; ",
    "KaiValue * volatile _discard = NULL; ",
    "KaiValue *_body_result; ",
    alias_id_c,
    "if (setjmp(_jmp) == 0) { ",
      "kai_evidence_push_with_jmp(&_node, \"", eff_name, "\", &_ev, &_jmp, (KaiValue **) &_discard); ",
      "_body_result = ", body_c, "; ",
      "kai_evidence_pop(); ",
    "} else { ",
      "_body_result = _discard; ",
    "} ",
    ret_c,
    " })"
  ])
}

# R9: keep only the names that are actually in scope at the install
# site. `handle_captures_at` returns the union of every clause's
# `fv_expr` result; `lcs` is the list of locals visible to
# `emit_handle`. The install code reads each capture as a local
# `kai_<name>` to populate the env struct, so a name not in `lcs`
# would expand to an undeclared identifier.
fn list_filter_in(names: [String], lcs: [String]) : [String] {
  match names {
    [] -> []
    [h, ...rest] ->
      if list_has(lcs, h) { [h, ...list_filter_in(rest, lcs)] }
      else { list_filter_in(rest, lcs) }
  }
}

# R9 install side: allocate one env struct per handle (zero-init,
# stack-allocated inside the handle's stmt-expression), populate one
# field per capture, and stash a `void *` pointer in `_ev.env`. Empty
# when the handle has no captures — the EvE's `env` slot stays NULL
# and clause prologues never read it. The emitted env-struct typedef
# is minted once per (line, col) pair by `emit_handle_env_typedefs`
# at top level, and lives ahead of every clause forward in the
# generated C.
fn emit_handle_env_alloc(caps: [String], enc_fn: String,
                          hline: Int, hcol: Int) : String {
  match caps {
    [] -> ""
    _ -> {
      let env_name = handle_env_struct_name(enc_fn, hline, hcol)
      concat_all([
        env_name, " _env = {0}; ",
        emit_handle_env_field_assigns(caps)
      ])
    }
  }
}

fn emit_handle_env_field_assigns(caps: [String]) : String {
  match caps {
    [] -> ""
    [c, ...rest] -> concat_all([
      "_env.kai_", c, " = kai_", c, "; ",
      emit_handle_env_field_assigns(rest)
    ])
  }
}

fn emit_handle_env_ev_assign(caps: [String]) : String {
  match caps {
    [] -> ""
    _  -> "_ev.env = (void *) &_env; "
  }
}

# m4c #4: install code mints `_ev.<op> = &<clause_sym>;` where
# `<clause_sym>` must match the C function emitted for the clause
# body. Both ends now mint via `clause_fn_name(enc_fn, ...)`. The
# enc_fn lives in the matching `ClauseInfo` (stamped at collect time
# — see `lc_record_clauses`); we look it up by (hline, hcol, op_name).
# The lookup returns "" when the matching CI is missing, which is a
# defensive fallback — collect always records one CI per HClause.
fn emit_clause_assignments(eff_name: String, cs: [HClause],
                           hline: Int, hcol: Int,
                           cls: [ClauseInfo]) : String {
  match cs {
    [] -> ""
    [c, ...rest] -> match c {
      HC(op_name, _, _, _, _) -> {
        let enc_fn = lookup_clause_enc_fn(cls, hline, hcol, op_name)
        concat_all([
          "_ev.", op_name, " = &", clause_fn_name(enc_fn, hline, hcol, op_name), "; ",
          emit_clause_assignments(eff_name, rest, hline, hcol, cls)
        ])
      }
    }
  }
}

# m4c #4: locate the enclosing fn name stamped on a clause at collect
# time. Keyed on the install triple (line, col, op_name). Defensive
# fallback to "" when nothing matches — collect should always record
# a CI per HClause, but if a clause sneaks through pre-collect rewrites
# the fallback emits the unprefixed legacy name (which is what the
# corresponding clause-body would also emit, so the link still works).
fn lookup_clause_enc_fn(cs: [ClauseInfo], hline: Int, hcol: Int, op_name: String) : String {
  match cs {
    [] -> ""
    [c, ...rest] -> match c {
      CI(line, col, _, op, _, _, _, enc_fn, _) ->
        if line == hline and col == hcol and op == op_name { enc_fn }
        else { lookup_clause_enc_fn(rest, hline, hcol, op_name) }
    }
  }
}

# Issue #403: cheap structural test for `ECall(EVar("__perceus_drop"), _)`.
# `__perceus_drop` lowers to `kai_internal_drop`, which decrefs and returns
# the unit singleton — the SExprStmt fast path skips the redundant trailing
# `kai_decref` when this fires.
fn expr_is_perceus_drop_call(x: Expr) : Bool {
  match x.kind {
    ECall(callee, _) -> match callee.kind {
      EVar(nm) -> nm == "__perceus_drop"
      _ -> false
    }
    _ -> false
  }
}

fn emit_stmt(src: String, s: Stmt, lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : String / Console {

  match s {
    SLet(pat, _, rhs) -> emit_let_stmt(src, pat, rhs, lcs, fns, variants, lams, cls)
    SAssert(cond, opt_msg) -> emit_assert_stmt(src, cond, opt_msg, lcs, fns, variants, lams, cls)
    # Issue #403: when the SExprStmt is `__perceus_drop(name)`,
    # `kai_internal_drop` already decrements the value's rc and
    # returns the unit singleton (rc == INT32_MAX). The general
    # path's trailing `kai_decref(_)` short-circuits on that
    # singleton, but the call + branch still cost on every
    # invocation — and the issue-#350 arm-drop pass emits ~18 M
    # of these on the RB-tree workload. Mirrors the `(void) _;`
    # pattern the tcrec rule-3 emission already uses.
    SExprStmt(x) ->
      if expr_is_perceus_drop_call(x) {
        cat3("{ KaiValue *_ = ", emit_expr(src, x, lcs, fns, variants, lams, cls), "; (void) _; } ")
      } else {
        cat3("{ KaiValue *_ = ", emit_expr(src, x, lcs, fns, variants, lams, cls), "; kai_decref(_); } ")
      }
    # m7b #6: index-assign desugars away pre-resolve; this arm is dead
    # code in normal compilation but keeps the match exhaustive.
    SIndexAssign(_, _, _, _, _) -> "/* SIndexAssign: should have been desugared */ "
    # m7b #5: `var name = init` desugars away pre-resolve; this arm
    # is dead code in normal compilation but keeps the match exhaustive.
    SVar(_, _, _, _, _) -> "/* SVar: should have been desugared */ "
    # m7e §25: `use Effect` stmt desugars away pre-resolve. Dead code
    # in normal compilation; emit a comment for debug visibility.
    SUse(_, _, _) -> "/* SUse: should have been desugared */ "
  }
}

# m14 v1.x — fold over a block's stmts threading the local-name
# scope. After each `SLet(pat, _, _)`, the pattern's binders are
# appended to `lcs` so subsequent stmts (and the trailing final
# expression) see them as locals. Other stmt forms (`SAssert`,
# `SExprStmt`, dead `SVar` / `SUse` / `SIndexAssign`) are scope-
# neutral. The accumulated `lcs` is returned alongside the
# concatenated C output so the caller can pass it to the final
# expression.
type EmitBlockStmtsAcc = EBSA([String], String)

fn emit_block_stmts(src: String, stmts: [Stmt], drops: [String],
                    lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : EmitBlockStmtsAcc / Console =
  emit_block_stmts_loop(src, stmts, drops, lcs, fns, variants, lams, cls, "")

fn emit_block_stmts_loop(src: String, stmts: [Stmt], drops: [String],
                          lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo],
                          acc: String) : EmitBlockStmtsAcc / Console = match stmts {

  [] -> EBSA(lcs, acc)
  [s, ...rest] -> {
    let out = emit_stmt_with_drops(src, s, drops, lcs, fns, variants, lams, cls)
    let lcs1 = match s {
      SLet(pat, _, _) -> list_append(lcs, pat_binders(pat, []))
      _ -> lcs
    }
    emit_block_stmts_loop(src, rest, drops, lcs1, fns, variants, lams, cls,
                          string_concat(acc, out))
  }
}

# m5 #3 — emit_stmt variant that consults the per-block drop set.
# Only `SLet` is augmented; the other stmt forms route through the
# original `emit_stmt` path. The set is the result of
# `block_unused_lets`, so a name only appears here when it is safe
# to decref immediately after the let.
fn emit_stmt_with_drops(src: String, s: Stmt, drops: [String],
                        lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : String / Console {

  match s {
    SLet(pat, _, rhs) ->
      emit_let_stmt_with_drops(src, pat, rhs, drops, lcs, fns, variants, lams, cls)
    _ -> emit_stmt(src, s, lcs, fns, variants, lams, cls)
  }
}

fn emit_let_stmt_with_drops(src: String, pat: Pattern, rhs: Expr,
                             drops: [String],
                             lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : String / Console {

  match pat.pkind {
    # Tier 2.5 — raw scalar binding. The unbox pass marked the
    # rhs `MUnboxed`, which means this binding is stored as a raw
    # C scalar (no `KaiValue *`). RC bookkeeping does not apply
    # — the local lives on the C stack and dies at block exit.
    PBind(name) -> match rhs.mode {
      MUnboxed -> {
        let raw = emit_expr_raw(src, rhs, lcs, fns, variants, lams, cls)
        let cty = raw_c_type(rhs.ty)
        concat_all([cty, " kair_", name, " = ", raw, "; "])
      }
      _ -> {
        let rhs_c = emit_expr(src, rhs, lcs, fns, variants, lams, cls)
        let bind = concat_all(["KaiValue *kai_", name, " = ", rhs_c, "; "])
        if list_has(drops, name) {
          cat2(bind, concat_all(["kai_decref(kai_", name, "); "]))
        } else {
          bind
        }
      }
    }
    # `let _ = expr` discards the value. #293 Phase 2.1: emit_expr
    # always returns an owned reference (perceus_pass dups non-last
    # reads), so the discard site can unconditionally decref.
    PWild -> {
      let rhs_c = emit_expr(src, rhs, lcs, fns, variants, lams, cls)
      cat3("{ KaiValue *_w = ", rhs_c, "; kai_decref(_w); } ")
    }
    _ -> {
      # m7d §28: same shape as emit_let_stmt's destructuring path —
      # bind a unique temp and emit pattern binds INTO the enclosing
      # block so the destructured names stay in scope for the rest
      # of the block. Drops do not apply to destructured names; the
      # `drops` argument here is for PBind only.
      # #293 Phase 1.3: same RC discipline as the no-drops path —
      # alias=true so each binder increfs, then drop the composite.
      let rhs_c = emit_expr(src, rhs, lcs, fns, variants, lams, cls)
      let tmp = concat_all(["_letv_", int_to_string(pat.line), "_",
                              int_to_string(pat.col)])
      let binds = emit_pat_binds(src, pat, tmp, true, lcs, fns, variants, lams, cls)
      concat_all(["KaiValue *", tmp, " = ", rhs_c, "; ", binds, "kai_decref(", tmp, "); "])
    }
  }
}

# A let-binding is "droppable" when:
#   1. The pattern is a single `PBind(name)` (no destructuring).
#   2. The RHS is a fresh allocation (rc=1, no aliasing — see
#      `is_fresh_alloc` for the conservative subset).
#   3. The bound name is never read in the rest of the block: later
#      stmts AND the trailing optional final expression.
# Returns the list of droppable names in the block. The walker
# from m5 #2 (`scan_uses_in_stmts` / `scan_uses_expr`) is reused
# unchanged.
fn block_unused_lets(stmts: [Stmt], opt_final: Option[Expr]) : [String] / Console =

  block_unused_lets_loop(stmts, opt_final, [])

fn block_unused_lets_loop(stmts: [Stmt], opt_final: Option[Expr],
                          acc: [String]) : [String] / Console {

  match stmts {
    [] -> list_reverse(acc)
    [s, ...rest] -> {
      let acc1 = match s {
        SLet(pat, _, rhs) -> match pat.pkind {
          PBind(nm) -> {
            if is_fresh_alloc(rhs) and not name_read_in_block(rest, opt_final, nm) {
              [nm, ...acc]
            } else { acc }
          }
          _ -> acc
        }
        _ -> acc
      }
      block_unused_lets_loop(rest, opt_final, acc1)
    }
  }
}

fn name_read_in_block(stmts: [Stmt], opt_final: Option[Expr], nm: String) : Bool / Console {

  let stmt_uses = scan_uses_in_stmts(stmts, false)
  let final_uses = match opt_final {
    None -> []
    Some(e) -> scan_uses_expr(e, false)
  }
  any_use_of(list_append(stmt_uses, final_uses), nm)
}

fn any_use_of(uses: [Use], nm: String) : Bool {
  match uses {
    [] -> false
    [h, ...rest] -> match h {
      U(uname, _, _, _) ->
        if uname == nm { true } else { any_use_of(rest, nm) }
    }
  }
}

# Conservative "fresh allocation" predicate. Returns true when the
# RHS is known to materialise a value with rc=1 and no aliasing.
# False for `EVar` (alias of an existing binding), `EField` /
# `EIndex` (extracted ref into a parent), and the composite control
# forms (`EIf`, `EMatch`, `EBlock`, `EHandle`, `EPipe`) whose result
# can be a sub-expression aliased into the surrounding scope.
fn is_fresh_alloc(e: Expr) : Bool {
  match e.kind {
    EInt(_)         -> true
    EReal(_)        -> true
    EBool(_)        -> true
    EChar(_)        -> true
    EStr(_, _)      -> true
    EUnit           -> true
    ECall(_, _)     -> true
    EList(_)        -> true
    ERecordLit(_, _) -> true
    ERange(_, _, _) -> true
    ELambda(_, _)   -> true
    EBinop(_, _, _) -> true
    EUnop(_, _)     -> true
    _               -> false
  }
}

fn emit_let_stmt(src: String, pat: Pattern, rhs: Expr, lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : String / Console {

  match pat.pkind {
    PBind(name) -> match rhs.mode {
      MUnboxed -> {
        let raw = emit_expr_raw(src, rhs, lcs, fns, variants, lams, cls)
        let cty = raw_c_type(rhs.ty)
        concat_all([cty, " kair_", name, " = ", raw, "; "])
      }
      _ -> {
        let rhs_c = emit_expr(src, rhs, lcs, fns, variants, lams, cls)
        concat_all(["KaiValue *kai_", name, " = ", rhs_c, "; "])
      }
    }
    PWild -> {
      let rhs_c = emit_expr(src, rhs, lcs, fns, variants, lams, cls)
      cat3("{ KaiValue *_w = ", rhs_c, "; kai_decref(_w); } ")
    }
    _ -> {
      # m7d §28: destructuring let. Bind a unique temp and emit the
      # pattern's binds INTO THE ENCLOSING BLOCK (no `{...}`
      # wrapping) so the destructured names stay in scope for the
      # rest of the block. The temp name carries the source location
      # to avoid shadowing across nested let-destructurings.
      let rhs_c = emit_expr(src, rhs, lcs, fns, variants, lams, cls)
      let tmp = concat_all(["_letv_", int_to_string(pat.line), "_",
                              int_to_string(pat.col)])
      # #293 Phase 1.3 — destructuring let RC discipline. Treat children
      # as alias storage (is_alias=true) so each PBind increfs, then
      # drop `tmp` so the composite alloc balances. Field-typed children
      # already incref via `kai_op_field`; the alias flip only changes
      # cons.head/tail and var.args[i] sites which previously aliased
      # without bumping the rc. The `kai_decref(tmp)` at the end of the
      # binds releases the ownership transferred from the RHS.
      let binds = emit_pat_binds(src, pat, tmp, true, lcs, fns, variants, lams, cls)
      concat_all(["KaiValue *", tmp, " = ", rhs_c, "; ", binds, "kai_decref(", tmp, "); "])
    }
  }
}

fn emit_assert_stmt(src: String, cond: Expr, opt_msg: Option[Expr],
                    lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : String / Console {

  # kai_assert_check consults kai_test_in_progress at runtime and either
  # aborts (outside a test) or longjmps to the test harness (inside one),
  # so the emitter doesn't need to know whether it's in test mode.
  # m12.6.x #8: when opt_msg is a literal string (e.g. the contract-
  # desugar's "requires violated at line N"), embed its span as a C
  # literal so the panic shows the contract context instead of the
  # generic "assertion failed". Non-literal msgs fall back to the
  # generic — runtime evaluation of an arbitrary Expr to a C string
  # would need a kai_to_cstring helper that doesn't exist.
  let cc = emit_expr(src, cond, lcs, fns, variants, lams, cls)
  let msg_lit = match opt_msg {
    Some(m) -> match m.kind {
      EStr(span, false) -> span
      _ -> "\"assertion failed\""
    }
    None -> "\"assertion failed\""
  }
  concat_all(["kai_assert_check(", cc, ", ", msg_lit, "); "])
}

# ---- declaration emission ----

# m7a #6a: emit the `Ev<Eff>` struct per `effect Eff { ops }` decl,
# per docs/effects-impl.md §*Surface-to-runtime mapping*. Each op
# becomes a plain function-pointer field with `*Self` as the implicit
# first argument, the surface op args next, and a trailing `KaiCont
# *k` (the reified continuation). m7a #6a only emits the type; m7a
# #6b populates an EvE at handle entry, m7a #6c calls through it.
fn emit_op_fn_ptr_args(params: [Param]) : String {
  match params {
    [] -> ""
    _  -> cat2(", ", join_with(map(params, (pm) => cat2("KaiValue *kai_", pm.pname)), ", "))
  }
}

fn emit_op_fn_ptr(eff_name: String, op: EffectOp) : String {
  match op {
    EOp(op_name, _, params, _, _, _) ->
      concat_all([
        "    KaiValue *(*", op_name, ")(Ev", eff_name, " *self",
        emit_op_fn_ptr_args(params),
        ", KaiCont *k);\n"
      ])
  }
}

fn emit_effect_struct(d: Decl) : String {
  match d {
    DEffect(_, name, _tparams, ops, _, _) -> {
      let fields = concat_all(map(ops, (op) => emit_op_fn_ptr(name, op)))
      concat_all([
        "typedef struct Ev", name, " Ev", name, ";\n",
        "struct Ev", name, " {\n",
        "    KaiHandlerId handler_id;\n",
        "    void *env;\n",
        # m7b #11: every Ev struct carries a `state` slot for parameter-
        # ised handlers (`with State[T](init)` / `with Writer[W]([])`).
        # Stateless handlers leave it NULL — cost is one pointer per
        # handler instance; benefit is a uniform clause-body shape.
        "    KaiValue *state;\n",
        fields,
        "};\n\n"
      ])
    }
    _ -> ""
  }
}

fn effect_struct_decls(decls: [Decl]) : String =
  concat_all(map(decls, emit_effect_struct))

# m7c-a — LLVM equivalent of `emit_effect_struct`. Emits an
# `%EvX = type { i64, i8*, %KaiValue*, fn-ptrs... }` where the
# leading three fields mirror the C layout (handler_id, env,
# state slot) and each op contributes one function pointer.
# Doc C §m7c assumes the LLVM backend uses the same on-the-heap
# layout as the C backend so the runtime helpers can see both
# without translation.
fn llvm_emit_effect_struct(d: Decl) : String {
  match d {
    DEffect(_, name, _tparams, ops, _, _) -> {
      let fields = llvm_emit_op_fn_ptrs(name, ops)
      concat_all([
        "%Ev", name, " = type { i64, i8*, %KaiValue*",
        fields,
        " }\n"
      ])
    }
    _ -> ""
  }
}

fn llvm_emit_op_fn_ptrs(eff_name: String, ops: [EffectOp]) : String {
  match ops {
    [] -> ""
    [op, ...rest] -> match op {
      EOp(_, _, params, _, _, _) -> concat_all([
        ", %KaiValue* (%Ev", eff_name, "*",
        llvm_op_param_args(params),
        ", %KaiCont*)*",
        llvm_emit_op_fn_ptrs(eff_name, rest)
      ])
    }
  }
}

fn llvm_op_param_args(params: [Param]) : String {
  match params {
    [] -> ""
    [_, ...rest] -> concat_all([", %KaiValue*", llvm_op_param_args(rest)])
  }
}

fn llvm_effect_struct_decls(decls: [Decl]) : String =
  concat_all(map(decls, llvm_emit_effect_struct))

fn emit_param_list(params: [Param]) : String {
  match params {
    [] -> "void"
    _ -> join_with(map(params, (pm) => cat2("KaiValue *kai_", pm.pname)), ", ")
  }
}

# Phase 3 unboxing — emit the raw parameter list for a UFn.
# Each parameter is a raw C scalar named `kair_<pname>`; the
# emitter's MUnboxed EVar reads of `pname` resolve via
# `emit_ident_value` to that name.
fn emit_param_list_unboxed(params: [Param], param_tys: [Ty]) : String {
  match params {
    [] -> "void"
    _ -> join_with(emit_param_list_unboxed_each(params, param_tys, []), ", ")
  }
}

fn emit_param_list_unboxed_each(params: [Param], tys: [Ty], acc: [String]) : [String] {
  match params {
    [] -> list_reverse(acc)
    [p, ...rest] -> {
      let pty = match tys {
        [t, ...trest] -> t
        []            -> param_ty(p)
      }
      let trest = match tys {
        [_, ...r] -> r
        []        -> []
      }
      let entry = concat_all([raw_c_type(Some(pty)), " kair_", p.pname])
      emit_param_list_unboxed_each(rest, trest, [entry, ...acc])
    }
  }
}

fn emit_fn_signature(name: String, params: [Param]) : String =
  cat5("static KaiValue *kai_", name, "(", emit_param_list(params), ")")

# Phase 3 unboxing — raw signature for a UFn. Return type is the
# raw C scalar matching `ret_ty`; param list mints `kair_<name>`
# locals typed to each `param_ty`.
fn emit_fn_signature_unboxed(name: String, params: [Param], sig: UFnSig) : String =
  match sig {
    US(pts, rt) -> concat_all([
      "static ", raw_c_type(Some(rt)),
      " kai_", name, "(", emit_param_list_unboxed(params, pts), ")"
    ])
  }

# Decide whether a DFn declared `name`/`mo` was classified as a
# UFn in the EFn registry. Returns the UFnSig payload so callers
# can dispatch on raw vs boxed signature in one match. Iterates
# all matching entries (two modules can export the same bare name
# under v2 — e.g. `box_a.wrap` and `box_b.wrap`) and picks the one
# whose module-of-origin matches `mo` exactly.
fn lookup_ufn_sig(fns: [EFn], name: String, mo: Option[String]) : Option[UFnSig] {
  match fns {
    [] -> None
    [h, ...rest] -> match h {
      EFn(n, _, m2, sig) ->
        if n == name and mo_eq(mo, m2) { sig }
        else { lookup_ufn_sig(rest, name, mo) }
    }
  }
}

fn is_ufn_decl(fns: [EFn], name: String, mo: Option[String]) : Bool {
  match lookup_ufn_sig(fns, name, mo) {
    Some(_) -> true
    None    -> false
  }
}

# Phase 3 unboxing — find a UFn entry by its emitted C symbol
# (e.g. `numeric__real_pow_int_loop`). Iterates the EFn registry
# and compares `c_sym(name, mo)` against the target string.
fn lookup_ufn_by_csym(fns: [EFn], csym: String) : Option[UFnSig] {
  match fns {
    [] -> None
    [h, ...rest] -> match h {
      EFn(n, _, mo, Some(us)) ->
        if c_sym(n, mo) == csym { Some(us) }
        else { lookup_ufn_by_csym(rest, csym) }
      _ -> lookup_ufn_by_csym(rest, csym)
    }
  }
}

fn mo_eq(a: Option[String], b: Option[String]) : Bool {
  match a {
    None -> match b { None -> true _ -> false }
    Some(x) -> match b {
      Some(y) -> x == y
      None    -> false
    }
  }
}

fn emit_fn_forward(d: Decl, fns: [EFn]) : String {
  match d {
    DFn(_, name, _, params, _, _, _, _, _, mo) -> {
      let sig = match lookup_ufn_sig(fns, name, mo) {
        Some(us) -> emit_fn_signature_unboxed(c_sym(name, mo), params, us)
        None     -> emit_fn_signature(c_sym(name, mo), params)
      }
      cat2(sig, ";\n")
    }
    _ -> ""
  }
}

fn emit_thunk_forward(d: Decl) : String {
  match d {
    DFn(_, name, _, _, _, _, _, _, _, mo) ->
      cat3("static KaiValue *_kai_", c_sym(name, mo), "_thunk(KaiValue *, KaiValue **, int);\n")
    _ -> ""
  }
}

fn emit_fn_body(src: String, d: Decl, lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : String / Console {

  match d {
    DFn(_, name, _, params, ret_ty_opt, _, body, _, _, mo) -> {
      let opt_sig = lookup_ufn_sig(fns, name, mo)
      let sig = match opt_sig {
        Some(us) -> emit_fn_signature_unboxed(c_sym(name, mo), params, us)
        None     -> emit_fn_signature(c_sym(name, mo), params)
      }
      # m12.7.x FFI v1: a `[<extern_c>]` axiom lowered into a DFn
      # whose body is the magic ETodo tag. Emit the FFI shim instead
      # of the standard body — the shim unboxes each parameter to
      # the matching C scalar, calls the extern symbol, and re-boxes
      # the return value. The shim does its own `extern` forward decl
      # inline so callers don't need a separate header pass.
      if body_is_ffi_extern(body) {
        # Issue #261: the C-side symbol is either the override
        # baked into the body's tag or the kaikai identifier.
        emit_ffi_shim_body(sig, ffi_extern_symbol_of(body, name), params, ret_ty_opt)
      } else {
        # Seed the local-name scope with the fn's parameters so an
        # `EVar(pname)` reference inside the body emits the local C
        # variable read (`kai_<pname>`) rather than a closure-thunk
        # over a same-named top-level fn.
        let body_lcs = list_append(lcs, fn_param_names(params))
        # Same-module preference: when this DFn lives in a module,
        # rotate the EFn table so entries from that same module come
        # first. `efn_resolve`'s ambiguous-fallback returns the first
        # match, so a recursive call inside `loop.repeat` resolves
        # to `loop.repeat` even when `list.repeat` is also in scope.
        let body_fns = fns_prefer_module(fns, mo)
        # Phase 3 unboxing — UFn body emits a raw return expression
        # whose value is the raw scalar matching `ret_ty`. The
        # body's `mode` is set by `unbox_pass`/`ufn_promote_calls`;
        # `emit_expr_raw` handles the MBoxed→raw boundary if the
        # body somehow stayed boxed (defensive for partial
        # promotions). The TCO sentinel goto path stays compatible:
        # `tcrec_emit_goto` writes `goto _kai_<sym>_entry;` which
        # ignores the surrounding return-expression shape.
        match opt_sig {
          Some(_) -> {
            let body_c = emit_expr_raw(src, body, body_lcs, body_fns, variants, lams, cls)
            let label = if tcrec_body_has_sentinel(body) {
              concat_all(["_kai_", c_sym(name, mo), "_entry:;\n    "])
            } else { "" }
            concat_all([sig, " {\n    ", label, "return ", body_c, ";\n}\n\n"])
          }
          None -> {
            let body_c = emit_expr(src, body, body_lcs, body_fns, variants, lams, cls)
            # Issue #37: when `tcrec_rewrite_decl` planted at least one
            # `__kai_tcrec|...` self-tail-call sentinel inside `body`,
            # plant the matching `_kai_<c_sym>_entry:;` label *before*
            # the `return ({ ... });` so the goto inside the
            # statement-expression has a target.
            let label = if tcrec_body_has_sentinel(body) {
              concat_all(["_kai_", c_sym(name, mo), "_entry:;\n    "])
            } else { "" }
            concat_all([sig, " {\n    ", label, "return ", body_c, ";\n}\n\n"])
          }
        }
      }
    }
    _ -> ""
  }
}

# m12.7.x FFI v1: the C body of an `[<extern_c>]` axiom. The shim
# - forward-declares the extern symbol with the matching C signature,
# - unboxes each kaikai parameter into its C-side equivalent,
# - calls the extern, releases the input args, and
# - boxes the return value back into a `KaiValue *` (or `kai_unit()`
#   for a `void`-returning extern).
#
# Type translation v1 (per `docs/m12.7-ffi.md` §*Type table*):
#   Int    ↔ int64_t        Real   ↔ double
#   Bool   ↔ int             String ↔ const char *
#   Unit   ↔ void   (return only)
# Anything else surfaces as an `#error` so the C compiler flags it
# at build time — silently emitting a wrong shim would be worse than
# refusing the cast.
fn emit_ffi_shim_body(sig: String, name: String, params: [Param],
                      ret_ty_opt: Option[TypeExpr]) : String {
  let ret_kind = ffi_ret_kind_of(ret_ty_opt)
  # FFI v1 deliberately does NOT mint a fresh `extern` declaration
  # for the named symbol. The user is expected to either rely on a
  # libc symbol already declared by `<stdio.h>` / `<stdlib.h>` /
  # `<string.h>` / `<unistd.h>` / `<time.h>` (all pulled in by
  # `runtime.h`), or to feed an `#include` for their FFI library
  # via the user-supplied wrapper.c that the build links in. A
  # local extern declaration here would conflict with libc's
  # canonical signature whenever the kaikai-side type mapping does
  # not match the C-side native (e.g. kaikai `Int` → `int64_t` vs
  # libc `puts`'s `int` return).
  let arg_setup = ffi_emit_arg_setup(params, 0)
  let arg_list = ffi_emit_arg_list(params, 0)
  let call_expr = concat_all([name, "(", arg_list, ")"])
  let arg_decrefs = ffi_emit_arg_decrefs(params, 0)
  let body = match ret_kind {
    FfiRetUnit -> concat_all([
      arg_setup,
      "    ", call_expr, ";\n",
      arg_decrefs,
      "    return kai_unit();\n"
    ])
    FfiRetInt -> concat_all([
      arg_setup,
      "    int64_t _kai_ffi_ret = (int64_t) ", call_expr, ";\n",
      arg_decrefs,
      "    return kai_int(_kai_ffi_ret);\n"
    ])
    FfiRetReal -> concat_all([
      arg_setup,
      "    double _kai_ffi_ret = (double) ", call_expr, ";\n",
      arg_decrefs,
      "    return kai_real(_kai_ffi_ret);\n"
    ])
    FfiRetBool -> concat_all([
      arg_setup,
      "    int _kai_ffi_ret = (int) ", call_expr, ";\n",
      arg_decrefs,
      "    return kai_bool(_kai_ffi_ret != 0);\n"
    ])
    FfiRetString -> concat_all([
      arg_setup,
      "    const char *_kai_ffi_ret = ", call_expr, ";\n",
      arg_decrefs,
      "    return kai_str(_kai_ffi_ret == NULL ? \"\" : _kai_ffi_ret);\n"
    ])
    FfiRetUnknown(t) -> concat_all([
      "#error \"FFI return type `", t,
      "` is not supported in m12.7.x — use Int / Real / Bool / String / Unit\"\n"
    ])
  }
  concat_all([sig, " {\n", body, "}\n\n"])
}

# m12.7.x FFI v1: enumeration of the supported return kinds plus an
# escape hatch (`FfiRetUnknown`) carrying the offending type name so
# the emitted `#error` can name it back to the user.
type FfiRetKind
  = FfiRetUnit
  | FfiRetInt
  | FfiRetReal
  | FfiRetBool
  | FfiRetString
  | FfiRetUnknown(String)

fn ffi_ret_kind_of(opt: Option[TypeExpr]) : FfiRetKind {
  match opt {
    None -> FfiRetUnit
    Some(t) -> ffi_kind_of_ty(t)
  }
}

fn ffi_kind_of_ty(t: TypeExpr) : FfiRetKind {
  match t.tkind {
    TyName(n, _) ->
      if n == "Int" { FfiRetInt }
      else if n == "Real" { FfiRetReal }
      else if n == "Bool" { FfiRetBool }
      else if n == "String" { FfiRetString }
      else if n == "Unit" { FfiRetUnit }
      else { FfiRetUnknown(n) }
    _ -> FfiRetUnknown("non-named type")
  }
}

fn ffi_c_ret_type_str(k: FfiRetKind) : String {
  match k {
    FfiRetUnit -> "void"
    FfiRetInt -> "int64_t"
    FfiRetReal -> "double"
    FfiRetBool -> "int"
    FfiRetString -> "const char *"
    FfiRetUnknown(_) -> "void"  # body is `#error`, never compiled
  }
}

fn ffi_c_param_type_str(p: Param) : String {
  match p.ptype {
    None -> "/* missing type */ void *"
    Some(t) -> match ffi_kind_of_ty(t) {
      FfiRetInt -> "int64_t"
      FfiRetReal -> "double"
      FfiRetBool -> "int"
      FfiRetString -> "const char *"
      FfiRetUnit -> "/* Unit param not supported */ void *"
      FfiRetUnknown(_) -> "/* unsupported FFI param */ void *"
    }
  }
}

fn ffi_c_param_list(params: [Param]) : String {
  match params {
    [] -> "void"
    _ -> join_with(map(params, ffi_c_param_type_str), ", ")
  }
}

# Emit a sequence of local C bindings that unbox each kaikai
# parameter into the matching C scalar. The shim stores the inputs
# in `_kai_ffi_argN` so they survive across the extern call long
# enough for the caller to release the boxed inputs after the call.
fn ffi_emit_arg_setup(params: [Param], i: Int) : String {
  match params {
    [] -> ""
    [p, ...rest] -> {
      let kind = match p.ptype {
        None -> FfiRetUnknown("missing")
        Some(t) -> ffi_kind_of_ty(t)
      }
      let arg_name = concat_all(["_kai_ffi_arg", int_to_string(i)])
      let stmt = match kind {
        FfiRetInt -> concat_all([
          "    int64_t ", arg_name, " = kai_", p.pname, "->as.i;\n"
        ])
        FfiRetReal -> concat_all([
          "    double ", arg_name, " = kai_", p.pname, "->as.r;\n"
        ])
        FfiRetBool -> concat_all([
          "    int ", arg_name, " = kai_", p.pname, "->as.b ? 1 : 0;\n"
        ])
        FfiRetString -> concat_all([
          "    const char *", arg_name, " = kai_", p.pname, "->as.s.bytes;\n"
        ])
        FfiRetUnit -> concat_all([
          "    /* Unit FFI arg #", int_to_string(i), " elided */\n"
        ])
        FfiRetUnknown(t) -> concat_all([
          "#error \"FFI arg type `", t, "` is not supported\"\n"
        ])
      }
      cat2(stmt, ffi_emit_arg_setup(rest, i + 1))
    }
  }
}

fn ffi_emit_arg_list(params: [Param], i: Int) : String {
  match params {
    [] -> ""
    [_, ...rest] -> {
      let head = concat_all(["_kai_ffi_arg", int_to_string(i)])
      match rest {
        [] -> head
        _ -> concat_all([head, ", ", ffi_emit_arg_list(rest, i + 1)])
      }
    }
  }
}

# After the extern returns we must release the boxed kaikai inputs;
# the calling convention hands ownership to the callee.
fn ffi_emit_arg_decrefs(params: [Param], i: Int) : String {
  match params {
    [] -> ""
    [p, ...rest] -> cat2(
      concat_all(["    kai_decref(kai_", p.pname, ");\n"]),
      ffi_emit_arg_decrefs(rest, i + 1)
    )
  }
}

fn emit_param_args(params: [Param]) : String =
  join_with(map(params, (pm) => cat2("kai_", pm.pname)), ", ")

fn emit_param_reads(params: [Param], start: Int) : String {
  match params {
    [] -> ""
    [p, ...rest] ->
      cat2(
        concat_all(["    KaiValue *kai_", p.pname, " = args[", int_to_string(start), "];\n"]),
        emit_param_reads(rest, start + 1))
  }
}

fn emit_fn_thunk(d: Decl, fns: [EFn]) : String {
  match d {
    DFn(_, name, _, params, _, _, _, _, _, mo) -> {
      let sym = c_sym(name, mo)
      let hdr = concat_all([
        "static KaiValue *_kai_", sym,
        "_thunk(KaiValue *self, KaiValue **args, int n) {\n    (void) self; (void) n;\n"
      ])
      # Phase 3 unboxing — when the named fn is a UFn, the thunk
      # marshals each boxed `args[i]` into the matching raw scalar
      # via `->as.X` and wraps the raw return in `kai_<T>` so the
      # closure-call indirection (`kai_apply` / `kai_closure`)
      # still hands back a `KaiValue *`. This is the dispatch
      # bridge between the boxed first-class-fn world and the
      # raw direct-call world.
      match lookup_ufn_sig(fns, name, mo) {
        Some(US(pts, rt)) -> {
          let arg_unbox = emit_thunk_unbox_args(params, pts, 0)
          let arg_list = emit_thunk_raw_arg_list(params, 0)
          let call_raw = concat_all(["kai_", sym, "(", arg_list, ")"])
          let body = concat_all([
            arg_unbox,
            "    return ", box_wrap(Some(rt), call_raw), ";\n}\n\n"
          ])
          concat_all([hdr, body])
        }
        None -> {
          let param_reads = emit_param_reads(params, 0)
          let named_args = emit_param_args(params)
          let call = concat_all(["    return kai_", sym, "(", named_args, ");\n}\n\n"])
          concat_all([hdr, param_reads, call])
        }
      }
    }
    _ -> ""
  }
}

# Phase 3 unboxing — emit per-param `<raw_ty> kair_<name> = args[i]->as.X;`
# bindings inside a UFn thunk. The boxed arg slot is dropped as soon
# as the raw scalar is read; the caller (`kai_apply`) owns its
# argument array's references but the thunk takes ownership of each
# slot as it consumes it (matching the boxed thunk's
# `KaiValue *kai_<n> = args[i]; ...; kai_decref(...)` discipline).
fn emit_thunk_unbox_args(params: [Param], tys: [Ty], i: Int) : String {
  match params {
    [] -> ""
    [p, ...rest] -> {
      let pty = match tys {
        [t, ...trest] -> t
        []            -> param_ty(p)
      }
      let trest = match tys {
        [_, ...r] -> r
        []        -> []
      }
      let ix = int_to_string(i)
      let line = concat_all([
        "    ", raw_c_type(Some(pty)), " kair_", p.pname,
        " = args[", ix, "]", unbox_field_for(Some(pty)), ";\n",
        "    kai_decref(args[", ix, "]);\n"
      ])
      cat2(line, emit_thunk_unbox_args(rest, trest, i + 1))
    }
  }
}

fn emit_thunk_raw_arg_list(params: [Param], i: Int) : String {
  match params {
    [] -> ""
    [p, ...rest] -> {
      let head = concat_all(["kair_", p.pname])
      match rest {
        [] -> head
        _  -> concat_all([head, ", ", emit_thunk_raw_arg_list(rest, i + 1)])
      }
    }
  }
}

# ---- top-level passes ----

fn fn_forward_decls(decls: [Decl], fns: [EFn]) : String =
  concat_all(map(decls, (d) => emit_fn_forward(d, fns)))

fn thunk_forward_decls(decls: [Decl]) : String =
  concat_all(map(decls, emit_thunk_forward))

fn fn_bodies(src: String, decls: [Decl], lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo]) : String / Console =

  concat_all(map(decls, (d) => {
    match d {
      DFn(_, _, _, _, _, _, _, _, _, _) -> cat2(emit_fn_body(src, d, lcs, fns, variants, lams, cls), emit_fn_thunk(d, fns))
      _ -> ""
    }
  }))

# ---- test function emission (always emitted; only called from int main
#      when test_mode is on) ----

fn emit_test_fn(src: String, id: Int, desc_span: String, body: Expr,
                lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo],
                target_origin: Option[String]) : String / Console {

  # desc_span is the raw source of the description including its quotes,
  # so it's already a valid C string literal. We wrap the body in
  # setjmp/longjmp: kai_assert_check inside the body can longjmp us out
  # on failure, and the test still counts as a tried test.
  # Issue #335: rotate the EFn table so the target file's own module
  # entries come first. `efn_resolve`'s ambiguous fallback then
  # resolves a bare name (e.g. `concat([])`) to the same-module entry
  # rather than a sibling prelude's clashing export. Mirrors the rotate
  # `emit_fn_body` already does for DFn bodies.
  let body_fns = fns_prefer_module(fns, target_origin)
  let body_c = emit_expr(src, body, lcs, body_fns, variants, lams, cls)
  concat_all([
    "static void _kai_test_", int_to_string(id), "(void) {\n",
    "    kai_test_begin(", desc_span, ");\n",
    "    if (setjmp(kai_test_jmp) == 0) {\n",
    "        kai_test_in_progress = 1;\n",
    "        KaiValue *_body = ", body_c, ";\n",
    "        kai_decref(_body);\n",
    "        kai_test_in_progress = 0;\n",
    "        kai_test_pass();\n",
    "    } else {\n",
    "        kai_test_in_progress = 0;\n",
    "    }\n",
    "}\n\n"
  ])
}

fn test_decls(decls: [Decl]) : [Decl] =
  filter(decls, (d) => match d { DTest(_, _, _, _) -> true _ -> false })

fn emit_one_test(src: String, lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo],
                 target_origin: Option[String], id_d: DeclWithId) : String / Console {

  match id_d {
    DWI(id, d) -> match d {
      DTest(desc_span, body, _, _) -> emit_test_fn(src, id, desc_span, body, lcs, fns, variants, lams, cls, target_origin)
      _ -> ""
    }
  }
}

# Helper pair to zip index with decl for clean iteration.
type DeclWithId = DWI(Int, Decl)

fn number_tests_loop(decls: [Decl], id: Int, acc: [DeclWithId]) : [DeclWithId] {
  match decls {
    [] -> list_reverse(acc)
    [d, ...rest] -> match d {
      DTest(_, _, _, _) -> number_tests_loop(rest, id + 1, [DWI(id, d), ...acc])
      _ -> number_tests_loop(rest, id, acc)
    }
  }
}

fn number_tests(decls: [Decl]) : [DeclWithId] =
  number_tests_loop(decls, 0, [])

fn emit_all_tests(src: String, decls: [Decl], lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo],
                  target_origin: Option[String]) : String / Console {

  let numbered = number_tests(decls)
  concat_all(map(numbered, (dwi) => emit_one_test(src, lcs, fns, variants, lams, cls, target_origin, dwi)))
}

fn test_count(decls: [Decl]) : Int = list_length(test_decls(decls))

fn test_call_list(n: Int, i: Int) : String {
  if i >= n { "" }
  else {
    concat_all(["    _kai_test_", int_to_string(i), "();\n", test_call_list(n, i + 1)])
  }
}

# ---- bench function emission (always emitted; only called from int main
#      when bench_mode is on) ----
#
# bench v1.x (issue #437): each bench body runs in two phases —
# KAI_BENCH_WARMUP untimed iterations to reduce JIT/cache effects on
# the timed window, then KAI_BENCH_ITERS timed iterations whose
# per-iteration nanoseconds are recorded into the runtime sample
# buffer. Both knobs are env vars (read once via kai_bench_iters() /
# kai_bench_warmup() in runtime.h) so users can override at runtime
# without recompiling. On exit kai_bench_finalize sorts the samples
# and prints median + MAD + mean + range. Like test, we do NOT install
# a setjmp landing pad — an assertion failure inside a bench should
# panic the process, since timing aborted code is meaningless.

fn emit_bench_fn(src: String, id: Int, desc_span: String, body: Expr,
                 lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo],
                 target_origin: Option[String]) : String / Console {

  # Issue #335: same file-local rotate as emit_test_fn.
  let body_fns = fns_prefer_module(fns, target_origin)
  let body_c = emit_expr(src, body, lcs, body_fns, variants, lams, cls)
  concat_all([
    "static void _kai_bench_", int_to_string(id), "(void) {\n",
    "    int _kai_bench_iters = kai_bench_iters();\n",
    "    int _kai_bench_warmup = kai_bench_warmup();\n",
    "    int _kai_bench_w;\n",
    "    int _kai_bench_i;\n",
    "    long long _kai_bench_a;\n",
    "    long long _kai_bench_b;\n",
    "    kai_bench_ensure_capacity(_kai_bench_iters);\n",
    "    for (_kai_bench_w = 0; _kai_bench_w < _kai_bench_warmup; _kai_bench_w++) {\n",
    "        KaiValue *_body = ", body_c, ";\n",
    "        kai_decref(_body);\n",
    "    }\n",
    "    for (_kai_bench_i = 0; _kai_bench_i < _kai_bench_iters; _kai_bench_i++) {\n",
    "        _kai_bench_a = kai_bench_now_ns();\n",
    "        KaiValue *_body = ", body_c, ";\n",
    "        _kai_bench_b = kai_bench_now_ns();\n",
    "        kai_decref(_body);\n",
    "        kai_bench_record(_kai_bench_i, _kai_bench_b - _kai_bench_a);\n",
    "    }\n",
    "    kai_bench_finalize(", desc_span, ", _kai_bench_iters);\n",
    "}\n\n"
  ])
}

fn bench_decls(decls: [Decl]) : [Decl] =
  filter(decls, (d) => match d { DBench(_, _, _, _) -> true _ -> false })

fn emit_one_bench(src: String, lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo],
                  target_origin: Option[String], id_d: DeclWithId) : String / Console {

  match id_d {
    DWI(id, d) -> match d {
      DBench(desc_span, body, _, _) -> emit_bench_fn(src, id, desc_span, body, lcs, fns, variants, lams, cls, target_origin)
      _ -> ""
    }
  }
}

fn number_benches_loop(decls: [Decl], id: Int, acc: [DeclWithId]) : [DeclWithId] {
  match decls {
    [] -> list_reverse(acc)
    [d, ...rest] -> match d {
      DBench(_, _, _, _) -> number_benches_loop(rest, id + 1, [DWI(id, d), ...acc])
      _ -> number_benches_loop(rest, id, acc)
    }
  }
}

fn number_benches(decls: [Decl]) : [DeclWithId] =
  number_benches_loop(decls, 0, [])

fn emit_all_benches(src: String, decls: [Decl], lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo],
                    target_origin: Option[String]) : String / Console {

  let numbered = number_benches(decls)
  concat_all(map(numbered, (dwi) => emit_one_bench(src, lcs, fns, variants, lams, cls, target_origin, dwi)))
}

fn bench_count(decls: [Decl]) : Int = list_length(bench_decls(decls))

fn bench_call_list(n: Int, i: Int) : String {
  if i >= n { "" }
  else {
    concat_all(["    _kai_bench_", int_to_string(i), "();\n", bench_call_list(n, i + 1)])
  }
}

# ---- check function emission (always emitted; only called from int main
#      when check_mode is on) ----
#
# check v1 (issue #44): mirrors the test/bench pipelines above. Each
# check body is wrapped in a fixed-N (=KAI_CHECK_ITERS, 100) loop.
# Each iteration:
#
#   1. Records the description in the runtime via kai_check_begin
#      (only on iter 0).
#   2. Resets the counterexample buffer.
#   3. Generates a fresh value for every with-clause param via
#      kai_arbitrary_<T>() and records it for the counterexample.
#   4. Evaluates the body. The body must produce a Bool. true keeps
#      the loop running; false records a counterexample at the
#      current iter index and breaks early.
#
# After the loop, kai_check_pass / kai_check_fail prints the
# per-block result.
#
# The C-level local for each param is `kai_<name>` so the body's
# `EVar(name)` resolves to it through emit_ident_value's lcs lookup.
# The lcs argument passed to emit_expr therefore lists every
# with-clause param name.

# Picks the runtime arbitrary-helper name for a parameter type. v1
# supports primitives (Int / Bool / Char / String) and lists of those
# primitives. Anything else collapses to a panic stub so the failure
# is loud rather than silent — protocol-based / structural derivation
# lands in v1.x and v2.
fn check_arbitrary_for_ty(ty: TypeExpr) : String {
  match ty.tkind {
    TyName(name, _args) -> {
      if name == "Int" { "kai_arbitrary_int()" }
      else if name == "Bool" { "kai_arbitrary_bool()" }
      else if name == "Char" { "kai_arbitrary_char()" }
      else if name == "String" { "kai_arbitrary_string()" }
      else { check_arbitrary_panic(name) }
    }
    TyList(inner) -> match inner.tkind {
      TyName(iname, _) -> {
        if iname == "Int" { "kai_arbitrary_list_int()" }
        else if iname == "Bool" { "kai_arbitrary_list_bool()" }
        else if iname == "Char" { "kai_arbitrary_list_char()" }
        else if iname == "String" { "kai_arbitrary_list_string()" }
        else { check_arbitrary_panic(concat_all(["[", iname, "]"])) }
      }
      _ -> check_arbitrary_panic("[<complex>]")
    }
    _ -> check_arbitrary_panic("<complex>")
  }
}

fn check_arbitrary_panic(label: String) : String =
  concat_all([
    "kai_prelude_panic(kai_str(\"check v1: no generator for type ",
    label,
    " — supported types are Int, Bool, Char, String, and lists of those\"))"
  ])

# Picks the runtime shrink-helper names for a parameter type. Returns
# a list of strategy names. Lists have two strategies (drop-head, then
# shrink-head); scalars have one. Empty list means no shrink for this
# type — the runner will skip the param. Issue #438.
fn check_shrink_for_ty(ty: TypeExpr) : [String] {
  match ty.tkind {
    TyName(name, _args) -> {
      if name == "Int" { ["kai_shrink_int"] }
      else if name == "Bool" { ["kai_shrink_bool"] }
      else if name == "Char" { ["kai_shrink_char"] }
      else if name == "String" { ["kai_shrink_string"] }
      else { [] }
    }
    TyList(inner) -> match inner.tkind {
      TyName(iname, _) -> {
        if iname == "Int"    { ["kai_shrink_list_int",    "kai_shrink_list_int_head"] }
        else if iname == "Bool"   { ["kai_shrink_list_bool",   "kai_shrink_list_bool_head"] }
        else if iname == "Char"   { ["kai_shrink_list_char",   "kai_shrink_list_char_head"] }
        else if iname == "String" { ["kai_shrink_list_string", "kai_shrink_list_string_head"] }
        else { [] }
      }
      _ -> []
    }
    _ -> []
  }
}

fn emit_check_param_drops(params: [Param]) : String {
  match params {
    [] -> ""
    [p, ...rest] -> concat_all([
      "        kai_decref(kai_", p.pname, ");\n",
      emit_check_param_drops(rest)
    ])
  }
}

# After a counterexample is detected, the failing param values are
# captured in C locals named kai_<name> and we want to keep them alive
# beyond the per-iter loop's scope. The original loop already drops on
# every successful iter and breaks BEFORE dropping on failure, so the
# captured values still hold rc=1 — we just stop treating them as
# loop-scoped. Issue #438.
#
# Re-evaluating the body for shrinking is done by inlining body_c
# again — this is the cleanest way to keep `EVar(name)` resolving via
# the same lcs/locals path the typer already produced. Cost is one
# extra body emission per param-strategy at compile time and zero at
# steady-state runtime (the inlined re-eval only fires when a check
# actually fails, so passing checks pay nothing).

# Emits one strategy attempt: try kai_shrink_<helper>(kai_<param>); if
# it produces a non-NULL candidate AND the body still fails with that
# candidate swapped in, accept it (decref the previous value, keep the
# candidate as the new param), set _progressed=1, and break out of the
# strategy chain. Otherwise restore and decref the candidate.
fn emit_shrink_attempt(pname: String, helper: String, body_c: String) : String =
  concat_all([
    "        if (!_progressed) {\n",
    "            KaiValue *_cand = ", helper, "(kai_", pname, ");\n",
    "            if (_cand != NULL) {\n",
    "                KaiValue *_save = kai_", pname, ";\n",
    "                kai_", pname, " = _cand;\n",
    "                KaiValue *_body = ", body_c, ";\n",
    "                int _ok = kai_op_truthy(_body);\n",
    "                kai_decref(_body);\n",
    "                if (!_ok) {\n",
    "                    kai_decref(_save);\n",
    "                    _progressed = 1;\n",
    "                } else {\n",
    "                    kai_", pname, " = _save;\n",
    "                    kai_decref(_cand);\n",
    "                }\n",
    "            }\n",
    "        }\n"
  ])

# All strategies for one param, in order.
fn emit_shrink_attempts_for_param(pname: String, helpers: [String], body_c: String) : String {
  match helpers {
    [] -> ""
    [h, ...rest] -> concat_all([
      emit_shrink_attempt(pname, h, body_c),
      emit_shrink_attempts_for_param(pname, rest, body_c)
    ])
  }
}

# All shrink attempts across every param in the with-clause. The
# enclosing round flag (_progressed) short-circuits subsequent attempts
# once any candidate sticks, so we always greedily restart from the
# first param after each accepted shrink — that matches QuickCheck's
# greedy strategy and keeps the iter budget focused on the most-
# productive prefix of params.
fn emit_shrink_attempts(params: [Param], body_c: String) : String {
  match params {
    [] -> ""
    [p, ...rest] -> {
      let helpers = match p.ptype {
        Some(t) -> check_shrink_for_ty(t)
        None -> []
      }
      concat_all([
        emit_shrink_attempts_for_param(p.pname, helpers, body_c),
        emit_shrink_attempts(rest, body_c)
      ])
    }
  }
}

fn check_param_names(params: [Param]) : [String] = match params {
  [] -> []
  [p, ...rest] -> [p.pname, ...check_param_names(rest)]
}

# Re-records every param into the cx buffer (used after shrinking to
# rebuild the buffer with shrunk values).
fn emit_check_param_rerecord(params: [Param]) : String {
  match params {
    [] -> ""
    [p, ...rest] -> concat_all([
      "    kai_check_record_param(\"", p.pname, "\", kai_", p.pname, ");\n",
      emit_check_param_rerecord(rest)
    ])
  }
}

# Drops every param at function-tail scope (no leading indent variant
# of emit_check_param_drops).
fn emit_check_param_drops_tail(params: [Param]) : String {
  match params {
    [] -> ""
    [p, ...rest] -> concat_all([
      "    kai_decref(kai_", p.pname, ");\n",
      emit_check_param_drops_tail(rest)
    ])
  }
}

# Forward declares each param at function scope so the per-iter loop
# assigns into them and the post-loop shrink section can reference
# the surviving values. Initialised to NULL so the no-failure path
# leaves nothing to drop.
fn emit_check_param_decls(params: [Param]) : String {
  match params {
    [] -> ""
    [p, ...rest] -> concat_all([
      "    KaiValue *kai_", p.pname, " = NULL;\n",
      emit_check_param_decls(rest)
    ])
  }
}

# Emits the per-iter param init that ASSIGNS (not declares) into the
# function-scope locals so the post-loop shrink section can see them.
fn emit_check_param_inits_assign(params: [Param]) : String {
  match params {
    [] -> ""
    [p, ...rest] -> {
      let tyc = match p.ptype {
        Some(t) -> check_arbitrary_for_ty(t)
        None -> check_arbitrary_panic("<missing>")
      }
      concat_all([
        "        kai_", p.pname, " = ", tyc, ";\n",
        "        kai_check_record_param(\"", p.pname, "\", kai_", p.pname, ");\n",
        emit_check_param_inits_assign(rest)
      ])
    }
  }
}

fn emit_check_fn(src: String, id: Int, desc_span: String, params: [Param], body: Expr,
                 lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo],
                 target_origin: Option[String]) : String / Console {

  let lcs2 = list_append(check_param_names(params), lcs)
  # Issue #335: same file-local rotate as emit_test_fn.
  let body_fns = fns_prefer_module(fns, target_origin)
  let body_c = emit_expr(src, body, lcs2, body_fns, variants, lams, cls)
  # Issue #438: hoist param locals to function scope so the post-loop
  # shrink section can keep mutating them. The per-iter loop now
  # assigns into them (not redeclares) and only drops on the OK path —
  # on failure the values survive so the shrinker can use them as the
  # starting point.
  let decls = emit_check_param_decls(params)
  let inits = emit_check_param_inits_assign(params)
  let iter_drops = emit_check_param_drops(params)
  let tail_drops = emit_check_param_drops_tail(params)
  let attempts = emit_shrink_attempts(params, body_c)
  let rerecord = emit_check_param_rerecord(params)
  concat_all([
    "static void _kai_check_", int_to_string(id), "(void) {\n",
    "    kai_check_begin(", desc_span, ");\n",
    "    int _kai_check_i;\n",
    "    int _kai_check_failed_at = -1;\n",
    decls,
    "    for (_kai_check_i = 0; _kai_check_i < KAI_CHECK_ITERS; _kai_check_i++) {\n",
    "        kai_check_cx_reset();\n",
    inits,
    "        KaiValue *_body = ", body_c, ";\n",
    "        int _ok = kai_op_truthy(_body);\n",
    "        kai_decref(_body);\n",
    "        if (!_ok) { _kai_check_failed_at = _kai_check_i; break; }\n",
    iter_drops,
    "    }\n",
    "    if (_kai_check_failed_at >= 0) {\n",
    "        kai_check_cx_save_orig();\n",
    "        int _kai_shrink_budget = kai_check_shrink_iters_limit();\n",
    "        int _kai_shrink_i;\n",
    "        for (_kai_shrink_i = 0; _kai_shrink_i < _kai_shrink_budget; _kai_shrink_i++) {\n",
    "            int _progressed = 0;\n",
    attempts,
    "            if (!_progressed) break;\n",
    "        }\n",
    "        kai_check_cx_reset();\n",
    rerecord,
    "        kai_check_fail_shrunk(_kai_check_failed_at);\n",
    tail_drops,
    "    }\n",
    "    else { kai_check_pass(KAI_CHECK_ITERS); }\n",
    "}\n\n"
  ])
}

fn check_decls(decls: [Decl]) : [Decl] =
  filter(decls, (d) => match d { DCheck(_, _, _, _, _) -> true _ -> false })

fn emit_one_check(src: String, lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo],
                  target_origin: Option[String], id_d: DeclWithId) : String / Console {

  match id_d {
    DWI(id, d) -> match d {
      DCheck(desc_span, ps, body, _, _) -> emit_check_fn(src, id, desc_span, ps, body, lcs, fns, variants, lams, cls, target_origin)
      _ -> ""
    }
  }
}

fn number_checks_loop(decls: [Decl], id: Int, acc: [DeclWithId]) : [DeclWithId] {
  match decls {
    [] -> list_reverse(acc)
    [d, ...rest] -> match d {
      DCheck(_, _, _, _, _) -> number_checks_loop(rest, id + 1, [DWI(id, d), ...acc])
      _ -> number_checks_loop(rest, id, acc)
    }
  }
}

fn number_checks(decls: [Decl]) : [DeclWithId] =
  number_checks_loop(decls, 0, [])

fn emit_all_checks(src: String, decls: [Decl], lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo],
                   target_origin: Option[String]) : String / Console {

  let numbered = number_checks(decls)
  concat_all(map(numbered, (dwi) => emit_one_check(src, lcs, fns, variants, lams, cls, target_origin, dwi)))
}

fn check_count(decls: [Decl]) : Int = list_length(check_decls(decls))

fn check_call_list(n: Int, i: Int) : String {
  if i >= n { "" }
  else {
    concat_all(["    _kai_check_", int_to_string(i), "();\n", check_call_list(n, i + 1)])
  }
}

fn has_main_decl(decls: [Decl]) : Bool {
  match decls {
    [] -> false
    [d, ...rest] -> match d {
      DFn(_, n, _, _, _, _, _, _, _, _) -> if n == "main" { true } else { has_main_decl(rest) }
      _ -> has_main_decl(rest)
    }
  }
}

fn emit_main_wrapper(decls: [Decl], bmode: BuildMode) : String {
  match bmode {
    BMTest -> {
      let n = test_count(decls)
      concat_all([
        "int main(int argc, char **argv) {\n",
        "    kai_set_args(argc, argv);\n",
        test_call_list(n, 0),
        "    return kai_test_summary();\n",
        "}\n"
      ])
    }
    BMBench -> {
      let n = bench_count(decls)
      concat_all([
        "int main(int argc, char **argv) {\n",
        "    kai_set_args(argc, argv);\n",
        bench_call_list(n, 0),
        "    return kai_bench_summary();\n",
        "}\n"
      ])
    }
    BMCheck -> {
      let n = check_count(decls)
      concat_all([
        "int main(int argc, char **argv) {\n",
        "    kai_set_args(argc, argv);\n",
        check_call_list(n, 0),
        "    return kai_check_summary();\n",
        "}\n"
      ])
    }
    BMBuild -> {
      if has_main_decl(decls) {
        # m7a #7: install default handlers around `kai_main` only for
        # the builtin effects that appear in `main`'s row. The push/pop
        # pair is syntactically balanced (Doc C §*Per-fiber isolation*);
        # pop runs even if `kai_main` returns. Pops are emitted in
        # reverse-push order so the evidence stack stays LIFO-balanced.
        #
        # Issue #115: the shim block below is emitted at file scope,
        # before `int main()`. Each shim has the typed signature
        # matching the EvX struct field and forwards to the runtime
        # void-self function. Setup assigns shim addresses without a
        # cast, so UBSan's `-fsanitize=function` (Linux clang's
        # `-fsanitize=undefined`, absent from Apple clang's default)
        # sees matching types at every dispatch through `_ev_op->op`.
        # Issue #308: drop any effect name whose decl is user-supplied
        # (line/col != 0). The default-handler emit assumes the builtin
        # EvX layout — emitting it for a user `effect Log { ... }` shape
        # produces invalid C against the user's struct.
        let main_row = row_minus_user_effects(main_row_labels(decls), decls)
        let shims    = default_shims_for(main_row)
        let setup    = default_setups_for(main_row)
        let teardown = default_pops_for(main_row)
        concat_all([
          shims,
          "int main(int argc, char **argv) {\n",
          "    kai_set_args(argc, argv);\n",
          setup,
          "    KaiValue *_result = kai_main();\n",
          teardown,
          "    kai_decref(_result);\n",
          "    return 0;\n",
          "}\n"
        ])
      } else {
        ""
      }
    }
  }
}

# m7e §24: build a RowExpr from the body-performed labels collected
# by the inferencer. Used only for `main` without an explicit row;
# the typer writes this back into the DFn so the default-handler
# wrapper sees the inferred row at emit time. ty_args are dropped —
# every builtin effect with a default handler is non-parametric, and
# parametric effects (State[T], Reader[T]) have no default handler
# anyway, so the wrapper would not install anything for them. The
# Bug 6 row-vs-body subset check still skips `main` in
# `check_body_row`; this rewrite only changes what the wrapper sees.
fn inferred_main_row(performed: [Label]) : RowExpr {
  match performed {
    [] -> REmpty
    _  -> RClosed(map(performed, label_to_rl_zero))
  }
}

fn label_to_rl_zero(lab: Label) : RowLabel = RL(lab.eff, [])

# m12.6.x followup: walk a typed Expr collecting effect labels from
# every call site's callee type. Used only on `main`'s body to fix
# the footgun where every `Stdout.print` reached only via helpers
# left `inferred_main_row` empty, the wrapper installed no default
# handlers, and the program SIGSEGV'd. Caller-side effect tracking
# during typing is intentionally direct-only (Bug 6 enforcement
# lives there); this walk is a separate, post-typing pass that
# reads the *callee's* declared row out of its resolved Expr.ty so
# nothing changes for non-main inference. ELambda is *not* recursed
# into — a lambda's body effects only run when the lambda is
# invoked, and that invocation appears as its own ECall whose
# callee row already carries those effects (the row var was
# unified with the lambda's row at the call site).
fn collect_call_labels(e: Expr, acc: [Label]) : [Label] = match e.kind {
  EInt(_)             -> acc
  EReal(_)            -> acc
  EBool(_)            -> acc
  EChar(_)            -> acc
  EStr(_, _)          -> acc
  EUnit               -> acc
  EVar(_)             -> acc
  EUnder              -> acc
  EPlaceholder        -> acc
  EHole(_)            -> acc
  ETodo(_)            -> acc
  EVariantsOf(_, _)   -> acc
  EModCall(_, _)      -> acc
  ECall(callee, args_) -> {
    let acc1 = match callee.ty {
      Some(t) -> match t {
        TyFnT(_, _, row) -> append_labels(row.labels, acc)
        _                -> acc
      }
      None    -> acc
    }
    collect_call_labels_list(args_, collect_call_labels(callee, acc1))
  }
  EField(base, _)     -> collect_call_labels(base, acc)
  EIndex(a, b)        -> collect_call_labels(b, collect_call_labels(a, acc))
  EBinop(_, a, b)     -> collect_call_labels(b, collect_call_labels(a, acc))
  EUnop(_, x)         -> collect_call_labels(x, acc)
  EIf(c, t, eo)       -> {
    let a1 = collect_call_labels(t, collect_call_labels(c, acc))
    match eo { Some(b) -> collect_call_labels(b, a1) None -> a1 }
  }
  EMatch(scr, arms)   -> collect_call_labels_arms(arms, collect_call_labels(scr, acc))
  ELambda(_, _)       -> acc
  ERecordLit(_, fs)   -> collect_call_labels_fields(fs, acc)
  EList(els)          -> collect_call_labels_elems(els, acc)
  ERange(a, b, opt)   -> {
    let a1 = collect_call_labels(b, collect_call_labels(a, acc))
    match opt { Some(s) -> collect_call_labels(s, a1) None -> a1 }
  }
  EBlock(stmts, tail) -> {
    let a1 = collect_call_labels_stmts(stmts, acc)
    match tail { Some(t) -> collect_call_labels(t, a1) None -> a1 }
  }
  EPipe(a, b)         -> collect_call_labels(b, collect_call_labels(a, acc))
  EMapPipe(a, b)      -> collect_call_labels(b, collect_call_labels(a, acc))
  EFlatMapPipe(a, b)  -> collect_call_labels(b, collect_call_labels(a, acc))
  EFilterPipe(a, b)   -> collect_call_labels(b, collect_call_labels(a, acc))
  EBang(inner)        -> collect_call_labels(inner, acc)
  ELitUnit(inner, _)  -> collect_call_labels(inner, acc)
  EHandle(body, _, _, init_opt, _, clauses, ret_opt) -> {
    let a1 = collect_call_labels(body, acc)
    let a2 = match init_opt { Some(i) -> collect_call_labels(i, a1) None -> a1 }
    let a3 = collect_call_labels_clauses(clauses, a2)
    match ret_opt {
      Some(r) -> match r { HR(_, b, _, _) -> collect_call_labels(b, a3) }
      None    -> a3
    }
  }
}

fn collect_call_labels_list(es: [Expr], acc: [Label]) : [Label] = match es {
  []           -> acc
  [h, ...rest] -> collect_call_labels_list(rest, collect_call_labels(h, acc))
}

fn collect_call_labels_arms(arms: [Arm], acc: [Label]) : [Label] = match arms {
  []           -> acc
  [a, ...rest] -> match a {
    Arm(_, opt_guard, body) -> {
      let a1 = match opt_guard { Some(g) -> collect_call_labels(g, acc) None -> acc }
      collect_call_labels_arms(rest, collect_call_labels(body, a1))
    }
  }
}

fn collect_call_labels_fields(fs: [FieldInit], acc: [Label]) : [Label] = match fs {
  []           -> acc
  [f, ...rest] -> match f {
    FI(_, e) -> collect_call_labels_fields(rest, collect_call_labels(e, acc))
  }
}

fn collect_call_labels_elems(els: [ListElem], acc: [Label]) : [Label] = match els {
  []           -> acc
  [el, ...rest] -> match el {
    ElPlain(e)  -> collect_call_labels_elems(rest, collect_call_labels(e, acc))
    ElSpread(e) -> collect_call_labels_elems(rest, collect_call_labels(e, acc))
  }
}

fn collect_call_labels_stmts(ss: [Stmt], acc: [Label]) : [Label] = match ss {
  []           -> acc
  [s, ...rest] -> match s {
    SLet(_, _, e)        -> collect_call_labels_stmts(rest, collect_call_labels(e, acc))
    SVar(_, _, e, _, _)  -> collect_call_labels_stmts(rest, collect_call_labels(e, acc))
    SAssert(e, og)       -> {
      let a1 = collect_call_labels(e, acc)
      let a2 = match og { Some(g) -> collect_call_labels(g, a1) None -> a1 }
      collect_call_labels_stmts(rest, a2)
    }
    SExprStmt(e)         -> collect_call_labels_stmts(rest, collect_call_labels(e, acc))
    SIndexAssign(a, b, c, _, _) -> {
      let a1 = collect_call_labels(c, collect_call_labels(b, collect_call_labels(a, acc)))
      collect_call_labels_stmts(rest, a1)
    }
    SUse(_, _, _)        -> collect_call_labels_stmts(rest, acc)
  }
}

fn collect_call_labels_clauses(cs: [HClause], acc: [Label]) : [Label] = match cs {
  []           -> acc
  [c, ...rest] -> match c {
    HC(_, _, body, _, _) -> collect_call_labels_clauses(rest, collect_call_labels(body, acc))
  }
}

# Append `xs` onto `acc`, skipping labels already present by `eff`
# name (caller's own dedup via `st_add_label` is structural; we use
# the simpler eff-name dedup here because all builtin handlers are
# non-parametric — `inferred_main_row` would drop the ty_args anyway).
fn append_labels(xs: [Label], acc: [Label]) : [Label] = match xs {
  []           -> acc
  [h, ...rest] -> if eff_already_in(acc, h.eff) {
    append_labels(rest, acc)
  } else {
    append_labels(rest, [h, ...acc])
  }
}

fn eff_already_in(acc: [Label], eff: String) : Bool = match acc {
  []           -> false
  [l, ...rest] -> if l.eff == eff { true } else { eff_already_in(rest, eff) }
}

# m7a #7: extract the row labels declared on `fn main`. A row of
# `REmpty` returns []; `RClosed([Console, Fail])` returns those
# labels. The wrapper installs default handlers only for the
# subset of these that match a builtin effect. m7e §24: when
# `main` shipped without a declared row, the typer's
# `inferred_main_row` already populated this with the body's
# builtins, so this function reads back the same labels it would
# have read from an explicit annotation.
fn main_row_labels(decls: [Decl]) : [String] {
  match decls {
    [] -> []
    [d, ...rest] -> match d {
      DFn(_, n, _, _, _, row, _, _, _, _) ->
        if n == "main" {
          match row {
            REmpty       -> []
            RClosed(lbs) -> row_label_names(lbs)
            ROpen(_, lbs) -> row_label_names(lbs)
          }
        } else { main_row_labels(rest) }
      _ -> main_row_labels(rest)
    }
  }
}

# m12.8 Phase 4b: atomic Stdout / Stderr default setups. The
# combined `Console` is an alias `type Console = Stdout + Stderr`,
# so a `main` declaring `/ Console` installs BOTH the Stdout and
# Stderr default handlers via the alias-expansion path in
# `default_setups_for`.
#
# Issue #115: the runtime `kai_default_*` handlers in stage0/runtime.h
# take `void *self` because the runtime header cannot know the
# emitted `EvStdout` / `EvStderr` / ... types. Casting their
# addresses to typed function pointers (`(KaiValue *(*)(EvStdout *,
# ...))`) is a representation-equivalent cast in C, but UBSan's
# `-fsanitize=function` (active in clang's `-fsanitize=undefined`
# on Linux; absent from Apple clang's default `undefined` set)
# checks at every indirect call that the *function definition's*
# type tag equals the function pointer's static type. The cast
# does not change the function definition's type tag, so every
# dispatch through `_ev_op->print(...)` etc. trips the check on
# Linux while passing on macOS.
#
# Fix: emit a thin typed shim per default-op at file scope
# (`_kai_default_<eff>_<op>_shim`). The shim has the typed
# signature matching the struct field, forwards to the runtime
# void-self function via a regular call (not subject to
# `-fsanitize=function`). Setup assigns the shim's address; no
# cast required at the assignment, no UBSan diagnostic at the
# dispatch site.
fn default_stdout_shims() : String =
  concat_all([
    "static KaiValue *_kai_default_stdout_print_shim(EvStdout *self, KaiValue *kai_s, KaiCont *k) {\n",
    "    return kai_default_stdout_print(self, kai_s, k);\n",
    "}\n"
  ])

fn default_stdout_setup() : String =
  concat_all([
    "    static EvStdout _kai_default_ev_stdout;\n",
    "    static KaiEvidence _kai_default_node_stdout;\n",
    "    _kai_default_ev_stdout.handler_id = kai_fresh_handler_id();\n",
    "    _kai_default_ev_stdout.print = &_kai_default_stdout_print_shim;\n",
    "    kai_evidence_push(&_kai_default_node_stdout, \"Stdout\", &_kai_default_ev_stdout);\n"
  ])

fn default_stderr_shims() : String =
  concat_all([
    "static KaiValue *_kai_default_stderr_eprint_shim(EvStderr *self, KaiValue *kai_s, KaiCont *k) {\n",
    "    return kai_default_stderr_eprint(self, kai_s, k);\n",
    "}\n"
  ])

fn default_stderr_setup() : String =
  concat_all([
    "    static EvStderr _kai_default_ev_stderr;\n",
    "    static KaiEvidence _kai_default_node_stderr;\n",
    "    _kai_default_ev_stderr.handler_id = kai_fresh_handler_id();\n",
    "    _kai_default_ev_stderr.eprint = &_kai_default_stderr_eprint_shim;\n",
    "    kai_evidence_push(&_kai_default_node_stderr, \"Stderr\", &_kai_default_ev_stderr);\n"
  ])

fn default_fail_shims() : String =
  concat_all([
    "static KaiValue *_kai_default_fail_fail_shim(EvFail *self, KaiValue *kai_msg, KaiCont *k) {\n",
    "    return kai_default_fail_fail(self, kai_msg, k);\n",
    "}\n"
  ])

fn default_fail_setup() : String =
  concat_all([
    "    static EvFail _kai_default_ev_fail;\n",
    "    static KaiEvidence _kai_default_node_fail;\n",
    "    _kai_default_ev_fail.handler_id = kai_fresh_handler_id();\n",
    "    _kai_default_ev_fail.fail = &_kai_default_fail_fail_shim;\n",
    "    kai_evidence_push(&_kai_default_node_fail, \"Fail\", &_kai_default_ev_fail);\n"
  ])

