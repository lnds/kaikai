# stage 2: kaikai compiler, targeting full kaikai.
#
# Milestone 1 starts as a verbatim copy of stage 1's source. It is
# compiled by stage 1 (`../stage1/kaic1`) into `kaic2`, which behaves
# as a drop-in replacement for kaic1 — same tokens, same AST shape,
# same emitted C. From this baseline the compiler grows: HM-extended
# checker, LLVM backend, monomorphised generics, Perceus, modules,
# effects + handlers, fibers + scheduler, structured concurrency, and
# typed holes. See `docs/stage2-design.md`.
#
# Invariant during the early milestones: `make test` in stage2/ must
# pass by diffing every artefact against stage 1's output. Any stage 2
# feature that diverges must be explicitly gated behind a flag so the
# parity tests keep working until parity is retired (post self-host).

# ====================================================================
# char classification helpers
# ====================================================================
#
# These would naturally live in `stage2/chars.kai` now that the
# module system exists, but stage 1 (which compiles stage 2) does
# not resolve imports — partitioning the compiler is blocked until
# M6.1 is ported to stage 1 too. See
# `memory/project_stage0_bugs.md` and TODO notes for the plan.

fn ch_is_digit(c: Char) : Bool = c >= '0' and c <= '9'
fn ch_is_lower(c: Char) : Bool = c >= 'a' and c <= 'z'
fn ch_is_upper(c: Char) : Bool = c >= 'A' and c <= 'Z'
fn ch_is_alpha(c: Char) : Bool = ch_is_lower(c) or ch_is_upper(c) or c == '_'
fn ch_is_alnum(c: Char) : Bool = ch_is_alpha(c) or ch_is_digit(c)
fn ch_is_space(c: Char) : Bool = c == ' ' or c == '\t' or c == '\r'

# ====================================================================
# token kinds + tokens
# ====================================================================

type TokKind
  = TkEof
  | TkNewline
  # keywords (alphabetical)
  | TkAnd | TkAs | TkAssert | TkEffect | TkElse | TkFalse | TkFn | TkFor
  | TkHandle | TkIf | TkImpl | TkImport
  | TkLet | TkMatch | TkNot | TkOr | TkProtocol | TkPub | TkTest | TkTrue | TkType
  | TkUnitKw | TkVar | TkWith
  # m12.8: `#derive(P, ...)` annotation. The lexer recognises `#derive`
  # specifically (instead of treating it as a comment) so the parser can
  # consume it as a prefix to a `type` declaration.
  | TkDerive
  # literals
  | TkInt | TkReal | TkChar | TkString
  # identifiers
  | TkIdent | TkUnderscore
  # punctuation
  | TkLparen | TkRparen | TkLbracket | TkRbracket | TkLbrace | TkRbrace
  | TkComma | TkColon | TkColonEq | TkSemi | TkDot | TkDotDot | TkEllipsis
  # operators
  | TkEq | TkArrow | TkFatArrow | TkPipe | TkPipeApply
  | TkPlus | TkMinus | TkStar | TkSlash | TkSlashSlash | TkPercent
  # m7d §23: `++` is the string / list concatenation operator.
  # Right-associative, lower precedence than `+`/`-`/`*`/`/`,
  # higher than comparison.
  | TkPlusPlus
  | TkEqEq | TkNeq | TkLt | TkGt | TkLe | TkGe
  | TkBang | TkAt
  # m12.5: caret used for integer power inside unit expressions, e.g.
  # `m^2`, `sec^-1`. Reserved exclusively for unit syntax — outside
  # `<...>` annotations it is a parser error.
  | TkCaret
  # typed holes (M10): TkHole is a bare `?`; TkHoleName carries the
  # identifier for `?foo`. The lexer recognises `?ident` as one token
  # so the parser does not have to re-synthesise the form.
  | TkHole | TkHoleName(String)
  # m7d §1: `todo!` is a single token. The lexer recognises the
  # `todo` identifier followed immediately by `!` as `TkTodoBang`,
  # so the parser sees one symbol at the call site.
  | TkTodoBang
  # error token carries a human-readable message
  | TkError(String)

type Token = { kind: TokKind, line: Int, col: Int, start: Int, length: Int }

# Convenience constructor — fewer characters at call sites.
fn tok(kind: TokKind, line: Int, col: Int, start: Int, end: Int) : Token {
  Token { kind: kind, line: line, col: col, start: start, length: end - start }
}

# Mnemonic for token kinds (for --tokens dump). Keep in sync with TokKind.
fn tk_name(k: TokKind) : String {
  match k {
    TkEof -> "EOF"
    TkNewline -> "NEWLINE"
    TkAnd -> "and" TkAs -> "as" TkAssert -> "assert" TkEffect -> "effect" TkElse -> "else"
    TkFalse -> "false" TkFn -> "fn" TkFor -> "for" TkHandle -> "handle"
    TkIf -> "if" TkImpl -> "impl" TkImport -> "import"
    TkLet -> "let" TkMatch -> "match" TkNot -> "not" TkOr -> "or"
    TkProtocol -> "protocol" TkPub -> "pub" TkTest -> "test" TkTrue -> "true" TkType -> "type"
    TkUnitKw -> "unit" TkVar -> "var" TkWith -> "with"
    TkDerive -> "#derive"
    TkInt -> "INT" TkReal -> "REAL" TkChar -> "CHAR" TkString -> "STRING"
    TkIdent -> "IDENT" TkUnderscore -> "_"
    TkLparen -> "(" TkRparen -> ")" TkLbracket -> "[" TkRbracket -> "]"
    TkLbrace -> "{" TkRbrace -> "}"
    TkComma -> "," TkColon -> ":" TkColonEq -> ":=" TkSemi -> ";"
    TkDot -> "." TkDotDot -> ".." TkEllipsis -> "..."
    TkEq -> "=" TkArrow -> "->" TkFatArrow -> "=>"
    TkPipe -> "|" TkPipeApply -> "|>"
    TkPlus -> "+" TkMinus -> "-" TkStar -> "*" TkSlash -> "/"
    TkSlashSlash -> "//" TkPercent -> "%" TkPlusPlus -> "++"
    TkEqEq -> "==" TkNeq -> "!=" TkLt -> "<" TkGt -> ">"
    TkLe -> "<=" TkGe -> ">=" TkBang -> "!" TkAt -> "@" TkCaret -> "^"
    TkHole -> "?" TkHoleName(_) -> "?NAME"
    TkTodoBang -> "todo!"
    TkError(_) -> "ERROR"
  }
}

# ====================================================================
# lexer state + helpers
# ====================================================================

type Lexer = { src: String, pos: Int, line: Int, col: Int }

fn lex_new(src: String) : Lexer = Lexer { src: src, pos: 0, line: 1, col: 1 }

fn lex_at_end(l: Lexer) : Bool = l.pos >= string_length(l.src)

fn lex_peek_at(l: Lexer, off: Int) : Option[Char] =
  char_at(l.src, l.pos + off)

fn lex_peek(l: Lexer) : Option[Char] = lex_peek_at(l, 0)

fn lex_advance(l: Lexer) : Lexer {
  match char_at(l.src, l.pos) {
    None -> l
    Some(c) -> {
      if c == '\n' {
        Lexer { src: l.src, pos: l.pos + 1, line: l.line + 1, col: 1 }
      } else {
        Lexer { src: l.src, pos: l.pos + 1, line: l.line, col: l.col + 1 }
      }
    }
  }
}

# Pair of lexer state + emitted token. Used everywhere the scanner
# returns both a new position and a produced token.
type LexStep = Step(Lexer, Token)

# Returns true if the next char matches `want` (and does not consume it).
fn lex_peek_is(l: Lexer, want: Char) : Bool {
  match lex_peek(l) {
    None -> false
    Some(c) -> c == want
  }
}

fn lex_peek2_is(l: Lexer, want: Char) : Bool {
  match lex_peek_at(l, 1) {
    None -> false
    Some(c) -> c == want
  }
}

fn lex_peek3_is(l: Lexer, want: Char) : Bool {
  match lex_peek_at(l, 2) {
    None -> false
    Some(c) -> c == want
  }
}

# ====================================================================
# whitespace and comments
# ====================================================================

fn lex_skip_comment(l: Lexer) : Lexer {
  # `#` already consumed. Stop at newline or EOF; the newline itself is a
  # token and stays for the main loop to emit.
  match lex_peek(l) {
    None -> l
    Some(c) -> if c == '\n' { l } else { lex_skip_comment(lex_advance(l)) }
  }
}

fn lex_skip_ws(l: Lexer) : Lexer {
  match lex_peek(l) {
    None -> l
    Some(c) -> {
      if ch_is_space(c) { lex_skip_ws(lex_advance(l)) }
      else if c == '#' {
        # m12.8: `#derive` is a token, not a comment. Leave the `#`
        # in place so lex_punct can produce TkDerive. Anything else
        # starting with `#` is still a line comment.
        if lex_match_word_at(l, 1, "derive") { l }
        else { lex_skip_ws(lex_skip_comment(lex_advance(l))) }
      }
      else { l }
    }
  }
}

# m12.8: return true when `s` starts at offset `off` AND the character
# right after is not alphanumeric (so `#derive` matches `#derive(` but
# not `#deriveable`).
fn lex_match_word_at(l: Lexer, off: Int, s: String) : Bool {
  if not lex_match_str_at(l, off, s, 0) { false }
  else {
    let after = l.pos + off + string_length(s)
    match char_at(l.src, after) {
      None -> true
      Some(c) -> not ch_is_alnum(c)
    }
  }
}

fn lex_match_str_at(l: Lexer, off: Int, s: String, i: Int) : Bool {
  let n = string_length(s)
  if i >= n { true }
  else {
    match char_at(s, i) {
      None -> true
      Some(want) -> match char_at(l.src, l.pos + off + i) {
        None -> false
        Some(have) -> if have == want { lex_match_str_at(l, off, s, i + 1) } else { false }
      }
    }
  }
}

# ====================================================================
# identifiers and keywords
# ====================================================================

fn lex_scan_ident_rest(l: Lexer) : Lexer {
  match lex_peek(l) {
    None -> l
    Some(c) -> if ch_is_alnum(c) { lex_scan_ident_rest(lex_advance(l)) } else { l }
  }
}

fn keyword_kind(text: String) : TokKind {
  if text == "and" { TkAnd }
  else if text == "as" { TkAs }
  else if text == "assert" { TkAssert }
  else if text == "effect" { TkEffect }
  else if text == "else" { TkElse }
  else if text == "false" { TkFalse }
  else if text == "fn" { TkFn }
  else if text == "for" { TkFor }
  else if text == "handle" { TkHandle }
  else if text == "if" { TkIf }
  else if text == "impl" { TkImpl }
  else if text == "import" { TkImport }
  else if text == "let" { TkLet }
  else if text == "match" { TkMatch }
  else if text == "not" { TkNot }
  else if text == "or" { TkOr }
  else if text == "protocol" { TkProtocol }
  else if text == "pub" { TkPub }
  else if text == "test" { TkTest }
  else if text == "true" { TkTrue }
  else if text == "type" { TkType }
  else if text == "unit" { TkUnitKw }   # m12.5
  else if text == "var" { TkVar }
  else if text == "with" { TkWith }
  else { TkIdent }
}

fn lex_ident(l: Lexer) : LexStep {
  let start = l.pos
  let sl = l.line
  let sc = l.col
  let l2 = lex_scan_ident_rest(l)
  let text = string_slice(l.src, start, l2.pos - start)
  # m7d §1: `todo!` lexes as a single token. We recognise the
  # identifier `todo` immediately followed by `!` (no whitespace)
  # so the parser sees `TkTodoBang` instead of `TkIdent` + `TkBang`.
  # The bang stays available as a postfix operator elsewhere (m7e §13).
  if text == "todo" and lex_peek_is(l2, '!') {
    let l3 = lex_advance(l2)
    Step(l3, tok(TkTodoBang, sl, sc, start, l3.pos))
  } else {
    let kind =
      if string_length(text) == 1 and text == "_" {
        TkUnderscore
      } else {
        keyword_kind(text)
      }
    Step(l2, tok(kind, sl, sc, start, l2.pos))
  }
}

# ====================================================================
# numbers
# ====================================================================

fn lex_scan_digits(l: Lexer) : Lexer {
  match lex_peek(l) {
    None -> l
    Some(c) -> {
      if ch_is_digit(c) or c == '_' { lex_scan_digits(lex_advance(l)) }
      else { l }
    }
  }
}

fn lex_number(l: Lexer) : LexStep {
  let start = l.pos
  let sl = l.line
  let sc = l.col
  let l1 = lex_scan_digits(l)
  # Fractional part: only when `.` is followed by a digit. `x..y` (range)
  # and `x.field` (access) must be left alone.
  let after_frac_kind =
    if lex_peek_is(l1, '.') {
      match lex_peek_at(l1, 1) {
        Some(d) -> if ch_is_digit(d) { Some(true) } else { Some(false) }
        None -> Some(false)
      }
    } else {
      Some(false)
    }
  let l2 =
    match after_frac_kind {
      Some(true) -> lex_scan_digits(lex_advance(lex_advance(l1)))
      _ -> l1
    }
  let is_real1 = match after_frac_kind { Some(true) -> true _ -> false }
  # Exponent part: `e` or `E`, optional sign, digits.
  let has_exp =
    match lex_peek(l2) {
      Some(c) -> c == 'e' or c == 'E'
      None -> false
    }
  if has_exp {
    let l3 = lex_advance(l2)
    let l4 =
      match lex_peek(l3) {
        Some(c) -> if c == '+' or c == '-' { lex_advance(l3) } else { l3 }
        None -> l3
      }
    match lex_peek(l4) {
      Some(d) -> {
        if ch_is_digit(d) {
          let l5 = lex_scan_digits(l4)
          Step(l5, tok(TkReal, sl, sc, start, l5.pos))
        } else {
          Step(l4, tok(TkError("malformed number: expected digits after exponent"),
                       sl, sc, start, l4.pos))
        }
      }
      None -> {
        Step(l4, tok(TkError("malformed number: expected digits after exponent"),
                     sl, sc, start, l4.pos))
      }
    }
  } else {
    let kind = if is_real1 { TkReal } else { TkInt }
    Step(l2, tok(kind, sl, sc, start, l2.pos))
  }
}

# ====================================================================
# strings
# ====================================================================

# Walk a string literal consuming chars until the closing `"` (or `"""`).
# Handles backslash escapes and `#{...}` interpolation (nested braces).
# Return the lexer positioned past the closing quote, plus the kind of
# token to emit (TkString or TkError(msg)).

type StrResult = StrOk(Lexer) | StrErr(Lexer, String)

# Skip past a nested {...} block inside interpolation, counting braces.
fn lex_skip_interp(l: Lexer, depth: Int) : StrResult {
  if depth == 0 { StrOk(l) }
  else {
    match lex_peek(l) {
      None -> StrErr(l, "unterminated interpolation in string")
      Some(c) -> {
        if c == '{' { lex_skip_interp(lex_advance(l), depth + 1) }
        else if c == '}' { lex_skip_interp(lex_advance(l), depth - 1) }
        else if c == '"' {
          # Skip a nested string literal inside the interpolation.
          match lex_skip_inner_string(lex_advance(l)) {
            StrOk(l2) -> lex_skip_interp(l2, depth)
            StrErr(l2, msg) -> StrErr(l2, msg)
          }
        } else {
          lex_skip_interp(lex_advance(l), depth)
        }
      }
    }
  }
}

fn lex_skip_inner_string(l: Lexer) : StrResult {
  match lex_peek(l) {
    None -> StrErr(l, "unterminated string inside interpolation")
    Some(c) -> {
      if c == '"' { StrOk(lex_advance(l)) }
      else if c == '\\' {
        let l1 = lex_advance(l)
        match lex_peek(l1) {
          None -> StrErr(l1, "unterminated string inside interpolation")
          Some(_) -> lex_skip_inner_string(lex_advance(l1))
        }
      } else {
        lex_skip_inner_string(lex_advance(l))
      }
    }
  }
}

fn lex_string_body(l: Lexer, triple: Bool) : StrResult {
  match lex_peek(l) {
    None -> StrErr(l, "unterminated string")
    Some(c) -> {
      if c == '\\' {
        let l1 = lex_advance(l)
        match lex_peek(l1) {
          None -> StrErr(l1, "unterminated string")
          Some(_) -> lex_string_body(lex_advance(l1), triple)
        }
      } else if c == '#' and lex_peek2_is(l, '{') {
        let l1 = lex_advance(lex_advance(l))
        match lex_skip_interp(l1, 1) {
          StrOk(l2) -> lex_string_body(l2, triple)
          StrErr(l2, msg) -> StrErr(l2, msg)
        }
      } else if triple {
        if c == '"' and lex_peek2_is(l, '"') and lex_peek3_is(l, '"') {
          StrOk(lex_advance(lex_advance(lex_advance(l))))
        } else {
          lex_string_body(lex_advance(l), triple)
        }
      } else {
        if c == '\n' {
          StrErr(l, "unterminated string (newline in single-line string)")
        } else if c == '"' {
          StrOk(lex_advance(l))
        } else {
          lex_string_body(lex_advance(l), triple)
        }
      }
    }
  }
}

fn lex_string(l: Lexer) : LexStep {
  let start = l.pos
  let sl = l.line
  let sc = l.col
  let l1 = lex_advance(l)                  # consume opening "
  let triple = lex_peek_is(l1, '"') and lex_peek2_is(l1, '"')
  let l2 = if triple { lex_advance(lex_advance(l1)) } else { l1 }
  match lex_string_body(l2, triple) {
    StrOk(l3) -> Step(l3, tok(TkString, sl, sc, start, l3.pos))
    StrErr(l3, msg) -> Step(l3, tok(TkError(msg), sl, sc, start, l3.pos))
  }
}

# ====================================================================
# char literals
# ====================================================================

fn lex_char_skip_u_escape(l: Lexer) : Lexer {
  # We're past `\u`; consume `{HHHH}`.
  match lex_peek(l) {
    None -> l
    Some(c) -> {
      if c == '}' { lex_advance(l) }
      else { lex_char_skip_u_escape(lex_advance(l)) }
    }
  }
}

fn lex_char(l: Lexer) : LexStep {
  let start = l.pos
  let sl = l.line
  let sc = l.col
  let l1 = lex_advance(l)                 # consume opening '
  match lex_peek(l1) {
    None -> Step(l1, tok(TkError("unterminated char literal"),
                         sl, sc, start, l1.pos))
    Some(c) -> {
      let l2 =
        if c == '\\' {
          let la = lex_advance(l1)
          match lex_peek(la) {
            None -> la
            Some(e) -> {
              if e == 'u' and lex_peek2_is(la, '{') {
                lex_char_skip_u_escape(lex_advance(lex_advance(la)))
              } else {
                lex_advance(la)
              }
            }
          }
        } else {
          # One byte of a UTF-8 codepoint. For the stage-0-compatible
          # subset we treat multi-byte characters structurally: consume
          # one byte and trust the closing quote to appear.
          lex_advance(l1)
        }
      if lex_peek_is(l2, '\'') {
        Step(lex_advance(l2), tok(TkChar, sl, sc, start, l2.pos + 1))
      } else {
        Step(l2, tok(TkError("unterminated char literal"),
                     sl, sc, start, l2.pos))
      }
    }
  }
}

# ====================================================================
# punctuation and operators
# ====================================================================

fn lex_punct(l: Lexer) : LexStep {
  let start = l.pos
  let sl = l.line
  let sc = l.col
  match lex_peek(l) {
    None -> Step(l, tok(TkEof, sl, sc, start, start))
    Some(c) -> {
      let l1 = lex_advance(l)
      if c == '(' { Step(l1, tok(TkLparen, sl, sc, start, l1.pos)) }
      else if c == ')' { Step(l1, tok(TkRparen, sl, sc, start, l1.pos)) }
      else if c == '[' { Step(l1, tok(TkLbracket, sl, sc, start, l1.pos)) }
      else if c == ']' { Step(l1, tok(TkRbracket, sl, sc, start, l1.pos)) }
      else if c == '{' { Step(l1, tok(TkLbrace, sl, sc, start, l1.pos)) }
      else if c == '}' { Step(l1, tok(TkRbrace, sl, sc, start, l1.pos)) }
      else if c == ',' { Step(l1, tok(TkComma, sl, sc, start, l1.pos)) }
      else if c == '@' { Step(l1, tok(TkAt, sl, sc, start, l1.pos)) }
      # m12.5: caret token for unit exponents — only meaningful inside
      # `<...>` annotations; the parser rejects it elsewhere.
      else if c == '^' { Step(l1, tok(TkCaret, sl, sc, start, l1.pos)) }
      else if c == ':' {
        if lex_peek_is(l1, '=') {
          let l2 = lex_advance(l1)
          Step(l2, tok(TkColonEq, sl, sc, start, l2.pos))
        } else {
          Step(l1, tok(TkColon, sl, sc, start, l1.pos))
        }
      }
      else if c == ';' { Step(l1, tok(TkSemi, sl, sc, start, l1.pos)) }
      else if c == '+' {
        # m7d §23: `++` is the concatenation operator. The lexer
        # fuses two adjacent `+` characters into a single token; a
        # space breaks it (so `1 + +2` is still allowed if anyone
        # writes it).
        if lex_peek_is(l1, '+') {
          let l2 = lex_advance(l1)
          Step(l2, tok(TkPlusPlus, sl, sc, start, l2.pos))
        } else {
          Step(l1, tok(TkPlus, sl, sc, start, l1.pos))
        }
      }
      else if c == '*' { Step(l1, tok(TkStar, sl, sc, start, l1.pos)) }
      else if c == '%' { Step(l1, tok(TkPercent, sl, sc, start, l1.pos)) }
      else if c == '-' {
        if lex_peek_is(l1, '>') {
          let l2 = lex_advance(l1)
          Step(l2, tok(TkArrow, sl, sc, start, l2.pos))
        } else {
          Step(l1, tok(TkMinus, sl, sc, start, l1.pos))
        }
      }
      else if c == '/' {
        if lex_peek_is(l1, '/') {
          let l2 = lex_advance(l1)
          Step(l2, tok(TkSlashSlash, sl, sc, start, l2.pos))
        } else {
          Step(l1, tok(TkSlash, sl, sc, start, l1.pos))
        }
      }
      else if c == '=' {
        if lex_peek_is(l1, '=') {
          let l2 = lex_advance(l1)
          Step(l2, tok(TkEqEq, sl, sc, start, l2.pos))
        } else if lex_peek_is(l1, '>') {
          let l2 = lex_advance(l1)
          Step(l2, tok(TkFatArrow, sl, sc, start, l2.pos))
        } else {
          Step(l1, tok(TkEq, sl, sc, start, l1.pos))
        }
      }
      else if c == '<' {
        if lex_peek_is(l1, '=') {
          let l2 = lex_advance(l1)
          Step(l2, tok(TkLe, sl, sc, start, l2.pos))
        } else {
          Step(l1, tok(TkLt, sl, sc, start, l1.pos))
        }
      }
      else if c == '>' {
        if lex_peek_is(l1, '=') {
          let l2 = lex_advance(l1)
          Step(l2, tok(TkGe, sl, sc, start, l2.pos))
        } else {
          Step(l1, tok(TkGt, sl, sc, start, l1.pos))
        }
      }
      else if c == '!' {
        if lex_peek_is(l1, '=') {
          let l2 = lex_advance(l1)
          Step(l2, tok(TkNeq, sl, sc, start, l2.pos))
        } else {
          Step(l1, tok(TkBang, sl, sc, start, l1.pos))
        }
      }
      else if c == '?' {
        # `?ident` is one TkHoleName token; `?` alone is TkHole.
        # Peek at the next char: if it's alpha (or `_`), read an
        # identifier.
        match lex_peek(l1) {
          Some(nc) -> {
            if ch_is_alpha(nc) {
              let l_end = lex_scan_ident_rest(lex_advance(l1))
              let name = string_slice(l.src, start + 1, l_end.pos - (start + 1))
              Step(l_end, tok(TkHoleName(name), sl, sc, start, l_end.pos))
            } else {
              Step(l1, tok(TkHole, sl, sc, start, l1.pos))
            }
          }
          None -> Step(l1, tok(TkHole, sl, sc, start, l1.pos))
        }
      }
      else if c == '|' {
        if lex_peek_is(l1, '>') {
          let l2 = lex_advance(l1)
          Step(l2, tok(TkPipeApply, sl, sc, start, l2.pos))
        } else {
          Step(l1, tok(TkPipe, sl, sc, start, l1.pos))
        }
      }
      else if c == '.' {
        if lex_peek_is(l1, '.') and lex_peek2_is(l1, '.') {
          let l2 = lex_advance(lex_advance(l1))
          Step(l2, tok(TkEllipsis, sl, sc, start, l2.pos))
        } else if lex_peek_is(l1, '.') {
          let l2 = lex_advance(l1)
          Step(l2, tok(TkDotDot, sl, sc, start, l2.pos))
        } else {
          Step(l1, tok(TkDot, sl, sc, start, l1.pos))
        }
      }
      else if c == '#' {
        # m12.8: `#derive` is a single token; the `#` here cannot be a
        # comment because lex_skip_ws only forwards `#` here when it is
        # immediately followed by `derive` and a non-alphanumeric tail.
        let l_end = lex_advance_n(l1, 6)
        Step(l_end, tok(TkDerive, sl, sc, start, l_end.pos))
      }
      else {
        let msg = string_concat("unexpected character '", string_concat("#{c}", "'"))
        Step(l1, tok(TkError(msg), sl, sc, start, l1.pos))
      }
    }
  }
}

fn lex_advance_n(l: Lexer, n: Int) : Lexer {
  if n <= 0 { l } else { lex_advance_n(lex_advance(l), n - 1) }
}

# ====================================================================
# dispatch: one token
# ====================================================================

fn lex_next(l: Lexer) : LexStep {
  let l0 = lex_skip_ws(l)
  let sl = l0.line
  let sc = l0.col
  match lex_peek(l0) {
    None -> Step(l0, tok(TkEof, sl, sc, l0.pos, l0.pos))
    Some(c) -> {
      if c == '\n' {
        let l1 = lex_advance(l0)
        Step(l1, tok(TkNewline, sl, sc, l0.pos, l1.pos))
      }
      else if ch_is_alpha(c) { lex_ident(l0) }
      else if ch_is_digit(c) { lex_number(l0) }
      else if c == '"' { lex_string(l0) }
      else if c == '\'' { lex_char(l0) }
      else { lex_punct(l0) }
    }
  }
}

# Build the full token list. Accumulate in reverse for O(1) prepend, then
# list_reverse once at the end.
fn lex_loop(l: Lexer, acc: [Token]) : [Token] {
  match lex_next(l) {
    Step(l1, t) -> {
      let acc1 = [t, ...acc]
      match t.kind {
        TkEof -> list_reverse(acc1)
        _ -> lex_loop(l1, acc1)
      }
    }
  }
}

fn tokenize(src: String) : [Token] {
  lex_loop(lex_new(src), [])
}

# ====================================================================
# token dump (for --tokens)
# ====================================================================

fn tok_text(src: String, t: Token) : String = string_slice(src, t.start, t.length)

fn tok_line_str(t: Token) : String = int_to_string(t.line)
fn tok_col_str(t: Token)  : String = int_to_string(t.col)

fn dump_token(src: String, t: Token) : Unit / Console {
  match t.kind {
    TkNewline -> print("#{tok_line_str(t)}:#{tok_col_str(t)}  NEWLINE")
    TkError(msg) -> eprint("#{tok_line_str(t)}:#{tok_col_str(t)}  ERROR  #{msg}")
    _ -> {
      let text = tok_text(src, t)
      print("#{tok_line_str(t)}:#{tok_col_str(t)}  #{tk_name(t.kind)}  \"#{text}\"")
    }
  }
}

fn dump_tokens(src: String, tokens: [Token]) : Unit {
  tokens |> each((t) => dump_token(src, t))
}

# ====================================================================
# diagnostics
# ====================================================================
#
# Rust-style source snippets for error reporting. A diagnostic site
# (file, line, col) renders as:
#
#     error: <msg>
#       --> foo.kai:5:12
#        |
#      5 | let x = bar(42)
#        |         ^
#
# Caret is placed by byte column, which matches the (line, col) kept
# on tokens and AST nodes. Multi-byte characters in source therefore
# shift the caret rightwards of the logical glyph — acceptable for
# the ASCII-heavy code we compile, and easy to replace later with
# a codepoint-aware locator.

# Build a string of `n` spaces in a single allocation via string_slice.
# Sidesteps the O(n²) fold of string_concat(acc, " "). 128 is the
# widest line-number gutter we plausibly print; grow on demand.
fn spaces(n: Int) : String {
  if n <= 0 { "" }
  else if n <= 128 { string_slice(spaces_pool(), 0, n) }
  else { string_concat(spaces_pool(), spaces(n - 128)) }
}

fn spaces_pool() : String =
  "                                                                                                                                "

# Extract the `n`-th (1-indexed) line from `src`, without the trailing
# newline. Two passes of char_at to locate [start, end) in the source,
# then a single string_slice — avoids the O(m²) per-char acc build.
fn nth_line(src: String, n: Int) : Option[String] {
  if n <= 0 { None }
  else {
    let total = string_length(src)
    let start = nth_line_start(src, 0, total, 1, n)
    if start < 0 { None }
    else {
      let end = scan_to_newline(src, start, total)
      Some(string_slice(src, start, end - start))
    }
  }
}

# Walk forward returning the byte offset where the target'th line
# starts, or -1 if the source ends first.
fn nth_line_start(src: String, i: Int, total: Int, cur: Int, target: Int) : Int {
  if cur == target { i }
  else if i >= total { -1 }
  else {
    match char_at(src, i) {
      None -> -1
      Some(c) -> {
        if c == '\n' { nth_line_start(src, i + 1, total, cur + 1, target) }
        else { nth_line_start(src, i + 1, total, cur, target) }
      }
    }
  }
}

fn scan_to_newline(src: String, i: Int, total: Int) : Int {
  if i >= total { total }
  else {
    match char_at(src, i) {
      None -> total
      Some(c) -> if c == '\n' { i } else { scan_to_newline(src, i + 1, total) }
    }
  }
}

# Render a snippet to stderr. `src` is the source of the entry file;
# for imported modules we re-read on the fly (see emit_source_caret).
fn emit_src_snippet(line: Int, col: Int, src_line: String) : Unit / Console {
  let num = int_to_string(line)
  let margin = spaces(string_length(num))
  eprint("  #{margin} |")
  eprint("  #{num} | #{src_line}")
  let caret_gap = if col > 1 { spaces(col - 1) } else { "" }
  eprint("  #{margin} | #{caret_gap}^")
}

fn emit_source_caret_from_src(src: String, line: Int, col: Int) : Unit {
  match nth_line(src, line) {
    None       -> ()
    Some(text) -> emit_src_snippet(line, col, text)
  }
}

# Self-contained variant: takes a path, reads it, and emits the
# snippet. Used by diagnostics that don't already have the source
# threaded through (most checker/infer sites).
fn emit_source_caret(file: String, line: Int, col: Int) : Unit / File {
  match read_file(file) {
    Err(_)  -> ()
    Ok(src) -> emit_source_caret_from_src(src, line, col)
  }
}

fn diag_error(file: String, line: Int, col: Int, msg: String) : Unit / Console {
  eprint("error: #{msg}")
  eprint("  --> #{file}:#{int_to_string(line)}:#{int_to_string(col)}")
  emit_source_caret(file, line, col)
}

fn diag_note(msg: String) : Unit / Console = eprint("  = note: #{msg}")
fn diag_help(msg: String) : Unit / Console = eprint("  = help: #{msg}")

# Levenshtein edit distance for "did you mean?" suggestions. Plain
# DP over rows, immutable — each row is a freshly-built list. Small
# strings + small scope means cost is negligible in practice; we
# only pay on the error path.

fn min3(a: Int, b: Int, c: Int) : Int {
  let ab = if a < b { a } else { b }
  if ab < c { ab } else { c }
}

fn row_at(xs: [Int], i: Int) : Int {
  match xs {
    [] -> 0
    [h, ...rest] -> if i == 0 { h } else { row_at(rest, i - 1) }
  }
}

fn row_head(xs: [Int]) : Int {
  match xs {
    [] -> 0
    [h, ...rest] -> h
  }
}

fn int_range_list(lo: Int, hi: Int) : [Int] = int_range_list_loop(lo, hi, [])

fn int_range_list_loop(i: Int, hi: Int, acc: [Int]) : [Int] {
  if i >= hi { list_reverse(acc) }
  else { int_range_list_loop(i + 1, hi, [i, ...acc]) }
}

fn char_eq_at(a: String, ai: Int, b: String, bi: Int) : Bool {
  match char_at(a, ai) {
    None -> false
    Some(ac) -> match char_at(b, bi) {
      None -> false
      Some(bc) -> ac == bc
    }
  }
}

fn lev_row_loop(a: String, b: String, i: Int, n: Int,
                prev: [Int], j: Int, acc: [Int]) : [Int] {
  if j > n { list_reverse(acc) }
  else {
    let cost = if char_eq_at(a, i - 1, b, j - 1) { 0 } else { 1 }
    let above = row_at(prev, j)         # d[i-1][j]
    let left  = row_head(acc)           # d[i][j-1]
    let diag  = row_at(prev, j - 1)     # d[i-1][j-1]
    let cell  = min3(above + 1, left + 1, diag + cost)
    lev_row_loop(a, b, i, n, prev, j + 1, [cell, ...acc])
  }
}

fn lev_row(a: String, b: String, i: Int, n: Int, prev: [Int]) : [Int] =
  lev_row_loop(a, b, i, n, prev, 1, [i])

fn lev_rows(a: String, b: String, m: Int, n: Int, i: Int, prev: [Int]) : Int {
  if i > m { row_at(prev, n) }
  else { lev_rows(a, b, m, n, i + 1, lev_row(a, b, i, n, prev)) }
}

fn levenshtein(a: String, b: String) : Int {
  let m = string_length(a)
  let n = string_length(b)
  let row0 = int_range_list(0, n + 1)
  lev_rows(a, b, m, n, 1, row0)
}

# Return the candidate whose Levenshtein distance to `target` is
# smallest, provided it's within `max_dist`. If several tie, keep
# the first one in order (matches insertion order of the scope,
# which is nearest-first by virtue of list prepending).
fn abs_int(n: Int) : Int = if n < 0 { 0 - n } else { n }

fn closest_name_loop(target: String, cands: [String], max_dist: Int,
                     best: Option[String], best_d: Int) : Option[String] {
  match cands {
    [] -> best
    [c, ...rest] -> {
      let la = string_length(target)
      let lb = string_length(c)
      if abs_int(la - lb) > max_dist {
        closest_name_loop(target, rest, max_dist, best, best_d)
      } else {
        let d = levenshtein(target, c)
        if d < best_d and d <= max_dist {
          closest_name_loop(target, rest, max_dist, Some(c), d)
        } else {
          closest_name_loop(target, rest, max_dist, best, best_d)
        }
      }
    }
  }
}

fn closest_name(target: String, cands: [String]) : Option[String] {
  # Cap at 3 to keep suggestions confident; otherwise completely
  # unrelated names start showing up on short identifiers.
  closest_name_loop(target, cands, 3, None, 999999)
}

fn diag_error_from_src(file: String, src: String, line: Int, col: Int, msg: String) : Unit / Console {
  eprint("error: #{msg}")
  eprint("  --> #{file}:#{int_to_string(line)}:#{int_to_string(col)}")
  emit_source_caret_from_src(src, line, col)
}

# ====================================================================
# error scanning
# ====================================================================

fn report_one_error(path: String, src: String, t: Token, msg: String) : Unit =
  diag_error_from_src(path, src, t.line, t.col, msg)

fn report_errors_loop(path: String, src: String, ts: [Token], count: Int) : Int {
  match ts {
    [] -> count
    [t, ...rest] -> match t.kind {
      TkError(msg) -> {
        report_one_error(path, src, t, msg)
        report_errors_loop(path, src, rest, count + 1)
      }
      _ -> report_errors_loop(path, src, rest, count)
    }
  }
}

# Returns 0 on success, 1 if any TkError tokens appeared (all reported to stderr).
fn report_errors(path: String, src: String, tokens: [Token]) : Int {
  if report_errors_loop(path, src, tokens, 0) > 0 { 1 } else { 0 }
}

# ====================================================================
# AST types
# ====================================================================

# Expressions carry their source position on the wrapper, so variants
# stay compact. Pattern matching on expressions therefore destructures
# the record to reach `.kind`, then matches the sum.

type Expr = { kind: ExprKind, line: Int, col: Int, ty: Option[Ty] }

type ExprKind
  = EInt(Int)
  | EReal(Real)
  | EBool(Bool)
  | EChar(Char)
  | EStr(String, Bool)                      # raw source span (includes quotes), is_triple
  | EUnit
  | EVar(String)
  | EUnder                                  # `_` (pattern context only, but lexer produces it anywhere)
  | EPlaceholder                            # `.` placeholder (stage 1 extension; stage 0 rejects)
  | ECall(Expr, [Expr])
  | EField(Expr, String)
  | EIndex(Expr, Expr)
  | EBinop(String, Expr, Expr)
  | EUnop(String, Expr)                     # "-" or "not"
  | EIf(Expr, Expr, Option[Expr])
  | EMatch(Expr, [Arm])
  | ELambda([Param], Expr)
  | ERecordLit(String, [FieldInit])
  | EList([ListElem])
  | ERange(Expr, Expr, Option[Expr])
  | EBlock([Stmt], Option[Expr])
  | EPipe(Expr, Expr)
  # Typed hole (M10). `None` payload → anonymous `?`. `Some(name)` →
  # `?name`. Checker reports at each hole site; emitter falls back
  # to a runtime panic so unfilled holes in a binary are loud.
  | EHole(Option[String])
  # m7d §1: `todo!(msg) : T` — a typed *unimplemented* marker. The
  # message is a literal `String` extracted at parse time. Behaves
  # like `EHole(None)` for inference (any expected type fits) and
  # like a panic at runtime, but the checker reports it under a
  # distinct `kind = "todo"` so tooling can tell `?` apart from
  # "I will fill this in" markers.
  | ETodo(String)
  # m7e §13: `expr!` — postfix `Option`/`Result` propagation.
  # `e!` on `Option[T]` unwraps `Some(x) -> x`; `None` short-circuits
  # with `return None` from the enclosing function. On `Result[E, T]`,
  # `Ok(x) -> x`; `Err(e)` short-circuits with `return Err(e)`. The
  # enclosing function's return type must be the matching `Option[U]`
  # or `Result[E, U]` (same E — no `From`-style coercion). The typer
  # validates the enclosing return type and stamps `x.ty` with the
  # unwrapped success type, which the emitter consumes to choose the
  # correct discriminator (`Some` / `Ok`).
  | EBang(Expr)
  # Effect handler (m7a #4b). `handle { body } with Eff [as alias]
  # { clauses [return(x) -> expr] }`. The `alias` (Option[String])
  # rebinds the capability name inside the body. m7a #4b is parser
  # only; type-checking and runtime are #4d / #6.
  # m7b #11: parametric effects. `eff_tyargs` is the `[T1, T2]` after
  # the effect name in `with Reader[Int]` (empty when none); `init_opt`
  # is the `(init)` after the type args in `with State[Int](0)` form
  # (None when the handler is stateless). Both extensions are inert
  # for stateless effects, so existing handlers parse to `[]` /
  # `None` and behave as before.
  | EHandle(Expr, String, [TypeExpr], Option[Expr], Option[String], [HClause], Option[HReturn])
  # m12.5: numeric literal annotated with a unit, e.g. `1.50<USD>` or
  # `42<UserId>`. The inner Expr is always EInt or EReal; the
  # UnitExprT comes from the source between the angle brackets.
  | ELitUnit(Expr, UnitExprT)
  # m7e §11: `variants[T]()` — enumerate the constructors of a sum
  # type T whose every variant is nullary. The compiler has the
  # constructor list after resolution; this node is a request to
  # materialise it as a `[T]` literal in declaration order. The
  # `()` suffix is required by the syntax but carries no payload —
  # the parser rejects any argument list. Parser produces this via
  # an explicit lookahead in `parse_ident_primary` when the source
  # ident is `variants` and the next token is `[`. Resolver
  # validates T (sum + nullary-only). Emitter materialises the
  # ordered constructor list.
  | EVariantsOf(TypeExpr)

type ListElem = ElPlain(Expr) | ElSpread(Expr)

type Arm = Arm(Pattern, Option[Expr], Expr)

type FieldInit = FI(String, Expr)

type Param = { pname: String, ptype: Option[TypeExpr], pline: Int, pcol: Int }

type Stmt
  = SLet(Pattern, Option[TypeExpr], Expr)
  | SAssert(Expr, Option[Expr])
  | SExprStmt(Expr)
  # m7b #6: indexed write `a[i] := v` (with `a` an `Ident ("." Ident)*`
  # field path). Lowered to a `Mutable.array_set`-style call by the
  # pre-resolve `desugar_index_assign` pass; never reaches the checker.
  | SIndexAssign(Expr, Expr, Expr, Int, Int)
  # m7b #5: local mutable cell `var name [: T] = init`. The parser
  # produces this node; the pre-resolve `desugar_var_decls` pass
  # rewrites every block containing an SVar into the canonical
  # `handle { rest } with State[T](init) as name { canonical clauses }`
  # form (Doc B §`State[T]` *Syntax note*, Doc C §m7b #5). SVar
  # therefore never reaches the resolver. The line/col point at the
  # `var` keyword.
  | SVar(String, Option[TypeExpr], Expr, Int, Int)

type Pattern = { pkind: PatKind, line: Int, col: Int }

type PatKind
  = PWild
  | PLit(Expr)                              # literal pattern (stores an Expr of literal shape)
  | PBind(String)
  | PList([Pattern], Option[String])         # fixed sub-patterns, optional rest binder name
  | PVariant(String, [Pattern])
  | PVariantRecord(String, [PField])
  | PRecord([PField])
  | PHole(Option[String])                   # `?` or `?name` in pattern position
  # m7d §14: `name @ pattern` — bind the whole scrutinee to `name`
  # while still destructuring it as `pattern`. The bound name must
  # be a fresh identifier; the inner pattern's bindings (if any)
  # remain visible in the arm body. Disjoint from m7b §2's prefix
  # `@cap` (an expression), which never appears in pattern position.
  | PAs(String, Pattern)

type PField = PField(String, Pattern, Bool) # field name, sub-pattern, is_shorthand

type TypeExpr = { tkind: TyKind, line: Int, col: Int }

type TyKind
  = TyName(String, [TypeExpr])              # Name or Name[T1, T2, ...]
  | TyList(TypeExpr)
  | TyFn([TypeExpr], TypeExpr, RowExpr)
  # m12.5: dimensioned numeric type, e.g. `Real<USD>` or `Int<m/sec>`.
  # The base TypeExpr is the underlying primitive (parser only ever
  # produces this with `Real`/`Int` underneath); the UnitExprT carries
  # the unit annotation that the typer canonicalises and unifies.
  | TyDim(TypeExpr, UnitExprT)

# Syntactic effect row: REmpty for `T` (no `/`), RClosed for `T / Io
# + Fail`, ROpen for `T / Io + e` or `T / e` where the lowercase tail
# `e` is a row variable scoped to the enclosing function declaration
# (m7b #12). In the AST this is the *raw* parsed shape; resolve_ty
# converts it into the semantic `Row` that lives inside `TyFnT`.
#
# m7b #11: each label carries optional type arguments (`Reader[Int]`
# parses as `RL("Reader", [TyName("Int", [])])`). Stateless effects
# (and pre-m7b #11 syntax) carry an empty arg list. ROpen merges m7b
# #11 (parametric labels) with m7b #12 (open row variable in tail).
type RowExpr = REmpty | RClosed([RowLabel]) | ROpen(String, [RowLabel])
type RowLabel = RL(String, [TypeExpr])

# m12.5: units of measure. UnitExprT is a tree of unit operations.
# The canonicaliser flattens it to a sorted vector of (sym, exponent).
# UVar appears only at the semantic level — the parser produces only
# the other shapes; UVar is allocated by the unifier for unit
# inference variables (parallel to TyVarT).
type UnitExprT
  = UOne                                    # the dimensionless unit "1"
  | USym(String)                            # atomic unit name (USD, m, kg)
  | UMul(UnitExprT, UnitExprT)              # product
  | UInv(UnitExprT)                          # multiplicative inverse
  | UPow(UnitExprT, Int)                     # integer power
  | UVar(Int)                                # unit unification variable

# m12.5: kind of a type parameter. KType is the default; KUnit marks a
# parameter that ranges over units rather than types (`[u: Unit]`).
# Kinds are encoded inside the tparam name with a "#Unit" suffix so
# the existing `tparams: [String]` plumbing keeps working unchanged.
type Kind = KType | KUnit

# Handler clause (op): `op_name(args..., resume) -> body`. The
# resume binding is conventionally the last param; m7a #4d will
# validate. m7a #4b stores the param list verbatim.
type HClause = HC(String, [Param], Expr, Int, Int)

# Optional `return(x) -> expr` clause inside a handle. `pname` is
# the parameter name bound inside `body`.
type HReturn = HR(String, Expr, Int, Int)

type Decl
  # m7b #13: optional type parameters on the function declaration —
  # `pub fn id[T](x: T) : T = x`. Empty list for monomorphic decls.
  # Each name in tparams is a quantified type variable in scope across
  # the param types, return type, row, and body. Generalised in
  # fn_scheme_of_decl so each call site fresh-instantiates.
  = DFn(Bool, String, [String], [Param], Option[TypeExpr], RowExpr, Expr, Int, Int)
  | DType(Bool, String, [String], TypeBody, Int, Int)
  | DTest(String, Expr, Int, Int)
  | DImport(ImportKind, Int, Int)
  # m7b #11: optional type parameters on the effect declaration —
  # `effect Reader[T] { ask() : T }`. Empty list for stateless effects.
  | DEffect(Bool, String, [String], [EffectOp], Int, Int)
  # m12.8: `protocol P { op_decls }` — single-dispatch ad-hoc
  # polymorphism. Each ProtoOp carries a parameter list using `Self`
  # as the first-position dispatch type. Defaults are not parsed in
  # the v1 (the parser only accepts bodyless op signatures).
  | DProtocol(Bool, String, [ProtoOp], Int, Int)
  # m12.8: `impl P for T { fn op(args) = body ... }` — supplies the
  # ops of protocol `pname` for the concrete type `target`. The body
  # decls live as ordinary DFns whose name is the op name (no
  # mangling at parse time; the lower-protocols pass renames them to
  # `__pimpl_<P>_<T>_<op>`).
  | DImpl(String, TypeExpr, [Decl], Int, Int)
  # m12.8: `#derive(P, ...) type T = ...` — opt-in structural impl
  # generator. The lower-protocols pass walks the type body and
  # synthesises one DImpl per derived protocol. The parser keeps the
  # annotation alongside the wrapped DType so the desugar pass has all
  # the data in one node.
  | DDerive([String], Decl, Int, Int)
  # m12.5: unit declaration. `unit USD` (alias = None) introduces an
  # atomic unit symbol; `unit Newton = kg * m / sec^2` (alias = Some)
  # introduces a named alias whose RHS the resolver expands eagerly
  # before unification ever runs. Codegen emits nothing for DUnit.
  | DUnit(Bool, String, Option[UnitExprT], Int, Int)

# m12.8: a single operation declared inside a `protocol P { ... }`
# block. Mirrors EffectOp's shape (no body, with optional generic
# tparams), but lives in its own type so the resolver / typer can
# distinguish protocol ops from effect ops cleanly.
type ProtoOp = POp(String, [String], [Param], TypeExpr, Int, Int)

# An operation declared inside an `effect Eff { ... }` block.
# name[op_tparams](params) : ret_ty — no body, no `fn` keyword.
# m7b #2: per-op type generics. `op_tparams` is the optional
# `[T1, T2]` between op name and `(args)`. Empty for monomorphic
# ops; non-empty when the op signature itself quantifies over
# types (Doc B §`Mutable`'s `array_get[T]`, etc.).
type EffectOp = EOp(String, [String], [Param], TypeExpr, Int, Int)

# TBEffectAlias holds a closed sum of effect labels, e.g.
# `type Io = Console + Stdin + Env + File` (m7b #1). The body is a
# list of label names; non-effect labels and cycles are rejected at
# resolve time. Single-effect aliases (`type Foo = Console`) parse as
# TBAlias(TyName(name, [])) and are recognised at resolve time.
type TypeBody = TBAlias(TypeExpr) | TBRecord([FieldDecl]) | TBSum([Variant]) | TBEffectAlias([String])
type FieldDecl = FD(String, TypeExpr)
type Variant = Var(String, [TypeExpr])

type ImportKind
  = IkPath(String)
  | IkAlias(String, String)
  | IkSelective(String, [String])

# ---- small constructors ----
fn mk_expr(k: ExprKind, line: Int, col: Int) : Expr = Expr { kind: k, line: line, col: col, ty: None }

# Return a copy of `e` with its inferred type set. Used by `synth` to
# hand back a typed expression tree alongside its Ty. Downstream passes
# (emitter today ignores it; M3/M4 will consume) can traverse the tree
# and read `.ty` at each node without re-running inference.
fn with_ty(e: Expr, t: Ty) : Expr =
  Expr { kind: e.kind, line: e.line, col: e.col, ty: Some(t) }
fn mk_pat(k: PatKind, line: Int, col: Int) : Pattern = Pattern { pkind: k, line: line, col: col }
fn mk_ty(k: TyKind, line: Int, col: Int) : TypeExpr = TypeExpr { tkind: k, line: line, col: col }

# ====================================================================
# parser state
# ====================================================================
#
# The Parser is immutable; each helper returns a new one with `rest`
# advanced and `had_error` possibly flipped. We don't carry a token
# index — `rest` is the unconsumed suffix of the token list, so
# p_advance is O(1) (takes tail). Peek-ahead uses list destructuring
# up to depth 3, which covers every lookahead stage 0 does.

type Parser = { file: String, src: String, rest: [Token], had_error: Bool,
                # m7b §1: trailing lambdas attach to Calls, but the
                # condition of `if` / `match` (and similar prefix
                # constructs that take an Expr followed by a `{`-block)
                # must not consume the `{` as a trailing lambda. This
                # flag is set to false while parsing such a cond and
                # restored when the cond parser finishes.
                allow_trailing_lambda: Bool }

# A result = a new parser plus an optional payload. `None` means the
# parser failed (had_error is set on `p`). This mirrors stage 0's
# error-then-stop style.

type PExpr   = { p: Parser, r: Option[Expr] }
type PStmt   = { p: Parser, r: Option[Stmt] }
type PPat    = { p: Parser, r: Option[Pattern] }
type PTy     = { p: Parser, r: Option[TypeExpr] }
type PDecl   = { p: Parser, r: Option[Decl] }
type PArm    = { p: Parser, r: Option[Arm] }
type PParam  = { p: Parser, r: Option[Param] }
type PFI     = { p: Parser, r: Option[FieldInit] }
type PVar    = { p: Parser, r: Option[Variant] }
type PFD     = { p: Parser, r: Option[FieldDecl] }
type PPF     = { p: Parser, r: Option[PField] }
type PEL     = { p: Parser, r: Option[ListElem] }

fn parser_new(file: String, src: String, toks: [Token]) : Parser =
  Parser { file: file, src: src, rest: toks, had_error: false, allow_trailing_lambda: true }

fn p_mark_err(p: Parser) : Parser =
  Parser { file: p.file, src: p.src, rest: p.rest, had_error: true,
           allow_trailing_lambda: p.allow_trailing_lambda }

fn p_advance(p: Parser) : Parser {
  match p.rest {
    [_, ...rest1] -> Parser { file: p.file, src: p.src, rest: rest1,
                              had_error: p.had_error,
                              allow_trailing_lambda: p.allow_trailing_lambda }
    [] -> p
  }
}

# A sentinel EOF token used when peeking past the list end. In practice
# the tokenizer always appends a TkEof, so we rarely hit this.
fn eof_tok() : Token = Token { kind: TkEof, line: 0, col: 0, start: 0, length: 0 }

fn p_peek(p: Parser) : Token {
  match p.rest {
    [t, ...rs] -> t
    [] -> eof_tok()
  }
}

fn p_peek1(p: Parser) : Token {
  match p.rest {
    [_, t, ...rs] -> t
    _ -> eof_tok()
  }
}

fn p_peek2(p: Parser) : Token {
  match p.rest {
    [_, _, t, ...rs] -> t
    _ -> eof_tok()
  }
}

# Token-kind comparison by structural case (TkError is the only payload-
# carrying variant, and we never compare it for equality in the parser).
fn tk_is(a: TokKind, b: TokKind) : Bool {
  match a {
    TkEof        -> match b { TkEof -> true _ -> false }
    TkNewline    -> match b { TkNewline -> true _ -> false }
    TkAnd        -> match b { TkAnd -> true _ -> false }
    TkAs         -> match b { TkAs -> true _ -> false }
    TkAssert     -> match b { TkAssert -> true _ -> false }
    TkEffect     -> match b { TkEffect -> true _ -> false }
    TkElse       -> match b { TkElse -> true _ -> false }
    TkFalse      -> match b { TkFalse -> true _ -> false }
    TkFn         -> match b { TkFn -> true _ -> false }
    TkFor        -> match b { TkFor -> true _ -> false }
    TkHandle     -> match b { TkHandle -> true _ -> false }
    TkIf         -> match b { TkIf -> true _ -> false }
    TkImpl       -> match b { TkImpl -> true _ -> false }
    TkImport     -> match b { TkImport -> true _ -> false }
    TkLet        -> match b { TkLet -> true _ -> false }
    TkMatch      -> match b { TkMatch -> true _ -> false }
    TkNot        -> match b { TkNot -> true _ -> false }
    TkOr         -> match b { TkOr -> true _ -> false }
    TkProtocol   -> match b { TkProtocol -> true _ -> false }
    TkPub        -> match b { TkPub -> true _ -> false }
    TkTest       -> match b { TkTest -> true _ -> false }
    TkTrue       -> match b { TkTrue -> true _ -> false }
    TkType       -> match b { TkType -> true _ -> false }
    TkUnitKw     -> match b { TkUnitKw -> true _ -> false }
    TkVar        -> match b { TkVar -> true _ -> false }
    TkWith       -> match b { TkWith -> true _ -> false }
    TkInt        -> match b { TkInt -> true _ -> false }
    TkReal       -> match b { TkReal -> true _ -> false }
    TkChar       -> match b { TkChar -> true _ -> false }
    TkString     -> match b { TkString -> true _ -> false }
    TkIdent      -> match b { TkIdent -> true _ -> false }
    TkUnderscore -> match b { TkUnderscore -> true _ -> false }
    TkLparen     -> match b { TkLparen -> true _ -> false }
    TkRparen     -> match b { TkRparen -> true _ -> false }
    TkLbracket   -> match b { TkLbracket -> true _ -> false }
    TkRbracket   -> match b { TkRbracket -> true _ -> false }
    TkLbrace     -> match b { TkLbrace -> true _ -> false }
    TkRbrace     -> match b { TkRbrace -> true _ -> false }
    TkComma      -> match b { TkComma -> true _ -> false }
    TkColon      -> match b { TkColon -> true _ -> false }
    TkColonEq    -> match b { TkColonEq -> true _ -> false }
    TkSemi       -> match b { TkSemi -> true _ -> false }
    TkDot        -> match b { TkDot -> true _ -> false }
    TkDotDot     -> match b { TkDotDot -> true _ -> false }
    TkEllipsis   -> match b { TkEllipsis -> true _ -> false }
    TkEq         -> match b { TkEq -> true _ -> false }
    TkArrow      -> match b { TkArrow -> true _ -> false }
    TkFatArrow   -> match b { TkFatArrow -> true _ -> false }
    TkPipe       -> match b { TkPipe -> true _ -> false }
    TkPipeApply  -> match b { TkPipeApply -> true _ -> false }
    TkPlus       -> match b { TkPlus -> true _ -> false }
    TkMinus      -> match b { TkMinus -> true _ -> false }
    TkStar       -> match b { TkStar -> true _ -> false }
    TkSlash      -> match b { TkSlash -> true _ -> false }
    TkSlashSlash -> match b { TkSlashSlash -> true _ -> false }
    TkPercent    -> match b { TkPercent -> true _ -> false }
    TkEqEq       -> match b { TkEqEq -> true _ -> false }
    TkNeq        -> match b { TkNeq -> true _ -> false }
    TkLt         -> match b { TkLt -> true _ -> false }
    TkGt         -> match b { TkGt -> true _ -> false }
    TkLe         -> match b { TkLe -> true _ -> false }
    TkGe         -> match b { TkGe -> true _ -> false }
    TkBang       -> match b { TkBang -> true _ -> false }
    TkAt         -> match b { TkAt -> true _ -> false }
    TkCaret      -> match b { TkCaret -> true _ -> false }
    TkHole       -> match b { TkHole -> true _ -> false }
    TkHoleName(_) -> match b { TkHoleName(_) -> true _ -> false }
    TkTodoBang   -> match b { TkTodoBang -> true _ -> false }
    TkPlusPlus   -> match b { TkPlusPlus -> true _ -> false }
    TkDerive     -> match b { TkDerive -> true _ -> false }
    TkError(_)   -> false
  }
}

fn p_at(p: Parser, k: TokKind) : Bool = tk_is(p_peek(p).kind, k)

fn p_try_consume(p: Parser, k: TokKind) : Option[Parser] {
  if p_at(p, k) { Some(p_advance(p)) } else { None }
}

fn p_skip_newlines(p: Parser) : Parser {
  if p_at(p, TkNewline) { p_skip_newlines(p_advance(p)) } else { p }
}

# m7b §1: temporarily disable trailing-lambda attachment for the
# parser passed in (used by `if` / `match` cond parsing). Returns
# a parser identical except for the flag. The caller is expected
# to restore the original flag value after the cond parses by
# threading the flag back via `p_with_trailing_lambda(p, true)`.
fn p_with_trailing_lambda(p: Parser, allow: Bool) : Parser {
  Parser { file: p.file, src: p.src, rest: p.rest, had_error: p.had_error,
           allow_trailing_lambda: allow }
}

fn p_skip_newlines_and_semis(p: Parser) : Parser {
  if p_at(p, TkNewline) or p_at(p, TkSemi) { p_skip_newlines_and_semis(p_advance(p)) }
  else { p }
}

fn p_error(p: Parser, t: Token, msg: String) : Parser {
  if p.had_error { p }
  else {
    diag_error_from_src(p.file, p.src, t.line, t.col, msg)
    p_mark_err(p)
  }
}

fn p_error_here(p: Parser, msg: String) : Parser = p_error(p, p_peek(p), msg)

fn p_expect(p: Parser, k: TokKind, msg: String) : PExpr {
  # PExpr is a misnomer — we just reuse the record structure. We return
  # an Expr-less PExpr; callers that need the consumed token use
  # p_expect_tok instead. This variant is a convenience for "advance
  # past a required delimiter".
  if p_at(p, k) { PExpr { p: p_advance(p), r: Some(mk_expr(EUnit, 0, 0)) } }
  else { PExpr { p: p_error_here(p, msg), r: None } }
}

# Same, but returns the consumed token in the Option payload slot (as an
# EStr carrying the raw span — caller decodes).
fn p_expect_tok(p: Parser, k: TokKind, msg: String) : Token {
  if p_at(p, k) { p_peek(p) }
  else { eof_tok() }
}

fn is_upper_ident(src: String, t: Token) : Bool {
  match char_at(src, t.start) {
    Some(c) -> c >= 'A' and c <= 'Z'
    None -> false
  }
}

fn tok_source(src: String, t: Token) : String = string_slice(src, t.start, t.length)

# ====================================================================
# literal decoders
# ====================================================================

fn decode_int_loop(s: String, i: Int, n: Int, acc: Int, neg: Bool) : Int {
  if i >= n { if neg { 0 - acc } else { acc } }
  else {
    match char_at(s, i) {
      None -> if neg { 0 - acc } else { acc }
      Some(c) -> {
        if c == '_' { decode_int_loop(s, i + 1, n, acc, neg) }
        else if ch_is_digit(c) {
          let d = char_to_int(c) - char_to_int('0')
          decode_int_loop(s, i + 1, n, acc * 10 + d, neg)
        } else {
          if neg { 0 - acc } else { acc }
        }
      }
    }
  }
}

fn decode_int(span: String) : Int {
  let n = string_length(span)
  if n == 0 { 0 }
  else {
    match char_at(span, 0) {
      Some(c) -> if c == '-' { decode_int_loop(span, 1, n, 0, true) }
                 else { decode_int_loop(span, 0, n, 0, false) }
      None -> 0
    }
  }
}

fn strip_underscores_loop(s: String, i: Int, n: Int, acc: String) : String {
  if i >= n { acc }
  else {
    match char_at(s, i) {
      None -> acc
      Some(c) -> {
        if c == '_' { strip_underscores_loop(s, i + 1, n, acc) }
        else { strip_underscores_loop(s, i + 1, n, string_concat(acc, "#{c}")) }
      }
    }
  }
}

fn decode_real(span: String) : Real {
  let clean = strip_underscores_loop(span, 0, string_length(span), "")
  match string_to_real(clean) {
    Some(r) -> r
    None -> 0.0
  }
}

fn decode_char_escape(c: Char) : Char {
  if c == 'n' { '\n' }
  else if c == 't' { '\t' }
  else if c == 'r' { '\r' }
  else if c == '\\' { '\\' }
  else if c == '\'' { '\'' }
  else if c == '"' { '"' }
  else if c == '0' { int_to_char(0) }
  else { c }
}

fn decode_hex_loop(s: String, i: Int, n: Int, acc: Int) : Int {
  if i >= n { acc }
  else {
    match char_at(s, i) {
      None -> acc
      Some(c) -> {
        if c == '}' { acc }
        else {
          let v =
            if ch_is_digit(c) { char_to_int(c) - char_to_int('0') }
            else if c >= 'a' and c <= 'f' { char_to_int(c) - char_to_int('a') + 10 }
            else if c >= 'A' and c <= 'F' { char_to_int(c) - char_to_int('A') + 10 }
            else { 0 }
          decode_hex_loop(s, i + 1, n, acc * 16 + v)
        }
      }
    }
  }
}

# span is the raw char literal including surrounding quotes: 'a', '\n', '\u{2603}'
fn decode_char(span: String) : Char {
  let n = string_length(span)
  if n < 2 { int_to_char(0) }
  else {
    match char_at(span, 1) {
      None -> int_to_char(0)
      Some(c1) -> {
        if c1 == '\\' {
          match char_at(span, 2) {
            None -> int_to_char(0)
            Some(c2) -> {
              if c2 == 'u' {
                int_to_char(decode_hex_loop(span, 4, n - 1, 0))
              } else {
                decode_char_escape(c2)
              }
            }
          }
        } else {
          c1
        }
      }
    }
  }
}

# ====================================================================
# precedence climbing: forward declarations
# ====================================================================
#
# These are implemented below. Listed here as a reading aid.
#  parse_expr   -> parse_pipe
#  parse_pipe   -> parse_or ("|>" parse_or)*
#  parse_or     -> parse_and ("or" parse_and)*
#  parse_and    -> parse_cmp ("and" parse_cmp)*
#  parse_cmp    -> parse_add (cmpop parse_add)?        (no chains)
#  parse_add    -> parse_mul ([+-] parse_mul)*
#  parse_mul    -> parse_unary ([*/%//] parse_unary)*
#  parse_unary  -> ("-" | "not")? parse_postfix
#  parse_postfix-> parse_primary (call | field | index)*
#  parse_primary-> literal | ident | "(" expr ")" | if | match | block | record | list | lambda

fn op_of_tok(k: TokKind) : String {
  match k {
    TkPlus -> "+" TkMinus -> "-" TkStar -> "*" TkSlash -> "/"
    TkSlashSlash -> "//" TkPercent -> "%" TkPlusPlus -> "++"
    TkEqEq -> "==" TkNeq -> "!=" TkLt -> "<" TkGt -> ">" TkLe -> "<=" TkGe -> ">="
    TkAnd -> "and" TkOr -> "or"
    _ -> "?"
  }
}

# ====================================================================
# expression parsing
# ====================================================================

fn ok_e(p: Parser, e: Expr) : PExpr = PExpr { p: p, r: Some(e) }
fn err_e(p: Parser) : PExpr = PExpr { p: p, r: None }
fn ok_s(p: Parser, s: Stmt) : PStmt = PStmt { p: p, r: Some(s) }
fn err_s(p: Parser) : PStmt = PStmt { p: p, r: None }
fn ok_p(p: Parser, x: Pattern) : PPat = PPat { p: p, r: Some(x) }
fn err_p(p: Parser) : PPat = PPat { p: p, r: None }
fn ok_t(p: Parser, x: TypeExpr) : PTy = PTy { p: p, r: Some(x) }
fn err_t(p: Parser) : PTy = PTy { p: p, r: None }
fn ok_d(p: Parser, x: Decl) : PDecl = PDecl { p: p, r: Some(x) }
fn err_d(p: Parser) : PDecl = PDecl { p: p, r: None }
fn ok_a(p: Parser, x: Arm) : PArm = PArm { p: p, r: Some(x) }
fn err_a(p: Parser) : PArm = PArm { p: p, r: None }
fn ok_pm(p: Parser, x: Param) : PParam = PParam { p: p, r: Some(x) }
fn err_pm(p: Parser) : PParam = PParam { p: p, r: None }
fn ok_fi(p: Parser, x: FieldInit) : PFI = PFI { p: p, r: Some(x) }
fn err_fi(p: Parser) : PFI = PFI { p: p, r: None }
fn ok_v(p: Parser, x: Variant) : PVar = PVar { p: p, r: Some(x) }
fn err_v(p: Parser) : PVar = PVar { p: p, r: None }
fn ok_fd(p: Parser, x: FieldDecl) : PFD = PFD { p: p, r: Some(x) }
fn err_fd(p: Parser) : PFD = PFD { p: p, r: None }
fn ok_pf(p: Parser, x: PField) : PPF = PPF { p: p, r: Some(x) }
fn err_pf(p: Parser) : PPF = PPF { p: p, r: None }
fn ok_el(p: Parser, x: ListElem) : PEL = PEL { p: p, r: Some(x) }
fn err_el(p: Parser) : PEL = PEL { p: p, r: None }

fn parse_expr(p: Parser) : PExpr = parse_pipe(p)

fn parse_pipe(p: Parser) : PExpr {
  let r = parse_or(p)
  match r.r {
    None -> r
    Some(lhs) -> parse_pipe_rest(r.p, lhs)
  }
}

# m7d §21 — outcome of a pipeline placeholder substitution attempt.
# `PPRPassthrough` keeps the legacy first-arg behaviour. The other
# two arms either return the substituted call expression (single `_`
# in the rhs args) or report a multiple-placeholder error.
type PPRResult
  = PPRPassthrough
  | PPRSubstituted(Expr, Parser)
  | PPRError(Parser)

fn try_pipe_placeholder(line: Int, col: Int, lhs: Expr, rhs: Expr, p: Parser) : PPRResult {
  match rhs.kind {
    ECall(callee, args_) -> {
      let n = count_underscores(args_, 0)
      if n == 0 { PPRPassthrough }
      else if n > 1 {
        PPRError(p_error(p, p_peek(p),
          "multiple `_` in a `|>` call would evaluate the left-hand side more than once"))
      }
      else {
        # The substitution evaluates the lhs once via an immediate
        # lambda application: `((__pipe) => f(args[_ := __pipe]))(lhs)`.
        # Equivalent to a `let __pipe = lhs in f(...)` block but
        # composes through the existing lambda machinery (closure
        # capture, perceus, monomorphisation) without depending on
        # the SLet -> EBlock walker quirks for sub-expressions
        # synthesised mid-parse.
        let tmp_name = "__pipe"
        let tmp_var = mk_expr(EVar(tmp_name), lhs.line, lhs.col)
        let new_args = subst_underscores(args_, tmp_var)
        let new_call = mk_expr(ECall(callee, new_args), rhs.line, rhs.col)
        let param = Param { pname: tmp_name, ptype: None, pline: lhs.line, pcol: lhs.col }
        let lam = mk_expr(ELambda([param], new_call), line, col)
        let app = mk_expr(ECall(lam, [lhs]), line, col)
        PPRSubstituted(app, p)
      }
    }
    _ -> PPRPassthrough
  }
}

fn count_underscores(es: [Expr], acc: Int) : Int {
  match es {
    [] -> acc
    [h, ...rest] -> match h.kind {
      EUnder -> count_underscores(rest, acc + 1)
      _      -> count_underscores(rest, acc)
    }
  }
}

fn subst_underscores(es: [Expr], replacement: Expr) : [Expr] {
  match es {
    [] -> []
    [h, ...rest] -> match h.kind {
      EUnder -> [replacement, ...subst_underscores(rest, replacement)]
      _      -> [h, ...subst_underscores(rest, replacement)]
    }
  }
}

fn parse_pipe_rest(p: Parser, lhs: Expr) : PExpr {
  # Both `|>` (apply pipe) and `|` (map pipe) sit at the lowest binop
  # level, left-associative. `|` is m7b #9: `xs | f` lowers at parse
  # time to `map(xs, f)` so the rest of the pipeline sees a plain call.
  # The `|` variant separator in `type T = A | B` is parsed by
  # `parse_sum_body`, not the expression grammar, so there is no
  # ambiguity here.
  #
  # The synthetic call binds the prelude's `map`. That contract has
  # three load-bearing entries that must move together: the runtime
  # symbol in `prelude_table` (`EP("map", "kai_prelude_map", 2)`), the
  # type scheme `([a], (a) -> b) -> [b]` in the type env (search
  # `TyEntry { name: "map"`), and the literal `"map"` here. Renaming
  # any one without the others silently breaks this desugar.
  if p_at(p, TkPipeApply) {
    let t = p_peek(p)
    let p1 = p_skip_newlines(p_advance(p))
    let r = parse_or(p1)
    match r.r {
      None -> err_e(r.p)
      Some(rhs) -> {
        # m7d §21: pipeline placeholder. If the rhs is a call whose
        # arg list contains exactly one `_`, the apply pipe lands
        # the lhs at that position instead of as the first arg.
        # `let __pipe = lhs in f(args[_ := __pipe])` — the let
        # binding ensures the lhs is evaluated once, even if it has
        # side effects. The default-first-arg behaviour stays for
        # calls with no `_`. Multiple `_` in the same call would
        # silently duplicate side effects, so we reject them.
        match try_pipe_placeholder(t.line, t.col, lhs, rhs, r.p) {
          PPRError(p2)         -> err_e(p2)
          PPRSubstituted(e, p2) -> parse_pipe_rest(p2, e)
          PPRPassthrough       -> parse_pipe_rest(r.p, mk_expr(EPipe(lhs, rhs), t.line, t.col))
        }
      }
    }
  } else if p_at(p, TkPipe) {
    let t = p_peek(p)
    let p1 = p_skip_newlines(p_advance(p))
    let r = parse_or(p1)
    match r.r {
      None -> err_e(r.p)
      Some(rhs) -> {
        let map_callee = mk_expr(EVar("map"), t.line, t.col)
        let call = mk_expr(ECall(map_callee, [lhs, rhs]), t.line, t.col)
        parse_pipe_rest(r.p, call)
      }
    }
  } else {
    ok_e(p, lhs)
  }
}

fn parse_or(p: Parser) : PExpr {
  let r = parse_and(p)
  match r.r {
    None -> r
    Some(lhs) -> parse_or_rest(r.p, lhs)
  }
}

fn parse_or_rest(p: Parser, lhs: Expr) : PExpr {
  if p_at(p, TkOr) {
    let t = p_peek(p)
    let r = parse_and(p_skip_newlines(p_advance(p)))
    match r.r {
      None -> err_e(r.p)
      Some(rhs) -> parse_or_rest(r.p, mk_expr(EBinop("or", lhs, rhs), t.line, t.col))
    }
  } else {
    ok_e(p, lhs)
  }
}

fn parse_and(p: Parser) : PExpr {
  let r = parse_cmp(p)
  match r.r {
    None -> r
    Some(lhs) -> parse_and_rest(r.p, lhs)
  }
}

fn parse_and_rest(p: Parser, lhs: Expr) : PExpr {
  if p_at(p, TkAnd) {
    let t = p_peek(p)
    let r = parse_cmp(p_skip_newlines(p_advance(p)))
    match r.r {
      None -> err_e(r.p)
      Some(rhs) -> parse_and_rest(r.p, mk_expr(EBinop("and", lhs, rhs), t.line, t.col))
    }
  } else {
    ok_e(p, lhs)
  }
}

fn is_cmp_tok(k: TokKind) : Bool {
  tk_is(k, TkEqEq) or tk_is(k, TkNeq) or tk_is(k, TkLt) or tk_is(k, TkGt) or tk_is(k, TkLe) or tk_is(k, TkGe)
}

# Comparison is deliberately non-associative (see `kaikai-minimal.md`
# → Operator precedence): `a < b < c` is a syntax error, not a chain.
# A plain fall-through would report "expected `fn`, `type`, ..." at
# the outer statement parser, which is useless. Instead, when we see
# a second comparison token right after `lhs OP rhs`, we emit a
# tailored diagnostic pointing at the offending `OP'` and suggesting
# the `and`-based rewrite.
fn parse_cmp(p: Parser) : PExpr {
  let r = parse_concat(p)
  match r.r {
    None -> r
    Some(lhs) -> {
      let t = p_peek(r.p)
      if is_cmp_tok(t.kind) {
        let op = op_of_tok(t.kind)
        let r2 = parse_concat(p_skip_newlines(p_advance(r.p)))
        match r2.r {
          None -> err_e(r2.p)
          Some(rhs) -> {
            let after = p_peek(r2.p)
            if is_cmp_tok(after.kind) {
              let hint = "comparison is non-associative; write `... and ... #{op_of_tok(after.kind)} ...` instead"
              err_e(p_error(r2.p, after, hint))
            } else {
              ok_e(r2.p, mk_expr(EBinop(op, lhs, rhs), t.line, t.col))
            }
          }
        }
      } else { ok_e(r.p, lhs) }
    }
  }
}

# m7d §23 — `++` sits one slot below comparison, one above
# additive (`+`/`-`). Right-associative, so `a ++ b ++ c` parses
# as `a ++ (b ++ c)` — which matches both `string_concat` and
# `list_append` since both are the natural fold direction (no
# spine duplication on the head list / left string).
fn parse_concat(p: Parser) : PExpr {
  let r = parse_add(p)
  match r.r {
    None -> r
    Some(lhs) -> {
      if p_at(r.p, TkPlusPlus) {
        let t = p_peek(r.p)
        let rr = parse_concat(p_skip_newlines(p_advance(r.p)))
        match rr.r {
          None -> err_e(rr.p)
          Some(rhs) -> ok_e(rr.p, mk_expr(EBinop("++", lhs, rhs), t.line, t.col))
        }
      } else { ok_e(r.p, lhs) }
    }
  }
}

fn parse_add(p: Parser) : PExpr {
  let r = parse_mul(p)
  match r.r {
    None -> r
    Some(lhs) -> parse_add_rest(r.p, lhs)
  }
}

fn parse_add_rest(p: Parser, lhs: Expr) : PExpr {
  let t = p_peek(p)
  if tk_is(t.kind, TkPlus) or tk_is(t.kind, TkMinus) {
    let op = op_of_tok(t.kind)
    let r = parse_mul(p_skip_newlines(p_advance(p)))
    match r.r {
      None -> err_e(r.p)
      Some(rhs) -> parse_add_rest(r.p, mk_expr(EBinop(op, lhs, rhs), t.line, t.col))
    }
  } else { ok_e(p, lhs) }
}

fn parse_mul(p: Parser) : PExpr {
  let r = parse_unary(p)
  match r.r {
    None -> r
    Some(lhs) -> parse_mul_rest(r.p, lhs)
  }
}

fn parse_mul_rest(p: Parser, lhs: Expr) : PExpr {
  let t = p_peek(p)
  if tk_is(t.kind, TkStar) or tk_is(t.kind, TkSlash) or tk_is(t.kind, TkSlashSlash) or tk_is(t.kind, TkPercent) {
    let op = op_of_tok(t.kind)
    let r = parse_unary(p_skip_newlines(p_advance(p)))
    match r.r {
      None -> err_e(r.p)
      Some(rhs) -> parse_mul_rest(r.p, mk_expr(EBinop(op, lhs, rhs), t.line, t.col))
    }
  } else { ok_e(p, lhs) }
}

fn parse_unary(p: Parser) : PExpr {
  let t = p_peek(p)
  if tk_is(t.kind, TkMinus) {
    let r = parse_unary(p_advance(p))
    match r.r {
      None -> err_e(r.p)
      Some(e) -> ok_e(r.p, mk_expr(EUnop("-", e), t.line, t.col))
    }
  } else if tk_is(t.kind, TkNot) {
    let r = parse_unary(p_advance(p))
    match r.r {
      None -> err_e(r.p)
      Some(e) -> ok_e(r.p, mk_expr(EUnop("not", e), t.line, t.col))
    }
  } else if tk_is(t.kind, TkAt) {
    # m7b #4: `@cap` desugars to `cap.get()`. The alias rewrite later
    # remaps `Reader[T].get` to `Reader.ask`. Doc B §`Syntax note:
    # capability read/write sugar` rule 3: the identifier after `@`
    # must be a simple capability binding (no dotted paths).
    let p1 = p_advance(p)
    let id = p_peek(p1)
    if not tk_is(id.kind, TkIdent) {
      err_e(p_error(p1, id, "expected capability name after `@`"))
    } else {
      let name = tok_source(p1.src, id)
      let p2 = p_advance(p1)
      let cap = mk_expr(EVar(name), id.line, id.col)
      let getter = mk_expr(EField(cap, "get"), t.line, t.col)
      ok_e(p2, mk_expr(ECall(getter, []), t.line, t.col))
    }
  } else {
    parse_postfix(p)
  }
}

fn parse_postfix(p: Parser) : PExpr {
  let r = parse_primary(p)
  match r.r {
    None -> r
    Some(e) -> parse_postfix_rest(r.p, e)
  }
}

fn parse_postfix_rest(p: Parser, lhs: Expr) : PExpr {
  let t = p_peek(p)
  if tk_is(t.kind, TkLparen) {
    let args_r = parse_call_args(p_advance(p))
    match args_r.r {
      None -> err_e(args_r.p)
      Some(xs) -> {
        # m7b §1/§5: same-line `{` after `f(args)` attaches as a
        # trailing lambda. Up to two consecutive trailings (greedy,
        # both must be on the same line as the previous token).
        # Trailing-lambda attachment is disabled for cond positions
        # (see p_with_trailing_lambda).
        let lam_r = if args_r.p.allow_trailing_lambda {
          parse_trailing_lambdas(args_r.p, xs)
        } else {
          ok_args(args_r.p, xs)
        }
        match lam_r.r {
          None -> err_e(lam_r.p)
          Some(xs1) -> parse_postfix_rest(lam_r.p, mk_expr(ECall(lhs, xs1), t.line, t.col))
        }
      }
    }
  } else if tk_is(t.kind, TkDot) {
    let p1 = p_advance(p)
    let id = p_peek(p1)
    # m7b #5: `var` is a new statement keyword (§3 of syntax-sugars)
    # but also the name of a Doc B `Env` effect op (`Env.var(name)`).
    # Accept `var` here as a field-name token so the keyword does not
    # break existing Env-op call sites.
    if tk_is(id.kind, TkIdent) or tk_is(id.kind, TkVar) {
      let name = tok_source(p.src, id)
      parse_postfix_rest(p_advance(p1), mk_expr(EField(lhs, name), t.line, t.col))
    } else {
      err_e(p_error_here(p1, "expected field name after `.`"))
    }
  } else if tk_is(t.kind, TkLbracket) {
    let p1 = p_advance(p)
    let r = parse_expr(p1)
    match r.r {
      None -> err_e(r.p)
      Some(idx) -> {
        let closed = p_expect(r.p, TkRbracket, "expected `]` after index")
        match closed.r {
          None -> err_e(closed.p)
          Some(_) -> parse_postfix_rest(closed.p, mk_expr(EIndex(lhs, idx), t.line, t.col))
        }
      }
    }
  } else if tk_is(t.kind, TkBang) {
    # m7e §13: `expr!` — postfix Option/Result propagation. Binds
    # tighter than calls and field access can chain through it
    # (`f()!.field`, `xs[0]!`), but binary operators sit lower.
    parse_postfix_rest(p_advance(p), mk_expr(EBang(lhs), t.line, t.col))
  } else if tk_is(t.kind, TkLbrace) and p.allow_trailing_lambda {
    # m7b §1: paren-free trailing lambda — `f { body }` desugars
    # to `f(() => body)`, optionally followed by a second trailing
    # lambda (§5). Same-line is implicit: parse_postfix_rest does
    # not skip newlines, so a `{` appearing here is on the same
    # source line as `lhs`. Disabled inside `if` / `match` conds.
    let lam_r = parse_trailing_lambdas(p, [])
    match lam_r.r {
      None -> err_e(lam_r.p)
      Some(xs1) -> parse_postfix_rest(lam_r.p, mk_expr(ECall(lhs, xs1), t.line, t.col))
    }
  } else {
    ok_e(p, lhs)
  }
}

# m7b §1 + §5 — parse zero, one, or two trailing lambdas after a
# call site. Each trailing lambda must be on the same line as the
# preceding token (parse_postfix_rest never skips newlines, so a
# `TkLbrace` at the head of `p` is by construction same-line).
# `acc` is the call's existing argument list; the parsed lambdas
# are appended in source order. Returns the call's full arg list.
fn parse_trailing_lambdas(p: Parser, acc: [Expr]) : PArgs {
  if p_at(p, TkLbrace) {
    let lr = parse_trailing_lambda(p)
    match lr.r {
      None -> err_args(lr.p)
      Some(lam) -> {
        let acc1 = list_append(acc, [lam])
        if p_at(lr.p, TkLbrace) {
          let lr2 = parse_trailing_lambda(lr.p)
          match lr2.r {
            None -> err_args(lr2.p)
            Some(lam2) -> ok_args(lr2.p, list_append(acc1, [lam2]))
          }
        } else {
          ok_args(lr.p, acc1)
        }
      }
    }
  } else {
    ok_args(p, acc)
  }
}

# Parse a single trailing-lambda `{ (LambdaParams "->")? Block }`.
# Position is at the `{`. Returns an `ELambda(params, body)` where
# `body` is an EBlock (the lambda's body block). The block-form
# `{ x -> body }` desugars to `(x) => body` per syntax-sugars §1.
fn parse_trailing_lambda(p: Parser) : PExpr {
  let t = p_peek(p)
  # Consume `{`.
  let p1 = p_advance(p)
  # Decide between `(LambdaParams "->")? Block`. Peek past optional
  # newlines after `{` to see whether we're staring at a parameter
  # list. The lookahead is bounded: `Ident ("," Ident)* "->"` or
  # just `->` for zero arity.
  let p1n = p_skip_newlines(p1)
  let pp_r = try_parse_lambda_block_params(p1n)
  match pp_r {
    Some(res) -> {
      # `res.p` is positioned right after `->`. Body is a brace-less
      # block of statements terminated by `}`.
      let body_r = parse_lambda_block_body(res.p, t)
      match body_r.r {
        None -> err_e(body_r.p)
        Some(body) -> ok_e(body_r.p, mk_expr(ELambda(res.params, body), t.line, t.col))
      }
    }
    None -> {
      # Zero-arity trailing lambda: no `params ->` prefix. The body
      # is the contents of the brace block. Treat as a lambda with
      # an empty parameter list whose body is the parsed block.
      let body_r = parse_lambda_block_body(p1, t)
      match body_r.r {
        None -> err_e(body_r.p)
        Some(body) -> ok_e(body_r.p, mk_expr(ELambda([], body), t.line, t.col))
      }
    }
  }
}

# Parse the contents of a lambda-block body up to the closing `}`.
# Position is after the optional `params ->` prefix. The body is
# the same shape as a regular block: zero or more statements
# followed by an optional final expression. We reuse the existing
# parse_block_body machinery for this.
fn parse_lambda_block_body(p: Parser, t: Token) : PExpr {
  let p0 = p_skip_newlines_and_semis(p)
  parse_block_body(p0, [], t)
}

# Bounded-lookahead: tentatively scan for `LambdaParams "->"` or
# bare `"->"`. Returns Some(parser-after-arrow, params) on match,
# None otherwise. The scan never consumes tokens of the underlying
# parser on failure (it's a pure predicate over the token stream).
type LamBlockParams = { p: Parser, params: [Param] }

fn try_parse_lambda_block_params(p: Parser) : Option[LamBlockParams] {
  # Zero-arity: `{ -> body }`.
  if p_at(p, TkArrow) {
    Some(LamBlockParams { p: p_advance(p), params: [] })
  } else if p_at(p, TkIdent) {
    try_parse_lambda_block_params_loop(p, [])
  } else {
    None
  }
}

fn try_parse_lambda_block_params_loop(p: Parser, acc: [Param]) : Option[LamBlockParams] {
  let t = p_peek(p)
  if not tk_is(t.kind, TkIdent) { None }
  else {
    let name = tok_source(p.src, t)
    let p1 = p_advance(p)
    let pm = Param { pname: name, ptype: None, pline: t.line, pcol: t.col }
    let acc1 = [pm, ...acc]
    if p_at(p1, TkComma) {
      try_parse_lambda_block_params_loop(p_skip_newlines(p_advance(p1)), acc1)
    } else if p_at(p1, TkArrow) {
      Some(LamBlockParams { p: p_advance(p1), params: list_reverse(acc1) })
    } else {
      None
    }
  }
}

# Parse the argument list of a call. Position is AT the token after the
# opening `(`. Returns with `(` already consumed by caller, `)` to be
# consumed here. Newlines between args are allowed.
type PArgs = { p: Parser, r: Option[[Expr]] }

fn ok_args(p: Parser, xs: [Expr]) : PArgs = PArgs { p: p, r: Some(xs) }
fn err_args(p: Parser) : PArgs = PArgs { p: p, r: None }

fn parse_call_args(p: Parser) : PArgs {
  let p0 = p_skip_newlines(p)
  if p_at(p0, TkRparen) { ok_args(p_advance(p0), []) }
  else { parse_call_args_loop(p0, []) }
}

fn parse_call_args_loop(p: Parser, acc: [Expr]) : PArgs {
  let r = parse_expr(p_skip_newlines(p))
  match r.r {
    None -> err_args(r.p)
    Some(e) -> {
      let p1 = p_skip_newlines(r.p)
      if p_at(p1, TkComma) { parse_call_args_loop(p_skip_newlines(p_advance(p1)), [e, ...acc]) }
      else if p_at(p1, TkRparen) {
        ok_args(p_advance(p1), list_reverse([e, ...acc]))
      }
      else { err_args(p_error_here(p1, "expected `,` or `)` in call arguments")) }
    }
  }
}

# ====================================================================
# primary expressions — placeholders for later implementations
# ====================================================================

# m12.5: after a numeric literal, peek for an *adjacent* `<` (no
# whitespace between the literal and the `<`). When found, parse the
# unit expression and wrap the literal in an ELitUnit. Adjacency is
# the only disambiguator from a comparison `1 < 2`; the spec explicitly
# requires no space between the number and `<`.
fn try_lit_unit_annotation(p: Parser, lit: Expr, lit_tok: Token) : PExpr {
  let nxt = p_peek(p)
  let lit_end = lit_tok.start + lit_tok.length
  if tk_is(nxt.kind, TkLt) and nxt.start == lit_end {
    let p2 = p_skip_newlines(p_advance(p))
    let ru = parse_unit_expr(p2)
    match ru.r {
      None -> err_e(ru.p)
      Some(u) -> {
        let p3 = p_skip_newlines(ru.p)
        if not p_at(p3, TkGt) {
          err_e(p_error_here(p3, "expected `>` to close the unit annotation on a literal"))
        } else {
          ok_e(p_advance(p3), mk_expr(ELitUnit(lit, u), lit_tok.line, lit_tok.col))
        }
      }
    }
  } else {
    ok_e(p, lit)
  }
}

fn parse_primary(p: Parser) : PExpr {
  let t = p_peek(p)
  match t.kind {
    TkInt -> {
      let span = tok_source(p.src, t)
      let lit = mk_expr(EInt(decode_int(span)), t.line, t.col)
      try_lit_unit_annotation(p_advance(p), lit, t)
    }
    TkReal -> {
      let span = tok_source(p.src, t)
      let lit = mk_expr(EReal(decode_real(span)), t.line, t.col)
      try_lit_unit_annotation(p_advance(p), lit, t)
    }
    TkTrue  -> ok_e(p_advance(p), mk_expr(EBool(true),  t.line, t.col))
    TkFalse -> ok_e(p_advance(p), mk_expr(EBool(false), t.line, t.col))
    TkChar  -> {
      let span = tok_source(p.src, t)
      ok_e(p_advance(p), mk_expr(EChar(decode_char(span)), t.line, t.col))
    }
    TkString -> {
      let span = tok_source(p.src, t)
      let is_triple =
        string_length(span) >= 6 and
        match char_at(span, 0) { Some(c) -> c == '"' _ -> false } and
        match char_at(span, 1) { Some(c) -> c == '"' _ -> false } and
        match char_at(span, 2) { Some(c) -> c == '"' _ -> false }
      ok_e(p_advance(p), mk_expr(EStr(span, is_triple), t.line, t.col))
    }
    TkUnderscore -> ok_e(p_advance(p), mk_expr(EUnder, t.line, t.col))
    TkDot -> ok_e(p_advance(p), mk_expr(EPlaceholder, t.line, t.col))
    TkHole -> ok_e(p_advance(p), mk_expr(EHole(None), t.line, t.col))
    TkHoleName(nm) -> ok_e(p_advance(p), mk_expr(EHole(Some(nm)), t.line, t.col))
    TkTodoBang -> parse_todo_bang(p, t)
    TkIdent -> parse_ident_primary(p, t)
    TkLparen -> parse_paren_or_lambda(p, t)
    TkLbracket -> parse_list_or_range(p, t)
    TkLbrace -> parse_brace_primary(p, t)
    TkIf -> parse_if(p, t)
    TkMatch -> parse_match(p, t)
    TkHandle -> parse_handle(p_advance(p), t)
    _ -> err_e(p_error_here(p, "expected expression"))
  }
}

# m7d §1: `todo!(msg)` — `todo!` is a single token (lexer-fused).
# The message must be a plain (non-triple, no interpolation) string
# literal so the compile-time `--holes-json` report and the runtime
# panic message agree on a single static value. The token at `t` is
# the `todo!`, and `p` is positioned right after it.
fn parse_todo_bang(p: Parser, t: Token) : PExpr {
  let p1 = p_advance(p)
  if not p_at(p1, TkLparen) {
    err_e(p_error_here(p1, "expected `(` after `todo!`"))
  } else {
    let p2 = p_skip_newlines(p_advance(p1))
    let st = p_peek(p2)
    if not tk_is(st.kind, TkString) {
      err_e(p_error(p2, st, "`todo!` requires a literal string message: `todo!(\"...\")`"))
    } else {
      let span = tok_source(p2.src, st)
      let n = string_length(span)
      let is_triple =
        n >= 6 and
        match char_at(span, 0) { Some(c) -> c == '"' _ -> false } and
        match char_at(span, 1) { Some(c) -> c == '"' _ -> false } and
        match char_at(span, 2) { Some(c) -> c == '"' _ -> false }
      if is_triple {
        err_e(p_error(p2, st, "`todo!` does not accept triple-quoted strings"))
      } else {
        let body_start = 1
        let body_end = n - 1
        if has_interp(span, body_start, body_end) {
          err_e(p_error(p2, st,
            "`todo!` message must be a plain string literal (no interpolation)"))
        } else {
          let msg = string_slice(span, body_start, body_end - body_start)
          let p3 = p_skip_newlines(p_advance(p2))
          if not p_at(p3, TkRparen) {
            err_e(p_error_here(p3, "expected `)` after `todo!` message"))
          } else {
            ok_e(p_advance(p3), mk_expr(ETodo(msg), t.line, t.col))
          }
        }
      }
    }
  }
}

# `handle { body } with Eff [as alias] { clauses }`. Pinned in
# Doc A §*Handling*. Both blocks are parsed by handle-specific
# rules; the body is an ordinary block expression, the clauses
# block contains `op_name(args, resume) -> body` plus an optional
# `return(x) -> body` at the end.
fn parse_handle(p: Parser, t: Token) : PExpr {
  let bt = p_peek(p)
  if not p_at(p, TkLbrace) {
    err_e(p_error_here(p, "expected `{` to start handle body"))
  } else {
    let body_r = parse_block(p, bt)
    match body_r.r {
      None -> err_e(body_r.p)
      Some(body) -> {
        let p1 = p_skip_newlines(body_r.p)
        if not p_at(p1, TkWith) {
          err_e(p_error_here(p1, "expected `with` after handle body"))
        } else {
          let p2 = p_advance(p1)
          let eff_t = p_peek(p2)
          if not tk_is(eff_t.kind, TkIdent) {
            err_e(p_error(p2, eff_t, "expected effect name after `with`"))
          } else {
            let eff_name = tok_source(p2.src, eff_t)
            let p3 = p_advance(p2)
            # m7b #11: optional `[T1, T2]` after the effect name —
            # the type instantiation. e.g. `with Reader[Int]`.
            let tyargs_r =
              if p_at(p3, TkLbracket) {
                parse_row_label_args(p_skip_newlines(p_advance(p3)), [])
              } else {
                PRowArgs { p: p3, r: Some([]) }
              }
            match tyargs_r.r {
              None -> err_e(tyargs_r.p)
              Some(eff_tyargs) -> {
                # m7b #11: optional `(init)` after the type args —
                # the handler-state initial value, e.g. `with State[Int](0)`.
                let init_r =
                  if p_at(tyargs_r.p, TkLparen) {
                    let p_io = p_skip_newlines(p_advance(tyargs_r.p))
                    let ie = parse_expr(p_io)
                    match ie.r {
                      None -> PInit { p: ie.p, r: None, has_init: true }
                      Some(ix) -> {
                        let p_ic = p_skip_newlines(ie.p)
                        if not p_at(p_ic, TkRparen) {
                          PInit { p: p_error_here(p_ic, "expected `)` after handler-state initializer"),
                                  r: None, has_init: true }
                        } else {
                          PInit { p: p_advance(p_ic), r: Some(ix), has_init: true }
                        }
                      }
                    }
                  } else {
                    PInit { p: tyargs_r.p, r: None, has_init: false }
                  }
                let init_failed =
                  if init_r.has_init {
                    match init_r.r { None -> true Some(_) -> false }
                  } else { false }
                if init_failed {
                  err_e(init_r.p)
                } else {
                let alias_r = parse_handle_alias(init_r.p)
                let p4 = p_skip_newlines(alias_r.p)
                if not p_at(p4, TkLbrace) {
                  err_e(p_error_here(p4, "expected `{` to start handler clauses"))
                } else {
                  let p5 = p_skip_newlines(p_advance(p4))
                  let cr = parse_handle_clauses(p5, [], None)
                  match cr.r {
                    None -> err_e(cr.p)
                    Some(_) -> ok_e(cr.p,
                      mk_expr(EHandle(body, eff_name, eff_tyargs, init_r.r,
                                       alias_r.r, cr.clauses, cr.return_clause),
                              t.line, t.col))
                  }
                }
                }
              }
            }
          }
        }
      }
    }
  }
}

type PInit = { p: Parser, r: Option[Expr], has_init: Bool }

# Handler-clause params: like fn params but the type annotation is
# optional. `print(s, resume) -> ...` is the common shape.
fn parse_clause_params(p: Parser, acc: [Param]) : PParams {
  if p_at(p, TkRparen) { PParams { p: p_advance(p), r: Some(list_reverse(acc)) } }
  else {
    let t = p_peek(p)
    if not tk_is(t.kind, TkIdent) {
      PParams { p: p_error(p, t, "expected parameter name"), r: None }
    } else {
      let name = tok_source(p.src, t)
      let p1 = p_advance(p)
      let opt_ty_r =
        if p_at(p1, TkColon) {
          let rt = parse_type(p_advance(p1))
          match rt.r {
            None -> PTy { p: rt.p, r: None }
            Some(ty) -> PTy { p: rt.p, r: Some(ty) }
          }
        } else {
          PTy { p: p1, r: None }
        }
      let pm = Param { pname: name, ptype: opt_ty_r.r, pline: t.line, pcol: t.col }
      let p2 = p_skip_newlines(opt_ty_r.p)
      if p_at(p2, TkComma) {
        parse_clause_params(p_skip_newlines(p_advance(p2)), [pm, ...acc])
      } else if p_at(p2, TkRparen) {
        PParams { p: p_advance(p2), r: Some(list_reverse([pm, ...acc])) }
      } else {
        PParams { p: p_error_here(p2, "expected `,` or `)` in parameter list"), r: None }
      }
    }
  }
}

type PAlias = { p: Parser, r: Option[String] }

fn parse_handle_alias(p: Parser) : PAlias {
  if not p_at(p, TkAs) { PAlias { p: p, r: None } }
  else {
    let p1 = p_advance(p)
    let nt = p_peek(p1)
    if not tk_is(nt.kind, TkIdent) {
      PAlias { p: p_error(p1, nt, "expected alias name after `as`"), r: None }
    } else {
      PAlias { p: p_advance(p1), r: Some(tok_source(p1.src, nt)) }
    }
  }
}

type PClauses = {
  p: Parser,
  clauses: [HClause],
  return_clause: Option[HReturn],
  r: Option[Bool]
}

fn parse_handle_clauses(p: Parser, acc: [HClause], rret: Option[HReturn]) : PClauses {
  let p0 = p_skip_newlines(p)
  if p_at(p0, TkRbrace) {
    PClauses { p: p_advance(p0), clauses: list_reverse(acc),
               return_clause: rret, r: Some(true) }
  } else {
    let id_t = p_peek(p0)
    if not tk_is(id_t.kind, TkIdent) {
      PClauses { p: p_error(p0, id_t, "expected operation name in handler"),
                 clauses: [], return_clause: None, r: None }
    } else {
      let name = tok_source(p0.src, id_t)
      let p1 = p_advance(p0)
      if not p_at(p1, TkLparen) {
        PClauses { p: p_error_here(p1, "expected `(` after operation name"),
                   clauses: [], return_clause: None, r: None }
      } else {
        let p2 = p_skip_newlines(p_advance(p1))
        let params_r = parse_clause_params(p2, [])
        match params_r.r {
          None -> PClauses { p: params_r.p, clauses: [], return_clause: None, r: None }
          Some(params) -> {
            let p3 = p_skip_newlines(params_r.p)
            if not p_at(p3, TkArrow) {
              PClauses { p: p_error_here(p3, "expected `->` after operation parameters"),
                         clauses: [], return_clause: None, r: None }
            } else {
              let p4 = p_skip_newlines(p_advance(p3))
              let rb = parse_expr(p4)
              match rb.r {
                None -> PClauses { p: rb.p, clauses: [], return_clause: None, r: None }
                Some(body) -> {
                  if name == "return" {
                    match params {
                      [pp] -> {
                        let hr = HR(pp.pname, body, id_t.line, id_t.col)
                        parse_handle_clauses(rb.p, acc, Some(hr))
                      }
                      _ -> PClauses { p: p_error(p3, id_t,
                             "return clause takes exactly one parameter"),
                             clauses: [], return_clause: None, r: None }
                    }
                  } else {
                    let hc = HC(name, params, body, id_t.line, id_t.col)
                    parse_handle_clauses(rb.p, [hc, ...acc], rret)
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}

fn parse_ident_primary(p: Parser, t: Token) : PExpr {
  let name = tok_source(p.src, t)
  let p1 = p_advance(p)
  # m7e §11: `variants[T]()` — compile-time enumeration of a nullary
  # sum type's constructors. Special-cased before `[` would otherwise
  # pick up the postfix EIndex path. Active only when the source
  # ident is exactly "variants" and the next token is `[`. Any other
  # use of an identifier called `variants` followed by an expression
  # in `[...]` still parses as EIndex via parse_postfix_rest.
  if name == "variants" and p_at(p1, TkLbracket) {
    parse_variants_of(p1, t)
  }
  # Lambda: `name => body`
  else if p_at(p1, TkFatArrow) {
    let p2 = p_advance(p1)
    let r = parse_expr(p2)
    match r.r {
      None -> err_e(r.p)
      Some(body) -> {
        let param = Param { pname: name, ptype: None, pline: t.line, pcol: t.col }
        ok_e(r.p, mk_expr(ELambda([param], body), t.line, t.col))
      }
    }
  }
  # Record literal: `Name { ... }` — but only when the name is Uppercase.
  else if is_upper_ident(p.src, t) and p_at(p1, TkLbrace) {
    parse_record_lit(p1, name, t)
  }
  # Plain variable reference.
  else {
    ok_e(p1, mk_expr(EVar(name), t.line, t.col))
  }
}

# m7e §11: parse `variants[T]()`. `p` is positioned at the `[`; `t` is
# the original `variants` token (used for line/col). The closing `()`
# is mandatory and carries no payload — `variants[T](anything)` is a
# parse error. The TypeExpr inside the brackets is whatever
# `parse_type` accepts; resolver validates that it is a sum type with
# nullary-only variants.
fn parse_variants_of(p: Parser, t: Token) : PExpr {
  let p1 = p_skip_newlines(p_advance(p))
  let r = parse_type(p1)
  match r.r {
    None -> err_e(r.p)
    Some(ty) -> {
      let p2 = p_skip_newlines(r.p)
      if not p_at(p2, TkRbracket) {
        err_e(p_error_here(p2, "expected `]` after type in `variants[T]`"))
      } else {
        let p3 = p_advance(p2)
        if not p_at(p3, TkLparen) {
          err_e(p_error_here(p3, "expected `()` after `variants[T]`"))
        } else {
          let p4 = p_advance(p3)
          if not p_at(p4, TkRparen) {
            err_e(p_error_here(p4,
              "`variants[T]()` does not accept arguments"))
          } else {
            ok_e(p_advance(p4),
                  mk_expr(EVariantsOf(ty), t.line, t.col))
          }
        }
      }
    }
  }
}

fn parse_record_lit(p: Parser, type_name: String, tname: Token) : PExpr {
  # `{` is next. Consume it.
  let p1 = p_skip_newlines(p_advance(p))
  if p_at(p1, TkRbrace) {
    ok_e(p_advance(p1), mk_expr(ERecordLit(type_name, []), tname.line, tname.col))
  } else {
    parse_record_fields_loop(p1, [], type_name, tname)
  }
}

fn parse_record_fields_loop(p: Parser, acc: [FieldInit], type_name: String, tname: Token) : PExpr {
  let p0 = p_skip_newlines(p)
  let tk = p_peek(p0)
  if not tk_is(tk.kind, TkIdent) {
    err_e(p_error(p0, tk, "expected field name in record literal"))
  } else {
    let fname = tok_source(p0.src, tk)
    let p1 = p_advance(p0)
    if p_at(p1, TkColon) {
      let p2 = p_skip_newlines(p_advance(p1))
      let r = parse_expr(p2)
      match r.r {
        None -> err_e(r.p)
        Some(val) -> {
          let acc1 = [FI(fname, val), ...acc]
          let p3 = p_skip_newlines(r.p)
          if p_at(p3, TkComma) {
            parse_record_fields_loop(p_skip_newlines(p_advance(p3)), acc1, type_name, tname)
          } else if p_at(p3, TkRbrace) {
            ok_e(p_advance(p3), mk_expr(ERecordLit(type_name, list_reverse(acc1)), tname.line, tname.col))
          } else {
            err_e(p_error_here(p3, "expected `,` or `}` in record literal"))
          }
        }
      }
    }
    # m7d §10: record-literal punning. `{ x, y }` desugars to
    # `{ x: x, y: y }`. Symmetric with the pattern form already
    # parsed by `parse_record_pattern_fields` (PField is_shorthand).
    # Mixed forms (`{ x, y: other }`) compose because the punning
    # decision is per-field.
    else if p_at(p1, TkComma) or p_at(p1, TkRbrace) {
      let val = mk_expr(EVar(fname), tk.line, tk.col)
      let acc1 = [FI(fname, val), ...acc]
      if p_at(p1, TkComma) {
        parse_record_fields_loop(p_skip_newlines(p_advance(p1)), acc1, type_name, tname)
      } else {
        ok_e(p_advance(p1), mk_expr(ERecordLit(type_name, list_reverse(acc1)), tname.line, tname.col))
      }
    }
    else {
      err_e(p_error_here(p1, "expected `:`, `,`, or `}` after field name in record literal"))
    }
  }
}

fn parse_paren_or_lambda(p: Parser, t: Token) : PExpr {
  # We need to distinguish:
  #   (expr)                  — grouping
  #   ()                       — unit
  #   () => expr               — zero-arg lambda
  #   (a, b, ...) => expr      — multi-arg lambda
  #   (a) => expr              — single-arg lambda (parenthesised)
  # Strategy: speculatively parse a lambda-param list. If followed by
  # `=>`, it's a lambda. Otherwise it was a parenthesised expression
  # and we re-parse from the original position.
  let p1 = p_skip_newlines(p_advance(p))
  # Empty parens: unit, or zero-arg lambda.
  if p_at(p1, TkRparen) {
    let p2 = p_advance(p1)
    if p_at(p2, TkFatArrow) {
      let p3 = p_advance(p2)
      let r = parse_expr(p3)
      match r.r {
        None -> err_e(r.p)
        Some(body) -> ok_e(r.p, mk_expr(ELambda([], body), t.line, t.col))
      }
    } else {
      ok_e(p2, mk_expr(EUnit, t.line, t.col))
    }
  } else {
    # Try lambda: tentatively scan for an ident list ending with `)` `=>`.
    match try_parse_lambda_params(p1) {
      Some(res) -> {
        let r = parse_expr(res.p)
        match r.r {
          None -> err_e(r.p)
          Some(body) -> ok_e(r.p, mk_expr(ELambda(res.params, body), t.line, t.col))
        }
      }
      None -> {
        # Fall back to `( expr )`.
        let r = parse_expr(p1)
        match r.r {
          None -> err_e(r.p)
          Some(e) -> {
            let p2 = p_skip_newlines(r.p)
            if p_at(p2, TkRparen) { ok_e(p_advance(p2), e) }
            else { err_e(p_error_here(p2, "expected `)` after expression")) }
          }
        }
      }
    }
  }
}

# A lambda parameter list is a comma-separated sequence of identifiers
# (optionally with `: Type` annotations) followed by `)` then `=>`.
# This scan is non-destructive: it returns the parser advanced past the
# `=>` on success, None on failure.
type LamParams = { p: Parser, params: [Param] }

fn try_parse_lambda_params(p: Parser) : Option[LamParams] {
  try_parse_lambda_params_loop(p, [])
}

fn try_parse_lambda_params_loop(p: Parser, acc: [Param]) : Option[LamParams] {
  let t = p_peek(p)
  if not tk_is(t.kind, TkIdent) { None }
  else {
    let name = tok_source(p.src, t)
    let p1 = p_advance(p)
    # Optional `: Type`
    let p2_opt =
      if p_at(p1, TkColon) {
        let r = parse_type(p_advance(p1))
        match r.r {
          None -> None
          Some(_) -> Some(r.p)
        }
      } else {
        Some(p1)
      }
    match p2_opt {
      None -> None
      Some(p2) -> {
        let param = Param { pname: name, ptype: None, pline: t.line, pcol: t.col }
        let acc1 = [param, ...acc]
        if p_at(p2, TkComma) {
          try_parse_lambda_params_loop(p_skip_newlines(p_advance(p2)), acc1)
        } else if p_at(p2, TkRparen) {
          let p3 = p_advance(p2)
          if p_at(p3, TkFatArrow) {
            Some(LamParams { p: p_advance(p3), params: list_reverse(acc1) })
          } else { None }
        } else { None }
      }
    }
  }
}

# ====================================================================
# list / range
# ====================================================================

fn parse_list_or_range(p: Parser, t: Token) : PExpr {
  let p1 = p_skip_newlines(p_advance(p))
  if p_at(p1, TkRbracket) {
    ok_e(p_advance(p1), mk_expr(EList([]), t.line, t.col))
  } else {
    # Parse first element (could start with `...`).
    parse_first_list_elem(p1, t)
  }
}

fn parse_first_list_elem(p: Parser, t: Token) : PExpr {
  if p_at(p, TkEllipsis) {
    let r = parse_expr(p_advance(p))
    match r.r {
      None -> err_e(r.p)
      Some(e) -> parse_list_rest(r.p, [ElSpread(e)], t)
    }
  } else {
    let r = parse_expr(p)
    match r.r {
      None -> err_e(r.p)
      Some(first) -> {
        # Range: `[ a .. b ]` or `[ a .. b .. step ]`.
        let p1 = p_skip_newlines(r.p)
        if p_at(p1, TkDotDot) {
          let r2 = parse_expr(p_skip_newlines(p_advance(p1)))
          match r2.r {
            None -> err_e(r2.p)
            Some(to) -> {
              let p2 = p_skip_newlines(r2.p)
              if p_at(p2, TkDotDot) {
                let r3 = parse_expr(p_skip_newlines(p_advance(p2)))
                match r3.r {
                  None -> err_e(r3.p)
                  Some(step) -> {
                    let p3 = p_skip_newlines(r3.p)
                    if p_at(p3, TkRbracket) {
                      ok_e(p_advance(p3), mk_expr(ERange(first, to, Some(step)), t.line, t.col))
                    } else { err_e(p_error_here(p3, "expected `]` at end of range")) }
                  }
                }
              } else if p_at(p2, TkRbracket) {
                ok_e(p_advance(p2), mk_expr(ERange(first, to, None), t.line, t.col))
              } else { err_e(p_error_here(p2, "expected `]` at end of range")) }
            }
          }
        } else {
          parse_list_rest(p1, [ElPlain(first)], t)
        }
      }
    }
  }
}

fn parse_list_rest(p: Parser, acc: [ListElem], t: Token) : PExpr {
  let p0 = p_skip_newlines(p)
  if p_at(p0, TkRbracket) {
    ok_e(p_advance(p0), mk_expr(EList(list_reverse(acc)), t.line, t.col))
  } else if p_at(p0, TkComma) {
    let p1 = p_skip_newlines(p_advance(p0))
    if p_at(p1, TkEllipsis) {
      let r = parse_expr(p_advance(p1))
      match r.r {
        None -> err_e(r.p)
        Some(e) -> parse_list_rest(r.p, [ElSpread(e), ...acc], t)
      }
    } else {
      let r = parse_expr(p1)
      match r.r {
        None -> err_e(r.p)
        Some(e) -> parse_list_rest(r.p, [ElPlain(e), ...acc], t)
      }
    }
  } else {
    err_e(p_error_here(p0, "expected `,` or `]` in list"))
  }
}

# ====================================================================
# block, if, match
# ====================================================================

fn parse_block(p: Parser, t: Token) : PExpr {
  # `{` is at current position.
  let p1 = p_skip_newlines_and_semis(p_advance(p))
  parse_block_body(p1, [], t)
}

# m7b §1 *Lambda-block in non-trailing positions* — a `{` in
# expression position (i.e., reached via parse_primary, not via
# parse_handle's body) may start either a lambda-block or an
# ordinary block expression. Disambiguation is bounded lookahead:
#   {  ->  body    } -> zero-arity lambda-block
#   {  Ident ("," Ident)* "->"  body  } -> parameterised lambda-block
#   anything else -> ordinary block expression
# parse_handle still calls parse_block directly, so its body is
# always a block (a `{ x -> ... }` shape there is a syntax error,
# matching Doc A — handle clauses use a different production).
fn parse_brace_primary(p: Parser, t: Token) : PExpr {
  # `{` is at p_peek(p). Peek past it (and any whitespace).
  let after_lbrace = p_skip_newlines(p_advance(p))
  let pp_r = try_parse_lambda_block_params(after_lbrace)
  match pp_r {
    Some(res) -> {
      let body_r = parse_lambda_block_body(res.p, t)
      match body_r.r {
        None -> err_e(body_r.p)
        Some(body) -> ok_e(body_r.p, mk_expr(ELambda(res.params, body), t.line, t.col))
      }
    }
    None -> parse_block(p, t)
  }
}

fn parse_block_body(p: Parser, stmts: [Stmt], t: Token) : PExpr {
  let p0 = p_skip_newlines_and_semis(p)
  if p_at(p0, TkRbrace) {
    ok_e(p_advance(p0), mk_expr(EBlock(list_reverse(stmts), None), t.line, t.col))
  } else {
    let r = parse_stmt(p0)
    match r.r {
      None -> err_e(r.p)
      Some(s) -> {
        let p1 = p_skip_newlines_and_semis(r.p)
        if p_at(p1, TkRbrace) {
          # If the last stmt was an expression statement, it becomes the
          # block's final expression.
          match s {
            SExprStmt(e) -> ok_e(p_advance(p1), mk_expr(EBlock(list_reverse(stmts), Some(e)), t.line, t.col))
            _ -> ok_e(p_advance(p1), mk_expr(EBlock(list_reverse([s, ...stmts]), None), t.line, t.col))
          }
        } else {
          parse_block_body(p1, [s, ...stmts], t)
        }
      }
    }
  }
}

fn parse_stmt(p: Parser) : PStmt {
  let t = p_peek(p)
  if tk_is(t.kind, TkLet) {
    parse_let(p, t)
  } else if tk_is(t.kind, TkVar) {
    parse_var(p, t)
  } else if tk_is(t.kind, TkAssert) {
    parse_assert(p, t)
  } else {
    let r = parse_expr(p)
    match r.r {
      None -> err_s(r.p)
      Some(e) -> {
        # m7b #6: indexed write `a[i] := v`. The LHS expression we just
        # parsed must be an `EIndex(base, idx)` whose `base` is a plain
        # identifier or a `.`-chain of fields rooted at an identifier
        # (the IndexLhs of `docs/syntax-sugars.md` §4). Anything else
        # (e.g. a call result) is rejected so the write hits a named
        # binding the caller can observe elsewhere.
        if p_at(r.p, TkColonEq) {
          parse_index_assign_rest(r.p, e, t)
        } else {
          ok_s(r.p, SExprStmt(e))
        }
      }
    }
  }
}

# m7b #6 + m7b #4: validate the LHS of `:=` and parse the RHS.
# Accepted shapes:
#   `Ident[i] := v`            (m7b #6 indexed write — SIndexAssign)
#   `Ident.field…[i] := v`     (m7b #6 indexed write through field path)
#   `Ident := v`               (m7b #4 capability write — desugared to
#                              `cap.set(v)`; the alias rewrite later
#                              maps it to `State.set(cap, v)`)
fn parse_index_assign_rest(p: Parser, lhs: Expr, t: Token) : PStmt {
  match lhs.kind {
    EIndex(base, idx) -> {
      if not is_index_lhs_path(base) {
        err_s(p_error(p, t,
          string_concat(
            "left-hand side of `:=` must be `Ident` or `Ident.field…[i]`; ",
            "bind a temporary first if you need to write to a call result")))
      } else {
        let p1 = p_skip_newlines(p_advance(p))
        let rv = parse_expr(p1)
        match rv.r {
          None -> err_s(rv.p)
          Some(v) -> ok_s(rv.p, SIndexAssign(base, idx, v, lhs.line, lhs.col))
        }
      }
    }
    EVar(name) -> {
      # m7b #4: `cap := v` — desugar inline to `cap.set(v)` as a
      # statement. The alias rewrite remaps the resulting field
      # expression to `State.set(cap, v)`. Doc B §`Syntax note:
      # capability read/write sugar` rule 2: only `State[T].set(v)`
      # is the semantic target; if cap is a Reader binding the
      # desugar still produces `cap.set(v)`, the alias rewrite emits
      # `Reader.set(v)`, and the resolver rejects it ("Reader has
      # no operation `set`").
      let p1 = p_skip_newlines(p_advance(p))
      let rv = parse_expr(p1)
      match rv.r {
        None -> err_s(rv.p)
        Some(v) -> {
          let cap = mk_expr(EVar(name), lhs.line, lhs.col)
          let setter = mk_expr(EField(cap, "set"), lhs.line, lhs.col)
          let call = mk_expr(ECall(setter, [v]), lhs.line, lhs.col)
          ok_s(rv.p, SExprStmt(call))
        }
      }
    }
    _ -> err_s(p_error(p, t,
      "left-hand side of `:=` must be a capability binding `Ident`, an indexed `Ident[i]`, or `Ident.field…[i]`"))
  }
}

# IndexLhs ::= Ident ("." Ident)*  — used by m7b #6 to reject call-LHS
# index writes like `get_array()[0] := v`.
fn is_index_lhs_path(e: Expr) : Bool {
  match e.kind {
    EVar(_) -> true
    EField(base, _) -> is_index_lhs_path(base)
    _ -> false
  }
}

fn parse_let(p: Parser, t: Token) : PStmt {
  let p1 = p_advance(p)
  let rp = parse_pattern(p1)
  match rp.r {
    None -> err_s(rp.p)
    Some(pat) -> {
      # Optional `: Type` annotation.
      let pa = p_skip_newlines(rp.p)
      let ty_opt_r =
        if p_at(pa, TkColon) {
          let rt = parse_type(p_advance(pa))
          match rt.r {
            None -> PTy { p: rt.p, r: None }
            Some(ty) -> PTy { p: rt.p, r: Some(ty) }
          }
        } else {
          PTy { p: pa, r: None }
        }
      if ty_opt_r.p.had_error and not pa.had_error { err_s(ty_opt_r.p) }
      else {
        let p_eq = p_skip_newlines(ty_opt_r.p)
        if not p_at(p_eq, TkEq) {
          err_s(p_error_here(p_eq, "expected `=` in let binding"))
        } else {
          let p_rhs = p_skip_newlines(p_advance(p_eq))
          let re = parse_expr(p_rhs)
          match re.r {
            None -> err_s(re.p)
            Some(rhs) -> ok_s(re.p, SLet(pat, ty_opt_r.r, rhs))
          }
        }
      }
    }
  }
}

# m7b #5: `var name (: T)? = init` — local mutable cell. The parser
# produces an `SVar` node; the pre-resolve `desugar_var_decls` pass
# rewrites every block containing an SVar into the canonical
# `handle { rest } with State[T](init) as name { ... }` form. No
# `var name` (without `= init`) form: rejected here with a syntax
# error so the desugared `with State[T](init)` always has a state
# value to thread.
fn parse_var(p: Parser, t: Token) : PStmt {
  let p1 = p_advance(p)
  let nt = p_peek(p1)
  if not tk_is(nt.kind, TkIdent) {
    err_s(p_error(p1, nt, "expected identifier after `var`"))
  } else {
    let name = tok_source(p1.src, nt)
    let p2 = p_advance(p1)
    let ty_opt_r =
      if p_at(p2, TkColon) {
        let rt = parse_type(p_advance(p2))
        match rt.r {
          None -> PTy { p: rt.p, r: None }
          Some(ty) -> PTy { p: rt.p, r: Some(ty) }
        }
      } else {
        PTy { p: p2, r: None }
      }
    if ty_opt_r.p.had_error and not p2.had_error { err_s(ty_opt_r.p) }
    else {
      let p_eq = p_skip_newlines(ty_opt_r.p)
      if not p_at(p_eq, TkEq) {
        err_s(p_error_here(p_eq, "expected `=` in var binding (initialiser is required)"))
      } else {
        let p_rhs = p_skip_newlines(p_advance(p_eq))
        let re = parse_expr(p_rhs)
        match re.r {
          None -> err_s(re.p)
          Some(rhs) -> ok_s(re.p, SVar(name, ty_opt_r.r, rhs, t.line, t.col))
        }
      }
    }
  }
}

fn parse_assert(p: Parser, t: Token) : PStmt {
  let p1 = p_advance(p)
  let re = parse_expr(p1)
  match re.r {
    None -> err_s(re.p)
    Some(cond) -> {
      if p_at(re.p, TkComma) {
        let p2 = p_skip_newlines(p_advance(re.p))
        let rm = parse_expr(p2)
        match rm.r {
          None -> err_s(rm.p)
          Some(msg) -> ok_s(rm.p, SAssert(cond, Some(msg)))
        }
      } else {
        ok_s(re.p, SAssert(cond, None))
      }
    }
  }
}

fn parse_if(p: Parser, t: Token) : PExpr {
  let p1 = p_advance(p)
  # m7b §1: cond cannot consume a trailing `{` as a trailing lambda
  # — that `{` is the `if` body. Disable while parsing cond, then
  # restore the flag's prior value before consuming the body.
  let prev_atl = p1.allow_trailing_lambda
  let pc = p_with_trailing_lambda(p1, false)
  let rc = parse_expr(pc)
  match rc.r {
    None -> err_e(rc.p)
    Some(cond) -> {
      # Then-block
      let p2 = p_skip_newlines(p_with_trailing_lambda(rc.p, prev_atl))
      if not p_at(p2, TkLbrace) {
        err_e(p_error_here(p2, "expected `{` after `if` condition"))
      } else {
        let tb = p_peek(p2)
        let rt = parse_block(p2, tb)
        match rt.r {
          None -> err_e(rt.p)
          Some(then_e) -> {
            let p3 = p_skip_newlines(rt.p)
            if p_at(p3, TkElse) {
              let p4 = p_skip_newlines(p_advance(p3))
              if p_at(p4, TkIf) {
                let te = p_peek(p4)
                let re = parse_if(p4, te)
                match re.r {
                  None -> err_e(re.p)
                  Some(else_e) -> ok_e(re.p, mk_expr(EIf(cond, then_e, Some(else_e)), t.line, t.col))
                }
              } else if p_at(p4, TkLbrace) {
                let teb = p_peek(p4)
                let re = parse_block(p4, teb)
                match re.r {
                  None -> err_e(re.p)
                  Some(else_e) -> ok_e(re.p, mk_expr(EIf(cond, then_e, Some(else_e)), t.line, t.col))
                }
              } else {
                err_e(p_error_here(p4, "expected `if` or `{` after `else`"))
              }
            } else {
              ok_e(p3, mk_expr(EIf(cond, then_e, None), t.line, t.col))
            }
          }
        }
      }
    }
  }
}

fn parse_match(p: Parser, t: Token) : PExpr {
  let p1 = p_advance(p)
  # m7b §1: same as `if` — scrutinee cannot eat the `{` that opens
  # the arms block as a trailing lambda.
  let prev_atl = p1.allow_trailing_lambda
  let ps = p_with_trailing_lambda(p1, false)
  let rs = parse_expr(ps)
  match rs.r {
    None -> err_e(rs.p)
    Some(scrut) -> {
      let p2 = p_skip_newlines(p_with_trailing_lambda(rs.p, prev_atl))
      if not p_at(p2, TkLbrace) {
        err_e(p_error_here(p2, "expected `{` after `match` expression"))
      } else {
        parse_match_arms(p_skip_newlines(p_advance(p2)), [], scrut, t)
      }
    }
  }
}

fn parse_match_arms(p: Parser, acc: [Arm], scrut: Expr, t: Token) : PExpr {
  let p0 = p_skip_newlines_and_semis(p)
  if p_at(p0, TkRbrace) {
    ok_e(p_advance(p0), mk_expr(EMatch(scrut, list_reverse(acc)), t.line, t.col))
  } else {
    let ra = parse_arm(p0)
    match ra.r {
      None -> err_e(ra.p)
      Some(arm) -> parse_match_arms(ra.p, [arm, ...acc], scrut, t)
    }
  }
}

fn parse_arm(p: Parser) : PArm {
  let rp = parse_pattern(p)
  match rp.r {
    None -> err_a(rp.p)
    Some(pat) -> {
      let p1 = p_skip_newlines(rp.p)
      # Optional guard: `if expr`. Same discipline as `parse_if` /
      # `parse_match`: the guard expression cannot eat the `->` (or
      # an arm body's `{`) by extending into a trailing lambda. Off
      # the flag for the guard, restore for the body.
      let guard_opt_r =
        if p_at(p1, TkIf) {
          let prev_atl = p1.allow_trailing_lambda
          let pg = p_with_trailing_lambda(p_advance(p1), false)
          let rg = parse_expr(pg)
          let rg_p = p_with_trailing_lambda(rg.p, prev_atl)
          match rg.r {
            None -> PExpr { p: rg_p, r: None }
            Some(g) -> PExpr { p: rg_p, r: Some(g) }
          }
        } else {
          PExpr { p: p1, r: None }
        }
      match guard_opt_r.r {
        None -> if guard_opt_r.p.had_error { err_a(guard_opt_r.p) } else {
          parse_arm_body(guard_opt_r.p, pat, None)
        }
        Some(_) -> parse_arm_body(guard_opt_r.p, pat, guard_opt_r.r)
      }
    }
  }
}

fn parse_arm_body(p: Parser, pat: Pattern, guard: Option[Expr]) : PArm {
  let p1 = p_skip_newlines(p)
  if not p_at(p1, TkArrow) {
    err_a(p_error_here(p1, "expected `->` in match arm"))
  } else {
    let p2 = p_skip_newlines(p_advance(p1))
    let rb = parse_expr(p2)
    match rb.r {
      None -> err_a(rb.p)
      Some(body) -> ok_a(rb.p, Arm(pat, guard, body))
    }
  }
}

# ====================================================================
# patterns
# ====================================================================

fn parse_pattern(p: Parser) : PPat {
  let t = p_peek(p)
  match t.kind {
    TkHole          -> ok_p(p_advance(p), mk_pat(PHole(None), t.line, t.col))
    TkHoleName(nm)  -> ok_p(p_advance(p), mk_pat(PHole(Some(nm)), t.line, t.col))
    _ -> parse_pattern_rest(p, t)
  }
}

fn parse_pattern_rest(p: Parser, t: Token) : PPat {
  if tk_is(t.kind, TkUnderscore) {
    ok_p(p_advance(p), mk_pat(PWild, t.line, t.col))
  } else if tk_is(t.kind, TkInt) {
    let span = tok_source(p.src, t)
    let lit = mk_expr(EInt(decode_int(span)), t.line, t.col)
    ok_p(p_advance(p), mk_pat(PLit(lit), t.line, t.col))
  } else if tk_is(t.kind, TkReal) {
    let span = tok_source(p.src, t)
    let lit = mk_expr(EReal(decode_real(span)), t.line, t.col)
    ok_p(p_advance(p), mk_pat(PLit(lit), t.line, t.col))
  } else if tk_is(t.kind, TkTrue) {
    ok_p(p_advance(p), mk_pat(PLit(mk_expr(EBool(true), t.line, t.col)), t.line, t.col))
  } else if tk_is(t.kind, TkFalse) {
    ok_p(p_advance(p), mk_pat(PLit(mk_expr(EBool(false), t.line, t.col)), t.line, t.col))
  } else if tk_is(t.kind, TkChar) {
    let span = tok_source(p.src, t)
    ok_p(p_advance(p), mk_pat(PLit(mk_expr(EChar(decode_char(span)), t.line, t.col)), t.line, t.col))
  } else if tk_is(t.kind, TkString) {
    let span = tok_source(p.src, t)
    ok_p(p_advance(p), mk_pat(PLit(mk_expr(EStr(span, false), t.line, t.col)), t.line, t.col))
  } else if tk_is(t.kind, TkMinus) {
    let nxt = p_peek1(p)
    if tk_is(nxt.kind, TkInt) {
      let span = tok_source(p.src, nxt)
      let v = 0 - decode_int(span)
      let p1 = p_advance(p_advance(p))
      ok_p(p1, mk_pat(PLit(mk_expr(EInt(v), t.line, t.col)), t.line, t.col))
    } else {
      err_p(p_error_here(p, "expected literal after `-` in pattern"))
    }
  } else if tk_is(t.kind, TkLbracket) {
    parse_list_pattern(p, t)
  } else if tk_is(t.kind, TkIdent) {
    parse_ident_pattern(p, t)
  } else {
    err_p(p_error_here(p, "expected pattern"))
  }
}

fn parse_list_pattern(p: Parser, t: Token) : PPat {
  let p1 = p_skip_newlines(p_advance(p))
  if p_at(p1, TkRbracket) {
    ok_p(p_advance(p1), mk_pat(PList([], None), t.line, t.col))
  } else {
    parse_list_pattern_loop(p1, [], None, t)
  }
}

fn parse_list_pattern_loop(p: Parser, acc: [Pattern], rest: Option[String], t: Token) : PPat {
  if p_at(p, TkEllipsis) {
    # Spread binder.
    let p1 = p_advance(p)
    let id = p_peek(p1)
    if not tk_is(id.kind, TkIdent) {
      err_p(p_error_here(p1, "expected identifier after `...` in list pattern"))
    } else {
      let name = tok_source(p1.src, id)
      let p2 = p_skip_newlines(p_advance(p1))
      if p_at(p2, TkRbracket) {
        ok_p(p_advance(p2), mk_pat(PList(list_reverse(acc), Some(name)), t.line, t.col))
      } else {
        err_p(p_error_here(p2, "expected `]` after spread pattern"))
      }
    }
  } else {
    let r = parse_pattern(p)
    match r.r {
      None -> err_p(r.p)
      Some(pat) -> {
        let p1 = p_skip_newlines(r.p)
        if p_at(p1, TkComma) {
          parse_list_pattern_loop(p_skip_newlines(p_advance(p1)), [pat, ...acc], None, t)
        } else if p_at(p1, TkRbracket) {
          ok_p(p_advance(p1), mk_pat(PList(list_reverse([pat, ...acc]), None), t.line, t.col))
        } else {
          err_p(p_error_here(p1, "expected `,` or `]` in list pattern"))
        }
      }
    }
  }
}

fn parse_ident_pattern(p: Parser, t: Token) : PPat {
  let name = tok_source(p.src, t)
  let p1 = p_advance(p)
  if is_upper_ident(p.src, t) and p_at(p1, TkLparen) {
    # Variant with positional sub-patterns.
    let p2 = p_skip_newlines(p_advance(p1))
    if p_at(p2, TkRparen) {
      ok_p(p_advance(p2), mk_pat(PVariant(name, []), t.line, t.col))
    } else {
      parse_variant_sub_patterns(p2, [], name, t)
    }
  } else if is_upper_ident(p.src, t) and p_at(p1, TkLbrace) {
    # Variant-record pattern: parse as record, wrap in PVariantRecord.
    let p2 = p_skip_newlines(p_advance(p1))
    parse_record_pattern_fields(p2, [], Some(name), t)
  } else if is_upper_ident(p.src, t) {
    # Bare uppercase ident: 0-arg variant.
    ok_p(p1, mk_pat(PVariant(name, []), t.line, t.col))
  } else if p_at(p1, TkAt) {
    # m7d §14: `name @ pattern` — as-pattern. Bind `name` to the
    # whole scrutinee and continue matching with the sub-pattern.
    # The lowercase ident already implies a fresh binding; the inner
    # pattern is parsed by the same `parse_pattern` entry, so list,
    # variant, record, hole, and even nested as-patterns compose.
    let p2 = p_skip_newlines(p_advance(p1))
    let r = parse_pattern(p2)
    match r.r {
      None -> err_p(r.p)
      Some(sub) -> ok_p(r.p, mk_pat(PAs(name, sub), t.line, t.col))
    }
  } else {
    ok_p(p1, mk_pat(PBind(name), t.line, t.col))
  }
}

fn parse_variant_sub_patterns(p: Parser, acc: [Pattern], name: String, t: Token) : PPat {
  let r = parse_pattern(p)
  match r.r {
    None -> err_p(r.p)
    Some(sub) -> {
      let p1 = p_skip_newlines(r.p)
      if p_at(p1, TkComma) {
        parse_variant_sub_patterns(p_skip_newlines(p_advance(p1)), [sub, ...acc], name, t)
      } else if p_at(p1, TkRparen) {
        ok_p(p_advance(p1), mk_pat(PVariant(name, list_reverse([sub, ...acc])), t.line, t.col))
      } else {
        err_p(p_error_here(p1, "expected `,` or `)` in variant pattern"))
      }
    }
  }
}

fn parse_record_pattern_fields(p: Parser, acc: [PField], ctor: Option[String], t: Token) : PPat {
  let p0 = p_skip_newlines(p)
  if p_at(p0, TkRbrace) {
    let p1 = p_advance(p0)
    match ctor {
      None -> ok_p(p1, mk_pat(PRecord(list_reverse(acc)), t.line, t.col))
      Some(name) -> ok_p(p1, mk_pat(PVariantRecord(name, list_reverse(acc)), t.line, t.col))
    }
  } else {
    let fn_t = p_peek(p0)
    if not tk_is(fn_t.kind, TkIdent) {
      err_p(p_error(p0, fn_t, "expected field name in record pattern"))
    } else {
      let fname = tok_source(p0.src, fn_t)
      let p1 = p_advance(p0)
      let sub_r =
        if p_at(p1, TkColon) {
          let r = parse_pattern(p_advance(p1))
          match r.r {
            None -> PPat { p: r.p, r: None }
            Some(sp) -> PPat { p: r.p, r: Some(sp) }
          }
        } else {
          PPat { p: p1, r: Some(mk_pat(PBind(fname), fn_t.line, fn_t.col)) }
        }
      match sub_r.r {
        None -> err_p(sub_r.p)
        Some(sub) -> {
          let is_short = not p_at(p1, TkColon)
          let pf = PField(fname, sub, is_short)
          let p2 = p_skip_newlines(sub_r.p)
          if p_at(p2, TkComma) {
            parse_record_pattern_fields(p_skip_newlines(p_advance(p2)), [pf, ...acc], ctor, t)
          } else if p_at(p2, TkRbrace) {
            parse_record_pattern_fields(p2, [pf, ...acc], ctor, t)
          } else {
            err_p(p_error_here(p2, "expected `,` or `}` in record pattern"))
          }
        }
      }
    }
  }
}

# ====================================================================
# type expressions
# ====================================================================

# After a return-type is parsed, an optional row suffix can follow:
#   T / Eff
#   T / Eff + Eff + ...
#   T / e                # row variable alone (m7b #12)
#   T / Eff + e          # closed labels followed by a row variable
# Capitalisation disambiguates: TitleCase identifiers are effect
# labels, lowercase identifiers in tail position are row variables.
# Two row variables (`/ e + r`) and a row variable not in tail
# (`/ e + Eff`) are syntax errors — kaikai picks the simpler
# tail-variable semantics. If `/` is absent, REmpty.
type PRow = { p: Parser, r: RowExpr }

fn parse_row_suffix(p: Parser) : PRow {
  if not p_at(p, TkSlash) { PRow { p: p, r: REmpty } }
  else {
    let p1 = p_advance(p)
    parse_row_labels(p1, [])
  }
}

fn parse_row_labels(p: Parser, acc: [RowLabel]) : PRow {
  let t = p_peek(p)
  if not tk_is(t.kind, TkIdent) {
    PRow { p: p_error(p, t, "expected effect name in row"), r: REmpty }
  } else {
    let name = tok_source(p.src, t)
    let p1 = p_advance(p)
    if is_upper_ident(p.src, t) {
      # m7b #11: optional `[T1, T2]` after the label name. `Reader[Int]`
      # in row position parses the same way as a generic type
      # application — distinct labels for distinct instantiations.
      let args_r =
        if p_at(p1, TkLbracket) {
          parse_row_label_args(p_skip_newlines(p_advance(p1)), [])
        } else {
          PRowArgs { p: p1, r: Some([]) }
        }
      match args_r.r {
        None -> PRow { p: args_r.p, r: REmpty }
        Some(targs) -> {
          let acc1 = [RL(name, targs), ...acc]
          if p_at(args_r.p, TkPlus) {
            parse_row_labels(p_advance(args_r.p), acc1)
          } else {
            PRow { p: args_r.p, r: RClosed(list_reverse(acc1)) }
          }
        }
      }
    } else {
      # m7b #12: lowercase identifier — a row variable in tail
      # position. Row variables themselves carry no type args and
      # must be the last item in the row; anything after `+` here
      # is rejected.
      if p_at(p1, TkPlus) {
        let pe = p_error(p1, p_peek(p1),
          "row variable must be the last item in the row")
        PRow { p: pe, r: ROpen(name, list_reverse(acc)) }
      } else {
        PRow { p: p1, r: ROpen(name, list_reverse(acc)) }
      }
    }
  }
}

type PRowArgs = { p: Parser, r: Option[[TypeExpr]] }

fn parse_row_label_args(p: Parser, acc: [TypeExpr]) : PRowArgs {
  let r = parse_type(p)
  match r.r {
    None -> PRowArgs { p: r.p, r: None }
    Some(arg) -> {
      let p1 = p_skip_newlines(r.p)
      if p_at(p1, TkComma) {
        parse_row_label_args(p_skip_newlines(p_advance(p1)), [arg, ...acc])
      } else if p_at(p1, TkRbracket) {
        PRowArgs { p: p_advance(p1), r: Some(list_reverse([arg, ...acc])) }
      } else {
        PRowArgs { p: p_error_here(p1, "expected `,` or `]` after row-label type arguments"), r: None }
      }
    }
  }
}

fn parse_type(p: Parser) : PTy {
  let t = p_peek(p)
  if tk_is(t.kind, TkLbracket) {
    let p1 = p_advance(p)
    let r = parse_type(p1)
    match r.r {
      None -> err_t(r.p)
      Some(inner) -> {
        if p_at(r.p, TkRbracket) {
          ok_t(p_advance(r.p), mk_ty(TyList(inner), t.line, t.col))
        } else {
          err_t(p_error_here(r.p, "expected `]` in list type"))
        }
      }
    }
  } else if tk_is(t.kind, TkLparen) {
    parse_fn_type(p, t)
  } else if tk_is(t.kind, TkIdent) {
    parse_named_type(p, t)
  } else {
    err_t(p_error_here(p, "expected type"))
  }
}

fn parse_named_type(p: Parser, t: Token) : PTy {
  let name = tok_source(p.src, t)
  let p1 = p_advance(p)
  if p_at(p1, TkLbracket) {
    # Generic type: Name[T1, T2, ...]
    let p2 = p_skip_newlines(p_advance(p1))
    parse_type_args_loop(p2, [], name, t)
  } else if (name == "Real" or name == "Int") and p_at(p1, TkLt) {
    # m12.5: dimensioned numeric — `Real<unit-expr>` / `Int<unit-expr>`.
    # Restricted to the two primitive eligible types per spec §3.
    let p2 = p_skip_newlines(p_advance(p1))
    let ru = parse_unit_expr(p2)
    match ru.r {
      None -> err_t(ru.p)
      Some(u) -> {
        let p3 = p_skip_newlines(ru.p)
        if not p_at(p3, TkGt) {
          err_t(p_error_here(p3, "expected `>` to close the unit annotation"))
        } else {
          let base = mk_ty(TyName(name, []), t.line, t.col)
          ok_t(p_advance(p3), mk_ty(TyDim(base, u), t.line, t.col))
        }
      }
    }
  } else {
    ok_t(p1, mk_ty(TyName(name, []), t.line, t.col))
  }
}

fn parse_type_args_loop(p: Parser, acc: [TypeExpr], name: String, t: Token) : PTy {
  let r = parse_type(p)
  match r.r {
    None -> err_t(r.p)
    Some(arg) -> {
      let p1 = p_skip_newlines(r.p)
      if p_at(p1, TkComma) {
        parse_type_args_loop(p_skip_newlines(p_advance(p1)), [arg, ...acc], name, t)
      } else if p_at(p1, TkRbracket) {
        ok_t(p_advance(p1), mk_ty(TyName(name, list_reverse([arg, ...acc])), t.line, t.col))
      } else {
        err_t(p_error_here(p1, "expected `,` or `]` after type arguments"))
      }
    }
  }
}

fn parse_fn_type(p: Parser, t: Token) : PTy {
  let p1 = p_skip_newlines(p_advance(p))
  if p_at(p1, TkRparen) {
    let p2 = p_advance(p1)
    if not p_at(p2, TkArrow) {
      err_t(p_error_here(p2, "expected `->` in function type"))
    } else {
      let r = parse_type(p_advance(p2))
      match r.r {
        None -> err_t(r.p)
        Some(ret) -> {
          let row_r = parse_row_suffix(r.p)
          ok_t(row_r.p, mk_ty(TyFn([], ret, row_r.r), t.line, t.col))
        }
      }
    }
  } else {
    parse_fn_type_args(p1, [], t)
  }
}

fn parse_fn_type_args(p: Parser, acc: [TypeExpr], t: Token) : PTy {
  let r = parse_type(p)
  match r.r {
    None -> err_t(r.p)
    Some(arg) -> {
      let p1 = p_skip_newlines(r.p)
      if p_at(p1, TkComma) {
        parse_fn_type_args(p_skip_newlines(p_advance(p1)), [arg, ...acc], t)
      } else if p_at(p1, TkRparen) {
        let p2 = p_advance(p1)
        if not p_at(p2, TkArrow) {
          err_t(p_error_here(p2, "expected `->` in function type"))
        } else {
          let rr = parse_type(p_advance(p2))
          match rr.r {
            None -> err_t(rr.p)
            Some(ret) -> {
              let row_r = parse_row_suffix(rr.p)
              ok_t(row_r.p, mk_ty(TyFn(list_reverse([arg, ...acc]), ret, row_r.r), t.line, t.col))
            }
          }
        }
      } else {
        err_t(p_error_here(p1, "expected `,` or `)` in function type args"))
      }
    }
  }
}

# ====================================================================
# declarations
# ====================================================================

fn parse_decl(p: Parser) : PDecl {
  let p0 = p_skip_newlines(p)
  let t = p_peek(p0)
  let is_pub_r =
    if tk_is(t.kind, TkPub) { PTy { p: p_advance(p0), r: Some(mk_ty(TyName("", []), 0, 0)) } }
    else { PTy { p: p0, r: None } }
  let is_pub =
    match is_pub_r.r { Some(_) -> true None -> false }
  let p1 = is_pub_r.p
  let hd = p_peek(p1)
  if tk_is(hd.kind, TkFn) {
    parse_fn_decl(p_advance(p1), is_pub, hd)
  } else if tk_is(hd.kind, TkType) {
    parse_type_decl(p_advance(p1), is_pub, hd)
  } else if tk_is(hd.kind, TkEffect) {
    parse_effect_decl(p_advance(p1), is_pub, hd)
  } else if tk_is(hd.kind, TkProtocol) {
    parse_protocol_decl(p_advance(p1), is_pub, hd)
  } else if tk_is(hd.kind, TkImpl) {
    if is_pub { err_d(p_error(p1, hd, "`pub` is not allowed on an impl")) }
    else { parse_impl_decl(p_advance(p1), hd) }
  } else if tk_is(hd.kind, TkDerive) {
    if is_pub { err_d(p_error(p1, hd, "`pub` must precede the `type` declaration after `#derive`")) }
    else { parse_derive_decl(p_advance(p1), hd) }
  } else if tk_is(hd.kind, TkTest) {
    if is_pub { err_d(p_error(p1, hd, "`pub` is not allowed on a test")) }
    else { parse_test_decl(p_advance(p1), hd) }
  } else if tk_is(hd.kind, TkImport) {
    if is_pub { err_d(p_error(p1, hd, "`pub` is not allowed on an import")) }
    else { parse_import_decl(p_advance(p1), hd) }
  } else if tk_is(hd.kind, TkUnitKw) {
    parse_unit_decl(p_advance(p1), is_pub, hd)
  } else {
    let base = "expected `fn`, `type`, `effect`, `protocol`, `impl`, `test`, `unit`, or `import`"
    let msg = if tk_is(hd.kind, TkIdent) {
      let text = tok_source(p1.src, hd)
      match closest_name(text, ["fn", "type", "effect", "protocol", "impl", "test", "unit", "import", "pub"]) {
        Some(sug) -> concat_all([base, " (did you mean `", sug, "`?)"])
        None      -> base
      }
    } else { base }
    err_d(p_error(p1, hd, msg))
  }
}

# m12.5: parse a unit declaration. Two shapes:
#   `unit USD`                                    — atomic
#   `unit Newton = kg * m / sec^2`                — alias
fn parse_unit_decl(p: Parser, is_pub: Bool, t: Token) : PDecl {
  let id = p_peek(p)
  if not tk_is(id.kind, TkIdent) {
    err_d(p_error(p, id, "expected unit name after `unit`"))
  } else {
    let name = tok_source(p.src, id)
    let p1 = p_advance(p)
    if p_at(p1, TkEq) {
      let p2 = p_skip_newlines(p_advance(p1))
      let rb = parse_unit_expr(p2)
      match rb.r {
        None -> err_d(rb.p)
        Some(u) -> ok_d(rb.p, DUnit(is_pub, name, Some(u), t.line, t.col))
      }
    } else {
      ok_d(p1, DUnit(is_pub, name, None, t.line, t.col))
    }
  }
}

# m12.5: unit-expression grammar.
#   unit_expr := unit_term ( ('*' | '/') unit_term )*
#   unit_term := unit_factor ('^' integer)?
#   unit_factor := IDENT | INT('1') | '(' unit_expr ')'
type PUnit = { p: Parser, r: Option[UnitExprT] }

fn ok_u(p: Parser, u: UnitExprT) : PUnit = PUnit { p: p, r: Some(u) }
fn err_u(p: Parser) : PUnit = PUnit { p: p, r: None }

fn parse_unit_expr(p: Parser) : PUnit {
  let r = parse_unit_term(p)
  match r.r {
    None -> err_u(r.p)
    Some(lhs) -> parse_unit_expr_rest(r.p, lhs)
  }
}

fn parse_unit_expr_rest(p: Parser, lhs: UnitExprT) : PUnit {
  if p_at(p, TkStar) {
    let r = parse_unit_term(p_advance(p))
    match r.r {
      None -> err_u(r.p)
      Some(rhs) -> parse_unit_expr_rest(r.p, UMul(lhs, rhs))
    }
  } else if p_at(p, TkSlash) {
    let r = parse_unit_term(p_advance(p))
    match r.r {
      None -> err_u(r.p)
      Some(rhs) -> parse_unit_expr_rest(r.p, UMul(lhs, UInv(rhs)))
    }
  } else {
    ok_u(p, lhs)
  }
}

fn parse_unit_term(p: Parser) : PUnit {
  let r = parse_unit_factor(p)
  match r.r {
    None -> err_u(r.p)
    Some(base) -> {
      if p_at(r.p, TkCaret) {
        let p1 = p_advance(r.p)
        let rn = parse_unit_signed_int(p1)
        match rn.r {
          None -> err_u(rn.p)
          Some(n) -> ok_u(rn.p, UPow(base, n))
        }
      } else {
        ok_u(r.p, base)
      }
    }
  }
}

type PUInt = { p: Parser, r: Option[Int] }

fn parse_unit_signed_int(p: Parser) : PUInt {
  let neg = p_at(p, TkMinus)
  let p1 = if neg { p_advance(p) } else { p }
  let t = p_peek(p1)
  if not tk_is(t.kind, TkInt) {
    PUInt { p: p_error_here(p1, "expected integer after `^` in unit expression"), r: None }
  } else {
    let n = decode_int(tok_source(p1.src, t))
    let v = if neg { 0 - n } else { n }
    PUInt { p: p_advance(p1), r: Some(v) }
  }
}

fn parse_unit_factor(p: Parser) : PUnit {
  let t = p_peek(p)
  if tk_is(t.kind, TkIdent) {
    ok_u(p_advance(p), USym(tok_source(p.src, t)))
  } else if tk_is(t.kind, TkInt) {
    # Per spec §6 `<1>` is the dimensionless unit. Reject other ints.
    let span = tok_source(p.src, t)
    if decode_int(span) == 1 { ok_u(p_advance(p), UOne) }
    else { err_u(p_error(p, t, "only `1` is allowed as a unit literal (use a unit symbol or a parenthesised expression instead)")) }
  } else if tk_is(t.kind, TkLparen) {
    let r = parse_unit_expr(p_advance(p))
    match r.r {
      None -> err_u(r.p)
      Some(u) -> {
        if not p_at(r.p, TkRparen) {
          err_u(p_error_here(r.p, "expected `)` in unit expression"))
        } else {
          ok_u(p_advance(r.p), u)
        }
      }
    }
  } else {
    err_u(p_error(p, t, "expected unit symbol, `1`, or parenthesised unit expression"))
  }
}

fn parse_fn_decl(p: Parser, is_pub: Bool, t: Token) : PDecl {
  let id = p_peek(p)
  if not tk_is(id.kind, TkIdent) {
    err_d(p_error(p, id, "expected function name"))
  } else {
    let name = tok_source(p.src, id)
    let p1 = p_advance(p)
    # m7b #13: optional `[T1, T2, ...]` type parameter list before `(`.
    # Same shape as effect tparams (m7b #11) — uppercase or lowercase
    # identifiers, comma-separated. Empty when omitted.
    let tparams_r =
      if p_at(p1, TkLbracket) {
        parse_type_params_loop(p_skip_newlines(p_advance(p1)), [])
      } else {
        PTParams { p: p1, r: Some([]) }
      }
    match tparams_r.r {
      None -> err_d(tparams_r.p)
      Some(tparams) -> {
        let pp = tparams_r.p
        if not p_at(pp, TkLparen) {
          err_d(p_error_here(pp, "expected `(` after function name"))
        } else {
      let p2 = p_skip_newlines(p_advance(pp))
      let params_r = parse_fn_params(p2, [])
      match params_r.r {
        None -> err_d(params_r.p)
        Some(params) -> {
          let p3 = p_skip_newlines(params_r.p)
          # Optional `: ReturnType`
          let ret_r =
            if p_at(p3, TkColon) {
              let rt = parse_type(p_advance(p3))
              match rt.r {
                None -> PTy { p: rt.p, r: None }
                Some(ty) -> PTy { p: rt.p, r: Some(ty) }
              }
            } else {
              PTy { p: p3, r: None }
            }
          if ret_r.p.had_error and not p3.had_error { err_d(ret_r.p) }
          else {
            # Optional effect-row suffix: `T / Io + Fail`. m7a #3b.
            let row_r = parse_row_suffix(ret_r.p)
            let p4 = p_skip_newlines(row_r.p)
            # Body: `= expr` or `{ block }`.
            if p_at(p4, TkEq) {
              let p5 = p_skip_newlines(p_advance(p4))
              let rb = parse_expr(p5)
              match rb.r {
                None -> err_d(rb.p)
                Some(body) -> ok_d(rb.p, DFn(is_pub, name, tparams, params, ret_r.r, row_r.r, body, t.line, t.col))
              }
            } else if p_at(p4, TkLbrace) {
              let tb = p_peek(p4)
              let rb = parse_block(p4, tb)
              match rb.r {
                None -> err_d(rb.p)
                Some(body) -> ok_d(rb.p, DFn(is_pub, name, tparams, params, ret_r.r, row_r.r, body, t.line, t.col))
              }
            } else {
              err_d(p_error_here(p4, "expected `=` or `{` to start function body"))
            }
          }
        }
      }
        }
      }
    }
  }
}

# `effect Eff[T1, T2] { op_decl ... }` — m7a #3a + m7b #11.
# No name resolution and no evidence-type emission live here; those are
# #3c and #3d. Each op_decl is `name(params) : ReturnType`, body-less;
# per docs/effects-impl.md §*Evidence types*. Per-op type generics are
# m7b #2 (separate sub-task). m7b #11 adds the optional `[T1, T2]`
# tparam list after the effect name; tparams are in scope inside every
# op signature's parameter and return types.
fn parse_effect_decl(p: Parser, is_pub: Bool, t: Token) : PDecl {
  let id = p_peek(p)
  if not tk_is(id.kind, TkIdent) {
    err_d(p_error(p, id, "expected effect name"))
  } else {
    let name = tok_source(p.src, id)
    let p1 = p_advance(p)
    let p1n = p_skip_newlines(p1)
    let tparams_r =
      if p_at(p1n, TkLbracket) {
        parse_type_params_loop(p_skip_newlines(p_advance(p1n)), [])
      } else {
        PTParams { p: p1n, r: Some([]) }
      }
    match tparams_r.r {
      None -> err_d(tparams_r.p)
      Some(tparams) -> {
        let p2 = p_skip_newlines(tparams_r.p)
        if not p_at(p2, TkLbrace) {
          err_d(p_error_here(p2, "expected `{` to start effect body"))
        } else {
          let p3 = p_skip_newlines(p_advance(p2))
          let ops_r = parse_effect_ops(p3, [])
          match ops_r.r {
            None -> err_d(ops_r.p)
            Some(ops) -> ok_d(ops_r.p, DEffect(is_pub, name, tparams, ops, t.line, t.col))
          }
        }
      }
    }
  }
}

type PEffectOps = { p: Parser, r: Option[[EffectOp]] }

fn parse_effect_ops(p: Parser, acc: [EffectOp]) : PEffectOps {
  let p0 = p_skip_newlines(p)
  if p_at(p0, TkRbrace) {
    PEffectOps { p: p_advance(p0), r: Some(list_reverse(acc)) }
  } else {
    let id = p_peek(p0)
    if not tk_is(id.kind, TkIdent) {
      PEffectOps { p: p_error(p0, id, "expected operation name"), r: None }
    } else {
      let opname = tok_source(p0.src, id)
      let p1 = p_advance(p0)
      # m7b #2: optional `[T1, T2]` op-level tparams before `(args)`.
      # Reuses parse_type_params_loop (m7b #11 / m7a effects). Empty
      # when omitted; the op signature is then monomorphic.
      let op_tparams_r =
        if p_at(p1, TkLbracket) {
          parse_type_params_loop(p_skip_newlines(p_advance(p1)), [])
        } else {
          PTParams { p: p1, r: Some([]) }
        }
      match op_tparams_r.r {
        None -> PEffectOps { p: op_tparams_r.p, r: None }
        Some(op_tparams) -> {
          let pp = op_tparams_r.p
          if not p_at(pp, TkLparen) {
            PEffectOps { p: p_error_here(pp, "expected `(` after operation name"), r: None }
          } else {
        let p2 = p_skip_newlines(p_advance(pp))
        let params_r = parse_fn_params(p2, [])
        match params_r.r {
          None -> PEffectOps { p: params_r.p, r: None }
          Some(params) -> {
            let p3 = p_skip_newlines(params_r.p)
            if not p_at(p3, TkColon) {
              PEffectOps { p: p_error_here(p3, "expected `:` before operation return type"), r: None }
            } else {
              let rt = parse_type(p_advance(p3))
              match rt.r {
                None -> PEffectOps { p: rt.p, r: None }
                Some(ty) -> {
                  let op = EOp(opname, op_tparams, params, ty, id.line, id.col)
                  parse_effect_ops(rt.p, [op, ...acc])
                }
              }
            }
          }
        }
          }
        }
      }
    }
  }
}

type PParams = { p: Parser, r: Option[[Param]] }

fn parse_fn_params(p: Parser, acc: [Param]) : PParams {
  if p_at(p, TkRparen) { PParams { p: p_advance(p), r: Some(list_reverse(acc)) } }
  else {
    let t = p_peek(p)
    if not tk_is(t.kind, TkIdent) {
      PParams { p: p_error(p, t, "expected parameter name"), r: None }
    } else {
      let name = tok_source(p.src, t)
      let p1 = p_advance(p)
      if not p_at(p1, TkColon) {
        PParams { p: p_error_here(p1, "expected `:` after parameter name"), r: None }
      } else {
        let rt = parse_type(p_advance(p1))
        match rt.r {
          None -> PParams { p: rt.p, r: None }
          Some(ty) -> {
            let param = Param { pname: name, ptype: Some(ty), pline: t.line, pcol: t.col }
            let p2 = p_skip_newlines(rt.p)
            if p_at(p2, TkComma) {
              parse_fn_params(p_skip_newlines(p_advance(p2)), [param, ...acc])
            } else if p_at(p2, TkRparen) {
              PParams { p: p_advance(p2), r: Some(list_reverse([param, ...acc])) }
            } else {
              PParams { p: p_error_here(p2, "expected `,` or `)` in parameter list"), r: None }
            }
          }
        }
      }
    }
  }
}

# m12.8: `protocol P { op_decls }`. Each op_decl is `name(params) :
# ReturnType`, body-less, mirroring effect-op shape. The first param
# may use `Self` as its type to indicate the dispatch site; the
# resolver / typer treats `Self` as a fresh type variable.
fn parse_protocol_decl(p: Parser, is_pub: Bool, t: Token) : PDecl {
  let id = p_peek(p)
  if not tk_is(id.kind, TkIdent) or not is_upper_ident(p.src, id) {
    err_d(p_error(p, id, "expected an uppercase protocol name"))
  } else {
    let name = tok_source(p.src, id)
    let p1 = p_advance(p)
    let p1n = p_skip_newlines(p1)
    if not p_at(p1n, TkLbrace) {
      err_d(p_error_here(p1n, "expected `{` to start protocol body"))
    } else {
      let p2 = p_skip_newlines(p_advance(p1n))
      let ops_r = parse_protocol_ops(p2, [])
      match ops_r.r {
        None -> err_d(ops_r.p)
        Some(ops) -> ok_d(ops_r.p, DProtocol(is_pub, name, ops, t.line, t.col))
      }
    }
  }
}

type PProtoOps = { p: Parser, r: Option[[ProtoOp]] }

fn parse_protocol_ops(p: Parser, acc: [ProtoOp]) : PProtoOps {
  let p0 = p_skip_newlines(p)
  if p_at(p0, TkRbrace) {
    PProtoOps { p: p_advance(p0), r: Some(list_reverse(acc)) }
  } else {
    let id = p_peek(p0)
    if not tk_is(id.kind, TkIdent) {
      PProtoOps { p: p_error(p0, id, "expected operation name"), r: None }
    } else {
      let opname = tok_source(p0.src, id)
      let p1 = p_advance(p0)
      let op_tparams_r =
        if p_at(p1, TkLbracket) {
          parse_type_params_loop(p_skip_newlines(p_advance(p1)), [])
        } else {
          PTParams { p: p1, r: Some([]) }
        }
      match op_tparams_r.r {
        None -> PProtoOps { p: op_tparams_r.p, r: None }
        Some(op_tparams) -> {
          let pp = op_tparams_r.p
          if not p_at(pp, TkLparen) {
            PProtoOps { p: p_error_here(pp, "expected `(` after operation name"), r: None }
          } else {
            let p2 = p_skip_newlines(p_advance(pp))
            let params_r = parse_fn_params(p2, [])
            match params_r.r {
              None -> PProtoOps { p: params_r.p, r: None }
              Some(params) -> {
                let p3 = p_skip_newlines(params_r.p)
                if not p_at(p3, TkColon) {
                  PProtoOps { p: p_error_here(p3, "expected `:` before operation return type"), r: None }
                } else {
                  let rt = parse_type(p_advance(p3))
                  match rt.r {
                    None -> PProtoOps { p: rt.p, r: None }
                    Some(ty) -> {
                      let op = POp(opname, op_tparams, params, ty, id.line, id.col)
                      parse_protocol_ops(rt.p, [op, ...acc])
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}

# m12.8: `impl P for T { fn op(args) = body ... }`. Each method is a
# regular DFn whose name matches a protocol op name. The body
# inherits the parser's full feature set (any expression form).
#
# m12.8 phase 2: an optional impl-level tparam list `[u: Unit, ...]`
# may follow `impl` (mirrors the `fn[T1, T2]` shape). The bound names
# are prepended to each method's own tparams so the typer sees them
# as ordinary fn tparams in scope inside parameter and body types
# (e.g. `impl[u: Unit] Show for Real<u> { fn show(x: Real<u>) ... }`).
fn parse_impl_decl(p: Parser, t: Token) : PDecl {
  let imp_tps_r =
    if p_at(p, TkLbracket) {
      parse_type_params_loop(p_skip_newlines(p_advance(p)), [])
    } else {
      PTParams { p: p, r: Some([]) }
    }
  match imp_tps_r.r {
    None -> err_d(imp_tps_r.p)
    Some(impl_tparams) -> {
      let p_after_tps = p_skip_newlines(imp_tps_r.p)
      let id = p_peek(p_after_tps)
      if not tk_is(id.kind, TkIdent) or not is_upper_ident(p_after_tps.src, id) {
        err_d(p_error(p_after_tps, id, "expected an uppercase protocol name after `impl`"))
      } else {
        let pname = tok_source(p_after_tps.src, id)
        let p1 = p_advance(p_after_tps)
        let p1n = p_skip_newlines(p1)
        if not p_at(p1n, TkFor) {
          err_d(p_error_here(p1n, "expected `for` after protocol name in `impl`"))
        } else {
          let p2 = p_skip_newlines(p_advance(p1n))
          let target_r = parse_type(p2)
          match target_r.r {
            None -> err_d(target_r.p)
            Some(target_ty) -> {
              let p3 = p_skip_newlines(target_r.p)
              if not p_at(p3, TkLbrace) {
                err_d(p_error_here(p3, "expected `{` to start impl body"))
              } else {
                let p4 = p_skip_newlines(p_advance(p3))
                let methods_r = parse_impl_methods(p4, [])
                match methods_r.r {
                  None -> err_d(methods_r.p)
                  Some(ms) -> {
                    let ms2 = prepend_impl_tparams_to_methods(impl_tparams, ms)
                    ok_d(methods_r.p, DImpl(pname, target_ty, ms2, t.line, t.col))
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}

# m12.8 phase 2: prepend the impl-level tparams to each method's own
# tparams. Caller has already validated method shape (parse_impl_methods
# only emits DFn nodes).
fn prepend_impl_tparams_to_methods(impl_tps: [String], ms: [Decl]) : [Decl] {
  match impl_tps {
    [] -> ms
    _  -> map(ms, (d) => prepend_impl_tparams_to_method(impl_tps, d))
  }
}

fn prepend_impl_tparams_to_method(impl_tps: [String], d: Decl) : Decl {
  match d {
    DFn(pub_, n, tps, ps, ret, row, body, l, c) ->
      DFn(pub_, n, list_append(impl_tps, tps), ps, ret, row, body, l, c)
    _ -> d
  }
}

type PImplMethods = { p: Parser, r: Option[[Decl]] }

fn parse_impl_methods(p: Parser, acc: [Decl]) : PImplMethods {
  let p0 = p_skip_newlines(p)
  if p_at(p0, TkRbrace) {
    PImplMethods { p: p_advance(p0), r: Some(list_reverse(acc)) }
  } else {
    if not p_at(p0, TkFn) {
      PImplMethods { p: p_error_here(p0, "expected `fn` to start an impl method"), r: None }
    } else {
      let fn_tok = p_peek(p0)
      let p1 = p_advance(p0)
      let dr = parse_fn_decl(p1, false, fn_tok)
      match dr.r {
        None -> PImplMethods { p: dr.p, r: None }
        Some(d) -> parse_impl_methods(dr.p, [d, ...acc])
      }
    }
  }
}

# m12.8: `#derive(P1, P2, ...)` immediately followed by a `type` decl.
# The annotation list is attached to the wrapped DType so the lower
# pass can synthesise structural impls.
fn parse_derive_decl(p: Parser, t: Token) : PDecl {
  if not p_at(p, TkLparen) {
    err_d(p_error_here(p, "expected `(` after `#derive`"))
  } else {
    let p1 = p_skip_newlines(p_advance(p))
    let names_r = parse_derive_names(p1, [])
    match names_r.r {
      None -> err_d(names_r.p)
      Some(names) -> {
        let p2 = p_skip_newlines(names_r.p)
        let p2_pub_r =
          if tk_is(p_peek(p2).kind, TkPub) { PTy { p: p_advance(p2), r: Some(mk_ty(TyName("", []), 0, 0)) } }
          else { PTy { p: p2, r: None } }
        let inner_pub = match p2_pub_r.r { Some(_) -> true None -> false }
        let p3 = p2_pub_r.p
        let hd = p_peek(p3)
        if not tk_is(hd.kind, TkType) {
          err_d(p_error(p3, hd, "`#derive` must precede a `type` declaration"))
        } else {
          let inner = parse_type_decl(p_advance(p3), inner_pub, hd)
          match inner.r {
            None -> err_d(inner.p)
            Some(d) -> ok_d(inner.p, DDerive(names, d, t.line, t.col))
          }
        }
      }
    }
  }
}

type PDeriveNames = { p: Parser, r: Option[[String]] }

fn parse_derive_names(p: Parser, acc: [String]) : PDeriveNames {
  let id = p_peek(p)
  if not tk_is(id.kind, TkIdent) or not is_upper_ident(p.src, id) {
    PDeriveNames { p: p_error(p, id, "expected a protocol name in `#derive(...)`"), r: None }
  } else {
    let name = tok_source(p.src, id)
    let p1 = p_skip_newlines(p_advance(p))
    if p_at(p1, TkComma) {
      parse_derive_names(p_skip_newlines(p_advance(p1)), [name, ...acc])
    } else if p_at(p1, TkRparen) {
      PDeriveNames { p: p_advance(p1), r: Some(list_reverse([name, ...acc])) }
    } else {
      PDeriveNames { p: p_error_here(p1, "expected `,` or `)` in `#derive(...)`"), r: None }
    }
  }
}

fn parse_type_decl(p: Parser, is_pub: Bool, t: Token) : PDecl {
  let id = p_peek(p)
  if not tk_is(id.kind, TkIdent) or not is_upper_ident(p.src, id) {
    err_d(p_error(p, id, "expected an uppercase type name after `type`"))
  } else {
    let name = tok_source(p.src, id)
    let p1 = p_advance(p)
    let p1n = p_skip_newlines(p1)
    # Optional type params `[a, b, c]`.
    let tparams_r =
      if p_at(p1n, TkLbracket) {
        parse_type_params_loop(p_skip_newlines(p_advance(p1n)), [])
      } else {
        PTParams { p: p1n, r: Some([]) }
      }
    match tparams_r.r {
      None -> err_d(tparams_r.p)
      Some(tparams) -> {
        let p2 = p_skip_newlines(tparams_r.p)
        if not p_at(p2, TkEq) {
          err_d(p_error_here(p2, "expected `=` in type declaration"))
        } else {
          let p3 = p_skip_newlines(p_advance(p2))
          parse_type_body(p3, is_pub, name, tparams, t)
        }
      }
    }
  }
}

type PTParams = { p: Parser, r: Option[[String]] }

fn parse_type_params_loop(p: Parser, acc: [String]) : PTParams {
  let t = p_peek(p)
  if not tk_is(t.kind, TkIdent) {
    PTParams { p: p_error(p, t, "expected type parameter name"), r: None }
  } else {
    let raw_name = tok_source(p.src, t)
    let p1 = p_skip_newlines(p_advance(p))
    # m12.5: optional `: Unit` (or `: Type`) kind annotation. Stored
    # by suffixing the param name with "#Unit" for unit-kind params.
    let kr = parse_optional_kind_annotation(p1)
    let stored = tp_make(raw_name, kr.kind)
    let p2 = p_skip_newlines(kr.p)
    if p_at(p2, TkComma) {
      parse_type_params_loop(p_skip_newlines(p_advance(p2)), [stored, ...acc])
    } else if p_at(p2, TkRbracket) {
      PTParams { p: p_advance(p2), r: Some(list_reverse([stored, ...acc])) }
    } else {
      PTParams { p: p_error_here(p2, "expected `,` or `]` after type parameter"), r: None }
    }
  }
}

# m12.5: helper — consume an optional `: Type` / `: Unit` kind suffix.
# Defaults to KType when absent, preserving existing behaviour.
type PKind = { p: Parser, kind: Kind }

fn parse_optional_kind_annotation(p: Parser) : PKind {
  if p_at(p, TkColon) {
    let p1 = p_skip_newlines(p_advance(p))
    let t = p_peek(p1)
    if not tk_is(t.kind, TkIdent) {
      PKind { p: p_error_here(p1, "expected `Type` or `Unit` after `:` in type parameter"), kind: KType }
    } else {
      let kw = tok_source(p1.src, t)
      let p2 = p_advance(p1)
      if kw == "Unit" { PKind { p: p2, kind: KUnit } }
      else if kw == "Type" { PKind { p: p2, kind: KType } }
      else { PKind { p: p_error(p1, t, "type-parameter kind must be `Type` or `Unit`"), kind: KType } }
    }
  } else {
    PKind { p: p, kind: KType }
  }
}

fn parse_type_body(p: Parser, is_pub: Bool, name: String, tparams: [String], t: Token) : PDecl {
  if p_at(p, TkLbrace) {
    let p1 = p_skip_newlines(p_advance(p))
    parse_record_body(p1, [], is_pub, name, tparams, t)
  } else {
    # Sum or alias: check for an uppercase ident followed by `(` OR
    # followed eventually by `|` to decide. Simpler approach: try to
    # parse as sum; if the first variant is followed by `|`, continue
    # as sum; otherwise, fall back to alias. But stage 1 mirrors stage
    # 0: use the same heuristic — if the first token is Uppercase and
    # the next is `(` OR further along we see `|`, treat as sum.
    let hd = p_peek(p)
    if tk_is(hd.kind, TkIdent) and is_upper_ident(p.src, hd) {
      # Effect alias body has the form `Eff1 + Eff2 + ...`. The `+`
      # immediately after the first uppercase ident is the unambiguous
      # signal: type aliases never use `+`, sums use `|`. Single-effect
      # aliases (`type Foo = Console`) parse as TBAlias and are
      # recognised at resolve time. (m7b #1a)
      let nxt = p_peek1(p)
      if tk_is(nxt.kind, TkPlus) {
        let nm = tok_source(p.src, hd)
        parse_effect_alias_body(p_advance(p_advance(p)), [nm], is_pub, name, tparams, t)
      } else {
        let is_sum = looks_like_sum(p)
        if is_sum {
          parse_sum_body(p, [], is_pub, name, tparams, t)
        } else {
          let rt = parse_type(p)
          match rt.r {
            None -> err_d(rt.p)
            Some(aliased) -> ok_d(rt.p, DType(is_pub, name, tparams, TBAlias(aliased), t.line, t.col))
          }
        }
      }
    } else {
      let rt = parse_type(p)
      match rt.r {
        None -> err_d(rt.p)
        Some(aliased) -> ok_d(rt.p, DType(is_pub, name, tparams, TBAlias(aliased), t.line, t.col))
      }
    }
  }
}

# Mirror of stage 0's looks_like_sum heuristic: scan ahead for `|` or
# for `Uppercase(` indicating a variant with payload.
fn looks_like_sum(p: Parser) : Bool {
  let hd = p_peek(p)
  let nxt = p_peek1(p)
  if is_upper_ident(p.src, hd) and tk_is(nxt.kind, TkLparen) { true }
  else { looks_like_sum_scan(p.rest, 0) }
}

fn looks_like_sum_scan(toks: [Token], depth: Int) : Bool {
  match toks {
    [] -> false
    [t, ...rs] -> {
      match t.kind {
        TkEof -> false
        TkLparen -> looks_like_sum_scan(rs, depth + 1)
        TkLbracket -> looks_like_sum_scan(rs, depth + 1)
        TkLbrace -> looks_like_sum_scan(rs, depth + 1)
        TkRparen -> looks_like_sum_scan(rs, depth - 1)
        TkRbracket -> looks_like_sum_scan(rs, depth - 1)
        TkRbrace -> looks_like_sum_scan(rs, depth - 1)
        TkPipe -> if depth == 0 { true } else { looks_like_sum_scan(rs, depth) }
        TkNewline -> if depth == 0 { looks_like_sum_after_nl(rs) }
                     else { looks_like_sum_scan(rs, depth) }
        _ -> looks_like_sum_scan(rs, depth)
      }
    }
  }
}

fn looks_like_sum_after_nl(toks: [Token]) : Bool {
  match toks {
    [] -> false
    [t, ...rs] -> {
      match t.kind {
        TkNewline -> looks_like_sum_after_nl(rs)
        TkPipe -> true
        _ -> false
      }
    }
  }
}

fn parse_record_body(p: Parser, acc: [FieldDecl], is_pub: Bool, name: String, tparams: [String], t: Token) : PDecl {
  let p0 = p_skip_newlines(p)
  if p_at(p0, TkRbrace) {
    ok_d(p_advance(p0), DType(is_pub, name, tparams, TBRecord(list_reverse(acc)), t.line, t.col))
  } else {
    let ft = p_peek(p0)
    if not tk_is(ft.kind, TkIdent) {
      err_d(p_error(p0, ft, "expected field name in record type"))
    } else {
      let fname = tok_source(p0.src, ft)
      let p1 = p_advance(p0)
      if not p_at(p1, TkColon) {
        err_d(p_error_here(p1, "expected `:` after field name"))
      } else {
        let rt = parse_type(p_advance(p1))
        match rt.r {
          None -> err_d(rt.p)
          Some(ty) -> {
            let fd = FD(fname, ty)
            let p2 = p_skip_newlines(rt.p)
            if p_at(p2, TkComma) {
              parse_record_body(p_skip_newlines(p_advance(p2)), [fd, ...acc], is_pub, name, tparams, t)
            } else if p_at(p2, TkRbrace) {
              ok_d(p_advance(p2), DType(is_pub, name, tparams, TBRecord(list_reverse([fd, ...acc])), t.line, t.col))
            } else {
              err_d(p_error_here(p2, "expected `,` or `}` in record type"))
            }
          }
        }
      }
    }
  }
}

# m7b #1a — closed effect-alias body. Caller has consumed the first
# label and the `+` separator; `acc` holds the labels parsed so far in
# reverse order. Subsequent labels must be uppercase idents separated
# by `+`. Validation that each label refers to a declared effect, plus
# cycle detection, is m7b #1c at resolve time.
fn parse_effect_alias_body(p: Parser, acc: [String], is_pub: Bool, name: String, tparams: [String], t: Token) : PDecl {
  let hd = p_peek(p)
  if not tk_is(hd.kind, TkIdent) or not is_upper_ident(p.src, hd) {
    err_d(p_error(p, hd, "expected uppercase effect name in effect alias"))
  } else {
    let nm = tok_source(p.src, hd)
    let p1 = p_advance(p)
    let acc1 = [nm, ...acc]
    if p_at(p1, TkPlus) {
      parse_effect_alias_body(p_advance(p1), acc1, is_pub, name, tparams, t)
    } else {
      ok_d(p1, DType(is_pub, name, tparams, TBEffectAlias(list_reverse(acc1)), t.line, t.col))
    }
  }
}

fn parse_sum_body(p: Parser, acc: [Variant], is_pub: Bool, name: String, tparams: [String], t: Token) : PDecl {
  let p0 = p_skip_newlines(p)
  let vt = p_peek(p0)
  if not tk_is(vt.kind, TkIdent) or not is_upper_ident(p0.src, vt) {
    err_d(p_error(p0, vt, "expected variant constructor name"))
  } else {
    let vname = tok_source(p0.src, vt)
    let p1 = p_advance(p0)
    let args_r =
      if p_at(p1, TkLparen) {
        parse_variant_args(p_skip_newlines(p_advance(p1)), [])
      } else {
        PVariantArgs { p: p1, r: Some([]) }
      }
    match args_r.r {
      None -> err_d(args_r.p)
      Some(vargs) -> {
        let vnode = Var(vname, vargs)
        let p2 = p_skip_newlines(args_r.p)
        if p_at(p2, TkPipe) {
          parse_sum_body(p_skip_newlines(p_advance(p2)), [vnode, ...acc], is_pub, name, tparams, t)
        } else {
          ok_d(p2, DType(is_pub, name, tparams, TBSum(list_reverse([vnode, ...acc])), t.line, t.col))
        }
      }
    }
  }
}

type PVariantArgs = { p: Parser, r: Option[[TypeExpr]] }

fn parse_variant_args(p: Parser, acc: [TypeExpr]) : PVariantArgs {
  if p_at(p, TkRparen) { PVariantArgs { p: p_advance(p), r: Some(list_reverse(acc)) } }
  else {
    let r = parse_type(p)
    match r.r {
      None -> PVariantArgs { p: r.p, r: None }
      Some(ty) -> {
        let p1 = p_skip_newlines(r.p)
        if p_at(p1, TkComma) {
          parse_variant_args(p_skip_newlines(p_advance(p1)), [ty, ...acc])
        } else if p_at(p1, TkRparen) {
          PVariantArgs { p: p_advance(p1), r: Some(list_reverse([ty, ...acc])) }
        } else {
          PVariantArgs { p: p_error_here(p1, "expected `,` or `)` in variant payload"), r: None }
        }
      }
    }
  }
}

fn parse_test_decl(p: Parser, t: Token) : PDecl {
  let desc_t = p_peek(p)
  if not tk_is(desc_t.kind, TkString) {
    err_d(p_error(p, desc_t, "expected string description after `test`"))
  } else {
    let desc_span = tok_source(p.src, desc_t)
    let p1 = p_skip_newlines(p_advance(p))
    if not p_at(p1, TkLbrace) {
      err_d(p_error_here(p1, "expected `{` for test body"))
    } else {
      let tb = p_peek(p1)
      let rb = parse_block(p1, tb)
      match rb.r {
        None -> err_d(rb.p)
        Some(body) -> ok_d(rb.p, DTest(desc_span, body, t.line, t.col))
      }
    }
  }
}

fn parse_import_decl(p: Parser, t: Token) : PDecl {
  # For stage 1 MVP, imports are structurally parsed but not resolved.
  # Accept: `import a.b.c`, `import a.b.c as X`, `import a.b.c.{f, g}`.
  let first = p_peek(p)
  if not tk_is(first.kind, TkIdent) {
    err_d(p_error(p, first, "expected module name after `import`"))
  } else {
    parse_import_path(p_advance(p), tok_source(p.src, first), t)
  }
}

fn parse_import_path(p: Parser, acc_path: String, t: Token) : PDecl {
  if p_at(p, TkDot) {
    let p1 = p_advance(p)
    let nxt = p_peek(p1)
    if tk_is(nxt.kind, TkIdent) {
      let seg = tok_source(p1.src, nxt)
      parse_import_path(p_advance(p1), string_concat(string_concat(acc_path, "."), seg), t)
    } else if tk_is(nxt.kind, TkLbrace) {
      # Selective: `.{a, b}`
      parse_import_selectives(p_skip_newlines(p_advance(p1)), [], acc_path, t)
    } else {
      err_d(p_error_here(p1, "expected identifier or `{` after `.`"))
    }
  } else if p_at(p, TkAs) {
    let p1 = p_advance(p)
    let nxt = p_peek(p1)
    if not tk_is(nxt.kind, TkIdent) {
      err_d(p_error(p1, nxt, "expected alias name after `as`"))
    } else {
      let alias = tok_source(p1.src, nxt)
      ok_d(p_advance(p1), DImport(IkAlias(acc_path, alias), t.line, t.col))
    }
  } else {
    ok_d(p, DImport(IkPath(acc_path), t.line, t.col))
  }
}

fn parse_import_selectives(p: Parser, acc: [String], path: String, t: Token) : PDecl {
  let p0 = p_skip_newlines(p)
  let nxt = p_peek(p0)
  if not tk_is(nxt.kind, TkIdent) {
    err_d(p_error(p0, nxt, "expected identifier in selective import"))
  } else {
    let name = tok_source(p0.src, nxt)
    let p1 = p_skip_newlines(p_advance(p0))
    if p_at(p1, TkComma) {
      parse_import_selectives(p_skip_newlines(p_advance(p1)), [name, ...acc], path, t)
    } else if p_at(p1, TkRbrace) {
      ok_d(p_advance(p1), DImport(IkSelective(path, list_reverse([name, ...acc])), t.line, t.col))
    } else {
      err_d(p_error_here(p1, "expected `,` or `}` in selective import"))
    }
  }
}

# ====================================================================
# program
# ====================================================================

fn parse_program_loop(p: Parser, acc: [Decl]) : PParser {
  let p0 = p_skip_newlines(p)
  if p_at(p0, TkEof) { PParser { p: p0, decls: Some(list_reverse(acc)) } }
  else {
    let r = parse_decl(p0)
    match r.r {
      None -> PParser { p: r.p, decls: None }
      Some(d) -> parse_program_loop(r.p, [d, ...acc])
    }
  }
}

type PParser = { p: Parser, decls: Option[[Decl]] }

fn parse_program(file: String, src: String, toks: [Token]) : PParser {
  parse_program_loop(parser_new(file, src, toks), [])
}

# ====================================================================
# AST dumper (for --ast)
# ====================================================================
#
# The format is indented nesting, one node per line. It does not try
# to match stage 0's kai_dump_ast byte-for-byte; the value here is to
# help visually inspect stage 1's parser while the emitter is being
# written.

fn indent_of(depth: Int) : String {
  if depth == 0 { "" } else { string_concat("  ", indent_of(depth - 1)) }
}

fn emit_line(depth: Int, s: String) : Unit / Console = print("#{indent_of(depth)}#{s}")

fn dump_expr(e: Expr, depth: Int) : Unit {
  match e.kind {
    EInt(n) -> emit_line(depth, "int #{int_to_string(n)} @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
    EReal(r) -> emit_line(depth, "real #{real_to_string(r)} @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
    EBool(b) -> {
      let s = if b { "true" } else { "false" }
      emit_line(depth, "bool #{s} @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
    }
    EChar(c) -> emit_line(depth, "char '#{c}' @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
    EStr(s, _) -> emit_line(depth, "string #{s} @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
    EUnit -> emit_line(depth, "unit @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
    EVar(name) -> emit_line(depth, "ident #{name} @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
    EUnder -> emit_line(depth, "_ @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
    EPlaceholder -> emit_line(depth, ". @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
    ECall(callee, xs) -> {
      emit_line(depth, "call @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      dump_expr(callee, depth + 1)
      xs |> each((a) => dump_expr(a, depth + 1))
    }
    EField(base, name) -> {
      emit_line(depth, "field .#{name} @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      dump_expr(base, depth + 1)
    }
    EIndex(base, idx) -> {
      emit_line(depth, "index @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      dump_expr(base, depth + 1)
      dump_expr(idx, depth + 1)
    }
    EBinop(op, a, b) -> {
      emit_line(depth, "binop #{op} @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      dump_expr(a, depth + 1)
      dump_expr(b, depth + 1)
    }
    EUnop(op, x) -> {
      emit_line(depth, "unop #{op} @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      dump_expr(x, depth + 1)
    }
    EIf(c, a, opt_b) -> {
      emit_line(depth, "if @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      dump_expr(c, depth + 1)
      dump_expr(a, depth + 1)
      match opt_b { Some(b) -> dump_expr(b, depth + 1) None -> () }
    }
    EMatch(scrut, arms) -> {
      emit_line(depth, "match @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      dump_expr(scrut, depth + 1)
      arms |> each((a) => dump_arm(a, depth + 1))
    }
    ELambda(params, body) -> {
      emit_line(depth, "lambda @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      params |> each((pm) => emit_line(depth + 1, "param #{pm.pname}"))
      dump_expr(body, depth + 1)
    }
    ERecordLit(name, fields) -> {
      emit_line(depth, "record #{name} @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      fields |> each((fi) => dump_field_init(fi, depth + 1))
    }
    EList(elems) -> {
      emit_line(depth, "list @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      elems |> each((el) => dump_list_elem(el, depth + 1))
    }
    ERange(a, b, opt_step) -> {
      emit_line(depth, "range @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      dump_expr(a, depth + 1)
      dump_expr(b, depth + 1)
      match opt_step { Some(s) -> dump_expr(s, depth + 1) None -> () }
    }
    EBlock(stmts, opt_final) -> {
      emit_line(depth, "block @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      stmts |> each((s) => dump_stmt(s, depth + 1))
      match opt_final { Some(fe) -> dump_expr(fe, depth + 1) None -> () }
    }
    EPipe(a, b) -> {
      emit_line(depth, "pipe @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      dump_expr(a, depth + 1)
      dump_expr(b, depth + 1)
    }
    EHole(nm_opt) -> {
      let label = match nm_opt { Some(nm) -> cat2("?", nm) None -> "?" }
      emit_line(depth, "hole #{label} @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
    }
    ETodo(msg) ->
      emit_line(depth, "todo \"#{msg}\" @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
    EBang(inner) -> {
      emit_line(depth, "bang @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      dump_expr(inner, depth + 1)
    }
    EHandle(body, eff_name, eff_tyargs, init_opt, alias_opt, clauses, ret_opt) -> {
      let alias_s = match alias_opt { Some(a) -> string_concat(" as ", a) None -> "" }
      let targs_s = match eff_tyargs {
        [] -> ""
        _ -> concat_all(["[", join_with(map(eff_tyargs, type_expr_display), ", "), "]"])
      }
      emit_line(depth, "handle #{eff_name}#{targs_s}#{alias_s} @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      match init_opt {
        Some(ie) -> { emit_line(depth + 1, "init") dump_expr(ie, depth + 2) }
        None -> ()
      }
      emit_line(depth + 1, "body")
      dump_expr(body, depth + 2)
      clauses |> each((c) => dump_hclause(c, depth + 1))
      match ret_opt { Some(r) -> dump_hreturn(r, depth + 1) None -> () }
    }
    ELitUnit(inner, u) -> {
      emit_line(depth, "lit-unit <#{unit_expr_display(u)}> @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
      dump_expr(inner, depth + 1)
    }
    EVariantsOf(ty) ->
      emit_line(depth, "variants-of #{type_expr_display(ty)} @#{int_to_string(e.line)}:#{int_to_string(e.col)}")
  }
}

fn dump_hclause(c: HClause, depth: Int) : Unit {
  match c {
    HC(name, params, body, line, col) -> {
      emit_line(depth, "clause #{name} @#{int_to_string(line)}:#{int_to_string(col)}")
      params |> each((pm) => dump_param(pm, depth + 1))
      dump_expr(body, depth + 1)
    }
  }
}

fn dump_hreturn(r: HReturn, depth: Int) : Unit {
  match r {
    HR(name, body, line, col) -> {
      emit_line(depth, "return #{name} @#{int_to_string(line)}:#{int_to_string(col)}")
      dump_expr(body, depth + 1)
    }
  }
}

fn dump_arm(a: Arm, depth: Int) : Unit {
  emit_line(depth, "arm")
  match a {
    Arm(pat, guard, body) -> {
      dump_pat(pat, depth + 1)
      match guard { Some(g) -> { emit_line(depth + 1, "guard"); dump_expr(g, depth + 2) } None -> () }
      dump_expr(body, depth + 1)
    }
  }
}

fn dump_field_init(fi: FieldInit, depth: Int) : Unit {
  match fi {
    FI(name, val) -> {
      emit_line(depth, "field_init #{name}")
      dump_expr(val, depth + 1)
    }
  }
}

fn dump_list_elem(el: ListElem, depth: Int) : Unit {
  match el {
    ElPlain(e) -> dump_expr(e, depth)
    ElSpread(e) -> {
      emit_line(depth, "spread")
      dump_expr(e, depth + 1)
    }
  }
}

fn dump_stmt(s: Stmt, depth: Int) : Unit {
  match s {
    SLet(pat, opt_ty, rhs) -> {
      emit_line(depth, "let")
      dump_pat(pat, depth + 1)
      match opt_ty { Some(ty) -> dump_type(ty, depth + 1) None -> () }
      dump_expr(rhs, depth + 1)
    }
    SAssert(cond, opt_msg) -> {
      emit_line(depth, "assert")
      dump_expr(cond, depth + 1)
      match opt_msg { Some(m) -> dump_expr(m, depth + 1) None -> () }
    }
    SExprStmt(e) -> dump_expr(e, depth)
    SIndexAssign(base, idx, val, line, col) -> {
      emit_line(depth, "index-assign @#{int_to_string(line)}:#{int_to_string(col)}")
      dump_expr(base, depth + 1)
      dump_expr(idx, depth + 1)
      dump_expr(val, depth + 1)
    }
    SVar(name, opt_ty, rhs, line, col) -> {
      emit_line(depth, "var #{name} @#{int_to_string(line)}:#{int_to_string(col)}")
      match opt_ty { Some(ty) -> dump_type(ty, depth + 1) None -> () }
      dump_expr(rhs, depth + 1)
    }
  }
}

fn dump_pat(pat: Pattern, depth: Int) : Unit {
  match pat.pkind {
    PWild -> emit_line(depth, "pat _ @#{int_to_string(pat.line)}:#{int_to_string(pat.col)}")
    PLit(e) -> {
      emit_line(depth, "pat_lit @#{int_to_string(pat.line)}:#{int_to_string(pat.col)}")
      dump_expr(e, depth + 1)
    }
    PBind(name) -> emit_line(depth, "pat_bind #{name} @#{int_to_string(pat.line)}:#{int_to_string(pat.col)}")
    PList(pats, opt_rest) -> {
      emit_line(depth, "pat_list @#{int_to_string(pat.line)}:#{int_to_string(pat.col)}")
      pats |> each((pp) => dump_pat(pp, depth + 1))
      match opt_rest { Some(r) -> emit_line(depth + 1, "...#{r}") None -> () }
    }
    PVariant(name, subs) -> {
      emit_line(depth, "pat_variant #{name} @#{int_to_string(pat.line)}:#{int_to_string(pat.col)}")
      subs |> each((pp) => dump_pat(pp, depth + 1))
    }
    PVariantRecord(name, fields) -> {
      emit_line(depth, "pat_variant_record #{name} @#{int_to_string(pat.line)}:#{int_to_string(pat.col)}")
      fields |> each((pf) => dump_pfield(pf, depth + 1))
    }
    PRecord(fields) -> {
      emit_line(depth, "pat_record @#{int_to_string(pat.line)}:#{int_to_string(pat.col)}")
      fields |> each((pf) => dump_pfield(pf, depth + 1))
    }
    PHole(nm_opt) -> {
      let label = match nm_opt { Some(nm) -> cat2("?", nm) None -> "?" }
      emit_line(depth, "pat_hole #{label} @#{int_to_string(pat.line)}:#{int_to_string(pat.col)}")
    }
    PAs(name, sub) -> {
      emit_line(depth, "pat_as #{name} @#{int_to_string(pat.line)}:#{int_to_string(pat.col)}")
      dump_pat(sub, depth + 1)
    }
  }
}

fn dump_pfield(pf: PField, depth: Int) : Unit {
  match pf {
    PField(name, sub, short) -> {
      let suffix = if short { " (shorthand)" } else { "" }
      emit_line(depth, "pat_field #{name}#{suffix}")
      dump_pat(sub, depth + 1)
    }
  }
}

fn dump_type(ty: TypeExpr, depth: Int) : Unit {
  match ty.tkind {
    TyName(name, targs) -> {
      emit_line(depth, "ty_name #{name} @#{int_to_string(ty.line)}:#{int_to_string(ty.col)}")
      targs |> each((a) => dump_type(a, depth + 1))
    }
    TyList(inner) -> {
      emit_line(depth, "ty_list @#{int_to_string(ty.line)}:#{int_to_string(ty.col)}")
      dump_type(inner, depth + 1)
    }
    TyFn(targs, ret, row) -> {
      emit_line(depth, "ty_fn @#{int_to_string(ty.line)}:#{int_to_string(ty.col)}")
      targs |> each((a) => dump_type(a, depth + 1))
      dump_type(ret, depth + 1)
      dump_row_expr(row, depth + 1)
    }
    TyDim(base, u) -> {
      emit_line(depth, "ty_dim <#{unit_expr_display(u)}> @#{int_to_string(ty.line)}:#{int_to_string(ty.col)}")
      dump_type(base, depth + 1)
    }
  }
}

fn dump_row_expr(r: RowExpr, depth: Int) : Unit {
  match r {
    REmpty -> ()
    RClosed(labels) -> {
      let s = if labels == [] { "row (empty)" }
              else { string_concat("row ", join_with(map(labels, row_label_display), " + ")) }
      emit_line(depth, s)
    }
    ROpen(rv, labels) -> {
      let s = if labels == [] { string_concat("row ", rv) }
              else { string_concat("row ",
                       string_concat(join_with(map(labels, row_label_display), " + "),
                         string_concat(" + ", rv))) }
      emit_line(depth, s)
    }
  }
}

# m7b #11 — render `RowLabel` for diagnostics and dumps. Effect names
# without type args render as the bare name; parameterised effects
# render as `Eff[T1, T2]`. The rendered TypeExpr arguments use the
# coarse `type_expr_display` helper — fine for diagnostics, not a
# canonical pretty-printer.
fn row_label_display(rl: RowLabel) : String {
  match rl {
    RL(name, []) -> name
    RL(name, args) -> concat_all([name, "[", join_with(map(args, type_expr_display), ", "), "]"])
  }
}

fn type_expr_display(t: TypeExpr) : String {
  match t.tkind {
    TyName(name, []) -> name
    TyName(name, ts) -> concat_all([name, "[", join_with(map(ts, type_expr_display), ", "), "]"])
    TyList(inner) -> concat_all(["[", type_expr_display(inner), "]"])
    TyFn(ps, ret, _) -> concat_all([
      "(", join_with(map(ps, type_expr_display), ", "), ") -> ", type_expr_display(ret)
    ])
    TyDim(base, u) -> concat_all([type_expr_display(base), "<", unit_expr_display(u), ">"])
  }
}

# m12.5: render a UnitExprT as user-readable text. The display is *not*
# the canonical form (which lives as Map[Sym,Int]); it's the tree shape
# the parser produced, with light cleanup. Use unit_canon_display for
# canonical output.
fn unit_expr_display(u: UnitExprT) : String {
  match u {
    UOne -> "1"
    USym(s) -> s
    UMul(a, b) -> concat_all([unit_expr_display(a), " * ", unit_expr_display(b)])
    UInv(a) -> concat_all(["1 / ", unit_expr_display(a)])
    UPow(a, n) -> concat_all([unit_expr_display(a), "^", int_to_string(n)])
    UVar(n) -> cat2("?u", int_to_string(n))
  }
}

# Extract just the eff names from a row's labels — useful for the
# many string-based passes in the resolver that don't need the type
# args. Parametric effects are projected to their bare name (so
# `Reader[Int]` and `Reader[String]` both yield `Reader`); callers
# that need to distinguish instantiations work on the full label list.
fn row_label_names(labels: [RowLabel]) : [String] {
  match labels {
    [] -> []
    [l, ...rest] -> match l {
      RL(name, _) -> [name, ...row_label_names(rest)]
    }
  }
}

fn dump_decl(d: Decl, depth: Int) : Unit {
  match d {
    DFn(is_pub, name, tparams, params, opt_ret, row, body, line, col) -> {
      let pub_s = if is_pub { "pub " } else { "" }
      emit_line(depth, "fn #{pub_s}\"#{name}\" @#{int_to_string(line)}:#{int_to_string(col)}")
      tparams |> each((tp) => emit_line(depth + 1, "tparam #{tp}"))
      params |> each((pm) => dump_param(pm, depth + 1))
      match opt_ret { Some(ty) -> dump_type(ty, depth + 1) None -> () }
      dump_row_expr(row, depth + 1)
      dump_expr(body, depth + 1)
    }
    DType(is_pub, name, tparams, body, line, col) -> {
      let pub_s = if is_pub { "pub " } else { "" }
      emit_line(depth, "type #{pub_s}\"#{name}\" @#{int_to_string(line)}:#{int_to_string(col)}")
      tparams |> each((tp) => emit_line(depth + 1, "tparam #{tp}"))
      dump_type_body(body, depth + 1)
    }
    DTest(desc, body, line, col) -> {
      emit_line(depth, "test #{desc} @#{int_to_string(line)}:#{int_to_string(col)}")
      dump_expr(body, depth + 1)
    }
    DImport(ik, line, col) -> {
      match ik {
        IkPath(path) -> emit_line(depth, "import #{path} @#{int_to_string(line)}:#{int_to_string(col)}")
        IkAlias(path, a) -> emit_line(depth, "import #{path} as #{a} @#{int_to_string(line)}:#{int_to_string(col)}")
        IkSelective(path, names) -> {
          emit_line(depth, "import #{path} @#{int_to_string(line)}:#{int_to_string(col)}")
          names |> each((n) => emit_line(depth + 1, "sel #{n}"))
        }
      }
    }
    DEffect(is_pub, name, tparams, ops, line, col) -> {
      let pub_s = if is_pub { "pub " } else { "" }
      emit_line(depth, "effect #{pub_s}\"#{name}\" @#{int_to_string(line)}:#{int_to_string(col)}")
      tparams |> each((tp) => emit_line(depth + 1, "tparam #{tp}"))
      ops |> each((op) => dump_effect_op(op, depth + 1))
    }
    DProtocol(is_pub, name, ops, line, col) -> {
      let pub_s = if is_pub { "pub " } else { "" }
      emit_line(depth, "protocol #{pub_s}\"#{name}\" @#{int_to_string(line)}:#{int_to_string(col)}")
      ops |> each((op) => dump_proto_op(op, depth + 1))
    }
    DImpl(pname, target, ms, line, col) -> {
      emit_line(depth, "impl \"#{pname}\" for @#{int_to_string(line)}:#{int_to_string(col)}")
      dump_type(target, depth + 1)
      ms |> each((m) => dump_decl(m, depth + 1))
    }
    DDerive(names, inner, line, col) -> {
      let names_s = join_with(names, ", ")
      emit_line(depth, "#derive(#{names_s}) @#{int_to_string(line)}:#{int_to_string(col)}")
      dump_decl(inner, depth + 1)
    }
    DUnit(is_pub, name, alias_opt, line, col) -> {
      let pub_s = if is_pub { "pub " } else { "" }
      let body_s = match alias_opt {
        None -> ""
        Some(u) -> string_concat(" = ", unit_expr_display(u))
      }
      emit_line(depth, "unit #{pub_s}\"#{name}\"#{body_s} @#{int_to_string(line)}:#{int_to_string(col)}")
    }
  }
}

fn dump_proto_op(op: ProtoOp, depth: Int) : Unit {
  match op {
    POp(name, op_tparams, params, ret, line, col) -> {
      emit_line(depth, "op \"#{name}\" @#{int_to_string(line)}:#{int_to_string(col)}")
      op_tparams |> each((tp) => emit_line(depth + 1, "op_tparam #{tp}"))
      params |> each((pm) => dump_param(pm, depth + 1))
      dump_type(ret, depth + 1)
    }
  }
}

fn dump_effect_op(op: EffectOp, depth: Int) : Unit {
  match op {
    EOp(name, op_tparams, params, ret, line, col) -> {
      emit_line(depth, "op \"#{name}\" @#{int_to_string(line)}:#{int_to_string(col)}")
      op_tparams |> each((tp) => emit_line(depth + 1, "op_tparam #{tp}"))
      params |> each((pm) => dump_param(pm, depth + 1))
      dump_type(ret, depth + 1)
    }
  }
}

fn dump_param(pm: Param, depth: Int) : Unit {
  emit_line(depth, "param #{pm.pname} @#{int_to_string(pm.pline)}:#{int_to_string(pm.pcol)}")
  match pm.ptype { Some(ty) -> dump_type(ty, depth + 1) None -> () }
}

fn dump_type_body(tb: TypeBody, depth: Int) : Unit {
  match tb {
    TBAlias(ty) -> {
      emit_line(depth, "ty_alias")
      dump_type(ty, depth + 1)
    }
    TBRecord(fields) -> {
      emit_line(depth, "ty_record")
      fields |> each((fd) => dump_field_decl(fd, depth + 1))
    }
    TBSum(variants) -> {
      emit_line(depth, "ty_sum")
      variants |> each((v) => dump_variant(v, depth + 1))
    }
    TBEffectAlias(labels) -> {
      let s = if labels == [] { "ty_effect_alias (empty)" }
              else { string_concat("ty_effect_alias ", join_with(labels, " + ")) }
      emit_line(depth, s)
    }
  }
}

fn dump_field_decl(fd: FieldDecl, depth: Int) : Unit {
  match fd {
    FD(name, ty) -> {
      emit_line(depth, "field_decl #{name}")
      dump_type(ty, depth + 1)
    }
  }
}

fn dump_variant(v: Variant, depth: Int) : Unit {
  match v {
    Var(name, vargs) -> {
      emit_line(depth, "variant #{name}")
      vargs |> each((a) => dump_type(a, depth + 1))
    }
  }
}

fn dump_program(decls: [Decl]) : Unit / Console {
  print("program")
  decls |> each((d) => dump_decl(d, 1))
}

# ====================================================================
# checker: name resolution
# ====================================================================
#
# Mirrors stage 0's `check.c`. No type inference, no exhaustiveness —
# just "every identifier is bound somewhere in scope." Top-level names
# (fns, type constructors, imported names) are pre-registered so
# forward references work. Each scope introduced by a block, match
# arm, lambda, or function body is pushed and popped as the walker
# enters and leaves. Errors accumulate into `had_error`; the driver
# returns 1 when that flag is set.

type Env = { scopes: [[String]], had_error: Bool, file: String }

fn env_new(file: String) : Env = Env { scopes: [[]], had_error: false, file: file }

fn env_push(e: Env) : Env =
  Env { scopes: [[], ...e.scopes], had_error: e.had_error, file: e.file }

fn env_pop(e: Env) : Env {
  match e.scopes {
    [_, ...rest] -> Env { scopes: rest, had_error: e.had_error, file: e.file }
    _ -> e
  }
}

fn env_add(e: Env, name: String) : Env {
  match e.scopes {
    [top, ...rest] ->
      Env { scopes: [[name, ...top], ...rest], had_error: e.had_error, file: e.file }
    _ -> e
  }
}

fn list_has(names: [String], target: String) : Bool {
  match names {
    [] -> false
    [n, ...rest] -> if n == target { true } else { list_has(rest, target) }
  }
}

fn scopes_has(scopes: [[String]], target: String) : Bool {
  match scopes {
    [] -> false
    [top, ...rest] -> if list_has(top, target) { true } else { scopes_has(rest, target) }
  }
}

fn env_has(e: Env, name: String) : Bool = scopes_has(e.scopes, name)

fn env_all_names(e: Env) : [String] = concat_scopes(e.scopes, [])

fn concat_scopes(ss: [[String]], acc: [String]) : [String] {
  match ss {
    [] -> acc
    [scope, ...rest] -> concat_scopes(rest, list_append(acc, scope))
  }
}

fn env_mark_err(e: Env) : Env =
  Env { scopes: e.scopes, had_error: true, file: e.file }

fn chk_error(e: Env, line: Int, col: Int, msg: String) : Env {
  diag_error(e.file, line, col, msg)
  env_mark_err(e)
}

# ---- prelude seeding (kept in sync with stage 0's PRELUDE) ----

fn prelude_names() : [String] {
  [
    "print", "eprint", "read_file", "write_file", "read_line", "args",
    "exit", "panic",
    "int_to_string", "real_to_string", "string_to_int", "string_to_real",
    "string_length", "string_concat", "string_concat_all", "string_join",
    "string_split", "string_contains", "char_at",
    "string_slice", "char_to_int", "int_to_char",
    "list_length", "list_append", "list_reverse",
    "map", "filter", "reduce", "each",
    "array_make", "array_length", "array_get", "array_set", "array_grow",
    # m8 #7: mailbox runtime exposed as prelude functions; user-facing
    # API lives in stdlib/actor.kai's `with_mailbox` helper.
    # m8 #8: bounded variant takes (cap: Int, overflow_code: Int).
    "mailbox_alloc", "mailbox_alloc_bounded",
    "mailbox_send", "mailbox_recv", "mailbox_free",
    "Some", "None", "Ok", "Err",
    # m5 #4 — Perceus dup/drop magic names. The pass synthesises
    # ECall(EVar("__perceus_dup"), [...]) and ECall(EVar("__perceus_drop"),
    # [...]) AFTER inference; the emitter handles them via special cases
    # in emit_call_expr. They're listed here so the closure-capture
    # analyser does not treat them as free vars to capture inside lambda
    # bodies (which would emit invalid C: `kai___perceus_dup` is undeclared).
    "__perceus_dup", "__perceus_drop",
    # Bug 8 (docs/m12.8-followup.md): `unitless` removed from the
    # user-visible prelude. It was implemented as an emit-time
    # identity special case (no kai_prelude_unitless runtime fn),
    # which made first-class use (`x |> unitless`, `let f = unitless`)
    # crash at C compile. The emit special cases below were repurposed
    # for `__strip_unit`, the typer-internal erasure intrinsic that
    # the parametric `impl Show for Real[u: Unit]` body uses to feed
    # `Real<u>` into `real_to_string : Real -> String`.
    # m12.8.x phase 2 (Gap 1): compile-time unit reflection;
    # emitter lowers to a constant String literal.
    "unit_name",
    # m12.8 phase 2: typer-internal erasure of the unit annotation on a
    # dimensioned Real. NOT for user code — the `__` prefix marks it as
    # a compiler-generated name. Used by the parametric Show impl in
    # stdlib/protocols.kai to revive the dead `unitless` emit identity.
    "__strip_unit"
  ]
}

fn add_all(e: Env, names: [String]) : Env =
  reduce(names, e, (acc, n) => env_add(acc, n))

# ---- pattern bindings: walk a pattern and add its bound names ----

fn bind_pat(e: Env, pat: Pattern) : Env {
  match pat.pkind {
    PWild -> e
    PLit(_) -> e
    PBind(name) -> env_add(e, name)
    PList(pats, opt_rest) -> {
      let e1 = bind_pats_loop(e, pats)
      match opt_rest {
        Some(rname) -> env_add(e1, rname)
        None -> e1
      }
    }
    PVariant(_, subs) -> bind_pats_loop(e, subs)
    PVariantRecord(_, fields) -> bind_pfields_loop(e, fields)
    PRecord(fields) -> bind_pfields_loop(e, fields)
    PHole(_) -> e
    PAs(name, sub) -> bind_pat(env_add(e, name), sub)
  }
}

fn bind_pats_loop(e: Env, ps: [Pattern]) : Env {
  match ps {
    [] -> e
    [p, ...rest] -> bind_pats_loop(bind_pat(e, p), rest)
  }
}

fn bind_pfields_loop(e: Env, fs: [PField]) : Env {
  match fs {
    [] -> e
    [pf, ...rest] -> bind_pfields_loop(bind_pfield(e, pf), rest)
  }
}

fn bind_pfield(e: Env, pf: PField) : Env {
  match pf {
    # Shorthand `{ x }` binds `x` directly; the parser already builds the
    # equivalent of `{ x: x }` so bind_pat handles both cases uniformly.
    PField(_, sub, _) -> bind_pat(e, sub)
  }
}

# ---- expression walker ----

fn chk_expr(e: Env, x: Expr) : Env {
  match x.kind {
    EInt(_)    -> e
    EReal(_)   -> e
    EBool(_)   -> e
    EChar(_)   -> e
    EStr(_, _) -> e
    EUnit      -> e
    EUnder     -> e
    EPlaceholder -> e
    EVar(name) -> {
      if env_has(e, name) { e }
      else {
        let hint = match closest_name(name, env_all_names(e)) {
          Some(sug) -> " (did you mean `#{sug}`?)"
          None      -> ""
        }
        chk_error(e, x.line, x.col, "undefined name `#{name}`#{hint}")
      }
    }
    ECall(f, xs) -> {
      let e1 = chk_expr(e, f)
      chk_exprs(e1, xs)
    }
    EField(base, _) -> chk_expr(e, base)
    EIndex(base, idx) -> chk_expr(chk_expr(e, base), idx)
    EBinop(_, a, b) -> chk_expr(chk_expr(e, a), b)
    EUnop(_, inner) -> chk_expr(e, inner)
    EIf(c, a, opt_b) -> {
      let e1 = chk_expr(chk_expr(e, c), a)
      match opt_b {
        Some(b) -> chk_expr(e1, b)
        None -> e1
      }
    }
    EMatch(scrut, arms) -> {
      let e1 = chk_expr(e, scrut)
      chk_arms(e1, arms)
    }
    ELambda(params, body) -> {
      let e1 = env_push(e)
      let e2 = add_params(e1, params)
      let e3 = chk_expr(e2, body)
      env_pop(e3)
    }
    ERecordLit(_, fields) -> chk_field_inits(e, fields)
    EList(elems) -> chk_list_elems(e, elems)
    ERange(a, b, opt_step) -> {
      let e1 = chk_expr(chk_expr(e, a), b)
      match opt_step { Some(s) -> chk_expr(e1, s) None -> e1 }
    }
    EBlock(stmts, opt_final) -> {
      let e1 = env_push(e)
      let e2 = chk_stmts(e1, stmts)
      let e3 = match opt_final { Some(f) -> chk_expr(e2, f) None -> e2 }
      env_pop(e3)
    }
    EPipe(a, b) -> chk_expr(chk_expr(e, a), b)
    EHole(_) -> e          # holes bind no names; checker lets them pass silently
    ETodo(_) -> e          # m7d §1: same posture as a hole
    EBang(inner) -> chk_expr(e, inner)   # m7e §13: scope-walk the operand
    EHandle(body, _, _, init_opt, alias_opt, clauses, ret_opt) -> {
      # m7a #4e: `Eff as log` makes `log` a binding that names
      # the capability inside the body. We push a scope so the
      # name disappears once the body is done.
      # m7b #11: the init expression (`with State[T](init)`) lives
      # in the outer scope — its free vars are the surrounding env.
      let stateful = match init_opt { Some(_) -> true None -> false }
      let after_init = match init_opt {
        Some(ie) -> chk_expr(e, ie)
        None     -> e
      }
      let body_env = match alias_opt {
        Some(alias) -> env_add(env_push(after_init), alias)
        None        -> after_init
      }
      let e1 = chk_expr(body_env, body)
      let restored = match alias_opt {
        Some(_) -> env_pop(e1)
        None    -> e1
      }
      let e2 = chk_handler_clauses(restored, clauses, stateful)
      match ret_opt {
        Some(r) -> chk_handler_return(e2, r, stateful)
        None    -> e2
      }
    }
    # m12.5: literal carrying a unit annotation. Recurse into the inner
    # numeric literal; the unit symbols themselves are validated at
    # type-resolution time, not here.
    ELitUnit(inner, _) -> chk_expr(e, inner)
    # m7e §11: `variants[T]()` carries no value-level sub-expressions.
    # The TypeExpr is validated by the resolver (sum + nullary-only)
    # in a later pass, not here.
    EVariantsOf(_) -> e
  }
}

fn chk_handler_clauses(e: Env, cs: [HClause], stateful: Bool) : Env {
  match cs {
    [] -> e
    [c, ...rest] -> match c {
      HC(_, params, body, _, _) -> {
        let e1 = env_push(e)
        # m7b #11: parameterised handlers (`with State[T](init)`)
        # expose the current handler-state inside every clause as
        # `state` (and the alias `log` for accumulator-shaped handlers
        # like `Writer[W]`). They are aliases of the same slot — the
        # codegen layer resolves both to `self->state`.
        let e1s = if stateful { env_add(env_add(e1, "state"), "log") } else { e1 }
        let e2 = add_params(e1s, params)
        let e3 = chk_expr(e2, body)
        chk_handler_clauses(env_pop(e3), rest, stateful)
      }
    }
  }
}

fn chk_handler_return(e: Env, r: HReturn, stateful: Bool) : Env {
  match r {
    HR(name, body, _, _) -> {
      let e1 = env_push(e)
      let e2 = env_add(e1, name)
      let e2s = if stateful { env_add(env_add(e2, "state"), "log") } else { e2 }
      let e3 = chk_expr(e2s, body)
      env_pop(e3)
    }
  }
}

fn chk_exprs(e: Env, xs: [Expr]) : Env {
  match xs {
    [] -> e
    [h, ...rest] -> chk_exprs(chk_expr(e, h), rest)
  }
}

fn chk_field_inits(e: Env, fs: [FieldInit]) : Env {
  match fs {
    [] -> e
    [f, ...rest] -> match f {
      FI(_, val) -> chk_field_inits(chk_expr(e, val), rest)
    }
  }
}

fn chk_list_elems(e: Env, es: [ListElem]) : Env {
  match es {
    [] -> e
    [el, ...rest] -> match el {
      ElPlain(x)  -> chk_list_elems(chk_expr(e, x), rest)
      ElSpread(x) -> chk_list_elems(chk_expr(e, x), rest)
    }
  }
}

fn chk_arms(e: Env, arms: [Arm]) : Env {
  match arms {
    [] -> e
    [a, ...rest] -> chk_arms(chk_arm(e, a), rest)
  }
}

fn chk_arm(e: Env, a: Arm) : Env {
  match a {
    Arm(pat, guard, body) -> {
      let e1 = env_push(e)
      let e2 = bind_pat(e1, pat)
      let e3 = match guard { Some(g) -> chk_expr(e2, g) None -> e2 }
      let e4 = chk_expr(e3, body)
      env_pop(e4)
    }
  }
}

fn chk_stmts(e: Env, ss: [Stmt]) : Env {
  match ss {
    [] -> e
    [s, ...rest] -> chk_stmts(chk_stmt(e, s), rest)
  }
}

fn chk_stmt(e: Env, s: Stmt) : Env {
  match s {
    SLet(pat, _, rhs) -> {
      let e1 = chk_expr(e, rhs)
      bind_pat(e1, pat)
    }
    SAssert(cond, opt_msg) -> {
      let e1 = chk_expr(e, cond)
      match opt_msg { Some(m) -> chk_expr(e1, m) None -> e1 }
    }
    SExprStmt(x) -> chk_expr(e, x)
    # m7b #6: index-assign sugar — desugared away before this pass runs,
    # but kept arm here so the match stays exhaustive if name resolution
    # is invoked on the raw AST (e.g. from a future debug dump).
    SIndexAssign(base, idx, val, _, _) -> {
      let e1 = chk_expr(e, base)
      let e2 = chk_expr(e1, idx)
      chk_expr(e2, val)
    }
    # m7b #5b: `var name = init` is desugared away pre-resolve by
    # `desugar_var_decls`. This arm is dead code in normal compilation;
    # if a future debug mode skips the desugar, treat the binding like
    # `let` so the match stays exhaustive and follow-on resolution
    # still produces useful diagnostics.
    SVar(name, _, rhs, line, col) -> {
      let e1 = chk_expr(e, rhs)
      env_add(e1, name)
    }
  }
}

fn add_params(e: Env, ps: [Param]) : Env {
  match ps {
    [] -> e
    [p, ...rest] -> add_params(env_add(e, p.pname), rest)
  }
}

# ---- declaration walkers ----

fn chk_decl(e: Env, d: Decl) : Env {
  match d {
    DFn(_, _, _, params, _, _, body, _, _) -> {
      let e1 = env_push(e)
      let e2 = add_params(e1, params)
      let e3 = chk_expr(e2, body)
      env_pop(e3)
    }
    DType(_, _, _, _, _, _) -> e
    DTest(_, body, _, _) -> {
      let e1 = env_push(e)
      let e2 = chk_expr(e1, body)
      env_pop(e2)
    }
    DImport(_, _, _) -> e
    DEffect(_, _, _, _, _, _) -> e          # m7a #3c will register effect names
    # m12.8: protocol / impl / derive decls are stripped by
    # `lower_protocols` before `check_program` runs, so reaching one
    # here means the pipeline was driven directly into `chk_decl` (e.g.
    # via `--check` on a file that bypassed lowering, or a future
    # caller that forgot to lower first). Treat as a no-op rather than
    # a fatal error so the selfhost path continues to validate the
    # post-lowering decl stream.
    DProtocol(_, _, _, _, _) -> e
    DImpl(_, _, _, _, _) -> e
    DDerive(_, _, _, _) -> e
    DUnit(_, _, _, _, _) -> e               # m12.5: unit declarations introduce no value bindings
  }
}

fn chk_decls(e: Env, ds: [Decl]) : Env {
  match ds {
    [] -> e
    [d, ...rest] -> chk_decls(chk_decl(e, d), rest)
  }
}

# ---- top-level pre-registration ----

fn register_decls(e: Env, ds: [Decl]) : Env {
  match ds {
    [] -> e
    [d, ...rest] -> register_decls(register_one(e, d), rest)
  }
}

fn register_one(e: Env, d: Decl) : Env {
  match d {
    DFn(_, name, _, _, _, _, _, _, _) -> env_add(e, name)
    DType(_, name, _, body, _, _) -> {
      let e1 = env_add(e, name)
      match body {
        TBSum(variants) -> register_variants_env(e1, variants)
        _ -> e1
      }
    }
    DTest(_, _, _, _) -> e
    DImport(ik, _, _) -> register_import(e, ik)
    DEffect(_, name, _, _, _, _) -> env_add(e, name)
    # m12.8: stripped pre-resolve; never reaches register_one in
    # practice. No-op for completeness so the match stays exhaustive.
    DProtocol(_, _, _, _, _) -> e
    DImpl(_, _, _, _, _) -> e
    DDerive(_, _, _, _) -> e
    DUnit(_, _, _, _, _) -> e               # m12.5: unit names live in their own namespace, validated at type-resolve time
  }
}

fn register_variants_env(e: Env, vs: [Variant]) : Env {
  match vs {
    [] -> e
    [v, ...rest] -> match v {
      Var(name, _) -> register_variants_env(env_add(e, name), rest)
    }
  }
}

# For imports we add just the surface name: the last segment of the
# dotted path, the alias, or each selected name. Stage 0 does the
# same; deeper module resolution is a stage 2 concern.
fn last_segment(path: String) : String {
  last_segment_loop(path, string_length(path) - 1, string_length(path))
}

fn last_segment_loop(s: String, i: Int, end: Int) : String {
  if i < 0 { string_slice(s, 0, end) }
  else {
    match char_at(s, i) {
      Some(c) -> if c == '.' { string_slice(s, i + 1, end - i - 1) }
                 else { last_segment_loop(s, i - 1, end) }
      None -> string_slice(s, 0, end)
    }
  }
}

fn register_import(e: Env, ik: ImportKind) : Env {
  match ik {
    IkPath(path) -> env_add(e, last_segment(path))
    IkAlias(_, alias) -> env_add(e, alias)
    IkSelective(_, names) -> add_all(e, names)
  }
}

# ---- entry point ----

fn check_program(file: String, decls: [Decl]) : Int {
  let e0 = env_new(file)
  let e1 = add_all(e0, prelude_names())
  let e2 = register_decls(e1, decls)
  let e3 = chk_decls(e2, decls)
  let eff_names = collect_effect_names(decls)
  let arities = collect_effect_arities(decls)
  let row_errs = check_row_labels(decls, file, eff_names, arities)
  if e3.had_error or row_errs > 0 { 1 } else { 0 }
}

# m7b #11j — arity table built from every DEffect in the program.
# `inject_builtin_effects` runs before `check_program`, so the
# parametric stdlib effects (State, Reader, Writer) and any used
# default-handler effects are already in `decls`. Any builtin not
# yet injected (the user's main doesn't reference it) is filled in
# from `builtin_effect_arities()` so a helper can still use the
# effect with the right tparam count.
type EffArity = EA(String, Int)

fn collect_effect_arities(decls: [Decl]) : [EffArity] {
  let from_decls = collect_effect_arities_loop(decls)
  list_append(from_decls, builtin_effect_arities_filtered(from_decls))
}

fn collect_effect_arities_loop(decls: [Decl]) : [EffArity] {
  match decls {
    [] -> []
    [d, ...rest] -> match d {
      DEffect(_, name, tparams, _, _, _) ->
        [EA(name, list_length(tparams)), ...collect_effect_arities_loop(rest)]
      _ -> collect_effect_arities_loop(rest)
    }
  }
}

# Names known to `builtin_effect_names()` that the program did not
# declare or inject. Tparam counts are the canonical Doc B values
# (Console/Fail/Stdin/Env/File: 0; State/Reader/Writer: 1).
fn builtin_effect_arities_filtered(known: [EffArity]) : [EffArity] {
  let all = [
    EA("Console", 0), EA("Fail", 0), EA("Stdin", 0),
    EA("Env", 0), EA("File", 0),
    EA("State", 1), EA("Reader", 1), EA("Writer", 1),
    EA("Mutable", 0)
  ]
  filter_unknown_arities(all, known)
}

fn filter_unknown_arities(all: [EffArity], known: [EffArity]) : [EffArity] {
  match all {
    [] -> []
    [a, ...rest] -> match a {
      EA(n, _) ->
        if has_arity(known, n) { filter_unknown_arities(rest, known) }
        else { [a, ...filter_unknown_arities(rest, known)] }
    }
  }
}

fn has_arity(arities: [EffArity], target: String) : Bool {
  match arities {
    [] -> false
    [a, ...rest] -> match a {
      EA(n, _) -> if n == target { true } else { has_arity(rest, target) }
    }
  }
}

fn lookup_arity(arities: [EffArity], target: String) : Option[Int] {
  match arities {
    [] -> None
    [a, ...rest] -> match a {
      EA(n, k) -> if n == target { Some(k) } else { lookup_arity(rest, target) }
    }
  }
}

# ---- m7a #3c: name resolution for effect labels in rows ----
# Every label that appears in a `T / Eff + ...` suffix must refer to
# a declared effect. Anything else is a compile error. m7a #3 does
# not yet build evidence types or check the body's row against the
# declared row — those are #3d and #8.

fn collect_effect_names(decls: [Decl]) : [String] {
  match decls {
    [] -> []
    [d, ...rest] -> match d {
      DEffect(_, name, _, _, _, _) -> [name, ...collect_effect_names(rest)]
      _ -> collect_effect_names(rest)
    }
  }
}

fn check_row_labels(decls: [Decl], file: String, eff_names: [String],
                     arities: [EffArity]) : Int {
  match decls {
    [] -> 0
    [d, ...rest] ->
      check_decl_row_labels(d, file, eff_names, arities) +
      check_row_labels(rest, file, eff_names, arities)
  }
}

fn check_decl_row_labels(d: Decl, file: String, eff_names: [String],
                          arities: [EffArity]) : Int {
  match d {
    DFn(_, _, _, _, _, rexpr, _, line, col) ->
      check_row_expr(rexpr, file, line, col, eff_names, arities)
    _ -> 0
  }
}

fn check_row_expr(re: RowExpr, file: String, line: Int, col: Int,
                   eff_names: [String], arities: [EffArity]) : Int {
  match re {
    REmpty -> 0
    RClosed(labels) -> check_row_labels_loop(labels, file, line, col, eff_names, arities)
    # m7b #12: row variables in tail position carry the same labels;
    # apply the same name + arity check.
    ROpen(_, labels) -> check_row_labels_loop(labels, file, line, col, eff_names, arities)
  }
}

# m7b #11j — per-label name + arity check. Unknown effect → "unknown
# effect: X". Arity mismatch → "effect 'X' expects N type
# argument(s), got M".
fn check_row_labels_loop(labels: [RowLabel], file: String, line: Int, col: Int,
                          eff_names: [String], arities: [EffArity]) : Int {
  match labels {
    [] -> 0
    [l, ...rest] -> match l {
      RL(name, ts) -> {
        let got = list_length(ts)
        let here =
          if not list_has(eff_names, name) {
            let _ = diag_error(file, line, col,
              string_concat("unknown effect: ", name))
            let _ = diag_note("only declared `effect Foo { ... }` names and the catalog (Console, Fail, Stdin, Env, File, State, Reader, Writer, Mutable) are valid in a row")
            let _ = diag_help("declare `effect #{name} { ... }` first, or fix the spelling")
            1
          } else {
            match lookup_arity(arities, name) {
              None -> 0     # declared without arity — should not happen given collect_effect_arities covers all
              Some(want) ->
                if want == got { 0 }
                else {
                  let _ = diag_error(file, line, col,
                    concat_all(["effect '", name, "' expects ",
                                int_to_string(want),
                                " type argument(s), got ",
                                int_to_string(got)]))
                  let _ = diag_note("the parametric label must match the effect's `[...]` declaration")
                  let _ = diag_help(
                    if got > want {
                      concat_all(["drop ", int_to_string(got - want), " type argument(s) from `", name, "[...]`"])
                    } else {
                      concat_all(["add ", int_to_string(want - got), " more type argument(s) to `", name, "[...]`"])
                    })
                  1
                }
            }
          }
        here + check_row_labels_loop(rest, file, line, col, eff_names, arities)
      }
    }
  }
}

# ====================================================================
# emitter
# ====================================================================
#
# Produces C source that links against stage 0's runtime.h. This
# milestone (6) only covers what hello.kai needs — enough of expressions
# to emit a call, a string literal, a block body, and the top-level
# scaffolding (forward decls, thunks, int main). Subsequent milestones
# extend emit_expr to cover the rest of ExprKind.

# ---- small string helpers ----

fn cat2(a: String, b: String) : String = string_concat(a, b)
fn cat3(a: String, b: String, c: String) : String =
  string_concat(a, string_concat(b, c))
fn cat4(a: String, b: String, c: String, d: String) : String =
  string_concat(a, string_concat(b, string_concat(c, d)))
fn cat5(a: String, b: String, c: String, d: String, ee: String) : String =
  string_concat(a, string_concat(b, string_concat(c, string_concat(d, ee))))

fn concat_all(xs: [String]) : String = string_concat_all(xs)

fn join_with(xs: [String], sep: String) : String = string_join(xs, sep)

# ---- tables: user function arities, variant arities ----
#
# Stage 0 emit keeps parallel tables of user-defined function names and
# variant constructors; the ident dispatcher looks into both before
# falling back to a local. Stage 1 does the same; both tables are
# lists of sum-variant pairs.

type EFn  = EFn(String, Int)
type EVar = EV(String, Int)

fn efn_find(fns: [EFn], target: String) : Option[Int] {
  match fns {
    [] -> None
    [h, ...rest] -> match h {
      EFn(n, ar) -> if n == target { Some(ar) } else { efn_find(rest, target) }
    }
  }
}

fn evar_find(vs: [EVar], target: String) : Option[Int] {
  match vs {
    [] -> None
    [h, ...rest] -> match h {
      EV(n, ar) -> if n == target { Some(ar) } else { evar_find(rest, target) }
    }
  }
}

fn fn_of_decl(d: Decl) : Option[EFn] {
  match d {
    DFn(_, name, _, params, _, _, _, _, _) -> Some(EFn(name, list_length(params)))
    _ -> None
  }
}

fn register_fn_decls(decls: [Decl]) : [EFn] {
  match decls {
    [] -> []
    [d, ...rest] -> match fn_of_decl(d) {
      Some(fs) -> [fs, ...register_fn_decls(rest)]
      None -> register_fn_decls(rest)
    }
  }
}

fn builtin_variants() : [EVar] =
  [EV("Some", 1), EV("None", 0), EV("Ok", 1), EV("Err", 1)]

fn collect_user_variants_loop(ds: [Decl], acc: [EVar]) : [EVar] {
  match ds {
    [] -> acc
    [d, ...rest] -> match d {
      DType(_, _, _, body, _, _) -> match body {
        TBSum(vs) -> collect_user_variants_loop(rest, vs_to_evars(vs, acc))
        _ -> collect_user_variants_loop(rest, acc)
      }
      _ -> collect_user_variants_loop(rest, acc)
    }
  }
}

fn vs_to_evars(vs: [Variant], acc: [EVar]) : [EVar] {
  match vs {
    [] -> acc
    [v, ...rest] -> match v {
      Var(n, tys) -> vs_to_evars(rest, [EV(n, list_length(tys)), ...acc])
    }
  }
}

fn register_variants(decls: [Decl]) : [EVar] =
  collect_user_variants_loop(decls, builtin_variants())

# ---- prelude mapping for emission ----
#
# For user-facing builtins, we map to their runtime C symbol and arity.
# Stage 1 mirrors stage 0's table 1:1.

type EPrelude = EP(String, String, Int)     # kai name, c name, arity

fn prelude_table() : [EPrelude] {
  [
    EP("print",            "kai_prelude_print",            1),
    EP("eprint",           "kai_prelude_eprint",           1),
    EP("panic",            "kai_prelude_panic",            1),
    EP("exit",             "kai_prelude_exit",             1),
    EP("int_to_string",    "kai_prelude_int_to_string",    1),
    EP("real_to_string",   "kai_prelude_real_to_string",   1),
    EP("string_length",    "kai_prelude_string_length",    1),
    EP("string_concat",    "kai_prelude_string_concat",    2),
    EP("string_concat_all","kai_prelude_string_concat_all",1),
    EP("string_join",      "kai_prelude_string_join",      2),
    EP("list_length",      "kai_prelude_list_length",      1),
    EP("list_append",      "kai_prelude_list_append",      2),
    EP("list_reverse",     "kai_prelude_list_reverse",     1),
    EP("map",              "kai_prelude_map",              2),
    EP("filter",           "kai_prelude_filter",           2),
    EP("reduce",           "kai_prelude_reduce",           3),
    EP("each",             "kai_prelude_each",             2),
    EP("args",             "kai_prelude_args",             0),
    EP("read_file",        "kai_prelude_read_file",        1),
    EP("write_file",       "kai_prelude_write_file",       2),
    EP("read_line",        "kai_prelude_read_line",        0),
    EP("string_to_int",    "kai_prelude_string_to_int",    1),
    EP("string_to_real",   "kai_prelude_string_to_real",   1),
    EP("char_at",          "kai_prelude_char_at",          2),
    EP("string_split",     "kai_prelude_string_split",     2),
    EP("string_contains",  "kai_prelude_string_contains",  2),
    EP("string_slice",     "kai_prelude_string_slice",     3),
    EP("char_to_int",      "kai_prelude_char_to_int",      1),
    EP("int_to_char",      "kai_prelude_int_to_char",      1),
    EP("array_make",       "kai_prelude_array_make",       2),
    EP("array_length",     "kai_prelude_array_length",     1),
    EP("array_get",        "kai_prelude_array_get",        2),
    EP("array_set",        "kai_prelude_array_set",        3),
    EP("array_grow",       "kai_prelude_array_grow",       3),
    # m8 #7: mailbox runtime
    EP("mailbox_alloc",         "kai_prelude_mailbox_alloc",         0),
    EP("mailbox_alloc_bounded", "kai_prelude_mailbox_alloc_bounded", 2),
    EP("mailbox_send",          "kai_prelude_mailbox_send",          2),
    EP("mailbox_recv",          "kai_prelude_mailbox_recv",          1),
    EP("mailbox_free",          "kai_prelude_mailbox_free",          1)
  ]
}

fn prelude_find(target: String) : Option[EPrelude] {
  prelude_find_loop(prelude_table(), target)
}

fn prelude_find_loop(table: [EPrelude], target: String) : Option[EPrelude] {
  match table {
    [] -> None
    [ep, ...rest] -> match ep {
      EP(name, _, _) -> if name == target { Some(ep) } else { prelude_find_loop(rest, target) }
    }
  }
}

# ---- expression emission ----

fn emit_ident_callee(name: String) : String {
  match prelude_find(name) {
    Some(ep) -> match ep { EP(_, cname, _) -> cname }
    None -> cat2("kai_", name)
  }
}

# Emit an ident used as a value (not a call target).
fn emit_ident_value(name: String, fns: [EFn], variants: [EVar]) : String {
  match evar_find(variants, name) {
    Some(_) -> cat3("kai_variant(0, \"", name, "\", 0, NULL)")
    None -> match prelude_find(name) {
      Some(ep) -> match ep {
        EP(_, cname, ar) ->
          cat5("kai_closure(&_", cname, "_thunk, ", int_to_string(ar), ", 0, NULL)")
      }
      None -> match efn_find(fns, name) {
        Some(ar) ->
          cat5("kai_closure(&_kai_", name, "_thunk, ", int_to_string(ar), ", 0, NULL)")
        None -> cat2("kai_", name)
      }
    }
  }
}

# Emit a raw string literal's *body* as a C string literal. For now this
# only handles hello-style cases: no #{...} interpolation, no \u{HHHH},
# the escapes that kaikai and C share are passed through unchanged.
# Later milestones extend this to full interpolation.
fn emit_string_lit_body(span: String) : String {
  # span includes opening and closing quotes; C literal syntax matches.
  span
}

# m7d §23: pick the runtime helper a `++` lowers to. The typer
# pins the binop's result type to `String` or `[T]`; anything else
# means we lost the annotation somewhere upstream.
fn concat_helper_of(opt_ty: Option[Ty]) : String {
  match opt_ty {
    Some(t) -> match t {
      TyString    -> "kai_prelude_string_concat"
      TyListT(_)  -> "kai_prelude_list_append"
      _           -> "kai_prelude_string_concat /* m7d §23: unexpected type */"
    }
    None -> "kai_prelude_string_concat /* m7d §23: missing type */"
  }
}

fn binop_cname(op: String) : Option[String] {
  if op == "+" { Some("kai_add") }
  else if op == "-" { Some("kai_sub") }
  else if op == "*" { Some("kai_mul") }
  else if op == "/" { Some("kai_div") }
  else if op == "//" { Some("kai_idiv") }
  else if op == "%" { Some("kai_mod") }
  else if op == "<" { Some("kai_lt") }
  else if op == ">" { Some("kai_gt") }
  else if op == "<=" { Some("kai_le") }
  else if op == ">=" { Some("kai_ge") }
  else if op == "==" { Some("kai_eq_v") }
  else if op == "!=" { Some("kai_ne_v") }
  else { None }
}

fn unop_cname(op: String) : Option[String] {
  if op == "-" { Some("kai_neg") }
  else if op == "not" { Some("kai_boolnot") }
  else { None }
}

fn emit_call_args(src: String, args_e: [Expr], fns: [EFn], variants: [EVar], lams: [LamInfo]) : String =
  join_with(map(args_e, (a) => emit_expr(src, a, fns, variants, lams)), ", ")

fn emit_variant_call(name: String, n_args: Int, arg_out: String) : String {
  if n_args == 0 {
    cat3("kai_variant(0, \"", name, "\", 0, NULL)")
  } else {
    concat_all([
      "kai_variant(0, \"", name, "\", ", int_to_string(n_args),
      ", (KaiValue *[]){", arg_out, "})"
    ])
  }
}

fn emit_call_expr(src: String, f: Expr, args_e: [Expr], fns: [EFn], variants: [EVar], lams: [LamInfo]) : String {
  let call_args = emit_call_args(src, args_e, fns, variants, lams)
  match f.kind {
    EVar(callee) -> {
      # m7a #6d: `resume(v)` lowers to a runtime call that performs
      # the one-shot status check, flips the status, and tail-calls
      # the continuation's `fn` (currently kai_cont_identity, until
      # the full CPS transform reifies the rest of the caller's
      # body). Doc C §*resume representation*.
      if callee == "resume" {
        match args_e {
          [a] -> concat_all([
            "kai_cont_resume(k, ", emit_expr(src, a, fns, variants, lams), ")"
          ])
          # m7b #11: 2-arg resume `resume(v, new_state)` — used in
          # parameterised handler clauses (`State[T]` / `Writer[W]`).
          # Writes the new state into the enclosing Ev's `state` slot
          # before resuming. `self` is the clause's first argument.
          [a, ns] -> concat_all([
            "({ self->state = ",
            emit_expr(src, ns, fns, variants, lams),
            "; kai_cont_resume(k, ",
            emit_expr(src, a, fns, variants, lams),
            "); })"
          ])
          _   -> "kai_unit() /* resume: arity mismatch (expected 1 or 2 args) */"
        }
      } else if callee == "__perceus_dup" {
        # m5 #4 — AST-level dup, lowered to runtime `kai_incref`.
        # Inserted by `perceus_pass` around every non-last EVar read of
        # a binding that lives long enough to need an extra reference.
        match args_e {
          [a] -> concat_all([
            "kai_internal_dup(", emit_expr(src, a, fns, variants, lams), ")"
          ])
          _   -> "kai_unit() /* __perceus_dup: arity mismatch */"
        }
      } else if callee == "__strip_unit" {
        # m12.8 phase 2: typer-internal erasure of the unit annotation
        # on `Real<u>`. At runtime it is identity — units carry no
        # representation, so the lowered call is exactly the inner
        # expression. Inherits the original `unitless` emit shape
        # (Bug 8 retired the user-visible name; the parametric Show
        # impl in stdlib/protocols.kai now uses this intrinsic to feed
        # `Real<u>` into `real_to_string : Real -> String`).
        match args_e {
          [a] -> emit_expr(src, a, fns, variants, lams)
          _   -> "kai_unit() /* __strip_unit: expected 1 arg */"
        }
      } else if callee == "unit_name" {
        # m12.8.x phase 2 (Gap 1, partial): compile-time reflection
        # on the dimensioned argument. Inlines the canonical unit
        # symbol as a String literal. Reads the arg's `.ty` (which
        # the typed-AST finalisation pass populated with the fully
        # substituted type). When the unit is still a UVar (e.g.
        # the protocol-impl-generic case) or the arg type is bare
        # `Real` with no dimension, an empty string literal is
        # emitted instead of failing — keeps user code that calls
        # `unit_name` defensively well-defined.
        match args_e {
          [a] -> {
            let nm = unit_name_of_ty(a.ty)
            concat_all(["kai_str(\"", nm, "\")"])
          }
          _ -> "kai_unit() /* unit_name: expected 1 arg */"
        }
      } else if callee == "__perceus_drop" {
        # m5 #4 — AST-level drop, lowered to runtime `kai_decref`
        # (returns Unit so the call site type-checks as KaiValue *).
        match args_e {
          [a] -> concat_all([
            "kai_internal_drop(", emit_expr(src, a, fns, variants, lams), ")"
          ])
          _   -> "kai_unit() /* __perceus_drop: arity mismatch */"
        }
      } else if string_contains_dot(callee) {
        # m7a #6c/#6d/#6e: op call `Eff.op(args)`. Look up the
        # innermost EvEff node, allocate a KaiCont on the stack
        # (identity continuation for one-shot resume), and indirect-
        # call the op fn ptr. After the clause returns, if it never
        # called resume (status stays UNRESUMED), pop the evidence
        # and longjmp to the enclosing handle's setjmp landing pad
        # — Doc A §*Discarding the continuation*. The default
        # handlers (m7a #7) always resume, so the longjmp branch is
        # a no-op for them; the node's handle_jmp is NULL there.
        let eff_n = dotted_prefix(callee)
        let op_n_tagged = dotted_suffix(callee)
        # m7b #15 (compiler integration, scope-limited): the alias
        # rewrite tags op names with `@<alias>` when the original
        # callee was an `as`-bound capability. Split here: when
        # tagged, dispatch via the handle's local
        # `kai_alias_<alias>_id` (kai_evidence_lookup_node_by_id);
        # otherwise the standard innermost-by-name lookup.
        let at_pos = string_index_of_at(op_n_tagged)
        let op_n = if at_pos >= 0 { string_slice(op_n_tagged, 0, at_pos) } else { op_n_tagged }
        let alias_n = if at_pos >= 0 { string_slice(op_n_tagged, at_pos + 1, string_length(op_n_tagged)) } else { "" }
        let lookup_c =
          if at_pos >= 0 {
            concat_all(["kai_evidence_lookup_node_by_id(kai_alias_", alias_n, "_id)"])
          } else {
            concat_all(["kai_evidence_lookup_node(\"", eff_n, "\")"])
          }
        let arg_str = match args_e {
          [] -> ""
          _  -> cat2(", ", call_args)
        }
        concat_all([
          "({ KaiEvidence *_node_op = ", lookup_c, "; ",
          "Ev", eff_n, " *_ev_op = (Ev", eff_n, " *) _node_op->handler; ",
          "KaiCont _k; kai_cont_init_identity(&_k, _ev_op->handler_id); ",
          "KaiValue *_op_r = _ev_op->", op_n, "(_ev_op", arg_str, ", &_k); ",
          "if (_k.status == KAI_CONT_UNRESUMED && _node_op->handle_jmp != NULL) { ",
            "*_node_op->discard_slot = _op_r; ",
            "kai_evidence_pop(); ",
            "longjmp(*_node_op->handle_jmp, 1); ",
          "} ",
          "_op_r; })"
        ])
      } else {
      match evar_find(variants, callee) {
        Some(_) -> emit_variant_call(callee, list_length(args_e), call_args)
        None -> match prelude_find(callee) {
          Some(ep) -> match ep {
            EP(_, cname, _) -> cat4(cname, "(", call_args, ")")
          }
          None -> match efn_find(fns, callee) {
            Some(_) -> cat5("kai_", callee, "(", call_args, ")")
            None -> concat_all([
              "kai_apply(kai_", callee, ", ", int_to_string(list_length(args_e)),
              ", (KaiValue *[]){", call_args, "})"
            ])
          }
        }
      }
      }
    }
    _ -> {
      let fc = emit_expr(src, f, fns, variants, lams)
      concat_all([
        "kai_apply(", fc, ", ", int_to_string(list_length(args_e)),
        ", (KaiValue *[]){", call_args, "})"
      ])
    }
  }
}

fn emit_pipe_expr(src: String, lhs: Expr, rhs: Expr, fns: [EFn], variants: [EVar], lams: [LamInfo]) : String {
  let lhs_c = emit_expr(src, lhs, fns, variants, lams)
  match rhs.kind {
    ECall(f, args_e) -> match f.kind {
      EVar(callee) -> {
        let rest_args = emit_call_args(src, args_e, fns, variants, lams)
        let args_all = if list_length(args_e) == 0 { lhs_c } else { cat3(lhs_c, ", ", rest_args) }
        match evar_find(variants, callee) {
          Some(_) -> emit_variant_call(callee, list_length(args_e) + 1, args_all)
          None -> match prelude_find(callee) {
            Some(ep) -> match ep {
              EP(_, cname, _) -> cat4(cname, "(", args_all, ")")
            }
            None -> match efn_find(fns, callee) {
              Some(_) -> cat5("kai_", callee, "(", args_all, ")")
              None -> concat_all([
                "kai_apply(kai_", callee, ", ", int_to_string(list_length(args_e) + 1),
                ", (KaiValue *[]){", args_all, "})"
              ])
            }
          }
        }
      }
      _ -> {
        let fc = emit_expr(src, f, fns, variants, lams)
        let rest_args = emit_call_args(src, args_e, fns, variants, lams)
        let args_all = if list_length(args_e) == 0 { lhs_c } else { cat3(lhs_c, ", ", rest_args) }
        concat_all([
          "kai_apply(", fc, ", ", int_to_string(list_length(args_e) + 1),
          ", (KaiValue *[]){", args_all, "})"
        ])
      }
    }
    EVar(callee) -> {
      match evar_find(variants, callee) {
        Some(_) -> emit_variant_call(callee, 1, lhs_c)
        None -> match prelude_find(callee) {
          Some(ep) -> match ep { EP(_, cname, _) -> cat4(cname, "(", lhs_c, ")") }
          None -> match efn_find(fns, callee) {
            Some(_) -> cat5("kai_", callee, "(", lhs_c, ")")
            None -> concat_all([
              "kai_apply(kai_", callee,
              ", 1, (KaiValue *[]){", lhs_c, "})"
            ])
          }
        }
      }
    }
    _ -> concat_all([
      "kai_apply(", emit_expr(src, rhs, fns, variants, lams),
      ", 1, (KaiValue *[]){", lhs_c, "})"
    ])
  }
}

fn emit_range_expr(src: String, from: Expr, to: Expr, opt_step: Option[Expr],
                   fns: [EFn], variants: [EVar], lams: [LamInfo]) : String {
  let a = emit_expr(src, from, fns, variants, lams)
  let b = emit_expr(src, to, fns, variants, lams)
  match opt_step {
    None -> cat5("kai_range(", a, ", ", b, ")")
    Some(s) -> {
      let sc = emit_expr(src, s, fns, variants, lams)
      concat_all(["kai_range_step(", a, ", ", b, ", ", sc, ")"])
    }
  }
}

# ---- list literal emission ----

fn emit_list_tail(src: String, elems: [ListElem], fns: [EFn], variants: [EVar], lams: [LamInfo]) : String {
  match elems {
    [] -> "kai_nil()"
    # Tail spread `[..., ...xs]`: `kai_incref(xs)` gives the caller
    # a result whose RC is 1 and leaves xs untouched, matching the
    # ownership contract list_append used to provide via spine copy
    # — but in O(1) instead of O(|xs|). This collapses the O(n²)
    # blowup of the `[x, ...acc]` parser prepend pattern.
    [el] -> match el {
      ElPlain(x) -> concat_all(["kai_cons(", emit_expr(src,x, fns, variants, lams), ", kai_nil())"])
      ElSpread(x) -> concat_all(["kai_incref(", emit_expr(src, x, fns, variants, lams), ")"])
    }
    [el, ...rest] -> match el {
      ElPlain(x) -> concat_all([
        "kai_cons(", emit_expr(src,x, fns, variants, lams), ", ",
        emit_list_tail(src, rest, fns, variants, lams), ")"
      ])
      ElSpread(x) -> concat_all([
        "kai_prelude_list_append(", emit_expr(src,x, fns, variants, lams), ", ",
        emit_list_tail(src, rest, fns, variants, lams), ")"
      ])
    }
  }
}

fn emit_list_expr(src: String, elems: [ListElem], fns: [EFn], variants: [EVar], lams: [LamInfo]) : String =
  emit_list_tail(src, elems, fns, variants, lams)

# ---- record literal emission ----

fn emit_field_init_val(src: String, fi: FieldInit, fns: [EFn], variants: [EVar], lams: [LamInfo]) : String {
  match fi { FI(_, val) -> emit_expr(src,val, fns, variants, lams) }
}

fn emit_field_init_name(fi: FieldInit) : String {
  match fi { FI(name, _) -> cat3("\"", name, "\"") }
}

fn emit_record_lit(src: String, fields: [FieldInit], fns: [EFn], variants: [EVar], lams: [LamInfo]) : String {
  let n = list_length(fields)
  let vals = join_with(map(fields, (fi) => emit_field_init_val(src, fi, fns, variants, lams)), ", ")
  let names = join_with(map(fields, emit_field_init_name), ", ")
  concat_all([
    "kai_record(", int_to_string(n),
    ", (KaiValue *[]){", vals, "}, (const char *[]){", names, "})"
  ])
}

# ---- match: pattern test + bind emission ----

fn emit_pat_test(src: String, pat: Pattern, scr: String, fns: [EFn], variants: [EVar], lams: [LamInfo]) : String {
  match pat.pkind {
    PWild -> "1"
    PBind(_) -> "1"
    PLit(e) -> concat_all(["kai_eq(", scr, ", ", emit_expr(src,e, fns, variants, lams), ")"])
    PList(pats, opt_rest) -> emit_pat_test_list(src, pats, opt_rest, scr, fns, variants, lams)
    PVariant(name, subs) -> emit_pat_test_variant(src, name, subs, scr, fns, variants, lams)
    PVariantRecord(name, fields) -> emit_pat_test_variant_record(src, name, fields, scr, fns, variants, lams)
    PRecord(fields) -> emit_pat_test_record(src, fields, scr, fns, variants, lams)
    PHole(_) -> "1"
    # m7d §14: `name @ sub` matches iff `sub` matches; the binding
    # is performed by emit_pat_binds.
    PAs(_, sub) -> emit_pat_test(src, sub, scr, fns, variants, lams)
  }
}

fn emit_pat_test_list(src: String, pats: [Pattern], opt_rest: Option[String],
                      scr: String, fns: [EFn], variants: [EVar], lams: [LamInfo]) : String {
  let n_fixed = list_length(pats)
  let has_rest = match opt_rest { Some(_) -> true None -> false }
  if n_fixed == 0 and not has_rest {
    concat_all(["(", scr, " && ", scr, "->tag == KAI_NIL)"])
  } else {
    cat3("(", emit_pat_test_list_loop(src, pats, has_rest, scr, 0, n_fixed, fns, variants, lams), ")")
  }
}

fn emit_pat_test_list_loop(src: String, pats: [Pattern], has_rest: Bool,
                            cur: String, i: Int, n_fixed: Int,
                            fns: [EFn], variants: [EVar], lams: [LamInfo]) : String {
  if i >= n_fixed {
    if has_rest { "1" }
    else { concat_all([cur, " && ", cur, "->tag == KAI_NIL"]) }
  } else {
    let head = cat2(cur, "->as.cons.head")
    let tail = cat2(cur, "->as.cons.tail")
    let pi = list_nth(pats, i)
    let head_test = emit_pat_test(src, pi, head, fns, variants, lams)
    let cons_guard = concat_all([cur, " && ", cur, "->tag == KAI_CONS"])
    concat_all([
      cons_guard, " && ", head_test, " && ",
      emit_pat_test_list_loop(src, pats, has_rest, tail, i + 1, n_fixed, fns, variants, lams)
    ])
  }
}

fn list_nth(xs: [Pattern], i: Int) : Pattern {
  match xs {
    [] -> mk_pat(PWild, 0, 0)
    [h, ...rest] -> if i == 0 { h } else { list_nth(rest, i - 1) }
  }
}

fn emit_pat_test_variant(src: String, name: String, subs: [Pattern],
                         scr: String, fns: [EFn], variants: [EVar], lams: [LamInfo]) : String {
  let base = concat_all([
    "(", scr, " && ", scr, "->tag == KAI_VARIANT && strcmp(",
    scr, "->as.var.variant_name, \"", name, "\") == 0"
  ])
  cat3(base, emit_pat_test_variant_subs(src, subs, scr, 0, fns, variants, lams), ")")
}

fn emit_pat_test_variant_subs(src: String, subs: [Pattern], scr: String, i: Int,
                              fns: [EFn], variants: [EVar], lams: [LamInfo]) : String {
  match subs {
    [] -> ""
    [sp, ...rest] -> {
      let sub_scr = concat_all([scr, "->as.var.args[", int_to_string(i), "]"])
      let t = emit_pat_test(src, sp, sub_scr, fns, variants, lams)
      concat_all([" && ", t, emit_pat_test_variant_subs(src, rest, scr, i + 1, fns, variants, lams)])
    }
  }
}

fn emit_pat_test_record(src: String, fields: [PField], scr: String,
                        fns: [EFn], variants: [EVar], lams: [LamInfo]) : String {
  let base = concat_all(["(", scr, " && ", scr, "->tag == KAI_RECORD"])
  cat3(base, emit_pat_test_record_fields(src, fields, scr, fns, variants, lams), ")")
}

fn emit_pat_test_record_fields(src: String, fields: [PField], scr: String,
                               fns: [EFn], variants: [EVar], lams: [LamInfo]) : String {
  match fields {
    [] -> ""
    [pf, ...rest] -> match pf {
      PField(name, sub, _) -> {
        let tmp = concat_all(["kai_field(", scr, ", \"", name, "\")"])
        let t = emit_pat_test(src, sub, tmp, fns, variants, lams)
        concat_all([" && (", t, ")", emit_pat_test_record_fields(src, rest, scr, fns, variants, lams)])
      }
    }
  }
}

fn emit_pat_test_variant_record(src: String, name: String, fields: [PField], scr: String,
                                 fns: [EFn], variants: [EVar], lams: [LamInfo]) : String {
  # Variant with record destructuring: first check variant tag, then
  # record fields are accessed via kai_field on the scrutinee itself
  # because the emit side stores records directly in variants.
  let base = concat_all([
    "(", scr, " && ", scr, "->tag == KAI_VARIANT && strcmp(",
    scr, "->as.var.variant_name, \"", name, "\") == 0"
  ])
  cat3(base, emit_pat_test_record_fields(src, fields, scr, fns, variants, lams), ")")
}

fn emit_pat_binds(src: String, pat: Pattern, scr: String, fns: [EFn], variants: [EVar], lams: [LamInfo]) : String {
  match pat.pkind {
    PWild -> ""
    PLit(_) -> ""
    PBind(name) -> concat_all(["KaiValue *kai_", name, " = ", scr, "; "])
    PList(pats, opt_rest) -> emit_pat_binds_list(src, pats, opt_rest, scr, 0, fns, variants, lams)
    PVariant(_, subs) -> emit_pat_binds_variant(src, subs, scr, 0, fns, variants, lams)
    PVariantRecord(_, fields) -> emit_pat_binds_record(src, fields, scr, fns, variants, lams)
    PRecord(fields) -> emit_pat_binds_record(src, fields, scr, fns, variants, lams)
    PHole(_) -> ""
    # m7d §14: bind the as-name to the whole scrutinee, then descend
    # into the inner pattern's bindings on the same scrutinee.
    PAs(name, sub) -> cat2(
      concat_all(["KaiValue *kai_", name, " = ", scr, "; "]),
      emit_pat_binds(src, sub, scr, fns, variants, lams))
  }
}

fn emit_pat_binds_list(src: String, pats: [Pattern], opt_rest: Option[String],
                       cur: String, i: Int, fns: [EFn], variants: [EVar], lams: [LamInfo]) : String {
  match pats {
    [] -> match opt_rest {
      Some(name) -> concat_all(["KaiValue *kai_", name, " = ", cur, "; "])
      None -> ""
    }
    [p, ...rest] -> {
      let head = cat2(cur, "->as.cons.head")
      let tail = cat2(cur, "->as.cons.tail")
      cat2(emit_pat_binds(src, p, head, fns, variants, lams),
           emit_pat_binds_list(src, rest, opt_rest, tail, i + 1, fns, variants, lams))
    }
  }
}

fn emit_pat_binds_variant(src: String, subs: [Pattern], scr: String, i: Int,
                          fns: [EFn], variants: [EVar], lams: [LamInfo]) : String {
  match subs {
    [] -> ""
    [sp, ...rest] -> {
      let sub_scr = concat_all([scr, "->as.var.args[", int_to_string(i), "]"])
      cat2(emit_pat_binds(src, sp, sub_scr, fns, variants, lams),
           emit_pat_binds_variant(src, rest, scr, i + 1, fns, variants, lams))
    }
  }
}

fn emit_pat_binds_record(src: String, fields: [PField], scr: String,
                          fns: [EFn], variants: [EVar], lams: [LamInfo]) : String {
  match fields {
    [] -> ""
    [pf, ...rest] -> match pf {
      PField(name, sub, _) -> {
        let tmp = concat_all(["kai_field(", scr, ", \"", name, "\")"])
        cat2(emit_pat_binds(src, sub, tmp, fns, variants, lams),
             emit_pat_binds_record(src, rest, scr, fns, variants, lams))
      }
    }
  }
}

fn emit_match_arms(src: String, arms: [Arm], fns: [EFn], variants: [EVar], lams: [LamInfo]) : String =
  concat_all(map(arms, (a) => emit_match_arm(src, a, fns, variants, lams)))

fn emit_match_arm(src: String, a: Arm, fns: [EFn], variants: [EVar], lams: [LamInfo]) : String {
  match a {
    Arm(pat, opt_guard, body) -> {
      let pt = emit_pat_test(src, pat, "_scr", fns, variants, lams)
      let binds = emit_pat_binds(src, pat, "_scr", fns, variants, lams)
      let body_c = emit_expr(src,body, fns, variants, lams)
      match opt_guard {
        Some(g) -> {
          let gc = emit_expr(src,g, fns, variants, lams)
          concat_all([
            "    if (", pt, ") { ", binds,
            "if (kai_truthy(", gc, ")) { _r = ", body_c, "; break; } }\n"
          ])
        }
        None -> concat_all([
          "    if (", pt, ") { ", binds, "_r = ", body_c, "; break; }\n"
        ])
      }
    }
  }
}

fn emit_match_expr(src: String, scrut: Expr, arms: [Arm], fns: [EFn], variants: [EVar], lams: [LamInfo]) : String {
  let sc = emit_expr(src,scrut, fns, variants, lams)
  concat_all([
    "({ KaiValue *_scr = ", sc, "; KaiValue *_r = kai_unit(); do {\n",
    emit_match_arms(src, arms, fns, variants, lams),
    "    kai_prelude_panic(kai_str(\"non-exhaustive match\"));\n",
    "} while (0); _r; })"
  ])
}

# ---- string interpolation ----
#
# The raw span includes quotes: either 1 quote on each side for single-
# or 3 quotes for triple. We walk the body (between the quotes) and
# split into literal / expression parts at each `#{...}` boundary, then
# chain them via kai_string_concat wrapping each expression in
# kai_to_string.

type IPart = IpLit(String, String) | IpExp(String)   # lit: body_slice, raw_literal; exp: body_slice

fn interp_is_triple(span: String) : Bool {
  let n = string_length(span)
  if n < 6 { false }
  else {
    match char_at(span, 0) {
      Some(c) -> c == '"' and match char_at(span, 1) {
        Some(c2) -> c2 == '"' and match char_at(span, 2) {
          Some(c3) -> c3 == '"'
          None -> false
        }
        None -> false
      }
      None -> false
    }
  }
}

# Walk the inner body of a string span between (start, end), accumulating
# parts. At `#{`, open a new IpExp until the balanced `}`; otherwise
# grow the current literal span.
type IScan = { parts: [IPart], lit_start: Int, i: Int }

# `st.parts` accumulates in REVERSE here for O(1) prepend; the public
# iscan_collect entry point reverses once at the end.
fn iscan_collect_rev(span: String, end: Int, st: IScan) : [IPart] {
  if st.i >= end { finish_iscan_rev(span, end, st) }
  else {
    match char_at(span, st.i) {
      None -> finish_iscan_rev(span, end, st)
      Some(c) -> {
        let nxt = match char_at(span, st.i + 1) { Some(c2) -> c2 None -> ' ' }
        if c == '#' and nxt == '{' and st.i + 1 < end {
          let with_lit =
            if st.i > st.lit_start {
              let piece = string_slice(span, st.lit_start, st.i - st.lit_start)
              [IpLit(piece, cat3("\"", piece, "\"")), ...st.parts]
            } else { st.parts }
          let expr_start = st.i + 2
          let expr_end = iscan_expr_end(span, expr_start, end, 1)
          let expr_src = string_slice(span, expr_start, expr_end - expr_start)
          let new_parts = [IpExp(expr_src), ...with_lit]
          let next_i = if expr_end < end { expr_end + 1 } else { expr_end }
          iscan_collect_rev(span, end, IScan { parts: new_parts, lit_start: next_i, i: next_i })
        } else {
          iscan_collect_rev(span, end, IScan { parts: st.parts, lit_start: st.lit_start, i: st.i + 1 })
        }
      }
    }
  }
}

fn iscan_collect(span: String, end: Int, st: IScan) : [IPart] =
  list_reverse(iscan_collect_rev(span, end, st))

fn iscan_expr_end(span: String, i: Int, end: Int, depth: Int) : Int {
  if depth == 0 or i >= end { i }
  else {
    match char_at(span, i) {
      None -> i
      Some(c) -> {
        if c == '{' { iscan_expr_end(span, i + 1, end, depth + 1) }
        else if c == '}' {
          if depth == 1 { i }
          else { iscan_expr_end(span, i + 1, end, depth - 1) }
        }
        else { iscan_expr_end(span, i + 1, end, depth) }
      }
    }
  }
}

fn finish_iscan_rev(span: String, end: Int, st: IScan) : [IPart] {
  if st.lit_start < end {
    let piece = string_slice(span, st.lit_start, end - st.lit_start)
    [IpLit(piece, cat3("\"", piece, "\"")), ...st.parts]
  } else {
    st.parts
  }
}

fn emit_interp_parts(src: String, parts: [IPart], fns: [EFn], variants: [EVar], lams: [LamInfo]) : String {
  match parts {
    [] -> "kai_str(\"\")"
    [p] -> emit_interp_part(src, p, fns, variants, lams)
    [p, ...rest] -> concat_all([
      "kai_string_concat(",
      emit_interp_part(src, p, fns, variants, lams),
      ", ",
      emit_interp_parts(src, rest, fns, variants, lams),
      ")"
    ])
  }
}

fn emit_interp_part(src: String, p: IPart, fns: [EFn], variants: [EVar], lams: [LamInfo]) : String {
  match p {
    IpLit(_, raw) -> cat3("kai_str(", raw, ")")
    IpExp(expr_src) -> {
      let toks = tokenize(expr_src)
      let prs = parser_new("<interp>", expr_src, toks)
      let r = parse_expr(prs)
      match r.r {
        Some(e) -> cat3("kai_to_string(", emit_expr(src,e, fns, variants, lams), ")")
        None -> "kai_str(\"\")"
      }
    }
  }
}

fn emit_string_expr(src: String, span: String, is_triple: Bool, fns: [EFn], variants: [EVar], lams: [LamInfo]) : String {
  let n = string_length(span)
  let body_start = if is_triple { 3 } else { 1 }
  let body_end = if is_triple { n - 3 } else { n - 1 }
  # Fast path: if no `#{` appears, emit as a plain C literal.
  if not has_interp(span, body_start, body_end) {
    cat3("kai_str(", span, ")")
  } else {
    let parts = iscan_collect(span, body_end, IScan { parts: [], lit_start: body_start, i: body_start })
    emit_interp_parts(src, parts, fns, variants, lams)
  }
}

fn has_interp(span: String, i: Int, end: Int) : Bool {
  if i + 1 >= end { false }
  else {
    match char_at(span, i) {
      Some(c) -> {
        if c == '#' {
          match char_at(span, i + 1) {
            Some(c2) -> if c2 == '{' { true } else { has_interp(span, i + 1, end) }
            None -> false
          }
        } else { has_interp(span, i + 1, end) }
      }
      None -> false
    }
  }
}

# ---- lambda collection + emission ----
#
# We pre-walk the program building a list of LamInfo entries; each entry
# gets a unique id and records the lambda's params, its free variables
# (its closure captures), and its body. At emit time the lambda
# expression is replaced with `kai_closure(&_kai_lam_<id>, arity,
# n_caps, captures)`; the body is emitted as a separate function later.

type LamInfo = LamInfo(Int, Int, Int, [Param], [String], Expr)

# m7a #6c: each handler op clause becomes a top-level C function.
# The id pair (handle_line, handle_col) plus op_name uniquely names
# the clause (HCs do not nest within the same handle, and two
# handles cannot share both line and column). `params` is the
# clause's surface param list — the last one is the conventional
# `resume` binding (Doc A §*resume: one-shot, explicit*); m7a #6c
# treats `resume(v)` as direct-style identity and does not need to
# distinguish args from resume in the C signature beyond skipping
# the trailing slot.
# m7b #11: a clause is `stateful` (the trailing Bool) when its
# enclosing `handle` carries a state initializer (`with State[T](init)`
# / `with Writer[W]([])`). The codegen layer prepends a `kai_state` /
# `kai_log` alias of `self->state` to the clause body and emits the
# 2-arg `resume(v, ns)` form as a state write before resume.
type ClauseInfo = CI(Int, Int, String, String, [Param], Expr, Bool)

fn find_lam(lams: [LamInfo], line: Int, col: Int) : Option[LamInfo] {
  match lams {
    [] -> None
    [l, ...rest] -> match l {
      LamInfo(_, ln, cl, _, _, _) ->
        if ln == line and cl == col { Some(l) }
        else { find_lam(rest, line, col) }
    }
  }
}

# Free variables of an expression, given the lambda's own params and the
# program's globals. We skip descent into nested ELambdas (each gets its
# own capture set), and re-parse string interpolations so identifiers
# hidden inside #{...} get captured too.
fn fv_expr(x: Expr, own: [String], globals: [String], acc: [String]) : [String] {
  match x.kind {
    EInt(_)  -> acc
    EReal(_) -> acc
    EBool(_) -> acc
    EChar(_) -> acc
    EStr(span, is_triple) -> fv_interp(span, is_triple, own, globals, acc)
    EUnit -> acc
    EVar(name) -> {
      if list_has(own, name) { acc }
      else if list_has(globals, name) { acc }
      else if list_has(acc, name) { acc }
      else { [name, ...acc] }
    }
    EUnder -> acc
    EPlaceholder -> acc
    ECall(f, xs) -> fv_exprs(xs, own, globals, fv_expr(f, own, globals, acc))
    EField(base, _) -> fv_expr(base, own, globals, acc)
    EIndex(a, b) -> fv_expr(b, own, globals, fv_expr(a, own, globals, acc))
    EBinop(_, a, b) -> fv_expr(b, own, globals, fv_expr(a, own, globals, acc))
    EUnop(_, inner) -> fv_expr(inner, own, globals, acc)
    EIf(c, a, opt_b) -> {
      let acc1 = fv_expr(a, own, globals, fv_expr(c, own, globals, acc))
      match opt_b { Some(b) -> fv_expr(b, own, globals, acc1) None -> acc1 }
    }
    EMatch(scr, arms) -> fv_arms(arms, own, globals, fv_expr(scr, own, globals, acc))
    ELambda(_, _) -> acc                      # nested lambdas collect their own
    ETodo(_) -> acc
    EBang(inner) -> fv_expr(inner, own, globals, acc)
    ERecordLit(_, fields) -> fv_field_inits(fields, own, globals, acc)
    EList(elems) -> fv_list_elems(elems, own, globals, acc)
    ERange(a, b, opt_step) -> {
      let acc1 = fv_expr(b, own, globals, fv_expr(a, own, globals, acc))
      match opt_step { Some(s) -> fv_expr(s, own, globals, acc1) None -> acc1 }
    }
    EBlock(stmts, opt_final) -> {
      # m7b #18: track the scope as it grows through SLet / SVar so
      # the optional trailing expression sees the same bindings the
      # earlier statements introduced.
      let r = fv_stmts_scoped(stmts, own, globals, acc)
      match opt_final { Some(f) -> fv_expr(f, r.own, globals, r.acc) None -> r.acc }
    }
    EPipe(a, b) -> fv_expr(b, own, globals, fv_expr(a, own, globals, acc))
    EHole(_) -> acc
    EHandle(body, _, _, init_opt, alias_opt, clauses, ret_opt) -> {
      # m7b #11: free vars in the handler-state init expression
      # contribute to the surrounding scope.
      let acc0 = match init_opt {
        Some(ie) -> fv_expr(ie, own, globals, acc)
        None     -> acc
      }
      # m12.8.x phase 4 followup: when `with Eff(init) as name { body }`
      # binds an alias, treat that name as in-scope for the body —
      # references to it dispatch via the runtime evidence stack at
      # call time, not via a captured C local. Pre-fix the m7b #5b
      # desugar (`var top = 0` → `with State[Int](0) as top { ... }`)
      # caused inner lambdas to capture `top` as if it were a value;
      # the C emit then read `kai_top` against an undeclared
      # identifier. The alias is only in scope inside the body — not
      # in `init` (runs before the handler is installed) and not in
      # the clauses (which see `state` / `log` magic instead).
      let own_body = match alias_opt {
        Some(a) -> [a, ...own]
        None    -> own
      }
      let acc1 = fv_expr(body, own_body, globals, acc0)
      let acc2 = fv_hclauses(clauses, own, globals, acc1)
      match ret_opt { Some(r) -> fv_hreturn(r, own, globals, acc2) None -> acc2 }
    }
    # m12.5: literal-with-unit captures whatever the inner literal does
    # (always nothing in practice, since the inner is EInt/EReal).
    ELitUnit(inner, _) -> fv_expr(inner, own, globals, acc)
    # m7e §11: `variants[T]()` has no value-level sub-expressions, so
    # it captures nothing.
    EVariantsOf(_) -> acc
  }
}

fn fv_hclauses(cs: [HClause], own: [String], globals: [String], acc: [String]) : [String] {
  match cs {
    [] -> acc
    [c, ...rest] -> match c {
      HC(_, params, body, _, _) -> {
        # m7b #18: stateful handler clauses see two magic bindings —
        # `state` and `log` — that the codegen aliases to the
        # evidence struct's slot. Always include them in `own` so the
        # free-var collector does not promote them to lambda captures
        # when the whole `with State[T]` sits inside a closure body
        # (e.g. desugared `var` inside a lambda).
        let own_magic = ["state", "log", ...own]
        let own1 = list_concat_strings(map(params, (pm) => pm.pname), own_magic)
        let acc1 = fv_expr(body, own1, globals, acc)
        fv_hclauses(rest, own, globals, acc1)
      }
    }
  }
}

fn fv_hreturn(r: HReturn, own: [String], globals: [String], acc: [String]) : [String] {
  match r {
    # m7b #18: same `state` / `log` magic bindings as in
    # `fv_hclauses` apply here (Doc C §m7b #11l: stateful return
    # clauses see the handler-state alias too).
    HR(name, body, _, _) -> fv_expr(body, [name, "state", "log", ...own], globals, acc)
  }
}

fn list_concat_strings(a: [String], b: [String]) : [String] {
  match a {
    [] -> b
    [h, ...rest] -> [h, ...list_concat_strings(rest, b)]
  }
}

fn fv_exprs(xs: [Expr], own: [String], globals: [String], acc: [String]) : [String] {
  match xs {
    [] -> acc
    [h, ...rest] -> fv_exprs(rest, own, globals, fv_expr(h, own, globals, acc))
  }
}

fn fv_arms(arms: [Arm], own: [String], globals: [String], acc: [String]) : [String] {
  match arms {
    [] -> acc
    [a, ...rest] -> match a {
      Arm(pat, opt_g, body) -> {
        # m7b #18: extend `own` with the pattern's bound names so the
        # guard and body don't treat them as free vars when the arm
        # sits inside a lambda body.
        let own1 = pat_bindings(pat, own)
        let acc1 = match opt_g { Some(g) -> fv_expr(g, own1, globals, acc) None -> acc }
        fv_arms(rest, own, globals, fv_expr(body, own1, globals, acc1))
      }
    }
  }
}

# m7b #18: collect every name a pattern would bind into the accumulator,
# mirroring `bind_pat` (resolver) but operating on a [String] instead of
# an Env. Used by `fv_arms` and `fv_stmts` to keep `let` / pattern-bound
# names out of a lambda's free-var capture set.
fn pat_bindings(pat: Pattern, acc: [String]) : [String] {
  match pat.pkind {
    PWild -> acc
    PLit(_) -> acc
    PBind(name) -> [name, ...acc]
    PList(pats, opt_rest) -> {
      let acc1 = pat_bindings_loop(pats, acc)
      match opt_rest {
        Some(rname) -> [rname, ...acc1]
        None -> acc1
      }
    }
    PVariant(_, subs) -> pat_bindings_loop(subs, acc)
    PVariantRecord(_, fields) -> pfield_bindings_loop(fields, acc)
    PRecord(fields) -> pfield_bindings_loop(fields, acc)
    PHole(_) -> acc
    PAs(name, sub) -> pat_bindings(sub, [name, ...acc])
  }
}

fn pat_bindings_loop(ps: [Pattern], acc: [String]) : [String] {
  match ps {
    [] -> acc
    [p, ...rest] -> pat_bindings_loop(rest, pat_bindings(p, acc))
  }
}

fn pfield_bindings_loop(fs: [PField], acc: [String]) : [String] {
  match fs {
    [] -> acc
    [f, ...rest] -> match f {
      PField(_, sub, _) -> pfield_bindings_loop(rest, pat_bindings(sub, acc))
    }
  }
}

fn fv_field_inits(fs: [FieldInit], own: [String], globals: [String], acc: [String]) : [String] {
  match fs {
    [] -> acc
    [f, ...rest] -> match f {
      FI(_, val) -> fv_field_inits(rest, own, globals, fv_expr(val, own, globals, acc))
    }
  }
}

fn fv_list_elems(es: [ListElem], own: [String], globals: [String], acc: [String]) : [String] {
  match es {
    [] -> acc
    [el, ...rest] -> match el {
      ElPlain(x) -> fv_list_elems(rest, own, globals, fv_expr(x, own, globals, acc))
      ElSpread(x) -> fv_list_elems(rest, own, globals, fv_expr(x, own, globals, acc))
    }
  }
}

fn fv_stmts(ss: [Stmt], own: [String], globals: [String], acc: [String]) : [String] {
  let r = fv_stmts_scoped(ss, own, globals, acc)
  r.acc
}

# m7b #18: scoped variant of `fv_stmts` that also returns the scope as
# extended by every SLet / SVar in the list. Used by `EBlock` so the
# optional trailing expression sees the bindings introduced earlier in
# the block.
type FvScoped = { own: [String], acc: [String] }

fn fv_stmts_scoped(ss: [Stmt], own: [String], globals: [String], acc: [String]) : FvScoped {
  match ss {
    [] -> FvScoped { own: own, acc: acc }
    [s, ...rest] -> match s {
      SLet(pat, _, rhs) -> {
        let acc1 = fv_expr(rhs, own, globals, acc)
        let own1 = pat_bindings(pat, own)
        fv_stmts_scoped(rest, own1, globals, acc1)
      }
      SVar(name, _, rhs, _, _) -> {
        let acc1 = fv_expr(rhs, own, globals, acc)
        fv_stmts_scoped(rest, [name, ...own], globals, acc1)
      }
      _ -> fv_stmts_scoped(rest, own, globals, fv_stmt(s, own, globals, acc))
    }
  }
}

fn fv_stmt(s: Stmt, own: [String], globals: [String], acc: [String]) : [String] {
  match s {
    SLet(_, _, rhs) -> fv_expr(rhs, own, globals, acc)
    SAssert(c, opt_m) -> {
      let acc1 = fv_expr(c, own, globals, acc)
      match opt_m { Some(m) -> fv_expr(m, own, globals, acc1) None -> acc1 }
    }
    SExprStmt(x) -> fv_expr(x, own, globals, acc)
    SIndexAssign(b, i, v, _, _) -> {
      let acc1 = fv_expr(b, own, globals, acc)
      let acc2 = fv_expr(i, own, globals, acc1)
      fv_expr(v, own, globals, acc2)
    }
    # m7b #5: `var name = init` — desugared away pre-resolve. The free
    # variables of the init expression contribute; the bound name is a
    # local introduction (handled by the surrounding scope).
    SVar(_, _, rhs, _, _) -> fv_expr(rhs, own, globals, acc)
  }
}

fn fv_interp(span: String, is_triple: Bool, own: [String], globals: [String], acc: [String]) : [String] {
  let n = string_length(span)
  let body_start = if is_triple { 3 } else { 1 }
  let body_end = if is_triple { n - 3 } else { n - 1 }
  let parts = iscan_collect(span, body_end, IScan { parts: [], lit_start: body_start, i: body_start })
  fv_interp_parts(parts, own, globals, acc)
}

fn fv_interp_parts(parts: [IPart], own: [String], globals: [String], acc: [String]) : [String] {
  match parts {
    [] -> acc
    [p, ...rest] -> match p {
      IpLit(_, _) -> fv_interp_parts(rest, own, globals, acc)
      IpExp(esrc) -> {
        let toks = tokenize(esrc)
        let prs = parser_new("<interp>", esrc, toks)
        let r = parse_expr(prs)
        let acc1 = match r.r {
          Some(e) -> fv_expr(e, own, globals, acc)
          None -> acc
        }
        fv_interp_parts(rest, own, globals, acc1)
      }
    }
  }
}

# ---- lambda collection pass ----

type LamCollect = { next_id: Int, lams: [LamInfo], clauses: [ClauseInfo], globals: [String] }

fn lc_new(globals: [String]) : LamCollect =
  LamCollect { next_id: 0, lams: [], clauses: [], globals: globals }

fn params_to_names(ps: [Param]) : [String] =
  map(ps, (pm) => pm.pname)

fn collect_expr(x: Expr, st: LamCollect) : LamCollect {
  match x.kind {
    EInt(_)  -> st
    EReal(_) -> st
    EBool(_) -> st
    EChar(_) -> st
    EStr(span, is_triple) -> collect_interp(span, is_triple, st)
    EUnit -> st
    EVar(_) -> st
    EUnder -> st
    EPlaceholder -> st
    ECall(f, xs) -> collect_exprs(xs, collect_expr(f, st))
    EField(base, _) -> collect_expr(base, st)
    EIndex(a, b) -> collect_expr(b, collect_expr(a, st))
    EBinop(_, a, b) -> collect_expr(b, collect_expr(a, st))
    EUnop(_, inner) -> collect_expr(inner, st)
    EIf(c, a, opt_b) -> {
      let s1 = collect_expr(a, collect_expr(c, st))
      match opt_b { Some(b) -> collect_expr(b, s1) None -> s1 }
    }
    EMatch(scr, arms) -> collect_arms(arms, collect_expr(scr, st))
    ELambda(params, body) -> {
      let id = st.next_id
      let own = params_to_names(params)
      let caps = fv_expr(body, own, st.globals, [])
      let info = LamInfo(id, x.line, x.col, params, caps, body)
      let st1 = LamCollect { next_id: id + 1, lams: [info, ...st.lams], clauses: st.clauses, globals: st.globals }
      collect_expr(body, st1)
    }
    ERecordLit(_, fields) -> collect_field_inits(fields, st)
    EList(elems) -> collect_list_elems(elems, st)
    ERange(a, b, opt_step) -> {
      let s1 = collect_expr(b, collect_expr(a, st))
      match opt_step { Some(s) -> collect_expr(s, s1) None -> s1 }
    }
    EBlock(stmts, opt_final) -> {
      let s1 = collect_stmts(stmts, st)
      match opt_final { Some(f) -> collect_expr(f, s1) None -> s1 }
    }
    EPipe(a, b) -> collect_expr(b, collect_expr(a, st))
    EHole(_) -> st
    ETodo(_) -> st
    EBang(inner) -> collect_expr(inner, st)
    EHandle(body, eff_name, _, init_opt, alias_opt, clauses, ret_opt) -> {
      let stateful = match init_opt { Some(_) -> true None -> false }
      let s_init = match init_opt { Some(ie) -> collect_expr(ie, st) None -> st }
      let s0 = lc_record_clauses(clauses, eff_name, stateful, x.line, x.col, s_init)
      # m12.8.x phase 4 followup: when `with Eff(init) as name { body }`
      # binds an alias, mark `name` as an in-scope global for the body
      # walk so any inner lambda's free-var analysis treats references
      # to it as alias dispatches (resolved via the runtime evidence
      # stack), not as values that need capture in the closure
      # environment. Pre-fix the m7b #5b desugar (`var top = 0` →
      # `with State[Int](0) as top { ... }`) caused inner lambdas
      # passed to row-polymorphic helpers like `while` to capture
      # `top` as if it were a value, and the C emit then read
      # `kai_top` against an undeclared identifier. Surfaced via
      # `demos/spiral`. The alias is only in scope inside the body —
      # not in `init` (runs before the handler is installed) and not
      # in the clauses (which see `state` / `log` magic instead).
      let outer_globals = s0.globals
      let s_body_in = match alias_opt {
        Some(a) -> LamCollect {
          next_id: s0.next_id, lams: s0.lams,
          clauses: s0.clauses, globals: [a, ...outer_globals]
        }
        None -> s0
      }
      let s1_ext = collect_expr(body, s_body_in)
      let s1 = LamCollect {
        next_id: s1_ext.next_id, lams: s1_ext.lams,
        clauses: s1_ext.clauses, globals: outer_globals
      }
      let s2 = collect_hclauses(clauses, s1)
      match ret_opt { Some(r) -> collect_hreturn(r, s2) None -> s2 }
    }
    # m12.5: literal-with-unit — the inner literal contributes nothing,
    # but recurse so future non-literal carriers stay covered.
    ELitUnit(inner, _) -> collect_expr(inner, st)
    # m7e §11: `variants[T]()` produces no lambdas / no clauses to
    # collect. The TypeExpr is not a lambda host.
    EVariantsOf(_) -> st
  }
}

# m7a #6c: append one ClauseInfo per HClause of this handle. The
# (line, col) of the EHandle node is reused as the clause's stable
# id; the op_name disambiguates among clauses of the same handle.
fn lc_record_clauses(cs: [HClause], eff: String, stateful: Bool,
                     hline: Int, hcol: Int, st: LamCollect) : LamCollect {
  match cs {
    [] -> st
    [c, ...rest] -> match c {
      HC(op_name, params, body, _, _) -> {
        let info = CI(hline, hcol, eff, op_name, params, body, stateful)
        let st1 = LamCollect {
          next_id: st.next_id, lams: st.lams,
          clauses: [info, ...st.clauses], globals: st.globals
        }
        lc_record_clauses(rest, eff, stateful, hline, hcol, st1)
      }
    }
  }
}

fn collect_hclauses(cs: [HClause], st: LamCollect) : LamCollect {
  match cs {
    [] -> st
    [c, ...rest] -> match c {
      HC(_, _, body, _, _) -> collect_hclauses(rest, collect_expr(body, st))
    }
  }
}

fn collect_hreturn(r: HReturn, st: LamCollect) : LamCollect {
  match r {
    HR(_, body, _, _) -> collect_expr(body, st)
  }
}

fn collect_exprs(xs: [Expr], st: LamCollect) : LamCollect {
  match xs {
    [] -> st
    [h, ...rest] -> collect_exprs(rest, collect_expr(h, st))
  }
}

fn collect_arms(arms: [Arm], st: LamCollect) : LamCollect {
  match arms {
    [] -> st
    [a, ...rest] -> match a {
      Arm(_, opt_g, body) -> {
        let s1 = match opt_g { Some(g) -> collect_expr(g, st) None -> st }
        collect_arms(rest, collect_expr(body, s1))
      }
    }
  }
}

fn collect_field_inits(fs: [FieldInit], st: LamCollect) : LamCollect {
  match fs {
    [] -> st
    [f, ...rest] -> match f {
      FI(_, val) -> collect_field_inits(rest, collect_expr(val, st))
    }
  }
}

fn collect_list_elems(es: [ListElem], st: LamCollect) : LamCollect {
  match es {
    [] -> st
    [el, ...rest] -> match el {
      ElPlain(x) -> collect_list_elems(rest, collect_expr(x, st))
      ElSpread(x) -> collect_list_elems(rest, collect_expr(x, st))
    }
  }
}

fn collect_stmts(ss: [Stmt], st: LamCollect) : LamCollect {
  match ss {
    [] -> st
    [s, ...rest] -> collect_stmts(rest, collect_stmt(s, st))
  }
}

fn collect_stmt(s: Stmt, st: LamCollect) : LamCollect {
  match s {
    SLet(_, _, rhs) -> collect_expr(rhs, st)
    SAssert(c, opt_m) -> {
      let s1 = collect_expr(c, st)
      match opt_m { Some(m) -> collect_expr(m, s1) None -> s1 }
    }
    SExprStmt(x) -> collect_expr(x, st)
    SIndexAssign(b, i, v, _, _) -> {
      let s1 = collect_expr(b, st)
      let s2 = collect_expr(i, s1)
      collect_expr(v, s2)
    }
    # m7b #5: `var name = init` — desugared away pre-resolve.
    SVar(_, _, rhs, _, _) -> collect_expr(rhs, st)
  }
}

fn collect_interp(span: String, is_triple: Bool, st: LamCollect) : LamCollect {
  let n = string_length(span)
  let body_start = if is_triple { 3 } else { 1 }
  let body_end = if is_triple { n - 3 } else { n - 1 }
  let parts = iscan_collect(span, body_end, IScan { parts: [], lit_start: body_start, i: body_start })
  collect_interp_parts(parts, st)
}

fn collect_interp_parts(parts: [IPart], st: LamCollect) : LamCollect {
  match parts {
    [] -> st
    [p, ...rest] -> match p {
      IpLit(_, _) -> collect_interp_parts(rest, st)
      IpExp(esrc) -> {
        let toks = tokenize(esrc)
        let prs = parser_new("<interp>", esrc, toks)
        let r = parse_expr(prs)
        let st1 = match r.r { Some(e) -> collect_expr(e, st) None -> st }
        collect_interp_parts(rest, st1)
      }
    }
  }
}

fn collect_decl(d: Decl, st: LamCollect) : LamCollect {
  match d {
    DFn(_, _, _, _, _, _, body, _, _) -> collect_expr(body, st)
    DType(_, _, _, _, _, _) -> st
    DTest(_, body, _, _) -> collect_expr(body, st)
    DImport(_, _, _) -> st
    DEffect(_, _, _, _, _, _) -> st          # no expressions to walk
    # m12.8: stripped pre-resolve. No expressions to walk if one
    # somehow survives.
    DProtocol(_, _, _, _, _) -> st
    DImpl(_, _, _, _, _) -> st
    DDerive(_, _, _, _) -> st
    DUnit(_, _, _, _, _) -> st               # m12.5: no expressions in a unit decl
  }
}

fn collect_decls(ds: [Decl], st: LamCollect) : LamCollect {
  match ds {
    [] -> st
    [d, ...rest] -> collect_decls(rest, collect_decl(d, st))
  }
}

# Globals: prelude names + user fn names + variant ctor names. Used as a
# cheap "this ident does not need to be captured" test.
fn efn_name(e: EFn) : String = match e { EFn(n, _) -> n }
fn evar_name(v: EVar) : String = match v { EV(n, _) -> n }

fn build_globals(fns: [EFn], variants: [EVar], eff_names: [String], op_quals: [String]) : [String] {
  let p = prelude_names()
  let f = map(fns, efn_name)
  let v = map(variants, evar_name)
  # Effect names (e.g. `Console`) and qualified op references
  # (`Stdout.print`) are not runtime values; they are
  # name-resolved at op-call sites via the evidence stack.
  # `desugar_op_calls_callee` rewrites `EField(EVar(Eff), op)` into
  # `EVar("Eff.op")` (a single qualified ident), so without
  # including the qualified form in globals, `fv_expr` would treat
  # `Stdout.print` as a free variable inside a lambda body and the
  # lambda lifter would capture it, emitting invalid C
  # (`kai_Stdout.print` is not a valid C identifier).
  list_append(p,
    list_append(f,
      list_append(v,
        list_append(eff_names, op_quals))))
}

# For every `effect Eff { op_a(...) : T  op_b(...) : U }` decl,
# yield the qualified ident strings `"Eff.op_a"`, `"Eff.op_b"`.
# These match what `desugar_op_calls_callee` produces when it
# rewrites `Eff.op(args)` callees into `EVar("Eff.op")`.
fn op_qualified_names_for(eff_name: String, ops: [EffectOp], acc: [String]) : [String] {
  match ops {
    [] -> acc
    [o, ...rest] -> match o {
      EOp(op_name, _, _, _, _, _) ->
        op_qualified_names_for(eff_name, rest,
          [string_concat(eff_name, string_concat(".", op_name)), ...acc])
    }
  }
}

# m12.8 Phase 4b: (op_name, eff_name) pairs collected from every
# DEffect in the program. Used to resolve alias-qualified op calls
# (`Console.print` → `Stdout.print`, `Io.read_line` → `Stdin.read_line`).
type OpToEff = OEFP(String, String)

fn collect_op_to_eff(decls: [Decl]) : [OpToEff] {
  match decls {
    [] -> []
    [d, ...rest] -> match d {
      DEffect(_, eff_name, _, ops, _, _) ->
        list_append(ops_to_eff_pairs(eff_name, ops),
                    collect_op_to_eff(rest))
      _ -> collect_op_to_eff(rest)
    }
  }
}

fn ops_to_eff_pairs(eff_name: String, ops: [EffectOp]) : [OpToEff] {
  match ops {
    [] -> []
    [op, ...rest] -> match op {
      EOp(op_name, _, _, _, _, _) ->
        [OEFP(op_name, eff_name), ...ops_to_eff_pairs(eff_name, rest)]
    }
  }
}

# Returns Some(eff_name) if some component of the alias provides op_name.
# When multiple components share an op_name (currently impossible in
# the catalog — Stdout.print, Stderr.eprint, Stdin.read_line, etc., are
# disjoint), the leftmost component wins. The check is case-sensitive.
fn find_eff_for_alias_op(components: [String], op_to_eff: [OpToEff], op_name: String) : Option[String] {
  match components {
    [] -> None
    [c, ...rest] ->
      if eff_has_op(c, op_name, op_to_eff) { Some(c) }
      else { find_eff_for_alias_op(rest, op_to_eff, op_name) }
  }
}

fn eff_has_op(eff_name: String, op_name: String, op_to_eff: [OpToEff]) : Bool {
  match op_to_eff {
    [] -> false
    [oe, ...rest] -> match oe {
      OEFP(o, e) ->
        if o == op_name and e == eff_name { true }
        else { eff_has_op(eff_name, op_name, rest) }
    }
  }
}

# m12.8 Phase 4b: alias-aware op-call resolution lives inside
# `try_op_call` (typer) and `desugar_op_calls_callee` (emit) instead
# of as a standalone walker — a separate pre-pass blew the selfhost
# stack when traversing compiler.kai's deep AST. The helpers
# `find_alias` / `find_eff_for_alias_op` / `eff_has_op` (defined
# above) are consulted at each call site.

fn collect_op_qualified_names(decls: [Decl]) : [String] {
  match decls {
    [] -> []
    [d, ...rest] -> match d {
      DEffect(_, name, _, ops, _, _) ->
        list_append(op_qualified_names_for(name, ops, []),
                    collect_op_qualified_names(rest))
      _ -> collect_op_qualified_names(rest)
    }
  }
}

# ---- lambda helper emission ----

fn emit_lam_arg_reads(params: [Param], i: Int) : String {
  match params {
    [] -> ""
    [p, ...rest] -> concat_all([
      "    KaiValue *kai_", p.pname, " = args[", int_to_string(i), "];\n",
      emit_lam_arg_reads(rest, i + 1)
    ])
  }
}

fn emit_lam_cap_reads(caps: [String], i: Int) : String {
  match caps {
    [] -> ""
    [c, ...rest] -> concat_all([
      "    KaiValue *kai_", c, " = self->as.clo.captures[", int_to_string(i), "];\n",
      emit_lam_cap_reads(rest, i + 1)
    ])
  }
}

fn emit_lam_helper(src: String, l: LamInfo, fns: [EFn], variants: [EVar], lams: [LamInfo]) : String {
  match l {
    LamInfo(id, _, _, params, caps, body) -> {
      let arg_reads = emit_lam_arg_reads(params, 0)
      let cap_reads = emit_lam_cap_reads(caps, 0)
      let body_c = emit_expr(src,body, fns, variants, lams)
      concat_all([
        "static KaiValue *_kai_lam_", int_to_string(id),
        "(KaiValue *self, KaiValue **args, int n) {\n",
        "    (void) self; (void) n;\n",
        arg_reads, cap_reads,
        "    return ", body_c, ";\n}\n\n"
      ])
    }
  }
}

fn emit_lam_helpers(src: String, lams: [LamInfo], fns: [EFn], variants: [EVar]) : String =
  concat_all(map(lams, (l) => emit_lam_helper(src, l, fns, variants, lams)))

fn emit_one_lam_forward(l: LamInfo) : String =
  match l {
    LamInfo(id, _, _, _, _, _) ->
      concat_all(["static KaiValue *_kai_lam_", int_to_string(id), "(KaiValue *, KaiValue **, int);\n"])
  }

fn emit_lam_forward_decls(lams: [LamInfo]) : String =
  concat_all(map(lams, emit_one_lam_forward))

# m7a #6c — clause body emission. Each HClause becomes a top-level
# C function whose name encodes the EHandle's source position plus
# the op name (collisions are impossible since two distinct HCs
# either belong to different handles or carry different op names).
# The signature matches the EvE field type pinned in #6a:
#   `static KaiValue *_kai_clause_<line>_<col>_<op>(EvE *self, args..., KaiCont *k)`.
# `resume` is the surface convention for the trailing param and is
# never part of the C signature — the body uses `resume(v)` as
# direct-style identity (m7a #6c only). m7a #6d will replace this
# with a reified continuation closure.

fn op_args_only(params: [Param]) : [Param] {
  match params {
    [] -> []
    [_] -> []                       # the lone trailing `resume`
    [p, ...rest] -> [p, ...op_args_only(rest)]
  }
}

fn clause_fn_name(line: Int, col: Int, op: String) : String =
  concat_all([
    "_kai_clause_", int_to_string(line), "_", int_to_string(col), "_", op
  ])

fn emit_clause_sig(c: ClauseInfo) : String {
  match c {
    CI(line, col, eff, op_name, params, _, _) -> {
      let op_args = op_args_only(params)
      let arg_str = match op_args {
        [] -> ""
        _  -> cat2(", ", join_with(map(op_args, (pm) => cat2("KaiValue *kai_", pm.pname)), ", "))
      }
      concat_all([
        "static KaiValue *", clause_fn_name(line, col, op_name),
        "(Ev", eff, " *self", arg_str, ", KaiCont *k)"
      ])
    }
  }
}

fn emit_clause_forward(c: ClauseInfo) : String =
  cat2(emit_clause_sig(c), ";\n")

fn emit_clause_forwards(cs: [ClauseInfo]) : String =
  concat_all(map(cs, emit_clause_forward))

# m7b #11: stateful-clause prologue. `state` and `log` are aliases of
# `self->state`. Both names are bound (the two are aliases of the same
# slot — the spec uses `state` for `State[T]` and `log` for `Writer[W]`,
# but at this layer they read the same field). The clause body is then
# emitted unchanged: any `state` / `log` reference falls through the
# normal ident lookup and resolves to the local C alias.
fn clause_state_prologue(stateful: Bool) : String {
  if stateful {
    "    KaiValue *kai_state = self->state; KaiValue *kai_log = self->state;\n"
  } else { "" }
}

fn emit_clause_body(src: String, c: ClauseInfo, fns: [EFn], variants: [EVar],
                     lams: [LamInfo]) : String {
  match c {
    CI(_, _, _, _, _, body, stateful) -> {
      let body_c = emit_expr_in_clause(src, body, fns, variants, lams, stateful)
      concat_all([
        emit_clause_sig(c), " {\n",
        "    (void) self; (void) k;\n",
        clause_state_prologue(stateful),
        "    return ", body_c, ";\n",
        "}\n\n"
      ])
    }
  }
}

# Wrapper around `emit_expr` that flips the in-clause flag, so that
# `resume(v, ns)` lowers to a state-write before the resume call.
# Defined further below near emit_expr.
fn emit_expr_in_clause(src: String, e: Expr, fns: [EFn], variants: [EVar],
                        lams: [LamInfo], stateful: Bool) : String =
  emit_expr(src, e, fns, variants, lams)

fn emit_clause_bodies(src: String, cs: [ClauseInfo], fns: [EFn], variants: [EVar],
                      lams: [LamInfo]) : String =
  concat_all(map(cs, (c) => emit_clause_body(src, c, fns, variants, lams)))

# m7c-d — emit each clause as a top-level LLVM function. Mirrors
# `emit_clause_body`/`emit_clause_sig` from the C backend. The
# function takes `(EvX *self, %KaiValue* %arg1, ..., i8* %k)`
# and returns `%KaiValue*`. Inside, `self` and `k` are bound as
# locals (literal register names `%self` / `%k` so the resume
# handler in `llvm_emit_call` can reference `%k` directly). For
# stateful clauses we load `self->state` once into a local
# `%kai_state` (also bound as `%kai_log`) so the body can
# reference `state`/`log` like any other ident.
fn llvm_emit_clause_body(c: ClauseInfo, fns: [EFn], vs: [EVar], lams: [LamInfo],
                          oo: [OpOffset], start_id: Int) : LlvmDeclOut {
  match c {
    CI(line, col, eff, op_name, params, body, stateful) -> {
      let sym = clause_fn_name(line, col, op_name)
      let op_args = op_args_only(params)
      let arg_sig = llvm_clause_arg_sig(op_args)
      let locals0 = llvm_clause_locals(op_args)
      let e0 = LlvmEmit { ids: LlvmIdGen { next: start_id },
                          globals: "", body: "",
                          last_val: "", cur_label: "entry",
                          locals: locals0, fns: fns, vars_: vs, lams: lams,
                          op_offsets: oo }
      # Stateful prologue: read self->state into a fresh value and
      # bind it under both `state` and `log` so the body resolves.
      let e_pro = if stateful {
        let st_p_reg = llvm_fresh_reg(e0)
        let st_p_gep = concat_all([
          "  ", st_p_reg.reg, " = getelementptr %Ev", eff,
          ", %Ev", eff, "* %self, i32 0, i32 2\n"
        ])
        let e_p1 = llvm_append_body(st_p_reg.e, st_p_gep)
        let st_v_reg = llvm_fresh_reg(e_p1)
        let st_load = concat_all([
          "  ", st_v_reg.reg, " = load %KaiValue*, %KaiValue** ", st_p_reg.reg, "\n"
        ])
        let e_p2 = llvm_append_body(st_v_reg.e, st_load)
        let bound_state = llvm_push_local(e_p2, "state", st_v_reg.reg)
        llvm_push_local(bound_state, "log", st_v_reg.reg)
      } else { e0 }
      let e1 = llvm_emit_expr(e_pro, body)
      let text = concat_all([
        e1.globals,
        "\n",
        "define %KaiValue* @", sym,
        "(%Ev", eff, "* %self", arg_sig, ", i8* %k) {\n",
        e1.body,
        "  ret %KaiValue* ", e1.last_val, "\n",
        "}\n\n"
      ])
      LlvmDeclOut { text: text, next_id: e1.ids.next }
    }
  }
}

fn llvm_clause_arg_sig(ps: [Param]) : String {
  match ps {
    [] -> ""
    [p, ...rest] ->
      concat_all([", %KaiValue* %kai_", p.pname, llvm_clause_arg_sig(rest)])
  }
}

fn llvm_clause_locals(ps: [Param]) : [LlvmLocal] {
  match ps {
    [] -> []
    [p, ...rest] -> [LL(p.pname, concat_all(["%kai_", p.pname])),
                      ...llvm_clause_locals(rest)]
  }
}

fn llvm_emit_clause_bodies(cs: [ClauseInfo], fns: [EFn], vs: [EVar],
                            lams: [LamInfo], oo: [OpOffset],
                            start_id: Int, acc: String) : LlvmDeclOut {
  match cs {
    [] -> LlvmDeclOut { text: acc, next_id: start_id }
    [c, ...rest] -> {
      let out = llvm_emit_clause_body(c, fns, vs, lams, oo, start_id)
      llvm_emit_clause_bodies(rest, fns, vs, lams, oo,
                              out.next_id, string_concat(acc, out.text))
    }
  }
}

fn emit_closure_caps(caps: [String]) : String =
  join_with(map(caps, (c) => cat2("kai_", c)), ", ")

fn emit_lambda_ref(x: Expr, fns: [EFn], variants: [EVar], lams: [LamInfo]) : String {
  match find_lam(lams, x.line, x.col) {
    None -> "kai_unit() /* lambda: missing info */"
    Some(l) -> match l {
      LamInfo(id, _, _, params, caps, _) -> {
        let arity = list_length(params)
        let n_caps = list_length(caps)
        if n_caps == 0 {
          concat_all([
            "kai_closure(&_kai_lam_", int_to_string(id),
            ", ", int_to_string(arity), ", 0, NULL)"
          ])
        } else {
          concat_all([
            "kai_closure(&_kai_lam_", int_to_string(id),
            ", ", int_to_string(arity), ", ", int_to_string(n_caps),
            ", (KaiValue *[]){", emit_closure_caps(caps), "})"
          ])
        }
      }
    }
  }
}

# ---- full emit_expr (with lambda support) ----

fn emit_expr(src: String, x: Expr, fns: [EFn], variants: [EVar], lams: [LamInfo]) : String {
  match x.kind {
    EInt(n)      -> cat3("kai_int(", int_to_string(n), "LL)")
    EReal(r)     -> cat3("kai_real(", real_to_string(r), ")")
    EBool(b)     -> if b { "kai_bool(1)" } else { "kai_bool(0)" }
    EChar(c)     -> cat3("kai_char(", int_to_string(char_to_int(c)), ")")
    EStr(span, is_triple) -> emit_string_expr(src, span, is_triple, fns, variants, lams)
    EUnit        -> "kai_unit()"
    EVar(name)   -> emit_ident_value(name, fns, variants)
    EUnder       -> "kai_unit() /* _ */"
    EPlaceholder -> "kai_unit() /* placeholder */"
    ECall(f, args_e) -> emit_call_expr(src, f, args_e, fns, variants, lams)
    EField(base, fname) -> {
      let b = emit_expr(src, base, fns, variants, lams)
      cat5("kai_field(", b, ", \"", fname, "\")")
    }
    EIndex(_, _) -> "kai_unit() /* index: not used by bootstrap examples */"
    EBinop(op, a, b) -> {
      if op == "and" {
        concat_all([
          "({ KaiValue *_a = ", emit_expr(src, a, fns, variants, lams),
          "; kai_truthy(_a) ? ", emit_expr(src, b, fns, variants, lams),
          " : kai_bool(0); })"
        ])
      } else if op == "or" {
        concat_all([
          "({ KaiValue *_a = ", emit_expr(src, a, fns, variants, lams),
          "; kai_truthy(_a) ? kai_bool(1) : ", emit_expr(src, b, fns, variants, lams), "; })"
        ])
      } else if op == "++" {
        # m7d §23: lower `a ++ b` to either `string_concat(a, b)` or
        # `list_append(a, b)` depending on the binop's typed result.
        # The typer pins `x.ty` to `String` or `[T]` before we get
        # here; an untyped `++` is a typer bug we surface as a panic
        # stub so it shows up in fixtures.
        let helper = concat_helper_of(x.ty)
        concat_all([
          helper, "(",
          emit_expr(src, a, fns, variants, lams), ", ",
          emit_expr(src, b, fns, variants, lams), ")"
        ])
      } else {
        match binop_cname(op) {
          Some(cn) -> concat_all([
            cn, "(",
            emit_expr(src, a, fns, variants, lams), ", ",
            emit_expr(src, b, fns, variants, lams), ")"
          ])
          None -> cat3("kai_unit() /* unknown binop: ", op, " */")
        }
      }
    }
    EUnop(op, inner) -> {
      match unop_cname(op) {
        Some(cn) -> concat_all([cn, "(", emit_expr(src, inner, fns, variants, lams), ")"])
        None -> cat3("kai_unit() /* unknown unop: ", op, " */")
      }
    }
    EIf(c, a, opt_b) -> {
      let cc = emit_expr(src, c, fns, variants, lams)
      let tc = emit_expr(src, a, fns, variants, lams)
      let ec = match opt_b {
        Some(eb) -> emit_expr(src, eb, fns, variants, lams)
        None -> "kai_unit()"
      }
      concat_all(["(kai_truthy(", cc, ") ? ", tc, " : ", ec, ")"])
    }
    EMatch(scr, arms) -> emit_match_expr(src, scr, arms, fns, variants, lams)
    ELambda(_, _) -> emit_lambda_ref(x, fns, variants, lams)
    ERecordLit(_, fields) -> emit_record_lit(src, fields, fns, variants, lams)
    EList(elems) -> emit_list_expr(src, elems, fns, variants, lams)
    ERange(a, b, opt_step) -> emit_range_expr(src, a, b, opt_step, fns, variants, lams)
    EBlock(stmts, opt_final) -> {
      match stmts {
        [] -> match opt_final {
          Some(fe) -> emit_expr(src, fe, fns, variants, lams)
          None -> "kai_unit()"
        }
        _ -> {
          # m5 #3 — drops for unused let-bindings whose RHS is a
          # fresh allocation. See `block_unused_lets`. The set is
          # computed once per block so each let-binding's drop
          # decision considers all subsequent stmts and the trailing
          # final expression.
          let drops = block_unused_lets(stmts, opt_final)
          let stmt_out = concat_all(map(stmts,
            (s) => emit_stmt_with_drops(src, s, drops, fns, variants, lams)))
          let final_out = match opt_final {
            Some(fe) -> cat2(emit_expr(src, fe, fns, variants, lams), "; ")
            None -> "kai_unit(); "
          }
          cat4("({ ", stmt_out, final_out, "})")
        }
      }
    }
    EPipe(a, b) -> emit_pipe_expr(src, a, b, fns, variants, lams)
    EHole(nm_opt) -> {
      # Unfilled holes are runtime-panicky but syntactically valid:
      # the checker reports them and emission leaves a panic stub,
      # so a binary with holes is runnable — it just aborts loudly
      # on first reach.
      let label = match nm_opt { Some(nm) -> cat2("?", nm) None -> "?" }
      let msg = cat2("unfilled hole: ", label)
      concat_all(["kai_prelude_panic(kai_str(\"", msg, "\"))"])
    }
    ETodo(msg) -> {
      # m7d §1: `todo!(msg)` lowers to the same panic path as a hole
      # but with the user-supplied message, prefixed `todo: ` so the
      # binary's abort tag matches the source-form intent.
      let full = cat2("todo: ", msg)
      concat_all(["kai_prelude_panic(kai_str(\"", full, "\"))"])
    }
    EBang(inner) -> emit_bang(src, inner, fns, variants, lams)
    EHandle(body, eff_name, _eff_tyargs, init_opt, alias_opt, clauses, ret_opt) ->
      emit_handle(src, body, eff_name, init_opt, alias_opt, clauses, ret_opt, x.line, x.col, fns, variants, lams)
    # m12.5: codegen erasure — `1.0<USD>` emits the same C as `1.0`.
    # Units are typer-only; the generated value carries no unit tag.
    ELitUnit(inner, _) -> emit_expr(src, inner, fns, variants, lams)
    # m7e §11: `variants[T]()`. The real codegen (lookup the sum-type
    # T's variant list and materialise it as a kai_list literal) lives
    # in the m7e §11 codegen lane (task 16 of the variants[T]() Full
    # prereq); this site only keeps the match exhaustive so commits
    # before that lane still build. Until then any reachable use of
    # `variants[T]()` panics at runtime with a clear message.
    EVariantsOf(_) ->
      concat_all([
        "kai_prelude_panic(kai_str(\"variants[T]() codegen NYI (m7e §11 in flight)\"))"
      ])
  }
}

# m7e §13 — lower `expr!` to a statement-expression that evaluates
# `inner`, returns the success payload, or short-circuits the
# enclosing C function with an early `return`. The discriminator
# (`Some` vs `Ok`) is chosen from `inner.ty`, which the typer
# stamped to `Option[_]` or `Result[_, _]` after substitution. Any
# other shape here is a typer bug — we fall back to a panic stub
# rather than emit silently-wrong C.
fn emit_bang(src: String, inner: Expr, fns: [EFn], variants: [EVar],
             lams: [LamInfo]) : String {
  let inner_c = emit_expr(src, inner, fns, variants, lams)
  let success = bang_success_variant(inner.ty)
  match success {
    Some(name) -> concat_all([
      "({ KaiValue *_b = ", inner_c, "; ",
      "if (!(_b && _b->tag == KAI_VARIANT && strcmp(_b->as.var.variant_name, \"",
      name, "\") == 0)) return _b; ",
      "_b->as.var.args[0]; })"
    ])
    None -> concat_all([
      "kai_prelude_panic(kai_str(\"internal: `!` on non-Option/Result reached emitter\"))"
    ])
  }
}

fn bang_success_variant(opt_ty: Option[Ty]) : Option[String] {
  match opt_ty {
    None -> None
    Some(t) -> match t {
      TyCon(name, _) ->
        if name == "Option" { Some("Some") }
        else if name == "Result" { Some("Ok") }
        else { None }
      _ -> None
    }
  }
}

# m7a #6b/#6c: lower `handle { body } with Eff [as alias] { clauses }`
# to its prologue/body/epilogue. m7a #6b shipped the EvE alloca,
# the handler-id stamp, the kai_evidence_push/pop pair, and the
# optional return clause; m7a #6c populates each op fn-ptr with the
# top-level clause function emitted by emit_clause_body, so that op
# calls inside the body dispatch through the EvE.
# m7b #11: when `init_opt` is `Some(ie)`, write the init value into
# `_ev.state` after the handler-id and op-fn-ptr assignments. The
# clause body emitter exposes that slot inside clauses as `state` /
# `log` aliases of `self->state`.
fn emit_handle(src: String, body: Expr, eff_name: String, init_opt: Option[Expr],
               alias_opt: Option[String],
               clauses: [HClause],
               ret_opt: Option[HReturn], hline: Int, hcol: Int,
               fns: [EFn], variants: [EVar], lams: [LamInfo]) : String {
  let body_c = emit_expr(src, body, fns, variants, lams)
  let assigns = emit_clause_assignments(eff_name, clauses, hline, hcol)
  # m7b #15 (compiler integration): expose the handle's
  # `handler_id` as a local C variable named `kai_alias_<a>_id`
  # whenever the handle declared an `as`-bound capability. The
  # op-call dispatch (emit_call_expr) emits a
  # `kai_evidence_lookup_node_by_id(kai_alias_<a>_id)` call
  # whenever the alias rewrite tagged the op name with
  # `@<a>`. The local lives in the same statement-expression
  # as the rest of the handle prologue, so it is in scope for
  # every op-call site inside `body_c`.
  let alias_id_c = match alias_opt {
    Some(a) -> concat_all([
      "KaiHandlerId kai_alias_", a, "_id = _ev.handler_id; "
    ])
    None -> ""
  }
  let init_c = match init_opt {
    Some(ie) -> concat_all(["_ev.state = ", emit_expr(src, ie, fns, variants, lams), "; "])
    None     -> ""
  }
  let ret_c = match ret_opt {
    Some(r) -> match r {
      HR(pname, rexpr, _, _) -> {
        # m7b #11: when the handler is stateful, the return clause
        # also sees `state` / `log` (so `return(x) -> (x, state)` works).
        let stateful = match init_opt { Some(_) -> true None -> false }
        let prologue = if stateful {
          # _node is a KaiEvidence; its `handler` field is `&_ev`.
          "KaiValue *kai_state = _ev.state; KaiValue *kai_log = _ev.state; "
        } else { "" }
        concat_all([
          "KaiValue *kai_", pname, " = _body_result; ",
          prologue,
          emit_expr(src, rexpr, fns, variants, lams), ";"
        ])
      }
    }
    None -> "_body_result;"
  }
  # m7a #6e: handle owns a jmp_buf and a discard-value slot. If a
  # clause discards `resume`, the op-call site pops the evidence
  # and longjmps here; the setjmp-else branch picks the discarded
  # value as `_body_result` and the return clause runs as usual.
  # Push uses the *_with_jmp variant so the op site can find the
  # jmp via the looked-up KaiEvidence node.
  concat_all([
    "({ Ev", eff_name, " _ev = {0}; ",
    "_ev.handler_id = kai_fresh_handler_id(); ",
    assigns,
    init_c,
    "KaiEvidence _node; ",
    "jmp_buf _jmp; ",
    "KaiValue *_discard = NULL; ",
    "KaiValue *_body_result; ",
    alias_id_c,
    "if (setjmp(_jmp) == 0) { ",
      "kai_evidence_push_with_jmp(&_node, \"", eff_name, "\", &_ev, &_jmp, &_discard); ",
      "_body_result = ", body_c, "; ",
      "kai_evidence_pop(); ",
    "} else { ",
      "_body_result = _discard; ",
    "} ",
    ret_c,
    " })"
  ])
}

fn emit_clause_assignments(eff_name: String, cs: [HClause],
                           hline: Int, hcol: Int) : String {
  match cs {
    [] -> ""
    [c, ...rest] -> match c {
      HC(op_name, _, _, _, _) -> concat_all([
        "_ev.", op_name, " = &", clause_fn_name(hline, hcol, op_name), "; ",
        emit_clause_assignments(eff_name, rest, hline, hcol)
      ])
    }
  }
}

fn emit_stmt(src: String, s: Stmt, fns: [EFn], variants: [EVar], lams: [LamInfo]) : String {
  match s {
    SLet(pat, _, rhs) -> emit_let_stmt(src, pat, rhs, fns, variants, lams)
    SAssert(cond, opt_msg) -> emit_assert_stmt(src, cond, opt_msg, fns, variants, lams)
    SExprStmt(x) -> cat3("{ KaiValue *_ = ", emit_expr(src, x, fns, variants, lams), "; (void) _; } ")
    # m7b #6: index-assign desugars away pre-resolve; this arm is dead
    # code in normal compilation but keeps the match exhaustive.
    SIndexAssign(_, _, _, _, _) -> "/* SIndexAssign: should have been desugared */ "
    # m7b #5: `var name = init` desugars away pre-resolve; this arm
    # is dead code in normal compilation but keeps the match exhaustive.
    SVar(_, _, _, _, _) -> "/* SVar: should have been desugared */ "
  }
}

# m5 #3 — emit_stmt variant that consults the per-block drop set.
# Only `SLet` is augmented; the other stmt forms route through the
# original `emit_stmt` path. The set is the result of
# `block_unused_lets`, so a name only appears here when it is safe
# to decref immediately after the let.
fn emit_stmt_with_drops(src: String, s: Stmt, drops: [String],
                        fns: [EFn], variants: [EVar], lams: [LamInfo]) : String {
  match s {
    SLet(pat, _, rhs) ->
      emit_let_stmt_with_drops(src, pat, rhs, drops, fns, variants, lams)
    _ -> emit_stmt(src, s, fns, variants, lams)
  }
}

fn emit_let_stmt_with_drops(src: String, pat: Pattern, rhs: Expr,
                             drops: [String],
                             fns: [EFn], variants: [EVar], lams: [LamInfo]) : String {
  let rhs_c = emit_expr(src, rhs, fns, variants, lams)
  match pat.pkind {
    PBind(name) -> {
      let bind = concat_all(["KaiValue *kai_", name, " = ", rhs_c, "; "])
      if list_has(drops, name) {
        cat2(bind, concat_all(["kai_decref(kai_", name, "); "]))
      } else {
        bind
      }
    }
    # `let _ = expr` discards the value. If RHS is a fresh
    # allocation we can decref it; otherwise the original behaviour
    # (no decref) is preserved to avoid double-freeing an alias.
    PWild -> {
      if is_fresh_alloc(rhs) {
        cat3("{ KaiValue *_w = ", rhs_c, "; kai_decref(_w); } ")
      } else {
        cat3("{ KaiValue *_w = ", rhs_c, "; (void) _w; } ")
      }
    }
    _ -> {
      let binds = emit_pat_binds(src, pat, "_letv", fns, variants, lams)
      concat_all(["{ KaiValue *_letv = ", rhs_c, "; ", binds, "} "])
    }
  }
}

# A let-binding is "droppable" when:
#   1. The pattern is a single `PBind(name)` (no destructuring).
#   2. The RHS is a fresh allocation (rc=1, no aliasing — see
#      `is_fresh_alloc` for the conservative subset).
#   3. The bound name is never read in the rest of the block: later
#      stmts AND the trailing optional final expression.
# Returns the list of droppable names in the block. The walker
# from m5 #2 (`scan_uses_in_stmts` / `scan_uses_expr`) is reused
# unchanged.
fn block_unused_lets(stmts: [Stmt], opt_final: Option[Expr]) : [String] =
  block_unused_lets_loop(stmts, opt_final, [])

fn block_unused_lets_loop(stmts: [Stmt], opt_final: Option[Expr],
                          acc: [String]) : [String] {
  match stmts {
    [] -> list_reverse(acc)
    [s, ...rest] -> {
      let acc1 = match s {
        SLet(pat, _, rhs) -> match pat.pkind {
          PBind(nm) -> {
            if is_fresh_alloc(rhs) and not name_read_in_block(rest, opt_final, nm) {
              [nm, ...acc]
            } else { acc }
          }
          _ -> acc
        }
        _ -> acc
      }
      block_unused_lets_loop(rest, opt_final, acc1)
    }
  }
}

fn name_read_in_block(stmts: [Stmt], opt_final: Option[Expr], nm: String) : Bool {
  let stmt_uses = scan_uses_in_stmts(stmts, false)
  let final_uses = match opt_final {
    None -> []
    Some(e) -> scan_uses_expr(e, false)
  }
  any_use_of(list_append(stmt_uses, final_uses), nm)
}

fn any_use_of(uses: [Use], nm: String) : Bool {
  match uses {
    [] -> false
    [h, ...rest] -> match h {
      U(uname, _, _, _) ->
        if uname == nm { true } else { any_use_of(rest, nm) }
    }
  }
}

# Conservative "fresh allocation" predicate. Returns true when the
# RHS is known to materialise a value with rc=1 and no aliasing.
# False for `EVar` (alias of an existing binding), `EField` /
# `EIndex` (extracted ref into a parent), and the composite control
# forms (`EIf`, `EMatch`, `EBlock`, `EHandle`, `EPipe`) whose result
# can be a sub-expression aliased into the surrounding scope.
fn is_fresh_alloc(e: Expr) : Bool {
  match e.kind {
    EInt(_)         -> true
    EReal(_)        -> true
    EBool(_)        -> true
    EChar(_)        -> true
    EStr(_, _)      -> true
    EUnit           -> true
    ECall(_, _)     -> true
    EList(_)        -> true
    ERecordLit(_, _) -> true
    ERange(_, _, _) -> true
    ELambda(_, _)   -> true
    EBinop(_, _, _) -> true
    EUnop(_, _)     -> true
    _               -> false
  }
}

fn emit_let_stmt(src: String, pat: Pattern, rhs: Expr, fns: [EFn], variants: [EVar], lams: [LamInfo]) : String {
  let rhs_c = emit_expr(src, rhs, fns, variants, lams)
  match pat.pkind {
    PBind(name) -> concat_all(["KaiValue *kai_", name, " = ", rhs_c, "; "])
    PWild -> cat3("{ KaiValue *_w = ", rhs_c, "; (void) _w; } ")
    _ -> {
      # Destructuring let: bind a temp, then run pattern binds.
      let binds = emit_pat_binds(src, pat, "_letv", fns, variants, lams)
      concat_all(["{ KaiValue *_letv = ", rhs_c, "; ", binds, "} "])
    }
  }
}

fn emit_assert_stmt(src: String, cond: Expr, opt_msg: Option[Expr],
                    fns: [EFn], variants: [EVar], lams: [LamInfo]) : String {
  # kai_assert_check consults kai_test_in_progress at runtime and either
  # aborts (outside a test) or longjmps to the test harness (inside one),
  # so the emitter doesn't need to know whether it's in test mode.
  # `opt_msg` is ignored for now — we always pass the generic string,
  # matching stage 0's out-of-test panic path.
  let cc = emit_expr(src, cond, fns, variants, lams)
  concat_all(["kai_assert_check(", cc, ", \"assertion failed\"); "])
}

# ---- declaration emission ----

# m7a #6a: emit the `Ev<Eff>` struct per `effect Eff { ops }` decl,
# per docs/effects-impl.md §*Surface-to-runtime mapping*. Each op
# becomes a plain function-pointer field with `*Self` as the implicit
# first argument, the surface op args next, and a trailing `KaiCont
# *k` (the reified continuation). m7a #6a only emits the type; m7a
# #6b populates an EvE at handle entry, m7a #6c calls through it.
fn emit_op_fn_ptr_args(params: [Param]) : String {
  match params {
    [] -> ""
    _  -> cat2(", ", join_with(map(params, (pm) => cat2("KaiValue *kai_", pm.pname)), ", "))
  }
}

fn emit_op_fn_ptr(eff_name: String, op: EffectOp) : String {
  match op {
    EOp(op_name, _, params, _, _, _) ->
      concat_all([
        "    KaiValue *(*", op_name, ")(Ev", eff_name, " *self",
        emit_op_fn_ptr_args(params),
        ", KaiCont *k);\n"
      ])
  }
}

fn emit_effect_struct(d: Decl) : String {
  match d {
    DEffect(_, name, _tparams, ops, _, _) -> {
      let fields = concat_all(map(ops, (op) => emit_op_fn_ptr(name, op)))
      concat_all([
        "typedef struct Ev", name, " Ev", name, ";\n",
        "struct Ev", name, " {\n",
        "    KaiHandlerId handler_id;\n",
        "    void *env;\n",
        # m7b #11: every Ev struct carries a `state` slot for parameter-
        # ised handlers (`with State[T](init)` / `with Writer[W]([])`).
        # Stateless handlers leave it NULL — cost is one pointer per
        # handler instance; benefit is a uniform clause-body shape.
        "    KaiValue *state;\n",
        fields,
        "};\n\n"
      ])
    }
    _ -> ""
  }
}

fn effect_struct_decls(decls: [Decl]) : String =
  concat_all(map(decls, emit_effect_struct))

# m7c-a — LLVM equivalent of `emit_effect_struct`. Emits an
# `%EvX = type { i64, i8*, %KaiValue*, fn-ptrs... }` where the
# leading three fields mirror the C layout (handler_id, env,
# state slot) and each op contributes one function pointer.
# Doc C §m7c assumes the LLVM backend uses the same on-the-heap
# layout as the C backend so the runtime helpers can see both
# without translation.
fn llvm_emit_effect_struct(d: Decl) : String {
  match d {
    DEffect(_, name, _tparams, ops, _, _) -> {
      let fields = llvm_emit_op_fn_ptrs(name, ops)
      concat_all([
        "%Ev", name, " = type { i64, i8*, %KaiValue*",
        fields,
        " }\n"
      ])
    }
    _ -> ""
  }
}

fn llvm_emit_op_fn_ptrs(eff_name: String, ops: [EffectOp]) : String {
  match ops {
    [] -> ""
    [op, ...rest] -> match op {
      EOp(_, _, params, _, _, _) -> concat_all([
        ", %KaiValue* (%Ev", eff_name, "*",
        llvm_op_param_args(params),
        ", %KaiCont*)*",
        llvm_emit_op_fn_ptrs(eff_name, rest)
      ])
    }
  }
}

fn llvm_op_param_args(params: [Param]) : String {
  match params {
    [] -> ""
    [_, ...rest] -> concat_all([", %KaiValue*", llvm_op_param_args(rest)])
  }
}

fn llvm_effect_struct_decls(decls: [Decl]) : String =
  concat_all(map(decls, llvm_emit_effect_struct))

fn emit_param_list(params: [Param]) : String {
  match params {
    [] -> "void"
    _ -> join_with(map(params, (pm) => cat2("KaiValue *kai_", pm.pname)), ", ")
  }
}

fn emit_fn_signature(name: String, params: [Param]) : String =
  cat5("static KaiValue *kai_", name, "(", emit_param_list(params), ")")

fn emit_fn_forward(d: Decl) : String {
  match d {
    DFn(_, name, _, params, _, _, _, _, _) -> cat2(emit_fn_signature(name, params), ";\n")
    _ -> ""
  }
}

fn emit_thunk_forward(d: Decl) : String {
  match d {
    DFn(_, name, _, _, _, _, _, _, _) ->
      cat3("static KaiValue *_kai_", name, "_thunk(KaiValue *, KaiValue **, int);\n")
    _ -> ""
  }
}

fn emit_fn_body(src: String, d: Decl, fns: [EFn], variants: [EVar], lams: [LamInfo]) : String {
  match d {
    DFn(_, name, _, params, _, _, body, _, _) -> {
      let sig = emit_fn_signature(name, params)
      let body_c = emit_expr(src, body, fns, variants, lams)
      cat5(sig, " {\n    return ", body_c, ";\n", "}\n\n")
    }
    _ -> ""
  }
}

fn emit_param_args(params: [Param]) : String =
  join_with(map(params, (pm) => cat2("kai_", pm.pname)), ", ")

fn emit_param_reads(params: [Param], start: Int) : String {
  match params {
    [] -> ""
    [p, ...rest] ->
      cat2(
        concat_all(["    KaiValue *kai_", p.pname, " = args[", int_to_string(start), "];\n"]),
        emit_param_reads(rest, start + 1))
  }
}

fn emit_fn_thunk(d: Decl) : String {
  match d {
    DFn(_, name, _, params, _, _, _, _, _) -> {
      let param_reads = emit_param_reads(params, 0)
      let named_args = emit_param_args(params)
      let hdr = concat_all([
        "static KaiValue *_kai_", name,
        "_thunk(KaiValue *self, KaiValue **args, int n) {\n    (void) self; (void) n;\n"
      ])
      let call = concat_all(["    return kai_", name, "(", named_args, ");\n}\n\n"])
      concat_all([hdr, param_reads, call])
    }
    _ -> ""
  }
}

# ---- top-level passes ----

fn fn_forward_decls(decls: [Decl]) : String =
  concat_all(map(decls, emit_fn_forward))

fn thunk_forward_decls(decls: [Decl]) : String =
  concat_all(map(decls, emit_thunk_forward))

fn fn_bodies(src: String, decls: [Decl], fns: [EFn], variants: [EVar], lams: [LamInfo]) : String =
  concat_all(map(decls, (d) => {
    match d {
      DFn(_, _, _, _, _, _, _, _, _) -> cat2(emit_fn_body(src, d, fns, variants, lams), emit_fn_thunk(d))
      _ -> ""
    }
  }))

# ---- test function emission (always emitted; only called from int main
#      when test_mode is on) ----

fn emit_test_fn(src: String, id: Int, desc_span: String, body: Expr,
                fns: [EFn], variants: [EVar], lams: [LamInfo]) : String {
  # desc_span is the raw source of the description including its quotes,
  # so it's already a valid C string literal. We wrap the body in
  # setjmp/longjmp: kai_assert_check inside the body can longjmp us out
  # on failure, and the test still counts as a tried test.
  let body_c = emit_expr(src, body, fns, variants, lams)
  concat_all([
    "static void _kai_test_", int_to_string(id), "(void) {\n",
    "    kai_test_begin(", desc_span, ");\n",
    "    if (setjmp(kai_test_jmp) == 0) {\n",
    "        kai_test_in_progress = 1;\n",
    "        KaiValue *_body = ", body_c, ";\n",
    "        kai_decref(_body);\n",
    "        kai_test_in_progress = 0;\n",
    "        kai_test_pass();\n",
    "    } else {\n",
    "        kai_test_in_progress = 0;\n",
    "    }\n",
    "}\n\n"
  ])
}

fn test_decls(decls: [Decl]) : [Decl] =
  filter(decls, (d) => match d { DTest(_, _, _, _) -> true _ -> false })

fn emit_one_test(src: String, fns: [EFn], variants: [EVar], lams: [LamInfo],
                 id_d: DeclWithId) : String {
  match id_d {
    DWI(id, d) -> match d {
      DTest(desc_span, body, _, _) -> emit_test_fn(src, id, desc_span, body, fns, variants, lams)
      _ -> ""
    }
  }
}

# Helper pair to zip index with decl for clean iteration.
type DeclWithId = DWI(Int, Decl)

fn number_tests_loop(decls: [Decl], id: Int, acc: [DeclWithId]) : [DeclWithId] {
  match decls {
    [] -> list_reverse(acc)
    [d, ...rest] -> match d {
      DTest(_, _, _, _) -> number_tests_loop(rest, id + 1, [DWI(id, d), ...acc])
      _ -> number_tests_loop(rest, id, acc)
    }
  }
}

fn number_tests(decls: [Decl]) : [DeclWithId] =
  number_tests_loop(decls, 0, [])

fn emit_all_tests(src: String, decls: [Decl], fns: [EFn], variants: [EVar], lams: [LamInfo]) : String {
  let numbered = number_tests(decls)
  concat_all(map(numbered, (dwi) => emit_one_test(src, fns, variants, lams, dwi)))
}

fn test_count(decls: [Decl]) : Int = list_length(test_decls(decls))

fn test_call_list(n: Int, i: Int) : String {
  if i >= n { "" }
  else {
    concat_all(["    _kai_test_", int_to_string(i), "();\n", test_call_list(n, i + 1)])
  }
}

fn has_main_decl(decls: [Decl]) : Bool {
  match decls {
    [] -> false
    [d, ...rest] -> match d {
      DFn(_, n, _, _, _, _, _, _, _) -> if n == "main" { true } else { has_main_decl(rest) }
      _ -> has_main_decl(rest)
    }
  }
}

fn emit_main_wrapper(decls: [Decl], test_mode: Bool) : String {
  if test_mode {
    let n = test_count(decls)
    concat_all([
      "int main(int argc, char **argv) {\n",
      "    kai_set_args(argc, argv);\n",
      test_call_list(n, 0),
      "    return kai_test_summary();\n",
      "}\n"
    ])
  } else if has_main_decl(decls) {
    # m7a #7: install default handlers around `kai_main` only for
    # the builtin effects that appear in `main`'s row. The push/pop
    # pair is syntactically balanced (Doc C §*Per-fiber isolation*);
    # pop runs even if `kai_main` returns. Pops are emitted in
    # reverse-push order so the evidence stack stays LIFO-balanced.
    let main_row = main_row_labels(decls)
    let setup    = default_setups_for(main_row)
    let teardown = default_pops_for(main_row)
    concat_all([
      "int main(int argc, char **argv) {\n",
      "    kai_set_args(argc, argv);\n",
      setup,
      "    KaiValue *_result = kai_main();\n",
      teardown,
      "    kai_decref(_result);\n",
      "    return 0;\n",
      "}\n"
    ])
  } else {
    ""
  }
}

# m7a #7: extract the row labels declared on `fn main`. A row of
# `REmpty` returns []; `RClosed([Console, Fail])` returns those
# labels. The wrapper installs default handlers only for the
# subset of these that match a builtin effect.
fn main_row_labels(decls: [Decl]) : [String] {
  match decls {
    [] -> []
    [d, ...rest] -> match d {
      DFn(_, n, _, _, _, row, _, _, _) ->
        if n == "main" {
          match row {
            REmpty       -> []
            RClosed(lbs) -> row_label_names(lbs)
            ROpen(_, lbs) -> row_label_names(lbs)
          }
        } else { main_row_labels(rest) }
      _ -> main_row_labels(rest)
    }
  }
}

# m12.8 Phase 4b: atomic Stdout / Stderr default setups. The
# combined `Console` is an alias `type Console = Stdout + Stderr`,
# so a `main` declaring `/ Console` installs BOTH the Stdout and
# Stderr default handlers via the alias-expansion path in
# `default_setups_for`.
fn default_stdout_setup() : String =
  concat_all([
    "    static EvStdout _kai_default_ev_stdout;\n",
    "    static KaiEvidence _kai_default_node_stdout;\n",
    "    _kai_default_ev_stdout.handler_id = kai_fresh_handler_id();\n",
    "    _kai_default_ev_stdout.print = (KaiValue *(*)(EvStdout *, KaiValue *, KaiCont *)) &kai_default_stdout_print;\n",
    "    kai_evidence_push(&_kai_default_node_stdout, \"Stdout\", &_kai_default_ev_stdout);\n"
  ])

fn default_stderr_setup() : String =
  concat_all([
    "    static EvStderr _kai_default_ev_stderr;\n",
    "    static KaiEvidence _kai_default_node_stderr;\n",
    "    _kai_default_ev_stderr.handler_id = kai_fresh_handler_id();\n",
    "    _kai_default_ev_stderr.eprint = (KaiValue *(*)(EvStderr *, KaiValue *, KaiCont *)) &kai_default_stderr_eprint;\n",
    "    kai_evidence_push(&_kai_default_node_stderr, \"Stderr\", &_kai_default_ev_stderr);\n"
  ])

fn default_fail_setup() : String =
  concat_all([
    "    static EvFail _kai_default_ev_fail;\n",
    "    static KaiEvidence _kai_default_node_fail;\n",
    "    _kai_default_ev_fail.handler_id = kai_fresh_handler_id();\n",
    "    _kai_default_ev_fail.fail = (KaiValue *(*)(EvFail *, KaiValue *, KaiCont *)) &kai_default_fail_fail;\n",
    "    kai_evidence_push(&_kai_default_node_fail, \"Fail\", &_kai_default_ev_fail);\n"
  ])

fn default_stdin_setup() : String =
  concat_all([
    "    static EvStdin _kai_default_ev_stdin;\n",
    "    static KaiEvidence _kai_default_node_stdin;\n",
    "    _kai_default_ev_stdin.handler_id = kai_fresh_handler_id();\n",
    "    _kai_default_ev_stdin.read_line = (KaiValue *(*)(EvStdin *, KaiCont *)) &kai_default_stdin_read_line;\n",
    "    kai_evidence_push(&_kai_default_node_stdin, \"Stdin\", &_kai_default_ev_stdin);\n"
  ])

fn default_env_setup() : String =
  concat_all([
    "    static EvEnv _kai_default_ev_env;\n",
    "    static KaiEvidence _kai_default_node_env;\n",
    "    _kai_default_ev_env.handler_id = kai_fresh_handler_id();\n",
    "    _kai_default_ev_env.args = (KaiValue *(*)(EvEnv *, KaiCont *)) &kai_default_env_args;\n",
    "    _kai_default_ev_env.var  = (KaiValue *(*)(EvEnv *, KaiValue *, KaiCont *)) &kai_default_env_var;\n",
    "    kai_evidence_push(&_kai_default_node_env, \"Env\", &_kai_default_ev_env);\n"
  ])

fn default_file_setup() : String =
  concat_all([
    "    static EvFile _kai_default_ev_file;\n",
    "    static KaiEvidence _kai_default_node_file;\n",
    "    _kai_default_ev_file.handler_id = kai_fresh_handler_id();\n",
    "    _kai_default_ev_file.read_file  = (KaiValue *(*)(EvFile *, KaiValue *, KaiCont *)) &kai_default_file_read_file;\n",
    "    _kai_default_ev_file.write_file = (KaiValue *(*)(EvFile *, KaiValue *, KaiValue *, KaiCont *)) &kai_default_file_write_file;\n",
    "    kai_evidence_push(&_kai_default_node_file, \"File\", &_kai_default_ev_file);\n"
  ])

# Default Random handler — non-deterministic per-process PCG64
# seeded from time(NULL) ^ getpid() at first use. See
# `kai_default_random_int_range` in stage0/runtime.h.
fn default_random_setup() : String =
  concat_all([
    "    static EvRandom _kai_default_ev_random;\n",
    "    static KaiEvidence _kai_default_node_random;\n",
    "    _kai_default_ev_random.handler_id = kai_fresh_handler_id();\n",
    "    _kai_default_ev_random.int_range = (KaiValue *(*)(EvRandom *, KaiValue *, KaiValue *, KaiCont *)) &kai_default_random_int_range;\n",
    "    kai_evidence_push(&_kai_default_node_random, \"Random\", &_kai_default_ev_random);\n"
  ])

# m7b #2b: default Mutable handler — wraps the prelude `array_*`
# runtime functions with clauses that resume with the result. Each
# slot is initialised to the matching `kai_default_mutable_*`
# trampoline (defined in stage0/runtime.h).
fn default_mutable_setup() : String =
  concat_all([
    "    static EvMutable _kai_default_ev_mutable;\n",
    "    static KaiEvidence _kai_default_node_mutable;\n",
    "    _kai_default_ev_mutable.handler_id = kai_fresh_handler_id();\n",
    "    _kai_default_ev_mutable.array_make   = (KaiValue *(*)(EvMutable *, KaiValue *, KaiValue *, KaiCont *)) &kai_default_mutable_array_make;\n",
    "    _kai_default_ev_mutable.array_length = (KaiValue *(*)(EvMutable *, KaiValue *, KaiCont *)) &kai_default_mutable_array_length;\n",
    "    _kai_default_ev_mutable.array_get    = (KaiValue *(*)(EvMutable *, KaiValue *, KaiValue *, KaiCont *)) &kai_default_mutable_array_get;\n",
    "    _kai_default_ev_mutable.array_set    = (KaiValue *(*)(EvMutable *, KaiValue *, KaiValue *, KaiValue *, KaiCont *)) &kai_default_mutable_array_set;\n",
    "    _kai_default_ev_mutable.array_grow   = (KaiValue *(*)(EvMutable *, KaiValue *, KaiValue *, KaiValue *, KaiCont *)) &kai_default_mutable_array_grow;\n",
    "    kai_evidence_push(&_kai_default_node_mutable, \"Mutable\", &_kai_default_ev_mutable);\n"
  ])

# m8 #4: emit EvCancel + push it between the I/O group and Spawn
# (Doc B §*Installation order*). Single op `raise()`. The default
# resumes by exiting the program; user-installed Cancel handlers
# can wrap a region to run cleanup before the unwind escapes the
# wrapping `handle` block.
fn default_cancel_setup() : String =
  concat_all([
    "    static EvCancel _kai_default_ev_cancel;\n",
    "    static KaiEvidence _kai_default_node_cancel;\n",
    "    _kai_default_ev_cancel.handler_id = kai_fresh_handler_id();\n",
    "    _kai_default_ev_cancel.raise = (KaiValue *(*)(EvCancel *, KaiCont *)) &kai_default_cancel_raise;\n",
    "    kai_evidence_push(&_kai_default_node_cancel, \"Cancel\", &_kai_default_ev_cancel);\n"
  ])

# m8 #2/#3: emit EvSpawn + push it as the innermost default-handler
# node (Doc B §*Installation order*: Spawn sits closest to main,
# Cancel the layer below it, the I/O group below that). Wires all
# five ops to the inline-eager v1 defaults — see stage0/runtime.h
# for what each one does at runtime.
fn default_spawn_setup() : String =
  concat_all([
    "    static EvSpawn _kai_default_ev_spawn;\n",
    "    static KaiEvidence _kai_default_node_spawn;\n",
    "    _kai_default_ev_spawn.handler_id = kai_fresh_handler_id();\n",
    "    _kai_default_ev_spawn.yield  = (KaiValue *(*)(EvSpawn *, KaiCont *)) &kai_default_spawn_yield;\n",
    "    _kai_default_ev_spawn.spawn  = (KaiValue *(*)(EvSpawn *, KaiValue *, KaiCont *)) &kai_default_spawn_spawn;\n",
    "    _kai_default_ev_spawn.await  = (KaiValue *(*)(EvSpawn *, KaiValue *, KaiCont *)) &kai_default_spawn_await;\n",
    "    _kai_default_ev_spawn.select = (KaiValue *(*)(EvSpawn *, KaiValue *, KaiCont *)) &kai_default_spawn_select;\n",
    "    _kai_default_ev_spawn.cancel = (KaiValue *(*)(EvSpawn *, KaiValue *, KaiCont *)) &kai_default_spawn_cancel;\n",
    "    kai_evidence_push(&_kai_default_node_spawn, \"Spawn\", &_kai_default_ev_spawn);\n"
  ])

# m7a #7 + m7b #2b + m8 #2/#4 + m12.8 Phase 4b: assemble the full
# setup block for the builtins listed in `main`'s row. Push order
# Stdout → Stderr → Fail → Stdin → Env → File → Mutable → Cancel →
# Spawn matches Doc B §*Installation order*: Spawn innermost (last
# pushed, first looked up); Cancel the layer below it (root nursery
# flags fibers, Cancel handler unwinds); Mutable below Cancel (I/O
# cluster). Phase 4b: `Console` acts as the alias `Stdout + Stderr`,
# so a row containing it triggers both setups.
fn default_setups_for(main_row: [String]) : String = {
  # Phase 4b note: after alias expansion in `expand_aliases_in_decls`,
  # main's row never contains "Console" — it has been substituted
  # to `Stdout + Stderr + Stdin` already. We gate on the atomic
  # labels only; the older `or list_has(main_row, "Console")` was
  # dead code carried over from the pre-alias scaffolding.
  concat_all([
    if list_has(main_row, "Stdout")  { default_stdout_setup() } else { "" },
    if list_has(main_row, "Stderr")  { default_stderr_setup() } else { "" },
    if list_has(main_row, "Fail")    { default_fail_setup() }    else { "" },
    if list_has(main_row, "Stdin")   { default_stdin_setup() }   else { "" },
    if list_has(main_row, "Env")     { default_env_setup() }     else { "" },
    if list_has(main_row, "File")    { default_file_setup() }    else { "" },
    if list_has(main_row, "Random")  { default_random_setup() }  else { "" },
    if list_has(main_row, "Mutable") { default_mutable_setup() } else { "" },
    if list_has(main_row, "Cancel")  { default_cancel_setup() }  else { "" },
    if list_has(main_row, "Spawn")   { default_spawn_setup() }   else { "" }
  ])
}

# Pops in reverse-push order so the evidence stack drains LIFO.
fn default_pops_for(main_row: [String]) : String =
  concat_all([
    if list_has(main_row, "Spawn")   { "    kai_evidence_pop();\n" } else { "" },
    if list_has(main_row, "Cancel")  { "    kai_evidence_pop();\n" } else { "" },
    if list_has(main_row, "Mutable") { "    kai_evidence_pop();\n" } else { "" },
    if list_has(main_row, "Random")  { "    kai_evidence_pop();\n" } else { "" },
    if list_has(main_row, "File")    { "    kai_evidence_pop();\n" } else { "" },
    if list_has(main_row, "Env")     { "    kai_evidence_pop();\n" } else { "" },
    if list_has(main_row, "Stdin")   { "    kai_evidence_pop();\n" } else { "" },
    if list_has(main_row, "Fail")    { "    kai_evidence_pop();\n" } else { "" },
    if list_has(main_row, "Stderr")  { "    kai_evidence_pop();\n" } else { "" },
    if list_has(main_row, "Stdout")  { "    kai_evidence_pop();\n" } else { "" }
  ])

# m7b #5b/handle-as: rewrite alias-based callees `EField(EVar(alias),
# op)` to `EField(EVar(eff_name), op)` so the subsequent
# desugar_op_calls pass can fold them into `EVar("eff_name.op")`. The
# inferencer's synth_op_call_with_scheme already does this rewrite on
# the typed AST (via the alias table built from `with Eff as alias`),
# but check_infer is a diagnostic-only pass — its rewrite does not
# propagate into all_decls. This walker closes the gap. It is also
# what makes the m7b #5b `var x = init` desugar end-to-end: the
# desugar emits `with State[T](init) as x { ... x.get() ... }`, and
# this pass converts the body's `x.get()` calls to `State.get()` so
# desugar_op_calls + emit_call_expr can take it from there.
#
# Scope tracking: the alias map is pushed on entering an `EHandle`
# body when `alias_opt = Some(name)` and dropped on the way out. The
# init expression and the clause bodies are walked under the *outer*
# alias map (matching the inferencer's `st_push_alias` placement at
# synth_handle:9183-9186). Shadowing by an inner `let alias = ...` is
# not tracked — the resolver's binding rules already make that
# pattern resolve to the let, but for now this rewrite naively rewrites
# any `alias.op` it finds inside the body. Pinned in Doc C §m7b #5
# *Pre-resolve sugars*.
type AliasMap = AM([AliasBinding], Bool)   # bindings, may_tag

fn alias_map_empty() : AliasMap = AM([], true)

fn alias_map_push(m: AliasMap, name: String, eff: String) : AliasMap {
  # m7b #15: the rewrite-pass AliasMap stores the per-binding
  # taggability Bool inside AB so the inferencer's snapshots stay
  # symmetric, but the rewrite pass actually consults
  # `alias_map_may_tag(m)` (a per-map flag) to decide tagging.
  # Pass `true` here unconditionally — the per-map flag is what
  # gates EField tagging in `rewrite_alias_kind`.
  match m { AM(xs, t) -> AM([AB(name, eff, true), ...xs], t) }
}

fn alias_map_lookup(m: AliasMap, name: String) : Option[String] {
  match m { AM(xs, _) -> lookup_alias(xs, name) }
}

# m7b #15 (compiler integration, scope-limited): once we descend
# into a closure (lambda body), the handle prologue's
# `kai_alias_<a>_id` C local is no longer in scope. Mark the
# alias map so the EField rewrite stops tagging op names with
# `@<alias>` and falls back to the legacy name-keyed lookup.
# The bindings themselves stay live so the substitution
# `cap.op` → `Eff.op` keeps working inside the closure.
fn alias_map_disable_tag(m: AliasMap) : AliasMap {
  match m { AM(xs, _) -> AM(xs, false) }
}

fn alias_map_may_tag(m: AliasMap) : Bool {
  match m { AM(_, t) -> t }
}

# m7b #17: drop every binding for `name` from the alias map. Used
# when entering a scope (let / var / lambda param / match pattern)
# whose binder shadows an outer `with Eff as name`. Removes from
# the head down so the most recent re-bind no longer matches.
fn alias_map_remove(m: AliasMap, name: String) : AliasMap {
  match m { AM(xs, t) -> AM(alias_remove_loop(xs, name, []), t) }
}

fn alias_remove_loop(xs: [AliasBinding], name: String, acc: [AliasBinding]) : [AliasBinding] {
  match xs {
    [] -> list_reverse(acc)
    [h, ...rest] -> match h {
      AB(n, _, _) ->
        if n == name { alias_remove_loop(rest, name, acc) }
        else        { alias_remove_loop(rest, name, [h, ...acc]) }
    }
  }
}

# m7b #17: drop every binding whose name is in `names`. Convenience
# for shadowing by lambda params and match-arm patterns where the
# whole pattern's bound-name set lands in scope at once.
fn alias_map_remove_all(m: AliasMap, names: [String]) : AliasMap {
  match names {
    [] -> m
    [h, ...rest] -> alias_map_remove_all(alias_map_remove(m, h), rest)
  }
}

fn rewrite_alias_decls(ds: [Decl]) : [Decl] = map(ds, rewrite_alias_decl)

fn rewrite_alias_decl(d: Decl) : Decl {
  match d {
    DFn(pub_, n, tps, ps, ret, row, body, l, c) ->
      DFn(pub_, n, tps, ps, ret, row, rewrite_alias_expr(body, alias_map_empty()), l, c)
    DTest(desc, body, l, c) ->
      DTest(desc, rewrite_alias_expr(body, alias_map_empty()), l, c)
    _ -> d
  }
}

fn rewrite_alias_expr(e: Expr, m: AliasMap) : Expr =
  Expr { kind: rewrite_alias_kind(e.kind, m, e.line, e.col),
         line: e.line, col: e.col, ty: e.ty }

fn rewrite_alias_opt(opt: Option[Expr], m: AliasMap) : Option[Expr] {
  match opt {
    Some(e) -> Some(rewrite_alias_expr(e, m))
    None    -> None
  }
}

# m7b #17: walk a statement list with shadow-aware alias map.
# Each SLet / SVar binds its name(s) for the rest of the block, so
# subsequent statements (and the trailing expression handled in
# the EBlock arm) see a map with those names removed. Without this
# the walker would rewrite an inner `let x = ...; x.op()` against
# an outer `with Eff as x` even though the inner `x` shadows.
type StmtsRewrite = { stmts: [Stmt], m: AliasMap }

fn rewrite_alias_stmts_scoped(ss: [Stmt], m: AliasMap, acc: [Stmt]) : StmtsRewrite {
  match ss {
    [] -> StmtsRewrite { stmts: list_reverse(acc), m: m }
    [s, ...rest] -> match s {
      SLet(pat, ann, rhs) -> {
        let s1 = SLet(pat, ann, rewrite_alias_expr(rhs, m))
        let m1 = alias_map_remove_all(m, pat_bindings(pat, []))
        rewrite_alias_stmts_scoped(rest, m1, [s1, ...acc])
      }
      SVar(n, ty, rhs, l, c) -> {
        let s1 = SVar(n, ty, rewrite_alias_expr(rhs, m), l, c)
        let m1 = alias_map_remove(m, n)
        rewrite_alias_stmts_scoped(rest, m1, [s1, ...acc])
      }
      _ -> rewrite_alias_stmts_scoped(rest, m, [rewrite_alias_stmt(s, m), ...acc])
    }
  }
}

fn rewrite_alias_stmt(s: Stmt, m: AliasMap) : Stmt {
  match s {
    SLet(pat, ann, rhs) -> SLet(pat, ann, rewrite_alias_expr(rhs, m))
    SAssert(c, msg) -> SAssert(rewrite_alias_expr(c, m), rewrite_alias_opt(msg, m))
    SExprStmt(x) -> SExprStmt(rewrite_alias_expr(x, m))
    SIndexAssign(b, i, v, l, c) ->
      SIndexAssign(rewrite_alias_expr(b, m), rewrite_alias_expr(i, m),
                   rewrite_alias_expr(v, m), l, c)
    SVar(n, ty, rhs, l, c) -> SVar(n, ty, rewrite_alias_expr(rhs, m), l, c)
  }
}

fn rewrite_alias_arms(arms: [Arm], m: AliasMap) : [Arm] =
  map(arms, (a) => rewrite_alias_arm(a, m))

# m7b #17: pattern bindings shadow outer aliases inside the arm's
# guard and body — same idea as the SLet shadow in stmts.
fn rewrite_alias_arm(a: Arm, m: AliasMap) : Arm {
  match a {
    Arm(p, g, b) -> {
      let m1 = alias_map_remove_all(m, pat_bindings(p, []))
      Arm(p, rewrite_alias_opt(g, m1), rewrite_alias_expr(b, m1))
    }
  }
}

fn rewrite_alias_clauses(cs: [HClause], m: AliasMap) : [HClause] =
  map(cs, (c) => rewrite_alias_clause(c, m))

fn rewrite_alias_clause(c: HClause, m: AliasMap) : HClause {
  match c {
    HC(n, ps, b, l, co) -> {
      # m7b #17: clause params (op args + the trailing `resume`)
      # shadow outer aliases inside the clause body.
      let names = map(ps, (pm) => pm.pname)
      let m1 = alias_map_remove_all(m, names)
      HC(n, ps, rewrite_alias_expr(b, m1), l, co)
    }
  }
}

fn rewrite_alias_opt_return(opt: Option[HReturn], m: AliasMap) : Option[HReturn] {
  match opt {
    Some(r) -> Some(rewrite_alias_return(r, m))
    None    -> None
  }
}

fn rewrite_alias_return(r: HReturn, m: AliasMap) : HReturn {
  match r {
    # m7b #17: the return clause's `p` binding shadows outer
    # aliases inside its body (Doc C §m7b #11l: `state` / `log`
    # magic bindings are introduced by the codegen, not the
    # rewrite pass — only `p` is user-visible here).
    HR(p, b, l, c) -> {
      let m1 = alias_map_remove(m, p)
      HR(p, rewrite_alias_expr(b, m1), l, c)
    }
  }
}

# ---------------------------------------------------------------------------
# Shared structural map over ExprKind.
#
# Background (Full prerequisite 0.1, see `docs/stage2-design.md`):
# every AST-walking pass used to hand-roll its own structural recursion
# with a `_ -> k` catch-all over ExprKind. The wildcard audit in
# `7bd5a68` showed the same pattern duplicated 10x. Adding a new
# ExprKind variant (m7e variants[T](), refinement carriers, future
# actor primitives) silently re-introduces the same `_ -> k` debt
# at every site.
#
# `map_expr_kind` is the single point of structural recursion. Each
# walker handles only the kinds it actually transforms (or that
# require scope-aware bookkeeping); everything else falls through to
# `map_expr_kind`, which recurses into sub-Exprs explicitly. Adding
# a new ExprKind now breaks the compiler at one match site instead
# of degrading ten walkers.
#
# Convention: `f` is a closure that captures the walker's context
# and threads it through `<walker>_expr`. The closure is responsible
# for further recursion (i.e., `map_expr_kind` is one-level: it
# applies `f` to direct children, not to grandchildren).
#
# Sub-helpers (`map_stmt_exprs`, `map_arm_exprs`, etc.) replicate
# the structure for the auxiliary AST nodes that contain Exprs.
# A pass that needs scope-aware traversal (pattern shadowing in
# arms, binding shadowing in stmt blocks) handles those nodes
# explicitly in its own walker and never reaches the helpers below.
# ---------------------------------------------------------------------------
fn map_expr_kind(k: ExprKind, f: (Expr) -> Expr) : ExprKind {
  match k {
    # Leaves: no sub-Expr to recurse into.
    EInt(_)        -> k
    EReal(_)       -> k
    EBool(_)       -> k
    EChar(_)       -> k
    EStr(_, _)     -> k
    EUnit          -> k
    EVar(_)        -> k
    EUnder         -> k
    EPlaceholder   -> k
    EHole(_)       -> k
    ETodo(_)       -> k
    # `EVariantsOf(TypeExpr)` carries no sub-Expr (only a TypeExpr,
    # which the visitor does not traverse). Same shape as EHole/ETodo
    # for the purposes of the structural recursion.
    EVariantsOf(_) -> k
    # Composites: apply f to every direct sub-Expr.
    ECall(callee, args_) -> ECall(f(callee), map(args_, f))
    EField(base, name)   -> EField(f(base), name)
    EIndex(a, b)         -> EIndex(f(a), f(b))
    EBinop(op, a, b)     -> EBinop(op, f(a), f(b))
    EUnop(op, x)         -> EUnop(op, f(x))
    EIf(c, t_, eo)       -> EIf(f(c), f(t_), map_opt_expr(eo, f))
    EMatch(scr, arms)    -> EMatch(f(scr), map(arms, (a) => map_arm_exprs(a, f)))
    ELambda(ps, b)       -> ELambda(ps, f(b))
    ERecordLit(name, fs) -> ERecordLit(name, map(fs, (fi) => map_field_exprs(fi, f)))
    EList(els)           -> EList(map(els, (el) => map_elem_exprs(el, f)))
    ERange(a, b, opt_step) -> ERange(f(a), f(b), map_opt_expr(opt_step, f))
    EBlock(stmts, tail)  -> EBlock(map(stmts, (s) => map_stmt_exprs(s, f)),
                                    map_opt_expr(tail, f))
    EPipe(a, b)          -> EPipe(f(a), f(b))
    EHandle(body, eff_name, eff_tyargs, init_opt, alias_opt, clauses, ret_opt) ->
      EHandle(f(body), eff_name, eff_tyargs,
              map_opt_expr(init_opt, f), alias_opt,
              map(clauses, (c) => map_clause_exprs(c, f)),
              map_opt_return_exprs(ret_opt, f))
    ELitUnit(inner, u)   -> ELitUnit(f(inner), u)
    EBang(inner)         -> EBang(f(inner))
  }
}

fn map_opt_expr(opt: Option[Expr], f: (Expr) -> Expr) : Option[Expr] {
  match opt {
    Some(e) -> Some(f(e))
    None    -> None
  }
}

fn map_stmt_exprs(s: Stmt, f: (Expr) -> Expr) : Stmt {
  match s {
    SLet(p, ann, rhs)           -> SLet(p, ann, f(rhs))
    SAssert(c, m)               -> SAssert(f(c), map_opt_expr(m, f))
    SExprStmt(x)                -> SExprStmt(f(x))
    SIndexAssign(b, i, v, l, c) -> SIndexAssign(f(b), f(i), f(v), l, c)
    SVar(n, ty, rhs, l, c)      -> SVar(n, ty, f(rhs), l, c)
  }
}

fn map_arm_exprs(a: Arm, f: (Expr) -> Expr) : Arm {
  match a {
    Arm(p, g, b) -> Arm(p, map_opt_expr(g, f), f(b))
  }
}

fn map_field_exprs(fi: FieldInit, f: (Expr) -> Expr) : FieldInit {
  match fi {
    FI(n, v) -> FI(n, f(v))
  }
}

fn map_elem_exprs(el: ListElem, f: (Expr) -> Expr) : ListElem {
  match el {
    ElPlain(x)  -> ElPlain(f(x))
    ElSpread(x) -> ElSpread(f(x))
  }
}

fn map_clause_exprs(c: HClause, f: (Expr) -> Expr) : HClause {
  match c {
    HC(n, ps, b, l, co) -> HC(n, ps, f(b), l, co)
  }
}

fn map_opt_return_exprs(opt: Option[HReturn], f: (Expr) -> Expr) : Option[HReturn] {
  match opt {
    Some(r) -> Some(map_return_exprs(r, f))
    None    -> None
  }
}

fn map_return_exprs(r: HReturn, f: (Expr) -> Expr) : HReturn {
  match r {
    HR(p, b, l, c) -> HR(p, f(b), l, c)
  }
}

fn rewrite_alias_kind(k: ExprKind, m: AliasMap, line: Int, col: Int) : ExprKind {
  match k {
    EField(base, fname) -> match base.kind {
      EVar(name) -> match alias_map_lookup(m, name) {
        Some(eff_name) -> {
          # m7b #4: the `@cap` desugar always emits `cap.get`; for
          # a Reader-bound capability the actual op is `ask`.
          # Translate the field name here so a downstream
          # `cap.get()` call becomes `Reader.ask()`.
          let real_fname =
            if eff_name == "Reader" and fname == "get" { "ask" } else { fname }
          # m7b #15 (compiler integration, scope-limited): tag the
          # field name with `@<alias>` so the codegen can dispatch
          # via the handle's local `kai_alias_<a>_id` instead of a
          # name-keyed lookup. This fixes the innermost-wins bug
          # for the case where the op-call site is reachable from
          # the handle prologue's lexical scope (no intervening
          # closure). Inside a closure (`alias_map_may_tag = false`)
          # the handle's local is out of scope, so we do not tag —
          # the legacy name-keyed lookup runs and the closure-
          # capture path keeps working. See m7b #15 sub-followup.
          let tagged_fname =
            if alias_map_may_tag(m) {
              string_concat(real_fname, string_concat("@", name))
            } else {
              real_fname
            }
          EField(mk_expr(EVar(eff_name), base.line, base.col), tagged_fname)
        }
        None -> EField(rewrite_alias_expr(base, m), fname)
      }
      _ -> EField(rewrite_alias_expr(base, m), fname)
    }
    EHandle(body, eff_name, eff_tyargs, init_opt, alias_opt, clauses, ret_opt) -> {
      let body_m = match alias_opt {
        Some(a) -> alias_map_push(m, a, eff_name)
        None    -> m
      }
      EHandle(rewrite_alias_expr(body, body_m), eff_name, eff_tyargs,
              map_opt_expr(init_opt, (e) => rewrite_alias_expr(e, m)),
              alias_opt,
              rewrite_alias_clauses(clauses, m),
              rewrite_alias_opt_return(ret_opt, m))
    }
    EBlock(stmts, tail) -> {
      # m7b #17: track shadowing through the block. The trailing
      # expression sees the alias map after every SLet / SVar in
      # the block has had its name removed.
      let r = rewrite_alias_stmts_scoped(stmts, m, [])
      EBlock(r.stmts, map_opt_expr(tail, (e) => rewrite_alias_expr(e, r.m)))
    }
    ELambda(ps, b) -> {
      # m7b #17: lambda params shadow outer aliases inside the body.
      # m7b #15 (scope-limited): also disable the @alias tagging
      # inside the lambda body — the handle's `kai_alias_<a>_id`
      # local is not in scope across the lambda boundary, so any
      # tagged op call would emit invalid C. The substitution
      # `cap.op` → `Eff.op` still runs; only the per-instance
      # dispatch tag is suppressed.
      let names = map(ps, (pm) => pm.pname)
      let m1 = alias_map_disable_tag(alias_map_remove_all(m, names))
      ELambda(ps, rewrite_alias_expr(b, m1))
    }
    EMatch(scr, arms) -> EMatch(rewrite_alias_expr(scr, m),
                                 rewrite_alias_arms(arms, m))
    # All remaining kinds (ECall, EIf, EBinop, EUnop, EPipe, EIndex,
    # ERecordLit, EList, ERange, ELitUnit, EBang) recurse purely
    # structurally with no scope or alias bookkeeping. The leaves
    # (EInt, EReal, ..., EVar, EHole, ETodo) return unchanged. The
    # shared visitor handles both — adding a new ExprKind variant
    # breaks the compiler at `map_expr_kind`'s match instead of
    # silently leaking through this walker.
    _ -> map_expr_kind(k, (sub) => rewrite_alias_expr(sub, m))
  }
}

# m7a #6c: pre-emit op-call desugar. Walk the AST and rewrite every
# `EField(EVar(eff), op)` callee, where `eff` is a declared effect,
# into `EVar("eff.op")`. emit_call_expr then dispatches it through
# kai_evidence_lookup. All other expression shapes are traversed
# verbatim — only call sites are touched.
fn desugar_op_calls_decls(ds: [Decl], effs: [String]) : [Decl] =
  map(ds, (d) => desugar_op_calls_decl(d, effs))

fn desugar_op_calls_decl(d: Decl, effs: [String]) : Decl {
  match d {
    DFn(pub_, n, tps, ps, ret, row, body, l, c) ->
      DFn(pub_, n, tps, ps, ret, row, desugar_op_calls_expr(body, effs), l, c)
    DTest(desc, body, l, c) ->
      DTest(desc, desugar_op_calls_expr(body, effs), l, c)
    _ -> d
  }
}

fn desugar_op_calls_expr(e: Expr, effs: [String]) : Expr =
  Expr { kind: desugar_op_calls_kind(e.kind, effs),
         line: e.line, col: e.col, ty: e.ty }

fn desugar_op_calls_callee(callee: Expr, effs: [String]) : Expr {
  match callee.kind {
    EField(base, op_name) -> match base.kind {
      EVar(name) ->
        if list_has(effs, name) {
          mk_expr(EVar(string_concat(name, string_concat(".", op_name))),
                  callee.line, callee.col)
        } else { desugar_op_calls_expr(callee, effs) }
      _ -> desugar_op_calls_expr(callee, effs)
    }
    _ -> desugar_op_calls_expr(callee, effs)
  }
}

fn desugar_op_calls_kind(k: ExprKind, effs: [String]) : ExprKind {
  match k {
    # The only kind that needs special handling: rewrite a
    # `EField(EVar(eff), op)` callee into the flat `EVar("eff.op")`
    # form so emit_call_expr can dispatch through kai_evidence_lookup.
    # All sub-expressions (args + non-EField callee) recurse via the
    # shared visitor.
    ECall(callee, args_) ->
      ECall(desugar_op_calls_callee(callee, effs),
            map(args_, (a) => desugar_op_calls_expr(a, effs)))
    _ -> map_expr_kind(k, (sub) => desugar_op_calls_expr(sub, effs))
  }
}

# m7b #6: pre-resolve desugar of the array-indexing sugars.
#
# `a[i]`        ≡  Mutable.array_get(a, i)
# `a[i] := v`   ≡  Mutable.array_set(a, i, v)
#
# `docs/syntax-sugars.md` §4 phrases the desugaring as `Mutable.<op>`
# calls; the migration of `array_get` / `array_set` behind the
# `Mutable` effect lands together with the rest of m7a's `Mutable`
# retrofit. Until that arrives the bare prelude functions of the same
# name carry the same operational semantics (mutate-in-place +
# panic-on-OOB), so this pass emits them directly. Switching the
# desugar target from `array_get` → `Mutable.array_get` is one
# rewrite each in `array_index_callee_get` / `_set`.
fn desugar_index_decls(ds: [Decl]) : [Decl] = map(ds, desugar_index_decl)

fn desugar_index_decl(d: Decl) : Decl {
  match d {
    DFn(pub_, n, tps, ps, ret, row, body, l, c) ->
      DFn(pub_, n, tps, ps, ret, row, desugar_index_expr(body), l, c)
    DTest(desc, body, l, c) -> DTest(desc, desugar_index_expr(body), l, c)
    _ -> d
  }
}

fn array_index_callee_get(line: Int, col: Int) : Expr =
  mk_expr(EVar("array_get"), line, col)

fn array_index_callee_set(line: Int, col: Int) : Expr =
  mk_expr(EVar("array_set"), line, col)

fn desugar_index_expr(e: Expr) : Expr =
  Expr { kind: desugar_index_kind(e.kind, e.line, e.col),
         line: e.line, col: e.col, ty: e.ty }

fn desugar_index_opt(opt: Option[Expr]) : Option[Expr] {
  match opt {
    Some(e) -> Some(desugar_index_expr(e))
    None    -> None
  }
}

fn desugar_index_stmts(ss: [Stmt]) : [Stmt] = map(ss, desugar_index_stmt)

fn desugar_index_stmt(s: Stmt) : Stmt {
  match s {
    SLet(pat, ann, rhs) -> SLet(pat, ann, desugar_index_expr(rhs))
    SAssert(c, m) -> SAssert(desugar_index_expr(c), desugar_index_opt(m))
    SExprStmt(x) -> SExprStmt(desugar_index_expr(x))
    SIndexAssign(b, i, v, line, col) -> {
      let bd = desugar_index_expr(b)
      let id = desugar_index_expr(i)
      let vd = desugar_index_expr(v)
      let call = mk_expr(ECall(array_index_callee_set(line, col), [bd, id, vd]),
                         line, col)
      SExprStmt(call)
    }
    # m7b #5: pass through; the var-desugar pass below transforms SVar
    # into a `handle ... with State[T](init)` form. Until that pass runs
    # we still need to recurse into `init` so any nested `a[i]` inside
    # the initialiser is rewritten.
    SVar(n, ty, rhs, l, c) -> SVar(n, ty, desugar_index_expr(rhs), l, c)
  }
}

fn desugar_index_kind(k: ExprKind, line: Int, col: Int) : ExprKind {
  match k {
    # `a[i]` becomes `array_get(a, i)`. Sub-expressions still need to
    # recurse so a nested `b[j]` inside `a` or `i` is also lowered.
    EIndex(a, b) -> {
      let ad = desugar_index_expr(a)
      let bd = desugar_index_expr(b)
      ECall(array_index_callee_get(line, col), [ad, bd])
    }
    # EBlock stays explicit because desugar_index_stmt transforms
    # SIndexAssign → SExprStmt; the shared visitor only maps Exprs
    # inside Stmts and would not change the Stmt's variant.
    EBlock(stmts, tail) -> EBlock(desugar_index_stmts(stmts),
                                   desugar_index_opt(tail))
    _ -> map_expr_kind(k, desugar_index_expr)
  }
}

# ====================================================================
# m7b #5b: pre-resolve desugar of `var name [: T] = init`
# ====================================================================
#
# Doc B §`State[T]` *Syntax note* and Doc C §m7b #5 mandate this
# lowering: a block
#
#   { stmt0; ...; var name [: T] = init; rest_stmts; tail_expr }
#
# becomes
#
#   { stmt0; ...; handle { rest_stmts; tail_expr } with State[T](init) as name {
#       get(resume)    -> resume(state)
#       set(v, resume) -> resume((), v)
#       return(x)      -> x
#     } }
#
# Doc B locality: the `with` consumes `State[T]` inside the function,
# so the function's effect row is unchanged (no `+ State[T]` leaking
# out). When `T` is omitted, synth_handle infers it from the init's
# inferred type — see the `eff_tyargs == []` fallback in synth_handle.
#
# Nested `var`s nest handlers, innermost first: the recursion finds
# the head SVar in each block, wraps everything that follows it under
# a fresh State[T] handler, and recurses into that wrapped block — so
# a second `var` inside the rest produces a second handler nested
# inside the first.

fn desugar_var_decls(ds: [Decl]) : [Decl] = map(ds, desugar_var_decl)

fn desugar_var_decl(d: Decl) : Decl {
  match d {
    DFn(pub_, n, tps, ps, ret, row, body, l, c) ->
      DFn(pub_, n, tps, ps, ret, row, desugar_var_expr(body), l, c)
    DTest(desc, body, l, c) -> DTest(desc, desugar_var_expr(body), l, c)
    _ -> d
  }
}

fn desugar_var_expr(e: Expr) : Expr =
  Expr { kind: desugar_var_kind(e.kind, e.line, e.col),
         line: e.line, col: e.col, ty: e.ty }

fn desugar_var_opt(opt: Option[Expr]) : Option[Expr] {
  match opt {
    Some(e) -> Some(desugar_var_expr(e))
    None    -> None
  }
}

# Recurse into a non-block stmt's expressions. Used for stmts that
# appear *before* the head SVar of a block — they cannot reference the
# cell the var introduces, but their inner blocks (lambdas, ifs, match
# arms, etc.) may declare their own `var`s.
fn desugar_var_stmt(s: Stmt) : Stmt {
  match s {
    SLet(pat, ann, rhs) -> SLet(pat, ann, desugar_var_expr(rhs))
    SAssert(c, m) -> SAssert(desugar_var_expr(c), desugar_var_opt(m))
    SExprStmt(x) -> SExprStmt(desugar_var_expr(x))
    SIndexAssign(b, i, v, l, c) ->
      SIndexAssign(desugar_var_expr(b), desugar_var_expr(i),
                   desugar_var_expr(v), l, c)
    # SVar at this site means it sits at non-head position relative to
    # the wrapping pass. desugar_var_block consumes head-position SVars;
    # any residual one here is rewritten to a `let` so the resolver does
    # not see a stray SVar (defensive — should not occur in well-formed
    # input).
    SVar(n, _, rhs, _, _) -> SLet(mk_pat(PBind(n), 0, 0), None,
                                   desugar_var_expr(rhs))
  }
}

# Build the canonical `with State[?T](init) as name { ... }` clauses
# Doc B §`State[T]` *Syntax note* prescribes for a `var` lowering.
fn var_canonical_clauses(line: Int, col: Int) : [HClause] {
  let p_resume = Param { pname: "resume", ptype: None, pline: line, pcol: col }
  let p_v      = Param { pname: "v",      ptype: None, pline: line, pcol: col }
  let resume_e = mk_expr(EVar("resume"), line, col)
  let state_e  = mk_expr(EVar("state"),  line, col)
  let unit_e   = mk_expr(EUnit,           line, col)
  let v_e      = mk_expr(EVar("v"),       line, col)
  let get_body = mk_expr(ECall(resume_e, [state_e]), line, col)
  let set_body = mk_expr(ECall(resume_e, [unit_e, v_e]), line, col)
  [
    HC("get", [p_resume], get_body, line, col),
    HC("set", [p_v, p_resume], set_body, line, col)
  ]
}

fn var_canonical_return(line: Int, col: Int) : HReturn {
  HR("x", mk_expr(EVar("x"), line, col), line, col)
}

# m7b #16 — variable specialisation. Doc B §`State[T]` *Performance*
# promised that a `var x = init; @x; x := v` block compiles to a
# stack slot, not a chain of handler invocations. The specialised
# form replaces the canonical `with State[T] as x` handler with:
#   let x_slot = array_make(1, init)
#   { rest_with_n.get() → array_get(x_slot, 0)
#         and n.set(v)   → { let _ = array_set(x_slot, 0, v); () } }
# Trigger conditions per Doc C §*Variable specialisation*:
#   1. canonical handler shape (always true — emitted by us);
#   2. no multi-shot resume (always true — canonical clauses);
#   3. `name` only appears as `name.get()` / `name.set(v)` callee
#      (no escape into a closure or argument);
#   4. `init` is a "normal expression" — no op calls.
# Conditions 1 and 2 hold by construction; this section adds the
# conservative checks for 3 and 4 plus the rewrite.

# Trigger 4: init is a normal expression. Conservative subset:
# literals, EVar (refers to a local or global value), prelude
# arithmetic / unary, calls whose callee is a non-effect EVar.
# Anything else (op call, lambda, handle, match, if, block, list,
# record, etc.) is rejected so the canonical handler runs instead.
fn init_is_safe(e: Expr) : Bool {
  match e.kind {
    EInt(_) -> true
    EReal(_) -> true
    EBool(_) -> true
    EChar(_) -> true
    EStr(_, _) -> true
    EUnit -> true
    EVar(_) -> true
    EBinop(_, a, b) -> init_is_safe(a) and init_is_safe(b)
    EUnop(_, x) -> init_is_safe(x)
    ECall(callee, args_) -> {
      let callee_ok = match callee.kind {
        EVar(_) -> true
        _ -> false
      }
      callee_ok and init_args_safe(args_)
    }
    _ -> false
  }
}

fn init_args_safe(es: [Expr]) : Bool {
  match es {
    [] -> true
    [h, ...rest] -> if init_is_safe(h) { init_args_safe(rest) } else { false }
  }
}

# Trigger 3: name appears in body ONLY as the immediate base of a
# `name.get` or `name.set` field on the callee of a call. Any other
# occurrence — closure capture, function-argument position, plain
# value reference — is treated as escape and disables specialisation.
fn body_escapes(name: String, e: Expr) : Bool {
  match e.kind {
    EInt(_) -> false
    EReal(_) -> false
    EBool(_) -> false
    EChar(_) -> false
    EStr(_, _) -> false
    EUnit -> false
    EUnder -> false
    EPlaceholder -> false
    EHole(_) -> false
    ETodo(_) -> false
    EVar(n) -> n == name
    ECall(callee, args_) -> {
      let callee_is_get_set = match callee.kind {
        EField(base, fname) -> match base.kind {
          EVar(n) ->
            if n == name and (fname == "get" or fname == "set") { true }
            else { false }
          _ -> false
        }
        _ -> false
      }
      let callee_escape =
        if callee_is_get_set { false } else { body_escapes(name, callee) }
      callee_escape or args_escape(name, args_)
    }
    EField(base, _) -> body_escapes(name, base)
    EIndex(a, b) -> body_escapes(name, a) or body_escapes(name, b)
    EBinop(_, a, b) -> body_escapes(name, a) or body_escapes(name, b)
    EUnop(_, x) -> body_escapes(name, x)
    EIf(c, t_, eo) -> body_escapes(name, c) or body_escapes(name, t_) or opt_escapes(name, eo)
    EBlock(stmts, tail) -> stmts_escape(name, stmts) or opt_escapes(name, tail)
    EPipe(a, b) -> body_escapes(name, a) or body_escapes(name, b)
    EMatch(scr, arms) -> body_escapes(name, scr) or arms_escape(name, arms)
    ELambda(_, _) -> contains_var(name, e)
    EList(elems) -> elems_escape(name, elems)
    ERange(a, b, opt_step) -> body_escapes(name, a) or body_escapes(name, b) or opt_escapes(name, opt_step)
    ERecordLit(_, fields) -> fields_escape(name, fields)
    EHandle(body, _, _, init_opt, _, clauses, ret_opt) -> body_escapes(name, body) or opt_escapes(name, init_opt) or clauses_escape(name, clauses) or ret_opt_escapes(name, ret_opt)
    EBang(inner) -> body_escapes(name, inner)
    ELitUnit(inner, _) -> body_escapes(name, inner)
    # m7e §11: `variants[T]()` has no value-level sub-expressions —
    # nothing can mention `name` inside it.
    EVariantsOf(_) -> false
  }
}

fn args_escape(name: String, es: [Expr]) : Bool {
  match es {
    [] -> false
    [h, ...rest] -> if body_escapes(name, h) { true } else { args_escape(name, rest) }
  }
}

fn opt_escapes(name: String, opt: Option[Expr]) : Bool {
  match opt {
    None -> false
    Some(e) -> body_escapes(name, e)
  }
}

fn stmts_escape(name: String, ss: [Stmt]) : Bool {
  match ss {
    [] -> false
    [s, ...rest] -> if stmt_escapes(name, s) { true } else { stmts_escape(name, rest) }
  }
}

fn stmt_escapes(name: String, s: Stmt) : Bool {
  match s {
    SLet(_, _, rhs) -> body_escapes(name, rhs)
    SAssert(c, msg) -> body_escapes(name, c) or opt_escapes(name, msg)
    SExprStmt(x) -> body_escapes(name, x)
    SIndexAssign(b, i, v, _, _) ->
      body_escapes(name, b) or body_escapes(name, i) or body_escapes(name, v)
    SVar(_, _, rhs, _, _) -> body_escapes(name, rhs)
  }
}

fn arms_escape(name: String, arms: [Arm]) : Bool {
  match arms {
    [] -> false
    [a, ...rest] -> if arm_escapes(name, a) { true } else { arms_escape(name, rest) }
  }
}

fn arm_escapes(name: String, a: Arm) : Bool {
  match a {
    Arm(_, opt_g, b) -> opt_escapes(name, opt_g) or body_escapes(name, b)
  }
}

fn elems_escape(name: String, es: [ListElem]) : Bool {
  match es {
    [] -> false
    [el, ...rest] -> match el {
      ElPlain(x)  -> if body_escapes(name, x) { true } else { elems_escape(name, rest) }
      ElSpread(x) -> if body_escapes(name, x) { true } else { elems_escape(name, rest) }
    }
  }
}

fn fields_escape(name: String, fs: [FieldInit]) : Bool {
  match fs {
    [] -> false
    [f, ...rest] -> match f {
      FI(_, v) -> if body_escapes(name, v) { true } else { fields_escape(name, rest) }
    }
  }
}

fn clauses_escape(name: String, cs: [HClause]) : Bool {
  match cs {
    [] -> false
    [c, ...rest] -> match c {
      HC(_, _, b, _, _) ->
        if body_escapes(name, b) { true } else { clauses_escape(name, rest) }
    }
  }
}

fn ret_opt_escapes(name: String, opt: Option[HReturn]) : Bool {
  match opt {
    None -> false
    Some(r) -> match r { HR(_, b, _, _) -> body_escapes(name, b) }
  }
}

# Conservative containment check used by the lambda branch of
# `body_escapes`: a closure that mentions `name` at all is treated
# as escape (we have no way to prove the closure does not outlive
# the handle). Returns true if `name` appears anywhere in `e`.
fn contains_var(name: String, e: Expr) : Bool {
  match e.kind {
    EVar(n) -> n == name
    ECall(c, args_) -> contains_var(name, c) or any_contains(name, args_)
    EField(b, _) -> contains_var(name, b)
    EIndex(a, b) -> contains_var(name, a) or contains_var(name, b)
    EBinop(_, a, b) -> contains_var(name, a) or contains_var(name, b)
    EUnop(_, x) -> contains_var(name, x)
    EIf(c, t_, eo) -> contains_var(name, c) or contains_var(name, t_) or opt_contains(name, eo)
    EBlock(stmts, tail) -> stmts_contain(name, stmts) or opt_contains(name, tail)
    EMatch(scr, arms) -> contains_var(name, scr) or arms_contain(name, arms)
    ELambda(_, b) -> contains_var(name, b)
    EList(elems) -> elems_contain(name, elems)
    ERange(a, b, opt_step) ->
      contains_var(name, a) or contains_var(name, b) or opt_contains(name, opt_step)
    ERecordLit(_, fields) -> fields_contain(name, fields)
    EPipe(a, b) -> contains_var(name, a) or contains_var(name, b)
    EHandle(body, _, _, init_opt, _, clauses, ret_opt) -> contains_var(name, body) or opt_contains(name, init_opt) or clauses_contain(name, clauses) or ret_opt_contains(name, ret_opt)
    EBang(inner) -> contains_var(name, inner)
    _ -> false
  }
}

fn any_contains(name: String, es: [Expr]) : Bool {
  match es {
    [] -> false
    [h, ...rest] -> if contains_var(name, h) { true } else { any_contains(name, rest) }
  }
}

fn opt_contains(name: String, opt: Option[Expr]) : Bool {
  match opt { None -> false  Some(e) -> contains_var(name, e) }
}

fn stmts_contain(name: String, ss: [Stmt]) : Bool {
  match ss {
    [] -> false
    [s, ...rest] -> if stmt_contains(name, s) { true } else { stmts_contain(name, rest) }
  }
}

fn stmt_contains(name: String, s: Stmt) : Bool {
  match s {
    SLet(_, _, rhs) -> contains_var(name, rhs)
    SAssert(c, msg) -> contains_var(name, c) or opt_contains(name, msg)
    SExprStmt(x) -> contains_var(name, x)
    SIndexAssign(b, i, v, _, _) ->
      contains_var(name, b) or contains_var(name, i) or contains_var(name, v)
    SVar(_, _, rhs, _, _) -> contains_var(name, rhs)
  }
}

fn arms_contain(name: String, arms: [Arm]) : Bool {
  match arms {
    [] -> false
    [a, ...rest] -> match a {
      Arm(_, g, b) ->
        if opt_contains(name, g) or contains_var(name, b) { true }
        else { arms_contain(name, rest) }
    }
  }
}

fn elems_contain(name: String, es: [ListElem]) : Bool {
  match es {
    [] -> false
    [el, ...rest] -> match el {
      ElPlain(x)  -> if contains_var(name, x) { true } else { elems_contain(name, rest) }
      ElSpread(x) -> if contains_var(name, x) { true } else { elems_contain(name, rest) }
    }
  }
}

fn fields_contain(name: String, fs: [FieldInit]) : Bool {
  match fs {
    [] -> false
    [f, ...rest] -> match f {
      FI(_, v) -> if contains_var(name, v) { true } else { fields_contain(name, rest) }
    }
  }
}

fn clauses_contain(name: String, cs: [HClause]) : Bool {
  match cs {
    [] -> false
    [c, ...rest] -> match c {
      HC(_, _, b, _, _) ->
        if contains_var(name, b) { true } else { clauses_contain(name, rest) }
    }
  }
}

fn ret_opt_contains(name: String, opt: Option[HReturn]) : Bool {
  match opt { None -> false  Some(r) -> match r { HR(_, b, _, _) -> contains_var(name, b) } }
}

# Specialise a body: rewrite every `name.get()` to
# `array_get(slot_var, 0)` and every `name.set(v)` to a unit-typed
# block `{ let _ = array_set(slot_var, 0, v); () }`. The slot_var
# name is `<name>__slot`. Other expressions pass through.
fn specialise_body(name: String, slot_name: String, e: Expr) : Expr {
  Expr { kind: specialise_kind(name, slot_name, e.kind, e.line, e.col),
         line: e.line, col: e.col, ty: e.ty }
}

fn specialise_kind(name: String, slot_name: String, k: ExprKind, line: Int, col: Int) : ExprKind {
  match k {
    # The only kind that needs special handling: a call site that
    # matches `name.get()` or `name.set(v)` gets lowered to
    # `array_get(slot, 0)` / `array_set(slot, 0, v)`. All other
    # kinds (and non-matching ECalls) recurse purely structurally.
    ECall(callee, args_) -> {
      let getset = match callee.kind {
        EField(base, fname) -> match base.kind {
          EVar(n) ->
            if n == name and fname == "get" { Some("get") }
            else if n == name and fname == "set" { Some("set") }
            else { None }
          _ -> None
        }
        _ -> None
      }
      match getset {
        Some(op) -> {
          let slot_e = mk_expr(EVar(slot_name), line, col)
          let zero = mk_expr(EInt(0), line, col)
          if op == "get" {
            ECall(mk_expr(EVar("array_get"), line, col), [slot_e, zero])
          } else {
            # `name.set(v)`: emit `{ let _ = array_set(slot, 0, v); () }`
            # so the result type stays Unit (matches the canonical clause).
            let v = match args_ {
              [a, ...ignore] -> specialise_body(name, slot_name, a)
              [] -> mk_expr(EUnit, line, col)
            }
            let set_call = mk_expr(
              ECall(mk_expr(EVar("array_set"), line, col), [slot_e, zero, v]),
              line, col)
            let let_pat = mk_pat(PWild, line, col)
            let let_stmt = SLet(let_pat, None, set_call)
            EBlock([let_stmt], Some(mk_expr(EUnit, line, col)))
          }
        }
        None ->
          ECall(specialise_body(name, slot_name, callee),
                map(args_, (a) => specialise_body(name, slot_name, a)))
      }
    }
    _ -> map_expr_kind(k, (sub) => specialise_body(name, slot_name, sub))
  }
}

# Walk a block's stmts looking for the first SVar. Returns the rewritten
# (stmts, tail) pair: every stmt before the first SVar is structurally
# desugared (so lambdas / inner blocks inside their expressions still
# get their own `var`s rewritten), and from the SVar onward the rest
# of the block becomes the body of a fresh `with State[T](init) as name`
# handler. If no SVar is present, recursion proceeds structurally.
fn desugar_var_block(stmts: [Stmt], tail: Option[Expr]) : ExprKind {
  match stmts {
    [] -> EBlock([], desugar_var_opt(tail))
    [s, ...rest] -> match s {
      SVar(name, ty, init, line, col) -> {
        let init_d = desugar_var_expr(init)
        let inner_kind = desugar_var_block(rest, tail)
        let inner_expr = mk_expr(inner_kind, line, col)
        # m7b #16 — try variable specialisation first. When all
        # trigger conditions hold, lower the var to a 1-element
        # array slot (prelude `array_*`, no `Mutable` row) instead
        # of the canonical State[T] handler. The conditions:
        #   * init is a "normal expression" (init_is_safe)
        #   * `name` only appears as `name.get`/`name.set` callee
        #     in the body (body_escapes is false)
        # When either fails, fall back to the canonical handler so
        # captures, escapes, and complex inits still work.
        if init_is_safe(init_d) and not body_escapes(name, inner_expr) {
          let slot_name = string_concat(name, "__slot")
          let slot_init = mk_expr(
            ECall(mk_expr(EVar("array_make"), line, col),
                  [mk_expr(EInt(1), line, col), init_d]),
            line, col)
          let let_pat = mk_pat(PBind(slot_name), line, col)
          let let_stmt = SLet(let_pat, None, slot_init)
          let body_spec = specialise_body(name, slot_name, inner_expr)
          EBlock([let_stmt], Some(body_spec))
        } else {
          let tyargs = match ty { Some(t) -> [t] None -> [] }
          let clauses = var_canonical_clauses(line, col)
          let ret = var_canonical_return(line, col)
          let handle_kind = EHandle(inner_expr, "State", tyargs,
                                     Some(init_d), Some(name),
                                     clauses, Some(ret))
          EBlock([], Some(mk_expr(handle_kind, line, col)))
        }
      }
      _ -> {
        let s_d = desugar_var_stmt(s)
        let inner_kind = desugar_var_block(rest, tail)
        match inner_kind {
          EBlock(rest_stmts, rest_tail) ->
            EBlock([s_d, ...rest_stmts], rest_tail)
          _ -> EBlock([s_d], Some(mk_expr(inner_kind, 0, 0)))
        }
      }
    }
  }
}

fn desugar_var_kind(k: ExprKind, line: Int, col: Int) : ExprKind {
  match k {
    # EBlock is the only kind that needs special handling: a head
    # SVar inside the block lifts to a fresh `with State[T](init)`
    # handler, which `desugar_var_block` builds. Stmts before the
    # head SVar still recurse into their inner expressions.
    EBlock(stmts, tail) -> desugar_var_block(stmts, tail)
    _ -> map_expr_kind(k, desugar_var_expr)
  }
}

# ====================================================================
# m12.8.x phase 2 (Bug 4): lift `"...#{x}..."` interpolation parts
# into the pre-inference AST so the typer + protocol-call rewrite see
# them. Without this the interp body is parsed at emit time and
# routed through the universal `kai_to_string` runtime, which
# bypasses any user-defined `impl Show for T`.
# ====================================================================
#
# Run only when the program declares `protocol Show` (the
# `op_names` list contains "show"); otherwise leave EStr nodes alone
# so files that just use `#{int_to_string(x)}` and never load the
# stdlib protocols continue to work via the legacy emit-time path.
#
# Lowering shape: a string `"prefix #{e1} mid #{e2} suffix"` becomes
#
#   string_concat_all(["prefix ", show(e1), " mid ", show(e2), " suffix"])
#
# Each interp body `e_i` is parsed using `parse_expr` (same parser
# the emitter used to call lazily) and then recursively desugared so
# nested interpolations also lift.

fn desugar_interp_decls(ds: [Decl], op_names: [String]) : [Decl] {
  if not list_has(op_names, "show") { ds }
  else { map(ds, (d) => desugar_interp_decl(d, op_names)) }
}

fn desugar_interp_decl(d: Decl, op_names: [String]) : Decl {
  match d {
    DFn(p, n, tps, ps, ret, row, body, l, c) ->
      DFn(p, n, tps, ps, ret, row, desugar_interp_expr(body, op_names), l, c)
    DTest(desc, body, l, c) ->
      DTest(desc, desugar_interp_expr(body, op_names), l, c)
    _ -> d
  }
}

fn desugar_interp_expr(e: Expr, op_names: [String]) : Expr =
  Expr { kind: desugar_interp_kind(e.kind, op_names, e.line, e.col),
         line: e.line, col: e.col, ty: e.ty }

fn desugar_interp_kind(k: ExprKind, op_names: [String],
                        line: Int, col: Int) : ExprKind {
  match k {
    # The two kinds the pass actually transforms:
    #   * EStr with `#{...}` interpolation lifts into a
    #     `string_concat_all([...])` call so the typer sees the
    #     interp body's typed expressions and protocol ops route
    #     through the user's `impl Show for T`.
    #   * ECall whose callee is `EField(receiver, op_name)` for an
    #     op_name in `op_names` (a declared protocol op) rewrites
    #     to `__proto_<op>(receiver, ...args)` so the post-inference
    #     rewrite can route the call to the matching impl. Records
    #     that happen to carry a field with the same name as a
    #     protocol op shadow this rule.
    EStr(span, is_triple) -> {
      let n = string_length(span)
      let body_start = if is_triple { 3 } else { 1 }
      let body_end = if is_triple { n - 3 } else { n - 1 }
      if has_interp(span, body_start, body_end) {
        lift_interp_string(span, body_start, body_end, op_names, line, col)
      } else { k }
    }
    ECall(c, args_) -> match c.kind {
      EField(receiver, op_name) ->
        if list_has(op_names, op_name) {
          let new_callee = mk_expr(EVar(proto_dispatcher_name(op_name)),
                                    c.line, c.col)
          let new_recv   = desugar_interp_expr(receiver, op_names)
          let new_args   = map(args_, (a) => desugar_interp_expr(a, op_names))
          ECall(new_callee, [new_recv, ...new_args])
        } else {
          ECall(desugar_interp_expr(c, op_names),
                map(args_, (a) => desugar_interp_expr(a, op_names)))
        }
      _ -> ECall(desugar_interp_expr(c, op_names),
                  map(args_, (a) => desugar_interp_expr(a, op_names)))
    }
    _ -> map_expr_kind(k, (sub) => desugar_interp_expr(sub, op_names))
  }
}

fn lift_interp_string(span: String, body_start: Int, body_end: Int,
                       op_names: [String], line: Int, col: Int) : ExprKind {
  let parts = iscan_collect(span, body_end,
                             IScan { parts: [], lit_start: body_start, i: body_start })
  let part_exprs = map(parts, (p: IPart) => interp_part_to_expr(p, op_names, line, col))
  ECall(mk_expr(EVar("string_concat_all"), line, col),
        [mk_expr(EList(map(part_exprs, (e: Expr) => ElPlain(e))), line, col)])
}

fn interp_part_to_expr(p: IPart, op_names: [String],
                        line: Int, col: Int) : Expr {
  match p {
    IpLit(_, raw_quoted) -> mk_expr(EStr(raw_quoted, false), line, col)
    IpExp(expr_src) -> {
      let toks = tokenize(expr_src)
      let prs = parser_new("<interp>", expr_src, toks)
      let r = parse_expr(prs)
      let inner = match r.r {
        Some(e) -> desugar_interp_expr(e, op_names)
        None    -> mk_expr(EStr("\"\"", false), line, col)
      }
      # The post-rename dispatcher name (`__proto_show`) bypasses the
      # rename pass that already ran inside lower_protocols. The
      # post-inference rewrite recognises this prefixed form.
      mk_expr(ECall(mk_expr(EVar(proto_dispatcher_name("show")), line, col),
                     [inner]),
              line, col)
    }
  }
}

fn emit_program(file: String, src: String, raw_decls: [Decl], test_mode: Bool) : String {
  # m7a #6c: rewrite `Eff.op(args)` callees from `EField(EVar(Eff), op)`
  # to `EVar("Eff.op")` before code emission. The typer (synth_op_call_with_scheme)
  # produces this form internally, but check_infer is a diagnostic-only
  # pass — it does not propagate the rewritten AST back to all_decls.
  # This standalone walker closes the gap; the next pipeline iteration
  # (Doc C §*Pipeline order and desugaring*) will fold it into a proper
  # post-resolve desugar pass.
  let alias_resolved = rewrite_alias_decls(raw_decls)
  let eff_names = collect_effect_names(alias_resolved)
  let decls = desugar_op_calls_decls(alias_resolved, eff_names)
  let fns = register_fn_decls(decls)
  let variants = register_variants(decls)
  let op_quals = collect_op_qualified_names(decls)
  let globals = build_globals(fns, variants, eff_names, op_quals)
  let st0 = lc_new(globals)
  let st = collect_decls(decls, st0)
  let lams = st.lams
  let clauses_info = st.clauses
  let header = "/* generated by kaikai stage 2 */\n#include \"runtime.h\"\n\n"
  let eff_structs = effect_struct_decls(decls)
  let clause_fwd = emit_clause_forwards(clauses_info)
  let fwd = fn_forward_decls(decls)
  let thunk_fwd = thunk_forward_decls(decls)
  let lam_fwd = emit_lam_forward_decls(lams)
  let bodies = fn_bodies(src, decls, fns, variants, lams)
  let lam_bodies = emit_lam_helpers(src, lams, fns, variants)
  let clause_bodies = emit_clause_bodies(src, clauses_info, fns, variants, lams)
  let tests = emit_all_tests(src, decls, fns, variants, lams)
  let main_wr = emit_main_wrapper(decls, test_mode)
  concat_all([header, eff_structs, clause_fwd, fwd, "\n", thunk_fwd, "\n", lam_fwd, "\n", bodies, lam_bodies, clause_bodies, tests, main_wr])
}

# ====================================================================
# semantic types (M2a)
# ====================================================================
#
# The checker uses `Ty` for semantic (resolved) types. This is distinct
# from the syntactic `TypeExpr` carried on AST nodes. M2a introduces
# the representation plus a resolver from TypeExpr to Ty and a
# signature extractor for top-level decls; actual type inference lands
# in M2b+.

type Ty
  = TyInt
  | TyReal
  | TyBool
  | TyString
  | TyChar
  | TyUnit
  | TyListT(Ty)                         # resolved list type
  | TyFnT([Ty], Ty, Row)                # resolved function type (with effect row)
  | TyCon(String, [Ty])                 # user-defined type constructor application
  | TyVarT(Int)                         # unification variable
  | TyAny                               # placeholder for "not yet resolved"
  # m12.5: resolved dimensioned type. Inner Ty is always TyInt / TyReal
  # (or a TyVarT that the unifier later pins to one of them); the
  # unit lives in canonicalised form once the unifier touches it.
  | TyDimT(Ty, UnitExprT)

# Effect row, per docs/effects-impl.md §*Types: row slot on TyFnT*.
# The slot is reserved here in m7a #1; row unification (m7a #2) and
# evidence-bearing rows (m7a #3+) populate it. For now every TyFnT
# carries an empty row.
type Label = { eff: String, ty_args: [Ty] }

type Row = {
  labels:        [Label],          # invariant: sorted by eff, syntactically deduplicated
  tail:          Option[Int],      # row variable id, parallel to TyVarT
  display_alias: Option[String],   # for diagnostics only; ignored by unification
}

fn row_empty() : Row = Row {
  labels:        [],
  tail:          None,
  display_alias: None
}

fn resolve_ty_list(ts: [TypeExpr]) : [Ty] = map(ts, resolve_ty)

fn resolve_ty(t: TypeExpr) : Ty {
  match t.tkind {
    TyName(name, targs) -> {
      if name == "Int" { TyInt }
      else if name == "Real" { TyReal }
      else if name == "Bool" { TyBool }
      else if name == "String" { TyString }
      else if name == "Char" { TyChar }
      else if name == "Unit" { TyUnit }
      # m7a #7: `Nothing` is the uninhabited type used by `Fail.fail`
      # (Doc B §`Fail`). The typer can't witness uninhabitedness, so
      # we treat it as TyAny — a call producing Nothing unifies with
      # any expected type, which is sound only because the default
      # handler aborts before any consumer of that "value" runs.
      else if name == "Nothing" { TyAny }
      else { TyCon(name, resolve_ty_list(targs)) }
    }
    TyList(inner) -> TyListT(resolve_ty(inner))
    TyFn(fps, fret, rexpr) -> TyFnT(resolve_ty_list(fps), resolve_ty(fret), row_of_expr(rexpr))
    # m12.5: dimensioned base type. The unit goes through unit_canon
    # (with empty alias and tparam contexts here) so two textually
    # different but algebraically equal forms compare equal under unify.
    TyDim(base, u) -> TyDimT(resolve_ty(base), unit_canon(u))
  }
}

# Convert a parsed RowExpr into its semantic Row. m7a #3c validates
# that each label refers to a declared effect; this routine focuses
# on the type-arg projection. Type args declared in row position are
# resolved against the *current* declaration's tparam list when one
# is supplied (`row_of_expr_with_tparams`); calls without tparam
# context (display, alias rewriting) drop the args to keep behaviour
# additive while m7b #11's row-arg propagation lands in stages.
#
# m7b #12: ROpen carries a row-variable name in tail position. This
# helper has no per-decl row-var binding context, so it returns a
# Row with a *placeholder* tail id (-1). Callers that need a proper
# row-var binding (fn_scheme_of_decl, infer_decl) use
# `row_of_expr_with_rbinds` instead and pass a context built by
# `mk_rvbinds`. Diagnostics-only paths are fine with the placeholder.
fn row_of_expr(re: RowExpr) : Row {
  row_of_expr_with_rbinds(re, [])
}

# Row-variable binding: maps a surface name (`e`) to its allocated
# row variable id within the enclosing function declaration.
type RVBind = RVB(String, Int)

fn rvbind_lookup(binds: [RVBind], name: String) : Option[Int] {
  match binds {
    [] -> None
    [b, ...rest] -> match b {
      RVB(n, i) -> if n == name { Some(i) } else { rvbind_lookup(rest, name) }
    }
  }
}

fn row_of_expr_with_rbinds(re: RowExpr, rbinds: [RVBind]) : Row {
  match re {
    REmpty -> row_empty()
    RClosed(labels) -> Row {
      labels: row_labels_of_rls(labels),
      tail: None,
      display_alias: None
    }
    ROpen(rv, labels) -> Row {
      labels: row_labels_of_rls(labels),
      tail: match rvbind_lookup(rbinds, rv) {
        Some(id) -> Some(id)
        None     -> Some(-1)
      },
      display_alias: None
    }
  }
}

fn row_labels_of_rls(ls: [RowLabel]) : [Label] {
  match ls {
    [] -> []
    [rl, ...rest] -> match rl {
      RL(name, ts) -> [
        Label { eff: name, ty_args: resolve_ty_list(ts) },
        ...row_labels_of_rls(rest)
      ]
    }
  }
}

# m7b #11: resolve a row label list under a tparam binding. Used at
# decl boundaries where the `Reader[T]` type arg refers to one of the
# function's own tparams. Falls back to the unparameterised
# `row_labels_of_rls` for callers that lack a binding context.
fn row_labels_of_rls_with_tparams(ls: [RowLabel], binds: [TPBind]) : [Label] {
  match ls {
    [] -> []
    [rl, ...rest] -> match rl {
      RL(name, ts) -> [
        Label { eff: name, ty_args: map(ts, (te) => resolve_ty_with_tparams(te, binds)) },
        ...row_labels_of_rls_with_tparams(rest, binds)
      ]
    }
  }
}

fn row_of_expr_with_tparams(re: RowExpr, binds: [TPBind]) : Row {
  match re {
    REmpty -> row_empty()
    RClosed(labels) -> Row {
      labels: row_labels_of_rls_with_tparams(labels, binds),
      tail: None,
      display_alias: None
    }
    # m7b #12: row variables in user-written signatures resolve to
    # a row-variable id via `mk_rvbinds`; this helper takes only a
    # tparam binding context and is currently unused (defined for
    # the parametric-effect op-decl path). Pre-fill with a
    # placeholder tail to satisfy the exhaustiveness checker; if
    # this branch is ever hit, callers should switch to
    # `row_of_expr_with_rbinds` instead.
    ROpen(_, labels) -> Row {
      labels: row_labels_of_rls_with_tparams(labels, binds),
      tail: Some(-1),
      display_alias: None
    }
  }
}

# m7b #1b — closed effect aliases (Doc A §*Open questions* #5).
# An effect alias `type Io = Console + Stdin + Env + File` is a name
# that expands to a fixed label set in row position. The resolver
# performs a DFS expansion before any RowExpr is consumed; cycles and
# non-effect labels in alias bodies are rejected here. After
# rewriting, RowExpr.RClosed labels reference only declared effects.
#
# AliasCand: candidate alias decl harvested from the AST.
#   name     — the type-decl name
#   raw      — the labels as written (effects or other alias names)
#   explicit — true for `TBEffectAlias` (explicit `+` form); false for
#              `TBAlias(TyName(n, []))` (single-name form). Implicit
#              candidates whose label is not an effect/alias are
#              silently treated as regular type aliases instead of
#              effect aliases. Cycles are still rejected for both.
#   line/col — source position for diagnostics.
type AliasCand = AC(String, [String], Bool, Int, Int)

# AliasResult: a candidate that resolved to a flat label list.
type AliasResult = AR(String, [String])

# DFS expansion status for an alias name.
type AStatus = AsTodo | AsActive | AsDone([String]) | AsFail

type AEntry = AEnt(String, AStatus)

fn collect_alias_cands(decls: [Decl]) : [AliasCand] {
  match decls {
    [] -> []
    [d, ...rest] -> {
      let here = match d {
        DType(_, name, _, body, line, col) -> match body {
          TBEffectAlias(labels) -> [AC(name, labels, true, line, col)]
          TBAlias(ty) -> match ty.tkind {
            TyName(n, targs) ->
              if targs == [] { [AC(name, [n], false, line, col)] }
              else { [] }
            _ -> []
          }
          _ -> []
        }
        _ -> []
      }
      list_append(here, collect_alias_cands(rest))
    }
  }
}

fn cand_names_of(cands: [AliasCand]) : [String] {
  match cands {
    [] -> []
    [c, ...rest] -> match c {
      AC(n, _, _, _, _) -> [n, ...cand_names_of(rest)]
    }
  }
}

fn find_alias_cand(cands: [AliasCand], name: String) : Option[AliasCand] {
  match cands {
    [] -> None
    [c, ...rest] -> match c {
      AC(n, _, _, _, _) -> if n == name { Some(c) } else { find_alias_cand(rest, name) }
    }
  }
}

fn alias_status(entries: [AEntry], name: String) : AStatus {
  match entries {
    [] -> AsTodo
    [e, ...rest] -> match e {
      AEnt(en, es) -> if en == name { es } else { alias_status(rest, name) }
    }
  }
}

fn alias_set_status(entries: [AEntry], name: String, status: AStatus) : [AEntry] {
  match entries {
    [] -> [AEnt(name, status)]
    [e, ...rest] -> match e {
      AEnt(en, es) ->
        if en == name { [AEnt(en, status), ...rest] }
        else { [AEnt(en, es), ...alias_set_status(rest, name, status)] }
    }
  }
}

fn prepend_rev_strs(xs: [String], acc: [String]) : [String] {
  match xs {
    [] -> acc
    [x, ...rest] -> prepend_rev_strs(rest, [x, ...acc])
  }
}

fn dedup_strs(xs: [String]) : [String] = dedup_strs_loop(xs, [])
fn dedup_strs_loop(xs: [String], acc: [String]) : [String] {
  match xs {
    [] -> list_reverse(acc)
    [x, ...rest] ->
      if list_has(acc, x) { dedup_strs_loop(rest, acc) }
      else { dedup_strs_loop(rest, [x, ...acc]) }
  }
}

type AliasResolveState = { entries: [AEntry], errs: Int }
type AliasResolveOne   = { st: AliasResolveState, r: Option[[String]] }
type AliasPos     = { line: Int, col: Int }

fn cand_pos(cands: [AliasCand], name: String) : AliasPos {
  match find_alias_cand(cands, name) {
    None -> AliasPos { line: 0, col: 0 }
    Some(c) -> match c {
      AC(_, _, _, ln, co) -> AliasPos { line: ln, col: co }
    }
  }
}

fn resolve_alias(name: String, cands: [AliasCand], cand_ns: [String],
                 eff_names: [String], file: String, st: AliasResolveState) : AliasResolveOne {
  match alias_status(st.entries, name) {
    AsDone(labels) -> AliasResolveOne { st: st, r: Some(labels) }
    AsFail -> AliasResolveOne { st: st, r: None }
    AsActive -> {
      let pos = cand_pos(cands, name)
      diag_error(file, pos.line, pos.col,
        string_concat("cyclic effect alias: ", name))
      diag_note("an alias can only expand to declared effects, not back to itself")
      diag_help("break the cycle: list each effect explicitly in the body of `type #{name} = ...`")
      let st2 = AliasResolveState {
        entries: alias_set_status(st.entries, name, AsFail),
        errs:    st.errs + 1
      }
      AliasResolveOne { st: st2, r: None }
    }
    AsTodo -> {
      match find_alias_cand(cands, name) {
        None -> AliasResolveOne { st: st, r: None }
        Some(c) -> match c {
          AC(_, raw, explicit, line, col) -> {
            let entries1 = alias_set_status(st.entries, name, AsActive)
            let st1 = AliasResolveState { entries: entries1, errs: st.errs }
            let r = resolve_alias_labels(raw, cands, cand_ns, eff_names, file,
                                         name, explicit, line, col, st1, [])
            match r.r {
              None -> {
                let entries2 = alias_set_status(r.st.entries, name, AsFail)
                AliasResolveOne { st: AliasResolveState { entries: entries2, errs: r.st.errs }, r: None }
              }
              Some(labels) -> {
                let unique = dedup_strs(labels)
                let entries2 = alias_set_status(r.st.entries, name, AsDone(unique))
                AliasResolveOne { st: AliasResolveState { entries: entries2, errs: r.st.errs }, r: Some(unique) }
              }
            }
          }
        }
      }
    }
  }
}

fn resolve_alias_labels(raw: [String], cands: [AliasCand], cand_ns: [String],
                        eff_names: [String], file: String,
                        parent: String, explicit: Bool, pline: Int, pcol: Int,
                        st: AliasResolveState, acc: [String]) : AliasResolveOne {
  match raw {
    [] -> AliasResolveOne { st: st, r: Some(list_reverse(acc)) }
    [label, ...rest] -> {
      if list_has(eff_names, label) {
        resolve_alias_labels(rest, cands, cand_ns, eff_names, file, parent,
                             explicit, pline, pcol, st, [label, ...acc])
      } else if list_has(cand_ns, label) {
        let r = resolve_alias(label, cands, cand_ns, eff_names, file, st)
        match r.r {
          None -> AliasResolveOne { st: r.st, r: None }
          Some(sub) ->
            resolve_alias_labels(rest, cands, cand_ns, eff_names, file, parent,
                                 explicit, pline, pcol, r.st,
                                 prepend_rev_strs(sub, acc))
        }
      } else {
        if explicit {
          diag_error(file, pline, pcol,
            concat_all(["unknown effect in alias body: ", label,
                        " (declared as part of `", parent, "`)"]))
          let st1 = AliasResolveState { entries: st.entries, errs: st.errs + 1 }
          AliasResolveOne { st: st1, r: None }
        } else {
          AliasResolveOne { st: st, r: None }
        }
      }
    }
  }
}

type AliasResolution = { aliases: [AliasResult], errs: Int }

fn resolve_alias_cands(cands: [AliasCand], eff_names: [String], file: String) : AliasResolution {
  let cand_ns = cand_names_of(cands)
  resolve_alias_cands_loop(cands, cand_ns, eff_names, file,
                           AliasResolveState { entries: [], errs: 0 }, cands, [])
}

fn resolve_alias_cands_loop(all_cands: [AliasCand], cand_ns: [String],
                            eff_names: [String], file: String,
                            st: AliasResolveState, todo: [AliasCand],
                            acc: [AliasResult]) : AliasResolution {
  match todo {
    [] -> AliasResolution { aliases: list_reverse(acc), errs: st.errs }
    [c, ...rest] -> match c {
      AC(name, _, _, _, _) -> {
        let r = resolve_alias(name, all_cands, cand_ns, eff_names, file, st)
        let acc1 = match r.r {
          Some(labels) -> [AR(name, labels), ...acc]
          None -> acc
        }
        resolve_alias_cands_loop(all_cands, cand_ns, eff_names, file, r.st, rest, acc1)
      }
    }
  }
}

fn find_alias(aliases: [AliasResult], name: String) : Option[AliasResult] {
  match aliases {
    [] -> None
    [a, ...rest] -> match a {
      AR(n, _) -> if n == name { Some(a) } else { find_alias(rest, name) }
    }
  }
}

# Substitute every alias name in `labels` with its expanded form.
# Effect names pass through unchanged. Duplicates introduced by
# expansion are removed by the caller.
fn expand_label_list(labels: [String], aliases: [AliasResult]) : [String] {
  match labels {
    [] -> []
    [l, ...rest] -> {
      let here = match find_alias(aliases, l) {
        Some(AR(_, expanded)) -> expanded
        None -> [l]
      }
      list_append(here, expand_label_list(rest, aliases))
    }
  }
}

fn expand_aliases_in_row(re: RowExpr, aliases: [AliasResult]) : RowExpr {
  match re {
    REmpty -> REmpty
    RClosed(labels) -> RClosed(dedup_row_labels(expand_row_labels(labels, aliases)))
    ROpen(rv, labels) -> ROpen(rv, dedup_row_labels(expand_row_labels(labels, aliases)))
  }
}

# m7b #1 — alias expansion. Aliases (`type Io = Console + Stdin + ...`)
# only resolve plain non-parametric names; if the user wrote
# `Reader[Int]` we leave the label alone since aliases over
# parameterised effects (`type DbReader = Reader[DbConfig]`) are
# out of scope for m7b #11. Bare names that match an alias expand
# into a list of bare-name labels.
fn expand_row_labels(ls: [RowLabel], aliases: [AliasResult]) : [RowLabel] {
  match ls {
    [] -> []
    [l, ...rest] -> match l {
      RL(name, []) -> {
        let here = match find_alias(aliases, name) {
          Some(AR(_, expanded)) -> map(expanded, (n) => RL(n, []))
          None -> [l]
        }
        list_append(here, expand_row_labels(rest, aliases))
      }
      # Parameterised label: pass through unchanged (no alias is
      # registered with type args today).
      _ -> [l, ...expand_row_labels(rest, aliases)]
    }
  }
}

fn row_label_eq(a: RowLabel, b: RowLabel) : Bool {
  match a {
    RL(an, _) -> match b {
      RL(bn, _) -> an == bn
    }
  }
}

fn dedup_row_labels(ls: [RowLabel]) : [RowLabel] {
  dedup_row_labels_loop(ls, [], [])
}

fn dedup_row_labels_loop(ls: [RowLabel], seen: [String], acc: [RowLabel]) : [RowLabel] {
  match ls {
    [] -> list_reverse(acc)
    [h, ...rest] -> match h {
      RL(n, args) -> {
        let key = match args {
          [] -> n
          _ -> n   # for now we dedup by name only; same caveat as alias expansion
        }
        if list_has(seen, key) {
          dedup_row_labels_loop(rest, seen, acc)
        } else {
          dedup_row_labels_loop(rest, [key, ...seen], [h, ...acc])
        }
      }
    }
  }
}

fn expand_aliases_in_decl(d: Decl, aliases: [AliasResult]) : Decl {
  match d {
    DFn(p, n, tps, params, ret, rexpr, body, l, c) ->
      DFn(p, n, tps, params, ret, expand_aliases_in_row(rexpr, aliases), body, l, c)
    _ -> d
  }
}

fn expand_aliases_in_decls(decls: [Decl], aliases: [AliasResult]) : [Decl] {
  match decls {
    [] -> []
    [d, ...rest] -> [expand_aliases_in_decl(d, aliases),
                     ...expand_aliases_in_decls(rest, aliases)]
  }
}

# m7b #1d — display-time alias preservation (Doc A §*Open questions*
# #5). Render a label set using the largest alias that fully covers
# it; remaining labels (those outside the alias) are appended with
# `+`. The alias rewrite at resolve time is value-preserving, so the
# choice is purely cosmetic — diagnostics keep the user's `Io`
# spelling when it still describes the row, and fall back to the
# expanded labels on partial coverage. Currently no diagnostic prints
# whole rows; this helper is the building block when row-mismatch
# rendering lands.
fn row_to_diag_string(labels: [String], aliases: [AliasResult]) : String {
  if labels == [] { "(empty)" }
  else {
    match best_alias_cover(aliases, labels, None) {
      None -> join_with(labels, " + ")
      Some(AR(alias_name, alias_labels)) -> {
        let leftover = subtract_strings(labels, alias_labels)
        if leftover == [] { alias_name }
        else { string_concat(alias_name, string_concat(" + ", join_with(leftover, " + "))) }
      }
    }
  }
}

# Return the alias whose label set is a subset of `labels` and that
# covers the largest number of labels. Ties prefer the alias seen
# first (lexically earlier in source).
fn best_alias_cover(aliases: [AliasResult], labels: [String],
                    best: Option[AliasResult]) : Option[AliasResult] {
  match aliases {
    [] -> best
    [a, ...rest] -> match a {
      AR(_, alabels) -> {
        let covers = labels_subset(alabels, labels)
        let new_best =
          if covers and better_cover(best, alabels) { Some(a) }
          else { best }
        best_alias_cover(rest, labels, new_best)
      }
    }
  }
}

fn better_cover(prev: Option[AliasResult], candidate_labels: [String]) : Bool {
  match prev {
    None -> true
    Some(AR(_, p)) -> list_length(candidate_labels) > list_length(p)
  }
}

fn labels_subset(small: [String], big: [String]) : Bool {
  match small {
    [] -> true
    [x, ...rest] ->
      if list_has(big, x) { labels_subset(rest, big) }
      else { false }
  }
}

fn subtract_strings(xs: [String], ys: [String]) : [String] {
  match xs {
    [] -> []
    [x, ...rest] ->
      if list_has(ys, x) { subtract_strings(rest, ys) }
      else { [x, ...subtract_strings(rest, ys)] }
  }
}

fn param_ty(pm: Param) : Ty {
  match pm.ptype {
    Some(te) -> resolve_ty(te)
    None -> TyAny
  }
}

# Extract the declared signature of a top-level decl, or None if the
# decl has no signature shape (DType, DImport).
fn sig_of_decl(d: Decl) : Option[Ty] {
  match d {
    DFn(_, _, _, params, opt_ret, rexpr, _, _, _) -> {
      let pts = map(params, param_ty)
      let ret = match opt_ret {
        Some(rty) -> resolve_ty(rty)
        None -> TyUnit
      }
      Some(TyFnT(pts, ret, row_of_expr(rexpr)))
    }
    _ -> None
  }
}

# Render a Ty back as kaikai surface syntax. Inverse of resolve_ty
# modulo unknown-constructor handling.
fn ty_string_list(ts: [Ty]) : [String] = map(ts, ty_to_string)

fn ty_to_string(t: Ty) : String {
  match t {
    TyInt    -> "Int"
    TyReal   -> "Real"
    TyBool   -> "Bool"
    TyString -> "String"
    TyChar   -> "Char"
    TyUnit   -> "Unit"
    TyListT(inner) -> cat3("[", ty_to_string(inner), "]")
    # m7b #11k: render the function type's effect row alongside the
    # arrow when non-empty, with each label printed as `Eff` or
    # `Eff[T1, T2]` so parametric-effect mismatches (Reader[Int] vs
    # Reader[String]) are visible in `expected/found` notes.
    TyFnT(ps, ret, row) -> concat_all([
      "(", join_with(ty_string_list(ps), ", "), ") -> ",
      ty_to_string(ret),
      row_to_string_suffix(row)
    ])
    TyCon(cname, tas) -> {
      match tas {
        [] -> cname
        _ -> concat_all([cname, "[", join_with(ty_string_list(tas), ", "), "]"])
      }
    }
    TyVarT(n) -> cat2("?t", int_to_string(n))
    TyAny -> "?"
    # m12.5: render dimensioned base types as `Real<u>` / `Int<u>`.
    # The unit goes through unit_canon so the printed form matches
    # what the unifier compares against — same shape on every side.
    TyDimT(base, u) -> concat_all([ty_to_string(base), "<", unit_canon_display(u), ">"])
  }
}

# m12.5: render a UnitExprT in canonical form for diagnostics. Sorts
# symbols alphabetically and groups powers, so `kg * m` and `m * kg`
# render identically.
fn unit_canon_display(u: UnitExprT) : String = unit_expr_display(unit_canon(u))

# m12.8.x phase 2 (Gap 1, partial): extract the canonical unit symbol
# of a dimensioned type for the `unit_name` compile-time intrinsic.
# Bare types and unresolved unit-vars yield the empty string so the
# emitter never produces an LLVM/C error from a missing dimension.
fn unit_name_of_ty(ot: Option[Ty]) : String {
  match ot {
    Some(t) -> match t {
      TyDimT(_, u) -> match unit_canon(u) {
        UVar(_) -> ""
        UOne    -> ""
        cu      -> unit_expr_display(cu)
      }
      _ -> ""
    }
    None -> ""
  }
}

# m4c #2 — name-mangling helpers for monomorphisation.
#
# `mangle_name(name, [Ty]) : String` produces a deterministic,
# C-identifier-safe name for a polymorphic decl instantiated at a
# concrete type tuple. The empty tuple maps back to `name` (no
# instantiation, e.g. fully monomorphic decls). For non-empty tuples
# the form is `name__mono__T1[__T2...]`, with each `Tn` rendered by
# `mangle_ty` using bracketed sentinels (`L_..._E` for lists,
# `_O_..._C` for type-constructor argument lists, `F_..._R_..._E`
# for function arrows). The sentinels make the encoding unambiguous:
# `Foo[Bar]` and a hypothetical user fn named `Foo_Bar` cannot
# collide. Effects are erased — two instantiations that differ only
# in the row of an inner `TyFnT` mangle the same, by design (Perceus
# operates on values, not on rows).
#
# The mangler errors implicitly on `TyVarT` / `TyAny`: a resolved
# call-site tuple should not contain unresolved variables. If one
# slips through the renderer emits `TVAR` / `Any` and the resulting
# duplicate is caught by the m4c #3 collision check.

fn mangle_ty(t: Ty) : String {
  match t {
    TyInt    -> "Int"
    TyReal   -> "Real"
    TyBool   -> "Bool"
    TyString -> "String"
    TyChar   -> "Char"
    TyUnit   -> "Unit"
    TyListT(inner) -> concat_all(["L_", mangle_ty(inner), "_E"])
    TyFnT(ps, ret, _) -> concat_all([
      "F_", join_with(map(ps, mangle_ty), "_"),
      "_R_", mangle_ty(ret), "_E"
    ])
    TyCon(cname, tas) -> {
      match tas {
        [] -> cname
        [h, ...rest] -> concat_all([cname, "_O_",
                                    join_with(map(tas, mangle_ty), "_"),
                                    "_C"])
      }
    }
    TyVarT(_) -> "TVAR"
    TyAny     -> "Any"
    # m12.5: units are erased at codegen time. The mangled name for a
    # dimensioned type is the same as its base type's mangle — so a
    # call like `f(1.0<USD>)` and a call `f(1.0)` mangle into the same
    # specialisation. This is the codegen-erasure invariant manifest
    # at the mangler level.
    TyDimT(base, _) -> mangle_ty(base)
  }
}

fn mangle_name(name: String, tys: [Ty]) : String {
  match tys {
    [] -> name
    [h, ...rest] -> concat_all([name, "__mono__",
                                join_with(map(tys, mangle_ty), "__")])
  }
}

# Render a Row as the ` / Eff1 + Eff2` suffix used in fn-type
# strings. Empty row → empty string. Open row tail → trailing
# `+ ?eN`. Each label uses `label_to_string` so type args render.
fn row_to_string_suffix(r: Row) : String {
  let body =
    if labels_empty(r.labels) and (match r.tail { None -> true Some(_) -> false }) {
      ""
    } else {
      let lbs = join_with(map(r.labels, label_to_string), " + ")
      let tail_s = match r.tail {
        None -> ""
        Some(v) -> {
          let pre = if string_length(lbs) > 0 { " + " } else { "" }
          concat_all([pre, "?e", int_to_string(v)])
        }
      }
      concat_all([" / ", lbs, tail_s])
    }
  body
}

# Dump the declared signature (or shape) of every top-level decl. Used
# by `--types`; does not attempt to infer bodies, just surfaces what
# the user wrote.
fn dump_decl_type(d: Decl) : Unit / Console {
  match d {
    DFn(is_pub, name, _, _, _, _, _, line, col) -> {
      let pub_s = if is_pub { "pub " } else { "" }
      match sig_of_decl(d) {
        Some(ty) -> print("#{pub_s}fn #{name} : #{ty_to_string(ty)} @#{int_to_string(line)}:#{int_to_string(col)}")
        None -> ()
      }
    }
    DType(is_pub, name, tparams, _, line, col) -> {
      let pub_s = if is_pub { "pub " } else { "" }
      let tps = match tparams {
        [] -> ""
        _ -> concat_all(["[", join_with(tparams, ", "), "]"])
      }
      print("#{pub_s}type #{name}#{tps} @#{int_to_string(line)}:#{int_to_string(col)}")
    }
    DTest(desc, _, line, col) ->
      print("test #{desc} @#{int_to_string(line)}:#{int_to_string(col)}")
    DImport(ik, line, col) -> {
      match ik {
        IkPath(p) -> print("import #{p} @#{int_to_string(line)}:#{int_to_string(col)}")
        IkAlias(p, a) -> print("import #{p} as #{a} @#{int_to_string(line)}:#{int_to_string(col)}")
        IkSelective(p, _) -> print("import #{p} @#{int_to_string(line)}:#{int_to_string(col)}")
      }
    }
    DEffect(is_pub, name, _, _, line, col) -> {
      let pub_s = if is_pub { "pub " } else { "" }
      print("#{pub_s}effect #{name} @#{int_to_string(line)}:#{int_to_string(col)}")
    }
    DProtocol(is_pub, name, _, line, col) -> {
      let pub_s = if is_pub { "pub " } else { "" }
      print("#{pub_s}protocol #{name} @#{int_to_string(line)}:#{int_to_string(col)}")
    }
    DImpl(pname, _, _, line, col) ->
      print("impl #{pname} @#{int_to_string(line)}:#{int_to_string(col)}")
    DDerive(_, inner, _, _) -> dump_decl_type(inner)
    DUnit(is_pub, name, alias_opt, line, col) -> {
      let pub_s = if is_pub { "pub " } else { "" }
      let body_s = match alias_opt {
        None -> ""
        Some(u) -> string_concat(" = ", unit_canon_display(u))
      }
      print("#{pub_s}unit #{name}#{body_s} @#{int_to_string(line)}:#{int_to_string(col)}")
    }
  }
}

fn dump_types(decls: [Decl]) : Unit / Console = dump_types_loop(decls)

fn dump_types_loop(ds: [Decl]) : Unit / Console {
  match ds {
    [] -> ()
    [d, ...rest] -> { dump_decl_type(d) dump_types_loop(rest) }
  }
}

# ====================================================================
# type schemes + environment (M2b)
# ====================================================================
#
# A TyScheme is `Scheme(bound_vars, bound_rvars, Ty)`: the type-var
# ids in `bound_vars` appear as TyVarT(n) inside `Ty`; the row-var
# ids in `bound_rvars` appear as `Row { tail: Some(n) }` inside any
# TyFnT in `Ty`. Both kinds are instantiated to fresh ids at each
# use site (M2c for type vars, m7b #12 for row vars). The bound ids
# are scheme-local — bound-id 0 in scheme A and bound-id 0 in scheme
# B refer to different vars; the instantiation step rewrites them
# through a temporary substitution before they reach the inferencer's
# main subst slots.
#
# A TyEnv is a flat association list of (name, scheme) entries plus a
# fresh-variable counter used later. Lookups are linear — fine at this
# stage (a few dozen entries).

type TyScheme = Scheme([Int], [Int], [Int], Ty)
# m12.5: third parameter `bound_uvars` lists unit-var ids quantified
# by the scheme. Instantiation allocates a fresh UVar per bound id
# (parallel to bound_vars / bound_rvars). Empty for non-unit-poly
# schemes — preserves prior behaviour.

type TyEntry = { name: String, scheme: TyScheme }

type TyEnv = { entries: [TyEntry], fresh: Int }

fn ty_env_empty() : TyEnv = TyEnv { entries: [], fresh: 0 }

fn ty_env_add(env: TyEnv, name: String, sc: TyScheme) : TyEnv =
  TyEnv { entries: [TyEntry { name: name, scheme: sc }, ...env.entries], fresh: env.fresh }

fn ty_env_lookup_loop(es: [TyEntry], target: String) : Option[TyScheme] {
  match es {
    [] -> None
    [e, ...rest] -> if e.name == target { Some(e.scheme) } else { ty_env_lookup_loop(rest, target) }
  }
}

fn ty_env_lookup(env: TyEnv, target: String) : Option[TyScheme] =
  ty_env_lookup_loop(env.entries, target)

# Names of entries whose first byte is uppercase ASCII. Used to
# filter down to variant constructors (`Some`, `Ok`, `Err`, user
# variants) when suggesting alternatives for unknown variants.
fn ty_env_uppercase_names(env: TyEnv) : [String] =
  uppercase_names_loop(env.entries, [])

fn uppercase_names_loop(es: [TyEntry], acc: [String]) : [String] {
  match es {
    [] -> list_reverse(acc)
    [e, ...rest] -> {
      let first_upper = match char_at(e.name, 0) {
        Some(c) -> c >= 'A' and c <= 'Z'
        None    -> false
      }
      if first_upper {
        uppercase_names_loop(rest, [e.name, ...acc])
      } else {
        uppercase_names_loop(rest, acc)
      }
    }
  }
}

# ---- small constructors ----

fn mono(ty: Ty) : TyScheme = Scheme([], [], [], ty)

fn scheme(vars: [Int], ty: Ty) : TyScheme = Scheme(vars, [], [], ty)

fn scheme_full(vars: [Int], rvars: [Int], ty: Ty) : TyScheme = Scheme(vars, rvars, [], ty)

# m12.5: scheme generalising over type-, row-, and unit-vars all at once.
# Used by fn_scheme_of_decl when the signature has [u: Unit] tparams.
fn scheme_uvars(vars: [Int], rvars: [Int], uvars: [Int], ty: Ty) : TyScheme =
  Scheme(vars, rvars, uvars, ty)

fn tv(n: Int) : Ty = TyVarT(n)

fn fn_ty(ps: [Ty], ret: Ty) : Ty = TyFnT(ps, ret, row_empty())

# m12.8.x phase 4 (Bug 6): open-tail Row for row-polymorphic
# prelude signatures (each/map/filter/reduce). The row var id
# `rid` matches the scheme's bound rvar; at instantiation time the
# inferencer mints a fresh rvar so labels propagate from callee
# into caller.
fn row_with_tail(rid: Int) : Row = Row {
  labels:        [],
  tail:          Some(rid),
  display_alias: None
}

fn list_ty(t: Ty) : Ty = TyListT(t)

# ---- prelude signatures ----
#
# Kept in sync with stage 0's runtime and with stdlib/core.kai's
# assumptions. Type variables inside a scheme are private to it.

fn add_prelude_sigs(env: TyEnv) : TyEnv {
  let es = [
    # IO
    TyEntry { name: "print",          scheme: mono(fn_ty([TyString], TyUnit)) },
    TyEntry { name: "eprint",         scheme: mono(fn_ty([TyString], TyUnit)) },
    TyEntry { name: "args",           scheme: mono(fn_ty([], list_ty(TyString))) },
    TyEntry { name: "read_file",      scheme: mono(fn_ty([TyString], TyCon("Result", [TyString, TyString]))) },
    TyEntry { name: "write_file",     scheme: mono(fn_ty([TyString, TyString], TyCon("Result", [TyUnit, TyString]))) },
    TyEntry { name: "read_line",      scheme: mono(fn_ty([], TyCon("Result", [TyString, TyString]))) },
    # `exit` and `panic` never return — give them a polymorphic result so
    # they unify with any context.
    TyEntry { name: "exit",           scheme: scheme([0], fn_ty([TyInt],    tv(0))) },
    TyEntry { name: "panic",          scheme: scheme([0], fn_ty([TyString], tv(0))) },

    # Conversions
    TyEntry { name: "int_to_string",  scheme: mono(fn_ty([TyInt],    TyString)) },
    TyEntry { name: "real_to_string", scheme: mono(fn_ty([TyReal],   TyString)) },
    TyEntry { name: "string_to_int",  scheme: mono(fn_ty([TyString], TyCon("Option", [TyInt]))) },
    TyEntry { name: "string_to_real", scheme: mono(fn_ty([TyString], TyCon("Option", [TyReal]))) },
    TyEntry { name: "char_to_int",    scheme: mono(fn_ty([TyChar],   TyInt)) },
    TyEntry { name: "int_to_char",    scheme: mono(fn_ty([TyInt],    TyChar)) },

    # Strings
    TyEntry { name: "string_length",  scheme: mono(fn_ty([TyString],                TyInt)) },
    TyEntry { name: "string_concat",  scheme: mono(fn_ty([TyString, TyString],      TyString)) },
    TyEntry { name: "string_concat_all", scheme: mono(fn_ty([list_ty(TyString)],    TyString)) },
    TyEntry { name: "string_join",    scheme: mono(fn_ty([list_ty(TyString), TyString], TyString)) },
    TyEntry { name: "string_slice",   scheme: mono(fn_ty([TyString, TyInt, TyInt],  TyString)) },
    TyEntry { name: "string_split",   scheme: mono(fn_ty([TyString, TyString],      list_ty(TyString))) },
    TyEntry { name: "string_contains",scheme: mono(fn_ty([TyString, TyString],      TyBool)) },
    TyEntry { name: "char_at",        scheme: mono(fn_ty([TyString, TyInt],         TyCon("Option", [TyChar]))) },

    # Lists (monomorphic over element type `0`).
    TyEntry { name: "list_length",    scheme: scheme([0], fn_ty([list_ty(tv(0))],                    TyInt)) },
    TyEntry { name: "list_append",    scheme: scheme([0], fn_ty([list_ty(tv(0)), list_ty(tv(0))],    list_ty(tv(0)))) },
    TyEntry { name: "list_reverse",   scheme: scheme([0], fn_ty([list_ty(tv(0))],                    list_ty(tv(0)))) },

    # Higher-order (element `0`, result `1`).
    # m12.8.x phase 4 (Bug 6): higher-order combinators are row-
    # polymorphic in the callback. The callback's row tail equals
    # the combinator's outer row tail, so a `each(xs, dump_fn)` where
    # `dump_fn : Decl -> Unit / Console` propagates Console back to
    # the calling fn through `each`'s outer row. Without this,
    # row-bearing dump helpers can't be passed to each/map/filter
    # at all.
    TyEntry { name: "map",    scheme: scheme_full([0, 1], [0], TyFnT([list_ty(tv(0)), TyFnT([tv(0)], tv(1), row_with_tail(0))], list_ty(tv(1)), row_with_tail(0))) },
    TyEntry { name: "filter", scheme: scheme_full([0],    [0], TyFnT([list_ty(tv(0)), TyFnT([tv(0)], TyBool, row_with_tail(0))], list_ty(tv(0)), row_with_tail(0))) },
    TyEntry { name: "reduce", scheme: scheme_full([0, 1], [0], TyFnT([list_ty(tv(0)), tv(1), TyFnT([tv(1), tv(0)], tv(1), row_with_tail(0))], tv(1), row_with_tail(0))) },
    TyEntry { name: "each",   scheme: scheme_full([0],    [0], TyFnT([list_ty(tv(0)), TyFnT([tv(0)], TyUnit, row_with_tail(0))], TyUnit, row_with_tail(0))) },

    # Opaque mutable arrays.
    TyEntry { name: "array_make",   scheme: scheme([0], fn_ty([TyInt, tv(0)],                                TyCon("Array", [tv(0)]))) },
    TyEntry { name: "array_length", scheme: scheme([0], fn_ty([TyCon("Array", [tv(0)])],                      TyInt)) },
    TyEntry { name: "array_get",    scheme: scheme([0], fn_ty([TyCon("Array", [tv(0)]), TyInt],               tv(0))) },
    TyEntry { name: "array_set",    scheme: scheme([0], fn_ty([TyCon("Array", [tv(0)]), TyInt, tv(0)],        TyCon("Array", [tv(0)]))) },
    TyEntry { name: "array_grow",   scheme: scheme([0], fn_ty([TyCon("Array", [tv(0)]), TyInt, tv(0)],        TyCon("Array", [tv(0)]))) },
    # m8 #7: mailbox runtime — type-erased entries (Msg flows
    # through TyAny). The polymorphic surface is in stdlib/actor.kai
    # where `with_mailbox[Msg]` and `Actor[Msg]`'s clauses re-attach
    # the right Msg to send/receive. mailbox_alloc returns a Pid
    # whose Msg type is fresh at the call site (TyAny unifies with
    # whatever the surrounding context expects).
    TyEntry { name: "mailbox_alloc",         scheme: scheme([0], fn_ty([],                                       TyCon("Pid", [tv(0)]))) },
    TyEntry { name: "mailbox_alloc_bounded", scheme: scheme([0], fn_ty([TyInt, TyInt],                            TyCon("Pid", [tv(0)]))) },
    TyEntry { name: "mailbox_send",          scheme: scheme([0], fn_ty([TyCon("Pid", [tv(0)]), tv(0)],           TyUnit)) },
    TyEntry { name: "mailbox_recv",          scheme: scheme([0], fn_ty([TyCon("Pid", [tv(0)])],                  tv(0))) },
    TyEntry { name: "mailbox_free",          scheme: scheme([0], fn_ty([TyCon("Pid", [tv(0)])],                  TyUnit)) },
    # Bug 8: `unitless` TyEntry removed. The user-facing escape was
    # leaking typer-internal erasure as a callable; design-idiomatic
    # equivalents are `print("#{x}")` (post-Bug-4 + Gap-1) for output
    # and multiplication by a unit-bearing factor for conversions.
    # m12.8.x phase 2 (Gap 1): `unit_name[u: Unit](x: Real<u>) : String`
    # — compile-time reflection that returns the canonical unit
    # symbol of the dimensioned argument as a String literal. The
    # call lowers to a constant string at the C / LLVM emit step,
    # extracted from the arg's `.ty`. Lets user code build
    # "<value> <unit>" strings without per-unit-specialised protocol
    # impls (which would require a structural change to the impl
    # machinery; deferred). When the arg's unit is still a UVar
    # (the protocol-impl-generic case), the empty string is emitted.
    TyEntry { name: "unit_name",
              scheme: scheme_uvars([], [], [0],
                fn_ty([TyDimT(TyReal, UVar(0))], TyString)) },
    # m12.8 phase 2: typer-internal erasure of the unit annotation on
    # a dimensioned Real. Polymorphic in the unit-var so the call site
    # can pass `Real<USD>`, `Real<EUR>`, etc. and recover bare `Real`
    # for use with `real_to_string`. Not part of the user-facing
    # surface (the `__` prefix is the convention for compiler-internal
    # names).
    TyEntry { name: "__strip_unit",
              scheme: scheme_uvars([], [], [0],
                fn_ty([TyDimT(TyReal, UVar(0))], TyReal)) }
  ]
  TyEnv { entries: list_append(es, env.entries), fresh: env.fresh }
}

# ---- built-in variant constructors ----

fn add_builtin_variant_sigs(env: TyEnv) : TyEnv {
  let es = [
    # Option[a]
    TyEntry { name: "Some", scheme: scheme([0],    fn_ty([tv(0)], TyCon("Option", [tv(0)]))) },
    TyEntry { name: "None", scheme: scheme([0],    TyCon("Option", [tv(0)])) },
    # Result[e, a]: Ok carries `a` (TyVarT(1)), Err carries `e` (TyVarT(0)).
    TyEntry { name: "Ok",   scheme: scheme([0, 1], fn_ty([tv(1)], TyCon("Result", [tv(0), tv(1)]))) },
    TyEntry { name: "Err",  scheme: scheme([0, 1], fn_ty([tv(0)], TyCon("Result", [tv(0), tv(1)]))) }
  ]
  TyEnv { entries: list_append(es, env.entries), fresh: env.fresh }
}

# ---- user-defined signatures ----
#
# For each DFn decl add its signature; for each DType of sum-shape add a
# scheme per variant that produces TyCon(type_name, [tparams]). Records
# are not yet constructor-exposed in the env; they'll land alongside
# field-access typing in M2c.

fn tparam_ids_loop(tparams: [String], i: Int, acc: [Int]) : [Int] {
  match tparams {
    [] -> list_reverse(acc)
    [_, ...rest] -> tparam_ids_loop(rest, i + 1, [i, ...acc])
  }
}

fn tparam_ids(tparams: [String]) : [Int] = tparam_ids_loop(tparams, 0, [])

# m7b #2: same as tparam_ids but starts numbering from `start` so a
# nested set of tparams (op-level on top of effect-level) gets a
# disjoint id range.
fn tparam_ids_from(tparams: [String], start: Int) : [Int] = tparam_ids_loop(tparams, start, [])

# m12.5: split the tparam list into separate type-var and unit-var ID
# lists. Mirrors the kind-aware allocation in mk_tpbinds — bound_vars
# (type pool) get IDs 0..nT-1; bound_uvars (unit pool) get IDs 0..nU-1.
type TParamSplit = { tvars: [Int], uvars: [Int] }

fn tparam_id_split(tparams: [String]) : TParamSplit =
  tparam_id_split_loop(tparams, 0, 0, [], [])

fn tparam_id_split_loop(tparams: [String], ti: Int, ui: Int,
                        tacc: [Int], uacc: [Int]) : TParamSplit {
  match tparams {
    [] -> TParamSplit { tvars: list_reverse(tacc), uvars: list_reverse(uacc) }
    [n, ...rest] -> {
      if tp_kind_is_unit(n) {
        tparam_id_split_loop(rest, ti, ui + 1, tacc, [ui, ...uacc])
      } else {
        tparam_id_split_loop(rest, ti + 1, ui, [ti, ...tacc], uacc)
      }
    }
  }
}

# Resolve a TypeExpr under a mapping from tparam name to its TyVarT id.
# The mapping is itself an association list for now.
type TPBind = TPB(String, Int)

fn tpbind_lookup(binds: [TPBind], name: String) : Option[Int] {
  match binds {
    [] -> None
    [b, ...rest] -> match b {
      TPB(n, i) -> if n == name { Some(i) } else { tpbind_lookup(rest, name) }
    }
  }
}

fn resolve_ty_with_tparams(t: TypeExpr, binds: [TPBind]) : Ty {
  match t.tkind {
    TyName(name, tas) -> {
      match tpbind_lookup(binds, name) {
        Some(i) -> tv(i)
        None -> {
          if name == "Int"    { TyInt }
          else if name == "Real"   { TyReal }
          else if name == "Bool"   { TyBool }
          else if name == "String" { TyString }
          else if name == "Char"   { TyChar }
          else if name == "Unit"   { TyUnit }
          # m7a #7 / m8 #3: Nothing is the bottom type (used by
          # Fail.fail and Spawn's type-erased ops); the typer treats
          # it as TyAny because it can't witness uninhabitedness.
          # Without this case, Spawn.spawn(thunk: Nothing) refuses
          # any non-Nothing thunk argument. resolve_ty and
          # resolve_ty_with_binds both have this case; it was
          # missing here.
          else if name == "Nothing" { TyAny }
          else { TyCon(name, resolve_tas_with(tas, binds)) }
        }
      }
    }
    TyList(inner) -> list_ty(resolve_ty_with_tparams(inner, binds))
    TyFn(ps, ret, _) -> fn_ty(map(ps, (p) => resolve_ty_with_tparams(p, binds)),
                           resolve_ty_with_tparams(ret, binds))
    # m12.5: dimensioned types in this lighter resolver — without unit
    # tparam bindings — leave UVar references as USym holdovers. Real
    # generic-unit resolution lives in resolve_ty_with_binds below.
    TyDim(base, u) -> dim_collapse(resolve_ty_with_tparams(base, binds), unit_canon(u))
  }
}

fn resolve_tas_with(tas: [TypeExpr], binds: [TPBind]) : [Ty] =
  map(tas, (t) => resolve_ty_with_tparams(t, binds))

# Build the TPBind list for a decl's generic type parameters.
# m12.5: type-kind and unit-kind params allocate IDs from *separate*
# pools (type-var pool for KType, unit-var pool for KUnit). Without
# this split a `[u: Unit, T]` decl would conflate type-var 1 with
# unit-var 1 across instantiation passes.
fn mk_tpbinds_loop(tparams: [String], ti: Int, ui: Int, acc: [TPBind]) : [TPBind] {
  match tparams {
    [] -> list_reverse(acc)
    [n, ...rest] -> {
      if tp_kind_is_unit(n) {
        mk_tpbinds_loop(rest, ti, ui + 1, [TPB(n, ui), ...acc])
      } else {
        mk_tpbinds_loop(rest, ti + 1, ui, [TPB(n, ti), ...acc])
      }
    }
  }
}

fn mk_tpbinds(tparams: [String]) : [TPBind] = mk_tpbinds_loop(tparams, 0, 0, [])

# m7b #2: same as mk_tpbinds but starts ids at `start`. Used to
# combine effect-level and op-level tparams into a single binding
# context with disjoint ids.
fn mk_tpbinds_from(tparams: [String], start: Int) : [TPBind] = mk_tpbinds_loop(tparams, start, 0, [])

fn append_tpbinds(a: [TPBind], b: [TPBind]) : [TPBind] {
  match a {
    [] -> b
    [h, ...rest] -> [h, ...append_tpbinds(rest, b)]
  }
}

fn append_ints(a: [Int], b: [Int]) : [Int] {
  match a {
    [] -> b
    [h, ...rest] -> [h, ...append_ints(rest, b)]
  }
}

fn scheme_of_variant(type_name: String, tparams: [String], v: Variant) : TyScheme {
  match v {
    Var(ctor_name, vargs) -> {
      let binds = mk_tpbinds(tparams)
      let ids = tparam_ids(tparams)
      let arg_tys = map(vargs, (a) => resolve_ty_with_tparams(a, binds))
      let result = TyCon(type_name, map(ids, tv))
      match vargs {
        [] -> scheme(ids, result)
        _  -> scheme(ids, fn_ty(arg_tys, result))
      }
    }
  }
}

fn add_variants_of_decl(env: TyEnv, d: Decl) : TyEnv {
  match d {
    DType(_, tname, tparams, body, _, _) -> match body {
      TBSum(vs) -> add_variants_loop(env, tname, tparams, vs)
      _ -> env
    }
    _ -> env
  }
}

fn add_variants_loop(env: TyEnv, tname: String, tparams: [String], vs: [Variant]) : TyEnv {
  match vs {
    [] -> env
    [v, ...rest] -> match v {
      Var(cname, _) -> {
        let sc = scheme_of_variant(tname, tparams, v)
        add_variants_loop(ty_env_add(env, cname, sc), tname, tparams, rest)
      }
    }
  }
}

# m7b #12 — collect all distinct row-variable names appearing in the
# row positions of a function declaration's signature: the outer
# return-row plus every nested `TyFn` row inside parameter types and
# the return type. Order of first occurrence is preserved so each
# decl gets a stable assignment of bound row-var ids.
fn collect_decl_rvars(d: Decl) : [String] {
  match d {
    DFn(_, _, _, params, opt_ret, rexpr, _, _, _) -> {
      let acc0 = collect_rvars_in_row(rexpr, [])
      let acc1 = collect_rvars_in_params(params, acc0)
      match opt_ret {
        Some(rty) -> collect_rvars_in_typeexpr(rty, acc1)
        None      -> acc1
      }
    }
    _ -> []
  }
}

fn collect_rvars_in_row(re: RowExpr, acc: [String]) : [String] {
  match re {
    REmpty -> acc
    RClosed(_) -> acc
    ROpen(rv, _) -> if list_has(acc, rv) { acc } else { list_append(acc, [rv]) }
  }
}

fn collect_rvars_in_params(ps: [Param], acc: [String]) : [String] {
  match ps {
    [] -> acc
    [p, ...rest] -> {
      let acc1 = match p.ptype {
        Some(te) -> collect_rvars_in_typeexpr(te, acc)
        None     -> acc
      }
      collect_rvars_in_params(rest, acc1)
    }
  }
}

fn collect_rvars_in_typeexpr(t: TypeExpr, acc: [String]) : [String] {
  match t.tkind {
    TyName(_, tas) -> collect_rvars_in_typeexprs(tas, acc)
    TyList(inner)  -> collect_rvars_in_typeexpr(inner, acc)
    TyFn(ps, ret, rexpr) -> {
      let acc1 = collect_rvars_in_typeexprs(ps, acc)
      let acc2 = collect_rvars_in_typeexpr(ret, acc1)
      collect_rvars_in_row(rexpr, acc2)
    }
    # m12.5: dimensioned base — recurse into the inner ty; the unit
    # itself never carries row variables.
    TyDim(base, _) -> collect_rvars_in_typeexpr(base, acc)
  }
}

fn collect_rvars_in_typeexprs(ts: [TypeExpr], acc: [String]) : [String] {
  match ts {
    [] -> acc
    [t, ...rest] -> collect_rvars_in_typeexprs(rest, collect_rvars_in_typeexpr(t, acc))
  }
}

fn mk_rvbinds_loop(names: [String], i: Int, acc: [RVBind]) : [RVBind] {
  match names {
    [] -> list_reverse(acc)
    [n, ...rest] -> mk_rvbinds_loop(rest, i + 1, [RVB(n, i), ...acc])
  }
}

fn mk_rvbinds(names: [String]) : [RVBind] = mk_rvbinds_loop(names, 0, [])

fn rvbind_ids_loop(binds: [RVBind], acc: [Int]) : [Int] {
  match binds {
    [] -> list_reverse(acc)
    [b, ...rest] -> match b {
      RVB(_, i) -> rvbind_ids_loop(rest, [i, ...acc])
    }
  }
}

fn rvbind_ids(binds: [RVBind]) : [Int] = rvbind_ids_loop(binds, [])

# Resolve a TypeExpr under both the type-parameter and row-variable
# binding contexts. m7b #13 added the tpbinds half on top of the
# m7b #12 rbinds half. A `TyName(name, [])` is first looked up as a
# tparam; if not found, the existing builtin / user-type fallback
# applies.
fn resolve_ty_with_binds(t: TypeExpr, tpbinds: [TPBind], rbinds: [RVBind]) : Ty {
  match t.tkind {
    TyName(name, tas) -> {
      match tpbind_lookup(tpbinds, name) {
        Some(i) -> tv(i)
        None -> {
          if name == "Int" { TyInt }
          else if name == "Real"   { TyReal }
          else if name == "Bool"   { TyBool }
          else if name == "String" { TyString }
          else if name == "Char"   { TyChar }
          else if name == "Unit"   { TyUnit }
          else if name == "Nothing" { TyAny }
          else { TyCon(name, map(tas, (a) => resolve_ty_with_binds(a, tpbinds, rbinds))) }
        }
      }
    }
    TyList(inner) -> TyListT(resolve_ty_with_binds(inner, tpbinds, rbinds))
    TyFn(fps, fret, rexpr) ->
      TyFnT(map(fps, (p) => resolve_ty_with_binds(p, tpbinds, rbinds)),
            resolve_ty_with_binds(fret, tpbinds, rbinds),
            row_of_expr_with_binds(rexpr, tpbinds, rbinds))
    # m12.5: dimensioned base — resolve the inner Ty against tpbinds,
    # then walk the unit and rewrite any symbol that names a unit
    # tparam (`[u: Unit]` → name "u#Unit") to UVar(id).
    TyDim(base, u) ->
      dim_collapse(resolve_ty_with_binds(base, tpbinds, rbinds),
                   unit_canon(unit_resolve_tparams(u, tpbinds)))
  }
}

# m12.5: walk a UnitExprT and replace USym("u") with UVar(id) when "u"
# matches a unit-kind tparam. Type-kind tparams are left alone — they
# would be a category error in unit position; we surface that as a
# unification failure later if necessary, not as a parser/resolve error.
fn unit_resolve_tparams(u: UnitExprT, tpbinds: [TPBind]) : UnitExprT {
  match u {
    UOne -> u
    UVar(_) -> u
    USym(s) -> match unit_tparam_lookup(tpbinds, s) {
      Some(id) -> UVar(id)
      None     -> u
    }
    UMul(a, b) -> UMul(unit_resolve_tparams(a, tpbinds), unit_resolve_tparams(b, tpbinds))
    UInv(a) -> UInv(unit_resolve_tparams(a, tpbinds))
    UPow(a, n) -> UPow(unit_resolve_tparams(a, tpbinds), n)
  }
}

# Look up a unit-kind tparam by its surface name. The tparam list
# stores names with the "#Unit" suffix for unit-kind params; the
# resolver compares the bare surface name against the suffix-stripped
# stored name.
fn unit_tparam_lookup(binds: [TPBind], surface: String) : Option[Int] {
  match binds {
    [] -> None
    [b, ...rest] -> match b {
      TPB(stored, id) -> {
        if tp_kind_is_unit(stored) and tp_strip_kind(stored) == surface { Some(id) }
        else { unit_tparam_lookup(rest, surface) }
      }
    }
  }
}

# m12.5: tparam-name suffix encoding helpers. KType params keep the
# user's surface name; KUnit params get "#Unit" appended. The "#"
# character can never appear in a kaikai identifier (lexer only
# accepts alnum + '_'), so the encoding is collision-free.
fn tp_unit_suffix() : String = "#Unit"

fn tp_make(name: String, k: Kind) : String {
  match k {
    KType -> name
    KUnit -> string_concat(name, tp_unit_suffix())
  }
}

fn tp_kind_is_unit(stored: String) : Bool = string_ends_with(stored, tp_unit_suffix())

fn tp_kind_of(stored: String) : Kind =
  if tp_kind_is_unit(stored) { KUnit } else { KType }

fn tp_strip_kind(stored: String) : String {
  if tp_kind_is_unit(stored) {
    string_slice(stored, 0, string_length(stored) - string_length(tp_unit_suffix()))
  } else { stored }
}

fn string_ends_with(s: String, suffix: String) : Bool {
  let sl = string_length(s)
  let xl = string_length(suffix)
  if xl > sl { false }
  else { string_slice(s, sl - xl, xl) == suffix }
}

# Pre-#13 callers that only carry rbinds (no fn-level tparams).
fn resolve_ty_with_rvbinds(t: TypeExpr, rbinds: [RVBind]) : Ty =
  resolve_ty_with_binds(t, [], rbinds)

fn param_ty_with_binds(pm: Param, tpbinds: [TPBind], rbinds: [RVBind]) : Ty {
  match pm.ptype {
    Some(te) -> resolve_ty_with_binds(te, tpbinds, rbinds)
    None     -> TyAny
  }
}

fn param_ty_with_rvbinds(pm: Param, rbinds: [RVBind]) : Ty =
  param_ty_with_binds(pm, [], rbinds)

# Variant of row_of_expr_with_rbinds that also resolves per-label
# ty_args under tpbinds — labels like `Reader[T]` where `T` is a
# fn-level type parameter (m7b #13).
fn row_of_expr_with_binds(re: RowExpr, tpbinds: [TPBind], rbinds: [RVBind]) : Row {
  match re {
    REmpty -> row_empty()
    RClosed(labels) -> Row {
      labels: row_labels_of_rls_with_binds(labels, tpbinds, rbinds),
      tail: None,
      display_alias: None
    }
    ROpen(rv, labels) -> Row {
      labels: row_labels_of_rls_with_binds(labels, tpbinds, rbinds),
      tail: match rvbind_lookup(rbinds, rv) {
        Some(id) -> Some(id)
        None     -> Some(-1)
      },
      display_alias: None
    }
  }
}

fn row_labels_of_rls_with_binds(ls: [RowLabel], tpbinds: [TPBind], rbinds: [RVBind]) : [Label] {
  match ls {
    [] -> []
    [rl, ...rest] -> match rl {
      RL(name, ts) -> [
        Label { eff: name, ty_args: map(ts, (te) => resolve_ty_with_binds(te, tpbinds, rbinds)) },
        ...row_labels_of_rls_with_binds(rest, tpbinds, rbinds)
      ]
    }
  }
}

fn fn_scheme_of_decl(d: Decl) : Option[TyScheme] {
  match d {
    DFn(_, _, tparams, params, opt_ret, rexpr, _, _, _) -> {
      # m7b #12: collect row-variable names per decl, allocate small
      # bound ids (0, 1, ...) in order of appearance, build the body
      # type with those ids in tail positions. The scheme generalises
      # over them so each call site fresh-instantiates.
      # m7b #13: same idea for declared type parameters (`fn id[T]...`).
      # tparam ids are 0..len(tparams)-1; row-var ids live in their
      # own dimension, so the two namespaces don't collide.
      # R1 fix (2026-04-26): also auto-collect lowercase TyName
      # identifiers that appear in the signature but were not
      # declared in `[T1, T2]`. Treat them as *implicit* tparams.
      # Without this, `pub fn list_contains(xs: [a], x: a) : Bool`
      # ends up with `a` as a nominal `TyCon("a", [])` and the
      # call site fails to unify with `[Int], Int`. The implicit
      # set is appended to the declared one so explicit `[a]` still
      # wins on collisions; their ids form a contiguous block.
      let names = collect_decl_rvars(d)
      let rbinds = mk_rvbinds(names)
      let implicit = collect_implicit_tparams_in_decl(d, tparams)
      let effective_tparams = list_append(tparams, implicit)
      let tpbinds = mk_tpbinds(effective_tparams)
      let pts = map(params, (p) => param_ty_with_binds(p, tpbinds, rbinds))
      let ret = match opt_ret {
        Some(rty) -> resolve_ty_with_binds(rty, tpbinds, rbinds)
        None      -> TyUnit
      }
      let body = TyFnT(pts, ret, row_of_expr_with_binds(rexpr, tpbinds, rbinds))
      # m12.5: split tparam IDs by kind so unit-vars live in their own
      # pool and get fresh-instantiated by st_instantiate_report.
      let split = tparam_id_split(effective_tparams)
      Some(scheme_uvars(split.tvars, rvbind_ids(rbinds), split.uvars, body))
    }
    _ -> None
  }
}

# R1 fix: walk a decl's signature for lowercase identifiers in type
# position, appending them in first-seen order. Skip names already
# declared in the explicit `[…]` tparam list, builtin primitive
# names (which start uppercase anyway, but defensive), and the empty
# string. Used by `fn_scheme_of_decl` and `infer_decl` to make
# implicit polymorphism work the way pre-#13 code (and the stdlib)
# already assumed.
fn collect_implicit_tparams_in_decl(d: Decl, declared: [String]) : [String] {
  match d {
    DFn(_, _, _, params, opt_ret, rexpr, _, _, _) -> {
      let acc0 = collect_implicit_in_params(params, declared, [])
      let acc1 = match opt_ret {
        Some(rty) -> collect_implicit_in_typeexpr(rty, declared, acc0)
        None      -> acc0
      }
      collect_implicit_in_row(rexpr, declared, acc1)
    }
    _ -> []
  }
}

fn collect_implicit_in_params(ps: [Param], declared: [String], acc: [String]) : [String] {
  match ps {
    [] -> acc
    [p, ...rest] -> {
      let acc1 = match p.ptype {
        Some(te) -> collect_implicit_in_typeexpr(te, declared, acc)
        None     -> acc
      }
      collect_implicit_in_params(rest, declared, acc1)
    }
  }
}

fn collect_implicit_in_typeexpr(t: TypeExpr, declared: [String], acc: [String]) : [String] {
  match t.tkind {
    TyName(name, tas) -> {
      let acc1 = collect_implicit_in_typeexprs(tas, declared, acc)
      if is_implicit_tparam_candidate(name) and not list_has(declared, name) and not list_has(acc1, name) { list_append(acc1, [name]) } else { acc1 }
    }
    TyList(inner) -> collect_implicit_in_typeexpr(inner, declared, acc)
    TyFn(ps, ret, rexpr) -> {
      let acc1 = collect_implicit_in_typeexprs(ps, declared, acc)
      let acc2 = collect_implicit_in_typeexpr(ret, declared, acc1)
      collect_implicit_in_row(rexpr, declared, acc2)
    }
    # m12.5: implicit-tparam collection for dimensioned types — recurse
    # into the base ty; unit-vars are NOT implicitly generalised, the
    # user must declare them via `[u: Unit]`.
    TyDim(base, _) -> collect_implicit_in_typeexpr(base, declared, acc)
  }
}

fn collect_implicit_in_typeexprs(ts: [TypeExpr], declared: [String], acc: [String]) : [String] {
  match ts {
    [] -> acc
    [t, ...rest] -> collect_implicit_in_typeexprs(rest, declared, collect_implicit_in_typeexpr(t, declared, acc))
  }
}

fn collect_implicit_in_row(re: RowExpr, declared: [String], acc: [String]) : [String] {
  match re {
    REmpty -> acc
    RClosed(labels) -> collect_implicit_in_row_labels(labels, declared, acc)
    ROpen(_, labels) -> collect_implicit_in_row_labels(labels, declared, acc)
  }
}

fn collect_implicit_in_row_labels(labels: [RowLabel], declared: [String], acc: [String]) : [String] {
  match labels {
    [] -> acc
    [l, ...rest] -> match l {
      RL(_, tas) -> collect_implicit_in_row_labels(rest, declared,
                       collect_implicit_in_typeexprs(tas, declared, acc))
    }
  }
}

# A name is an implicit-tparam candidate if it begins with a
# lowercase letter. Builtin primitives (Int, Real, Bool, …) all
# start uppercase, so this naturally excludes them.
fn is_implicit_tparam_candidate(name: String) : Bool {
  if string_length(name) == 0 { false }
  else { match char_at(name, 0) {
    Some(c) -> ch_is_lower(c)
    None -> false
  } }
}

fn add_decls_loop(env: TyEnv, ar_acc: [OpEffArity], ds: [Decl]) : EnvWithArities {
  match ds {
    [] -> EnvWithArities { env: env, arities: ar_acc }
    [d, ...rest] -> {
      let r = match d {
        DFn(_, fname, _, _, _, _, _, _, _) -> match fn_scheme_of_decl(d) {
          Some(sc) -> EnvWithArities { env: ty_env_add(env, fname, sc), arities: ar_acc }
          None     -> EnvWithArities { env: env, arities: ar_acc }
        }
        DType(_, _, _, _, _, _) -> EnvWithArities { env: add_variants_of_decl(env, d), arities: ar_acc }
        DEffect(_, eff_name, tparams, ops, _, _) -> {
          let r2 = add_effect_op_sigs(env, eff_name, tparams, ops)
          # m7b #2: merge per-effect arities into the running accumulator.
          EnvWithArities { env: r2.env, arities: append_op_arities(r2.arities, ar_acc) }
        }
        _ -> EnvWithArities { env: env, arities: ar_acc }
      }
      add_decls_loop(r.env, r.arities, rest)
    }
  }
}

fn append_op_arities(a: [OpEffArity], b: [OpEffArity]) : [OpEffArity] {
  match a {
    [] -> b
    [h, ...rest] -> [h, ...append_op_arities(rest, b)]
  }
}

# m7a #4a: register each effect op under the dotted key "Eff.op"
# in the type env. When synth_call sees `ECall(EField(EVar(Eff),
# op), args)`, it looks up that key and treats the call as an op
# invocation. Per-op type generics (m7b) will replace the monomorphic
# scheme with one that carries the op's own quantifiers.
type EnvWithArities = { env: TyEnv, arities: [OpEffArity] }

fn add_effect_op_sigs(env: TyEnv, eff_name: String, tparams: [String],
                       ops: [EffectOp]) : EnvWithArities {
  let binds = mk_tpbinds(tparams)
  let ids = tparam_ids(tparams)
  add_effect_op_sigs_loop(env, eff_name, binds, ids, ops, [])
}

# m7b #11 + m7b #2: register each op of `Eff[T1, T2]` under the
# dotted key `Eff.op` with a polymorphic scheme that quantifies
# over BOTH the effect's type parameters AND the op's own
# per-op tparams (`op[U](...)` from m7b #2). Op tparam ids are
# allocated from `next_id` so they never collide with effect
# tparams. Stateless effects with monomorphic ops yield the same
# monomorphic scheme as before.
fn add_effect_op_sigs_loop(env: TyEnv, eff_name: String, binds: [TPBind],
                            ids: [Int], ops: [EffectOp],
                            ar_acc: [OpEffArity]) : EnvWithArities {
  match ops {
    [] -> EnvWithArities { env: env, arities: ar_acc }
    [op, ...rest] -> match op {
      EOp(op_name, op_tparams, params, ret, _, _) -> {
        let next_id = list_length(binds)
        let op_binds = mk_tpbinds_from(op_tparams, next_id)
        let op_ids   = tparam_ids_from(op_tparams, next_id)
        let all_binds = append_tpbinds(binds, op_binds)
        let all_ids   = append_ints(ids, op_ids)
        let pts = param_tys_with_binds(params, all_binds)
        let ret_ty = resolve_ty_with_tparams(ret, all_binds)
        let body_ty = TyFnT(pts, ret_ty, row_empty())
        let sc = match all_ids {
          [] -> mono(body_ty)
          _  -> scheme(all_ids, body_ty)
        }
        let key = string_concat(eff_name, string_concat(".", op_name))
        let env1 = ty_env_add(env, key, sc)
        # Record only the effect-level arity per dotted key. The
        # synth_op_call_with_scheme caller uses this to take the
        # first N entries of `inst.fresh` as the row label's ty_args.
        let ar1 = [OEA(key, list_length(ids)), ...ar_acc]
        add_effect_op_sigs_loop(env1, eff_name, binds, ids, rest, ar1)
      }
    }
  }
}

# m7b #11 — parameter typing under tparam binds. Pattern-binding
# inside a `map`-lambda body confuses stage 1's capture analyser
# (CLAUDE.md note in dump_typed_subexprs); we use an explicit
# recursive helper instead of an inline lambda.
fn param_tys_with_binds(params: [Param], binds: [TPBind]) : [Ty] {
  match params {
    [] -> []
    [pm, ...rest] -> {
      let here = match pm.ptype {
        Some(te) -> resolve_ty_with_tparams(te, binds)
        None     -> TyAny
      }
      [here, ...param_tys_with_binds(rest, binds)]
    }
  }
}

type BuiltEnv = { env: TyEnv, prelude_len: Int, op_eff_arities: [OpEffArity] }

fn build_ty_env(decls: [Decl]) : BuiltEnv {
  let e0 = ty_env_empty()
  let e1 = add_prelude_sigs(e0)
  let e2 = add_builtin_variant_sigs(e1)
  let r = add_decls_loop(e2, [], decls)
  BuiltEnv { env: r.env, prelude_len: list_length(e2.entries),
             op_eff_arities: r.arities }
}

# ---- env dump (debugging) ----

fn scheme_to_string(sc: TyScheme) : String {
  match sc {
    Scheme(vars, rvars, uvars, ty) -> {
      let tv_part = map(vars, (n) => cat2("?t", int_to_string(n)))
      let rv_part = map(rvars, (n) => cat2("?r", int_to_string(n)))
      let uv_part = map(uvars, (n) => cat2("?u", int_to_string(n)))
      let all = list_append(tv_part, list_append(rv_part, uv_part))
      match all {
        [] -> ty_to_string(ty)
        _  -> concat_all(["forall ", join_with(all, " "), ". ", ty_to_string(ty)])
      }
    }
  }
}

fn dump_env_entry(e: TyEntry) : Unit / Console =
  print("#{e.name} : #{scheme_to_string(e.scheme)}")

fn dump_env(env: TyEnv) : Unit / Console = dump_env_loop(list_reverse(env.entries))

fn dump_env_loop(es: [TyEntry]) : Unit / Console {
  match es {
    [] -> ()
    [e, ...rest] -> { dump_env_entry(e) dump_env_loop(rest) }
  }
}

# ====================================================================
# substitution + unification (M2c)
# ====================================================================
#
# A Subst maps type-variable ids to types. It is applied to a type by
# walking structurally and replacing each TyVarT(n) whose n has a
# binding in the substitution. Unification takes two types and either
# extends a substitution so the two become equal or reports failure.
#
# The occurs check prevents infinite types: unifying `?t0` with
# `[?t0]` would otherwise loop, so we refuse.
#
# Instantiation turns a TyScheme into a Ty by replacing each bound id
# with a fresh TyVarT drawn from the environment's counter. Each call
# site of a polymorphic function gets its own fresh vars.

# The substitution is indexed directly by TyVar id, so apply_ty and
# occurs do O(1) lookups instead of walking an association list.
#
# ⚠️  Aliasing hazard. `Array[T]` is a provisional audited escape
# (see CLAUDE.md Tier 1 and docs/design.md "Memory model"): the
# mutation is not visible in the type. Every kaikai value otherwise
# pretends to be immutable, so the usual mental model —
# "Subst { slots: ... } builds a new record, the old subst is still
# valid" — is WRONG here. subst_extend mutates `s.slots` in place
# and returns a new Subst record that **aliases the same array**.
#
# The contract callers must obey:
#
#   1. Thread the substitution linearly. unify, st_set_sub,
#      mk_fresh_subst all do this already: extend it, pass it
#      forward, never look at the old value.
#   2. **Never fork** a Subst between two alternative trials and
#      compare results. Both trials will see each other's mutations
#      and the inference will silently corrupt. If you ever need
#      speculative unification (e.g. for typeclass resolution or
#      intersection types), this representation must change first.
#   3. Do not publish a Subst outside the inferencer's control flow
#      (no storing in long-lived records, no returning via Option,
#      no capturing in a closure that outlives the caller).
#
# When the `Mutable` effect lands, `array_set` should require it,
# and these informal rules become a type-level obligation.
type Subst = {
  slots:     Array[Option[Ty]],
  row_slots: Array[Option[Row]],
  row_fresh: Int,
  # m12.5: parallel slot table for unit unification variables (UVar).
  # Same opaque-mutable Array discipline as `slots`; never publish
  # outside the inferencer.
  unit_slots: Array[Option[UnitExprT]],
  unit_fresh: Int
}

fn subst_empty() : Subst = Subst {
  slots:     array_make(64, None),
  row_slots: array_make(16, None),
  row_fresh: 0,
  unit_slots: array_make(16, None),
  unit_fresh: 0
}

fn subst_lookup(s: Subst, v: Int) : Option[Ty] {
  if v >= array_length(s.slots) { None }
  else { array_get(s.slots, v) }
}

fn subst_extend(s: Subst, v: Int, ty: Ty) : Subst {
  let len = array_length(s.slots)
  let slots1 = if v >= len {
    let grown = if v + 1 > len * 2 { v + 1 } else { len * 2 }
    array_grow(s.slots, grown, None)
  } else { s.slots }
  let slots2 = array_set(slots1, v, Some(ty))
  Subst { slots: slots2, row_slots: s.row_slots, row_fresh: s.row_fresh,
          unit_slots: s.unit_slots, unit_fresh: s.unit_fresh }
}

# Row-var substitution (parallel to subst_lookup / subst_extend, but
# indexed into row_slots). m7a #2 introduces the shape; row vars are
# only created during unify_row, never elsewhere.

fn subst_row_lookup(s: Subst, v: Int) : Option[Row] {
  if v >= array_length(s.row_slots) { None }
  else { array_get(s.row_slots, v) }
}

fn subst_row_extend(s: Subst, v: Int, r: Row) : Subst {
  let len = array_length(s.row_slots)
  let rs1 = if v >= len {
    let grown = if v + 1 > len * 2 { v + 1 } else { len * 2 }
    array_grow(s.row_slots, grown, None)
  } else { s.row_slots }
  let rs2 = array_set(rs1, v, Some(r))
  Subst { slots: s.slots, row_slots: rs2, row_fresh: s.row_fresh,
          unit_slots: s.unit_slots, unit_fresh: s.unit_fresh }
}

# Allocate a fresh row variable id and bump the counter. Returned in
# a record because kaikai stage 2 has no tuples.
type FreshRow = { id: Int, subst: Subst }

fn subst_fresh_row(s: Subst) : FreshRow {
  let id = s.row_fresh
  let s1 = Subst { slots: s.slots, row_slots: s.row_slots, row_fresh: id + 1,
                   unit_slots: s.unit_slots, unit_fresh: s.unit_fresh }
  FreshRow { id: id, subst: s1 }
}

# m12.5: unit-var substitution. UVar(n) into the parallel `unit_slots`
# array. Same growth/lookup discipline as the type-var slots.
fn subst_unit_lookup(s: Subst, v: Int) : Option[UnitExprT] {
  if v >= array_length(s.unit_slots) { None }
  else { array_get(s.unit_slots, v) }
}

fn subst_unit_extend(s: Subst, v: Int, u: UnitExprT) : Subst {
  let len = array_length(s.unit_slots)
  let us1 = if v >= len {
    let grown = if v + 1 > len * 2 { v + 1 } else { len * 2 }
    array_grow(s.unit_slots, grown, None)
  } else { s.unit_slots }
  let us2 = array_set(us1, v, Some(u))
  Subst { slots: s.slots, row_slots: s.row_slots, row_fresh: s.row_fresh,
          unit_slots: us2, unit_fresh: s.unit_fresh }
}

type FreshUnit = { id: Int, subst: Subst }

fn subst_fresh_unit(s: Subst) : FreshUnit {
  let id = s.unit_fresh
  let s1 = Subst { slots: s.slots, row_slots: s.row_slots, row_fresh: s.row_fresh,
                   unit_slots: s.unit_slots, unit_fresh: id + 1 }
  FreshUnit { id: id, subst: s1 }
}

# ====================================================================
# m12.5 — unit-of-measure operations
# ====================================================================
#
# Three layers of operations on UnitExprT:
#   1. unit_to_table / unit_from_table — convert between the AST tree
#      shape and a canonical (sym, exponent) / (uvar, exponent) table.
#   2. unit_canon — normal form: alphabetically-sorted symbols, grouped
#      exponents, no factor-of-1 noise.
#   3. unify_unit — abelian-group unification (Stuckey/Kennedy): solve
#      `u1 = u2` by reducing `u1 * u2^-1 = 1` to a substitution.
#
# Aliases (`unit Newton = kg * m / sec^2`) are expanded by the *resolver*
# before they reach unification; canonicalisation never sees them.

# Sym and unit-var entries of the canonical table. Both use a sorted
# (key, exponent) representation; zero exponents are dropped.
type USymEntry = USE(String, Int)
type UVarEntry = UVE(Int, Int)

type UTable = { syms: [USymEntry], vars: [UVarEntry] }

fn utable_empty() : UTable = UTable { syms: [], vars: [] }

# True iff the table represents the dimensionless unit "1".
fn utable_is_one(t: UTable) : Bool {
  match t.syms { [] -> match t.vars { [] -> true _ -> false } _ -> false }
}

# Insert a `(sym, exp)` contribution; merges with an existing entry by
# adding exponents; drops entries that reach 0; keeps the list sorted
# alphabetically.
fn usym_insert(xs: [USymEntry], k: String, n: Int) : [USymEntry] {
  match xs {
    [] -> if n == 0 { [] } else { [USE(k, n)] }
    [h, ...rest] -> match h {
      USE(hk, hn) ->
        if hk == k {
          let m = hn + n
          if m == 0 { rest } else { [USE(hk, m), ...rest] }
        } else if string_lt(k, hk) {
          if n == 0 { [h, ...rest] } else { [USE(k, n), h, ...rest] }
        } else {
          [h, ...usym_insert(rest, k, n)]
        }
    }
  }
}

fn uvar_insert(xs: [UVarEntry], k: Int, n: Int) : [UVarEntry] {
  match xs {
    [] -> if n == 0 { [] } else { [UVE(k, n)] }
    [h, ...rest] -> match h {
      UVE(hk, hn) ->
        if hk == k {
          let m = hn + n
          if m == 0 { rest } else { [UVE(hk, m), ...rest] }
        } else if k < hk {
          if n == 0 { [h, ...rest] } else { [UVE(k, n), h, ...rest] }
        } else {
          [h, ...uvar_insert(rest, k, n)]
        }
    }
  }
}

# Lexicographic less-than for ASCII strings. The lexer guarantees
# unit symbols are plain identifiers, so this is a complete order.
fn string_lt(a: String, b: String) : Bool = string_lt_loop(a, b, 0)

fn string_lt_loop(a: String, b: String, i: Int) : Bool {
  let alen = string_length(a)
  let blen = string_length(b)
  if i >= alen { i < blen }
  else if i >= blen { false }
  else {
    match char_at(a, i) {
      Some(ca) -> match char_at(b, i) {
        Some(cb) ->
          if ca == cb { string_lt_loop(a, b, i + 1) }
          else { char_to_int(ca) < char_to_int(cb) }
        None -> false
      }
      None -> false
    }
  }
}

# Walk a UnitExprT, accumulating contributions into the table. The
# `mul` parameter scales every leaf's exponent; flips sign for UInv
# and multiplies by n for UPow.
fn unit_to_table_at(u: UnitExprT, scale: Int, t: UTable) : UTable {
  match u {
    UOne -> t
    USym(s) -> UTable { syms: usym_insert(t.syms, s, scale), vars: t.vars }
    UVar(v) -> UTable { syms: t.syms, vars: uvar_insert(t.vars, v, scale) }
    UMul(a, b) -> unit_to_table_at(b, scale, unit_to_table_at(a, scale, t))
    UInv(a) -> unit_to_table_at(a, 0 - scale, t)
    UPow(a, n) -> unit_to_table_at(a, scale * n, t)
  }
}

fn unit_to_table(u: UnitExprT) : UTable = unit_to_table_at(u, 1, utable_empty())

# m12.5: parallel walker that *also* chases UVar bindings through the
# substitution. `seen` keeps the recursion linear by short-circuiting
# any cycle (occurs check is the real guard; this is just defence).
fn unit_resolve_to_at(u: UnitExprT, scale: Int, t: UTable, s: Subst, seen: [Int]) : UTable {
  match u {
    UOne -> t
    USym(sm) -> UTable { syms: usym_insert(t.syms, sm, scale), vars: t.vars }
    UVar(v) -> {
      if list_has_int(seen, v) {
        UTable { syms: t.syms, vars: uvar_insert(t.vars, v, scale) }
      } else {
        match subst_unit_lookup(s, v) {
          Some(u_sub) -> unit_resolve_to_at(u_sub, scale, t, s, [v, ...seen])
          None -> UTable { syms: t.syms, vars: uvar_insert(t.vars, v, scale) }
        }
      }
    }
    UMul(a, b) -> unit_resolve_to_at(b, scale, unit_resolve_to_at(a, scale, t, s, seen), s, seen)
    UInv(a) -> unit_resolve_to_at(a, 0 - scale, t, s, seen)
    UPow(a, n) -> unit_resolve_to_at(a, scale * n, t, s, seen)
  }
}

# Rebuild a UnitExprT from a canonical table. The table is already
# sorted, so we walk left-to-right and chain UMul; positive exponents
# render as USym/UVar (or UPow when |n|>1), negative as UInv-of-pow.
fn utable_to_tree(t: UTable) : UnitExprT {
  let factors_syms = sym_entries_to_factors(t.syms)
  let factors_vars = var_entries_to_factors(t.vars)
  let all_factors = list_append(factors_syms, factors_vars)
  match all_factors {
    [] -> UOne
    [h, ...rest] -> tree_chain(h, rest)
  }
}

# m12.5: helpers to convert table entries into UnitExprT factors.
# Standalone (rather than inline lambdas) because stage 1's lambda
# free-var analysis predates m7b #18 and would over-capture the
# pattern binders here.
fn sym_entries_to_factors(xs: [USymEntry]) : [UnitExprT] {
  match xs {
    [] -> []
    [h, ...rest] -> match h {
      USE(k, n) -> [sym_factor(k, n), ...sym_entries_to_factors(rest)]
    }
  }
}

fn var_entries_to_factors(xs: [UVarEntry]) : [UnitExprT] {
  match xs {
    [] -> []
    [h, ...rest] -> match h {
      UVE(k, n) -> [var_factor(k, n), ...var_entries_to_factors(rest)]
    }
  }
}

fn sym_factor(k: String, n: Int) : UnitExprT {
  if n == 1 { USym(k) }
  else if n == 0 - 1 { UInv(USym(k)) }
  else if n > 0 { UPow(USym(k), n) }
  else { UInv(UPow(USym(k), 0 - n)) }
}

fn var_factor(k: Int, n: Int) : UnitExprT {
  if n == 1 { UVar(k) }
  else if n == 0 - 1 { UInv(UVar(k)) }
  else if n > 0 { UPow(UVar(k), n) }
  else { UInv(UPow(UVar(k), 0 - n)) }
}

fn tree_chain(acc: UnitExprT, rest: [UnitExprT]) : UnitExprT {
  match rest {
    [] -> acc
    [h, ...tl] -> tree_chain(UMul(acc, h), tl)
  }
}

# Public canonicaliser. Aliases are *not* expanded here; that's the
# resolver's job (resolve_ty_with_units below).
fn unit_canon(u: UnitExprT) : UnitExprT = utable_to_tree(unit_to_table(u))

fn unit_is_one(u: UnitExprT) : Bool = utable_is_one(unit_to_table(u))

# Apply the unit substitution to a UnitExprT: each UVar(n) is chased
# through unit_slots to its current binding (if any), and the resolved
# tree is canonicalised. This is the unit-side analogue of apply_ty
# and must be called before any structural decision about a unit.
fn apply_unit(s: Subst, u: UnitExprT) : UnitExprT {
  let tab = unit_to_table_resolved(u, s)
  utable_to_tree(tab)
}

# Walk the unit, chasing UVar bindings through `s.unit_slots`. The
# Bool guard prevents cycles by remembering which uvars we've already
# expanded on the current path; a cycle indicates a bug elsewhere
# (occurs check should have caught it) and we treat it as identity.
fn unit_to_table_resolved(u: UnitExprT, s: Subst) : UTable =
  unit_resolve_to_at(u, 1, utable_empty(), s, [])

# Subtract `b` from `a` (i.e. compute `a / b` as exponent vector). The
# result is `a * b^-1` in canonical form.
fn utable_diff(a: UTable, b: UTable) : UTable {
  let s1 = utable_diff_syms(a.syms, b.syms)
  let v1 = utable_diff_vars(a.vars, b.vars)
  UTable { syms: s1, vars: v1 }
}

fn utable_diff_syms(a: [USymEntry], b: [USymEntry]) : [USymEntry] {
  match b {
    [] -> a
    [h, ...rest] -> match h {
      USE(k, n) -> utable_diff_syms(usym_insert(a, k, 0 - n), rest)
    }
  }
}

fn utable_diff_vars(a: [UVarEntry], b: [UVarEntry]) : [UVarEntry] {
  match b {
    [] -> a
    [h, ...rest] -> match h {
      UVE(k, n) -> utable_diff_vars(uvar_insert(a, k, 0 - n), rest)
    }
  }
}

# Pick the unit-var with the smallest |exponent| in the table; returns
# (index_in_vars, var_id, exponent). None if `vars` is empty.
type UPickVar = { id: Int, exp: Int }

fn utable_pick_min_var(t: UTable) : Option[UPickVar] {
  match t.vars {
    [] -> None
    [h, ...rest] -> match h {
      UVE(id, e) -> Some(utable_pick_min_var_pick(rest, UPickVar { id: id, exp: e }))
    }
  }
}

fn utable_pick_min_var_pick(rest: [UVarEntry], best: UPickVar) : UPickVar {
  match rest {
    [] -> best
    [h, ...tl] -> match h {
      UVE(id, e) -> {
        let abs_e = abs_int(e)
        let abs_b = abs_int(best.exp)
        if abs_e < abs_b { utable_pick_min_var_pick(tl, UPickVar { id: id, exp: e }) }
        else { utable_pick_min_var_pick(tl, best) }
      }
    }
  }
}

# Remove a single (var, exp) entry by its id from the table, returning
# the table without that var.
fn utable_drop_var(t: UTable, target: Int) : UTable {
  UTable { syms: t.syms, vars: utable_drop_var_loop(t.vars, target) }
}

fn utable_drop_var_loop(xs: [UVarEntry], target: Int) : [UVarEntry] {
  match xs {
    [] -> []
    [h, ...rest] -> match h {
      UVE(k, _) -> if k == target { rest } else { [h, ...utable_drop_var_loop(rest, target)] }
    }
  }
}

# True iff every entry's exponent is a multiple of `k`. Used by the
# unit unifier to decide whether the chosen pivot var divides cleanly.
fn utable_all_divisible(t: UTable, k: Int) : Bool =
  syms_divisible(t.syms, k) and vars_divisible(t.vars, k)

fn syms_divisible(xs: [USymEntry], k: Int) : Bool {
  match xs {
    [] -> true
    [h, ...rest] -> match h {
      USE(_, n) -> if (n - (n / k) * k) == 0 { syms_divisible(rest, k) } else { false }
    }
  }
}

fn vars_divisible(xs: [UVarEntry], k: Int) : Bool {
  match xs {
    [] -> true
    [h, ...rest] -> match h {
      UVE(_, n) -> if (n - (n / k) * k) == 0 { vars_divisible(rest, k) } else { false }
    }
  }
}

# Negate every exponent and divide by k (caller guarantees k | every
# entry). Used to construct the substitution `var := -(rest)/k`.
fn utable_negdiv(t: UTable, k: Int) : UTable {
  UTable {
    syms: usym_negdiv(t.syms, k),
    vars: uvar_negdiv(t.vars, k)
  }
}

fn usym_negdiv(xs: [USymEntry], k: Int) : [USymEntry] {
  match xs {
    [] -> []
    [h, ...rest] -> match h {
      USE(s, n) -> [USE(s, (0 - n) / k), ...usym_negdiv(rest, k)]
    }
  }
}

fn uvar_negdiv(xs: [UVarEntry], k: Int) : [UVarEntry] {
  match xs {
    [] -> []
    [h, ...rest] -> match h {
      UVE(v, n) -> [UVE(v, (0 - n) / k), ...uvar_negdiv(rest, k)]
    }
  }
}

# Occurs check: does unit-var `v` appear (after substitution chase) in
# `u`? Refuses self-binding to keep apply_unit terminating.
fn occurs_unit(v: Int, u: UnitExprT, s: Subst) : Bool {
  let tab = unit_to_table_resolved(u, s)
  occurs_unit_in_vars(v, tab.vars)
}

fn occurs_unit_in_vars(v: Int, xs: [UVarEntry]) : Bool {
  match xs {
    [] -> false
    [h, ...rest] -> match h {
      UVE(k, _) -> if k == v { true } else { occurs_unit_in_vars(v, rest) }
    }
  }
}

# Unify two unit expressions under `s`. The classic equational view:
# `u1 ≡ u2` iff `u1 * u2^-1 ≡ 1`. We solve the homogeneous form by
# repeatedly picking the unit-var with the smallest |exponent| and
# isolating it. Polynomial in the size of the input — Kennedy 1996.
#
# Stop guard: this function only ever recurses through utable bookkeeping
# and a single substitution + retry. If the lane ever needs to introduce
# a real Smith-normal-form pass, that is a sign the design is being
# pushed past the docs/units-of-measure.md "polynomial" promise — call
# it out before extending.
fn unify_unit(u1: UnitExprT, u2: UnitExprT, s: Subst) : Option[Subst] {
  let t1 = unit_to_table_resolved(u1, s)
  let t2 = unit_to_table_resolved(u2, s)
  let diff = utable_diff(t1, t2)
  unify_unit_diff(diff, s)
}

fn unify_unit_diff(t: UTable, s: Subst) : Option[Subst] {
  if utable_is_one(t) { Some(s) }
  else {
    match utable_pick_min_var(t) {
      None -> None                                 # only syms left, but non-zero — fail
      Some(pick) -> {
        let rest = utable_drop_var(t, pick.id)
        let k = pick.exp
        if utable_all_divisible(rest, k) {
          # Bind `pick.id := (-rest) / k`. occurs check guards against
          # self-cycle (would be unusual since we removed the var).
          let bound = utable_to_tree(utable_negdiv(rest, k))
          if occurs_unit(pick.id, bound, s) { None }
          else { Some(subst_unit_extend(s, pick.id, bound)) }
        } else {
          # Pivot does not cleanly divide the remainder. The classical
          # Kennedy/Stuckey fix introduces a fresh unit-var w and
          # rewrites `pick := w * (low/k)` so the residual equation
          # uses smaller exponents. The lane fixtures don't exercise
          # this path (every case the lane ships pivots with |k|=1).
          # Refuse here so the failure is loud rather than silent —
          # see docs/units-of-measure.md §Risks "polynomial" guarantee.
          None
        }
      }
    }
  }
}

# Apply the substitution to a type. Recurses structurally; resolves
# `TyVarT(n)` via subst_lookup, then recurses on the replacement so a
# chained binding `?t0 -> ?t1 -> Int` collapses to `Int`.
fn apply_ty(s: Subst, t: Ty) : Ty {
  match t {
    TyInt    -> t
    TyReal   -> t
    TyBool   -> t
    TyString -> t
    TyChar   -> t
    TyUnit   -> t
    TyAny    -> t
    TyVarT(n) -> match subst_lookup(s, n) {
      Some(t2) -> apply_ty(s, t2)
      None     -> t
    }
    TyListT(inner) -> TyListT(apply_ty(s, inner))
    TyFnT(params, ret, row) -> TyFnT(apply_tys(s, params), apply_ty(s, ret), apply_row(s, row))
    TyCon(name, atys) -> TyCon(name, apply_tys(s, atys))
    # m12.5: applying a substitution to a dimensioned type recurses into
    # both the base type and the unit expression. Unit-vars chase
    # through unit_slots; everything else passes through unchanged.
    TyDimT(base, u) -> dim_collapse(apply_ty(s, base), apply_unit(s, u))
  }
}

# m12.5: collapse `TyDimT(TyDimT(b, u1), u2)` to `TyDimT(b, u1*u2)` and
# strip a `TyDimT(_, UOne)` down to its base. Both shapes can arise
# transiently when chasing unit-vars through nested dimensioned types.
fn dim_collapse(base: Ty, u: UnitExprT) : Ty {
  match base {
    TyDimT(inner, u_inner) -> dim_collapse(inner, unit_canon(UMul(u_inner, u)))
    _ -> {
      let uc = unit_canon(u)
      if unit_is_one(uc) { base } else { TyDimT(base, uc) }
    }
  }
}

fn apply_tys(s: Subst, ts: [Ty]) : [Ty] {
  match ts {
    [] -> []
    [t, ...rest] -> [apply_ty(s, t), ...apply_tys(s, rest)]
  }
}

# ---- row substitution + unification (m7a #2) -----------------------
#
# Rémy-style row unification, per docs/effects-impl.md §*Types: row
# slot on TyFnT* and Doc A §*Row unification*. In m7a #2 every row at
# every TyFnT site is `row_empty()`, so the unification path
# exercises the trivial empty/empty case. The full algorithm is
# wired in here so m7a #3 onward (where rows actually carry labels
# and tail variables) just feeds it real data.
#
# Canonicality (sorted/dedup labels) is the caller's responsibility.
# m7a #2 only ever receives empty label lists, so we do not enforce
# the invariant here; m7a #3 will revisit when labels start flowing.

fn label_concat(a: [Label], b: [Label]) : [Label] {
  match a {
    [] -> b
    [h, ...rest] -> [h, ...label_concat(rest, b)]
  }
}

fn apply_label_args(s: Subst, l: Label) : Label =
  Label { eff: l.eff, ty_args: apply_tys(s, l.ty_args) }

fn apply_labels(s: Subst, ls: [Label]) : [Label] {
  match ls {
    [] -> []
    [h, ...rest] -> [apply_label_args(s, h), ...apply_labels(s, rest)]
  }
}

# Resolve a row under the current substitution: apply_ty to each
# label payload, and chase the tail var if it's bound.
fn apply_row(s: Subst, r: Row) : Row {
  let labels1 = apply_labels(s, r.labels)
  match r.tail {
    None -> Row { labels: labels1, tail: None, display_alias: r.display_alias }
    Some(v) -> match subst_row_lookup(s, v) {
      None -> Row { labels: labels1, tail: Some(v), display_alias: r.display_alias }
      Some(r2) -> {
        let r2r = apply_row(s, r2)
        Row {
          labels: label_concat(labels1, r2r.labels),
          tail: r2r.tail,
          display_alias: r.display_alias
        }
      }
    }
  }
}

# Does row variable `v` appear in row `r` after applying the current
# substitution? Standard occurs check, restricted to the tail (row
# vars cannot appear inside a label's ty_args).
fn occurs_row(v: Int, r: Row, s: Subst) : Bool {
  let r1 = apply_row(s, r)
  match r1.tail {
    None -> false
    Some(w) -> v == w
  }
}

# Partition two label lists into (both-pairs, only-left, only-right).
# O(n*m); fine for rows of expected size <10.

type LabelPair = LPair(Label, Label)

type LabelPartition = {
  both_pairs: [LabelPair],
  only_left:  [Label],
  only_right: [Label]
}

# Find the first label in `ls` whose eff matches; return the label
# plus the list with it removed (preserving relative order).
type FindRemove = { found: Label, remain: [Label] }

fn find_remove_label(eff: String, ls: [Label]) : Option[FindRemove] {
  find_remove_label_loop(eff, ls, [])
}

fn find_remove_label_loop(eff: String, ls: [Label], seen: [Label]) : Option[FindRemove] {
  match ls {
    [] -> None
    [h, ...rest] -> {
      if h.eff == eff {
        Some(FindRemove { found: h, remain: label_concat(seen, rest) })
      } else {
        find_remove_label_loop(eff, rest, label_concat(seen, [h]))
      }
    }
  }
}

fn partition_labels(a: [Label], b: [Label]) : LabelPartition =
  partition_walk(a, b, [], [])

fn partition_walk(a: [Label], b_remain: [Label],
                  bp: [LabelPair], ol: [Label]) : LabelPartition {
  match a {
    [] -> LabelPartition { both_pairs: bp, only_left: ol, only_right: b_remain }
    [ah, ...arest] -> match find_remove_label(ah.eff, b_remain) {
      None -> partition_walk(arest, b_remain, bp, [ah, ...ol])
      Some(fr) -> partition_walk(arest, fr.remain, [LPair(ah, fr.found), ...bp], ol)
    }
  }
}

# Unify the ty_args of every (left, right) pair where the labels share
# an effect symbol.
fn unify_label_pairs(pairs: [LabelPair], s: Subst) : Option[Subst] {
  match pairs {
    [] -> Some(s)
    [LPair(la, lb), ...rest] -> match unify_list(la.ty_args, lb.ty_args, s) {
      None -> None
      Some(s1) -> unify_label_pairs(rest, s1)
    }
  }
}

# True iff the label list is empty.
fn labels_empty(ls: [Label]) : Bool {
  match ls { [] -> true _ -> false }
}

# Bind the two row tails per Doc A §*Row unification* steps 2–3.
# - Both rigid: the only-left and only-right lists must be empty.
# - One rigid, one flex: bind the flex tail to a row containing the
#   other side's "only" labels and a None tail (since the rigid side
#   admitted nothing extra). The "only" list of the rigid side must
#   be empty.
# - Both flex: introduce a fresh tail variable τ and bind each side
#   to a row carrying the *other* side's "only" labels plus τ.
fn bind_row_tails(at: Option[Int], bt: Option[Int],
                  oleft: [Label], oright: [Label],
                  s: Subst) : Option[Subst] {
  match at {
    None -> match bt {
      None -> if labels_empty(oleft) and labels_empty(oright) { Some(s) } else { None }
      Some(b_id) -> {
        if not labels_empty(oright) { None }
        else {
          let r = Row { labels: oleft, tail: None, display_alias: None }
          if occurs_row(b_id, r, s) { None }
          else { Some(subst_row_extend(s, b_id, r)) }
        }
      }
    }
    Some(a_id) -> match bt {
      None -> {
        if not labels_empty(oleft) { None }
        else {
          let r = Row { labels: oright, tail: None, display_alias: None }
          if occurs_row(a_id, r, s) { None }
          else { Some(subst_row_extend(s, a_id, r)) }
        }
      }
      Some(b_id) -> {
        if a_id == b_id and labels_empty(oleft) and labels_empty(oright) { Some(s) }
        else {
          let fr = subst_fresh_row(s)
          let s1 = fr.subst
          let r_for_a = Row { labels: oright, tail: Some(fr.id), display_alias: None }
          let r_for_b = Row { labels: oleft,  tail: Some(fr.id), display_alias: None }
          if occurs_row(a_id, r_for_a, s1) { None }
          else {
            let s2 = subst_row_extend(s1, a_id, r_for_a)
            if occurs_row(b_id, r_for_b, s2) { None }
            else { Some(subst_row_extend(s2, b_id, r_for_b)) }
          }
        }
      }
    }
  }
}

# Unify two effect rows. Returns the extended substitution or None.
fn unify_row(r1: Row, r2: Row, s: Subst) : Option[Subst] {
  let a = apply_row(s, r1)
  let b = apply_row(s, r2)
  let p = partition_labels(a.labels, b.labels)
  match unify_label_pairs(p.both_pairs, s) {
    None -> None
    Some(s1) -> bind_row_tails(a.tail, b.tail, p.only_left, p.only_right, s1)
  }
}

# Does TyVarT(v) appear inside `ty` after applying the substitution?
# Used as the occurs check in unify.
fn occurs_any(v: Int, ts: [Ty], s: Subst) : Bool {
  match ts {
    [] -> false
    [t, ...rest] -> if occurs(v, t, s) { true } else { occurs_any(v, rest, s) }
  }
}

fn occurs(v: Int, t: Ty, s: Subst) : Bool {
  let t1 = apply_ty(s, t)
  match t1 {
    TyVarT(n) -> n == v
    TyListT(inner) -> occurs(v, inner, s)
    TyFnT(params, ret, _) -> occurs_any(v, [ret, ...params], s)
    TyCon(_, atys) -> occurs_any(v, atys, s)
    # m12.5: TyDimT carries a base Ty to recurse into; the unit side
    # has its own occurs_unit guard inside unify_unit.
    TyDimT(base, _) -> occurs(v, base, s)
    _ -> false
  }
}

# Unify two types under substitution `s`. Returns Some(s') with the
# extended substitution, or None on failure. The caller is responsible
# for reporting the mismatch at the right source position.
#
# TyAny is the "unresolved" placeholder the walker emits when it cannot
# determine a type (unknown record field, opaque lookup). It must match
# *anything* without entering the substitution: if TyAny leaked into
# `sub`, it would pollute unrelated TyVars through later lookups and
# turn clean `[?t1]` inferences into `[?]` noise. So short-circuit it
# at the top of unify, before the var-binding branches.
fn unify(t1: Ty, t2: Ty, s: Subst) : Option[Subst] {
  let a = apply_ty(s, t1)
  let b = apply_ty(s, t2)
  match a {
    TyAny -> Some(s)
    _ -> match b {
      TyAny -> Some(s)
      _ -> match a {
        TyVarT(n) -> match b {
          TyVarT(m) -> if n == m { Some(s) } else { Some(subst_extend(s, n, b)) }
          _ -> if occurs(n, b, s) { None } else { Some(subst_extend(s, n, b)) }
        }
        _ -> match b {
          TyVarT(m) -> if occurs(m, a, s) { None } else { Some(subst_extend(s, m, a)) }
          _ -> unify_heads(a, b, s)
        }
      }
    }
  }
}

# Neither side is a var: must match head-symbol + structure.
fn unify_list(xs: [Ty], ys: [Ty], s: Subst) : Option[Subst] {
  match xs {
    [] -> match ys { [] -> Some(s) _ -> None }
    [x, ...xr] -> match ys {
      [] -> None
      [y, ...yr] -> match unify(x, y, s) {
        None -> None
        Some(s1) -> unify_list(xr, yr, s1)
      }
    }
  }
}

fn unify_heads(a: Ty, b: Ty, s: Subst) : Option[Subst] {
  match a {
    # m12.5: bare numerics on the LHS treat the RHS dim case specially
    # — `Real` ≡ `Real<1>`. Any other unit is a mismatch (`Real` vs
    # `Real<USD>` is rejected per spec §6).
    TyInt    -> match b {
      TyInt    -> Some(s)
      TyDimT(bb, bu) -> match bb { TyInt -> unify_unit(UOne, bu, s) _ -> None }
      _ -> None
    }
    TyReal   -> match b {
      TyReal   -> Some(s)
      TyDimT(bb, bu) -> match bb { TyReal -> unify_unit(UOne, bu, s) _ -> None }
      _ -> None
    }
    TyBool   -> match b { TyBool   -> Some(s) _ -> None }
    TyString -> match b { TyString -> Some(s) _ -> None }
    TyChar   -> match b { TyChar   -> Some(s) _ -> None }
    TyUnit   -> match b { TyUnit   -> Some(s) _ -> None }
    # TyAny unifies with anything until typed holes and error reporting
    # land; it's the "I don't know yet" placeholder.
    TyAny    -> Some(s)
    TyListT(a1) -> match b {
      TyListT(b1) -> unify(a1, b1, s)
      _ -> None
    }
    TyFnT(ap, ar, arow) -> match b {
      TyFnT(bp, br, brow) -> match unify_list(ap, bp, s) {
        None -> None
        Some(s1) -> match unify(ar, br, s1) {
          None -> None
          Some(s2) -> unify_row(arow, brow, s2)
        }
      }
      _ -> None
    }
    TyCon(an, aa) -> match b {
      TyCon(bn, ba) -> if an == bn { unify_list(aa, ba, s) } else { None }
      _ -> None
    }
    TyVarT(_) -> None                                  # handled in unify
    # m12.5: TyDimT vs TyDimT — unify base then unit. TyDimT vs bare
    # primitive uses the `Real ≡ Real<1>` rule above (the bare-side
    # arms catch this via the dim-aware match arms).
    TyDimT(ab, au) -> match b {
      TyDimT(bb, bu) -> match unify(ab, bb, s) {
        None -> None
        Some(s1) -> unify_unit(au, bu, s1)
      }
      TyInt    -> match ab { TyInt -> unify_unit(au, UOne, s) _ -> None }
      TyReal   -> match ab { TyReal -> unify_unit(au, UOne, s) _ -> None }
      _ -> None
    }
  }
}

# ---- instantiation ----
#
# Turn a TyScheme into (fresh Ty, updated env). Each bound var in the
# scheme is replaced by a freshly-generated TyVarT; everywhere the
# bound id appears inside the scheme body, we substitute the fresh
# id. The env's `fresh` counter advances by one per bound var.

fn fresh_var(env: TyEnv) : TyEnv =
  TyEnv { entries: env.entries, fresh: env.fresh + 1 }

fn advance_fresh(env: TyEnv, n: Int) : TyEnv =
  if n <= 0 { env } else { advance_fresh(fresh_var(env), n - 1) }

fn mk_fresh_subst_loop(vars: [Int], start: Int, s: Subst) : Subst {
  match vars {
    [] -> s
    [v, ...rest] -> mk_fresh_subst_loop(rest, start + 1, subst_extend(s, v, TyVarT(start)))
  }
}

fn mk_fresh_subst(vars: [Int], start: Int) : Subst =
  mk_fresh_subst_loop(vars, start, subst_empty())

# Turn a TyScheme into a pair `(env-with-advanced-counter, ty)` where
# every bound var in the scheme has been replaced by a fresh TyVarT
# drawn from the counter.
type Instantiated = { env: TyEnv, ty: Ty }

fn max_id_loop(vs: [Int], acc: Int) : Int {
  match vs {
    [] -> acc
    [v, ...rest] -> max_id_loop(rest, if v > acc { v } else { acc })
  }
}

# `start` must exceed every bound-var id in `vars`, otherwise the
# substitution would map a bound id to itself (e.g. `SB(0, TyVarT(0))`
# when env.fresh=0 and vars=[0]) and apply_ty would loop forever. By
# clamping up to `max(vars) + 1`, fresh vars never alias any bound id.
fn instantiate(env: TyEnv, sc: TyScheme) : Instantiated {
  match sc {
    Scheme(vars, _, _, body) -> {
      let n = list_length(vars)
      let need = if n == 0 { 0 } else { max_id_loop(vars, 0) + 1 }
      let start = if env.fresh >= need { env.fresh } else { need }
      let env1 = TyEnv { entries: env.entries, fresh: start + n }
      let sub = mk_fresh_subst(vars, start)
      Instantiated { env: env1, ty: apply_ty(sub, body) }
    }
  }
}

# Build a temporary substitution that maps each bound row-var id in
# `rvars` to a fresh row-variable id allocated from `s.row_fresh`.
# Returns the temp substitution (only used to rewrite the scheme body)
# and the updated subst with the fresh counter advanced.
type FreshRowSubst = { temp: Subst, sub: Subst }

fn mk_fresh_row_subst_loop(rvars: [Int], temp: Subst, s: Subst) : FreshRowSubst {
  match rvars {
    [] -> FreshRowSubst { temp: temp, sub: s }
    [v, ...rest] -> {
      let fr = subst_fresh_row(s)
      let r = Row { labels: [], tail: Some(fr.id), display_alias: None }
      let temp1 = subst_row_extend(temp, v, r)
      mk_fresh_row_subst_loop(rest, temp1, fr.subst)
    }
  }
}

fn mk_fresh_row_subst(rvars: [Int], s: Subst) : FreshRowSubst {
  # Fresh ids must be drawn from a counter strictly greater than any
  # bound id in `rvars`; otherwise the temp substitution might map a
  # bound id `v` to a Row whose tail is `v` (when v == row_fresh) and
  # apply_row would loop forever.
  let need = if rvars == [] { 0 } else { max_id_loop(rvars, 0) + 1 }
  let s_seed = if s.row_fresh >= need { s }
               else { Subst { slots: s.slots, row_slots: s.row_slots,
                              row_fresh: need,
                              unit_slots: s.unit_slots, unit_fresh: s.unit_fresh } }
  mk_fresh_row_subst_loop(rvars, subst_empty(), s_seed)
}

# m12.5: parallel to mk_fresh_row_subst — but for unit-vars. Allocates a
# fresh UVar per bound unit-var id and binds it via subst_unit_extend.
type FreshUnitSubst = { temp: Subst, sub: Subst }

fn mk_fresh_unit_subst_loop(uvars: [Int], temp: Subst, s: Subst) : FreshUnitSubst {
  match uvars {
    [] -> FreshUnitSubst { temp: temp, sub: s }
    [v, ...rest] -> {
      let fr = subst_fresh_unit(s)
      let temp1 = subst_unit_extend(temp, v, UVar(fr.id))
      mk_fresh_unit_subst_loop(rest, temp1, fr.subst)
    }
  }
}

fn mk_fresh_unit_subst(uvars: [Int], s: Subst) : FreshUnitSubst {
  let need = if uvars == [] { 0 } else { max_id_loop(uvars, 0) + 1 }
  let s_seed = if s.unit_fresh >= need { s }
               else { Subst { slots: s.slots, row_slots: s.row_slots,
                              row_fresh: s.row_fresh,
                              unit_slots: s.unit_slots, unit_fresh: need } }
  mk_fresh_unit_subst_loop(uvars, subst_empty(), s_seed)
}

# m7b #12: bump the row-var fresh counter past `n` reserved ids so a
# subsequent `subst_fresh_row` returns ids that don't alias them.
# Used by `infer_decl` to keep its row-poly bound ids out of the
# inferencer's fresh-row pool.
fn advance_row_fresh(st: InferState, n: Int) : InferState {
  if n <= 0 { st }
  else {
    let s1 = Subst { slots: st.sub.slots, row_slots: st.sub.row_slots,
                     row_fresh: st.sub.row_fresh + n,
                     unit_slots: st.sub.unit_slots, unit_fresh: st.sub.unit_fresh }
    st_set_sub(st, s1)
  }
}

# m12.5: parallel to advance_row_fresh, for unit-vars. Used by
# infer_decl when reserving bound unit-var ids ahead of synth.
fn advance_unit_fresh(st: InferState, n: Int) : InferState {
  if n <= 0 { st }
  else {
    let s1 = Subst { slots: st.sub.slots, row_slots: st.sub.row_slots,
                     row_fresh: st.sub.row_fresh,
                     unit_slots: st.sub.unit_slots, unit_fresh: st.sub.unit_fresh + n }
    st_set_sub(st, s1)
  }
}

# ====================================================================
# bidirectional inference (M2d)
# ====================================================================
#
# `synth` traverses an expression, returning the inferred `Ty` plus an
# updated InferState (environment, substitution, error counter, record
# registry). Type mismatches print a diagnostic at the offending source
# position and bump the error counter; the walker keeps going with the
# old substitution so a single failure doesn't cascade into a wall of
# noise.
#
# Local `let` bindings are treated monomorphically (no generalisation);
# user-level polymorphism continues to live in prelude and variant
# schemes. TyAny acts as the unknown-fallback for AST shapes we cannot
# yet resolve (unknown record names, records referenced without a
# registry entry) and unifies with anything, so it never blocks
# inference from making progress elsewhere.
#
# Output surfaced via the `--infer` flag: one line per `DFn` decl
# giving its inferred function type. Unresolved type variables survive
# as `?tN` (see `ty_to_string`).

# ---- record registry ----
#
# Collected once per program. Lookup is linear in the number of record
# declarations, which is tiny in practice.

type RecInfo = RI(String, [String], [FieldDecl])

fn rec_find_loop(rs: [RecInfo], target: String) : Option[RecInfo] {
  match rs {
    [] -> None
    [r, ...rest] -> match r {
      RI(nm, _, _) -> if nm == target { Some(r) } else { rec_find_loop(rest, target) }
    }
  }
}

fn rec_find(rs: [RecInfo], target: String) : Option[RecInfo] = rec_find_loop(rs, target)

fn collect_records_loop(ds: [Decl], acc: [RecInfo]) : [RecInfo] {
  match ds {
    [] -> list_reverse(acc)
    [d, ...rest] -> match d {
      DType(_, nm, tps, body, _, _) -> match body {
        TBRecord(fs) -> collect_records_loop(rest, [RI(nm, tps, fs), ...acc])
        _ -> collect_records_loop(rest, acc)
      }
      _ -> collect_records_loop(rest, acc)
    }
  }
}

fn collect_records(ds: [Decl]) : [RecInfo] = collect_records_loop(ds, [])

# ---- inference state ----

# A single call-site that instantiated a polymorphic scheme. `fresh`
# lists the TyVarT ids minted for that instantiation; running each
# through the final sub recovers the concrete type arguments.
type CallSite = CS(String, Int, Int, [Int])        # name, line, col, fresh ids

# A typed hole site: the kind discriminator (m7d §1 splits `?` /
# `?name` from `todo!(msg)`), source position, the fresh TyVarT id
# that stands in for it during inference, and the env entries
# visible at that point (snapshot of the locals stack). After
# inference the fresh id runs through the final sub to recover the
# expected type.
type HoleSite = HS(HoleKind, Int, Int, Int, [TyEntry], Int)
#                   kind     line col fresh scope      env_fresh

# m7d §1: hole kinds.
# - `HKHole(None)`     — anonymous `?` (M10).
# - `HKHole(Some(n))`  — named `?n`. Same `n` shares one TyVarT.
# - `HKTodo(msg)`      — `todo!(msg)`. Each occurrence is independent
#   (no name-based sharing), and reporting flags it under
#   `"kind": "todo"` in `--holes-json`.
type HoleKind = HKHole(Option[String]) | HKTodo(String)

type InferState = { file: String, env: TyEnv, prelude_len: Int, sub: Subst, recs: [RecInfo], errs: Int,
                    insts: [CallSite], holes: [HoleSite],
                    # m7b #11i: row accumulator carries full Labels (eff
                    # name + ty_args). Op calls add the parametric label
                    # built from the op's instantiation (`inst.fresh`);
                    # `synth_handle` filters by name + ty_args unification
                    # so distinct instantiations of the same effect stay
                    # separate when their ty_args do not unify.
                    row: [Label],
                    eff_uses: [EffUse],   # m7a #8: per-label first-use site for diagnostics
                    aliases: [AliasBinding],   # m7a #4e: `Eff as log` bindings active in scope
                    # m7b #11l: when type-checking a stateful handler's
                    # clause body, a ResumeBind tracks the effect's
                    # answer type and the handler-state type so
                    # `resume(v)` and `resume(v, ns)` calls validate
                    # against the right shape. None outside clauses or
                    # in stateless clauses (in which case the standard
                    # env binding is the source of truth).
                    clause_resume: Option[ResumeBind],
                    # m7b #2: per-op generic schemes quantify over both
                    # effect-level and op-level tparams; the row label
                    # only carries the effect-level ones. This table
                    # records, per dotted "Eff.op" key, the effect's
                    # arity so synth_op_call_with_scheme can split
                    # `inst.fresh` correctly. Builds during build_ty_env.
                    op_eff_arities: [OpEffArity],
                    # m7e §13: declared return type of the immediately-
                    # enclosing function. Set by `infer_decl` before it
                    # walks the body; cleared (None) inside lambda
                    # bodies — `e!` propagates from the enclosing
                    # function, not from a closure, so `!` inside a
                    # lambda is rejected with a clear diagnostic.
                    ret_ty: Option[Ty],
                    # m12.8 Phase 4b: type aliases (`type Console =
                    # Stdout + Stderr + Stdin`, `type Io = Console +
                    # Env + File`, ...) carried into the typer so
                    # `try_op_call` can resolve `Aliasname.opname` by
                    # finding which component effect provides the op.
                    # Populated from `alias_res.aliases` at the start
                    # of `infer_program` (or empty).
                    type_aliases: [AliasResult],
                    # m12.8 Phase 4b: per-effect op→eff catalog
                    # consulted alongside `type_aliases` so
                    # `try_op_call` can answer "which component of
                    # this alias declares this op?" in O(n*m).
                    op_to_eff: [OpToEff] }

type OpEffArity = OEA(String, Int)

# m7b #11l — answer type + handler-state type for the currently-walked
# clause body of a stateful handler.
type ResumeBind = RB(Ty, Ty)

# m7a #8: first-use record per effect label in the current body.
# `check_body_row` reads this when it needs to point a diagnostic
# at the op call that caused the row to widen, instead of pinning
# the whole error to the function's declaration site.
type EffUse = EU(String, Int, Int)

# Stack entry for `Eff as log`. The stack is pushed on entering
# the body of a `handle ... with Eff as log { ... }` and popped
# on exit. try_op_call consults it when the dotted lookup fails:
# `log.print` walks the stack, finds `log → Io`, and retries as
# `Io.print`.
#
# m7b #15 (compiler integration, scope-limited): the Bool field
# records whether the binding is "taggable" — when true, an op
# call through this alias gets the `@<alias>` suffix that the
# codegen turns into a `kai_evidence_lookup_node_by_id(...)`
# dispatch. When false (after we descended into a lambda body),
# the alias still resolves for substitution but the codegen
# falls back to the legacy name-keyed lookup. The handle
# prologue's `kai_alias_<a>_id` C local is not in scope across
# the lambda boundary, so tagged dispatch would emit invalid C.
type AliasBinding = AB(String, String, Bool)   # alias_name, eff_name, taggable

# `TyRes` is the narrow result returned by pure type operations that
# don't consume or produce an expression (fresh var, instantiate a
# scheme, compute a param type). `Inferred` adds the re-built Expr
# tree with every sub-node carrying its inferred `Ty`, which M4+
# passes consume without re-running inference.
type TyRes = { st: InferState, ty: Ty }

type Inferred = { st: InferState, ty: Ty, expr: Expr }

type InferredList = { st: InferState, tys: [Ty], exprs: [Expr] }

type InferredStmts = { st: InferState, stmts: [Stmt] }
type InferredArms  = { st: InferState, arms: [Arm] }
type InferredElems = { st: InferState, elems: [ListElem] }
type InferredFInits = { st: InferState, fis: [FieldInit] }

fn infer_state_new(file: String, env: TyEnv, prelude_len: Int, recs: [RecInfo]) : InferState =
  infer_state_new_full(file, env, prelude_len, recs, [])

fn infer_state_new_full(file: String, env: TyEnv, prelude_len: Int,
                        recs: [RecInfo], op_eff_arities: [OpEffArity]) : InferState =
  infer_state_new_full_aliases(file, env, prelude_len, recs, op_eff_arities, [], [])

# m12.8 Phase 4b: variant carrying type aliases + op-to-eff catalog
# so `try_op_call` can resolve `Aliasname.opname` against alias
# components. Older callers (no alias context) use the empty form.
fn infer_state_new_full_aliases(file: String, env: TyEnv, prelude_len: Int,
                                  recs: [RecInfo], op_eff_arities: [OpEffArity],
                                  type_aliases: [AliasResult],
                                  op_to_eff: [OpToEff]) : InferState =
  InferState { file: file, env: env, prelude_len: prelude_len, sub: subst_empty(),
               recs: recs, errs: 0, insts: [], holes: [], row: [],
               eff_uses: [], aliases: [], clause_resume: None,
               op_eff_arities: op_eff_arities, ret_ty: None,
               type_aliases: type_aliases, op_to_eff: op_to_eff }

fn st_set_env(st: InferState, new_env: TyEnv) : InferState =
  InferState { file: st.file, env: new_env, prelude_len: st.prelude_len, sub: st.sub,
               recs: st.recs, errs: st.errs, insts: st.insts, holes: st.holes,
               row: st.row, eff_uses: st.eff_uses, aliases: st.aliases,
               clause_resume: st.clause_resume, op_eff_arities: st.op_eff_arities,
               ret_ty: st.ret_ty, type_aliases: st.type_aliases, op_to_eff: st.op_to_eff }

fn st_set_sub(st: InferState, new_sub: Subst) : InferState =
  InferState { file: st.file, env: st.env, prelude_len: st.prelude_len, sub: new_sub,
               recs: st.recs, errs: st.errs, insts: st.insts, holes: st.holes,
               row: st.row, eff_uses: st.eff_uses, aliases: st.aliases,
               clause_resume: st.clause_resume, op_eff_arities: st.op_eff_arities,
               ret_ty: st.ret_ty, type_aliases: st.type_aliases, op_to_eff: st.op_to_eff }

fn st_bump_err(st: InferState) : InferState =
  InferState { file: st.file, env: st.env, prelude_len: st.prelude_len, sub: st.sub,
               recs: st.recs, errs: st.errs + 1, insts: st.insts, holes: st.holes,
               row: st.row, eff_uses: st.eff_uses, aliases: st.aliases,
               clause_resume: st.clause_resume, op_eff_arities: st.op_eff_arities,
               ret_ty: st.ret_ty, type_aliases: st.type_aliases, op_to_eff: st.op_to_eff }

# m7a #4c / m7b #11i: mark that the current body has performed an op
# of `eff` with the given type-arg instantiation. Labels with the same
# `eff` but unifiable ty_args dedup; labels with the same `eff` but
# non-unifiable ty_args are kept distinct so a body can perform e.g.
# `Reader[Int]` and `Reader[String]` and have both flow through.
fn st_add_label(st: InferState, lab: Label, line: Int, col: Int) : InferState {
  if label_present_unifiable(st.row, lab, st.sub) { st }
  else {
    InferState { file: st.file, env: st.env, prelude_len: st.prelude_len, sub: st.sub,
                 recs: st.recs, errs: st.errs, insts: st.insts, holes: st.holes,
                 row: [lab, ...st.row],
                 eff_uses: [EU(lab.eff, line, col), ...st.eff_uses],
                 aliases: st.aliases,
                 clause_resume: st.clause_resume, op_eff_arities: st.op_eff_arities,
                 ret_ty: st.ret_ty, type_aliases: st.type_aliases, op_to_eff: st.op_to_eff }
  }
}

# Compatibility wrapper for stateless / non-parametric op calls. The
# pattern carries no type args.
fn st_add_effect(st: InferState, eff: String, line: Int, col: Int) : InferState =
  st_add_label(st, Label { eff: eff, ty_args: [] }, line, col)

# True iff `target.eff` matches some label in `row` AND the existing
# label's ty_args unify with target.ty_args under the current sub.
# Used as a syntactic-dedup guard; non-unifying same-name labels do not
# match here (so the row keeps both, and the resolver / handler-filter
# pass decides their fate).
fn label_present_unifiable(row: [Label], target: Label, s: Subst) : Bool {
  match row {
    [] -> false
    [h, ...rest] ->
      if h.eff == target.eff and labels_args_unify(h.ty_args, target.ty_args, s) {
        true
      } else {
        label_present_unifiable(rest, target, s)
      }
  }
}

# Speculative arity + unification check on two ty_arg lists. Wrong
# arity → no match. Used by st_add_label and the handler-filter pass.
# Pure under apply_ty (does not extend the substitution) — the actual
# unification later in synth_op_call_with_scheme is what mutates the
# sub.
fn labels_args_unify(a: [Ty], b: [Ty], s: Subst) : Bool {
  match a {
    [] -> match b { [] -> true _ -> false }
    [ah, ...arest] -> match b {
      [] -> false
      [bh, ...brest] -> {
        let aa = apply_ty(s, ah)
        let bb = apply_ty(s, bh)
        if ty_unifiable_shallow(aa, bb) { labels_args_unify(arest, brest, s) }
        else { false }
      }
    }
  }
}

# Conservative shape-check on already-substituted types. Two TyVars
# never block a match; concrete-vs-concrete must agree structurally.
# Stricter than full unify (no substitution side effect) but enough
# for the dedup / filter decisions in this layer.
fn ty_unifiable_shallow(a: Ty, b: Ty) : Bool {
  match a {
    TyVarT(_) -> true
    TyAny     -> true
    _ -> match b {
      TyVarT(_) -> true
      TyAny     -> true
      _ -> ty_eq_shape(a, b)
    }
  }
}

# Structural equality on resolved Tys — used only as a fallback in
# `ty_unifiable_shallow`. Excludes TyVarT/TyAny which short-circuit
# above. Approximates HM-equality for concrete types.
fn ty_eq_shape(a: Ty, b: Ty) : Bool {
  match a {
    TyInt    -> match b { TyInt -> true _ -> false }
    TyReal   -> match b { TyReal -> true _ -> false }
    TyBool   -> match b { TyBool -> true _ -> false }
    TyString -> match b { TyString -> true _ -> false }
    TyChar   -> match b { TyChar -> true _ -> false }
    TyUnit   -> match b { TyUnit -> true _ -> false }
    TyListT(ai) -> match b { TyListT(bi) -> ty_eq_shape(ai, bi) _ -> false }
    TyFnT(ap, ar, _) -> match b {
      TyFnT(bp, br, _) -> ty_list_eq_shape(ap, bp) and ty_eq_shape(ar, br)
      _ -> false
    }
    TyCon(an, atas) -> match b {
      TyCon(bn, btas) -> an == bn and ty_list_eq_shape(atas, btas)
      _ -> false
    }
    _ -> false
  }
}

fn ty_list_eq_shape(a: [Ty], b: [Ty]) : Bool {
  match a {
    [] -> match b { [] -> true _ -> false }
    [h, ...rest] -> match b {
      [] -> false
      [h2, ...rest2] -> ty_eq_shape(h, h2) and ty_list_eq_shape(rest, rest2)
    }
  }
}

# m7a #4d: replace the row accumulator wholesale. Used by
# synth_handle to switch into an empty inner row before walking
# the body, then to merge the filtered body-row back with the
# outer row.
fn st_set_row(st: InferState, new_row: [Label]) : InferState =
  InferState { file: st.file, env: st.env, prelude_len: st.prelude_len, sub: st.sub,
               recs: st.recs, errs: st.errs, insts: st.insts, holes: st.holes,
               row: new_row, eff_uses: st.eff_uses, aliases: st.aliases,
               clause_resume: st.clause_resume, op_eff_arities: st.op_eff_arities,
               ret_ty: st.ret_ty, type_aliases: st.type_aliases, op_to_eff: st.op_to_eff }

# m7a #4e: push/pop the alias stack as we enter/leave a handle's body.
# m7b #15: a freshly-pushed alias starts taggable; descending into a
# lambda body marks every alias visible at that point as
# non-taggable so try_op_call's alias-fallback emits a bare
# dispatch key (no `@<alias>` suffix) and codegen falls back to
# the legacy name-keyed lookup.
fn st_push_alias(st: InferState, alias: String, eff: String) : InferState =
  InferState { file: st.file, env: st.env, prelude_len: st.prelude_len, sub: st.sub,
               recs: st.recs, errs: st.errs, insts: st.insts, holes: st.holes,
               row: st.row, eff_uses: st.eff_uses,
               aliases: [AB(alias, eff, true), ...st.aliases],
               clause_resume: st.clause_resume, op_eff_arities: st.op_eff_arities,
               ret_ty: st.ret_ty, type_aliases: st.type_aliases, op_to_eff: st.op_to_eff }

fn st_pop_alias(st: InferState) : InferState {
  match st.aliases {
    [] -> st
    [_, ...rest] ->
      InferState { file: st.file, env: st.env, prelude_len: st.prelude_len, sub: st.sub,
                   recs: st.recs, errs: st.errs, insts: st.insts, holes: st.holes,
                   row: st.row, eff_uses: st.eff_uses, aliases: rest,
                   clause_resume: st.clause_resume, op_eff_arities: st.op_eff_arities,
                   ret_ty: st.ret_ty, type_aliases: st.type_aliases, op_to_eff: st.op_to_eff }
  }
}

# m7b #11l — push / pop / read the clause resume binding.
fn st_set_clause_resume(st: InferState, rb: Option[ResumeBind]) : InferState =
  InferState { file: st.file, env: st.env, prelude_len: st.prelude_len, sub: st.sub,
               recs: st.recs, errs: st.errs, insts: st.insts, holes: st.holes,
               row: st.row, eff_uses: st.eff_uses, aliases: st.aliases,
               clause_resume: rb, op_eff_arities: st.op_eff_arities,
               ret_ty: st.ret_ty, type_aliases: st.type_aliases, op_to_eff: st.op_to_eff }

# m7e §13: stash/clear/restore the enclosing function's declared
# return type for `e!` propagation. Set by `infer_decl` before walking
# the body; cleared by `synth_lambda` so `!` inside a closure is
# rejected (would propagate from the lambda, not the surrounding fn).
fn st_set_ret_ty(st: InferState, rt: Option[Ty]) : InferState =
  InferState { file: st.file, env: st.env, prelude_len: st.prelude_len, sub: st.sub,
               recs: st.recs, errs: st.errs, insts: st.insts, holes: st.holes,
               row: st.row, eff_uses: st.eff_uses, aliases: st.aliases,
               clause_resume: st.clause_resume, op_eff_arities: st.op_eff_arities,
               ret_ty: rt, type_aliases: st.type_aliases, op_to_eff: st.op_to_eff }

fn lookup_alias(aliases: [AliasBinding], name: String) : Option[String] {
  match aliases {
    [] -> None
    [AB(alias, eff, _), ...rest] ->
      if alias == name { Some(eff) } else { lookup_alias(rest, name) }
  }
}

# m7b #15: variant of lookup_alias that also returns the binding's
# taggability flag. Used by try_op_call's alias-fallback to decide
# whether to emit a tagged dispatch key.
fn lookup_alias_taggable(aliases: [AliasBinding], name: String) : Option[Bool] {
  match aliases {
    [] -> None
    [AB(alias, _, t), ...rest] ->
      if alias == name { Some(t) } else { lookup_alias_taggable(rest, name) }
  }
}

# m7b #15: mark every alias currently in scope as non-taggable.
# Called from synth_lambda before walking the body and reverted
# afterwards via the standard `st_restore_entries` snapshot.
fn aliases_disable_tag(aliases: [AliasBinding]) : [AliasBinding] {
  match aliases {
    [] -> []
    [AB(a, e, _), ...rest] -> [AB(a, e, false), ...aliases_disable_tag(rest)]
  }
}

fn st_disable_alias_tag(st: InferState) : InferState =
  InferState { file: st.file, env: st.env, prelude_len: st.prelude_len, sub: st.sub,
               recs: st.recs, errs: st.errs, insts: st.insts, holes: st.holes,
               row: st.row, eff_uses: st.eff_uses,
               aliases: aliases_disable_tag(st.aliases),
               clause_resume: st.clause_resume, op_eff_arities: st.op_eff_arities,
               ret_ty: st.ret_ty, type_aliases: st.type_aliases, op_to_eff: st.op_to_eff }

fn st_push_inst(st: InferState, cs: CallSite) : InferState =
  InferState { file: st.file, env: st.env, prelude_len: st.prelude_len, sub: st.sub,
               recs: st.recs, errs: st.errs, insts: [cs, ...st.insts], holes: st.holes,
               row: st.row, eff_uses: st.eff_uses, aliases: st.aliases,
               clause_resume: st.clause_resume, op_eff_arities: st.op_eff_arities,
               ret_ty: st.ret_ty, type_aliases: st.type_aliases, op_to_eff: st.op_to_eff }

fn st_push_hole(st: InferState, h: HoleSite) : InferState =
  InferState { file: st.file, env: st.env, prelude_len: st.prelude_len, sub: st.sub,
               recs: st.recs, errs: st.errs, insts: st.insts, holes: [h, ...st.holes],
               row: st.row, eff_uses: st.eff_uses, aliases: st.aliases,
               clause_resume: st.clause_resume, op_eff_arities: st.op_eff_arities,
               ret_ty: st.ret_ty, type_aliases: st.type_aliases, op_to_eff: st.op_to_eff }

# m7a #8: lookup the recorded first-use line/col of an effect label.
# Returns (-1, -1) when the effect was never tracked — that should
# only happen when the row was set via st_set_row from outside, in
# which case the caller falls back to the function's decl span.
fn lookup_eff_use(uses: [EffUse], target: String) : EffUse {
  match uses {
    [] -> EU(target, -1, -1)
    [u, ...rest] -> match u {
      EU(name, _, _) -> if name == target { u } else { lookup_eff_use(rest, target) }
    }
  }
}

# Half-open range [lo, hi) as a list of ints. Used to name the fresh
# TyVarT ids minted by one call-site's instantiation.
fn range_ids_loop(i: Int, hi: Int, acc: [Int]) : [Int] {
  if i >= hi { list_reverse(acc) }
  else { range_ids_loop(i + 1, hi, [i, ...acc]) }
}

fn range_ids(lo: Int, hi: Int) : [Int] = range_ids_loop(lo, hi, [])

fn ty_res(st: InferState, t: Ty) : TyRes = TyRes { st: st, ty: t }

fn mk_inferred(st: InferState, t: Ty, e: Expr) : Inferred =
  Inferred { st: st, ty: t, expr: e }

# Leaf expressions (literals, EVar, EUnder, EPlaceholder) have no
# sub-nodes to rebuild, so they annotate themselves in place.
fn inferred_leaf(st: InferState, t: Ty, e: Expr) : Inferred =
  mk_inferred(st, t, with_ty(e, t))

fn st_fresh_ty(st: InferState) : TyRes {
  let n = st.env.fresh
  ty_res(st_set_env(st, fresh_var(st.env)), TyVarT(n))
}

fn st_unify(st: InferState, a: Ty, b: Ty, what: String, line: Int, col: Int) : InferState {
  match unify(a, b, st.sub) {
    Some(s2) -> st_set_sub(st, s2)
    None -> {
      let a1 = apply_ty(st.sub, a)
      let b1 = apply_ty(st.sub, b)
      diag_error(st.file, line, col, "type mismatch in #{what}")
      diag_note("expected: #{ty_to_string(a1)}")
      diag_note("found:    #{ty_to_string(b1)}")
      emit_type_hint(a1, b1)
      st_bump_err(st)
    }
  }
}

# Known conversion pairs. `emit_type_hint(expected, found)` suggests
# a prelude helper that lifts `found` into `expected` (or vice versa)
# when the pair is one we already have a built-in for. Kept narrow
# on purpose: hints that nearly-always apply are the helpful ones.
fn emit_type_hint(expected: Ty, found: Ty) : Unit {
  match expected {
    TyString -> match found {
      TyInt    -> diag_help("wrap the Int with `int_to_string(n)`")
      TyReal   -> diag_help("wrap the Real with `real_to_string(r)`")
      TyChar   -> diag_help("interpolate the Char into a String literal")
      _        -> ()
    }
    TyInt -> match found {
      TyString -> diag_help("parse with `string_to_int(s)` (returns Option[Int])")
      TyChar   -> diag_help("convert with `char_to_int(c)`")
      _        -> ()
    }
    TyReal -> match found {
      TyString -> diag_help("parse with `string_to_real(s)` (returns Option[Real])")
      _        -> ()
    }
    TyChar -> match found {
      TyInt -> diag_help("convert with `int_to_char(n)`")
      _     -> ()
    }
    TyCon(nm, _) -> {
      if nm == "Option" {
        diag_help("wrap the value with `Some(...)`, or use `None` if absent")
      } else { () }
    }
    _ -> ()
  }
}

# Wider instantiate result: also reports the fresh TyVarT ids that
# were minted to replace the scheme's bound vars. Those ids, run
# through the final substitution, give the call-site's concrete
# type arguments (M4b) and feed monomorphisation (M4c).
type TyInstRes = { st: InferState, ty: Ty, fresh: [Int] }

fn st_instantiate(st: InferState, sc: TyScheme) : TyRes {
  let r = st_instantiate_report(st, sc)
  ty_res(r.st, r.ty)
}

fn st_instantiate_report(st: InferState, sc: TyScheme) : TyInstRes {
  match sc {
    Scheme(vars, rvars, uvars, _) -> {
      let n = list_length(vars)
      let need = if n == 0 { 0 } else { max_id_loop(vars, 0) + 1 }
      let start = if st.env.fresh >= need { st.env.fresh } else { need }
      let inst = instantiate(st.env, sc)
      let fresh = range_ids(start, start + n)
      # m7b #12: also fresh-instantiate row vars. The temp substitution
      # rewrites each bound row-var id to a fresh one drawn from the
      # inferencer's row_fresh counter; we apply it once to the body
      # produced by `instantiate` (which rewrote type vars only) and
      # propagate the bumped row_fresh into the returned state.
      let st_env = st_set_env(st, inst.env)
      let mid = match rvars {
        [] -> TyInstRes { st: st_env, ty: inst.ty, fresh: fresh }
        _  -> {
          let frs = mk_fresh_row_subst(rvars, st_env.sub)
          let body1 = apply_ty(frs.temp, inst.ty)
          let st_out = st_set_sub(st_env, frs.sub)
          TyInstRes { st: st_out, ty: body1, fresh: fresh }
        }
      }
      # m12.5: also fresh-instantiate unit-vars. Same shape as the
      # row-var step above but threaded through unit_slots.
      match uvars {
        [] -> mid
        _  -> {
          let fus = mk_fresh_unit_subst(uvars, mid.st.sub)
          let body2 = apply_ty(fus.temp, mid.ty)
          let st_out2 = st_set_sub(mid.st, fus.sub)
          TyInstRes { st: st_out2, ty: body2, fresh: mid.fresh }
        }
      }
    }
  }
}

# Lexically scope a sub-walk: entries added during `inner` are dropped,
# but the fresh counter, substitution, record registry, and error
# counter propagate back to the caller.
fn st_restore_entries(outer: InferState, inner: InferState) : InferState =
  InferState {
    file: outer.file,
    env: TyEnv { entries: outer.env.entries, fresh: inner.env.fresh },
    prelude_len: outer.prelude_len,
    sub: inner.sub,
    recs: inner.recs,
    errs: inner.errs,
    insts: inner.insts,
    holes: inner.holes,
    row: inner.row,
    eff_uses: inner.eff_uses,
    aliases: outer.aliases,
    clause_resume: outer.clause_resume,
    op_eff_arities: outer.op_eff_arities,
    ret_ty: outer.ret_ty,
    type_aliases: outer.type_aliases,
    op_to_eff: outer.op_to_eff
  }

# ---- parameter typing ----

fn param_ty_or_fresh(st: InferState, pm: Param) : TyRes {
  match pm.ptype {
    Some(te) -> ty_res(st, resolve_ty(te))
    None     -> st_fresh_ty(st)
  }
}

fn param_ty_or_fresh_with_rvbinds(st: InferState, pm: Param, rbinds: [RVBind]) : TyRes =
  param_ty_or_fresh_with_binds(st, pm, [], rbinds)

# m7b #13: variant that also resolves type names against the fn-level
# tparams declared on the surrounding decl.
fn param_ty_or_fresh_with_binds(st: InferState, pm: Param,
                                tpbinds: [TPBind], rbinds: [RVBind]) : TyRes {
  match pm.ptype {
    Some(te) -> ty_res(st, resolve_ty_with_binds(te, tpbinds, rbinds))
    None     -> st_fresh_ty(st)
  }
}

# Add fn parameters to the type environment. Doesn't produce an Expr
# list (params aren't expressions), just the param types for later
# function-type construction.
type InferredParams = { st: InferState, tys: [Ty] }

fn add_infer_params_loop(st: InferState, ps: [Param], acc: [Ty]) : InferredParams {
  match ps {
    [] -> InferredParams { st: st, tys: list_reverse(acc) }
    [pm, ...rest] -> {
      let pr = param_ty_or_fresh(st, pm)
      let env2 = ty_env_add(pr.st.env, pm.pname, mono(pr.ty))
      let st2 = st_set_env(pr.st, env2)
      add_infer_params_loop(st2, rest, [pr.ty, ...acc])
    }
  }
}

fn add_infer_params(st: InferState, ps: [Param]) : InferredParams = add_infer_params_loop(st, ps, [])

# m7b #12: variant of `add_infer_params` that resolves param types
# under a row-variable binding context — used by `infer_decl` so the
# function body's view of every parameter type carries the same
# bound row-var ids that `fn_scheme_of_decl` chose for the scheme.
# m7b #13 added the tpbinds half so the body also sees fn-level
# tparams as bound type variables (`fn id[T](x: T) : T = x`).
fn add_infer_params_with_binds_loop(st: InferState, ps: [Param],
                                    tpbinds: [TPBind], rbinds: [RVBind],
                                    acc: [Ty]) : InferredParams {
  match ps {
    [] -> InferredParams { st: st, tys: list_reverse(acc) }
    [pm, ...rest] -> {
      let pr = param_ty_or_fresh_with_binds(st, pm, tpbinds, rbinds)
      let env2 = ty_env_add(pr.st.env, pm.pname, mono(pr.ty))
      let st2 = st_set_env(pr.st, env2)
      add_infer_params_with_binds_loop(st2, rest, tpbinds, rbinds, [pr.ty, ...acc])
    }
  }
}

fn add_infer_params_with_binds(st: InferState, ps: [Param],
                               tpbinds: [TPBind], rbinds: [RVBind]) : InferredParams =
  add_infer_params_with_binds_loop(st, ps, tpbinds, rbinds, [])

fn add_infer_params_with_rvbinds(st: InferState, ps: [Param],
                                 rbinds: [RVBind]) : InferredParams =
  add_infer_params_with_binds(st, ps, [], rbinds)

# ---- record instantiation ----

type FTy = FT(String, Ty)

type RecInst = { st: InferState, result_ty: Ty, fields: [FTy] }

fn rec_tpbinds_loop(tps: [String], start: Int, i: Int, acc: [TPBind]) : [TPBind] {
  match tps {
    [] -> list_reverse(acc)
    [n, ...rest] -> rec_tpbinds_loop(rest, start, i + 1, [TPB(n, start + i), ...acc])
  }
}

fn rec_field_tys(fs: [FieldDecl], binds: [TPBind]) : [FTy] {
  match fs {
    [] -> []
    [f, ...rest] -> match f {
      FD(nm, te) -> [FT(nm, resolve_ty_with_tparams(te, binds)), ...rec_field_tys(rest, binds)]
    }
  }
}

fn fresh_tv_range_loop(start: Int, n: Int, i: Int, acc: [Ty]) : [Ty] {
  if i >= n { list_reverse(acc) }
  else { fresh_tv_range_loop(start, n, i + 1, [TyVarT(start + i), ...acc]) }
}

fn fresh_tv_range(start: Int, n: Int) : [Ty] = fresh_tv_range_loop(start, n, 0, [])

fn rec_instantiate(st: InferState, ri: RecInfo) : RecInst {
  match ri {
    RI(nm, tps, fs) -> {
      let start = st.env.fresh
      let n = list_length(tps)
      let env2 = advance_fresh(st.env, n)
      let binds = rec_tpbinds_loop(tps, start, 0, [])
      let flds = rec_field_tys(fs, binds)
      let atys = fresh_tv_range(start, n)
      RecInst {
        st: st_set_env(st, env2),
        result_ty: TyCon(nm, atys),
        fields: flds
      }
    }
  }
}

fn fty_find_loop(fs: [FTy], target: String) : Option[Ty] {
  match fs {
    [] -> None
    [f, ...rest] -> match f {
      FT(nm, t) -> if nm == target { Some(t) } else { fty_find_loop(rest, target) }
    }
  }
}

fn fty_find(fs: [FTy], target: String) : Option[Ty] = fty_find_loop(fs, target)

fn fty_names(fs: [FTy]) : [String] = fty_names_loop(fs, [])

fn fty_names_loop(fs: [FTy], acc: [String]) : [String] {
  match fs {
    [] -> list_reverse(acc)
    [f, ...rest] -> match f {
      FT(nm, _) -> fty_names_loop(rest, [nm, ...acc])
    }
  }
}

fn field_hint(fs: [FTy], target: String) : String {
  match closest_name(target, fty_names(fs)) {
    Some(sug) -> " (did you mean `.#{sug}`?)"
    None      -> ""
  }
}

# ---- the walker ----

fn synth(st: InferState, e: Expr) : Inferred {
  match e.kind {
    EInt(_)        -> inferred_leaf(st, TyInt, e)
    EReal(_)       -> inferred_leaf(st, TyReal, e)
    EBool(_)       -> inferred_leaf(st, TyBool, e)
    EChar(_)       -> inferred_leaf(st, TyChar, e)
    EStr(_, _)     -> inferred_leaf(st, TyString, e)
    EUnit          -> inferred_leaf(st, TyUnit, e)
    EUnder         -> inferred_leaf(st, TyAny, e)
    EPlaceholder   -> inferred_leaf(st, TyAny, e)
    EVar(nm)       -> match ty_env_lookup(st.env, nm) {
      Some(sc) -> {
        let r = st_instantiate_report(st, sc)
        let st2 = match r.fresh {
          [] -> r.st
          _  -> st_push_inst(r.st, CS(nm, e.line, e.col, r.fresh))
        }
        inferred_leaf(st2, r.ty, e)
      }
      None     -> inferred_leaf(st, TyAny, e)
    }
    ECall(callee, args_)       -> synth_call(st, callee, args_, e.line, e.col)
    EField(obj, fnm)           -> synth_field(st, obj, fnm, e.line, e.col)
    EIndex(coll, ix)           -> synth_index(st, coll, ix, e.line, e.col)
    EBinop(op, l, r)           -> synth_binop(st, op, l, r, e.line, e.col)
    EUnop(op, x)               -> synth_unop(st, op, x, e.line, e.col)
    EIf(c, t_, eo)             -> synth_if(st, c, t_, eo, e.line, e.col)
    EMatch(scr, arms)          -> synth_match(st, scr, arms, e.line, e.col)
    ELambda(ps, body)          -> synth_lambda(st, ps, body, e.line, e.col)
    ERecordLit(nm, fis)        -> synth_record_lit(st, nm, fis, e.line, e.col)
    EList(els)                 -> synth_list_expr(st, els, e.line, e.col)
    ERange(lo, hi, stp)        -> synth_range(st, lo, hi, stp, e.line, e.col)
    EBlock(stmts, tail)        -> synth_block(st, stmts, tail, e.line, e.col)
    EPipe(lhs, rhs)            -> synth_pipe(st, lhs, rhs, e.line, e.col)
    EHole(nm_opt)              -> synth_hole(st, nm_opt, e)
    ETodo(msg)                 -> synth_todo(st, msg, e)
    EBang(inner)               -> synth_bang(st, inner, e.line, e.col)
    EHandle(_, _, _, _, _, _, _) -> synth_handle(st, e)
    # m12.5: numeric literal with a unit annotation. The inner Expr is
    # always EInt or EReal; the literal's type is `TyDimT(base, u)`
    # where base is TyInt or TyReal and u is the canonical unit.
    ELitUnit(inner, u) -> synth_lit_unit(st, inner, u, e.line, e.col)
    # m7e §11: `variants[T]()`. Real typing (`TyListT(TyCon(T, []))`
    # after validating T is a nullary-only sum type) lands in the
    # task-15 typer lane; this site keeps the match exhaustive with
    # a TyAny stub so commits before that lane still build. TyAny
    # unifies with anything, which is safe for a feature that has
    # no runtime emission yet (codegen panics — see emit_expr).
    EVariantsOf(_) -> inferred_leaf(st, TyAny, e)
  }
}

# m12.5: synth a literal annotated with a unit. Unit aliases were
# expanded by the resolver before the typer ever sees them; here we
# only canonicalise (sort/group) and stamp the dimensioned type onto
# the rebuilt expression node.
fn synth_lit_unit(st: InferState, inner: Expr, u: UnitExprT, line: Int, col: Int) : Inferred {
  let ri = synth(st, inner)
  let base = apply_ty(ri.st.sub, ri.ty)
  let canon_u = unit_canon(u)
  let ty = dim_collapse(base, canon_u)
  let root = with_ty(mk_expr(ELitUnit(ri.expr, canon_u), line, col), ty)
  mk_inferred(ri.st, ty, root)
}

# m7a #4d: type-check `handle { body } with Eff [as alias] {
# clauses }`. The body is walked under a fresh row accumulator;
# the named effect is filtered out of whatever the body
# accumulates, and the remainder merges back into the outer
# function's row. Clause bodies and the optional return clause
# are not yet type-checked against the op signatures — that
# extension lands in a later sub-step (or m7a #6 lowering).
# Alias resolution (`Eff as log`) is also deferred.
fn synth_handle(st: InferState, e: Expr) : Inferred {
  match e.kind {
    EHandle(body, eff_name, eff_tyargs, init_opt, alias_opt, clauses, ret_opt) -> {
      # m7b #11l: type-check the init expression in the outer scope.
      # The init's inferred type IS the handler-state type — it is
      # propagated into the clauses so `state` / `log` and 2-arg
      # `resume(v, ns)` are typed precisely (no TyAny escape).
      let init_typed_st = match init_opt {
        Some(ie) -> {
          let ri = synth(st, ie)
          let ity = apply_ty(ri.st.sub, ri.ty)
          IT { st: ri.st, init_opt: Some(ri.expr), state_ty: Some(ity) }
        }
        None -> IT { st: st, init_opt: None, state_ty: None }
      }
      # m7a #4e: alias rebinds the capability inside the body.
      let st_aliased = match alias_opt {
        Some(a) -> st_push_alias(init_typed_st.st, a, eff_name)
        None    -> init_typed_st.st
      }
      # m7b #5b: when a stateful handler omits the explicit `[T]`
      # instantiation but supplies an `(init)`, infer the single
      # type argument from the init's type. This is the path Doc C
      # §m7b #5 specifies for the unannotated `var x = init` desugar:
      # `with State(init) as x { ... }` resolves to
      # `State[type_of_init]`. The fallback only fires when no syntactic
      # type args were written, so explicit `with State[Int](0)` still
      # round-trips verbatim.
      let resolved_eff_tyargs = match eff_tyargs {
        [] -> match init_typed_st.state_ty {
          Some(t) -> [t]
          None    -> []
        }
        _ -> resolve_ty_list(eff_tyargs)
      }
      let prev_row = st_aliased.row
      let st_in = st_set_row(st_aliased, [])
      let rb = synth(st_in, body)
      # m7b #11i: filter out *only* the labels whose ty_args unify with
      # the handler's instantiation. Labels with the same eff name but
      # non-unifiable ty_args remain and propagate to the outer row —
      # they need their own enclosing handler.
      let body_row_minus = filter_labels_matching(rb.st.row, eff_name,
                                                    resolved_eff_tyargs, rb.st.sub)
      let merged = merge_label_lists(prev_row, body_row_minus, rb.st.sub)
      let st_out0 = st_set_row(rb.st, merged)
      let st_out1 = match alias_opt { Some(_) -> st_pop_alias(st_out0) None -> st_out0 }
      # m7a #4e: every clause name must be a declared op of `eff_name`.
      let st_out2 = check_clause_names(st_out1, eff_name, clauses, e.line, e.col)
      let stateful = match init_opt { Some(_) -> true None -> false }
      let cs_typed = check_clauses_types(st_out2, eff_name, clauses,
                                          stateful, init_typed_st.state_ty,
                                          resolved_eff_tyargs)
      let r_typed = check_return_clause_opt(cs_typed.st, ret_opt, rb.ty,
                                             stateful, init_typed_st.state_ty)
      let new_e = with_ty(
        mk_expr(EHandle(rb.expr, eff_name, eff_tyargs, init_typed_st.init_opt,
                         alias_opt, cs_typed.clauses, r_typed.ret_opt),
                e.line, e.col),
        r_typed.ty)
      mk_inferred(r_typed.st, r_typed.ty, new_e)
    }
    _ -> mk_inferred(st, TyAny, with_ty(e, TyAny))
  }
}

# m7b #11: thread an init's typed sub-expression and resolved
# handler-state type alongside the inferred state.
type IT = { st: InferState, init_opt: Option[Expr], state_ty: Option[Ty] }

type RetTyped = { st: InferState, ty: Ty, ret_opt: Option[HReturn] }

fn check_return_clause_opt(st: InferState, ret_opt: Option[HReturn],
                           body_ty: Ty, stateful: Bool,
                           state_ty: Option[Ty]) : RetTyped {
  match ret_opt {
    None    -> RetTyped { st: st, ty: body_ty, ret_opt: None }
    Some(r) -> match r {
      HR(pname, rexpr, line, col) -> {
        let outer = st
        let env1 = ty_env_add(st.env, pname, mono(body_ty))
        # m7b #11l: `state` / `log` get the actual handler-state type
        # in the return clause so `return(x) -> (x, state)` types as
        # `(body_ty, state_ty)`.
        let sty = match state_ty { Some(t) -> t None -> TyAny }
        let env2 =
          if stateful {
            ty_env_add(ty_env_add(env1, "state", mono(sty)),
                       "log", mono(sty))
          } else { env1 }
        let st1 = st_set_env(st, env2)
        let rr = synth(st1, rexpr)
        let st_out = st_restore_entries(outer, rr.st)
        let ty = apply_ty(st_out.sub, rr.ty)
        RetTyped { st: st_out, ty: ty, ret_opt: Some(HR(pname, rr.expr, line, col)) }
      }
    }
  }
}

# m7a #6f: type-check each handler clause body under an env that
# binds the op's args and `resume`. The trailing param is `resume`
# by surface convention; the rest map positionally to the op's
# declared parameter types. If the clause's arity does not match
# the op's signature we fall back to fresh tyvars for any unbound
# slot — clause-arity validation is a separate diagnostic-baseline
# task (m7a #8).
type ClausesTyped = { st: InferState, clauses: [HClause] }

fn check_clauses_types(st: InferState, eff_name: String, cs: [HClause],
                        stateful: Bool, state_ty: Option[Ty],
                        eff_tyargs: [Ty]) : ClausesTyped =
  check_clauses_types_loop(st, eff_name, cs, stateful, state_ty, eff_tyargs, [])

fn check_clauses_types_loop(st: InferState, eff_name: String, cs: [HClause],
                             stateful: Bool, state_ty: Option[Ty],
                             eff_tyargs: [Ty], acc: [HClause]) : ClausesTyped {
  match cs {
    [] -> ClausesTyped { st: st, clauses: list_reverse(acc) }
    [c, ...rest] -> match c {
      HC(op_name, params, body, line, col) -> {
        let outer = st
        # m7b #11l: bind the clause params and unify the op's
        # effect-tparam tyvars with the handler's instantiation, so
        # the answer type is concrete (e.g., `Int` for State.get under
        # `with State[Int]`). `st.clause_resume` is then set with the
        # concrete answer/state types so `resume(v)` / `resume(v, ns)`
        # are typechecked precisely.
        let bind_res = bind_clause_env_typed(st, eff_name, op_name, params,
                                              stateful, state_ty, eff_tyargs)
        let sty = match state_ty { Some(t) -> t None -> TyAny }
        let env_bound = bind_res.st.env
        let env_with_sl =
          if stateful {
            ty_env_add(ty_env_add(env_bound, "state", mono(sty)),
                       "log", mono(sty))
          } else { env_bound }
        let st_env = st_set_env(bind_res.st, env_with_sl)
        let answer_resolved = apply_ty(st_env.sub, bind_res.answer_ty)
        let st_resume = if stateful {
          match state_ty {
            Some(sv) -> st_set_clause_resume(st_env,
              Some(RB(answer_resolved, sv)))
            None -> st_env
          }
        } else { st_env }
        let rb = synth(st_resume, body)
        let st_out0 = st_restore_entries(outer, rb.st)
        let st_out = st_set_clause_resume(st_out0, outer.clause_resume)
        # m12.8 Phase 4b followup: keep the typed body so the
        # alias-aware op resolution that fired inside `synth` (e.g.
        # rewriting `Console.print(...)` to `EVar("Stdout.print")`)
        # actually reaches the emit phase. Returning only `st` and
        # discarding `rb.expr` was the bug behind the `kai_Console`
        # leak in `demos/concurrent` — handler-clause bodies kept the
        # original `EField(EVar("Console"), "print")` shape.
        let new_clause = HC(op_name, params, rb.expr, line, col)
        check_clauses_types_loop(st_out, eff_name, rest, stateful, state_ty,
                                  eff_tyargs, [new_clause, ...acc])
      }
    }
  }
}

# m7b #11l — bind clause params; also returns the answer type recovered
# from the op's instantiated signature so the caller can build a
# precise resume binding. The op's effect-tparam fresh tyvars are
# unified with `eff_tyargs` (the handler's `with Eff[T1, T2]`
# instantiation) so the answer type is concrete when the handler is
# instantiated to concrete types.
type ClauseBindRes = { st: InferState, answer_ty: Ty }

fn bind_clause_env_typed(st: InferState, eff_name: String, op_name: String,
                          params: [Param], stateful: Bool,
                          state_ty: Option[Ty], eff_tyargs: [Ty]) : ClauseBindRes {
  let key = string_concat(eff_name, string_concat(".", op_name))
  match ty_env_lookup(st.env, key) {
    None     -> ClauseBindRes { st: bind_params_lenient(st, params), answer_ty: TyAny }
    Some(sc) -> {
      let inst = st_instantiate_report(st, sc)
      # m7b #11l — unify the op-scheme's effect-tparam fresh tyvars
      # with the handler's instantiation. For State[Int], `get`'s
      # bound `?Tfresh` becomes `Int`, so the resume answer type is
      # `Int` rather than a free tyvar.
      let st_unified = unify_eff_tparams(inst.st, inst.fresh, eff_tyargs,
                                          op_name)
      match inst.ty {
        TyFnT(arg_tys, ret_ty, _) -> {
          let bound = bind_params_with_sig_typed(st_unified, params, arg_tys, ret_ty,
                                                   stateful, state_ty)
          ClauseBindRes { st: bound, answer_ty: ret_ty }
        }
        _ -> ClauseBindRes { st: bind_params_lenient(st_unified, params), answer_ty: TyAny }
      }
    }
  }
}

# Unify each effect-tparam fresh tyvar (from the op's polymorphic
# scheme) with the corresponding handler instantiation type. Length
# mismatch is silent — m7b #11j arity check has already reported the
# row-level error.
fn unify_eff_tparams(st: InferState, fresh: [Int], tys: [Ty],
                      op_name: String) : InferState {
  match fresh {
    [] -> st
    [id, ...frest] -> match tys {
      [] -> st
      [t, ...trest] -> {
        let st1 = st_unify(st, TyVarT(id), t,
                            string_concat("clause op tparam in ", op_name),
                            -1, -1)
        unify_eff_tparams(st1, frest, trest, op_name)
      }
    }
  }
}

fn bind_params_with_sig_typed(st: InferState, params: [Param], arg_tys: [Ty],
                                ret_ty: Ty, stateful: Bool,
                                state_ty: Option[Ty]) : InferState {
  match params {
    []      -> st
    [last]  -> bind_resume_param_typed(st, last, ret_ty, stateful, state_ty)
    [p, ...rest] -> match arg_tys {
      []           -> bind_params_lenient(st, params)
      [a, ...rest_a] -> {
        let env1 = ty_env_add(st.env, p.pname, mono(a))
        bind_params_with_sig_typed(st_set_env(st, env1), rest, rest_a, ret_ty,
                                     stateful, state_ty)
      }
    }
  }
}

# m7b #11l — stateless clauses bind `resume : (answer_ty) -> ?fresh`.
# Stateful clauses still bind `resume` to mono(TyAny) at the env
# level (so name lookup succeeds and arity errors don't surface as
# "unknown identifier"); the actual precise typing of `resume(v)` and
# `resume(v, ns)` is performed by synth_call's special-case using the
# st.clause_resume binding pushed by check_clauses_types.
fn bind_resume_param_typed(st: InferState, p: Param, ret_ty: Ty,
                            stateful: Bool, state_ty: Option[Ty]) : InferState {
  if stateful {
    st_set_env(st, ty_env_add(st.env, p.pname, mono(TyAny)))
  } else {
    let f = st_fresh_ty(st)
    let resume_ty = TyFnT([ret_ty], f.ty, row_empty())
    st_set_env(f.st, ty_env_add(f.st.env, p.pname, mono(resume_ty)))
  }
}

fn bind_params_lenient(st: InferState, params: [Param]) : InferState {
  match params {
    []      -> st
    [p, ...rest] -> {
      let f = st_fresh_ty(st)
      let env1 = ty_env_add(f.st.env, p.pname, mono(f.ty))
      bind_params_lenient(st_set_env(f.st, env1), rest)
    }
  }
}

fn check_clause_names(st: InferState, eff: String, cs: [HClause],
                      line: Int, col: Int) : InferState {
  match cs {
    [] -> st
    [c, ...rest] -> match c {
      HC(name, _, _, cline, ccol) -> {
        let key = string_concat(eff, string_concat(".", name))
        match ty_env_lookup(st.env, key) {
          Some(_) -> check_clause_names(st, eff, rest, line, col)
          None -> {
            diag_error(st.file, cline, ccol,
              string_concat("unknown op `",
                string_concat(name,
                  string_concat("` on effect `",
                    string_concat(eff, "`")))))
            diag_note("handler clauses must match an op declared in `effect #{eff} { ... }`")
            diag_help("either remove this clause, or add `#{name}(...)` to the effect declaration")
            check_clause_names(st_bump_err(st), eff, rest, line, col)
          }
        }
      }
    }
  }
}

# m7b #11i — filter labels whose `eff` matches `eff_name` AND whose
# ty_args unify with `tyargs`. This is the handler-removal path: only
# the labels matching the handler's instantiation are dropped from the
# body's row. A handler `with Reader[Int]` does NOT remove a body's
# `Reader[String]` label.
fn filter_labels_matching(xs: [Label], eff_name: String, tyargs: [Ty],
                           sub: Subst) : [Label] {
  match xs {
    [] -> []
    [h, ...rest] ->
      if h.eff == eff_name and labels_args_unify(h.ty_args, tyargs, sub) {
        filter_labels_matching(rest, eff_name, tyargs, sub)
      } else {
        [h, ...filter_labels_matching(rest, eff_name, tyargs, sub)]
      }
  }
}

# Merge two label lists, deduplicating by (eff name + unifiable
# ty_args). Used when synth_handle stitches the outer row back with
# the body's residual labels.
fn merge_label_lists(a: [Label], b: [Label], sub: Subst) : [Label] {
  match b {
    [] -> a
    [h, ...rest] ->
      if label_present_unifiable(a, h, sub) {
        merge_label_lists(a, rest, sub)
      } else {
        merge_label_lists([h, ...a], rest, sub)
      }
  }
}

# A hole gets a fresh TyVarT and records its source position and the
# current scope snapshot. Named holes with the same name within the
# same decl share a TyVarT so both instances unify to the same type
# (matches the `if ... { ?x } else { ?x }` example in the doc).
fn synth_hole(st: InferState, nm_opt: Option[String], e: Expr) : Inferred {
  match nm_opt {
    Some(nm) -> match find_hole_by_name(st.holes, nm) {
      Some(prior_fresh) -> inferred_leaf(st, TyVarT(prior_fresh), e)
      None -> register_fresh_hole(st, HKHole(nm_opt), e)
    }
    None -> register_fresh_hole(st, HKHole(nm_opt), e)
  }
}

# m7d §1: register a `todo!(msg)` site as a hole-with-kind. Each
# occurrence is independent (no name-based sharing — `todo!` carries
# a free-form message, not an identifier), so we always allocate a
# fresh TyVarT.
fn synth_todo(st: InferState, msg: String, e: Expr) : Inferred =
  register_fresh_hole(st, HKTodo(msg), e)

# m7e §13 — `expr!` typer.
# - Operand must be `Option[T]` or `Result[E, T]` (after substitution).
# - Enclosing function's declared return type must be the matching
#   `Option[U]` or `Result[E, U]` (same `E` — no `From` coercion).
# - Result type of the EBang node is the unwrapped success type `T`.
# Diagnostics name both types; the inner Expr is re-stamped with its
# resolved operand type so the C emitter can pick the correct
# discriminator (`Some` / `Ok`).
fn synth_bang(st: InferState, inner: Expr, line: Int, col: Int) : Inferred {
  let ri = synth(st, inner)
  let it_now = apply_ty(ri.st.sub, ri.ty)
  let inner_typed = with_ty(ri.expr, it_now)
  match it_now {
    TyCon(name, args_) ->
      if name == "Option" {
        match args_ {
          [t] -> bang_finish_option(ri.st, inner_typed, t, line, col)
          _   -> bang_bad_operand(ri.st, it_now, inner_typed, line, col)
        }
      } else if name == "Result" {
        match args_ {
          [e_ty, t] -> bang_finish_result(ri.st, inner_typed, e_ty, t, line, col)
          _ -> bang_bad_operand(ri.st, it_now, inner_typed, line, col)
        }
      } else {
        bang_bad_operand(ri.st, it_now, inner_typed, line, col)
      }
    _ -> bang_bad_operand(ri.st, it_now, inner_typed, line, col)
  }
}

# Validate `Option[t]` against the enclosing return type. The fn must
# return `Option[U]` for some `U` — we extract the U via a fresh
# tyvar so a generic `fn f[a]() : Option[a]` body still type-checks.
fn bang_finish_option(st: InferState, inner_typed: Expr, t: Ty,
                       line: Int, col: Int) : Inferred {
  match st.ret_ty {
    None -> bang_no_enclosing_fn(st, "Option", t, inner_typed, line, col)
    Some(rt) -> {
      let rt_now = apply_ty(st.sub, rt)
      match rt_now {
        TyCon(rname, rargs) ->
          if rname == "Option" {
            match rargs {
              [_] ->
                mk_inferred(st, t, with_ty(mk_expr(EBang(inner_typed), line, col), t))
              _ -> bang_ret_mismatch(st, "Option", t, rt_now, inner_typed, line, col)
            }
          } else {
            bang_ret_mismatch(st, "Option", t, rt_now, inner_typed, line, col)
          }
        _ -> bang_ret_mismatch(st, "Option", t, rt_now, inner_typed, line, col)
      }
    }
  }
}

# Validate `Result[e_ty, t]` against the enclosing return type. The fn
# must return `Result[E, U]` for the same E — we unify e_ty with the
# function's declared error type (no implicit conversion).
fn bang_finish_result(st: InferState, inner_typed: Expr, e_ty: Ty, t: Ty,
                       line: Int, col: Int) : Inferred {
  match st.ret_ty {
    None -> bang_no_enclosing_fn(st, "Result", t, inner_typed, line, col)
    Some(rt) -> {
      let rt_now = apply_ty(st.sub, rt)
      match rt_now {
        TyCon(rname, rargs) ->
          if rname == "Result" {
            match rargs {
              [ret_e_ty, _] -> {
                let st1 = st_unify(st, e_ty, ret_e_ty,
                  "`!` propagation requires the same error type as the enclosing function",
                  line, col)
                mk_inferred(st1, t, with_ty(mk_expr(EBang(inner_typed), line, col), t))
              }
              _ -> bang_ret_mismatch_result(st, e_ty, t, rt_now, inner_typed, line, col)
            }
          } else {
            bang_ret_mismatch_result(st, e_ty, t, rt_now, inner_typed, line, col)
          }
        _ -> bang_ret_mismatch_result(st, e_ty, t, rt_now, inner_typed, line, col)
      }
    }
  }
}

fn bang_bad_operand(st: InferState, found: Ty, inner_typed: Expr,
                     line: Int, col: Int) : Inferred {
  diag_error(st.file, line, col,
    "`!` requires an `Option[T]` or `Result[E, T]` operand")
  diag_note("operand type: #{ty_to_string(found)}")
  diag_help("`!` is reserved for the two compiler-blessed propagation types; convert the value explicitly first")
  let st1 = st_bump_err(st)
  let stub = with_ty(mk_expr(EBang(inner_typed), line, col), TyAny)
  mk_inferred(st1, TyAny, stub)
}

fn bang_no_enclosing_fn(st: InferState, fam: String, t: Ty, inner_typed: Expr,
                         line: Int, col: Int) : Inferred {
  diag_error(st.file, line, col,
    "`!` is only valid inside a function body")
  diag_note("operand type: #{fam}[#{ty_to_string(t)}]")
  diag_help("`!` propagates from the enclosing function; it cannot appear inside a lambda or at top level")
  let st1 = st_bump_err(st)
  let stub = with_ty(mk_expr(EBang(inner_typed), line, col), t)
  mk_inferred(st1, t, stub)
}

fn bang_ret_mismatch(st: InferState, fam: String, t: Ty, ret_ty: Ty,
                      inner_typed: Expr, line: Int, col: Int) : Inferred {
  diag_error(st.file, line, col,
    "`!` on `#{fam}[#{ty_to_string(t)}]` requires the enclosing function to return `#{fam}[U]`")
  diag_note("enclosing return type: #{ty_to_string(ret_ty)}")
  diag_help("change the function's return type, or pattern-match the operand explicitly")
  let st1 = st_bump_err(st)
  let stub = with_ty(mk_expr(EBang(inner_typed), line, col), t)
  mk_inferred(st1, t, stub)
}

fn bang_ret_mismatch_result(st: InferState, e_ty: Ty, t: Ty, ret_ty: Ty,
                             inner_typed: Expr, line: Int, col: Int) : Inferred {
  diag_error(st.file, line, col,
    "`!` on `Result[#{ty_to_string(e_ty)}, #{ty_to_string(t)}]` requires the enclosing function to return `Result[#{ty_to_string(e_ty)}, U]`")
  diag_note("enclosing return type: #{ty_to_string(ret_ty)}")
  diag_help("kaikai does not implicitly convert error types (no `From`); convert the error explicitly or change the function's return type")
  let st1 = st_bump_err(st)
  let stub = with_ty(mk_expr(EBang(inner_typed), line, col), t)
  mk_inferred(st1, t, stub)
}

fn register_fresh_hole(st: InferState, kind: HoleKind, e: Expr) : Inferred {
  let fresh_id = st.env.fresh
  let st1 = st_set_env(st, fresh_var(st.env))
  let site = HS(kind, e.line, e.col, fresh_id, st1.env.entries, st1.env.fresh)
  let st2 = st_push_hole(st1, site)
  inferred_leaf(st2, TyVarT(fresh_id), e)
}

fn find_hole_by_name(holes: [HoleSite], target: String) : Option[Int] {
  match holes {
    [] -> None
    [h, ...rest] -> match h {
      HS(kind, _, _, fresh, _, _) -> match kind {
        HKHole(nm_opt) -> match nm_opt {
          Some(nm) -> if nm == target { Some(fresh) } else { find_hole_by_name(rest, target) }
          None     -> find_hole_by_name(rest, target)
        }
        HKTodo(_) -> find_hole_by_name(rest, target)
      }
    }
  }
}

fn synth_many(st: InferState, es: [Expr]) : InferredList {
  match es {
    [] -> InferredList { st: st, tys: [], exprs: [] }
    [x, ...rest] -> {
      let r = synth(st, x)
      let rr = synth_many(r.st, rest)
      InferredList { st: rr.st, tys: [r.ty, ...rr.tys], exprs: [r.expr, ...rr.exprs] }
    }
  }
}

fn synth_call(st: InferState, callee: Expr, args_: [Expr], line: Int, col: Int) : Inferred {
  # m12.8.x phase 4 (Bug 6): when the callee is a syntactically-bare
  # prelude IO builtin (`print`, `eprint`, `read_line`, `read_file`,
  # `write_file`), accumulate the matching effect label on the
  # caller's row. The op-call pathway already adds labels for
  # explicit `Eff.op(...)` calls; this shim closes the gap for the
  # sugar prelude form so `check_body_row` enforces row declaration
  # uniformly per CLAUDE.md Tier 1 #1.
  let st_p = add_prelude_effect_label(st, callee, line, col)
  match try_resume_call(st_p, callee, args_, line, col) {
    Some(inf) -> inf
    None ->
      match try_op_call(st_p, callee, args_, line, col) {
        Some(inf) -> inf
        None -> {
          let rc = synth(st_p, callee)
          let ra = synth_many(rc.st, args_)
          let rv = st_fresh_ty(ra.st)
          # m7b #12: build the expected function type with an *open*
          # row (a fresh row variable in the tail) so that calling a
          # function whose declared row is non-empty or carries its
          # own row variable doesn't force-bind the callee's tail to
          # the empty row at the call site. The fresh row var absorbs
          # whatever residual labels the callee carries; the caller's
          # effect tracking is handled separately by `st_add_label`
          # for op calls.
          let fr = subst_fresh_row(rv.st.sub)
          let st_fresh = st_set_sub(rv.st, fr.subst)
          let expected_row = Row { labels: [], tail: Some(fr.id), display_alias: None }
          let expected = TyFnT(ra.tys, rv.ty, expected_row)
          let st2 = st_unify(st_fresh, rc.ty, expected, "function call", line, col)
          let ty = apply_ty(st2.sub, rv.ty)
          let root = with_ty(mk_expr(ECall(rc.expr, ra.exprs), line, col), ty)
          mk_inferred(st2, ty, root)
        }
      }
  }
}

# m7b #11l — type-check `resume(v)` / `resume(v, ns)` inside a
# stateful clause body. Returns None when the call is not a resume
# inside a stateful clause (caller falls through to the standard path).
fn try_resume_call(st: InferState, callee: Expr, args_: [Expr],
                    line: Int, col: Int) : Option[Inferred] {
  match callee.kind {
    EVar(name) ->
      if name == "resume" {
        match st.clause_resume {
          None -> None
          Some(rb) -> Some(synth_resume_call(st, rb, args_, callee, line, col))
        }
      } else { None }
    _ -> None
  }
}

fn synth_resume_call(st: InferState, rb: ResumeBind, args_: [Expr],
                      callee: Expr, line: Int, col: Int) : Inferred {
  match rb {
    RB(answer_ty, state_ty) -> {
      let ra = synth_many(st, args_)
      let rv = st_fresh_ty(ra.st)
      # st_unify treats the first arg as `expected` and the second as
      # `found`; the resume answer is what the clause must produce, so
      # answer_ty is the `expected` slot.
      let st_after = match ra.tys {
        [a]     -> st_unify(rv.st, answer_ty, a,
                             "resume answer", line, col)
        [a, ns] -> {
          let s1 = st_unify(rv.st, answer_ty, a,
                              "resume answer", line, col)
          st_unify(s1, state_ty, ns,
                    "resume new state", line, col)
        }
        _ -> {
          diag_error(rv.st.file, line, col,
            "resume call: expected 1 or 2 arguments inside a stateful clause")
          diag_note("`resume(v)` resumes with the answer; `resume(v, ns)` also writes the new handler state")
          diag_help("for `with State[T]` and `with Writer[W]`, use `resume(v, new_state)`; otherwise `resume(v)`")
          st_bump_err(rv.st)
        }
      }
      let ty = apply_ty(st_after.sub, rv.ty)
      let resume_root = with_ty(mk_expr(EVar("resume"), callee.line, callee.col), TyAny)
      let root = with_ty(mk_expr(ECall(resume_root, ra.exprs), line, col), ty)
      mk_inferred(st_after, ty, root)
    }
  }
}

# m7a #4a: detect the surface shape `Eff.op(args)` and treat it as
# an op call. `Eff` must be a declared effect (its op signatures
# were registered under dotted keys by `add_effect_op_sigs`). Args
# are unified against the op's parameter types; the result type
# is the op's return type. Adding `Eff` to the caller's row is
# m7a #4c.
#
# An "effect name" is detected by scanning the env for any entry
# of the form `Eff.<something>` — equivalent to "this name has
# at least one op registered". If `Eff` is an effect but the op
# is missing, we emit a dedicated diagnostic instead of falling
# through to the generic `unknown identifier` path.
fn try_op_call(st: InferState, callee: Expr, args_: [Expr],
               line: Int, col: Int) : Option[Inferred] {
  match callee.kind {
    EField(base, op_name) -> match base.kind {
      EVar(name) -> {
        # First try the literal name (`Io`, `Mutable`, ...).
        let key = string_concat(name, string_concat(".", op_name))
        match ty_env_lookup(st.env, key) {
          Some(sc) -> Some(synth_op_call_with_scheme(st, sc, args_, key, line, col))
          None ->
            if is_effect_in_env(st.env, name) {
              Some(synth_op_call_unknown_op(st, name, op_name, line, col))
            } else {
              # m7a #4e: maybe `name` is an alias bound by an
              # enclosing `handle ... with Eff as name`. Resolve
              # to the underlying effect and retry.
              # m7b #4: `@cap` desugars to `cap.get()` for every
              # capability shape; for a Reader-bound alias the op
              # is `ask`, not `get`. Remap here so the lookup hits.
              match lookup_alias(st.aliases, name) {
                None ->
                  # m12.8 Phase 4b: try type alias (`type Console =
                  # Stdout + Stderr + Stdin`, `type Io = Console + Env
                  # + File`). Find which component effect provides
                  # `op_name` and retry the lookup with that effect's
                  # qualified key. Body row label uses the resolved
                  # effect name so subset checking sees atomic labels
                  # and the runtime evidence stack is queried with
                  # the right key. Ambiguity (multiple components
                  # share an op_name) resolves to the leftmost.
                  match find_alias(st.type_aliases, name) {
                    None -> None
                    Some(AR(_, components)) ->
                      match find_eff_for_alias_op(components, st.op_to_eff, op_name) {
                        None -> None
                        Some(real_eff) -> {
                          let key2 = string_concat(real_eff, string_concat(".", op_name))
                          match ty_env_lookup(st.env, key2) {
                            Some(sc) -> Some(synth_op_call_with_scheme(st, sc, args_, key2, line, col))
                            None ->
                              if is_effect_in_env(st.env, real_eff) {
                                Some(synth_op_call_unknown_op(st, real_eff, op_name, line, col))
                              } else { None }
                          }
                        }
                      }
                  }
                Some(eff) -> {
                  let real_op =
                    if eff == "Reader" and op_name == "get" { "ask" } else { op_name }
                  let lookup_key = string_concat(eff, string_concat(".", real_op))
                  # m7b #15 (compiler integration, scope-limited):
                  # when the alias is taggable (the call site is
                  # in the same lexical scope as the handle's
                  # prologue, no intervening lambda), the
                  # dispatched callee carries an `@<alias>`
                  # suffix so the codegen routes through the
                  # handle's `kai_alias_<a>_id` C local instead
                  # of the innermost name-keyed lookup. Inside a
                  # lambda body the local is out of scope; we
                  # then emit a bare dispatch key so the legacy
                  # name-keyed lookup runs and the closure-
                  # capture path keeps compiling.
                  let taggable = match lookup_alias_taggable(st.aliases, name) {
                    Some(b) -> b
                    None    -> false
                  }
                  let dispatch_key = if taggable {
                    string_concat(lookup_key, string_concat("@", name))
                  } else {
                    lookup_key
                  }
                  match ty_env_lookup(st.env, lookup_key) {
                    Some(sc) -> Some(synth_op_call_with_scheme_keys(st, sc, args_, lookup_key, dispatch_key, line, col))
                    None ->
                      if is_effect_in_env(st.env, eff) {
                        Some(synth_op_call_unknown_op(st, eff, real_op, line, col))
                      } else { None }
                  }
                }
              }
            }
        }
      }
      _ -> None
    }
    _ -> None
  }
}

fn is_effect_in_env(env: TyEnv, eff_name: String) : Bool =
  is_effect_in_env_loop(env.entries, string_concat(eff_name, "."))

fn is_effect_in_env_loop(entries: [TyEntry], prefix: String) : Bool {
  match entries {
    [] -> false
    [e, ...rest] ->
      if string_has_prefix(e.name, prefix) { true }
      else { is_effect_in_env_loop(rest, prefix) }
  }
}

fn string_has_prefix(s: String, p: String) : Bool {
  let pl = string_length(p)
  if string_length(s) < pl { false }
  else { string_slice(s, 0, pl) == p }
}

fn synth_op_call_unknown_op(st: InferState, eff_name: String, op_name: String,
                             line: Int, col: Int) : Inferred {
  diag_error(st.file, line, col,
    string_concat("unknown op `", string_concat(op_name,
      string_concat("` on effect `", string_concat(eff_name, "`")))))
  diag_note("`#{eff_name}.#{op_name}` is not declared in `effect #{eff_name} { ... }`")
  diag_help("declare `#{op_name}(...)` inside the effect, or call an existing op")
  let st1 = st_bump_err(st)
  mk_inferred(st1, TyAny, with_ty(mk_expr(EVar(eff_name), line, col), TyAny))
}

fn synth_op_call_with_scheme(st: InferState, sc: TyScheme, args_: [Expr],
                              key: String, line: Int, col: Int) : Inferred {
  # m7b #15: most call sites pass a single key — both the type
  # lookup key and the codegen dispatch key are the same.
  synth_op_call_with_scheme_keys(st, sc, args_, key, key, line, col)
}

fn synth_op_call_with_scheme_keys(st: InferState, sc: TyScheme, args_: [Expr],
                                   lookup_key: String, dispatch_key: String,
                                   line: Int, col: Int) : Inferred {
  # m7b #11i: capture the fresh ids minted by instantiation. For
  # parametric effects (where the scheme quantifies over the effect's
  # tparams) these fresh tyvars are the row label's ty_args. For
  # stateless effects the list is empty and we add a bare-name label.
  # m7b #2: per-op generic schemes also quantify over op-level
  # tparams; those are NOT part of the row label's ty_args. Use the
  # `op_eff_arities` table to take only the first N fresh ids
  # (corresponding to the effect's tparams) for the row.
  # m7b #15: alias-rewritten op calls carry a `dispatch_key` with an
  # `@<alias>` suffix so codegen can route through the handle's
  # `kai_alias_<a>_id` local. Type-level lookups (op_eff_arities,
  # row label) still use the bare `lookup_key`.
  let inst = st_instantiate_report(st, sc)
  let ra = synth_many(inst.st, args_)
  let rv = st_fresh_ty(ra.st)
  let expected = fn_ty(ra.tys, rv.ty)
  let st2 = st_unify(rv.st, inst.ty, expected, string_concat("op call ", lookup_key), line, col)
  let eff_n = dotted_prefix(lookup_key)
  let eff_arity = lookup_op_eff_arity(st2.op_eff_arities, lookup_key)
  let eff_fresh = take_first(inst.fresh, eff_arity)
  let row_args = resolve_fresh_ids(eff_fresh, st2.sub)
  let lab = Label { eff: eff_n, ty_args: row_args }
  let st3 = st_add_label(st2, lab, line, col)
  let ty = apply_ty(st3.sub, rv.ty)
  let root = with_ty(mk_expr(ECall(callee_expr_for_op(dispatch_key, line, col), ra.exprs), line, col), ty)
  mk_inferred(st3, ty, root)
}

fn lookup_op_eff_arity(table: [OpEffArity], key: String) : Int {
  match table {
    [] -> 0
    [h, ...rest] -> match h {
      OEA(k, n) -> if k == key { n } else { lookup_op_eff_arity(rest, key) }
    }
  }
}

fn take_first(xs: [Int], n: Int) : [Int] {
  if n <= 0 { [] }
  else { match xs {
    [] -> []
    [h, ...rest] -> [h, ...take_first(rest, n - 1)]
  } }
}

# Apply the substitution to a list of fresh-tyvar ids, producing the
# resolved type for each. Avoids an inline lambda that would capture
# the substitution and confuse stage 1's capture analyser.
fn resolve_fresh_ids(ids: [Int], sub: Subst) : [Ty] {
  match ids {
    [] -> []
    [id, ...rest] -> [apply_ty(sub, TyVarT(id)), ...resolve_fresh_ids(rest, sub)]
  }
}

# Extract `Eff` from `Eff.op` so st_add_effect can record only the
# label, not the dotted form.
fn dotted_prefix(s: String) : String =
  dotted_prefix_loop(s, 0, string_length(s))

fn dotted_prefix_loop(s: String, i: Int, n: Int) : String {
  if i >= n { s }
  else {
    match char_at(s, i) {
      Some(c) -> if c == '.' { string_slice(s, 0, i) } else { dotted_prefix_loop(s, i + 1, n) }
      None    -> s
    }
  }
}

# m7a #6c: pair to dotted_prefix. Extract `op` from `Eff.op`.
fn dotted_suffix(s: String) : String =
  dotted_suffix_loop(s, 0, string_length(s))

fn dotted_suffix_loop(s: String, i: Int, n: Int) : String {
  if i >= n { s }
  else {
    match char_at(s, i) {
      Some(c) -> if c == '.' { string_slice(s, i + 1, n) } else { dotted_suffix_loop(s, i + 1, n) }
      None    -> s
    }
  }
}

fn string_contains_dot(s: String) : Bool =
  string_contains_dot_loop(s, 0, string_length(s))

fn string_contains_dot_loop(s: String, i: Int, n: Int) : Bool {
  if i >= n { false }
  else {
    match char_at(s, i) {
      Some(c) -> if c == '.' { true } else { string_contains_dot_loop(s, i + 1, n) }
      None    -> false
    }
  }
}

# m7b #15 (compiler integration) — locate the `@` separator the
# alias rewrite uses to tag op names. Returns the byte index, or
# -1 when no `@` is present.
fn string_index_of_at(s: String) : Int = string_index_of_at_loop(s, 0, string_length(s))

fn string_index_of_at_loop(s: String, i: Int, n: Int) : Int {
  if i >= n { -1 }
  else { match char_at(s, i) {
    Some(c) -> if c == '@' { i } else { string_index_of_at_loop(s, i + 1, n) }
    None    -> -1
  } }
}

# m7b #15: drop the `@<alias>` suffix from a tagged op key. When
# absent, returns the key unchanged.
fn string_strip_alias_tag(s: String) : String {
  let at = string_index_of_at(s)
  if at < 0 { s } else { string_slice(s, 0, at) }
}

# Synthesise a placeholder callee for the typed AST that emit later
# turns into the runtime op-dispatch call. For m7a #4a we keep the
# original surface shape (EField/EVar) so the existing emitter path
# falls through; m7a #6 (lowering) will replace this with a proper
# op-dispatch node.
fn callee_expr_for_op(key: String, line: Int, col: Int) : Expr =
  mk_expr(EVar(key), line, col)

fn field_root(obj_expr: Expr, fnm: String, line: Int, col: Int, ty: Ty) : Expr =
  with_ty(mk_expr(EField(obj_expr, fnm), line, col), ty)

fn synth_field(st: InferState, obj: Expr, fnm: String, line: Int, col: Int) : Inferred {
  let r = synth(st, obj)
  let applied = apply_ty(r.st.sub, r.ty)
  match applied {
    TyCon(cname, _) -> match rec_find(r.st.recs, cname) {
      None -> mk_inferred(r.st, TyAny, field_root(r.expr, fnm, line, col, TyAny))
      Some(ri) -> {
        let inst = rec_instantiate(r.st, ri)
        let st1 = st_unify(inst.st, inst.result_ty, r.ty, "record field access", line, col)
        match fty_find(inst.fields, fnm) {
          Some(t) -> {
            let ty = apply_ty(st1.sub, t)
            mk_inferred(st1, ty, field_root(r.expr, fnm, line, col, ty))
          }
          None -> {
            diag_error(st.file, line, col, "no field '#{fnm}' on #{cname}#{field_hint(inst.fields, fnm)}")
            mk_inferred(st_bump_err(st1), TyAny, field_root(r.expr, fnm, line, col, TyAny))
          }
        }
      }
    }
    _ -> mk_inferred(r.st, TyAny, field_root(r.expr, fnm, line, col, TyAny))
  }
}

fn synth_index(st: InferState, coll: Expr, ix: Expr, line: Int, col: Int) : Inferred {
  let rc = synth(st, coll)
  let ri = synth(rc.st, ix)
  let st1 = st_unify(ri.st, ri.ty, TyInt, "list index", line, col)
  let rv = st_fresh_ty(st1)
  let st2 = st_unify(rv.st, rc.ty, TyListT(rv.ty), "list indexing", line, col)
  let ty = apply_ty(st2.sub, rv.ty)
  let root = with_ty(mk_expr(EIndex(rc.expr, ri.expr), line, col), ty)
  mk_inferred(st2, ty, root)
}

# Binop typing is deliberately coarse: numeric operators unify their
# two operands and return the shared type (usually `Int`); comparison
# operators unify operands and return `Bool`; logical `and`/`or` pin
# both sides to `Bool`; `//` and `%` pin operands to `Int`.
fn binop_root(op: String, l_expr: Expr, r_expr: Expr, line: Int, col: Int, ty: Ty) : Expr =
  with_ty(mk_expr(EBinop(op, l_expr, r_expr), line, col), ty)

fn synth_binop(st: InferState, op: String, l: Expr, r: Expr, line: Int, col: Int) : Inferred {
  let rl = synth(st, l)
  let rr = synth(rl.st, r)
  if op == "++" {
    synth_concat(rr.st, rl.ty, rl.expr, rr.ty, rr.expr, line, col)
  } else if op == "and" or op == "or" {
    let s1 = st_unify(rr.st, rl.ty, TyBool, "boolean operator", line, col)
    let s2 = st_unify(s1, rr.ty, TyBool, "boolean operator", line, col)
    mk_inferred(s2, TyBool, binop_root(op, rl.expr, rr.expr, line, col, TyBool))
  } else if op == "==" or op == "!=" {
    let s1 = st_unify(rr.st, rl.ty, rr.ty, "comparison", line, col)
    mk_inferred(s1, TyBool, binop_root(op, rl.expr, rr.expr, line, col, TyBool))
  } else if op == "<" or op == ">" or op == "<=" or op == ">=" {
    let s1 = st_unify(rr.st, rl.ty, rr.ty, "comparison", line, col)
    mk_inferred(s1, TyBool, binop_root(op, rl.expr, rr.expr, line, col, TyBool))
  } else if op == "//" or op == "%" {
    let s1 = st_unify(rr.st, rl.ty, TyInt, "integer arithmetic", line, col)
    let s2 = st_unify(s1, rr.ty, TyInt, "integer arithmetic", line, col)
    mk_inferred(s2, TyInt, binop_root(op, rl.expr, rr.expr, line, col, TyInt))
  } else if op == "*" or op == "/" {
    # m12.5: multiplication and division of dimensioned values
    # combine units rather than requiring equality. The operand-type
    # rule still requires the *base* numeric types to agree (Real*Real
    # / Int*Int) — we delegate that to synth_dim_mul_div.
    synth_dim_mul_div(rr.st, op, rl.ty, rl.expr, rr.ty, rr.expr, line, col)
  } else {
    # `+` / `-` keep the unify-both-sides rule. The dim-aware unifier
    # checks the unit equality automatically.
    let what = string_concat("arithmetic operator '", string_concat(op, "'"))
    let s1 = st_unify(rr.st, rl.ty, rr.ty, what, line, col)
    let ty = apply_ty(s1.sub, rl.ty)
    mk_inferred(s1, ty, binop_root(op, rl.expr, rr.expr, line, col, ty))
  }
}

# m12.5: type rule for `*` and `/` over (possibly) dimensioned values.
# Splits each operand into (base_ty, unit_expr) — bare Real → unit
# `1`, TyDimT(b, u) → (b, u). The base types are unified; the units
# are combined into the result.
type DimSplit = { base: Ty, dim: UnitExprT }

fn ty_split_dim(t: Ty, s: Subst) : DimSplit {
  match apply_ty(s, t) {
    TyDimT(b, u) -> DimSplit { base: b, dim: u }
    other -> DimSplit { base: other, dim: UOne }
  }
}

fn synth_dim_mul_div(st: InferState, op: String, lt: Ty, le: Expr,
                     rt: Ty, re: Expr, line: Int, col: Int) : Inferred {
  let ls = ty_split_dim(lt, st.sub)
  let rs = ty_split_dim(rt, st.sub)
  let what = string_concat("arithmetic operator '", string_concat(op, "'"))
  let s1 = st_unify(st, ls.base, rs.base, what, line, col)
  let combined = if op == "*" {
    UMul(ls.dim, rs.dim)
  } else {
    UMul(ls.dim, UInv(rs.dim))
  }
  let ty = dim_collapse(apply_ty(s1.sub, ls.base), unit_canon(combined))
  mk_inferred(s1, ty, binop_root(op, le, re, line, col, ty))
}

# m7d §23 — `++` typer. Two hardcoded rules:
#   String ++ String  : String
#   [a]    ++ [a]     : [a]
# We probe the lhs's resolved type first; if it is a TyVar we fall
# back to the rhs's resolved type (mirror case). If neither side
# pins the operator, we report a targeted diagnostic — the
# concatenation operator is intentionally not generic, the way `+`
# is intentionally not overloaded for strings.
fn synth_concat(st: InferState, lt: Ty, le: Expr, rt: Ty, re: Expr, line: Int, col: Int) : Inferred {
  let lt_now = apply_ty(st.sub, lt)
  match lt_now {
    TyString -> concat_finish(st, TyString, lt, le, rt, re, line, col)
    TyListT(elem) -> concat_finish(st, TyListT(elem), lt, le, rt, re, line, col)
    _ -> {
      let rt_now = apply_ty(st.sub, rt)
      match rt_now {
        TyString -> concat_finish(st, TyString, lt, le, rt, re, line, col)
        TyListT(elem) -> concat_finish(st, TyListT(elem), lt, le, rt, re, line, col)
        _ -> {
          diag_error(st.file, line, col,
            "operator `++` requires both operands to be `String` or both to be `[T]`")
          diag_help("annotate one of the operands so the compiler can pick the right rule")
          mk_inferred(st_bump_err(st), TyAny,
            with_ty(mk_expr(EBinop("++", le, re), line, col), TyAny))
        }
      }
    }
  }
}

fn concat_finish(st: InferState, target: Ty, lt: Ty, le: Expr, rt: Ty, re: Expr, line: Int, col: Int) : Inferred {
  let s1 = st_unify(st, lt, target, "concat operator", line, col)
  let s2 = st_unify(s1, rt, target, "concat operator", line, col)
  let result_ty = apply_ty(s2.sub, target)
  let root = with_ty(mk_expr(EBinop("++", le, re), line, col), result_ty)
  mk_inferred(s2, result_ty, root)
}

fn synth_unop(st: InferState, op: String, x: Expr, line: Int, col: Int) : Inferred {
  let r = synth(st, x)
  if op == "not" {
    let s1 = st_unify(r.st, r.ty, TyBool, "logical 'not'", line, col)
    let root = with_ty(mk_expr(EUnop(op, r.expr), line, col), TyBool)
    mk_inferred(s1, TyBool, root)
  } else {
    let root = with_ty(mk_expr(EUnop(op, r.expr), line, col), r.ty)
    mk_inferred(r.st, r.ty, root)
  }
}

fn synth_if(st: InferState, c: Expr, t_: Expr, eo: Option[Expr], line: Int, col: Int) : Inferred {
  let rc = synth(st, c)
  let s1 = st_unify(rc.st, rc.ty, TyBool, "if condition", line, col)
  let rt = synth(s1, t_)
  match eo {
    None -> {
      let root = with_ty(mk_expr(EIf(rc.expr, rt.expr, None), line, col), TyUnit)
      mk_inferred(rt.st, TyUnit, root)
    }
    Some(ee) -> {
      let re = synth(rt.st, ee)
      let s2 = st_unify(re.st, rt.ty, re.ty, "if/else branches", line, col)
      let ty = apply_ty(s2.sub, rt.ty)
      let root = with_ty(mk_expr(EIf(rc.expr, rt.expr, Some(re.expr)), line, col), ty)
      mk_inferred(s2, ty, root)
    }
  }
}

fn synth_lambda(st: InferState, ps: [Param], body: Expr, line: Int, col: Int) : Inferred {
  let outer = st
  let added = add_infer_params(st, ps)
  # m7b #14: walk the body in an isolated row context. Effects
  # invoked inside the lambda body MUST NOT leak to the enclosing
  # function's row — they belong to the lambda type's own row.
  # Same pattern as `synth_handle` (snapshot, reset, walk, restore).
  # m7b #15 (scope-limited): also mark every alias visible at the
  # lambda boundary as non-taggable. The handle's
  # `kai_alias_<a>_id` C local is not in scope across the lambda
  # boundary, so try_op_call's alias-fallback must emit a bare
  # dispatch key (no @-suffix) for op calls inside the body.
  let prev_row = added.st.row
  let st_row = st_set_row(added.st, [])
  let st_in = st_disable_alias_tag(st_row)
  # m7e §13: `e!` propagates from the enclosing function, not from a
  # closure. Clear ret_ty inside the lambda body so any `!` site
  # inside reports a clean diagnostic. st_restore_entries (below)
  # restores ret_ty from `outer` after the walk, so subsequent
  # siblings of the lambda see the function-level ret_ty unchanged.
  let st_in2 = st_set_ret_ty(st_in, None)
  # m12.8.x post-Core REOPEN: same boundary applies to clause_resume.
  # `resume(v)` only makes sense inside the immediate handler clause
  # that introduced it; a lambda lifted out of the clause body does
  # not have access to the clause's continuation. Pre-fix, a lambda
  # inside `raise(resume) -> { (() => resume(v))() }` would type-
  # check `resume(v)` against the outer clause's answer/state types
  # — silently accepting code that, at runtime, calls the wrong
  # continuation. Mirror the alias-tag boundary at line 14294.
  let st_in3 = st_set_clause_resume(st_in2, None)
  let rb = synth(st_in3, body)
  let lambda_row_labels = apply_labels(rb.st.sub, rb.st.row)
  let st_after = st_set_row(rb.st, prev_row)
  let st2 = st_restore_entries(outer, st_after)
  # m12.8.x phase 4 followup: lambdas carry an *open* row with a
  # fresh tail var. Closed rows pinned row-polymorphic call sites
  # too eagerly: `while(pred, body)` would unify the pure-pred's
  # closed-empty row with `while`'s `e`, then reject `body`'s
  # `Stdout` row when the same `e` was already bound to empty.
  # The open form `[labels] + ?eN` lets sibling args' rows unify
  # via Rémy-style tail unification — the row variable absorbs
  # whatever residual labels each arg performs.
  let fr = subst_fresh_row(st2.sub)
  let st3 = st_set_sub(st2, fr.subst)
  let lam_row = Row { labels: lambda_row_labels,
                       tail: Some(fr.id),
                       display_alias: None }
  let lam_ty = TyFnT(apply_tys(st3.sub, added.tys),
                     apply_ty(st3.sub, rb.ty),
                     lam_row)
  let root = with_ty(mk_expr(ELambda(ps, rb.expr), line, col), lam_ty)
  mk_inferred(st3, lam_ty, root)
}

# m7b #14: build a closed Row from a labels list, dropping any
# duplicates that survived the body-row accumulator. Used by
# `synth_lambda` to attach the body's effect set to the lambda
# type itself.
fn labels_to_closed_row(labels: [Label]) : Row =
  Row { labels: labels, tail: None, display_alias: None }

fn synth_list_expr(st: InferState, els: [ListElem], line: Int, col: Int) : Inferred {
  let rv = st_fresh_ty(st)
  let elems = synth_list_elems(rv.st, els, rv.ty, line, col)
  let ty = TyListT(apply_ty(elems.st.sub, rv.ty))
  let root = with_ty(mk_expr(EList(elems.elems), line, col), ty)
  mk_inferred(elems.st, ty, root)
}

fn synth_list_elems(st: InferState, els: [ListElem], elem: Ty, line: Int, col: Int) : InferredElems {
  match els {
    [] -> InferredElems { st: st, elems: [] }
    [el, ...rest] -> match el {
      ElPlain(ex) -> {
        let r = synth(st, ex)
        let s1 = st_unify(r.st, elem, r.ty, "list element", line, col)
        let rr = synth_list_elems(s1, rest, elem, line, col)
        InferredElems { st: rr.st, elems: [ElPlain(r.expr), ...rr.elems] }
      }
      ElSpread(ex) -> {
        let r = synth(st, ex)
        let s1 = st_unify(r.st, TyListT(elem), r.ty, "list spread", line, col)
        let rr = synth_list_elems(s1, rest, elem, line, col)
        InferredElems { st: rr.st, elems: [ElSpread(r.expr), ...rr.elems] }
      }
    }
  }
}

fn synth_range(st: InferState, lo: Expr, hi: Expr, stp: Option[Expr], line: Int, col: Int) : Inferred {
  let rl = synth(st, lo)
  let s1 = st_unify(rl.st, rl.ty, TyInt, "range start", line, col)
  let rh = synth(s1, hi)
  let s2 = st_unify(rh.st, rh.ty, TyInt, "range end", line, col)
  match stp {
    None -> {
      let root = with_ty(mk_expr(ERange(rl.expr, rh.expr, None), line, col), TyListT(TyInt))
      mk_inferred(s2, TyListT(TyInt), root)
    }
    Some(se) -> {
      let rs_ = synth(s2, se)
      let s3 = st_unify(rs_.st, rs_.ty, TyInt, "range step", line, col)
      let root = with_ty(mk_expr(ERange(rl.expr, rh.expr, Some(rs_.expr)), line, col), TyListT(TyInt))
      mk_inferred(s3, TyListT(TyInt), root)
    }
  }
}

# `x |> f(y, z)` pipes `x` into `f` as its first argument. Rather
# than desugar and re-infer, we manually emit the same unify chain
# that an ECall would run, and rebuild EPipe around it so the emitter
# still sees the original shape (stage 2's emitter has its own
# desugaring of EPipe).
type PipeRes = { st: InferState, ty: Ty, rhs: Expr }

fn synth_pipe(st: InferState, lhs: Expr, rhs: Expr, line: Int, col: Int) : Inferred {
  let rl = synth(st, lhs)
  let res = match rhs.kind {
    ECall(f, pa) -> {
      let rf = synth(rl.st, f)
      let ra = synth_many(rf.st, pa)
      let rv = st_fresh_ty(ra.st)
      # m12.8.x phase 4 (Bug 6): same open-row trick `synth_call`
      # uses — let the callee's row tail bind to a fresh row var so
      # `xs |> each(handler)` against a row-polymorphic combinator
      # passes type checking when `handler` carries effect labels.
      let fr = subst_fresh_row(rv.st.sub)
      let st_fresh = st_set_sub(rv.st, fr.subst)
      let expected_row = Row { labels: [], tail: Some(fr.id), display_alias: None }
      let expected = TyFnT([rl.ty, ...ra.tys], rv.ty, expected_row)
      let st2 = st_unify(st_fresh, rf.ty, expected, "pipe call", line, col)
      let ty = apply_ty(st2.sub, rv.ty)
      let typed_rhs = with_ty(mk_expr(ECall(rf.expr, ra.exprs), rhs.line, rhs.col), ty)
      PipeRes { st: st2, ty: ty, rhs: typed_rhs }
    }
    _ -> {
      let rf = synth(rl.st, rhs)
      let rv = st_fresh_ty(rf.st)
      let fr = subst_fresh_row(rv.st.sub)
      let st_fresh = st_set_sub(rv.st, fr.subst)
      let expected_row = Row { labels: [], tail: Some(fr.id), display_alias: None }
      let expected = TyFnT([rl.ty], rv.ty, expected_row)
      let st2 = st_unify(st_fresh, rf.ty, expected, "pipe call", line, col)
      let ty = apply_ty(st2.sub, rv.ty)
      PipeRes { st: st2, ty: ty, rhs: rf.expr }
    }
  }
  let root = with_ty(mk_expr(EPipe(rl.expr, res.rhs), line, col), res.ty)
  mk_inferred(res.st, res.ty, root)
}

# m12.8.x phase 4 (Bug 6): for the syntactically-bare prelude IO
# builtins, accumulate the matching effect label on the caller's
# row. Effect names follow Doc B's catalog: Console covers print
# and eprint, Stdin owns read_line, File owns read_file and
# write_file. The op-call pathway already handles explicit
# `Eff.op(...)` calls; this shim closes the sugar-prelude gap.
fn add_prelude_effect_label(st: InferState, callee: Expr,
                              line: Int, col: Int) : InferState {
  match callee.kind {
    EVar(name) -> match prelude_effect_for(name) {
      Some(eff) -> st_add_effect(st, eff, line, col)
      None      -> st
    }
    _ -> st
  }
}

fn prelude_effect_for(name: String) : Option[String] {
  if name == "print" { Some("Stdout") }
  else if name == "eprint" { Some("Stderr") }
  else if name == "read_line" { Some("Stdin") }
  else if name == "read_file" or name == "write_file" { Some("File") }
  else { None }
}

fn synth_record_lit(st: InferState, nm: String, fis: [FieldInit], line: Int, col: Int) : Inferred {
  match rec_find(st.recs, nm) {
    None -> {
      let r = synth_field_inits(st, fis, [], line, col)
      let ty = TyCon(nm, [])
      let root = with_ty(mk_expr(ERecordLit(nm, r.fis), line, col), ty)
      mk_inferred(r.st, ty, root)
    }
    Some(ri) -> {
      let inst = rec_instantiate(st, ri)
      let r = synth_field_inits(inst.st, fis, inst.fields, line, col)
      let ty = apply_ty(r.st.sub, inst.result_ty)
      let root = with_ty(mk_expr(ERecordLit(nm, r.fis), line, col), ty)
      mk_inferred(r.st, ty, root)
    }
  }
}

fn synth_field_inits(st: InferState, fis: [FieldInit], fields: [FTy], line: Int, col: Int) : InferredFInits {
  match fis {
    [] -> InferredFInits { st: st, fis: [] }
    [fi, ...rest] -> match fi {
      FI(fnm, ex) -> {
        let r = synth(st, ex)
        let s1 = match fty_find(fields, fnm) {
          None -> r.st
          Some(ft) -> {
            let what = string_concat("record field '", string_concat(fnm, "'"))
            st_unify(r.st, ft, r.ty, what, line, col)
          }
        }
        let rr = synth_field_inits(s1, rest, fields, line, col)
        InferredFInits { st: rr.st, fis: [FI(fnm, r.expr), ...rr.fis] }
      }
    }
  }
}

fn synth_block(st: InferState, stmts: [Stmt], tail: Option[Expr], line: Int, col: Int) : Inferred {
  let outer = st
  let is = synth_stmts(st, stmts)
  let rt_kind = match tail {
    None     -> BlockTail { st: is.st, ty: TyUnit, expr_opt: None }
    Some(te) -> {
      let r = synth(is.st, te)
      BlockTail { st: r.st, ty: r.ty, expr_opt: Some(r.expr) }
    }
  }
  let st2 = st_restore_entries(outer, rt_kind.st)
  let ty = apply_ty(st2.sub, rt_kind.ty)
  let root = with_ty(mk_expr(EBlock(is.stmts, rt_kind.expr_opt), line, col), ty)
  mk_inferred(st2, ty, root)
}

# Local record so the two `match tail` branches return the same
# shape; kaikai-minimal has no tuples.
type BlockTail = { st: InferState, ty: Ty, expr_opt: Option[Expr] }

type OneStmt = { st: InferState, stmt: Stmt }
type InferredOptExpr = { st: InferState, expr: Option[Expr] }

fn synth_stmts(st: InferState, stmts: [Stmt]) : InferredStmts {
  match stmts {
    [] -> InferredStmts { st: st, stmts: [] }
    [one, ...rest] -> {
      let r = synth_stmt(st, one)
      let rr = synth_stmts(r.st, rest)
      InferredStmts { st: rr.st, stmts: [r.stmt, ...rr.stmts] }
    }
  }
}

fn synth_stmt(st: InferState, stmt: Stmt) : OneStmt {
  match stmt {
    SLet(pat, ann, rhs) -> {
      let rr = synth(st, rhs)
      let binding_st = match ann {
        None -> rr.st
        Some(te) -> {
          let declared = resolve_ty(te)
          st_unify(rr.st, declared, rr.ty, "let annotation", pat.line, pat.col)
        }
      }
      let binding_ty = match ann {
        None -> rr.ty
        Some(te) -> resolve_ty(te)
      }
      let after = check_pattern(binding_st, pat, binding_ty)
      OneStmt { st: after, stmt: SLet(pat, ann, rr.expr) }
    }
    SAssert(cond, msg) -> {
      let rc = synth(st, cond)
      let s1 = st_unify(rc.st, rc.ty, TyBool, "assert condition", cond.line, cond.col)
      let rm = match msg {
        None -> InferredOptExpr { st: s1, expr: None }
        Some(mx) -> {
          let r = synth(s1, mx)
          InferredOptExpr { st: r.st, expr: Some(r.expr) }
        }
      }
      OneStmt { st: rm.st, stmt: SAssert(rc.expr, rm.expr) }
    }
    SExprStmt(ex) -> {
      let r = synth(st, ex)
      OneStmt { st: r.st, stmt: SExprStmt(r.expr) }
    }
    # m7b #6: index-assign desugars away pre-resolve; this arm is dead
    # code in normal compilation but keeps the match exhaustive.
    SIndexAssign(b, i, v, line, col) -> {
      let rb = synth(st, b)
      let ri = synth(rb.st, i)
      let rv = synth(ri.st, v)
      OneStmt { st: rv.st, stmt: SIndexAssign(rb.expr, ri.expr, rv.expr, line, col) }
    }
    # m7b #5: `var name = init` — desugar pass not yet implemented.
    # The resolve pass (chk_stmt) already emits the explicit "not yet
    # implemented" diagnostic and short-circuits before infer normally
    # runs. If a future caller invokes inference on the raw AST, return
    # the init's type without binding `name`, so we never silently
    # produce a `let`-equivalent.
    SVar(name, ann, rhs, line, col) -> {
      let rr = synth(st, rhs)
      OneStmt { st: rr.st, stmt: SVar(name, ann, rr.expr, line, col) }
    }
  }
}

# ---- patterns ----

fn check_pattern(st: InferState, pat: Pattern, expected: Ty) : InferState {
  match pat.pkind {
    PWild      -> st
    PBind(nm)  -> {
      let env2 = ty_env_add(st.env, nm, mono(apply_ty(st.sub, expected)))
      st_set_env(st, env2)
    }
    PLit(lit)  -> {
      let r = synth(st, lit)
      st_unify(r.st, expected, r.ty, "literal pattern", pat.line, pat.col)
    }
    PList(subpats, rest_opt) -> {
      let rv = st_fresh_ty(st)
      let s1 = st_unify(rv.st, expected, TyListT(rv.ty), "list pattern", pat.line, pat.col)
      let s2 = check_list_subpats(s1, subpats, rv.ty)
      match rest_opt {
        None -> s2
        Some(rnm) -> {
          let env2 = ty_env_add(s2.env, rnm, mono(TyListT(apply_ty(s2.sub, rv.ty))))
          st_set_env(s2, env2)
        }
      }
    }
    PVariant(cname, sub_pats) ->
      check_variant_pattern(st, cname, sub_pats, expected, pat.line, pat.col)
    PVariantRecord(cname, pfs) ->
      check_variant_record_pattern(st, cname, pfs, expected, pat.line, pat.col)
    PRecord(pfs) ->
      check_record_pattern(st, pfs, expected, pat.line, pat.col)
    PHole(nm_opt) -> check_hole_pattern(st, nm_opt, expected, pat.line, pat.col)
    # m7d §14: bind the as-name to the scrutinee at the *expected*
    # type, then continue typing the inner pattern at the same type.
    # The inner pattern owns its own bindings; the as-binding adds
    # one more name that aliases the whole scrutinee.
    PAs(nm, sub) -> {
      let env2 = ty_env_add(st.env, nm, mono(apply_ty(st.sub, expected)))
      check_pattern(st_set_env(st, env2), sub, expected)
    }
  }
}

# A hole in pattern position behaves like PWild at runtime (matches
# anything, binds nothing) but additionally registers a HoleSite so
# the report surfaces the expected pattern type and the scope. For
# named pattern holes we reuse the same name-sharing rule as the
# expression form: two `?x` in the same decl unify to one TyVar.
fn check_hole_pattern(st: InferState, nm_opt: Option[String], expected: Ty, line: Int, col: Int) : InferState {
  let expected_now = apply_ty(st.sub, expected)
  match nm_opt {
    Some(nm) -> match find_hole_by_name(st.holes, nm) {
      Some(prior_fresh) -> st_unify(st, TyVarT(prior_fresh), expected_now, "pattern hole", line, col)
      None -> register_fresh_pattern_hole(st, nm_opt, expected_now, line, col)
    }
    None -> register_fresh_pattern_hole(st, nm_opt, expected_now, line, col)
  }
}

fn register_fresh_pattern_hole(st: InferState, nm_opt: Option[String], expected: Ty, line: Int, col: Int) : InferState {
  let fresh_id = st.env.fresh
  let st1 = st_set_env(st, fresh_var(st.env))
  let site = HS(HKHole(nm_opt), line, col, fresh_id, st1.env.entries, st1.env.fresh)
  let st2 = st_push_hole(st1, site)
  st_unify(st2, TyVarT(fresh_id), expected, "pattern hole", line, col)
}

fn check_list_subpats(st: InferState, ps: [Pattern], elem: Ty) : InferState {
  match ps {
    [] -> st
    [p, ...rest] -> check_list_subpats(check_pattern(st, p, elem), rest, elem)
  }
}

fn check_variant_pattern(st: InferState, cname: String, subpats: [Pattern], expected: Ty, line: Int, col: Int) : InferState {
  match ty_env_lookup(st.env, cname) {
    None -> {
      let hint = match closest_name(cname, ty_env_uppercase_names(st.env)) {
        Some(sug) -> " (did you mean `#{sug}`?)"
        None      -> ""
      }
      diag_error(st.file, line, col, "unknown variant '#{cname}'#{hint}")
      check_unknown_subpats(st_bump_err(st), subpats)
    }
    Some(sc) -> {
      let inst = st_instantiate(st, sc)
      match inst.ty {
        TyFnT(aps, ret, _) -> {
          let what = string_concat("variant pattern '", string_concat(cname, "'"))
          let s1 = st_unify(inst.st, expected, ret, what, line, col)
          check_subpat_list(s1, subpats, aps, line, col)
        }
        _ -> {
          let what = string_concat("variant pattern '", string_concat(cname, "'"))
          let s1 = st_unify(inst.st, expected, inst.ty, what, line, col)
          match subpats {
            [] -> s1
            _  -> {
              diag_error(st.file, line, col, "variant '#{cname}' takes no args but pattern has #{int_to_string(list_length(subpats))}")
              st_bump_err(s1)
            }
          }
        }
      }
    }
  }
}

fn check_unknown_subpats(st: InferState, ps: [Pattern]) : InferState {
  match ps {
    [] -> st
    [p, ...rest] -> check_unknown_subpats(check_pattern(st, p, TyAny), rest)
  }
}

fn check_subpat_list(st: InferState, ps: [Pattern], tys: [Ty], line: Int, col: Int) : InferState {
  variant_arity_check(st, ps, tys, line, col, list_length(tys), list_length(ps))
}

fn variant_arity_check(st: InferState, ps: [Pattern], tys: [Ty],
                        line: Int, col: Int, expected: Int, found: Int) : InferState {
  match ps {
    [] -> match tys {
      [] -> st
      _  -> {
        diag_error(st.file, line, col, "variant pattern has too few sub-patterns")
        diag_note("expected #{int_to_string(expected)}, found #{int_to_string(found)}")
        diag_help("add #{int_to_string(expected - found)} more sub-pattern(s), or use a wildcard `_` for each")
        st_bump_err(st)
      }
    }
    [p, ...pr] -> match tys {
      [] -> {
        diag_error(st.file, line, col, "variant pattern has too many sub-patterns")
        diag_note("expected #{int_to_string(expected)}, found #{int_to_string(found)}")
        diag_help("remove #{int_to_string(found - expected)} sub-pattern(s) so the count matches the variant's declared arity")
        st_bump_err(st)
      }
      [t, ...tr] -> variant_arity_check(check_pattern(st, p, t), pr, tr, line, col, expected, found)
    }
  }
}

fn check_variant_record_pattern(st: InferState, cname: String, pfs: [PField], expected: Ty, line: Int, col: Int) : InferState {
  match rec_find(st.recs, cname) {
    None -> check_unknown_pfields(st, pfs)
    Some(ri) -> {
      let inst = rec_instantiate(st, ri)
      let what = string_concat("record pattern '", string_concat(cname, "'"))
      let s1 = st_unify(inst.st, expected, inst.result_ty, what, line, col)
      check_pfield_list(s1, pfs, inst.fields, line, col)
    }
  }
}

fn check_record_pattern(st: InferState, pfs: [PField], expected: Ty, line: Int, col: Int) : InferState {
  let applied = apply_ty(st.sub, expected)
  match applied {
    TyCon(nm, _) -> match rec_find(st.recs, nm) {
      None -> check_unknown_pfields(st, pfs)
      Some(ri) -> {
        let inst = rec_instantiate(st, ri)
        let s1 = st_unify(inst.st, expected, inst.result_ty, "record pattern", line, col)
        check_pfield_list(s1, pfs, inst.fields, line, col)
      }
    }
    _ -> check_unknown_pfields(st, pfs)
  }
}

fn check_unknown_pfields(st: InferState, pfs: [PField]) : InferState {
  match pfs {
    [] -> st
    [pf, ...rest] -> match pf {
      PField(_, sub, _) -> check_unknown_pfields(check_pattern(st, sub, TyAny), rest)
    }
  }
}

fn check_pfield_list(st: InferState, pfs: [PField], fields: [FTy], line: Int, col: Int) : InferState {
  match pfs {
    [] -> st
    [pf, ...rest] -> match pf {
      PField(fnm, sub, _) -> {
        let s1 = match fty_find(fields, fnm) {
          Some(ft) -> check_pattern(st, sub, ft)
          None -> {
            diag_error(st.file, line, col, "no field '#{fnm}' in record pattern#{field_hint(fields, fnm)}")
            check_pattern(st_bump_err(st), sub, TyAny)
          }
        }
        check_pfield_list(s1, rest, fields, line, col)
      }
    }
  }
}

# ---- match ----

fn synth_match(st: InferState, scr: Expr, arms: [Arm], line: Int, col: Int) : Inferred {
  let rs_ = synth(st, scr)
  let rv = st_fresh_ty(rs_.st)
  let ra = synth_arms(rv.st, arms, rs_.ty, rv.ty, line, col)
  let ty = apply_ty(ra.st.sub, rv.ty)
  let scr_final = apply_ty(ra.st.sub, rs_.ty)
  let st_post = check_exhaustive(ra.st, arms, scr_final, line, col)
  let root = with_ty(mk_expr(EMatch(rs_.expr, ra.arms), line, col), ty)
  mk_inferred(st_post, ty, root)
}

# ---- exhaustiveness checking ----
#
# Flag match expressions that miss a constructor of a known sum
# type. Scope: built-in Option / Result and any user sum whose
# TyCon name appears in the env. "Known variants" is derived by
# walking the env and collecting uppercase-lead entries whose
# return type is that TyCon — cheap since errors are the only
# callers.

fn is_catch_all_pat(pat: Pattern) : Bool {
  match pat.pkind {
    PWild     -> true
    PBind(_)  -> true
    PHole(_)  -> true
    # m7d §14: `name @ catch_all` is itself a catch-all — the binding
    # does not narrow the cases the arm covers.
    PAs(_, sub) -> is_catch_all_pat(sub)
    _         -> false
  }
}

fn has_catch_all(arms: [Arm]) : Bool {
  match arms {
    [] -> false
    [a, ...rest] -> match a {
      Arm(pat, guard, _) -> {
        let catch = is_catch_all_pat(pat)
        let unguarded = match guard { None -> true Some(_) -> false }
        if catch and unguarded { true }
        else { has_catch_all(rest) }
      }
    }
  }
}

fn variant_name_of_arm(a: Arm) : Option[String] {
  match a {
    Arm(pat, _, _) -> variant_name_of_pat(pat)
  }
}

# m7d §14: drill through `name @ inner` so `Some(x) @ pat` and
# similar shapes still report their variant for exhaustiveness.
fn variant_name_of_pat(pat: Pattern) : Option[String] {
  match pat.pkind {
    PVariant(nm, _)       -> Some(nm)
    PVariantRecord(nm, _) -> Some(nm)
    PAs(_, sub)           -> variant_name_of_pat(sub)
    _                     -> None
  }
}

fn arms_cover_variant(arms: [Arm], target: String) : Bool {
  match arms {
    [] -> false
    [a, ...rest] -> match variant_name_of_arm(a) {
      Some(nm) -> if nm == target { true } else { arms_cover_variant(rest, target) }
      None     -> arms_cover_variant(rest, target)
    }
  }
}

fn extract_return_tycon(sc: TyScheme) : Option[String] {
  match sc {
    Scheme(_, _, _, ty) -> match ty {
      TyFnT(_, ret, _) -> match ret {
        TyCon(nm, _) -> Some(nm)
        _            -> None
      }
      TyCon(nm, _) -> Some(nm)
      _            -> None
    }
  }
}

fn variants_of_type_loop(es: [TyEntry], target: String, acc: [String]) : [String] {
  match es {
    [] -> list_reverse(acc)
    [e, ...rest] -> {
      # Effect ops are registered as `Eff.op` (m7a #4a) — those
      # names also start uppercase but are not sum-type constructors,
      # so the exhaustiveness check would otherwise treat them as
      # missing variants of any matching return type.
      let first_upper = match char_at(e.name, 0) {
        Some(c) -> c >= 'A' and c <= 'Z'
        None    -> false
      }
      if first_upper and not string_contains_dot(e.name) {
        match extract_return_tycon(e.scheme) {
          Some(tn) -> if tn == target {
            variants_of_type_loop(rest, target, [e.name, ...acc])
          } else {
            variants_of_type_loop(rest, target, acc)
          }
          None -> variants_of_type_loop(rest, target, acc)
        }
      } else {
        variants_of_type_loop(rest, target, acc)
      }
    }
  }
}

fn variants_of_type(env: TyEnv, tycon: String) : [String] =
  variants_of_type_loop(env.entries, tycon, [])

fn find_missing_variants(needed: [String], arms: [Arm], acc: [String]) : [String] {
  match needed {
    [] -> list_reverse(acc)
    [v, ...rest] -> {
      if arms_cover_variant(arms, v) {
        find_missing_variants(rest, arms, acc)
      } else {
        find_missing_variants(rest, arms, [v, ...acc])
      }
    }
  }
}

fn check_exhaustive(st: InferState, arms: [Arm], scr_ty: Ty, line: Int, col: Int) : InferState {
  if has_catch_all(arms) { st }
  else {
    match scr_ty {
      TyCon(tycon, _) -> {
        let needed = variants_of_type(st.env, tycon)
        match needed {
          [] -> st                     # unknown sum (e.g. Int, lists): skip
          _  -> {
            let missing = find_missing_variants(needed, arms, [])
            match missing {
              [] -> st
              _  -> {
                diag_error(st.file, line, col,
                  "non-exhaustive match on #{tycon}: missing #{join_with(missing, ", ")}")
                diag_help("add an arm for each missing variant, or a wildcard `_` arm")
                st_bump_err(st)
              }
            }
          }
        }
      }
      TyListT(_) -> check_list_exhaustive(st, arms, line, col)
      _ -> st
    }
  }
}

# A list match is exhaustive when (a) some unguarded arm matches the
# empty list `[]` and (b) some unguarded arm matches at least one
# non-empty shape. Any spread-bearing list pattern (`[_, ...rest]`,
# `[a, b, ...rest]`, …) collectively covers every list of length ≥
# its fixed portion; requiring one such arm is a pragmatic cover for
# non-empty. Fixed-length arms alone leave gaps (e.g. `[a]` matches
# size 1 only) — we flag that.

fn arm_pat_empty_list(a: Arm) : Bool {
  match a {
    Arm(pat, guard, _) -> {
      let unguarded = match guard { None -> true Some(_) -> false }
      if not unguarded { false } else { pat_is_empty_list(pat) }
    }
  }
}

# m7d §14: drill through `name @ inner` for the list-exhaustiveness
# helpers so an as-pattern wrapping `[]` or `[_, ...rest]` still
# satisfies the check.
fn pat_is_empty_list(pat: Pattern) : Bool {
  match pat.pkind {
    PList(ps, rest_opt) -> match ps {
      [] -> match rest_opt { None -> true Some(_) -> false }
      _  -> false
    }
    PAs(_, sub) -> pat_is_empty_list(sub)
    _ -> false
  }
}

fn arm_pat_spread_list(a: Arm) : Bool {
  match a {
    Arm(pat, guard, _) -> {
      let unguarded = match guard { None -> true Some(_) -> false }
      if not unguarded { false } else { pat_is_spread_list(pat) }
    }
  }
}

fn pat_is_spread_list(pat: Pattern) : Bool {
  match pat.pkind {
    PList(_, rest_opt) -> match rest_opt {
      Some(_) -> true
      None    -> false
    }
    PAs(_, sub) -> pat_is_spread_list(sub)
    _ -> false
  }
}

fn any_arm(arms: [Arm], pred: (Arm) -> Bool) : Bool {
  match arms {
    [] -> false
    [a, ...rest] -> if pred(a) { true } else { any_arm(rest, pred) }
  }
}

fn check_list_exhaustive(st: InferState, arms: [Arm], line: Int, col: Int) : InferState {
  let has_empty  = any_arm(arms, arm_pat_empty_list)
  let has_spread = any_arm(arms, arm_pat_spread_list)
  if has_empty and has_spread { st }
  else {
    let missing = if has_empty { "non-empty lists (e.g. `[_, ...rest]`)" }
                  else if has_spread { "the empty list `[]`" }
                  else { "the empty list `[]` and non-empty lists (e.g. `[_, ...rest]`)" }
    diag_error(st.file, line, col, "non-exhaustive match on list: missing #{missing}")
    diag_help("cover both `[]` and a spread pattern, or add a wildcard `_` arm")
    st_bump_err(st)
  }
}

fn synth_arms(st: InferState, arms: [Arm], scrut_ty: Ty, body_ty: Ty, line: Int, col: Int) : InferredArms {
  match arms {
    [] -> InferredArms { st: st, arms: [] }
    [a, ...rest] -> match a {
      Arm(pat, guard, body) -> {
        let outer = st
        let s_p = check_pattern(st, pat, scrut_ty)
        let guard_res = match guard {
          None -> InferredOptExpr { st: s_p, expr: None }
          Some(gx) -> {
            let rg = synth(s_p, gx)
            let s_g = st_unify(rg.st, rg.ty, TyBool, "match guard", gx.line, gx.col)
            InferredOptExpr { st: s_g, expr: Some(rg.expr) }
          }
        }
        let rb = synth(guard_res.st, body)
        let s_b = st_unify(rb.st, body_ty, rb.ty, "match arm", body.line, body.col)
        let s_scoped = st_restore_entries(outer, s_b)
        let rr = synth_arms(s_scoped, rest, scrut_ty, body_ty, line, col)
        InferredArms { st: rr.st, arms: [Arm(pat, guard_res.expr, rb.expr), ...rr.arms] }
      }
    }
  }
}

# ---- per-decl entry + dumper ----

fn print_inferred_fn(nm: String, final_ret: Ty, param_tys: [Ty], line: Int, col: Int) : Unit / Console {
  let fn_t = fn_ty(param_tys, final_ret)
  print("fn #{nm} : #{ty_to_string(fn_t)} @#{int_to_string(line)}:#{int_to_string(col)}")
}

# A CallSite whose fresh var ids have been resolved via the final
# substitution to concrete types. Consumed by monomorphisation later
# and surfaced as-is by `--dump-mono`.
type ResolvedCS = RCS(String, Int, Int, [Ty])       # name, line, col, concrete tys

fn resolve_callsite_tys(ids: [Int], sub: Subst) : [Ty] {
  match ids {
    [] -> []
    [i, ...rest] -> [apply_ty(sub, TyVarT(i)), ...resolve_callsite_tys(rest, sub)]
  }
}

fn resolve_callsites(css: [CallSite], sub: Subst) : [ResolvedCS] {
  match css {
    [] -> []
    [cs, ...rest] -> match cs {
      CS(nm, line, col, ids) ->
        [RCS(nm, line, col, resolve_callsite_tys(ids, sub)), ...resolve_callsites(rest, sub)]
    }
  }
}

# A hole resolved against the final substitution: the expected type
# is the TyVarT ran through sub, which usually pins to a concrete
# type from context but can remain a TyVarT if the hole sits in a
# position that doesn't constrain (e.g. the whole body of a fn with
# no declared return).
type ResolvedHole = RH(HoleKind, Int, Int, Ty, [TyEntry], Int)
#                       kind     line col expected scope     env_fresh

fn take_entries(es: [TyEntry], n: Int, acc: [TyEntry]) : [TyEntry] {
  if n <= 0 { list_reverse(acc) }
  else { match es {
    [] -> list_reverse(acc)
    [h, ...rest] -> take_entries(rest, n - 1, [h, ...acc])
  } }
}

fn drop_last_entries(es: [TyEntry], n: Int) : [TyEntry] {
  let total = list_length(es)
  let keep = total - n
  if keep <= 0 { [] } else { take_entries(es, keep, []) }
}

fn resolve_holes(hs: [HoleSite], sub: Subst) : [ResolvedHole] {
  match hs {
    [] -> []
    [h, ...rest] -> match h {
      HS(kind, line, col, fresh, scope, env_fresh) ->
        [RH(kind, line, col, apply_ty(sub, TyVarT(fresh)), scope, env_fresh),
         ...resolve_holes(rest, sub)]
    }
  }
}

# Decls after inference: type-annotated body (or original decl for
# non-DFn). Also carries the error count, the resolved call-site
# instantiations, and the resolved hole reports.
type TypedDecl = { decl: Decl, errs: Int, insts: [ResolvedCS], holes: [ResolvedHole] }

# Walk to the expression whose type is what the function body
# "produces". For block bodies that's the tail expression (or the
# block's closing brace if tail is absent). This lets return-type
# mismatches point at the offending expression instead of the `fn`
# header.
fn return_site_of(e: Expr) : Expr {
  match e.kind {
    EBlock(_, opt_tail) -> match opt_tail {
      Some(tail) -> return_site_of(tail)
      None       -> e
    }
    _ -> e
  }
}

fn infer_decl(file: String, env: TyEnv, prelude_len: Int, recs: [RecInfo],
              op_eff_arities: [OpEffArity],
              type_aliases: [AliasResult], op_to_eff: [OpToEff],
              d: Decl, verbose: Bool) : TypedDecl {
  match d {
    DFn(is_pub, nm, tparams, ps, opt_ret, row, body, line, col) -> {
      # m7b #12: row-variable binding context for this decl. The
      # bound ids match those produced by fn_scheme_of_decl so the
      # body's params and any internal references to row-poly user
      # functions agree with the scheme stored in the env. The
      # inferencer's row_fresh counter is advanced past the highest
      # bound id, so future fresh row vars can never alias these.
      # m7b #13: same idea for tpbinds — fn-level tparams resolve
      # to small bound ids reused by the inferencer when fresh-
      # instantiating at call sites.
      let rbinds = mk_rvbinds(collect_decl_rvars(d))
      # R1 fix (2026-04-26): pick up implicit lowercase tparams the
      # signature uses but did not declare in `[…]`, matching the
      # set fn_scheme_of_decl built into the registered scheme.
      let implicit = collect_implicit_tparams_in_decl(d, tparams)
      let effective_tparams = list_append(tparams, implicit)
      let tpbinds = mk_tpbinds(effective_tparams)
      let st_init = infer_state_new_full_aliases(file, env, prelude_len, recs,
                                                    op_eff_arities, type_aliases, op_to_eff)
      let st0 = advance_row_fresh(st_init, list_length(rbinds))
      # m7b #13 follow-up (surfaced by m8 #3's typed Spawn wrappers):
      # mk_tpbinds allocates ids 0..n-1 for the fn-level tparams, but
      # infer_state_new starts env.fresh at 0 too. Without bumping the
      # counter past the tparam ids, the first fresh ty-var minted in
      # the body (e.g., the result of synth_op_call_with_scheme inside
      # `pub fn fiber_spawn[T, e](...) = Spawn.spawn(f)`) aliases `T`,
      # which then fails the return-type unify with an occurs-check
      # error ("expected: Fiber[?t0], found: ?t0"). Advance the env's
      # fresh counter past the tpbinds the same way we already advance
      # the row_fresh counter past the rbinds above.
      let st0a = st_set_env(st0, advance_fresh(st0.env, list_length(tpbinds)))
      let added = add_infer_params_with_binds(st0a, ps, tpbinds, rbinds)
      # m12.8 Phase 4b follow-up: when the user omits the return-type
      # annotation, infer it from the body's actual type. The
      # `fn x() = expr` form (and `fn x() { ... last_expr }`) signals
      # "the function's value is the body's value", so forcing TyUnit
      # would break programs whose tail produces a real value (the
      # canonical case is `fn main() = { ... 0 }` returning Int).
      # The scheme registered earlier in `fn_scheme_of_decl` still
      # assumes TyUnit when opt_ret is None — fine for `main` (never
      # called from user code); a future pass threading the inferred
      # return into the scheme is the proper fix for callable helpers.
      let opt_declared = match opt_ret {
        Some(rty) -> Some(resolve_ty_with_binds(rty, tpbinds, rbinds))
        None      -> None
      }
      # m7e §13: thread the declared return type through the body walk
      # so `e!` can validate the propagation target. Cleared on entry
      # to lambda bodies (synth_lambda) — `!` does not propagate from
      # closures.
      let st_ready = st_set_ret_ty(added.st, opt_declared)
      let rb = synth(st_ready, body)
      let what = string_concat("return type of ", nm)
      let ret_site = return_site_of(body)
      let declared_ret = match opt_declared {
        Some(rty) -> rty
        None      -> rb.ty
      }
      let st1 = match opt_declared {
        Some(rty) -> st_unify(rb.st, rty, rb.ty, what, ret_site.line, ret_site.col)
        None      -> rb.st
      }
      # m8 #6: shallow region-brand check. The full brand machinery
      # (Doc B / structured-concurrency.md §*Type system*) tags every
      # Fiber[T] / Pid[Msg] handle with the brand of its enclosing
      # nursery scope and rejects values whose brand has expired.
      # That is significant typer work and lands together with the
      # m8.x ucontext or full-CPS scheduler. v1 ships the pragmatic
      # syntactic approximation: any function declared OUTSIDE
      # stdlib/ whose declared return type contains Fiber[T] (at any
      # nesting depth — list, option, record, etc.) is rejected at
      # the type-annotation line. Internal stdlib helpers
      # (fiber_spawn, etc.) are exempt by file-path because they are
      # the legitimate constructors of Fiber[T] values.
      let st1b = check_no_fiber_escape(st1, file, nm, opt_ret, line, col)
      let st2 = check_body_row(st1b, nm, row, line, col)
      let _ = if verbose {
        print_inferred_fn(nm, apply_ty(st2.sub, declared_ret), apply_tys(st2.sub, added.tys), line, col)
      } else { () }
      let resolved = resolve_callsites(list_reverse(st2.insts), st2.sub)
      let hole_reports = resolve_holes(list_reverse(st2.holes), st2.sub)
      # m12.8.x phase 2 (Bug 2): apply the final substitution to every
      # `Expr.ty` annotation in the body so the post-inference protocol-
      # call rewrite can read concrete head types from sites whose
      # `synth` saved a TyVar that later unified with a concrete type
      # — most visibly the parameters of lambdas passed to generic
      # higher-order ops (`each`, `map`, `filter`).
      let final_body = finalise_typed_expr(st2.sub, rb.expr)
      TypedDecl {
        decl: DFn(is_pub, nm, tparams, ps, opt_ret, row, final_body, line, col),
        errs: st2.errs,
        insts: resolved,
        holes: hole_reports
      }
    }
    _ -> TypedDecl { decl: d, errs: 0, insts: [], holes: [] }
  }
}

# Walk a typed Expr applying the per-decl substitution to every
# `Expr.ty`. Recurses through every kind that contains sub-Exprs.
# Patterns and Stmts are walked too because they hold Exprs whose
# `ty` field is read by downstream passes (notably the protocol-call
# rewrite). Pure structural; no type checking, no error production.
fn finalise_typed_expr(s: Subst, e: Expr) : Expr {
  let ty1 = match e.ty {
    Some(t) -> Some(apply_ty(s, t))
    None    -> None
  }
  Expr { kind: finalise_typed_kind(s, e.kind),
         line: e.line, col: e.col, ty: ty1 }
}

fn finalise_typed_kind(s: Subst, k: ExprKind) : ExprKind =
  # Pure structural recursion: every kind delegates to the visitor,
  # which threads `finalise_typed_expr` through every sub-Expr. The
  # per-Expr work (applying `apply_ty(s, t)` to `e.ty`) lives in
  # `finalise_typed_expr` itself, so the closure in the visitor
  # carries it through automatically.
  map_expr_kind(k, (sub) => finalise_typed_expr(s, sub))

# m8 #6: shallow region-brand check on Fiber[T]. Walks the type
# annotation (the user-written TypeExpr, not the resolved Ty, so
# the diagnostic can point at the exact text the user wrote) and
# rejects any occurrence of `Fiber[...]` in the return-type
# position of a fn that is NOT one of the legitimate stdlib
# producers (`fiber_spawn` family in stdlib/spawn.kai). See the
# comment at the call site in infer_decl for the design trade-off
# (path-based exemption doesn't work because import decls inherit
# the importer's file path through expand_imports).
fn check_no_fiber_escape(st: InferState, file: String, fname: String,
                          opt_ret: Option[TypeExpr], line: Int, col: Int) : InferState {
  if is_fiber_producer_helper(fname) { st }
  else {
    match opt_ret {
      None -> st
      Some(rty) -> {
        if ty_expr_contains_fiber(rty) {
          let lline = if rty.line > 0 { rty.line } else { line }
          let lcol  = if rty.col  > 0 { rty.col  } else { col  }
          diag_error(file, lline, lcol,
            string_concat(string_concat("Fiber[T] cannot escape `", fname),
                          "`'s structured-concurrency scope"))
          diag_note("a `Fiber[T]` handle is bound to the nursery that created it")
          diag_note("returning one from a function lets it outlive that scope")
          diag_help("process the fiber inside the nursery (e.g. with `fiber_await`), or pass a thunk in and a value out instead")
          st_bump_err(st)
        } else {
          st
        }
      }
    }
  }
}

# Hardcoded list of stdlib helpers permitted to mention Fiber[T] in
# their return type. Kept intentionally narrow — these are the only
# legitimate constructors / passthroughs of Fiber values today
# (stdlib/spawn.kai). Any new helper that needs to return a Fiber
# must be added here on purpose.
fn is_fiber_producer_helper(fname: String) : Bool =
  fname == "fiber_spawn"

# Walks a TypeExpr looking for any TyName("Fiber", ...) at any depth
# (list, function-arg / -ret, type-arg). Returns true on the first
# hit. Cheap because TypeExprs are small and shallow.
fn ty_expr_contains_fiber(t: TypeExpr) : Bool {
  match t.tkind {
    TyName(name, tas) ->
      if name == "Fiber" { true }
      else { ty_expr_list_has_fiber(tas) }
    TyList(inner) -> ty_expr_contains_fiber(inner)
    TyFn(ps, ret, _) -> {
      if ty_expr_list_has_fiber(ps) { true }
      else { ty_expr_contains_fiber(ret) }
    }
    # m12.5: dimensioned types never carry a Fiber — recurse into base.
    TyDim(base, _) -> ty_expr_contains_fiber(base)
  }
}

fn ty_expr_list_has_fiber(ts: [TypeExpr]) : Bool {
  match ts {
    [] -> false
    [t, ...rest] -> if ty_expr_contains_fiber(t) { true } else { ty_expr_list_has_fiber(rest) }
  }
}

# m7a #4c: enforce that every effect the body performs appears in
# the declared row. m7b #12: ROpen carries a row variable that
# absorbs any extras — every body row is admissible against an
# open declared row.
fn check_body_row(st: InferState, fname: String, declared: RowExpr,
                  line: Int, col: Int) : InferState {
  # m7b #11i + #11k: every body label must match a declared label by
  # eff name AND unifiable ty_args. `Reader[Int]` body label paired
  # with `Reader[String]` declared label is a row mismatch.
  # m7b #12: an open row (ROpen) absorbs extras through its tail
  # variable, so the body-vs-declared subset check is unconstrained.
  match declared {
    REmpty       ->
      # m12.8.x phase 4 + pinned "main excepción única" decision:
      # `fn main() { ... }` without an explicit row absorbs every
      # builtin effect the body performs. Helpers must still declare
      # their row — Bug 6 enforcement still bites where it matters.
      if fname == "main" { st }
      else { check_body_row_label_loop(st, fname, st.row, [], line, col) }
    RClosed(lbs) -> check_body_row_label_loop(st, fname, st.row,
                                                row_labels_of_rls(lbs),
                                                line, col)
    ROpen(_, _)  -> st
  }
}

# m12.8 Phase 4b: `expand_console_alias` removed. After Phase 4b,
# `Console` is the auto-injected alias `type Console = Stdout +
# Stderr + Stdin`; row labels are expanded to atomics by
# `expand_aliases_in_decls` at the program level before any DFn
# row reaches `check_body_row`. The earlier hardcoded expansion
# (which only knew about `Stdout + Stderr`, not `Stdin`) was both
# dead code and silently incomplete.

# m7b #11i — label-aware body-vs-declared check. For each label the
# body performed, look for an `eff`-name match in the declared list;
# unify ty_args with `unify_label_args` (extends the substitution).
# Unification failure or absence both report "effect not handled" with
# the parametric label rendered in full.
fn check_body_row_label_loop(st: InferState, fname: String, performed: [Label],
                              declared: [Label], fline: Int, fcol: Int) : InferState {
  match performed {
    [] -> st
    [lab, ...rest] -> {
      let st1 = match find_matching_declared(declared, lab, st) {
        Some(s_after) -> s_after
        None -> {
          let use_eu = lookup_eff_use(st.eff_uses, lab.eff)
          match use_eu {
            EU(_, uline, ucol) -> {
              let line = if uline >= 0 { uline } else { fline }
              let col  = if ucol  >= 0 { ucol  } else { fcol  }
              let lab_str = label_to_string(apply_label_args(st.sub, lab))
              diag_error(st.file, line, col,
                string_concat("effect not handled: ", lab_str))
              diag_note("`#{fname}`'s declared row does not include `#{lab_str}`")
              diag_help("either declare `#{fname} : ... / #{lab_str}`, or wrap this call site in `handle { ... } with #{lab_str} { ... }`")
              st_bump_err(st)
            }
          }
        }
      }
      check_body_row_label_loop(st1, fname, rest, declared, fline, fcol)
    }
  }
}

# m7b #11i — find a declared label whose eff name and ty_args unify
# with the body's label. Side effect: if a match is found, the unifier
# may bind tyvars on the body label's ty_args to concrete declared
# types. Returns the post-unification InferState, or None on no match.
fn find_matching_declared(declared: [Label], target: Label,
                            st: InferState) : Option[InferState] {
  match declared {
    [] -> None
    [d, ...rest] ->
      if d.eff == target.eff and labels_args_unify(d.ty_args, target.ty_args, st.sub) {
        Some(unify_label_args_into(d.ty_args, target.ty_args, st))
      } else {
        find_matching_declared(rest, target, st)
      }
  }
}

# Unify two ty_arg lists, propagating any new bindings into st.sub.
# Mismatched length → no-op (caller already excluded that case via
# labels_args_unify which requires equal length).
fn unify_label_args_into(a: [Ty], b: [Ty], st: InferState) : InferState {
  match a {
    [] -> st
    [ah, ...arest] -> match b {
      [] -> st
      [bh, ...brest] -> {
        let st1 = st_unify(st, ah, bh, "row label type argument", -1, -1)
        unify_label_args_into(arest, brest, st1)
      }
    }
  }
}

# m7b #11k — render a Label for diagnostics. Bare-name labels render
# as the eff name; parameterised labels render as `Eff[T1, T2]` with
# each ty_arg passed through `ty_to_string` so unbound TyVars show as
# `?tN`.
fn label_to_string(l: Label) : String {
  match l.ty_args {
    [] -> l.eff
    _ -> concat_all([
      l.eff, "[", join_with(map(l.ty_args, ty_to_string), ", "), "]"
    ])
  }
}

type TypedProgram = { decls: [Decl], errs: Int, insts: [ResolvedCS],
                      holes: [ResolvedHole], prelude_len: Int }

fn infer_all_loop(file: String, env: TyEnv, prelude_len: Int, recs: [RecInfo],
                   op_eff_arities: [OpEffArity],
                   ds: [Decl], verbose: Bool,
                   acc_decls: [Decl], acc_errs: Int, acc_insts: [ResolvedCS],
                   acc_holes: [ResolvedHole],
                   type_aliases: [AliasResult],
                   op_to_eff: [OpToEff]) : TypedProgram {
  match ds {
    [] -> TypedProgram {
      decls: list_reverse(acc_decls), errs: acc_errs,
      insts: list_reverse(acc_insts), holes: list_reverse(acc_holes),
      prelude_len: prelude_len
    }
    [d, ...rest] -> {
      let r = infer_decl(file, env, prelude_len, recs, op_eff_arities,
                          type_aliases, op_to_eff, d, verbose)
      infer_all_loop(file, env, prelude_len, recs, op_eff_arities, rest, verbose,
                     [r.decl, ...acc_decls],
                     acc_errs + r.errs,
                     llvm_prepend_reverse(r.insts, acc_insts),
                     prepend_reverse_holes(r.holes, acc_holes),
                     type_aliases, op_to_eff)
    }
  }
}

# Prepend `xs` onto `acc` in reverse order so `list_reverse(acc)` at
# the end restores document order. Saves a full list_append per decl.
fn llvm_prepend_reverse(xs: [ResolvedCS], acc: [ResolvedCS]) : [ResolvedCS] {
  match xs {
    [] -> acc
    [x, ...rest] -> llvm_prepend_reverse(rest, [x, ...acc])
  }
}

fn prepend_reverse_holes(xs: [ResolvedHole], acc: [ResolvedHole]) : [ResolvedHole] {
  match xs {
    [] -> acc
    [x, ...rest] -> prepend_reverse_holes(rest, [x, ...acc])
  }
}

# m12.5: alias expansion pre-pass.
#
# Walks decls, collecting the body of every `unit Newton = ...` alias
# into a flat table, then rewrites every USym(name) inside a TyDim or
# ELitUnit to that body recursively. After this pass the typer never
# sees an alias symbol — it only sees atomic units and unit-vars.

type UAliasEntry = UAE(String, UnitExprT)

fn collect_unit_alias_table(decls: [Decl]) : [UAliasEntry] =
  collect_unit_alias_table_loop(decls, [])

fn collect_unit_alias_table_loop(decls: [Decl], acc: [UAliasEntry]) : [UAliasEntry] {
  match decls {
    [] -> acc
    [d, ...rest] -> match d {
      DUnit(_, name, Some(body), _, _) -> collect_unit_alias_table_loop(rest, [UAE(name, body), ...acc])
      _ -> collect_unit_alias_table_loop(rest, acc)
    }
  }
}

fn unit_alias_lookup(aliases: [UAliasEntry], name: String) : Option[UnitExprT] {
  match aliases {
    [] -> None
    [a, ...rest] -> match a {
      UAE(n, b) -> if n == name { Some(b) } else { unit_alias_lookup(rest, name) }
    }
  }
}

# Walk a UnitExprT and replace USym(name) with the alias body whenever
# `name` is registered as an alias. Recursive — alias-of-alias chains
# expand fully. The `seen` parameter guards against accidental cycles
# (the m12.5 spec rules them out, but a defensive guard keeps the
# compiler from looping if a future refactor introduces one).
fn expand_unit_aliases_in_unit(u: UnitExprT, aliases: [UAliasEntry], seen: [String]) : UnitExprT {
  match u {
    UOne -> u
    UVar(_) -> u
    USym(s) -> {
      if list_has_string(seen, s) { u }
      else {
        match unit_alias_lookup(aliases, s) {
          Some(body) -> expand_unit_aliases_in_unit(body, aliases, [s, ...seen])
          None -> u
        }
      }
    }
    UMul(a, b) -> UMul(expand_unit_aliases_in_unit(a, aliases, seen),
                      expand_unit_aliases_in_unit(b, aliases, seen))
    UInv(a) -> UInv(expand_unit_aliases_in_unit(a, aliases, seen))
    UPow(a, n) -> UPow(expand_unit_aliases_in_unit(a, aliases, seen), n)
  }
}

fn expand_unit_aliases_decls(ds: [Decl], aliases: [UAliasEntry]) : [Decl] =
  map(ds, (d) => expand_unit_aliases_decl(d, aliases))

fn expand_unit_aliases_decl(d: Decl, aliases: [UAliasEntry]) : Decl {
  match d {
    DFn(p, n, tps, ps, ret, row, body, l, c) ->
      DFn(p, n, tps,
          map(ps, (pm) => expand_aliases_param(pm, aliases)),
          match ret { Some(t) -> Some(expand_aliases_typeexpr(t, aliases)) None -> None },
          row,
          expand_aliases_expr(body, aliases),
          l, c)
    DType(p, n, tps, body, l, c) ->
      DType(p, n, tps, expand_aliases_typebody(body, aliases), l, c)
    DTest(desc, body, l, c) -> DTest(desc, expand_aliases_expr(body, aliases), l, c)
    DImport(_, _, _) -> d
    DEffect(p, n, tps, ops, l, c) ->
      DEffect(p, n, tps, map(ops, (op) => expand_aliases_op(op, aliases)), l, c)
    DUnit(_, _, _, _, _) -> d
    # m12.8: protocols are stripped by `lower_protocols` before
    # `infer_program` runs, so reaching one here means the unit-alias
    # pass executed on a pre-lowering decl stream — pass through.
    DProtocol(_, _, _, _, _) -> d
    DImpl(_, _, _, _, _) -> d
    DDerive(_, _, _, _) -> d
  }
}

fn expand_aliases_param(pm: Param, aliases: [UAliasEntry]) : Param =
  Param {
    pname: pm.pname,
    ptype: match pm.ptype {
      Some(t) -> Some(expand_aliases_typeexpr(t, aliases))
      None -> None
    },
    pline: pm.pline,
    pcol: pm.pcol
  }

fn expand_aliases_typebody(b: TypeBody, aliases: [UAliasEntry]) : TypeBody {
  match b {
    TBAlias(t) -> TBAlias(expand_aliases_typeexpr(t, aliases))
    TBRecord(fs) -> TBRecord(expand_aliases_fdecls(fs, aliases))
    TBSum(vs) -> TBSum(expand_aliases_variants(vs, aliases))
    TBEffectAlias(_) -> b
  }
}

fn expand_aliases_fdecls(fs: [FieldDecl], aliases: [UAliasEntry]) : [FieldDecl] {
  match fs {
    [] -> []
    [h, ...rest] -> match h {
      FD(n, t) -> [FD(n, expand_aliases_typeexpr(t, aliases)),
                   ...expand_aliases_fdecls(rest, aliases)]
    }
  }
}

fn expand_aliases_variants(vs: [Variant], aliases: [UAliasEntry]) : [Variant] {
  match vs {
    [] -> []
    [h, ...rest] -> match h {
      Var(n, ts) -> [Var(n, expand_aliases_typeexprs(ts, aliases)),
                     ...expand_aliases_variants(rest, aliases)]
    }
  }
}

fn expand_aliases_typeexprs(ts: [TypeExpr], aliases: [UAliasEntry]) : [TypeExpr] {
  match ts {
    [] -> []
    [h, ...rest] -> [expand_aliases_typeexpr(h, aliases),
                     ...expand_aliases_typeexprs(rest, aliases)]
  }
}

fn expand_aliases_op(op: EffectOp, aliases: [UAliasEntry]) : EffectOp {
  match op {
    EOp(n, tps, ps, ret, l, c) ->
      EOp(n, tps,
          map(ps, (pm) => expand_aliases_param(pm, aliases)),
          expand_aliases_typeexpr(ret, aliases), l, c)
  }
}

fn expand_aliases_typeexpr(t: TypeExpr, aliases: [UAliasEntry]) : TypeExpr {
  match t.tkind {
    TyName(n, ts) ->
      mk_ty(TyName(n, map(ts, (a) => expand_aliases_typeexpr(a, aliases))), t.line, t.col)
    TyList(inner) ->
      mk_ty(TyList(expand_aliases_typeexpr(inner, aliases)), t.line, t.col)
    TyFn(ps, ret, row) ->
      mk_ty(TyFn(map(ps, (a) => expand_aliases_typeexpr(a, aliases)),
                 expand_aliases_typeexpr(ret, aliases), row), t.line, t.col)
    TyDim(base, u) ->
      mk_ty(TyDim(expand_aliases_typeexpr(base, aliases),
                  expand_unit_aliases_in_unit(u, aliases, [])), t.line, t.col)
  }
}

fn expand_aliases_expr(e: Expr, aliases: [UAliasEntry]) : Expr {
  let new_kind = expand_aliases_exprkind(e.kind, aliases)
  Expr { kind: new_kind, line: e.line, col: e.col, ty: e.ty }
}

fn expand_aliases_exprkind(k: ExprKind, aliases: [UAliasEntry]) : ExprKind {
  match k {
    EInt(_) -> k
    EReal(_) -> k
    EBool(_) -> k
    EChar(_) -> k
    EStr(_, _) -> k
    EUnit -> k
    EVar(_) -> k
    EUnder -> k
    EPlaceholder -> k
    ECall(f, xs) -> ECall(expand_aliases_expr(f, aliases),
                          map(xs, (x) => expand_aliases_expr(x, aliases)))
    EField(b, n) -> EField(expand_aliases_expr(b, aliases), n)
    EIndex(a, b) -> EIndex(expand_aliases_expr(a, aliases),
                           expand_aliases_expr(b, aliases))
    EBinop(op, a, b) -> EBinop(op, expand_aliases_expr(a, aliases),
                                   expand_aliases_expr(b, aliases))
    EUnop(op, x) -> EUnop(op, expand_aliases_expr(x, aliases))
    EIf(c, t_, eo) -> EIf(expand_aliases_expr(c, aliases),
                          expand_aliases_expr(t_, aliases),
                          match eo { Some(eb) -> Some(expand_aliases_expr(eb, aliases)) None -> None })
    EMatch(scr, arms) -> EMatch(expand_aliases_expr(scr, aliases),
                                map(arms, (a) => expand_aliases_arm(a, aliases)))
    ELambda(ps, body) ->
      ELambda(map(ps, (pm) => expand_aliases_param(pm, aliases)),
              expand_aliases_expr(body, aliases))
    ERecordLit(n, fis) -> ERecordLit(n, expand_aliases_field_inits(fis, aliases))
    EList(els) -> EList(map(els, (el) => expand_aliases_listelem(el, aliases)))
    ERange(a, b, opt_step) ->
      ERange(expand_aliases_expr(a, aliases),
             expand_aliases_expr(b, aliases),
             match opt_step { Some(s) -> Some(expand_aliases_expr(s, aliases)) None -> None })
    EBlock(stmts, opt_final) ->
      EBlock(map(stmts, (s) => expand_aliases_stmt(s, aliases)),
             match opt_final { Some(fe) -> Some(expand_aliases_expr(fe, aliases)) None -> None })
    EPipe(a, b) -> EPipe(expand_aliases_expr(a, aliases),
                         expand_aliases_expr(b, aliases))
    EHole(_) -> k
    ETodo(_) -> k
    EBang(inner) -> EBang(expand_aliases_expr(inner, aliases))
    EHandle(body, eff_n, eff_tas, init_opt, alias_opt, cs, ret_opt) ->
      EHandle(expand_aliases_expr(body, aliases), eff_n,
              map(eff_tas, (t) => expand_aliases_typeexpr(t, aliases)),
              match init_opt { Some(ie) -> Some(expand_aliases_expr(ie, aliases)) None -> None },
              alias_opt,
              map(cs, (c) => expand_aliases_hclause(c, aliases)),
              match ret_opt { Some(r) -> Some(expand_aliases_hreturn(r, aliases)) None -> None })
    ELitUnit(inner, u) ->
      ELitUnit(expand_aliases_expr(inner, aliases),
               expand_unit_aliases_in_unit(u, aliases, []))
    # m7e §11: expand aliases inside the TypeExpr that `variants[T]()`
    # carries, so a unit-aliased name (or a future generic-aliased
    # type) reaches the resolver in canonical form.
    EVariantsOf(ty) ->
      EVariantsOf(expand_aliases_typeexpr(ty, aliases))
  }
}

fn expand_aliases_field_inits(fis: [FieldInit], aliases: [UAliasEntry]) : [FieldInit] {
  match fis {
    [] -> []
    [h, ...rest] -> match h {
      FI(fn_, v) -> [FI(fn_, expand_aliases_expr(v, aliases)),
                     ...expand_aliases_field_inits(rest, aliases)]
    }
  }
}

fn expand_aliases_arm(a: Arm, aliases: [UAliasEntry]) : Arm {
  match a {
    Arm(pat, opt_g, body) -> Arm(pat,
      match opt_g { Some(g) -> Some(expand_aliases_expr(g, aliases)) None -> None },
      expand_aliases_expr(body, aliases))
  }
}

fn expand_aliases_listelem(el: ListElem, aliases: [UAliasEntry]) : ListElem {
  match el {
    ElPlain(x) -> ElPlain(expand_aliases_expr(x, aliases))
    ElSpread(x) -> ElSpread(expand_aliases_expr(x, aliases))
  }
}

fn expand_aliases_stmt(s: Stmt, aliases: [UAliasEntry]) : Stmt {
  match s {
    SLet(p, t, rhs) ->
      SLet(p,
           match t { Some(te) -> Some(expand_aliases_typeexpr(te, aliases)) None -> None },
           expand_aliases_expr(rhs, aliases))
    SAssert(c, msg) ->
      SAssert(expand_aliases_expr(c, aliases),
              match msg { Some(m) -> Some(expand_aliases_expr(m, aliases)) None -> None })
    SExprStmt(x) -> SExprStmt(expand_aliases_expr(x, aliases))
    SIndexAssign(b, i, v, l, c) ->
      SIndexAssign(expand_aliases_expr(b, aliases),
                   expand_aliases_expr(i, aliases),
                   expand_aliases_expr(v, aliases), l, c)
    SVar(n, te, rhs, l, c) ->
      SVar(n,
           match te { Some(t) -> Some(expand_aliases_typeexpr(t, aliases)) None -> None },
           expand_aliases_expr(rhs, aliases), l, c)
  }
}

fn expand_aliases_hclause(c: HClause, aliases: [UAliasEntry]) : HClause {
  match c {
    HC(n, ps, body, l, col) ->
      HC(n, map(ps, (pm) => expand_aliases_param(pm, aliases)),
         expand_aliases_expr(body, aliases), l, col)
  }
}

fn expand_aliases_hreturn(r: HReturn, aliases: [UAliasEntry]) : HReturn {
  match r {
    HR(n, body, l, c) -> HR(n, expand_aliases_expr(body, aliases), l, c)
  }
}

fn infer_program(file: String, decls: [Decl], verbose: Bool) : TypedProgram {
  # m12.5: expand `unit Newton = kg * m / sec^2` aliases at the AST
  # level before any pass that calls resolve_ty. After this pass no
  # USym in any TyDim or ELitUnit refers to an alias name.
  let aliases = collect_unit_alias_table(decls)
  let decls_a = expand_unit_aliases_decls(decls, aliases)
  let built = build_ty_env(decls_a)
  let recs = collect_records(decls_a)
  # m12.8 Phase 4b: rebuild the type-alias resolution table here so
  # `try_op_call` can resolve `Aliasname.opname` for aliases like
  # `Console = Stdout + Stderr + Stdin` and `Io = Console + Env +
  # File`. The work duplicates `compile_source`'s alias resolution
  # but avoids threading 10+ call sites with two extra parameters.
  let alias_cands = collect_alias_cands(decls_a)
  let eff_names_for_alias = list_append(builtin_effect_names(),
                                          collect_effect_names(decls_a))
  let alias_res = resolve_alias_cands(alias_cands, eff_names_for_alias, file)
  let op_to_eff = collect_op_to_eff(decls_a)
  infer_all_loop(file, built.env, built.prelude_len, recs,
                 built.op_eff_arities, decls_a, verbose, [], 0, [], [],
                 alias_res.aliases, op_to_eff)
}

fn dump_infer(file: String, decls: [Decl]) : Int {
  let r = infer_program(file, decls, true)
  r.errs
}

fn check_infer(file: String, decls: [Decl]) : Int {
  let r = infer_program(file, decls, false)
  r.errs
}

# ---- `--dump-typed`: typed AST pretty-printer ----
#
# Runs inference and walks the resulting annotated tree, printing a
# compact `<kind> : <ty>` line per Expr node. The point of the flag
# is diagnostic — every Expr node the walker returned is expected to
# carry a `Some(ty)`, so a `?` in the output indicates a missed
# rebuild path.

fn ty_tag(e: Expr) : String {
  match e.ty {
    Some(t) -> string_concat(" : ", ty_to_string(t))
    None    -> " : ?"
  }
}

fn tag_of_kind(k: ExprKind) : String {
  match k {
    EInt(n)        -> concat_all(["int ", int_to_string(n)])
    EReal(_)       -> "real"
    EBool(b)       -> if b { "bool true" } else { "bool false" }
    EChar(_)       -> "char"
    EStr(_, _)     -> "string"
    EUnit          -> "unit"
    EVar(nm)       -> concat_all(["ident ", nm])
    EUnder         -> "_"
    EPlaceholder   -> "."
    ECall(_, _)    -> "call"
    EField(_, nm)  -> concat_all(["field .", nm])
    EIndex(_, _)   -> "index"
    EBinop(op, _, _) -> concat_all(["binop ", op])
    EUnop(op, _)   -> concat_all(["unop ", op])
    EIf(_, _, _)   -> "if"
    EMatch(_, _)   -> "match"
    ELambda(_, _)  -> "lambda"
    ERecordLit(nm, _) -> concat_all(["record ", nm])
    EList(_)       -> "list"
    ERange(_, _, _) -> "range"
    EBlock(_, _)   -> "block"
    EPipe(_, _)    -> "pipe"
    EHole(nm_opt)  -> match nm_opt {
      Some(nm) -> concat_all(["hole ?", nm])
      None     -> "hole ?"
    }
    ETodo(msg)     -> concat_all(["todo \"", msg, "\""])
    EBang(_)       -> "bang"
    EHandle(_, eff_name, _, _, _, _, _) -> concat_all(["handle ", eff_name])
    ELitUnit(_, u) -> concat_all(["lit-unit <", unit_canon_display(u), ">"])
    EVariantsOf(ty) -> concat_all(["variants-of ", type_expr_display(ty)])
  }
}

fn dump_typed_expr(e: Expr, depth: Int) : Unit {
  emit_line(depth, concat_all([tag_of_kind(e.kind), ty_tag(e)]))
  dump_typed_subexprs(e.kind, depth + 1)
}

# Note: stage 1's capture analyser doesn't recognise pattern bindings
# inside a lambda body as locals, which turns a seemingly-innocent
# `each((a) => match a { Arm(_, g, body) -> ... })` into "capture
# g, body from outer scope" and fails to compile. Every iteration in
# this dumper therefore uses explicit recursive helpers with pattern
# matching at top level rather than inline lambdas.

fn dump_typed_exprs(xs: [Expr], depth: Int) : Unit {
  match xs {
    [] -> ()
    [x, ...rest] -> { dump_typed_expr(x, depth) dump_typed_exprs(rest, depth) }
  }
}

fn dump_typed_arms(arms: [Arm], depth: Int) : Unit {
  match arms {
    [] -> ()
    [a, ...rest] -> {
      match a {
        Arm(_, g, body) -> {
          match g {
            Some(gx) -> dump_typed_expr(gx, depth)
            None -> ()
          }
          dump_typed_expr(body, depth)
        }
      }
      dump_typed_arms(rest, depth)
    }
  }
}

fn dump_typed_fis(fis: [FieldInit], depth: Int) : Unit {
  match fis {
    [] -> ()
    [fi, ...rest] -> {
      match fi { FI(_, v) -> dump_typed_expr(v, depth) }
      dump_typed_fis(rest, depth)
    }
  }
}

fn dump_typed_elems(els: [ListElem], depth: Int) : Unit {
  match els {
    [] -> ()
    [el, ...rest] -> {
      match el {
        ElPlain(x)  -> dump_typed_expr(x, depth)
        ElSpread(x) -> dump_typed_expr(x, depth)
      }
      dump_typed_elems(rest, depth)
    }
  }
}

fn dump_typed_stmts(ss: [Stmt], depth: Int) : Unit {
  match ss {
    [] -> ()
    [s, ...rest] -> { dump_typed_stmt(s, depth) dump_typed_stmts(rest, depth) }
  }
}

fn dump_typed_subexprs(k: ExprKind, depth: Int) : Unit {
  match k {
    ECall(callee, xs) -> {
      dump_typed_expr(callee, depth)
      dump_typed_exprs(xs, depth)
    }
    EField(base, _)   -> dump_typed_expr(base, depth)
    EIndex(a, b)      -> { dump_typed_expr(a, depth) dump_typed_expr(b, depth) }
    EBinop(_, a, b)   -> { dump_typed_expr(a, depth) dump_typed_expr(b, depth) }
    EUnop(_, x)       -> dump_typed_expr(x, depth)
    EIf(c, a, eo)     -> {
      dump_typed_expr(c, depth)
      dump_typed_expr(a, depth)
      match eo { Some(b) -> dump_typed_expr(b, depth) None -> () }
    }
    EMatch(scr, arms) -> {
      dump_typed_expr(scr, depth)
      dump_typed_arms(arms, depth)
    }
    ELambda(_, body)  -> dump_typed_expr(body, depth)
    ERecordLit(_, fis) -> dump_typed_fis(fis, depth)
    EList(els) -> dump_typed_elems(els, depth)
    ERange(a, b, so) -> {
      dump_typed_expr(a, depth)
      dump_typed_expr(b, depth)
      match so { Some(s) -> dump_typed_expr(s, depth) None -> () }
    }
    EBlock(ss, tail) -> {
      dump_typed_stmts(ss, depth)
      match tail { Some(t) -> dump_typed_expr(t, depth) None -> () }
    }
    EPipe(a, b) -> { dump_typed_expr(a, depth) dump_typed_expr(b, depth) }
    EBang(inner) -> dump_typed_expr(inner, depth)
    _ -> ()
  }
}

fn dump_typed_stmt(s: Stmt, depth: Int) : Unit {
  match s {
    SLet(_, _, rhs)  -> { emit_line(depth, "let") dump_typed_expr(rhs, depth + 1) }
    SAssert(c, mo)   -> {
      emit_line(depth, "assert")
      dump_typed_expr(c, depth + 1)
      match mo { Some(m) -> dump_typed_expr(m, depth + 1) None -> () }
    }
    SExprStmt(ex)    -> dump_typed_expr(ex, depth)
    SIndexAssign(b, i, v, _, _) -> {
      emit_line(depth, "index-assign")
      dump_typed_expr(b, depth + 1)
      dump_typed_expr(i, depth + 1)
      dump_typed_expr(v, depth + 1)
    }
    SVar(n, _, rhs, _, _) -> {
      emit_line(depth, "var #{n}")
      dump_typed_expr(rhs, depth + 1)
    }
  }
}

fn dump_typed_decl(d: Decl) : Unit / Console {
  match d {
    DFn(_, nm, _, _, _, _, body, line, col) -> {
      print("fn #{nm} @#{int_to_string(line)}:#{int_to_string(col)}")
      dump_typed_expr(body, 1)
    }
    _ -> ()
  }
}

fn dump_typed(file: String, decls: [Decl]) : Int / Console {
  let r = infer_program(file, decls, false)
  dump_typed_loop(r.decls)
  r.errs
}

fn dump_typed_loop(ds: [Decl]) : Unit / Console {
  match ds {
    [] -> ()
    [d, ...rest] -> { dump_typed_decl(d) dump_typed_loop(rest) }
  }
}

# ---- `--dump-mono`: call-site instantiations ----
#
# Every EVar reference that instantiates a polymorphic scheme
# registers a CallSite; inference then resolves each CallSite's
# fresh TyVarT ids through the final substitution to get concrete
# type arguments. This flag prints one line per call-site showing
# the name, location, and the resolved type tuple.
#
# Monomorphisation (M4c) will de-duplicate these tuples per callee
# and emit one specialised function body per unique instantiation.

fn dump_mono_line(cs: ResolvedCS) : Unit / Console {
  match cs {
    RCS(nm, line, col, tys) -> {
      let tys_str = join_with(ty_string_list(tys), ", ")
      print("#{nm}@#{int_to_string(line)}:#{int_to_string(col)}  [#{tys_str}]")
    }
  }
}

fn dump_mono(file: String, decls: [Decl]) : Int {
  let r = infer_program(file, decls, false)
  r.insts |> each(dump_mono_line)
  r.errs
}

# ---- `--dump-mono-out`: planned mangled names per call site ----
#
# Same input as `--dump-mono` (the resolved-call-site list); output
# adds the mangled name `mangle_name` would produce for each tuple.
# Diagnostic for m4c #2; m4c #3 will use these names to mint the
# specialised decls. Lines look like:
#   foo@line:col  [Int, Bool]  ->  foo__mono__Int__Bool

fn dump_mono_out_line(cs: ResolvedCS) : Unit / Console {
  match cs {
    RCS(nm, line, col, tys) -> {
      let tys_str = join_with(ty_string_list(tys), ", ")
      let mname = mangle_name(nm, tys)
      print("#{nm}@#{int_to_string(line)}:#{int_to_string(col)}  [#{tys_str}]  ->  #{mname}")
    }
  }
}

fn dump_mono_out(file: String, decls: [Decl]) : Int {
  let r = infer_program(file, decls, false)
  r.insts |> each(dump_mono_out_line)
  r.errs
}

# ---- m4c — monomorphise (identity, m4c #1) ----
#
# Sits between `infer_program` and `perceus_pass` in the pipeline.
# Given a TypedProgram (post-inference, with `Expr.ty` populated and
# all `ResolvedCS` known), produce the `[Decl]` shape the next pass
# walks. m4c #1 is an identity transform: the post-mono decls are
# the typed decls, unchanged. Selfhost stays byte-identical because
# the emitter does not consume `Expr.ty`.
#
# Real specialisation (per-instantiation copies of polymorphic decls,
# call-site rewrites, dead-generic pruning) is deferred. The blocker
# surfaced under m4c #3: `clause_fn_name(line, col, op)` mints C
# symbols by source position alone, so two copies of a body that
# contains an `EHandle` produce identical clause symbols and the C
# linker rejects the binary. Fixing it is a real retrofit (~1-2 days,
# touches the clause-collection plumbing) and only pays off once
# unboxing / drop specialisation / reuse-in-place arrive — the
# "basic Perceus" pass below operates on uniform-boxed values and
# does not require specialised bodies.
#
# When the time comes, the four sub-steps still apply: mangling
# helper (`mangle_name` in this file already), specialised-copy
# emission (with fn-name-aware clause symbols), call-site rewrite,
# generic prune. Until then `monomorphise` stays identity and
# `--dump-mono-out` documents what specialisation WOULD do.

fn monomorphise(tp: TypedProgram) : [Decl] {
  tp.decls
}

# ---- m5 — basic Perceus (m5 #1, walker scaffold) ----
#
# Walks the post-mono `[Decl]` and (eventually) inserts `kai_dup` /
# `kai_decref` calls at non-last / last-use positions per the Koka
# Perceus paper. m5 #1 wires the slot; the body is identity. m5 #2
# computes per-binding last-use positions; m5 #3 emits drops at
# end-of-scope; m5 #4 emits dups at non-last uses; m5 #5 measures.
#
# Operates on values, not types. Under uniform boxing every
# `KaiValue *` has the same RC shape, so a single drop/dup discipline
# applies across instantiations — the m4c retrofit blocking real
# monomorphisation does not block this pass.
#
# Reads the source AST as the IR. The emitter consumes whatever this
# function returns; selfhost convergence remains the gate.

# m5 #4 step 2/4 — scope-aware Perceus pass.
#
# For each `DFn`, walks the body twice:
#   1. `pcs_collect_uses_expr` — accumulates `[Use]` for every EVar
#      whose name is currently in scope (params + lets + match
#      pattern bindings + handler-clause params + lambda params).
#      Mirrors `fv_expr` (5478) modulo polarity: we want IN-scope
#      reads, fv wants free vars.
#   2. `pcs_rewrite_expr` — reconstructs the body, wrapping every
#      non-last in-scope EVar in `ECall(EVar("__perceus_dup"), [...])`.
#      Last-use-per-name is computed via `pcs_last_use_for` (same as
#      m5 #2 but consumed for rewriting, not just reporting).
#
# Then `pcs_prepend_unused_drops` wraps the body in `EBlock` to drop
# every parameter whose `pcs_last_use_for` is `LUUnused`. Drops emit
# at body START — safe because the param was never read after entry.
#
# Together with the runtime primitive consumption (step 3/4 —
# blocked on stage 1 needing its own perceus pass; see
# `docs/perceus-basic.md` §"What unblocks step 3+"), this
# would produce a coherent linear discipline: every binding
# transferred at exactly one position (last use); earlier reads
# bump the refcount via dup; unused params dropped at entry.
# Inert until step 3 lands.

fn perceus_pass(decls: [Decl]) : [Decl] = map(decls, perceus_decl)

fn perceus_decl(d: Decl) : Decl {
  match d {
    DFn(is_pub, name, tparams, params, opt_ret, row, body, ln, cl) -> {
      let pnames = map(params, (p) => p.pname)
      let uses = pcs_collect_uses_expr(body, pnames, false, [])
      let new_body = pcs_rewrite_expr(body, pnames, uses, false)
      let body_with_drops = pcs_prepend_unused_drops(new_body, params, uses)
      DFn(is_pub, name, tparams, params, opt_ret, row, body_with_drops, ln, cl)
    }
    _ -> d
  }
}

# ---- pcs_collect_uses: scope-tracking EVar collection ----

fn pcs_collect_uses_expr(e: Expr, scope: [String], in_lam: Bool, acc: [Use]) : [Use] =
  pcs_collect_uses_kind(e.kind, e.line, e.col, scope, in_lam, acc)

fn pcs_collect_uses_kind(k: ExprKind, line: Int, col: Int, scope: [String],
                         in_lam: Bool, acc: [Use]) : [Use] {
  match k {
    EVar(nm) -> if list_has(scope, nm) { [U(nm, line, col, in_lam), ...acc] } else { acc }
    EStr(span, is_triple) -> pcs_collect_uses_in_interp(span, is_triple, scope, in_lam, acc)
    ECall(f, xs) -> pcs_collect_uses_in_exprs(xs, scope, in_lam,
                       pcs_collect_uses_expr(f, scope, in_lam, acc))
    EField(x, _) -> pcs_collect_uses_expr(x, scope, in_lam, acc)
    EIndex(x, i) -> pcs_collect_uses_expr(i, scope, in_lam,
                       pcs_collect_uses_expr(x, scope, in_lam, acc))
    EBinop(_, l, r) -> pcs_collect_uses_expr(r, scope, in_lam,
                          pcs_collect_uses_expr(l, scope, in_lam, acc))
    EUnop(_, x) -> pcs_collect_uses_expr(x, scope, in_lam, acc)
    EIf(c, t, opt_e) -> {
      let a1 = pcs_collect_uses_expr(c, scope, in_lam, acc)
      let a2 = pcs_collect_uses_expr(t, scope, in_lam, a1)
      match opt_e {
        None -> a2
        Some(e2) -> pcs_collect_uses_expr(e2, scope, in_lam, a2)
      }
    }
    EMatch(s, arms) -> pcs_collect_uses_in_arms(arms, scope, in_lam,
                          pcs_collect_uses_expr(s, scope, in_lam, acc))
    ELambda(ps, body) -> {
      let pn = map(ps, (p) => p.pname)
      pcs_collect_uses_expr(body, list_append(scope, pn), true, acc)
    }
    ERecordLit(_, fis) -> pcs_collect_uses_in_field_inits(fis, scope, in_lam, acc)
    EList(elems) -> pcs_collect_uses_in_list_elems(elems, scope, in_lam, acc)
    ERange(lo, hi, opt_by) -> {
      let a1 = pcs_collect_uses_expr(lo, scope, in_lam, acc)
      let a2 = pcs_collect_uses_expr(hi, scope, in_lam, a1)
      match opt_by {
        None -> a2
        Some(e2) -> pcs_collect_uses_expr(e2, scope, in_lam, a2)
      }
    }
    EBlock(stmts, opt_tail) -> pcs_collect_uses_in_block(stmts, opt_tail, scope, in_lam, acc)
    EPipe(l, r) -> pcs_collect_uses_expr(r, scope, in_lam,
                      pcs_collect_uses_expr(l, scope, in_lam, acc))
    EHandle(body, _, _, init_opt, _, clauses, ret_opt) -> {
      let a1 = pcs_collect_uses_expr(body, scope, in_lam, acc)
      let a2 = match init_opt {
        None -> a1
        Some(e2) -> pcs_collect_uses_expr(e2, scope, in_lam, a1)
      }
      let a3 = pcs_collect_uses_in_clauses(clauses, scope, in_lam, a2)
      match ret_opt {
        None -> a3
        Some(hr) -> match hr {
          HR(pname, body2, _, _) ->
            pcs_collect_uses_expr(body2, [pname, ...scope], in_lam, a3)
        }
      }
    }
    EBang(inner) -> pcs_collect_uses_expr(inner, scope, in_lam, acc)
    _ -> acc
  }
}

fn pcs_collect_uses_in_exprs(es: [Expr], scope: [String], in_lam: Bool, acc: [Use]) : [Use] {
  match es {
    [] -> acc
    [h, ...rest] -> pcs_collect_uses_in_exprs(rest, scope, in_lam,
                       pcs_collect_uses_expr(h, scope, in_lam, acc))
  }
}

fn pcs_collect_uses_in_arms(arms: [Arm], scope: [String], in_lam: Bool, acc: [Use]) : [Use] {
  match arms {
    [] -> acc
    [a, ...rest] -> match a {
      Arm(pat, opt_g, body) -> {
        let scope1 = pat_bindings(pat, scope)
        let a1 = match opt_g {
          None -> acc
          Some(g) -> pcs_collect_uses_expr(g, scope1, in_lam, acc)
        }
        let a2 = pcs_collect_uses_expr(body, scope1, in_lam, a1)
        pcs_collect_uses_in_arms(rest, scope, in_lam, a2)
      }
    }
  }
}

fn pcs_collect_uses_in_field_inits(fis: [FieldInit], scope: [String],
                                    in_lam: Bool, acc: [Use]) : [Use] {
  match fis {
    [] -> acc
    [h, ...rest] -> match h {
      FI(_, e) -> pcs_collect_uses_in_field_inits(rest, scope, in_lam,
                     pcs_collect_uses_expr(e, scope, in_lam, acc))
    }
  }
}

fn pcs_collect_uses_in_list_elems(es: [ListElem], scope: [String],
                                   in_lam: Bool, acc: [Use]) : [Use] {
  match es {
    [] -> acc
    [h, ...rest] -> {
      let inner = match h { ElPlain(e) -> e ElSpread(e) -> e }
      pcs_collect_uses_in_list_elems(rest, scope, in_lam,
        pcs_collect_uses_expr(inner, scope, in_lam, acc))
    }
  }
}

fn pcs_collect_uses_in_block(stmts: [Stmt], opt_tail: Option[Expr],
                              scope: [String], in_lam: Bool, acc: [Use]) : [Use] {
  let r = pcs_block_loop(stmts, scope, in_lam, acc)
  match opt_tail {
    None -> r.acc
    Some(e) -> pcs_collect_uses_expr(e, r.scope, in_lam, r.acc)
  }
}

type PcsBlockState = { scope: [String], acc: [Use] }

fn pcs_block_loop(stmts: [Stmt], scope: [String], in_lam: Bool,
                   acc: [Use]) : PcsBlockState {
  match stmts {
    [] -> PcsBlockState { scope: scope, acc: acc }
    [s, ...rest] -> {
      let nxt = match s {
        SLet(pat, _, rhs) -> {
          let acc1 = pcs_collect_uses_expr(rhs, scope, in_lam, acc)
          PcsBlockState { scope: pat_bindings(pat, scope), acc: acc1 }
        }
        SVar(name, _, rhs, _, _) -> {
          let acc1 = pcs_collect_uses_expr(rhs, scope, in_lam, acc)
          PcsBlockState { scope: [name, ...scope], acc: acc1 }
        }
        SAssert(c, opt_m) -> {
          let a1 = pcs_collect_uses_expr(c, scope, in_lam, acc)
          let a2 = match opt_m {
            None -> a1
            Some(m) -> pcs_collect_uses_expr(m, scope, in_lam, a1)
          }
          PcsBlockState { scope: scope, acc: a2 }
        }
        SExprStmt(e) ->
          PcsBlockState { scope: scope, acc: pcs_collect_uses_expr(e, scope, in_lam, acc) }
        SIndexAssign(b, i, v, _, _) -> {
          let a1 = pcs_collect_uses_expr(b, scope, in_lam, acc)
          let a2 = pcs_collect_uses_expr(i, scope, in_lam, a1)
          let a3 = pcs_collect_uses_expr(v, scope, in_lam, a2)
          PcsBlockState { scope: scope, acc: a3 }
        }
      }
      pcs_block_loop(rest, nxt.scope, in_lam, nxt.acc)
    }
  }
}

fn pcs_collect_uses_in_clauses(cs: [HClause], scope: [String], in_lam: Bool,
                                acc: [Use]) : [Use] {
  match cs {
    [] -> acc
    [h, ...rest] -> match h {
      HC(_, params, body, _, _) -> {
        # Filter out the trailing `resume` param. `resume(v)` is
        # emitted via a special case in emit_call_expr (and
        # llvm_emit_call) and has no runtime KaiValue representation,
        # so wrapping `EVar("resume")` in `__perceus_dup` would route
        # the inner `resume` through `emit_ident_value`'s `kai_resume`
        # fallback, which is undeclared.
        let pn = pcs_filter_non_resume(map(params, (p) => p.pname), [])
        let scope1 = list_append(scope, ["state", "log", ...pn])
        pcs_collect_uses_in_clauses(rest, scope, in_lam,
          pcs_collect_uses_expr(body, scope1, in_lam, acc))
      }
    }
  }
}

fn pcs_filter_non_resume(names: [String], acc: [String]) : [String] {
  match names {
    [] -> list_reverse(acc)
    [h, ...rest] ->
      if h == "resume" { pcs_filter_non_resume(rest, acc) }
      else { pcs_filter_non_resume(rest, [h, ...acc]) }
  }
}

fn pcs_collect_uses_in_interp(span: String, is_triple: Bool, scope: [String],
                               in_lam: Bool, acc: [Use]) : [Use] {
  let n = string_length(span)
  let body_start = if is_triple { 3 } else { 1 }
  let body_end = if is_triple { n - 3 } else { n - 1 }
  let parts = iscan_collect(span, body_end,
                            IScan { parts: [], lit_start: body_start, i: body_start })
  pcs_collect_uses_interp_parts(parts, scope, in_lam, acc)
}

fn pcs_collect_uses_interp_parts(parts: [IPart], scope: [String], in_lam: Bool,
                                   acc: [Use]) : [Use] {
  match parts {
    [] -> acc
    [p, ...rest] -> match p {
      IpLit(_, _) -> pcs_collect_uses_interp_parts(rest, scope, in_lam, acc)
      IpExp(esrc) -> {
        let toks = tokenize(esrc)
        let prs = parser_new("<interp>", esrc, toks)
        let r = parse_expr(prs)
        let acc1 = match r.r {
          Some(e) -> pcs_collect_uses_expr(e, scope, in_lam, acc)
          None -> acc
        }
        pcs_collect_uses_interp_parts(rest, scope, in_lam, acc1)
      }
    }
  }
}

# ---- pcs_rewrite: wrap non-last in-scope EVar reads in __perceus_dup ----

fn pcs_rewrite_expr(e: Expr, scope: [String], uses: [Use], in_lam: Bool) : Expr =
  Expr { kind: pcs_rewrite_kind(e.kind, e.line, e.col, scope, uses, in_lam),
         line: e.line, col: e.col, ty: e.ty }

fn pcs_rewrite_kind(k: ExprKind, line: Int, col: Int, scope: [String],
                    uses: [Use], in_lam: Bool) : ExprKind {
  match k {
    # The actual rewrite: wrap a non-last `EVar` use in `__perceus_dup`.
    EVar(nm) -> {
      if list_has(scope, nm) and pcs_is_non_last(nm, line, col, uses, in_lam) {
        ECall(
          Expr { kind: EVar("__perceus_dup"), line: line, col: col, ty: None },
          [Expr { kind: EVar(nm), line: line, col: col, ty: None }]
        )
      } else { EVar(nm) }
    }
    # Scope-aware kinds: ELambda extends scope with params and flips
    # in_lam; EBlock threads scope through SLet/SVar bindings; EMatch
    # delegates to pcs_rewrite_arms which adds pattern bindings to the
    # arm's scope; EHandle's HReturn binder shadows; clauses get the
    # state/log/op-param scope.
    ELambda(ps, body) -> {
      let pn = map(ps, (p) => p.pname)
      ELambda(ps, pcs_rewrite_expr(body, list_append(scope, pn), uses, true))
    }
    EBlock(stmts, opt_tail) -> {
      let r = pcs_rewrite_block(stmts, scope, uses, in_lam, [])
      EBlock(r.stmts, match opt_tail {
        None -> None
        Some(e) -> Some(pcs_rewrite_expr(e, r.scope, uses, in_lam))
      })
    }
    EMatch(s, arms) -> EMatch(pcs_rewrite_expr(s, scope, uses, in_lam),
                              pcs_rewrite_arms(arms, scope, uses, in_lam))
    EHandle(body, eff, eff_tas, init_opt, alias, clauses, ret_opt) -> {
      let body1 = pcs_rewrite_expr(body, scope, uses, in_lam)
      let init1 = match init_opt {
        None -> None
        Some(e2) -> Some(pcs_rewrite_expr(e2, scope, uses, in_lam))
      }
      let cls1 = pcs_rewrite_clauses(clauses, scope, uses, in_lam)
      let ret1 = match ret_opt {
        None -> None
        Some(hr) -> match hr {
          HR(pname, body2, hl, hc) ->
            Some(HR(pname,
                    pcs_rewrite_expr(body2, [pname, ...scope], uses, in_lam),
                    hl, hc))
        }
      }
      EHandle(body1, eff, eff_tas, init1, alias, cls1, ret1)
    }
    # All remaining kinds (ECall, EField, EIndex, EBinop, EUnop, EIf,
    # ERecordLit, EList, ERange, EPipe, EBang, ELitUnit) recurse
    # purely structurally with no scope changes; the leaves return
    # unchanged. The shared visitor handles both.
    _ -> map_expr_kind(k, (sub) => pcs_rewrite_expr(sub, scope, uses, in_lam))
  }
}

fn pcs_rewrite_arms(arms: [Arm], scope: [String], uses: [Use], in_lam: Bool) : [Arm] {
  match arms {
    [] -> []
    [a, ...rest] -> match a {
      Arm(pat, opt_g, body) -> {
        let scope1 = pat_bindings(pat, scope)
        let g1 = match opt_g {
          None -> None
          Some(g) -> Some(pcs_rewrite_expr(g, scope1, uses, in_lam))
        }
        let body1 = pcs_rewrite_expr(body, scope1, uses, in_lam)
        [Arm(pat, g1, body1), ...pcs_rewrite_arms(rest, scope, uses, in_lam)]
      }
    }
  }
}

type PcsRwBlock = { stmts: [Stmt], scope: [String] }

fn pcs_rewrite_block(stmts: [Stmt], scope: [String], uses: [Use], in_lam: Bool,
                     acc: [Stmt]) : PcsRwBlock {
  match stmts {
    [] -> PcsRwBlock { stmts: list_reverse(acc), scope: scope }
    [s, ...rest] -> {
      let r = pcs_rewrite_stmt(s, scope, uses, in_lam)
      pcs_rewrite_block(rest, r.scope, uses, in_lam, [r.stmt, ...acc])
    }
  }
}

type PcsRwStmt = { stmt: Stmt, scope: [String] }

fn pcs_rewrite_stmt(s: Stmt, scope: [String], uses: [Use], in_lam: Bool) : PcsRwStmt {
  match s {
    SLet(pat, ty_opt, rhs) -> {
      let rhs1 = pcs_rewrite_expr(rhs, scope, uses, in_lam)
      PcsRwStmt { stmt: SLet(pat, ty_opt, rhs1), scope: pat_bindings(pat, scope) }
    }
    SVar(name, ty_opt, rhs, ln, cl) -> {
      let rhs1 = pcs_rewrite_expr(rhs, scope, uses, in_lam)
      PcsRwStmt { stmt: SVar(name, ty_opt, rhs1, ln, cl), scope: [name, ...scope] }
    }
    SAssert(c, opt_m) -> {
      let c1 = pcs_rewrite_expr(c, scope, uses, in_lam)
      let m1 = match opt_m {
        None -> None
        Some(m) -> Some(pcs_rewrite_expr(m, scope, uses, in_lam))
      }
      PcsRwStmt { stmt: SAssert(c1, m1), scope: scope }
    }
    SExprStmt(e) -> {
      let e1 = pcs_rewrite_expr(e, scope, uses, in_lam)
      PcsRwStmt { stmt: SExprStmt(e1), scope: scope }
    }
    SIndexAssign(b, i, v, ln, cl) -> {
      let b1 = pcs_rewrite_expr(b, scope, uses, in_lam)
      let i1 = pcs_rewrite_expr(i, scope, uses, in_lam)
      let v1 = pcs_rewrite_expr(v, scope, uses, in_lam)
      PcsRwStmt { stmt: SIndexAssign(b1, i1, v1, ln, cl), scope: scope }
    }
  }
}

fn pcs_rewrite_clauses(cs: [HClause], scope: [String], uses: [Use],
                        in_lam: Bool) : [HClause] {
  match cs {
    [] -> []
    [h, ...rest] -> match h {
      HC(op, params, body, ln, cl) -> {
        let pn = pcs_filter_non_resume(map(params, (p) => p.pname), [])
        let scope1 = list_append(scope, ["state", "log", ...pn])
        let body1 = pcs_rewrite_expr(body, scope1, uses, in_lam)
        [HC(op, params, body1, ln, cl), ...pcs_rewrite_clauses(rest, scope, uses, in_lam)]
      }
    }
  }
}

# Last-use predicate, modeled on `last_use_for` but returning a Bool
# directly. A name is non-last when (a) it appears in a closure
# (in_lam==true at the use site), or (b) the use's (line, col) is
# strictly less than the max non-in-lam position recorded for the
# name. LUUnused names cannot reach this predicate (they have no
# uses to be wrapped).

fn pcs_is_non_last(nm: String, line: Int, col: Int, uses: [Use],
                   in_lam_here: Bool) : Bool {
  if in_lam_here { true }
  else {
    match last_use_for(nm, uses) {
      LUAt(_, ml, mc) -> not (line == ml and col == mc)
      LUBlocked(_) -> true
      LUUnused(_) -> false
    }
  }
}

# ---- unused-param drops at body start ----

fn pcs_prepend_unused_drops(body: Expr, params: [Param], uses: [Use]) : Expr {
  let drops = pcs_collect_param_drops(params, uses, [])
  match drops {
    [] -> body
    [_, ...__] -> Expr {
      kind: EBlock(drops, Some(body)),
      line: body.line, col: body.col, ty: body.ty
    }
  }
}

fn pcs_collect_param_drops(params: [Param], uses: [Use], acc: [Stmt]) : [Stmt] {
  match params {
    [] -> list_reverse(acc)
    [p, ...rest] -> {
      let acc1 = match last_use_for(p.pname, uses) {
        LUUnused(_) -> [pcs_make_drop_stmt(p.pname, p.pline, p.pcol), ...acc]
        _ -> acc
      }
      pcs_collect_param_drops(rest, uses, acc1)
    }
  }
}

fn pcs_make_drop_stmt(nm: String, ln: Int, cl: Int) : Stmt =
  SExprStmt(Expr {
    kind: ECall(
      Expr { kind: EVar("__perceus_drop"), line: ln, col: cl, ty: None },
      [Expr { kind: EVar(nm), line: ln, col: cl, ty: None }]
    ),
    line: ln, col: cl, ty: None
  })

# ---- m5 #2 — last-use analysis (fn-param scope) ----
#
# For each `pub fn` parameter, find the lexical position of its last
# direct read in the body. Reads inside an `ELambda` body are
# conservatively treated as closure captures and BLOCK "last": the
# lambda may survive past its own evaluation point, so the captured
# binding is alive until the closure dies. m5 #2 stays at fn-param
# scope; let-bindings, match-pattern bindings, and closure-aware
# data-flow refinement land in m5 #2b / m5 #3.
#
# Output is diagnostic only — `--dump-last-use` prints one line per
# parameter:
#   fn add@10:
#     param x: last-use at 10:32
#     param y: last-use at 10:36
#     param z: blocked by closure capture
#     param u: never used
# m5 #3 will consume the same `last_use_for` result to drive drop
# emission.

type Use = U(String, Int, Int, Bool)   # name, line, col, in_lambda

type LU
  = LUAt(String, Int, Int)             # last-use position
  | LUBlocked(String)                  # closure capture blocks last
  | LUUnused(String)                   # never referenced

# Walker entry: collect every EVar in `e`. The flag is true while we
# are inside any enclosing ELambda body; closure capture detection
# is conservative — a single in-lambda ref to a name blocks last for
# that name regardless of how far up the lambda is nested.
fn scan_uses_expr(e: Expr, in_lam: Bool) : [Use] =
  scan_uses_kind(e.kind, e.line, e.col, in_lam)

fn scan_uses_kind(k: ExprKind, line: Int, col: Int, in_lam: Bool) : [Use] {
  match k {
    EVar(nm) -> [U(nm, line, col, in_lam)]
    # Interpolated strings hide EVar refs inside `#{...}` segments —
    # the lexer keeps the raw source span and emit re-parses at code
    # gen. Mirror `fv_interp` (5700-5725) so a binding read only via
    # interpolation never gets mis-classified as `LUUnused`.
    EStr(span, is_triple) -> scan_uses_in_interp(span, is_triple, in_lam)
    ECall(f, xs) -> list_append(scan_uses_expr(f, in_lam),
                                scan_uses_in_exprs(xs, in_lam))
    EField(x, _) -> scan_uses_expr(x, in_lam)
    EIndex(x, i) -> list_append(scan_uses_expr(x, in_lam),
                                scan_uses_expr(i, in_lam))
    EBinop(_, l, r) -> list_append(scan_uses_expr(l, in_lam),
                                   scan_uses_expr(r, in_lam))
    EUnop(_, x) -> scan_uses_expr(x, in_lam)
    EIf(c, t, opt_e) -> {
      let p1 = list_append(scan_uses_expr(c, in_lam), scan_uses_expr(t, in_lam))
      match opt_e {
        None -> p1
        Some(e2) -> list_append(p1, scan_uses_expr(e2, in_lam))
      }
    }
    EMatch(s, arms) -> list_append(scan_uses_expr(s, in_lam),
                                    scan_uses_in_arms(arms, in_lam))
    ELambda(_, body) -> scan_uses_expr(body, true)
    ERecordLit(_, fis) -> scan_uses_in_field_inits(fis, in_lam)
    EList(elems) -> scan_uses_in_list_elems(elems, in_lam)
    ERange(lo, hi, opt_by) -> {
      let p1 = list_append(scan_uses_expr(lo, in_lam), scan_uses_expr(hi, in_lam))
      match opt_by {
        None -> p1
        Some(e2) -> list_append(p1, scan_uses_expr(e2, in_lam))
      }
    }
    EBlock(stmts, opt_tail) -> {
      let p1 = scan_uses_in_stmts(stmts, in_lam)
      match opt_tail {
        None -> p1
        Some(e2) -> list_append(p1, scan_uses_expr(e2, in_lam))
      }
    }
    EPipe(l, r) -> list_append(scan_uses_expr(l, in_lam),
                                scan_uses_expr(r, in_lam))
    EHandle(body, _, _, init_opt, _, clauses, ret_opt) -> {
      let p1 = scan_uses_expr(body, in_lam)
      let p2 = match init_opt {
        None -> p1
        Some(e2) -> list_append(p1, scan_uses_expr(e2, in_lam))
      }
      let p3 = list_append(p2, scan_uses_in_clauses(clauses, in_lam))
      match ret_opt {
        None -> p3
        Some(hr) -> match hr {
          HR(_, body2, _, _) -> list_append(p3, scan_uses_expr(body2, in_lam))
        }
      }
    }
    _ -> []
  }
}

fn scan_uses_in_exprs(es: [Expr], in_lam: Bool) : [Use] {
  match es {
    [] -> []
    [h, ...rest] -> list_append(scan_uses_expr(h, in_lam),
                                scan_uses_in_exprs(rest, in_lam))
  }
}

fn scan_uses_in_arms(arms: [Arm], in_lam: Bool) : [Use] {
  match arms {
    [] -> []
    [h, ...rest] -> match h {
      Arm(_, guard_opt, body) -> {
        let p1 = match guard_opt {
          None -> []
          Some(g) -> scan_uses_expr(g, in_lam)
        }
        let p2 = list_append(p1, scan_uses_expr(body, in_lam))
        list_append(p2, scan_uses_in_arms(rest, in_lam))
      }
    }
  }
}

fn scan_uses_in_field_inits(fis: [FieldInit], in_lam: Bool) : [Use] {
  match fis {
    [] -> []
    [h, ...rest] -> match h {
      FI(_, e) -> list_append(scan_uses_expr(e, in_lam),
                              scan_uses_in_field_inits(rest, in_lam))
    }
  }
}

fn scan_uses_in_list_elems(es: [ListElem], in_lam: Bool) : [Use] {
  match es {
    [] -> []
    [h, ...rest] -> {
      let inner = match h {
        ElPlain(e) -> e
        ElSpread(e) -> e
      }
      list_append(scan_uses_expr(inner, in_lam),
                  scan_uses_in_list_elems(rest, in_lam))
    }
  }
}

fn scan_uses_in_stmts(stmts: [Stmt], in_lam: Bool) : [Use] {
  match stmts {
    [] -> []
    [h, ...rest] -> {
      let p1 = match h {
        SLet(_, _, rhs) -> scan_uses_expr(rhs, in_lam)
        SAssert(c, opt_msg) -> {
          let q = scan_uses_expr(c, in_lam)
          match opt_msg {
            None -> q
            Some(e2) -> list_append(q, scan_uses_expr(e2, in_lam))
          }
        }
        SExprStmt(e) -> scan_uses_expr(e, in_lam)
        SIndexAssign(arr, idx, val, _, _) -> {
          let q1 = list_append(scan_uses_expr(arr, in_lam),
                               scan_uses_expr(idx, in_lam))
          list_append(q1, scan_uses_expr(val, in_lam))
        }
        SVar(_, _, init, _, _) -> scan_uses_expr(init, in_lam)
      }
      list_append(p1, scan_uses_in_stmts(rest, in_lam))
    }
  }
}

fn scan_uses_in_clauses(cs: [HClause], in_lam: Bool) : [Use] {
  match cs {
    [] -> []
    [h, ...rest] -> match h {
      HC(_, _, body, _, _) -> list_append(scan_uses_expr(body, in_lam),
                                          scan_uses_in_clauses(rest, in_lam))
    }
  }
}

# Re-parse an `EStr` span to surface `#{expr}` interpolations and
# scan each parsed sub-expression for EVar refs. Mirrors `fv_interp`.
fn scan_uses_in_interp(span: String, is_triple: Bool, in_lam: Bool) : [Use] {
  let n = string_length(span)
  let body_start = if is_triple { 3 } else { 1 }
  let body_end = if is_triple { n - 3 } else { n - 1 }
  let parts = iscan_collect(span, body_end,
                            IScan { parts: [], lit_start: body_start, i: body_start })
  scan_uses_interp_parts(parts, in_lam)
}

fn scan_uses_interp_parts(parts: [IPart], in_lam: Bool) : [Use] {
  match parts {
    [] -> []
    [p, ...rest] -> match p {
      IpLit(_, _) -> scan_uses_interp_parts(rest, in_lam)
      IpExp(esrc) -> {
        let toks = tokenize(esrc)
        let prs = parser_new("<interp>", esrc, toks)
        let r = parse_expr(prs)
        let head = match r.r {
          Some(e) -> scan_uses_expr(e, in_lam)
          None -> []
        }
        list_append(head, scan_uses_interp_parts(rest, in_lam))
      }
    }
  }
}

# Find the last-use record for `nm` among `uses`. A single in-lambda
# reference forces `LUBlocked`; otherwise the max (line, col) wins.
fn last_use_for(nm: String, uses: [Use]) : LU =
  last_use_for_loop(nm, uses, false, -1, -1)

fn last_use_for_loop(nm: String, uses: [Use], blocked: Bool,
                     mx_line: Int, mx_col: Int) : LU {
  match uses {
    [] -> {
      if blocked { LUBlocked(nm) }
      else if mx_line < 0 { LUUnused(nm) }
      else { LUAt(nm, mx_line, mx_col) }
    }
    [h, ...rest] -> match h {
      U(uname, ln, cl, in_lam) -> {
        if uname == nm {
          if in_lam {
            last_use_for_loop(nm, rest, true, mx_line, mx_col)
          } else if ln > mx_line or (ln == mx_line and cl > mx_col) {
            last_use_for_loop(nm, rest, blocked, ln, cl)
          } else {
            last_use_for_loop(nm, rest, blocked, mx_line, mx_col)
          }
        } else {
          last_use_for_loop(nm, rest, blocked, mx_line, mx_col)
        }
      }
    }
  }
}

# ---- `--dump-last-use`: per-fn-param last-use diagnostic ----

fn dump_last_use_for_param(p: Param, uses: [Use]) : Unit / Console {
  let lu = last_use_for(p.pname, uses)
  match lu {
    LUAt(nm, ln, cl) -> print("  param #{nm}: last-use at #{int_to_string(ln)}:#{int_to_string(cl)}")
    LUBlocked(nm)    -> print("  param #{nm}: blocked by closure capture")
    LUUnused(nm)     -> print("  param #{nm}: never used")
  }
}

fn dump_last_use_for_decl(d: Decl) : Unit / Console {
  match d {
    DFn(_, nm, _, params, _, _, body, ln, _) -> {
      print("fn #{nm}@#{int_to_string(ln)}:")
      let uses = scan_uses_expr(body, false)
      params |> each((p) => dump_last_use_for_param(p, uses))
    }
    _ -> {}
  }
}

fn dump_last_use(file: String, decls: [Decl]) : Int {
  let r = infer_program(file, decls, false)
  r.decls |> each(dump_last_use_for_decl)
  r.errs
}

# ---- `--holes`: typed-hole reports ----
#
# For each `?` / `?name` in the program, print the expected type
# (recovered from the final substitution) and the bindings visible
# at that point. Candidate synthesis — what the doc calls "a bounded
# enumeration of fillable expressions" — lands in a later milestone;
# this pass covers the "stop, record, keep going" half.
#
# Output mirrors the example in docs/typed-holes.md closely.

fn dump_scope_entry(te: TyEntry) : Unit / Console =
  print("    #{te.name} : #{scheme_to_string(te.scheme)}")

fn dump_hole_candidate(c: String) : Unit / Console =
  print("    #{c}")

fn dump_hole_report(file: String, rh: ResolvedHole, prelude_len: Int) : Unit / Console {
  match rh {
    RH(kind, line, col, ty, scope, env_fresh) -> {
      let label = hole_kind_label(kind)
      let user_scope = drop_last_entries(scope, prelude_len)
      let cands = synth_candidates(scope, ty, env_fresh)
      print("#{file}:#{int_to_string(line)}:#{int_to_string(col)}: type hole #{label}")
      print("")
      print("  expected: #{ty_to_string(ty)}")
      print("")
      match user_scope {
        [] -> { print("  in scope: (empty)") print("") }
        _  -> {
          print("  in scope:")
          user_scope |> each(dump_scope_entry)
          print("")
        }
      }
      match cands {
        [] -> ()
        _  -> {
          print("  candidates that fit:")
          cands |> each(dump_hole_candidate)
          print("")
        }
      }
    }
  }
}

# Human-readable label for a hole site. `?`, `?name`, or
# `todo!("msg")`. Used by `--holes` and `--strict-holes`.
fn hole_kind_label(k: HoleKind) : String {
  match k {
    HKHole(nm_opt) -> match nm_opt {
      Some(nm) -> cat2("?", nm)
      None     -> "?"
    }
    HKTodo(msg) -> concat_all(["todo!(\"", msg, "\")"])
  }
}

fn dump_holes_loop(file: String, hs: [ResolvedHole], prelude_len: Int) : Unit {
  match hs {
    [] -> ()
    [h, ...rest] -> { dump_hole_report(file, h, prelude_len) dump_holes_loop(file, rest, prelude_len) }
  }
}

# ---- bounded candidate synthesis ----
#
# Given a hole's expected type `E` and the visible scope, enumerate a
# small set of expressions the user (or an LLM) might plug in. The
# doc calls this a "bounded enumeration": we do not explore beyond a
# single application, and we never nest candidates. Two classes:
#   1. direct: `name` where `name : T` and `T ~= E`.
#   2. application: `f(x1, .., xn)` where `f : (T1..Tn) -> R`, `R ~= E`,
#      and each `Ti` unifies with some in-scope name's type.
# Entries whose *immediate* return type is a bare polymorphic var (e.g.
# `panic`, `exit`) are rejected from class 2 — they'd match any hole
# and drown useful suggestions. A shared `env_fresh` counter keeps
# each instantiation's fresh TyVars disjoint from the hole's own
# residual vars.

fn list_has_int(xs: [Int], n: Int) : Bool {
  match xs {
    [] -> false
    [h, ...rest] -> if h == n { true } else { list_has_int(rest, n) }
  }
}

# Reject entries whose return type after stripping TyFnT is a bare
# bound variable — the scheme accepts anything, so suggesting it is
# noise. Accept structural return types (TyCon, TyList, primitives),
# which still constrain the substitution meaningfully.
fn synth_return_structural(sc: TyScheme) : Bool {
  match sc {
    Scheme(vars, _, _, ty) -> match ty {
      TyFnT(_, ret, _) -> match ret {
        TyVarT(v) -> not list_has_int(vars, v)
        _         -> true
      }
      TyVarT(v) -> not list_has_int(vars, v)
      _         -> true
    }
  }
}

fn list_has_string(xs: [String], s: String) : Bool {
  match xs {
    [] -> false
    [h, ...rest] -> if h == s { true } else { list_has_string(rest, s) }
  }
}

# Walk scope looking for the first entry whose instantiated type
# unifies with `want`. Returns the name on hit, None otherwise.
# `avoid` prevents obvious circular fills like `f(f)` when f itself
# is the candidate head.
type ArgMatch = { name: String, sub: Subst, fresh: Int }

fn synth_find_arg(scope: [TyEntry], want: Ty, fresh: Int, avoid: [String], sub: Subst) : Option[ArgMatch] {
  match scope {
    [] -> None
    [te, ...rest] -> {
      if list_has_string(avoid, te.name) or (not synth_return_structural(te.scheme)) {
        synth_find_arg(rest, want, fresh, avoid, sub)
      } else {
        let inst = instantiate(TyEnv { entries: [], fresh: fresh }, te.scheme)
        match unify(inst.ty, want, sub) {
          Some(sub1) -> Some(ArgMatch { name: te.name, sub: sub1, fresh: inst.env.fresh })
          None       -> synth_find_arg(rest, want, fresh, avoid, sub)
        }
      }
    }
  }
}

type ArgsMatch = { names: [String], sub: Subst, fresh: Int }

fn synth_find_args(scope: [TyEntry], params: [Ty], fresh: Int, avoid: [String],
                   sub: Subst, acc: [String]) : Option[ArgsMatch] {
  match params {
    [] -> Some(ArgsMatch { names: list_reverse(acc), sub: sub, fresh: fresh })
    [p, ...rest] -> {
      let p_now = apply_ty(sub, p)
      match synth_find_arg(scope, p_now, fresh, avoid, sub) {
        Some(am) -> synth_find_args(scope, rest, am.fresh, avoid, am.sub, [am.name, ...acc])
        None     -> None
      }
    }
  }
}

# Try entry `te` as a direct match or a 1-level application against
# `expected`. Returns rendered candidate text or None.
fn synth_try_entry(all_scope: [TyEntry], te: TyEntry, expected: Ty, fresh: Int) : Option[String] {
  let inst = instantiate(TyEnv { entries: [], fresh: fresh }, te.scheme)
  match unify(inst.ty, expected, subst_empty()) {
    Some(_) -> Some(te.name)
    None    -> match inst.ty {
      TyFnT(ps, r, _) -> {
        if synth_return_structural(te.scheme) {
          match unify(r, expected, subst_empty()) {
            None     -> None
            Some(s0) -> match synth_find_args(all_scope, ps, inst.env.fresh, [te.name], s0, []) {
              None    -> None
              Some(m) -> Some(concat_all([te.name, "(", join_with(m.names, ", "), ")"]))
            }
          }
        } else { None }
      }
      _ -> None
    }
  }
}

fn synth_candidates_loop(all: [TyEntry], cur: [TyEntry], expected: Ty, fresh: Int,
                         acc: [String], max: Int) : [String] {
  if list_length(acc) >= max { list_reverse(acc) }
  else { match cur {
    [] -> list_reverse(acc)
    [te, ...rest] -> match synth_try_entry(all, te, expected, fresh) {
      Some(expr) -> synth_candidates_loop(all, rest, expected, fresh, [expr, ...acc], max)
      None       -> synth_candidates_loop(all, rest, expected, fresh, acc, max)
    }
  } }
}

fn synth_candidates(scope: [TyEntry], expected: Ty, fresh: Int) : [String] =
  synth_candidates_loop(scope, scope, expected, fresh, [], 8)

fn dump_holes(file: String, decls: [Decl]) : Int / Console {
  let r = infer_program(file, decls, false)
  match r.holes {
    [] -> { print("(no typed holes)") r.errs }
    _  -> { dump_holes_loop(file, r.holes, r.prelude_len) r.errs }
  }
}

# ---- `--holes-json`: machine-readable hole reports ----
#
# Emits a single JSON array, stable schema per docs/typed-holes.md.
# Each element carries {file, line, col, name, expected_type, in_scope,
# candidates}. `in_scope` lists every reachable binding including the
# prelude — an LLM that consumes this output wants the full picture.
# `candidates` is a (possibly empty) list; bounded synthesis fills it
# in a follow-up pass, but the array is always present so the schema
# stays stable across feature rollouts.

fn json_escape_char(c: Char) : String {
  if c == '"' { "\\\"" }
  else if c == '\\' { "\\\\" }
  else if c == '\n' { "\\n" }
  else if c == '\r' { "\\r" }
  else if c == '\t' { "\\t" }
  else if char_to_int(c) < 32 {
    # Control byte → \u00XX. We only ever feed ASCII into this path,
    # so two hex digits suffice.
    let n = char_to_int(c)
    let hi = n / 16
    let lo = n % 16
    concat_all(["\\u00", hex_digit(hi), hex_digit(lo)])
  }
  else { "#{c}" }
}

fn json_escape_loop(s: String, i: Int, n: Int, acc: String) : String {
  if i >= n { acc }
  else {
    match char_at(s, i) {
      Some(c) -> json_escape_loop(s, i + 1, n, string_concat(acc, json_escape_char(c)))
      None    -> acc
    }
  }
}

fn json_escape(s: String) : String =
  json_escape_loop(s, 0, string_length(s), "")

fn json_str(s: String) : String =
  concat_all(["\"", json_escape(s), "\""])

fn json_null() : String = "null"

fn json_scope_entry(te: TyEntry) : String =
  concat_all([
    "{\"name\": ", json_str(te.name),
    ", \"type\": ", json_str(scheme_to_string(te.scheme)), "}"
  ])

fn json_scope_entries(es: [TyEntry]) : String =
  concat_all(["[", join_with(map(es, json_scope_entry), ", "), "]"])

fn json_candidate(expr: String) : String =
  concat_all(["{\"expr\": ", json_str(expr), ", \"kind\": \"synth\"}"])

fn json_candidates(cs: [String]) : String =
  concat_all(["[", join_with(map(cs, json_candidate), ", "), "]"])

fn json_hole_report(file: String, rh: ResolvedHole) : String {
  match rh {
    RH(kind, line, col, ty, scope, env_fresh) -> {
      let kj = hole_kind_json(kind)
      let cands = synth_candidates(scope, ty, env_fresh)
      concat_all([
        "{",
        "\"file\": ", json_str(file),
        ", \"line\": ", int_to_string(line),
        ", \"col\": ", int_to_string(col),
        ", \"kind\": ", kj.kind,
        ", \"name\": ", kj.name,
        ", \"message\": ", kj.message,
        ", \"expected_type\": ", json_str(ty_to_string(ty)),
        ", \"in_scope\": ", json_scope_entries(scope),
        ", \"candidates\": ", json_candidates(cands),
        "}"
      ])
    }
  }
}

# Triple of JSON fields derived from a HoleKind: the discriminator
# string, the optional `name` payload (only `?name` populates it),
# and the optional `message` payload (only `todo!(msg)` populates).
type HoleKindJson = { kind: String, name: String, message: String }

fn hole_kind_json(k: HoleKind) : HoleKindJson {
  match k {
    HKHole(nm_opt) -> {
      let nm_field = match nm_opt {
        Some(nm) -> json_str(nm)
        None     -> json_null()
      }
      HoleKindJson { kind: json_str("hole"), name: nm_field, message: json_null() }
    }
    HKTodo(msg) ->
      HoleKindJson { kind: json_str("todo"), name: json_null(), message: json_str(msg) }
  }
}

fn dump_holes_json(file: String, decls: [Decl]) : Int / Console {
  let r = infer_program(file, decls, false)
  let body = join_with(map(r.holes, (h) => json_hole_report(file, h)), ", ")
  print(concat_all(["[", body, "]"]))
  r.errs
}

# --strict-holes uses this on the normal compile path: emit a
# one-line diagnostic per hole to stderr, and promote the hole count
# to the return code so the driver skips emission. Users who want the
# rich report should run --holes or --holes-json explicitly.
fn strict_holes_report_loop(file: String, hs: [ResolvedHole]) : Unit {
  match hs {
    [] -> ()
    [h, ...rest] -> {
      match h {
        RH(kind, line, col, ty, _, _) -> {
          let label = hole_kind_label(kind)
          diag_error(file, line, col, "unfilled hole #{label} : #{ty_to_string(ty)}")
          diag_help("replace `#{label}` with an expression of type `#{ty_to_string(ty)}`")
          diag_note("--strict-holes blocks emission until every `?` / `?name` / `todo!` is filled")
        }
      }
      strict_holes_report_loop(file, rest)
    }
  }
}

fn strict_holes_check(file: String, decls: [Decl]) : Int / Console {
  let r = infer_program(file, decls, false)
  let n = list_length(r.holes)
  if n == 0 { r.errs }
  else {
    strict_holes_report_loop(file, r.holes)
    eprint("#{file}: #{int_to_string(n)} unfilled hole(s) (--strict-holes)")
    r.errs + n
  }
}

# ====================================================================
# LLVM backend (M3a + M3b — skeleton)
# ====================================================================
#
# Emits textual LLVM IR that links against stage0/runtime_llvm.c. The
# runtime still owns refcounting, allocation, closures, and the prelude;
# the `.ll` just defines `kai_main` plus any user fns and routes every
# value through opaque `%KaiValue*` pointers.
#
# M3a handled hello.kai (strings + one print call). M3b adds:
#   - Int / Bool literals                           (kaix_int / kaix_bool)
#   - Fn params bound to named SSA registers        (%p_<name>)
#   - Local let bindings                            (stored in a lookup)
#   - EVar reads that resolve to a local            (no closures yet)
#   - ECall to user-defined fns                     (@kai_<name>)
#   - ECall to the M3b prelude subset               (@kaix_prelude_<name>)
#   - EBinop arithmetic/comparison/logic            (via kaix_* helpers)
#   - EUnop (unary -, not)                          (via kaix_neg / kaix_not)
#   - EIf with basic blocks + phi
#   - EBlock / SLet / SExprStmt / SAssert(cond)     (assert message: TODO)
#
# Still out of scope for M3b: strings with interpolation, pipes, map /
# filter / reduce / each, ranges, lists, variants, match, lambdas,
# records, field access.

fn llvm_header() : String =
  concat_all([
    "; generated by kaikai stage 2 (LLVM backend)\n",
    "%KaiValue = type opaque\n",
    # m7c-a: opaque types for the effects ABI. The C backend uses
    # full struct definitions (KaiCont with status/fn/data fields,
    # KaiEvidence with parent/handler/jmp pointers) but the LLVM
    # backend never inspects them at the IR level — every access
    # goes through a runtime helper. Treating them as opaque keeps
    # the IR small and lets stage0/runtime_llvm.c own the layout.
    "%KaiCont = type opaque\n",
    "%KaiEvidence = type opaque\n",
    "\n",
    "declare %KaiValue* @kaix_str(i8*)\n",
    "declare %KaiValue* @kaix_int(i64)\n",
    "declare %KaiValue* @kaix_bool(i32)\n",
    "declare i32           @kaix_truthy(%KaiValue*)\n",
    "declare %KaiValue* @kaix_internal_dup(%KaiValue*)\n",
    "declare %KaiValue* @kaix_internal_drop(%KaiValue*)\n",
    "declare %KaiValue* @kaix_add(%KaiValue*, %KaiValue*)\n",
    "declare %KaiValue* @kaix_sub(%KaiValue*, %KaiValue*)\n",
    "declare %KaiValue* @kaix_mul(%KaiValue*, %KaiValue*)\n",
    "declare %KaiValue* @kaix_div(%KaiValue*, %KaiValue*)\n",
    "declare %KaiValue* @kaix_idiv(%KaiValue*, %KaiValue*)\n",
    "declare %KaiValue* @kaix_mod(%KaiValue*, %KaiValue*)\n",
    "declare %KaiValue* @kaix_eq(%KaiValue*, %KaiValue*)\n",
    "declare %KaiValue* @kaix_ne(%KaiValue*, %KaiValue*)\n",
    "declare %KaiValue* @kaix_lt(%KaiValue*, %KaiValue*)\n",
    "declare %KaiValue* @kaix_gt(%KaiValue*, %KaiValue*)\n",
    "declare %KaiValue* @kaix_le(%KaiValue*, %KaiValue*)\n",
    "declare %KaiValue* @kaix_ge(%KaiValue*, %KaiValue*)\n",
    "declare %KaiValue* @kaix_neg(%KaiValue*)\n",
    "declare %KaiValue* @kaix_not(%KaiValue*)\n",
    "declare %KaiValue* @kaix_string_concat(%KaiValue*, %KaiValue*)\n",
    "declare %KaiValue* @kaix_to_string(%KaiValue*)\n",
    "declare %KaiValue* @kaix_range(%KaiValue*, %KaiValue*)\n",
    "declare %KaiValue* @kaix_range_step(%KaiValue*, %KaiValue*, %KaiValue*)\n",
    "declare %KaiValue* @kaix_closure(i8*, i32, i32, i8*)\n",
    "declare %KaiValue* @kaix_apply(%KaiValue*, i32, %KaiValue**)\n",
    "declare %KaiValue* @kaix_prelude_print(%KaiValue*)\n",
    "declare %KaiValue* @kaix_prelude_eprint(%KaiValue*)\n",
    "declare %KaiValue* @kaix_prelude_int_to_string(%KaiValue*)\n",
    "declare %KaiValue* @kaix_prelude_map(%KaiValue*, %KaiValue*)\n",
    "declare %KaiValue* @kaix_prelude_each(%KaiValue*, %KaiValue*)\n",
    "declare %KaiValue* @kaix_prelude_filter(%KaiValue*, %KaiValue*)\n",
    "declare %KaiValue* @kaix_prelude_reduce(%KaiValue*, %KaiValue*, %KaiValue*)\n",
    "declare %KaiValue* @kaix_print_thunk(%KaiValue*, %KaiValue**, i32)\n",
    "declare %KaiValue* @kaix_eprint_thunk(%KaiValue*, %KaiValue**, i32)\n",
    "declare %KaiValue* @kaix_int_to_string_thunk(%KaiValue*, %KaiValue**, i32)\n",
    "declare %KaiValue* @kaix_variant(i32, i8*, i32, %KaiValue**)\n",
    "declare i32           @kaix_is_variant(%KaiValue*, i8*)\n",
    "declare %KaiValue* @kaix_variant_arg(%KaiValue*, i32)\n",
    "declare %KaiValue* @kaix_eq_raw(%KaiValue*, %KaiValue*)\n",
    "declare %KaiValue* @kaix_match_panic(%KaiValue*)\n",
    "declare %KaiValue* @kaix_cons(%KaiValue*, %KaiValue*)\n",
    "declare %KaiValue* @kaix_incref(%KaiValue*)\n",
    "declare %KaiValue* @kaix_nil()\n",
    "declare i32           @kaix_is_cons(%KaiValue*)\n",
    "declare i32           @kaix_is_nil(%KaiValue*)\n",
    "declare %KaiValue* @kaix_cons_head(%KaiValue*)\n",
    "declare %KaiValue* @kaix_cons_tail(%KaiValue*)\n",
    "declare %KaiValue* @kaix_capture(%KaiValue*, i32)\n",
    "declare %KaiValue* @kaix_prelude_list_append(%KaiValue*, %KaiValue*)\n",
    "declare %KaiValue* @kaix_prelude_list_length(%KaiValue*)\n",
    "declare %KaiValue* @kaix_prelude_list_reverse(%KaiValue*)\n",
    "declare %KaiValue* @kaix_char(i32)\n",
    "declare %KaiValue* @kaix_real(double)\n",
    "declare %KaiValue* @kaix_unit()\n",
    "declare %KaiValue* @kaix_record(i32, %KaiValue**, i8**)\n",
    "declare %KaiValue* @kaix_field(%KaiValue*, i8*)\n",
    "declare %KaiValue* @kaix_prelude_args()\n",
    "declare %KaiValue* @kaix_prelude_exit(%KaiValue*)\n",
    "declare %KaiValue* @kaix_prelude_panic_fn(%KaiValue*)\n",
    "declare %KaiValue* @kaix_prelude_panic(%KaiValue*)\n",
    "declare %KaiValue* @kaix_prelude_read_file(%KaiValue*)\n",
    "declare %KaiValue* @kaix_prelude_write_file(%KaiValue*, %KaiValue*)\n",
    "declare %KaiValue* @kaix_prelude_read_line()\n",
    "declare %KaiValue* @kaix_prelude_real_to_string(%KaiValue*)\n",
    "declare %KaiValue* @kaix_prelude_string_to_int(%KaiValue*)\n",
    "declare %KaiValue* @kaix_prelude_string_to_real(%KaiValue*)\n",
    "declare %KaiValue* @kaix_prelude_string_length(%KaiValue*)\n",
    "declare %KaiValue* @kaix_prelude_string_concat(%KaiValue*, %KaiValue*)\n",
    "declare %KaiValue* @kaix_prelude_string_concat_all(%KaiValue*)\n",
    "declare %KaiValue* @kaix_prelude_string_join(%KaiValue*, %KaiValue*)\n",
    "declare %KaiValue* @kaix_prelude_array_make(%KaiValue*, %KaiValue*)\n",
    "declare %KaiValue* @kaix_prelude_array_length(%KaiValue*)\n",
    "declare %KaiValue* @kaix_prelude_array_get(%KaiValue*, %KaiValue*)\n",
    "declare %KaiValue* @kaix_prelude_array_set(%KaiValue*, %KaiValue*, %KaiValue*)\n",
    "declare %KaiValue* @kaix_prelude_array_grow(%KaiValue*, %KaiValue*, %KaiValue*)\n",
    "declare %KaiValue* @kaix_prelude_string_slice(%KaiValue*, %KaiValue*, %KaiValue*)\n",
    "declare %KaiValue* @kaix_prelude_string_split(%KaiValue*, %KaiValue*)\n",
    "declare %KaiValue* @kaix_prelude_string_contains(%KaiValue*, %KaiValue*)\n",
    "declare %KaiValue* @kaix_prelude_char_at(%KaiValue*, %KaiValue*)\n",
    "declare %KaiValue* @kaix_prelude_char_to_int(%KaiValue*)\n",
    "declare %KaiValue* @kaix_prelude_int_to_char(%KaiValue*)\n",
    # m7c-b: runtime helpers for the effects ABI. The C backend
    # invokes these via in-line statement-expressions; the LLVM
    # backend declares them as external and emits the same calls.
    "declare i64 @kaix_fresh_handler_id()\n",
    "declare void @kaix_evidence_push(i8*, i8*, i8*)\n",
    "declare void @kaix_evidence_pop()\n",
    # m7c-c — op-call dispatch helpers. `lookup_handler` returns
    # the `*Ev<Eff>` blob (cast to i8*); `cont_init_identity`
    # initialises the on-stack KaiCont alloca.
    "declare i8* @kaix_evidence_lookup_handler(i8*)\n",
    "declare void @kaix_cont_init_identity(i8*, i64)\n",
    # m7c-d — clause-body helper. The LLVM IR emits each
    # `resume(v)` call as a direct `kai_cont_resume(k, v)`
    # invocation; the cont pointer comes from the clause's `%k`
    # parameter (bound as a local register).
    "declare %KaiValue* @kaix_cont_resume(i8*, %KaiValue*)\n",
    # m7c-d — write `state` slot for 2-arg `resume(v, ns)`.
    # Wraps `((KaiValue **)((char*)self + 16))[0] = v` so the IR
    # stays free of EvX layout assumptions.
    "declare void @kaix_clause_state_set(i8*, %KaiValue*)\n",
    # m7c-d — default-handler wrappers for builtins in main's row.
    # Defined non-static in runtime_llvm.c so the IR can link.
    "declare %KaiValue* @kaix_default_stdout_print(i8*, %KaiValue*, i8*)\n",
    "declare %KaiValue* @kaix_default_stderr_eprint(i8*, %KaiValue*, i8*)\n",
    "declare %KaiValue* @kaix_default_fail_fail(i8*, %KaiValue*, i8*)\n",
    "declare %KaiValue* @kaix_default_mutable_array_make(i8*, %KaiValue*, %KaiValue*, i8*)\n",
    "declare %KaiValue* @kaix_default_mutable_array_length(i8*, %KaiValue*, i8*)\n",
    "declare %KaiValue* @kaix_default_mutable_array_get(i8*, %KaiValue*, %KaiValue*, i8*)\n",
    "declare %KaiValue* @kaix_default_mutable_array_set(i8*, %KaiValue*, %KaiValue*, %KaiValue*, i8*)\n",
    "declare %KaiValue* @kaix_default_mutable_array_grow(i8*, %KaiValue*, %KaiValue*, %KaiValue*, i8*)\n",
    "declare %KaiValue* @kaix_default_random_int_range(i8*, %KaiValue*, %KaiValue*, i8*)\n",
    "\n"
  ])

# ---- id generator ----
type LlvmIdGen = { next: Int }
fn llvm_id_new() : LlvmIdGen = LlvmIdGen { next: 0 }
fn llvm_id_bump(g: LlvmIdGen) : LlvmIdGen = LlvmIdGen { next: g.next + 1 }

# ---- local scope ----
type LlvmLocal = LL(String, String)       # user name → LLVM register (e.g. "n" → "%p_n")

fn llvm_local_find_loop(ls: [LlvmLocal], target: String) : Option[String] {
  match ls {
    [] -> None
    [l, ...rest] -> match l {
      LL(nm, reg) -> if nm == target { Some(reg) } else { llvm_local_find_loop(rest, target) }
    }
  }
}

fn llvm_local_find(ls: [LlvmLocal], target: String) : Option[String] = llvm_local_find_loop(ls, target)

# ---- the emit state carried through expressions ----
#
# `body` accumulates instructions for the current fn; `globals`
# accumulates @str.N constants shared across fns. `last_val` is the
# LLVM operand the most recent expression evaluated to. `locals` is
# the stack of visible bindings (newest first).

type LlvmEmit = {
  ids: LlvmIdGen,
  globals: String,
  body: String,
  last_val: String,
  cur_label: String,
  locals: [LlvmLocal],
  fns: [EFn],
  vars_: [EVar],
  lams: [LamInfo],
  # m7c-c — per-`Eff.op` field offset inside the matching `%EvX`
  # struct. Populated once in `emit_program_llvm` from the
  # declared (and injected-builtin) effects; consulted by the
  # op-call dispatch in `llvm_emit_call` to GEP the right
  # function pointer.
  op_offsets: [OpOffset]
}

type OpOffset = OO(String, Int)

fn llvm_emit_new() : LlvmEmit =
  LlvmEmit { ids: llvm_id_new(), globals: "", body: "", last_val: "",
             cur_label: "entry", locals: [], fns: [], vars_: [], lams: [],
             op_offsets: [] }

fn llvm_append_body(e: LlvmEmit, s: String) : LlvmEmit =
  LlvmEmit { ids: e.ids, globals: e.globals, body: string_concat(e.body, s),
             last_val: e.last_val, cur_label: e.cur_label,
             locals: e.locals, fns: e.fns, vars_: e.vars_, lams: e.lams, op_offsets: e.op_offsets }

fn llvm_set_last(e: LlvmEmit, v: String) : LlvmEmit =
  LlvmEmit { ids: e.ids, globals: e.globals, body: e.body,
             last_val: v, cur_label: e.cur_label,
             locals: e.locals, fns: e.fns, vars_: e.vars_, lams: e.lams, op_offsets: e.op_offsets }

fn llvm_set_label(e: LlvmEmit, lbl: String) : LlvmEmit =
  LlvmEmit { ids: e.ids, globals: e.globals, body: e.body,
             last_val: e.last_val, cur_label: lbl,
             locals: e.locals, fns: e.fns, vars_: e.vars_, lams: e.lams, op_offsets: e.op_offsets }

fn llvm_append_global(e: LlvmEmit, s: String) : LlvmEmit =
  LlvmEmit { ids: e.ids, globals: string_concat(e.globals, s), body: e.body,
             last_val: e.last_val, cur_label: e.cur_label,
             locals: e.locals, fns: e.fns, vars_: e.vars_, lams: e.lams, op_offsets: e.op_offsets }

fn llvm_fresh_id(e: LlvmEmit) : LlvmEmit =
  LlvmEmit { ids: llvm_id_bump(e.ids), globals: e.globals, body: e.body,
             last_val: e.last_val, cur_label: e.cur_label,
             locals: e.locals, fns: e.fns, vars_: e.vars_, lams: e.lams, op_offsets: e.op_offsets }

fn llvm_push_local(e: LlvmEmit, nm: String, reg: String) : LlvmEmit =
  LlvmEmit { ids: e.ids, globals: e.globals, body: e.body,
             last_val: e.last_val, cur_label: e.cur_label,
             locals: [LL(nm, reg), ...e.locals], fns: e.fns, vars_: e.vars_, lams: e.lams, op_offsets: e.op_offsets }

# Open a new LLVM basic block: emit the `<label>:` header and
# record `label` as the active one so downstream phi nodes can
# recover which block a value came from.
fn llvm_open_block(e: LlvmEmit, label: String) : LlvmEmit =
  llvm_set_label(llvm_append_body(e, concat_all([label, ":\n"])), label)

# Mint a fresh register name `%tN` and return (emit, name) as a struct.
type LlvmReg = { e: LlvmEmit, reg: String }

fn llvm_fresh_reg(e: LlvmEmit) : LlvmReg {
  let n = e.ids.next
  LlvmReg { e: llvm_fresh_id(e), reg: string_concat("%t", int_to_string(n)) }
}

fn llvm_fresh_label(e: LlvmEmit, prefix: String) : LlvmReg {
  let n = e.ids.next
  LlvmReg { e: llvm_fresh_id(e), reg: string_concat(prefix, int_to_string(n)) }
}

# ---- string-literal helpers (reused from M3a) ----

fn llvm_str_body(span: String) : String =
  string_slice(span, 1, string_length(span) - 2)

# kaikai source strings use C-style escapes (`\n`, `\t`, `\r`, `\"`,
# `\'`, `\\`, `\0`). LLVM IR's `c"..."` literal recognises only
# `\NN` hex escapes; everything else is treated as raw bytes —
# including `\n`, which LLVM sees as the two bytes `\` and `n`.
# That mismatch both blows up the declared length and produces
# incorrect runtime strings. This helper walks the kaikai source
# byte-by-byte, decodes kaikai escapes, and re-emits each decoded
# byte as a LLVM hex escape (or literal ASCII if it's safe).
type EncodedBody = { text: String, n_bytes: Int }

fn llvm_encode_body(body: String) : EncodedBody =
  llvm_encode_body_loop(body, 0, string_length(body), "", 0)

fn llvm_encode_body_loop(src: String, i: Int, n: Int, acc: String, bytes: Int) : EncodedBody {
  if i >= n { EncodedBody { text: acc, n_bytes: bytes } }
  else {
    match char_at(src, i) {
      None -> EncodedBody { text: acc, n_bytes: bytes }
      Some(c) -> {
        if c == '\\' {
          match char_at(src, i + 1) {
            None -> EncodedBody { text: acc, n_bytes: bytes }
            Some(c2) -> {
              let piece = llvm_byte_literal(decode_kai_escape(c2))
              llvm_encode_body_loop(src, i + 2, n, string_concat(acc, piece), bytes + 1)
            }
          }
        } else {
          let piece = llvm_byte_literal(char_to_int(c))
          llvm_encode_body_loop(src, i + 1, n, string_concat(acc, piece), bytes + 1)
        }
      }
    }
  }
}

fn decode_kai_escape(c: Char) : Int {
  if c == 'n' { 10 }
  else if c == 't' { 9 }
  else if c == 'r' { 13 }
  else if c == '0' { 0 }
  else { char_to_int(c) }       # covers `\"`, `\'`, `\\`, fallback
}

# Printable ASCII except `"` and `\` goes in literally; everything
# else becomes `\NN` in hex (exactly two hex digits).
fn llvm_byte_literal(b: Int) : String {
  if b == 34       { "\\22" }
  else if b == 92  { "\\5C" }
  else if b >= 32 and b < 127 { "#{int_to_char(b)}" }
  else { concat_all(["\\", hex_digit(b / 16), hex_digit(b % 16)]) }
}

fn hex_digit(d: Int) : String {
  if d == 0 { "0" } else if d == 1 { "1" } else if d == 2 { "2" }
  else if d == 3 { "3" } else if d == 4 { "4" } else if d == 5 { "5" }
  else if d == 6 { "6" } else if d == 7 { "7" } else if d == 8 { "8" }
  else if d == 9 { "9" } else if d == 10 { "A" } else if d == 11 { "B" }
  else if d == 12 { "C" } else if d == 13 { "D" } else if d == 14 { "E" }
  else { "F" }
}

# Emit an LLVM global string constant and return both the textual
# declaration and the total byte count (including null terminator),
# so callers can size their `getelementptr` with the same N the
# declaration uses.
type StrConst = { text: String, n: Int }

fn llvm_emit_string_const_enc(label: String, body: String) : StrConst {
  let enc = llvm_encode_body(body)
  let n = enc.n_bytes + 1
  let text = concat_all([
    "@", label, " = private unnamed_addr constant [",
    int_to_string(n), " x i8] c\"", enc.text, "\\00\"\n"
  ])
  StrConst { text: text, n: n }
}

# Legacy wrapper used in paths that pre-compute `n = string_length +
# 1`; those paths only pass ASCII-safe identifier names (variant /
# field names), where encoding is a no-op and the lengths still
# line up.
fn llvm_emit_string_const(label: String, body: String) : String {
  let r = llvm_emit_string_const_enc(label, body)
  r.text
}

fn llvm_gep_str(label: String, n: Int) : String =
  concat_all([
    "getelementptr inbounds ([", int_to_string(n), " x i8], [",
    int_to_string(n), " x i8]* @", label, ", i64 0, i64 0)"
  ])

# ---- prelude + user fn dispatch ----
#
# M3c's prelude subset. Each entry is (kaikai name, arity, supports
# being passed as a value). When the name appears as a *callee* in an
# ECall we emit a direct `@kaix_prelude_<nm>` call. When the name
# appears as an *EVar value* (i.e. passed to map/each as a function),
# we build a closure via `@kaix_closure` with the matching thunk
# symbol; only entries with a checked-in thunk shim can be passed as
# values.

type LlvmPrelude = LP(String, Int, Option[String])   # name, arity, value-thunk symbol or None

fn llvm_prelude_table() : [LlvmPrelude] {
  [
    LP("print",            1, Some("@kaix_print_thunk")),
    LP("eprint",           1, Some("@kaix_eprint_thunk")),
    LP("int_to_string",    1, Some("@kaix_int_to_string_thunk")),
    LP("map",              2, None),
    LP("each",             2, None),
    LP("filter",           2, None),
    LP("reduce",           3, None),
    LP("list_append",      2, None),
    LP("list_length",      1, None),
    LP("list_reverse",     1, None),
    LP("args",             0, None),
    LP("exit",             1, None),
    LP("panic",            1, None),
    LP("read_file",        1, None),
    LP("write_file",       2, None),
    LP("read_line",        0, None),
    LP("real_to_string",   1, None),
    LP("string_to_int",    1, None),
    LP("string_to_real",   1, None),
    LP("string_length",    1, None),
    LP("string_concat",    2, None),
    LP("string_concat_all",1, None),
    LP("string_join",      2, None),
    LP("string_slice",     3, None),
    LP("string_split",     2, None),
    LP("string_contains",  2, None),
    LP("char_at",          2, None),
    LP("char_to_int",      1, None),
    LP("int_to_char",      1, None),
    LP("array_make",       2, None),
    LP("array_length",     1, None),
    LP("array_get",        2, None),
    LP("array_set",        3, None),
    LP("array_grow",       3, None)
  ]
}

fn llvm_prelude_find_loop(tbl: [LlvmPrelude], target: String) : Option[LlvmPrelude] {
  match tbl {
    [] -> None
    [p, ...rest] -> match p {
      LP(n, _, _) -> if n == target { Some(p) } else { llvm_prelude_find_loop(rest, target) }
    }
  }
}

fn llvm_prelude_find(target: String) : Option[LlvmPrelude] =
  llvm_prelude_find_loop(llvm_prelude_table(), target)

fn llvm_is_prelude_fn(nm: String) : Bool = match llvm_prelude_find(nm) { Some(_) -> true None -> false }

fn llvm_prelude_symbol(nm: String) : String =
  string_concat("@kaix_prelude_", nm)

# ---- binop helper lookup ----

fn llvm_binop_helper(op: String) : Option[String] {
  if op == "+"       { Some("@kaix_add") }
  else if op == "-"  { Some("@kaix_sub") }
  else if op == "*"  { Some("@kaix_mul") }
  else if op == "/"  { Some("@kaix_div") }
  else if op == "//" { Some("@kaix_idiv") }
  else if op == "%"  { Some("@kaix_mod") }
  else if op == "==" { Some("@kaix_eq") }
  else if op == "!=" { Some("@kaix_ne") }
  else if op == "<"  { Some("@kaix_lt") }
  else if op == ">"  { Some("@kaix_gt") }
  else if op == "<=" { Some("@kaix_le") }
  else if op == ">=" { Some("@kaix_ge") }
  else { None }
}

# ---- expression emission ----

fn llvm_emit_expr(e: LlvmEmit, x: Expr) : LlvmEmit / Console {
  match x.kind {
    EInt(n) -> {
      let r = llvm_fresh_reg(e)
      let instr = concat_all(["  ", r.reg, " = call %KaiValue* @kaix_int(i64 ",
                              int_to_string(n), ")\n"])
      llvm_set_last(llvm_append_body(r.e, instr), r.reg)
    }
    EBool(b) -> {
      let r = llvm_fresh_reg(e)
      let v = if b { "1" } else { "0" }
      let instr = concat_all(["  ", r.reg, " = call %KaiValue* @kaix_bool(i32 ",
                              v, ")\n"])
      llvm_set_last(llvm_append_body(r.e, instr), r.reg)
    }
    EStr(span, is_triple) -> llvm_emit_string(e, span, is_triple)
    EChar(c) -> {
      let r = llvm_fresh_reg(e)
      let instr = concat_all(["  ", r.reg, " = call %KaiValue* @kaix_char(i32 ",
                              int_to_string(char_to_int(c)), ")\n"])
      llvm_set_last(llvm_append_body(r.e, instr), r.reg)
    }
    EReal(v) -> {
      # m12.8.x phase 2 (Bug 3): emit the actual decoded value. The
      # M12 placeholder hard-coded 0.0 because the compiler itself
      # had no live real literals; user code with `100.0<USD>` and
      # friends needs the real lexeme to round-trip. LLVM IR rejects
      # `double 100` (integer literal as double) — `real_to_string`
      # of an integer-valued double has no `.`, so append `.0`.
      let r = llvm_fresh_reg(e)
      let s = real_to_string(v)
      let s_dbl = if string_contains_dot(s) { s } else { concat_all([s, ".0"]) }
      let instr = concat_all(["  ", r.reg,
                              " = call %KaiValue* @kaix_real(double ",
                              s_dbl, ")\n"])
      llvm_set_last(llvm_append_body(r.e, instr), r.reg)
    }
    EUnit -> {
      let r = llvm_fresh_reg(e)
      let instr = concat_all(["  ", r.reg, " = call %KaiValue* @kaix_unit()\n"])
      llvm_set_last(llvm_append_body(r.e, instr), r.reg)
    }
    ERecordLit(nm, fis) -> llvm_emit_record_lit(e, nm, fis)
    EVar(nm) -> match llvm_local_find(e.locals, nm) {
      Some(reg) -> llvm_set_last(e, reg)
      None -> match evar_find(e.vars_, nm) {
        Some(ar) -> if ar == 0 {
          llvm_emit_variant_ctor(e, nm, [])
        } else {
          # Non-nullary ctor referenced as a value — would need a
          # closure wrapping the constructor. Out of scope for M3d
          # (interp.kai doesn't hit this).
          eprint("llvm: non-nullary variant ctor as value not supported: #{nm}")
          llvm_set_last(e, "undef")
        }
        None -> llvm_emit_fn_value(e, nm, x.line, x.col)
      }
    }
    ECall(callee, xs) -> llvm_emit_call(e, callee, xs)
    EBinop(op, l, r) -> llvm_emit_binop_typed(e, op, l, r, x.ty)
    EUnop(op, inner) -> llvm_emit_unop(e, op, inner)
    EIf(c, t, eo) -> llvm_emit_if(e, c, t, eo)
    EBlock(stmts, tail) -> llvm_emit_block(e, stmts, tail)
    ERange(lo, hi, stp) -> llvm_emit_range(e, lo, hi, stp)
    EPipe(lhs, rhs) -> llvm_emit_pipe(e, lhs, rhs)
    EMatch(scr, arms) -> llvm_emit_match(e, scr, arms, x.line, x.col)
    EList(elems) -> llvm_emit_list(e, elems)
    ELambda(_, _) -> llvm_emit_lambda_ref(e, x)
    EField(obj, fnm) -> llvm_emit_field(e, obj, fnm)
    EHandle(body, eff_name, _eff_tyargs, init_opt, alias_opt, clauses, ret_opt) ->
      llvm_emit_handle(e, body, eff_name, init_opt, alias_opt, clauses, ret_opt, x.line, x.col)
    EHole(nm_opt) -> {
      let label = match nm_opt { Some(nm) -> cat2("?", nm) None -> "?" }
      let msg = cat2("unfilled hole: ", label)
      let name_res = llvm_emit_name_constant(e, msg, "hole.msg.")
      let sreg = llvm_fresh_reg(name_res.e)
      let s_instr = concat_all([
        "  ", sreg.reg, " = call %KaiValue* @kaix_str(i8* ", name_res.gep, ")\n"
      ])
      let e_s = llvm_append_body(sreg.e, s_instr)
      let r = llvm_fresh_reg(e_s)
      let p_instr = concat_all([
        "  ", r.reg, " = call %KaiValue* @kaix_match_panic(%KaiValue* ", sreg.reg, ")\n"
      ])
      llvm_set_last(llvm_append_body(r.e, p_instr), r.reg)
    }
    ETodo(msg) -> {
      # m7d §1: same lowering as a hole, but the panic message is the
      # user-supplied string prefixed with `todo: `.
      let full = cat2("todo: ", msg)
      let name_res = llvm_emit_name_constant(e, full, "todo.msg.")
      let sreg = llvm_fresh_reg(name_res.e)
      let s_instr = concat_all([
        "  ", sreg.reg, " = call %KaiValue* @kaix_str(i8* ", name_res.gep, ")\n"
      ])
      let e_s = llvm_append_body(sreg.e, s_instr)
      let r = llvm_fresh_reg(e_s)
      let p_instr = concat_all([
        "  ", r.reg, " = call %KaiValue* @kaix_match_panic(%KaiValue* ", sreg.reg, ")\n"
      ])
      llvm_set_last(llvm_append_body(r.e, p_instr), r.reg)
    }
    EBang(inner) -> llvm_emit_bang(e, inner)
    # m12.5: codegen erasure — emit the inner literal exactly as if no
    # unit annotation were present. Units never reach LLVM IR.
    ELitUnit(inner, _) -> llvm_emit_expr(e, inner)
    _ -> {
      eprint("llvm: unsupported expression kind (#{expr_kind_name(x.kind)}) at #{int_to_string(x.line)}:#{int_to_string(x.col)}")
      llvm_set_last(e, "undef")
    }
  }
}

fn expr_kind_name(k: ExprKind) : String {
  match k {
    EInt(_)        -> "EInt"
    EReal(_)       -> "EReal"
    EBool(_)       -> "EBool"
    EChar(_)       -> "EChar"
    EStr(_, _)     -> "EStr"
    EUnit          -> "EUnit"
    EVar(_)        -> "EVar"
    EUnder         -> "EUnder"
    EPlaceholder   -> "EPlaceholder"
    ECall(_, _)    -> "ECall"
    EField(_, _)   -> "EField"
    EIndex(_, _)   -> "EIndex"
    EBinop(_, _, _) -> "EBinop"
    EUnop(_, _)    -> "EUnop"
    EIf(_, _, _)   -> "EIf"
    EMatch(_, _)   -> "EMatch"
    ELambda(_, _)  -> "ELambda"
    ERecordLit(_, _) -> "ERecordLit"
    EList(_)       -> "EList"
    ERange(_, _, _) -> "ERange"
    EBlock(_, _)   -> "EBlock"
    EPipe(_, _)    -> "EPipe"
    EHole(_)       -> "EHole"
    ETodo(_)       -> "ETodo"
    EBang(_)       -> "EBang"
    EHandle(_, _, _, _, _, _, _) -> "EHandle"
    ELitUnit(_, _) -> "ELitUnit"
    EVariantsOf(_) -> "EVariantsOf"
  }
}

# ---- strings (with interpolation) ----

fn llvm_emit_plain_str_body(e: LlvmEmit, body: String) : LlvmEmit {
  let label_id = llvm_fresh_label(e, "str.")
  let label = label_id.reg
  let sc = llvm_emit_string_const_enc(label, body)
  let e2 = llvm_append_global(label_id.e, sc.text)
  let r = llvm_fresh_reg(e2)
  let instr = concat_all(["  ", r.reg, " = call %KaiValue* @kaix_str(i8* ",
                          llvm_gep_str(label, sc.n), ")\n"])
  llvm_set_last(llvm_append_body(r.e, instr), r.reg)
}

fn llvm_emit_string(e: LlvmEmit, span: String, is_triple: Bool) : LlvmEmit {
  let n = string_length(span)
  let body_start = if is_triple { 3 } else { 1 }
  let body_end = if is_triple { n - 3 } else { n - 1 }
  if not has_interp(span, body_start, body_end) {
    llvm_emit_plain_str_body(e, string_slice(span, body_start, body_end - body_start))
  } else {
    let parts = iscan_collect(span, body_end, IScan { parts: [], lit_start: body_start, i: body_start })
    llvm_emit_interp_parts(e, parts)
  }
}

fn llvm_emit_interp_parts(e: LlvmEmit, parts: [IPart]) : LlvmEmit {
  match parts {
    [] -> llvm_emit_plain_str_body(e, "")
    [p] -> llvm_emit_interp_part(e, p)
    [p, ...rest] -> {
      let ep = llvm_emit_interp_part(e, p)
      let lv = ep.last_val
      let er = llvm_emit_interp_parts(ep, rest)
      let rv = er.last_val
      let r = llvm_fresh_reg(er)
      let instr = concat_all([
        "  ", r.reg, " = call %KaiValue* @kaix_string_concat(%KaiValue* ",
        lv, ", %KaiValue* ", rv, ")\n"
      ])
      llvm_set_last(llvm_append_body(r.e, instr), r.reg)
    }
  }
}

fn llvm_emit_interp_part(e: LlvmEmit, p: IPart) : LlvmEmit {
  match p {
    IpLit(body, _) -> llvm_emit_plain_str_body(e, body)
    IpExp(expr_src) -> {
      let toks = tokenize(expr_src)
      let prs = parser_new("<interp>", expr_src, toks)
      let res = parse_expr(prs)
      match res.r {
        Some(ex) -> {
          let ee = llvm_emit_expr(e, ex)
          let r = llvm_fresh_reg(ee)
          let instr = concat_all([
            "  ", r.reg, " = call %KaiValue* @kaix_to_string(%KaiValue* ",
            ee.last_val, ")\n"
          ])
          llvm_set_last(llvm_append_body(r.e, instr), r.reg)
        }
        None -> llvm_emit_plain_str_body(e, "")
      }
    }
  }
}

# ---- ranges ----

fn llvm_emit_range(e: LlvmEmit, lo: Expr, hi: Expr, stp: Option[Expr]) : LlvmEmit {
  let el = llvm_emit_expr(e, lo)
  let lo_val = el.last_val
  let eh = llvm_emit_expr(el, hi)
  let hi_val = eh.last_val
  match stp {
    None -> {
      let r = llvm_fresh_reg(eh)
      let instr = concat_all([
        "  ", r.reg, " = call %KaiValue* @kaix_range(%KaiValue* ",
        lo_val, ", %KaiValue* ", hi_val, ")\n"
      ])
      llvm_set_last(llvm_append_body(r.e, instr), r.reg)
    }
    Some(se) -> {
      let es = llvm_emit_expr(eh, se)
      let step_val = es.last_val
      let r = llvm_fresh_reg(es)
      let instr = concat_all([
        "  ", r.reg, " = call %KaiValue* @kaix_range_step(%KaiValue* ", lo_val,
        ", %KaiValue* ", hi_val, ", %KaiValue* ", step_val, ")\n"
      ])
      llvm_set_last(llvm_append_body(r.e, instr), r.reg)
    }
  }
}

# ---- field access + record literal ----
#
# Both route through the runtime: `kaix_field(rec, name_ptr)` reads a
# field by name; `kaix_record(n, fields_buf, names_buf)` allocates a
# KAI_RECORD with the n (value, name) pairs stored as parallel arrays.
# Field names are emitted as private global i8* constants shared
# across the .ll.

fn llvm_emit_field(e: LlvmEmit, obj: Expr, fnm: String) : LlvmEmit {
  let ro = llvm_emit_expr(e, obj)
  let nameinfo = llvm_emit_name_constant(ro, fnm, "fld.")
  let r = llvm_fresh_reg(nameinfo.e)
  let instr = concat_all([
    "  ", r.reg, " = call %KaiValue* @kaix_field(%KaiValue* ",
    ro.last_val, ", i8* ", nameinfo.gep, ")\n"
  ])
  llvm_set_last(llvm_append_body(r.e, instr), r.reg)
}

type RecLitBufs = { st: LlvmEmit, fields_buf: String, names_buf: String }

fn llvm_emit_record_lit(e: LlvmEmit, nm: String, fis: [FieldInit]) : LlvmEmit {
  let n = list_length(fis)
  if n == 0 {
    let r = llvm_fresh_reg(e)
    let instr = concat_all([
      "  ", r.reg, " = call %KaiValue* @kaix_record(i32 0, %KaiValue** null, i8** null)\n"
    ])
    llvm_set_last(llvm_append_body(r.e, instr), r.reg)
  } else {
    # alloca both buffers, fill them, call kaix_record.
    let fb = llvm_fresh_reg(e)
    let fb_i = concat_all([
      "  ", fb.reg, " = alloca %KaiValue*, i32 ", int_to_string(n), "\n"
    ])
    let e1 = llvm_append_body(fb.e, fb_i)
    let nb = llvm_fresh_reg(e1)
    let nb_i = concat_all([
      "  ", nb.reg, " = alloca i8*, i32 ", int_to_string(n), "\n"
    ])
    let e2 = llvm_append_body(nb.e, nb_i)
    let e3 = llvm_emit_rec_fill(e2, fb.reg, nb.reg, fis, 0)
    let r = llvm_fresh_reg(e3)
    let instr = concat_all([
      "  ", r.reg, " = call %KaiValue* @kaix_record(i32 ", int_to_string(n),
      ", %KaiValue** ", fb.reg, ", i8** ", nb.reg, ")\n"
    ])
    llvm_set_last(llvm_append_body(r.e, instr), r.reg)
  }
}

fn llvm_emit_rec_fill(e: LlvmEmit, fb: String, nb: String, fis: [FieldInit], i: Int) : LlvmEmit {
  match fis {
    [] -> e
    [fi, ...rest] -> match fi {
      FI(fnm, val) -> {
        let rv = llvm_emit_expr(e, val)
        # Store value into fields_buf[i]
        let fgep = llvm_fresh_reg(rv)
        let fgep_i = concat_all([
          "  ", fgep.reg, " = getelementptr inbounds %KaiValue*, %KaiValue** ", fb,
          ", i32 ", int_to_string(i), "\n"
        ])
        let e1 = llvm_append_body(fgep.e, fgep_i)
        let fst = concat_all([
          "  store %KaiValue* ", rv.last_val, ", %KaiValue** ", fgep.reg, "\n"
        ])
        let e2 = llvm_append_body(e1, fst)
        # Emit name constant + store its gep into names_buf[i]
        let nameinfo = llvm_emit_name_constant(e2, fnm, "fname.")
        let ngep = llvm_fresh_reg(nameinfo.e)
        let ngep_i = concat_all([
          "  ", ngep.reg, " = getelementptr inbounds i8*, i8** ", nb,
          ", i32 ", int_to_string(i), "\n"
        ])
        let e3 = llvm_append_body(ngep.e, ngep_i)
        let nst = concat_all([
          "  store i8* ", nameinfo.gep, ", i8** ", ngep.reg, "\n"
        ])
        let e4 = llvm_append_body(e3, nst)
        llvm_emit_rec_fill(e4, fb, nb, rest, i + 1)
      }
    }
  }
}

# ---- pipe ----
#
# `x |> f(y, z)` desugars to `f(x, y, z)`. A non-call rhs is applied
# as a unary function.
fn llvm_emit_pipe(e: LlvmEmit, lhs: Expr, rhs: Expr) : LlvmEmit {
  match rhs.kind {
    ECall(f, pa) -> llvm_emit_call(e, f, [lhs, ...pa])
    _ -> llvm_emit_call(e, rhs, [lhs])
  }
}

# ---- fn-value materialisation ----
#
# `EVar(nm)` appearing where a value is expected (not a call callee)
# builds a 0-capture closure over the fn's thunk. Supports:
#   1. prelude names with a thunk shim (print, eprint, int_to_string).
#   2. user-defined fns — we emit `@_kai_<name>_thunk` as part of the
#      fn's own definition, so the symbol exists.
# A reference to anything else is reported and compiled as `undef`.

fn llvm_emit_fn_value(e: LlvmEmit, nm: String, line: Int, col: Int) : LlvmEmit {
  match llvm_prelude_find(nm) {
    Some(lp) -> match lp {
      LP(_, arity, Some(thunk)) -> llvm_build_closure(e, thunk, arity)
      _ -> llvm_closure_error(e, nm, line, col)
    }
    None -> match efn_find(e.fns, nm) {
      Some(arity) -> {
        let thunk = concat_all(["@_kai_", nm, "_thunk"])
        llvm_build_closure(e, thunk, arity)
      }
      None -> llvm_closure_error(e, nm, line, col)
    }
  }
}

fn llvm_build_closure(e: LlvmEmit, thunk_sym: String, arity: Int) : LlvmEmit {
  let r = llvm_fresh_reg(e)
  let instr = concat_all([
    "  ", r.reg, " = call %KaiValue* @kaix_closure(",
    "i8* bitcast (%KaiValue* (%KaiValue*, %KaiValue**, i32)* ", thunk_sym, " to i8*), ",
    "i32 ", int_to_string(arity), ", i32 0, i8* null)\n"
  ])
  llvm_set_last(llvm_append_body(r.e, instr), r.reg)
}

fn llvm_closure_error(e: LlvmEmit, nm: String, line: Int, col: Int) : LlvmEmit / Console {
  eprint("llvm: cannot build closure for '#{nm}' at #{int_to_string(line)}:#{int_to_string(col)}")
  llvm_set_last(e, "undef")
}

# m7c-c — emit the LLVM IR for an `Eff.op(args)` call. Mirrors the
# C `emit_call_expr` op-call branch minus the discard/longjmp path
# (m7a #6e). The IR shape is:
#   %h = call i8* @kaix_evidence_lookup_handler(i8* @effname.str)
#   %ev = bitcast i8* %h to %EvEff*
#   ; KaiCont alloca (32 bytes covers the C struct)
#   %k_buf = alloca [32 x i8], align 8
#   %k = bitcast [32 x i8]* %k_buf to i8*
#   ; Read handler_id (field 0) for the cont's identity slot
#   %hid_p = getelementptr %EvEff, %EvEff* %ev, i32 0, i32 0
#   %hid = load i64, i64* %hid_p
#   call void @kaix_cont_init_identity(i8* %k, i64 %hid)
#   ; GEP fn ptr at field 3 + op_idx, load, indirect-call
#   %op_p = getelementptr %EvEff, %EvEff* %ev, i32 0, i32 N
#   %op = load <fn-type>, <fn-type>* %op_p
#   %r = call %KaiValue* %op(%EvEff* %ev, args..., i8* %k)
fn llvm_emit_op_dispatch(e: LlvmEmit, key: String, offset: Int, xs: [Expr]) : LlvmEmit {
  let eff_n = dotted_prefix(key)
  let name_res = llvm_emit_name_constant(e, eff_n, "eff.disp.name.")
  # 1. Lookup handler.
  let h_reg = llvm_fresh_reg(name_res.e)
  let h_call = concat_all([
    "  ", h_reg.reg, " = call i8* @kaix_evidence_lookup_handler(i8* ",
    name_res.gep, ")\n"
  ])
  let e1 = llvm_append_body(h_reg.e, h_call)
  # 2. Bitcast to %EvEff*.
  let ev_reg = llvm_fresh_reg(e1)
  let ev_cast = concat_all([
    "  ", ev_reg.reg, " = bitcast i8* ", h_reg.reg, " to %Ev", eff_n, "*\n"
  ])
  let e2 = llvm_append_body(ev_reg.e, ev_cast)
  # 3. Allocate KaiCont buf + cast.
  let k_buf_reg = llvm_fresh_reg(e2)
  let k_alloca = concat_all([
    "  ", k_buf_reg.reg, " = alloca [32 x i8], align 8\n"
  ])
  let e3 = llvm_append_body(k_buf_reg.e, k_alloca)
  let k_reg = llvm_fresh_reg(e3)
  let k_cast = concat_all([
    "  ", k_reg.reg, " = bitcast [32 x i8]* ", k_buf_reg.reg, " to i8*\n"
  ])
  let e4 = llvm_append_body(k_reg.e, k_cast)
  # 4. Read handler_id (field 0) and init the cont.
  let hid_p_reg = llvm_fresh_reg(e4)
  let hid_p_gep = concat_all([
    "  ", hid_p_reg.reg, " = getelementptr %Ev", eff_n,
    ", %Ev", eff_n, "* ", ev_reg.reg, ", i32 0, i32 0\n"
  ])
  let e5 = llvm_append_body(hid_p_reg.e, hid_p_gep)
  let hid_reg = llvm_fresh_reg(e5)
  let hid_load = concat_all([
    "  ", hid_reg.reg, " = load i64, i64* ", hid_p_reg.reg, "\n",
    "  call void @kaix_cont_init_identity(i8* ", k_reg.reg,
    ", i64 ", hid_reg.reg, ")\n"
  ])
  let e6 = llvm_append_body(hid_reg.e, hid_load)
  # 5. Evaluate args; build a comma-joined arg list of %KaiValue* registers.
  let ra = llvm_emit_args(e6, xs, [])
  # 6. GEP to op fn-ptr at field `offset`, load, indirect call.
  let fn_ptr_p_reg = llvm_fresh_reg(ra.st)
  # Build the fn-ptr type: %KaiValue* (%EvEff*, args..., i8*)*
  let arg_ty_list = llvm_op_arg_kaivalue_list(list_length(xs))
  let fn_ptr_ty = concat_all([
    "%KaiValue* (%Ev", eff_n, "*", arg_ty_list, ", i8*)*"
  ])
  let fn_p_gep = concat_all([
    "  ", fn_ptr_p_reg.reg, " = getelementptr %Ev", eff_n,
    ", %Ev", eff_n, "* ", ev_reg.reg, ", i32 0, i32 ",
    int_to_string(offset), "\n"
  ])
  let e7 = llvm_append_body(fn_ptr_p_reg.e, fn_p_gep)
  let fn_ptr_reg = llvm_fresh_reg(e7)
  let fn_load = concat_all([
    "  ", fn_ptr_reg.reg, " = load ", fn_ptr_ty, ", ", fn_ptr_ty, "* ", fn_ptr_p_reg.reg, "\n"
  ])
  let e8 = llvm_append_body(fn_ptr_reg.e, fn_load)
  # 7. Indirect call.
  let r_reg = llvm_fresh_reg(e8)
  let arg_regs_str = llvm_format_op_arg_regs(ra.regs)
  let call_instr = concat_all([
    "  ", r_reg.reg, " = call %KaiValue* ", fn_ptr_reg.reg,
    "(%Ev", eff_n, "* ", ev_reg.reg, arg_regs_str,
    ", i8* ", k_reg.reg, ")\n"
  ])
  llvm_set_last(llvm_append_body(r_reg.e, call_instr), r_reg.reg)
}

# Build the type signature suffix `, %KaiValue*, %KaiValue*, …`
# for `n` op arguments.
fn llvm_op_arg_kaivalue_list(n: Int) : String {
  if n <= 0 { "" }
  else { string_concat(", %KaiValue*", llvm_op_arg_kaivalue_list(n - 1)) }
}

# Emit the registered arg list as ", %KaiValue* %r1, %KaiValue* %r2, ..."
# for an indirect call.
fn llvm_format_op_arg_regs(regs: [String]) : String {
  match regs {
    [] -> ""
    [r, ...rest] -> string_concat(", %KaiValue* ", string_concat(r, llvm_format_op_arg_regs(rest)))
  }
}

fn llvm_emit_call(e: LlvmEmit, callee: Expr, xs: [Expr]) : LlvmEmit {
  match callee.kind {
    EVar(nm) -> {
      # m5 #4 — same dup/drop magic-name handling as the C emit
      # (`emit_call_expr` 4920-4937). Lower to direct `kaix_internal_*`
      # calls. Both names take exactly one arg.
      if nm == "__perceus_dup" or nm == "__perceus_drop" {
        let sym = if nm == "__perceus_dup" { "@kaix_internal_dup" } else { "@kaix_internal_drop" }
        let ra = llvm_emit_args(e, xs, [])
        let r = llvm_fresh_reg(ra.st)
        let instr = concat_all(["  ", r.reg, " = call %KaiValue* ", sym, "(",
                                llvm_format_args(ra.regs), ")\n"])
        llvm_set_last(llvm_append_body(r.e, instr), r.reg)
      } else if nm == "__strip_unit" {
        # m12.8 phase 2: identity at runtime — emit the inner value
        # directly. See the matching C-emit branch for full context.
        match xs {
          [a] -> llvm_emit_expr(e, a)
          _   -> llvm_set_last(e, "undef")
        }
      } else if nm == "unit_name" {
        # m12.8.x phase 2 (Gap 1, partial): same compile-time
        # reflection as the C path. Emit a string-constant load
        # whose contents are the canonical unit symbol of the
        # arg's type (empty when the unit is unresolved or absent).
        match xs {
          [a] -> llvm_emit_plain_str_body(e, unit_name_of_ty(a.ty))
          _   -> llvm_set_last(e, "undef")
        }
      } else if nm == "resume" {
        # m7c-d — emit `kai_cont_resume(k, v)` for the 1-arg form.
        # The 2-arg form `resume(v, ns)` writes new state first;
        # delegate to the runtime helper `kai_clause_state_set`
        # so we don't have to GEP into the opaque self struct from
        # IR. Together these cover every canonical State / Reader
        # / Writer / Mutable clause.
        match xs {
          [v] -> {
            let rv = llvm_emit_expr(e, v)
            let r = llvm_fresh_reg(rv)
            let instr = concat_all([
              "  ", r.reg, " = call %KaiValue* @kaix_cont_resume(i8* %k, %KaiValue* ",
              rv.last_val, ")\n"
            ])
            llvm_set_last(llvm_append_body(r.e, instr), r.reg)
          }
          [v, ns] -> {
            let rns = llvm_emit_expr(e, ns)
            let e_set = llvm_append_body(rns, concat_all([
              "  call void @kaix_clause_state_set(i8* %self, %KaiValue* ",
              rns.last_val, ")\n"
            ]))
            let rv = llvm_emit_expr(e_set, v)
            let r = llvm_fresh_reg(rv)
            let instr = concat_all([
              "  ", r.reg, " = call %KaiValue* @kaix_cont_resume(i8* %k, %KaiValue* ",
              rv.last_val, ")\n"
            ])
            llvm_set_last(llvm_append_body(r.e, instr), r.reg)
          }
          _ -> {
            let r = llvm_fresh_reg(e)
            let instr = concat_all([
              "  ", r.reg, " = call %KaiValue* @kaix_unit()\n"
            ])
            llvm_set_last(llvm_append_body(r.e, instr), r.reg)
          }
        }
      } else {
        # m7c-c: callees of the form "Eff.op" come from the
        # `desugar_op_calls` pass. Look the offset up in
        # `op_offsets`; if present, emit a per-instance dispatch
        # (lookup handler → bitcast → GEP fn ptr → indirect call
        # with KaiCont alloca). Otherwise fall through to the
        # standard fn-call path so dotted module paths and
        # non-effect names keep working.
        # m7b #15 (compiler integration): the alias rewrite tags
        # op names with `@<alias>`; the LLVM dispatcher does not
        # use the tag yet (the C dispatcher does — see
        # emit_call_expr), so strip it from the lookup key here.
        # Per-instance dispatch on the LLVM side stays a
        # follow-up.
        let lookup_key = string_strip_alias_tag(nm)
        match lookup_op_offset(e.op_offsets, lookup_key) {
          Some(offset) -> llvm_emit_op_dispatch(e, lookup_key, offset, xs)
          None ->
            match evar_find(e.vars_, nm) {
              Some(_) -> llvm_emit_variant_ctor(e, nm, xs)
              None -> match llvm_local_find_loop(e.locals, nm) {
                Some(reg) -> llvm_emit_apply(e, reg, xs)
                None      -> {
                  let ra = llvm_emit_args(e, xs, [])
                  let sym = if llvm_is_prelude_fn(nm) { llvm_prelude_symbol(nm) } else { string_concat("@kai_", nm) }
                  let r = llvm_fresh_reg(ra.st)
                  let instr = concat_all(["  ", r.reg, " = call %KaiValue* ", sym, "(",
                                          llvm_format_args(ra.regs), ")\n"])
                  llvm_set_last(llvm_append_body(r.e, instr), r.reg)
                }
              }
            }
        }
      }
    }
    _ -> {
      let ec = llvm_emit_expr(e, callee)
      llvm_emit_apply(ec, ec.last_val, xs)
    }
  }
}

# Invoke a closure value held in `clo_reg`. Args are evaluated in
# order and laid out in an alloca'd KaiValue* buffer, then passed to
# `kaix_apply` (thin wrapper over the runtime's kai_apply). Mirrors
# the layout used for variant construction.
fn llvm_emit_apply(e: LlvmEmit, clo_reg: String, xs: [Expr]) : LlvmEmit {
  let n = list_length(xs)
  let ra = llvm_emit_args(e, xs, [])
  if n == 0 {
    let r = llvm_fresh_reg(ra.st)
    let instr = concat_all([
      "  ", r.reg, " = call %KaiValue* @kaix_apply(%KaiValue* ", clo_reg,
      ", i32 0, %KaiValue** null)\n"
    ])
    llvm_set_last(llvm_append_body(r.e, instr), r.reg)
  } else {
    let buf = llvm_fresh_reg(ra.st)
    let alloc_instr = concat_all([
      "  ", buf.reg, " = alloca %KaiValue*, i32 ", int_to_string(n), "\n"
    ])
    let e2 = llvm_append_body(buf.e, alloc_instr)
    let e3 = llvm_emit_variant_stores(e2, buf.reg, ra.regs, 0)
    let r = llvm_fresh_reg(e3)
    let call_instr = concat_all([
      "  ", r.reg, " = call %KaiValue* @kaix_apply(%KaiValue* ", clo_reg,
      ", i32 ", int_to_string(n), ", %KaiValue** ", buf.reg, ")\n"
    ])
    llvm_set_last(llvm_append_body(r.e, call_instr), r.reg)
  }
}

# Construct a KAI_VARIANT via `kaix_variant(tag, name, n, args)`. The
# args array is an `alloca` + sequential stores; the tag field is
# always 0 — stage 0's runtime discriminates by name.
fn llvm_emit_variant_ctor(e: LlvmEmit, cname: String, xs: [Expr]) : LlvmEmit {
  let n = list_length(xs)
  # Global string constant for the ctor name.
  let name_label_id = llvm_fresh_label(e, "var.")
  let name_label = name_label_id.reg
  let name_body = cname
  let name_len = string_length(name_body) + 1
  let e1 = llvm_append_global(name_label_id.e, llvm_emit_string_const(name_label, name_body))
  if n == 0 {
    let r = llvm_fresh_reg(e1)
    let instr = concat_all([
      "  ", r.reg, " = call %KaiValue* @kaix_variant(i32 0, i8* ",
      llvm_gep_str(name_label, name_len), ", i32 0, %KaiValue** null)\n"
    ])
    llvm_set_last(llvm_append_body(r.e, instr), r.reg)
  } else {
    # Evaluate every arg, emit an alloca for the KaiValue*[] buffer,
    # store each value, then call kaix_variant with a pointer to the
    # first slot.
    let ra = llvm_emit_args(e1, xs, [])
    let buf = llvm_fresh_reg(ra.st)
    let alloc_instr = concat_all([
      "  ", buf.reg, " = alloca %KaiValue*, i32 ", int_to_string(n), "\n"
    ])
    let e2 = llvm_append_body(buf.e, alloc_instr)
    let e3 = llvm_emit_variant_stores(e2, buf.reg, ra.regs, 0)
    let r = llvm_fresh_reg(e3)
    let call_instr = concat_all([
      "  ", r.reg, " = call %KaiValue* @kaix_variant(i32 0, i8* ",
      llvm_gep_str(name_label, name_len),
      ", i32 ", int_to_string(n), ", %KaiValue** ", buf.reg, ")\n"
    ])
    llvm_set_last(llvm_append_body(r.e, call_instr), r.reg)
  }
}

fn llvm_emit_variant_stores(e: LlvmEmit, buf_reg: String, regs: [String], i: Int) : LlvmEmit {
  match regs {
    [] -> e
    [v, ...rest] -> {
      let gep = llvm_fresh_reg(e)
      let gep_instr = concat_all([
        "  ", gep.reg, " = getelementptr inbounds %KaiValue*, %KaiValue** ", buf_reg,
        ", i32 ", int_to_string(i), "\n"
      ])
      let e1 = llvm_append_body(gep.e, gep_instr)
      let store_instr = concat_all([
        "  store %KaiValue* ", v, ", %KaiValue** ", gep.reg, "\n"
      ])
      let e2 = llvm_append_body(e1, store_instr)
      llvm_emit_variant_stores(e2, buf_reg, rest, i + 1)
    }
  }
}

# Args are a list of (register) strings — evaluate each expression in
# order, collect its `last_val`, and hand back both the advanced
# LlvmEmit and the list of register strings.
type LlvmArgs = { st: LlvmEmit, regs: [String] }

fn llvm_emit_args(e: LlvmEmit, xs: [Expr], acc: [String]) : LlvmArgs {
  match xs {
    [] -> LlvmArgs { st: e, regs: list_reverse(acc) }
    [x0, ...rest] -> {
      let e1 = llvm_emit_expr(e, x0)
      llvm_emit_args(e1, rest, [e1.last_val, ...acc])
    }
  }
}

fn llvm_format_args(regs: [String]) : String {
  match regs {
    [] -> ""
    [x] -> string_concat("%KaiValue* ", x)
    [x, ...rest] -> concat_all(["%KaiValue* ", x, ", ", llvm_format_args(rest)])
  }
}

fn llvm_emit_binop_typed(e: LlvmEmit, op: String, l: Expr, r: Expr, opt_ty: Option[Ty]) : LlvmEmit {
  if op == "++" {
    let helper = llvm_concat_helper_of(opt_ty)
    let el = llvm_emit_expr(e, l)
    let lv = el.last_val
    let er = llvm_emit_expr(el, r)
    let rv = er.last_val
    let reg = llvm_fresh_reg(er)
    let instr = concat_all(["  ", reg.reg, " = call %KaiValue* ", helper,
                            "(%KaiValue* ", lv, ", %KaiValue* ", rv, ")\n"])
    llvm_set_last(llvm_append_body(reg.e, instr), reg.reg)
  } else { llvm_emit_binop(e, op, l, r) }
}

fn llvm_concat_helper_of(opt_ty: Option[Ty]) : String {
  match opt_ty {
    Some(t) -> match t {
      TyString    -> "@kaix_string_concat"
      TyListT(_)  -> "@kaix_prelude_list_append"
      _           -> "@kaix_string_concat"
    }
    None -> "@kaix_string_concat"
  }
}

fn llvm_emit_binop(e: LlvmEmit, op: String, l: Expr, r: Expr) : LlvmEmit / Console {
  if op == "and" or op == "or" {
    llvm_emit_short_circuit(e, op, l, r)
  } else {
    match llvm_binop_helper(op) {
      Some(sym) -> {
        let el = llvm_emit_expr(e, l)
        let lv = el.last_val
        let er = llvm_emit_expr(el, r)
        let rv = er.last_val
        let reg = llvm_fresh_reg(er)
        let instr = concat_all(["  ", reg.reg, " = call %KaiValue* ", sym,
                                "(%KaiValue* ", lv, ", %KaiValue* ", rv, ")\n"])
        llvm_set_last(llvm_append_body(reg.e, instr), reg.reg)
      }
      None -> {
        eprint("llvm: unsupported binop '#{op}'")
        llvm_set_last(e, "undef")
      }
    }
  }
}

# `and` / `or` short-circuit: evaluate lhs, branch on its truthiness,
# only evaluate rhs on the "continue" path, then phi the result so the
# block value is whichever operand decided the outcome. The phi uses
# the *actual* predecessor labels (captured from `cur_label`), not the
# block headers, for the same reason if-expressions do.
fn llvm_emit_short_circuit(e: LlvmEmit, op: String, l: Expr, r: Expr) : LlvmEmit {
  let el = llvm_emit_expr(e, l)
  let lhs_val = el.last_val
  let lhs_end_label = el.cur_label
  let tri = llvm_fresh_reg(el)
  let tr_instr = concat_all(["  ", tri.reg, " = call i32 @kaix_truthy(%KaiValue* ", lhs_val, ")\n"])
  let e1 = llvm_append_body(tri.e, tr_instr)
  let cond = llvm_fresh_reg(e1)
  let cond_instr = concat_all(["  ", cond.reg, " = icmp ne i32 ", tri.reg, ", 0\n"])
  let e2 = llvm_append_body(cond.e, cond_instr)
  let lhs_end_after_cond = e2.cur_label
  let rhs_lbl  = llvm_fresh_label(e2, "sc.rhs.")
  let skip_lbl = llvm_fresh_label(rhs_lbl.e, "sc.skip.")
  let end_lbl  = llvm_fresh_label(skip_lbl.e, "sc.end.")
  let br = if op == "and" {
    concat_all(["  br i1 ", cond.reg, ", label %", rhs_lbl.reg, ", label %", skip_lbl.reg, "\n"])
  } else {
    concat_all(["  br i1 ", cond.reg, ", label %", skip_lbl.reg, ", label %", rhs_lbl.reg, "\n"])
  }
  let e3 = llvm_append_body(end_lbl.e, br)
  # rhs block.
  let e4 = llvm_open_block(e3, rhs_lbl.reg)
  let er = llvm_emit_expr(e4, r)
  let rhs_val = er.last_val
  let rhs_end_label = er.cur_label
  let e5 = llvm_append_body(er, concat_all(["  br label %", end_lbl.reg, "\n"]))
  # skip block.
  let e6 = llvm_open_block(e5, skip_lbl.reg)
  let e7 = llvm_append_body(e6, concat_all(["  br label %", end_lbl.reg, "\n"]))
  # join.
  let e8 = llvm_open_block(e7, end_lbl.reg)
  let phi = llvm_fresh_reg(e8)
  let phi_instr = concat_all([
    "  ", phi.reg, " = phi %KaiValue* [ ", rhs_val, ", %", rhs_end_label,
    " ], [ ", lhs_val, ", %", skip_lbl.reg, " ]\n"
  ])
  llvm_set_last(llvm_append_body(phi.e, phi_instr), phi.reg)
}

fn llvm_emit_unop(e: LlvmEmit, op: String, inner: Expr) : LlvmEmit {
  let e1 = llvm_emit_expr(e, inner)
  let v = e1.last_val
  let sym = if op == "-" { "@kaix_neg" } else { "@kaix_not" }
  let rr = llvm_fresh_reg(e1)
  let instr = concat_all(["  ", rr.reg, " = call %KaiValue* ", sym,
                          "(%KaiValue* ", v, ")\n"])
  llvm_set_last(llvm_append_body(rr.e, instr), rr.reg)
}

# If-expression lowering: evaluate cond, branch on truthy, emit both
# arms as basic blocks, phi the result at the join block. The phi's
# predecessor labels come from `cur_label` at the end of each arm,
# not the block header — a nested if in either arm may end control
# flow in a different block than the one the arm opened.
fn llvm_emit_if(e: LlvmEmit, c: Expr, t: Expr, eo: Option[Expr]) : LlvmEmit {
  let ec = llvm_emit_expr(e, c)
  let cv = ec.last_val
  let tri = llvm_fresh_reg(ec)
  let e1 = llvm_append_body(tri.e, concat_all(["  ", tri.reg, " = call i32 @kaix_truthy(%KaiValue* ", cv, ")\n"]))
  let cond = llvm_fresh_reg(e1)
  let e2 = llvm_append_body(cond.e, concat_all(["  ", cond.reg, " = icmp ne i32 ", tri.reg, ", 0\n"]))
  let th  = llvm_fresh_label(e2, "if.then.")
  let el  = llvm_fresh_label(th.e, "if.else.")
  let jn  = llvm_fresh_label(el.e, "if.end.")
  let e3 = llvm_append_body(jn.e, concat_all(["  br i1 ", cond.reg,
                                              ", label %", th.reg,
                                              ", label %", el.reg, "\n"]))
  # then block. NOTE: do not name the captured last_val `tv` — that
  # shadows the `tv` prelude-local helper defined in the type section,
  # and stage 1's emitter does not track pattern-bound scope, so a
  # string-interpolated reference resolves to the global fn's closure
  # instead of the local binding. See project_stage0_bugs.md #2.
  let e4 = llvm_open_block(e3, th.reg)
  let et = llvm_emit_expr(e4, t)
  let then_val = et.last_val
  let then_end_label = et.cur_label
  let e5 = llvm_append_body(et, concat_all(["  br label %", jn.reg, "\n"]))
  # else block.
  let e6 = llvm_open_block(e5, el.reg)
  let ee_final = match eo {
    Some(ex) -> {
      let ev = llvm_emit_expr(e6, ex)
      let closing = llvm_append_body(ev, concat_all(["  br label %", jn.reg, "\n"]))
      LlvmArm { e: closing, reg: ev.last_val, from_label: ev.cur_label }
    }
    None -> {
      let defv = llvm_fresh_reg(e6)
      let defi = concat_all(["  ", defv.reg, " = call %KaiValue* @kaix_bool(i32 0)\n"])
      let after_def = llvm_append_body(defv.e, defi)
      let closing = llvm_append_body(after_def,
                                     concat_all(["  br label %", jn.reg, "\n"]))
      LlvmArm { e: closing, reg: defv.reg, from_label: after_def.cur_label }
    }
  }
  # join.
  let e7 = llvm_open_block(ee_final.e, jn.reg)
  let phi = llvm_fresh_reg(e7)
  let phi_instr = concat_all([
    "  ", phi.reg, " = phi %KaiValue* [ ", then_val, ", %", then_end_label,
    " ], [ ", ee_final.reg, ", %", ee_final.from_label, " ]\n"
  ])
  llvm_set_last(llvm_append_body(phi.e, phi_instr), phi.reg)
}

# Intermediate record used by llvm_emit_if to bundle an arm's closing
# state, result register, and the label control flow actually exits
# through (which may differ from the arm's header label when the arm
# itself contains branches).
type LlvmArm = { e: LlvmEmit, reg: String, from_label: String }

# Block: evaluate stmts for side effects (SLet adds a local), then the
# tail expression. Without a tail, the block value is a placeholder
# Unit — inference already ensures Unit-valued callers accept it.
# m7c-b — lower an `EHandle` expression to LLVM IR. The shape
# mirrors the C `emit_handle` minus the setjmp/longjmp landing
# pad: we allocate the `%EvX` struct on the stack, initialise
# its `handler_id` and (optional) `state`, leave the op fn-ptr
# slots NULL (m7c-d wires them when clauses become LLVM
# functions), allocate a 48-byte `%KaiEvidence` buffer, push,
# evaluate the body in-line, pop, and run the return clause
# with the body result bound to its parameter.
#
# Limitation: a clause that *discards* `resume` requires the
# longjmp dance from C's m7a #6e, which is m7c-c's territory
# (the op-call site is what triggers the discard branch). For
# now, every fixture whose clauses always resume — every
# State / Reader / Writer canonical handler, every default
# handler, every #5b var-desugar — type-checks and emits clean
# LLVM IR. Discard-bearing user handlers will UB until m7c-c
# (op dispatch) and m7c-d (clauses + setjmp) land.
# m7c-d — for each handler clause, GEP into the matching `%EvX`
# field and store a function pointer to the clause's emitted
# top-level LLVM function (named via `clause_fn_name`).
# m7c-d — generate the LLVM IR body of `kai_main_install_defaults`
# and `kai_main_teardown_defaults`. Each builtin in main's row
# contributes a `kai_evidence_push(...)` (install) and a matching
# `kai_evidence_pop()` (teardown, in reverse order). The
# `Ev<Builtin>` struct, the per-op fn-ptr table, and the
# `kai_default_<eff>_<op>` symbols all live in stage0/runtime.h
# and are declared here as externals when needed.
fn llvm_default_builtin_decls(main_row: [String]) : String {
  # Function declarations live in `llvm_header`; here we only emit
  # the per-builtin globals (Ev struct + node buffer + name string)
  # gated on main's row. m12.8 Phase 4b: `Console` is the alias
  # `Stdout + Stderr + Stdin`, expanded to its atomics by
  # `expand_aliases_in_decls` before main's row reaches this point.
  concat_all([
    if list_has(main_row, "Stdout") {
      concat_all([
        "@_kai_default_ev_stdout = internal global %EvStdout zeroinitializer\n",
        "@_kai_default_node_stdout = internal global [48 x i8] zeroinitializer\n",
        "@_kai_default_stdout_name = private unnamed_addr constant [7 x i8] c\"Stdout\\00\"\n"
      ])
    } else { "" },
    if list_has(main_row, "Stderr") {
      concat_all([
        "@_kai_default_ev_stderr = internal global %EvStderr zeroinitializer\n",
        "@_kai_default_node_stderr = internal global [48 x i8] zeroinitializer\n",
        "@_kai_default_stderr_name = private unnamed_addr constant [7 x i8] c\"Stderr\\00\"\n"
      ])
    } else { "" },
    if list_has(main_row, "Fail") {
      concat_all([
        "@_kai_default_ev_fail = internal global %EvFail zeroinitializer\n",
        "@_kai_default_node_fail = internal global [48 x i8] zeroinitializer\n",
        "@_kai_default_fail_name = private unnamed_addr constant [5 x i8] c\"Fail\\00\"\n"
      ])
    } else { "" },
    if list_has(main_row, "Mutable") {
      concat_all([
        "@_kai_default_ev_mutable = internal global %EvMutable zeroinitializer\n",
        "@_kai_default_node_mutable = internal global [48 x i8] zeroinitializer\n",
        "@_kai_default_mutable_name = private unnamed_addr constant [8 x i8] c\"Mutable\\00\"\n"
      ])
    } else { "" },
    if list_has(main_row, "Random") {
      concat_all([
        "@_kai_default_ev_random = internal global %EvRandom zeroinitializer\n",
        "@_kai_default_node_random = internal global [48 x i8] zeroinitializer\n",
        "@_kai_default_random_name = private unnamed_addr constant [7 x i8] c\"Random\\00\"\n"
      ])
    } else { "" }
  ])
}

fn llvm_emit_main_install_defaults(main_row: [String]) : String {
  let stdout_ = if list_has(main_row, "Stdout") {
    concat_all([
      "  ; install Stdout default handler\n",
      "  %hid_stdout = call i64 @kaix_fresh_handler_id()\n",
      "  %ev_stdout_hid_p = getelementptr %EvStdout, %EvStdout* @_kai_default_ev_stdout, i32 0, i32 0\n",
      "  store i64 %hid_stdout, i64* %ev_stdout_hid_p\n",
      "  %ev_stdout_print_p = getelementptr %EvStdout, %EvStdout* @_kai_default_ev_stdout, i32 0, i32 3\n",
      "  store %KaiValue* (%EvStdout*, %KaiValue*, %KaiCont*)* bitcast (%KaiValue* (i8*, %KaiValue*, i8*)* @kaix_default_stdout_print to %KaiValue* (%EvStdout*, %KaiValue*, %KaiCont*)*), %KaiValue* (%EvStdout*, %KaiValue*, %KaiCont*)** %ev_stdout_print_p\n",
      "  %node_stdout_p = getelementptr [48 x i8], [48 x i8]* @_kai_default_node_stdout, i32 0, i32 0\n",
      "  %ev_stdout_void = bitcast %EvStdout* @_kai_default_ev_stdout to i8*\n",
      "  call void @kaix_evidence_push(i8* %node_stdout_p, i8* getelementptr inbounds ([7 x i8], [7 x i8]* @_kai_default_stdout_name, i64 0, i64 0), i8* %ev_stdout_void)\n"
    ])
  } else { "" }
  let stderr_ = if list_has(main_row, "Stderr") {
    concat_all([
      "  ; install Stderr default handler\n",
      "  %hid_stderr = call i64 @kaix_fresh_handler_id()\n",
      "  %ev_stderr_hid_p = getelementptr %EvStderr, %EvStderr* @_kai_default_ev_stderr, i32 0, i32 0\n",
      "  store i64 %hid_stderr, i64* %ev_stderr_hid_p\n",
      "  %ev_stderr_eprint_p = getelementptr %EvStderr, %EvStderr* @_kai_default_ev_stderr, i32 0, i32 3\n",
      "  store %KaiValue* (%EvStderr*, %KaiValue*, %KaiCont*)* bitcast (%KaiValue* (i8*, %KaiValue*, i8*)* @kaix_default_stderr_eprint to %KaiValue* (%EvStderr*, %KaiValue*, %KaiCont*)*), %KaiValue* (%EvStderr*, %KaiValue*, %KaiCont*)** %ev_stderr_eprint_p\n",
      "  %node_stderr_p = getelementptr [48 x i8], [48 x i8]* @_kai_default_node_stderr, i32 0, i32 0\n",
      "  %ev_stderr_void = bitcast %EvStderr* @_kai_default_ev_stderr to i8*\n",
      "  call void @kaix_evidence_push(i8* %node_stderr_p, i8* getelementptr inbounds ([7 x i8], [7 x i8]* @_kai_default_stderr_name, i64 0, i64 0), i8* %ev_stderr_void)\n"
    ])
  } else { "" }
  let fail = if list_has(main_row, "Fail") {
    concat_all([
      "  ; install Fail default handler\n",
      "  %hid_fail = call i64 @kaix_fresh_handler_id()\n",
      "  %ev_fail_hid_p = getelementptr %EvFail, %EvFail* @_kai_default_ev_fail, i32 0, i32 0\n",
      "  store i64 %hid_fail, i64* %ev_fail_hid_p\n",
      "  %ev_fail_op_p = getelementptr %EvFail, %EvFail* @_kai_default_ev_fail, i32 0, i32 3\n",
      "  store %KaiValue* (%EvFail*, %KaiValue*, %KaiCont*)* bitcast (%KaiValue* (i8*, %KaiValue*, i8*)* @kaix_default_fail_fail to %KaiValue* (%EvFail*, %KaiValue*, %KaiCont*)*), %KaiValue* (%EvFail*, %KaiValue*, %KaiCont*)** %ev_fail_op_p\n",
      "  %node_fail_p = getelementptr [48 x i8], [48 x i8]* @_kai_default_node_fail, i32 0, i32 0\n",
      "  %ev_fail_void = bitcast %EvFail* @_kai_default_ev_fail to i8*\n",
      "  call void @kaix_evidence_push(i8* %node_fail_p, i8* getelementptr inbounds ([5 x i8], [5 x i8]* @_kai_default_fail_name, i64 0, i64 0), i8* %ev_fail_void)\n"
    ])
  } else { "" }
  let mutable_ = if list_has(main_row, "Mutable") {
    concat_all([
      "  ; install Mutable default handler\n",
      "  %hid_mutable = call i64 @kaix_fresh_handler_id()\n",
      "  %ev_mutable_hid_p = getelementptr %EvMutable, %EvMutable* @_kai_default_ev_mutable, i32 0, i32 0\n",
      "  store i64 %hid_mutable, i64* %ev_mutable_hid_p\n",
      "  %ev_mutable_make_p = getelementptr %EvMutable, %EvMutable* @_kai_default_ev_mutable, i32 0, i32 3\n",
      "  store %KaiValue* (%EvMutable*, %KaiValue*, %KaiValue*, %KaiCont*)* bitcast (%KaiValue* (i8*, %KaiValue*, %KaiValue*, i8*)* @kaix_default_mutable_array_make to %KaiValue* (%EvMutable*, %KaiValue*, %KaiValue*, %KaiCont*)*), %KaiValue* (%EvMutable*, %KaiValue*, %KaiValue*, %KaiCont*)** %ev_mutable_make_p\n",
      "  %ev_mutable_len_p = getelementptr %EvMutable, %EvMutable* @_kai_default_ev_mutable, i32 0, i32 4\n",
      "  store %KaiValue* (%EvMutable*, %KaiValue*, %KaiCont*)* bitcast (%KaiValue* (i8*, %KaiValue*, i8*)* @kaix_default_mutable_array_length to %KaiValue* (%EvMutable*, %KaiValue*, %KaiCont*)*), %KaiValue* (%EvMutable*, %KaiValue*, %KaiCont*)** %ev_mutable_len_p\n",
      "  %ev_mutable_get_p = getelementptr %EvMutable, %EvMutable* @_kai_default_ev_mutable, i32 0, i32 5\n",
      "  store %KaiValue* (%EvMutable*, %KaiValue*, %KaiValue*, %KaiCont*)* bitcast (%KaiValue* (i8*, %KaiValue*, %KaiValue*, i8*)* @kaix_default_mutable_array_get to %KaiValue* (%EvMutable*, %KaiValue*, %KaiValue*, %KaiCont*)*), %KaiValue* (%EvMutable*, %KaiValue*, %KaiValue*, %KaiCont*)** %ev_mutable_get_p\n",
      "  %ev_mutable_set_p = getelementptr %EvMutable, %EvMutable* @_kai_default_ev_mutable, i32 0, i32 6\n",
      "  store %KaiValue* (%EvMutable*, %KaiValue*, %KaiValue*, %KaiValue*, %KaiCont*)* bitcast (%KaiValue* (i8*, %KaiValue*, %KaiValue*, %KaiValue*, i8*)* @kaix_default_mutable_array_set to %KaiValue* (%EvMutable*, %KaiValue*, %KaiValue*, %KaiValue*, %KaiCont*)*), %KaiValue* (%EvMutable*, %KaiValue*, %KaiValue*, %KaiValue*, %KaiCont*)** %ev_mutable_set_p\n",
      "  %ev_mutable_grow_p = getelementptr %EvMutable, %EvMutable* @_kai_default_ev_mutable, i32 0, i32 7\n",
      "  store %KaiValue* (%EvMutable*, %KaiValue*, %KaiValue*, %KaiValue*, %KaiCont*)* bitcast (%KaiValue* (i8*, %KaiValue*, %KaiValue*, %KaiValue*, i8*)* @kaix_default_mutable_array_grow to %KaiValue* (%EvMutable*, %KaiValue*, %KaiValue*, %KaiValue*, %KaiCont*)*), %KaiValue* (%EvMutable*, %KaiValue*, %KaiValue*, %KaiValue*, %KaiCont*)** %ev_mutable_grow_p\n",
      "  %node_mutable_p = getelementptr [48 x i8], [48 x i8]* @_kai_default_node_mutable, i32 0, i32 0\n",
      "  %ev_mutable_void = bitcast %EvMutable* @_kai_default_ev_mutable to i8*\n",
      "  call void @kaix_evidence_push(i8* %node_mutable_p, i8* getelementptr inbounds ([8 x i8], [8 x i8]* @_kai_default_mutable_name, i64 0, i64 0), i8* %ev_mutable_void)\n"
    ])
  } else { "" }
  let random_ = if list_has(main_row, "Random") {
    concat_all([
      "  ; install Random default handler\n",
      "  %hid_random = call i64 @kaix_fresh_handler_id()\n",
      "  %ev_random_hid_p = getelementptr %EvRandom, %EvRandom* @_kai_default_ev_random, i32 0, i32 0\n",
      "  store i64 %hid_random, i64* %ev_random_hid_p\n",
      "  %ev_random_int_range_p = getelementptr %EvRandom, %EvRandom* @_kai_default_ev_random, i32 0, i32 3\n",
      "  store %KaiValue* (%EvRandom*, %KaiValue*, %KaiValue*, %KaiCont*)* bitcast (%KaiValue* (i8*, %KaiValue*, %KaiValue*, i8*)* @kaix_default_random_int_range to %KaiValue* (%EvRandom*, %KaiValue*, %KaiValue*, %KaiCont*)*), %KaiValue* (%EvRandom*, %KaiValue*, %KaiValue*, %KaiCont*)** %ev_random_int_range_p\n",
      "  %node_random_p = getelementptr [48 x i8], [48 x i8]* @_kai_default_node_random, i32 0, i32 0\n",
      "  %ev_random_void = bitcast %EvRandom* @_kai_default_ev_random to i8*\n",
      "  call void @kaix_evidence_push(i8* %node_random_p, i8* getelementptr inbounds ([7 x i8], [7 x i8]* @_kai_default_random_name, i64 0, i64 0), i8* %ev_random_void)\n"
    ])
  } else { "" }
  concat_all([
    llvm_default_builtin_decls(main_row),
    "\ndefine void @kai_main_install_defaults() {\n",
    stdout_,
    stderr_,
    fail,
    random_,
    mutable_,
    "  ret void\n",
    "}\n\n"
  ])
}

fn llvm_emit_main_teardown_defaults(main_row: [String]) : String {
  let pops = concat_all([
    if list_has(main_row, "Mutable") { "  call void @kaix_evidence_pop()\n" } else { "" },
    if list_has(main_row, "Random")  { "  call void @kaix_evidence_pop()\n" } else { "" },
    if list_has(main_row, "Fail")    { "  call void @kaix_evidence_pop()\n" } else { "" },
    if list_has(main_row, "Stderr")  { "  call void @kaix_evidence_pop()\n" } else { "" },
    if list_has(main_row, "Stdout")  { "  call void @kaix_evidence_pop()\n" } else { "" }
  ])
  concat_all([
    "define void @kai_main_teardown_defaults() {\n",
    pops,
    "  ret void\n",
    "}\n"
  ])
}

fn llvm_emit_handle_clause_assigns(e: LlvmEmit, ev_reg: String, eff_name: String,
                                    hline: Int, hcol: Int,
                                    cs: [HClause]) : LlvmEmit {
  match cs {
    [] -> e
    [c, ...rest] -> match c {
      HC(op_name, params, _, _, _) -> {
        let key = string_concat(eff_name, string_concat(".", op_name))
        match lookup_op_offset(e.op_offsets, key) {
          None -> llvm_emit_handle_clause_assigns(e, ev_reg, eff_name, hline, hcol, rest)
          Some(offset) -> {
            let op_args = op_args_only(params)
            let arg_ty_list = llvm_op_arg_kaivalue_list(list_length(op_args))
            let p_reg = llvm_fresh_reg(e)
            let p_gep = concat_all([
              "  ", p_reg.reg, " = getelementptr %Ev", eff_name,
              ", %Ev", eff_name, "* ", ev_reg, ", i32 0, i32 ",
              int_to_string(offset), "\n",
              "  store %KaiValue* (%Ev", eff_name, "*", arg_ty_list, ", i8*)* @",
              clause_fn_name(hline, hcol, op_name),
              ", %KaiValue* (%Ev", eff_name, "*", arg_ty_list, ", i8*)** ",
              p_reg.reg, "\n"
            ])
            let e1 = llvm_append_body(p_reg.e, p_gep)
            llvm_emit_handle_clause_assigns(e1, ev_reg, eff_name, hline, hcol, rest)
          }
        }
      }
    }
  }
}

fn llvm_emit_handle(e: LlvmEmit, body: Expr, eff_name: String,
                    init_opt: Option[Expr], alias_opt: Option[String],
                    clauses: [HClause], ret_opt: Option[HReturn],
                    hline: Int, hcol: Int) : LlvmEmit {
  let _ = alias_opt    # m7c-c will use this for per-instance dispatch
  # alloca the `%EvX` struct; zero-init field by field.
  let ev_reg = llvm_fresh_reg(e)
  let ev_alloca = concat_all([
    "  ", ev_reg.reg, " = alloca %Ev", eff_name, ", align 8\n"
  ])
  let e1 = llvm_append_body(ev_reg.e, ev_alloca)
  # handler_id <- kai_fresh_handler_id()
  let hid_reg = llvm_fresh_reg(e1)
  let hid_call = concat_all([
    "  ", hid_reg.reg, " = call i64 @kaix_fresh_handler_id()\n"
  ])
  let e2 = llvm_append_body(hid_reg.e, hid_call)
  let hid_gep_reg = llvm_fresh_reg(e2)
  let hid_gep = concat_all([
    "  ", hid_gep_reg.reg, " = getelementptr %Ev", eff_name,
    ", %Ev", eff_name, "* ", ev_reg.reg, ", i32 0, i32 0\n",
    "  store i64 ", hid_reg.reg, ", i64* ", hid_gep_reg.reg, "\n"
  ])
  let e3 = llvm_append_body(hid_gep_reg.e, hid_gep)
  # env <- null
  let env_gep_reg = llvm_fresh_reg(e3)
  let env_gep = concat_all([
    "  ", env_gep_reg.reg, " = getelementptr %Ev", eff_name,
    ", %Ev", eff_name, "* ", ev_reg.reg, ", i32 0, i32 1\n",
    "  store i8* null, i8** ", env_gep_reg.reg, "\n"
  ])
  let e4 = llvm_append_body(env_gep_reg.e, env_gep)
  # state <- init_opt or null
  let state_init = match init_opt {
    Some(ie) -> {
      let r = llvm_emit_expr(e4, ie)
      let r1 = r
      let st_gep_reg = llvm_fresh_reg(r1)
      let st_gep = concat_all([
        "  ", st_gep_reg.reg, " = getelementptr %Ev", eff_name,
        ", %Ev", eff_name, "* ", ev_reg.reg, ", i32 0, i32 2\n",
        "  store %KaiValue* ", r1.last_val, ", %KaiValue** ", st_gep_reg.reg, "\n"
      ])
      llvm_append_body(st_gep_reg.e, st_gep)
    }
    None -> {
      let st_gep_reg = llvm_fresh_reg(e4)
      let st_gep = concat_all([
        "  ", st_gep_reg.reg, " = getelementptr %Ev", eff_name,
        ", %Ev", eff_name, "* ", ev_reg.reg, ", i32 0, i32 2\n",
        "  store %KaiValue* null, %KaiValue** ", st_gep_reg.reg, "\n"
      ])
      llvm_append_body(st_gep_reg.e, st_gep)
    }
  }
  # m7c-d — wire each clause's fn pointer into the matching field
  # of the EvX struct. Field index comes from `op_offsets`, fn ptr
  # type is built from the clause's params (mirroring the effect
  # struct's per-op signature).
  let after_clauses = llvm_emit_handle_clause_assigns(state_init, ev_reg.reg, eff_name, hline, hcol, clauses)
  # alloca a 48-byte buffer for the KaiEvidence node and bitcast.
  let node_buf_reg = llvm_fresh_reg(after_clauses)
  let node_alloca = concat_all([
    "  ", node_buf_reg.reg, " = alloca [48 x i8], align 8\n"
  ])
  let e5 = llvm_append_body(node_buf_reg.e, node_alloca)
  let node_ptr_reg = llvm_fresh_reg(e5)
  let node_cast = concat_all([
    "  ", node_ptr_reg.reg, " = bitcast [48 x i8]* ", node_buf_reg.reg, " to i8*\n"
  ])
  let e6 = llvm_append_body(node_ptr_reg.e, node_cast)
  # name string
  let name_res = llvm_emit_name_constant(e6, eff_name, "eff.name.")
  # cast EvX* to i8* for kai_evidence_push
  let ev_void_reg = llvm_fresh_reg(name_res.e)
  let ev_cast = concat_all([
    "  ", ev_void_reg.reg, " = bitcast %Ev", eff_name, "* ", ev_reg.reg, " to i8*\n"
  ])
  let e7 = llvm_append_body(ev_void_reg.e, ev_cast)
  # push
  let push_call = concat_all([
    "  call void @kaix_evidence_push(i8* ", node_ptr_reg.reg,
    ", i8* ", name_res.gep,
    ", i8* ", ev_void_reg.reg, ")\n"
  ])
  let e8 = llvm_append_body(e7, push_call)
  # evaluate body
  let body_e = llvm_emit_expr(e8, body)
  let body_val = body_e.last_val
  # pop
  let e9 = llvm_append_body(body_e, "  call void @kaix_evidence_pop()\n")
  # return clause: bind body result to its pname and emit
  match ret_opt {
    Some(r) -> match r {
      HR(pname, rexpr, _, _) -> {
        let bound = llvm_push_local(e9, pname, body_val)
        # m7b #11: stateful return clauses also see `state` / `log`
        let bound2 = match init_opt {
          Some(_) -> {
            # Re-load state from the Ev struct (which we wrote above).
            # Since the alloca persists for the function, the load is fine.
            let st_gep_reg = llvm_fresh_reg(bound)
            let st_load_reg = llvm_fresh_reg(st_gep_reg.e)
            let st_code = concat_all([
              "  ", st_gep_reg.reg, " = getelementptr %Ev", eff_name,
              ", %Ev", eff_name, "* ", ev_reg.reg, ", i32 0, i32 2\n",
              "  ", st_load_reg.reg, " = load %KaiValue*, %KaiValue** ", st_gep_reg.reg, "\n"
            ])
            let with_load = llvm_append_body(st_load_reg.e, st_code)
            let with_state = llvm_push_local(with_load, "state", st_load_reg.reg)
            llvm_push_local(with_state, "log", st_load_reg.reg)
          }
          None -> bound
        }
        llvm_emit_expr(bound2, rexpr)
      }
    }
    None -> llvm_set_last(e9, body_val)
  }
}

fn llvm_emit_block(e: LlvmEmit, stmts: [Stmt], tail: Option[Expr]) : LlvmEmit {
  let outer_locals = e.locals
  let after = llvm_emit_stmts(e, stmts)
  let tailed = match tail {
    Some(te) -> llvm_emit_expr(after, te)
    None -> {
      let reg = llvm_fresh_reg(after)
      let instr = concat_all(["  ", reg.reg, " = call %KaiValue* @kaix_bool(i32 0)\n"])
      llvm_set_last(llvm_append_body(reg.e, instr), reg.reg)
    }
  }
  # Restore outer scope, keep id counter / body / globals / last_val.
  LlvmEmit { ids: tailed.ids, globals: tailed.globals, body: tailed.body,
             last_val: tailed.last_val, cur_label: tailed.cur_label,
             locals: outer_locals, fns: tailed.fns, vars_: tailed.vars_, lams: tailed.lams, op_offsets: tailed.op_offsets }
}

fn llvm_emit_stmts(e: LlvmEmit, stmts: [Stmt]) : LlvmEmit {
  match stmts {
    [] -> e
    [s, ...rest] -> llvm_emit_stmts(llvm_emit_stmt(e, s), rest)
  }
}

fn llvm_emit_stmt(e: LlvmEmit, s: Stmt) : LlvmEmit / Console {
  match s {
    SLet(pat, _, rhs) -> {
      let er = llvm_emit_expr(e, rhs)
      match pat.pkind {
        PBind(nm) -> llvm_push_local(er, nm, er.last_val)
        PWild     -> er
        _ -> {
          eprint("llvm: let with non-trivial pattern not supported in M3b at #{int_to_string(pat.line)}:#{int_to_string(pat.col)}")
          er
        }
      }
    }
    SAssert(cond, _) -> {
      # Evaluate for side effects; assert-message handling is M3b+.
      llvm_emit_expr(e, cond)
    }
    SExprStmt(ex) -> llvm_emit_expr(e, ex)
    # m7b #6: index-assign desugars away pre-resolve; this arm is dead
    # code in normal compilation but keeps the match exhaustive.
    SIndexAssign(_, _, _, line, col) -> {
      eprint("llvm: SIndexAssign reached llvm emitter at #{int_to_string(line)}:#{int_to_string(col)}")
      e
    }
    # m7b #5: SVar should be desugared away pre-resolve; this arm is
    # dead code in normal compilation but keeps the match exhaustive.
    SVar(_, _, _, line, col) -> {
      eprint("llvm: SVar reached llvm emitter at #{int_to_string(line)}:#{int_to_string(col)}")
      e
    }
  }
}

# ---- fn emission ----

fn llvm_param_list_loop(ps: [Param], acc: String) : String {
  match ps {
    [] -> acc
    [p, ...rest] -> {
      let sep = if string_length(acc) == 0 { "" } else { ", " }
      let piece = concat_all([sep, "%KaiValue* %p_", p.pname])
      llvm_param_list_loop(rest, string_concat(acc, piece))
    }
  }
}

fn llvm_param_list(ps: [Param]) : String = llvm_param_list_loop(ps, "")

fn llvm_init_locals_from_params(ps: [Param]) : [LlvmLocal] {
  match ps {
    [] -> []
    [p, ...rest] -> [LL(p.pname, string_concat("%p_", p.pname)), ...llvm_init_locals_from_params(rest)]
  }
}

# ---- list literals ----

fn llvm_emit_list(e: LlvmEmit, elems: [ListElem]) : LlvmEmit = llvm_emit_list_tail(e, elems)

fn llvm_emit_list_tail(e: LlvmEmit, elems: [ListElem]) : LlvmEmit {
  match elems {
    [] -> {
      let r = llvm_fresh_reg(e)
      let instr = concat_all(["  ", r.reg, " = call %KaiValue* @kaix_nil()\n"])
      llvm_set_last(llvm_append_body(r.e, instr), r.reg)
    }
    # Tail spread `[..., ...xs]`: mirror the C backend's fast path.
    # kaix_incref gives RC=1 result with source untouched in O(1),
    # matching the contract list_append used to provide via spine
    # copy. Critical for the self-hosting LLVM build — without it
    # the emitted binary takes 120× longer than the C equivalent.
    [el] -> match el {
      ElPlain(x) -> {
        let eh = llvm_emit_expr(e, x)
        let head_val = eh.last_val
        let rnil = llvm_fresh_reg(eh)
        let einil = llvm_append_body(rnil.e, concat_all(["  ", rnil.reg, " = call %KaiValue* @kaix_nil()\n"]))
        let r = llvm_fresh_reg(einil)
        let instr = concat_all([
          "  ", r.reg, " = call %KaiValue* @kaix_cons(%KaiValue* ", head_val,
          ", %KaiValue* ", rnil.reg, ")\n"
        ])
        llvm_set_last(llvm_append_body(r.e, instr), r.reg)
      }
      ElSpread(x) -> {
        let eh = llvm_emit_expr(e, x)
        let head_val = eh.last_val
        let r = llvm_fresh_reg(eh)
        let instr = concat_all([
          "  ", r.reg, " = call %KaiValue* @kaix_incref(%KaiValue* ", head_val, ")\n"
        ])
        llvm_set_last(llvm_append_body(r.e, instr), r.reg)
      }
    }
    [el, ...rest] -> match el {
      ElPlain(x) -> {
        let eh = llvm_emit_expr(e, x)
        let head_val = eh.last_val
        let et = llvm_emit_list_tail(eh, rest)
        let tail_val = et.last_val
        let r = llvm_fresh_reg(et)
        let instr = concat_all([
          "  ", r.reg, " = call %KaiValue* @kaix_cons(%KaiValue* ", head_val,
          ", %KaiValue* ", tail_val, ")\n"
        ])
        llvm_set_last(llvm_append_body(r.e, instr), r.reg)
      }
      ElSpread(x) -> {
        let eh = llvm_emit_expr(e, x)
        let head_val = eh.last_val
        let et = llvm_emit_list_tail(eh, rest)
        let tail_val = et.last_val
        let r = llvm_fresh_reg(et)
        let instr = concat_all([
          "  ", r.reg, " = call %KaiValue* @kaix_prelude_list_append(%KaiValue* ",
          head_val, ", %KaiValue* ", tail_val, ")\n"
        ])
        llvm_set_last(llvm_append_body(r.e, instr), r.reg)
      }
    }
  }
}

# ---- lambda expressions ----
#
# At the ELambda site we look up the LamInfo by (line, col) and emit
# a call to `kaix_closure` with the thunk's address, arity, and the
# captured values currently in scope.
fn llvm_emit_lambda_ref(e: LlvmEmit, x: Expr) : LlvmEmit / Console {
  match find_lam(e.lams, x.line, x.col) {
    None -> {
      eprint("llvm: lambda info missing at #{int_to_string(x.line)}:#{int_to_string(x.col)}")
      llvm_set_last(e, "undef")
    }
    Some(l) -> match l {
      LamInfo(id, _, _, params, caps, _) -> {
        let arity = list_length(params)
        let n_caps = list_length(caps)
        let thunk_sym = concat_all(["@_kai_lam_", int_to_string(id)])
        if n_caps == 0 {
          llvm_build_closure(e, thunk_sym, arity)
        } else {
          let buf = llvm_fresh_reg(e)
          let alloc_i = concat_all([
            "  ", buf.reg, " = alloca %KaiValue*, i32 ", int_to_string(n_caps), "\n"
          ])
          let e1 = llvm_append_body(buf.e, alloc_i)
          let e2 = llvm_emit_capture_stores(e1, buf.reg, caps, 0)
          # Bitcast the buffer to i8* as a separate instruction; inline
          # constant-expr bitcast is not allowed on function-local
          # SSA values like the `alloca` result.
          let cast = llvm_fresh_reg(e2)
          let cast_i = concat_all([
            "  ", cast.reg, " = bitcast %KaiValue** ", buf.reg, " to i8*\n"
          ])
          let e3 = llvm_append_body(cast.e, cast_i)
          let r = llvm_fresh_reg(e3)
          let call_i = concat_all([
            "  ", r.reg, " = call %KaiValue* @kaix_closure(",
            "i8* bitcast (%KaiValue* (%KaiValue*, %KaiValue**, i32)* ", thunk_sym, " to i8*), ",
            "i32 ", int_to_string(arity), ", ",
            "i32 ", int_to_string(n_caps), ", ",
            "i8* ", cast.reg, ")\n"
          ])
          llvm_set_last(llvm_append_body(r.e, call_i), r.reg)
        }
      }
    }
  }
}

# Fill the captures buffer with the current register binding for each
# captured name. If a capture isn't in scope (shouldn't happen after
# `fv_expr`), store a null to keep the IR well-formed.
fn llvm_emit_capture_stores(e: LlvmEmit, buf_reg: String, caps: [String], i: Int) : LlvmEmit {
  match caps {
    [] -> e
    [c, ...rest] -> {
      let val = match llvm_local_find(e.locals, c) {
        Some(r) -> r
        None -> "null"
      }
      let gep = llvm_fresh_reg(e)
      let gep_i = concat_all([
        "  ", gep.reg, " = getelementptr inbounds %KaiValue*, %KaiValue** ", buf_reg,
        ", i32 ", int_to_string(i), "\n"
      ])
      let e1 = llvm_append_body(gep.e, gep_i)
      let store_i = concat_all([
        "  store %KaiValue* ", val, ", %KaiValue** ", gep.reg, "\n"
      ])
      let e2 = llvm_append_body(e1, store_i)
      llvm_emit_capture_stores(e2, buf_reg, rest, i + 1)
    }
  }
}

# ---- match lowering ----
#
# A match expression lowers to a chain of try-blocks, one per arm.
# Each arm's pattern test branches to the arm's body on success and
# to the *next* try-block on failure; a successful body branches to
# the match's end block carrying its value. The last failure drops
# into a panic block that calls `kaix_panic` and ends with
# `unreachable` — LLVM requires every block to have a terminator.
#
# Pattern support for M3d: PWild, PBind, PLit, PVariant (including
# recursive sub-patterns). PList, PRecord, PVariantRecord are left
# for M3e.

type LlvmArmEntry = AE(String, String)          # (value reg, from_label)
type LlvmArmCollect = { e: LlvmEmit, entries: [LlvmArmEntry] }

fn llvm_format_phi_loop(entries: [LlvmArmEntry], first: Bool) : String {
  match entries {
    [] -> ""
    [ae, ...rest] -> match ae {
      AE(v, lbl) -> {
        let sep = if first { "" } else { ", " }
        concat_all([sep, "[ ", v, ", %", lbl, " ]", llvm_format_phi_loop(rest, false)])
      }
    }
  }
}

fn llvm_format_phi(entries: [LlvmArmEntry]) : String =
  llvm_format_phi_loop(entries, true)

# Emit one variant-name global + return the GEP expression for it.
type LlvmNameLabel = { e: LlvmEmit, gep: String }

fn llvm_emit_name_constant(e: LlvmEmit, nm: String, prefix: String) : LlvmNameLabel {
  let lbl = llvm_fresh_label(e, prefix)
  let n = string_length(nm) + 1
  let e2 = llvm_append_global(lbl.e, llvm_emit_string_const(lbl.reg, nm))
  LlvmNameLabel { e: e2, gep: llvm_gep_str(lbl.reg, n) }
}

# Emit a cond br that falls through when `cond_reg` is true and jumps
# to `fail_lbl` otherwise. Opens a fresh success block.
fn llvm_emit_cond_br_fail(e: LlvmEmit, cond_reg: String, fail_lbl: String, prefix: String) : LlvmEmit {
  let ok = llvm_fresh_label(e, prefix)
  let br = concat_all([
    "  br i1 ", cond_reg, ", label %", ok.reg, ", label %", fail_lbl, "\n"
  ])
  let e1 = llvm_append_body(ok.e, br)
  llvm_open_block(e1, ok.reg)
}

# Check truthiness of a KaiValue* in `scr_val` and branch to fail_lbl
# if false.
fn llvm_emit_truthy_br(e: LlvmEmit, scr_val: String, fail_lbl: String, prefix: String) : LlvmEmit {
  let tr = llvm_fresh_reg(e)
  let tr_i = concat_all(["  ", tr.reg, " = call i32 @kaix_truthy(%KaiValue* ", scr_val, ")\n"])
  let e1 = llvm_append_body(tr.e, tr_i)
  let cond = llvm_fresh_reg(e1)
  let cond_i = concat_all(["  ", cond.reg, " = icmp ne i32 ", tr.reg, ", 0\n"])
  let e2 = llvm_append_body(cond.e, cond_i)
  llvm_emit_cond_br_fail(e2, cond.reg, fail_lbl, prefix)
}

# Pattern test. Adds locals for PBind, branches to `fail_lbl` on any
# non-matching leaf. Falls through into the current block on success;
# the caller then emits the arm body.
fn llvm_emit_pattern_test(e: LlvmEmit, pat: Pattern, scr: String, fail_lbl: String) : LlvmEmit / Console {
  match pat.pkind {
    PWild -> e
    PBind(nm) -> llvm_push_local(e, nm, scr)
    PLit(lit) -> {
      let el = llvm_emit_expr(e, lit)
      let lv = el.last_val
      let eq = llvm_fresh_reg(el)
      let eq_i = concat_all([
        "  ", eq.reg, " = call %KaiValue* @kaix_eq_raw(%KaiValue* ", scr,
        ", %KaiValue* ", lv, ")\n"
      ])
      let e1 = llvm_append_body(eq.e, eq_i)
      llvm_emit_truthy_br(e1, eq.reg, fail_lbl, "pat.lit.ok.")
    }
    PVariant(cname, subpats) -> {
      let name_res = llvm_emit_name_constant(e, cname, "var.")
      let chk = llvm_fresh_reg(name_res.e)
      let chk_i = concat_all([
        "  ", chk.reg, " = call i32 @kaix_is_variant(%KaiValue* ", scr,
        ", i8* ", name_res.gep, ")\n"
      ])
      let e1 = llvm_append_body(chk.e, chk_i)
      let cond = llvm_fresh_reg(e1)
      let cond_i = concat_all(["  ", cond.reg, " = icmp ne i32 ", chk.reg, ", 0\n"])
      let e2 = llvm_append_body(cond.e, cond_i)
      let e3 = llvm_emit_cond_br_fail(e2, cond.reg, fail_lbl, "pat.var.ok.")
      llvm_emit_pat_subpats(e3, subpats, scr, fail_lbl, 0)
    }
    PList(sub_pats, opt_rest) -> llvm_emit_pat_list(e, sub_pats, opt_rest, scr, fail_lbl)
    PHole(_) -> e
    # m7d §14: bind the as-name to the whole scrutinee, then test +
    # bind the inner pattern on the same scrutinee.
    PAs(nm, sub) -> {
      let e1 = llvm_push_local(e, nm, scr)
      llvm_emit_pattern_test(e1, sub, scr, fail_lbl)
    }
    _ -> {
      eprint("llvm: pattern kind not supported at #{int_to_string(pat.line)}:#{int_to_string(pat.col)}")
      e
    }
  }
}

# List-pattern test. `[]` checks `is_nil`. `[p1, ..., pn]` without a
# rest binder requires exactly n elements (cons * n, then nil). With
# a rest binder (`...rest`) only the prefix is required; `rest` is
# bound to the tail at position n.
fn llvm_emit_pat_list(e: LlvmEmit, sub_pats: [Pattern], opt_rest: Option[String],
                       scr: String, fail_lbl: String) : LlvmEmit {
  let n_fixed = list_length(sub_pats)
  let has_rest = match opt_rest { Some(_) -> true None -> false }
  if n_fixed == 0 {
    if has_rest {
      # [..rest] — any list; bind rest = scr.
      match opt_rest {
        Some(nm) -> llvm_push_local(e, nm, scr)
        None     -> e
      }
    } else {
      # [] — require is_nil.
      let chk = llvm_fresh_reg(e)
      let chk_i = concat_all([
        "  ", chk.reg, " = call i32 @kaix_is_nil(%KaiValue* ", scr, ")\n"
      ])
      let e1 = llvm_append_body(chk.e, chk_i)
      let cond = llvm_fresh_reg(e1)
      let cond_i = concat_all(["  ", cond.reg, " = icmp ne i32 ", chk.reg, ", 0\n"])
      let e2 = llvm_append_body(cond.e, cond_i)
      llvm_emit_cond_br_fail(e2, cond.reg, fail_lbl, "pat.nil.ok.")
    }
  } else {
    llvm_emit_pat_list_loop(e, sub_pats, has_rest, opt_rest, scr, fail_lbl)
  }
}

fn llvm_emit_pat_list_loop(e: LlvmEmit, sub_pats: [Pattern], has_rest: Bool,
                            opt_rest: Option[String], scr: String, fail_lbl: String) : LlvmEmit {
  match sub_pats {
    [] -> {
      # End of fixed prefix: either rest-binder gets the tail, or we
      # require the tail to be nil.
      if has_rest {
        match opt_rest {
          Some(nm) -> llvm_push_local(e, nm, scr)
          None     -> e
        }
      } else {
        let chk = llvm_fresh_reg(e)
        let chk_i = concat_all([
          "  ", chk.reg, " = call i32 @kaix_is_nil(%KaiValue* ", scr, ")\n"
        ])
        let e1 = llvm_append_body(chk.e, chk_i)
        let cond = llvm_fresh_reg(e1)
        let cond_i = concat_all(["  ", cond.reg, " = icmp ne i32 ", chk.reg, ", 0\n"])
        let e2 = llvm_append_body(cond.e, cond_i)
        llvm_emit_cond_br_fail(e2, cond.reg, fail_lbl, "pat.nil_end.ok.")
      }
    }
    [p, ...rest] -> {
      let chk = llvm_fresh_reg(e)
      let chk_i = concat_all([
        "  ", chk.reg, " = call i32 @kaix_is_cons(%KaiValue* ", scr, ")\n"
      ])
      let e1 = llvm_append_body(chk.e, chk_i)
      let cond = llvm_fresh_reg(e1)
      let cond_i = concat_all(["  ", cond.reg, " = icmp ne i32 ", chk.reg, ", 0\n"])
      let e2 = llvm_append_body(cond.e, cond_i)
      let e3 = llvm_emit_cond_br_fail(e2, cond.reg, fail_lbl, "pat.cons.ok.")
      let head = llvm_fresh_reg(e3)
      let head_i = concat_all([
        "  ", head.reg, " = call %KaiValue* @kaix_cons_head(%KaiValue* ", scr, ")\n"
      ])
      let e4 = llvm_append_body(head.e, head_i)
      let tail = llvm_fresh_reg(e4)
      let tail_i = concat_all([
        "  ", tail.reg, " = call %KaiValue* @kaix_cons_tail(%KaiValue* ", scr, ")\n"
      ])
      let e5 = llvm_append_body(tail.e, tail_i)
      let e6 = llvm_emit_pattern_test(e5, p, head.reg, fail_lbl)
      llvm_emit_pat_list_loop(e6, rest, has_rest, opt_rest, tail.reg, fail_lbl)
    }
  }
}

fn llvm_emit_pat_subpats(e: LlvmEmit, ps: [Pattern], scr: String, fail_lbl: String, i: Int) : LlvmEmit {
  match ps {
    [] -> e
    [p, ...rest] -> {
      let arg = llvm_fresh_reg(e)
      let instr = concat_all([
        "  ", arg.reg, " = call %KaiValue* @kaix_variant_arg(%KaiValue* ", scr,
        ", i32 ", int_to_string(i), ")\n"
      ])
      let e1 = llvm_append_body(arg.e, instr)
      let e2 = llvm_emit_pattern_test(e1, p, arg.reg, fail_lbl)
      llvm_emit_pat_subpats(e2, rest, scr, fail_lbl, i + 1)
    }
  }
}

# Guard: evaluate, truthy-branch, fall through on success.
fn llvm_emit_guard_test(e: LlvmEmit, gx: Expr, fail_lbl: String) : LlvmEmit {
  let eg = llvm_emit_expr(e, gx)
  llvm_emit_truthy_br(eg, eg.last_val, fail_lbl, "match.guard.ok.")
}

fn llvm_emit_match_arms(e: LlvmEmit, arms: [Arm], scr_reg: String, end_lbl: String,
                         acc: [LlvmArmEntry]) : LlvmArmCollect {
  match arms {
    [] -> LlvmArmCollect { e: e, entries: list_reverse(acc) }
    [a, ...rest] -> match a {
      Arm(pat, guard, body) -> {
        let outer_locals = e.locals
        let next_try = llvm_fresh_label(e, "match.next.")
        let e_test = llvm_emit_pattern_test(next_try.e, pat, scr_reg, next_try.reg)
        let e_guarded = match guard {
          None -> e_test
          Some(gx) -> llvm_emit_guard_test(e_test, gx, next_try.reg)
        }
        let eb = llvm_emit_expr(e_guarded, body)
        let body_val = eb.last_val
        let body_end = eb.cur_label
        let e_br = llvm_append_body(eb, concat_all(["  br label %", end_lbl, "\n"]))
        let e_scoped = LlvmEmit {
          ids: e_br.ids, globals: e_br.globals, body: e_br.body,
          last_val: e_br.last_val, cur_label: e_br.cur_label,
          locals: outer_locals, fns: e_br.fns, vars_: e_br.vars_,
          lams: e_br.lams, op_offsets: e_br.op_offsets
        }
        let e_next = llvm_open_block(e_scoped, next_try.reg)
        llvm_emit_match_arms(e_next, rest, scr_reg, end_lbl,
                             [AE(body_val, body_end), ...acc])
      }
    }
  }
}

fn llvm_emit_match(e: LlvmEmit, scr: Expr, arms: [Arm], line: Int, col: Int) : LlvmEmit / Console {
  let es = llvm_emit_expr(e, scr)
  let scr_reg = es.last_val
  let end_lbl = llvm_fresh_label(es, "match.end.")
  let arm_res = llvm_emit_match_arms(end_lbl.e, arms, scr_reg, end_lbl.reg, [])
  # Trailing fall-through block (the last `match.next.N`) panics.
  let msg = concat_all([
    "non-exhaustive match at ", int_to_string(line), ":", int_to_string(col)
  ])
  let msg_res = llvm_emit_name_constant(arm_res.e, msg, "panic.msg.")
  let sreg = llvm_fresh_reg(msg_res.e)
  let s_instr = concat_all([
    "  ", sreg.reg, " = call %KaiValue* @kaix_str(i8* ", msg_res.gep, ")\n"
  ])
  let e_s = llvm_append_body(sreg.e, s_instr)
  let pcall = llvm_fresh_reg(e_s)
  let p_instr = concat_all([
    "  ", pcall.reg, " = call %KaiValue* @kaix_match_panic(%KaiValue* ", sreg.reg, ")\n",
    "  unreachable\n"
  ])
  let e_p = llvm_append_body(pcall.e, p_instr)
  let e_end = llvm_open_block(e_p, end_lbl.reg)
  match arm_res.entries {
    [] -> {
      eprint("llvm: match with no arms")
      llvm_set_last(e_end, "undef")
    }
    _ -> {
      let phi = llvm_fresh_reg(e_end)
      let phi_instr = concat_all([
        "  ", phi.reg, " = phi %KaiValue* ", llvm_format_phi(arm_res.entries), "\n"
      ])
      llvm_set_last(llvm_append_body(phi.e, phi_instr), phi.reg)
    }
  }
}

# m7e §13 (Phase 2) — LLVM lowering for `expr!`.
#
# Mirrors the C backend's `emit_bang`: evaluate the operand, branch
# on the success-variant tag (`Some` for Option, `Ok` for Result),
# return the operand value verbatim from the enclosing fn on failure,
# and yield the unwrapped payload on success. The discriminator is
# picked from `inner.ty`, which `synth_bang` stamps with the resolved
# `TyCon("Option" | "Result", _)` after substitution. The typer also
# rejects `e!` inside lambdas (see `synth_lambda`'s `ret_ty = None`),
# so the `ret` here is always for the immediately-enclosing kaikai
# fn — never for a closure body.
fn llvm_emit_bang(e: LlvmEmit, inner: Expr) : LlvmEmit {
  let success = bang_success_variant(inner.ty)
  match success {
    None -> {
      # Should be unreachable — synth_bang rejects non-Option/Result
      # operands. Keeping a panic stub here so a typer regression
      # surfaces as a runtime trap rather than silently-wrong IR.
      let msg = "internal: `!` on non-Option/Result reached LLVM emitter"
      let nm_res = llvm_emit_name_constant(e, msg, "bang.bug.msg.")
      let sreg = llvm_fresh_reg(nm_res.e)
      let s_instr = concat_all([
        "  ", sreg.reg, " = call %KaiValue* @kaix_str(i8* ", nm_res.gep, ")\n"
      ])
      let e_s = llvm_append_body(sreg.e, s_instr)
      let pcall = llvm_fresh_reg(e_s)
      let p_instr = concat_all([
        "  ", pcall.reg, " = call %KaiValue* @kaix_match_panic(%KaiValue* ", sreg.reg, ")\n",
        "  unreachable\n"
      ])
      llvm_set_last(llvm_append_body(pcall.e, p_instr), pcall.reg)
    }
    Some(name) -> {
      let ei = llvm_emit_expr(e, inner)
      let inner_reg = ei.last_val
      let nm_res = llvm_emit_name_constant(ei, name, "bang.var.")
      let chk = llvm_fresh_reg(nm_res.e)
      let chk_i = concat_all([
        "  ", chk.reg, " = call i32 @kaix_is_variant(%KaiValue* ", inner_reg,
        ", i8* ", nm_res.gep, ")\n"
      ])
      let e1 = llvm_append_body(chk.e, chk_i)
      let cond = llvm_fresh_reg(e1)
      let cond_i = concat_all(["  ", cond.reg, " = icmp ne i32 ", chk.reg, ", 0\n"])
      let e2 = llvm_append_body(cond.e, cond_i)
      let unwrap_lbl = llvm_fresh_label(e2, "bang.unwrap.")
      let fail_lbl   = llvm_fresh_label(unwrap_lbl.e, "bang.fail.")
      let br_i = concat_all([
        "  br i1 ", cond.reg,
        ", label %", unwrap_lbl.reg,
        ", label %", fail_lbl.reg, "\n"
      ])
      let e3 = llvm_append_body(fail_lbl.e, br_i)
      # Fail block: propagate the operand verbatim to the caller's
      # caller. The operand is already a `%KaiValue*` of the enclosing
      # fn's return type (typer enforces `Option[U]` / `Result[E, U]`
      # match), so a bare `ret` of `%inner_reg` is well-typed.
      let e_fail = llvm_open_block(e3, fail_lbl.reg)
      let fail_ret = concat_all([
        "  ret %KaiValue* ", inner_reg, "\n"
      ])
      let e_fail_done = llvm_append_body(e_fail, fail_ret)
      # Unwrap block: extract the payload at args[0]. Becomes the
      # `last_val` of the EBang expression, so any consumer reads
      # the unwrapped value as a regular SSA register.
      let e_unwrap = llvm_open_block(e_fail_done, unwrap_lbl.reg)
      let payload = llvm_fresh_reg(e_unwrap)
      let payload_i = concat_all([
        "  ", payload.reg, " = call %KaiValue* @kaix_variant_arg(%KaiValue* ",
        inner_reg, ", i32 0)\n"
      ])
      llvm_set_last(llvm_append_body(payload.e, payload_i), payload.reg)
    }
  }
}

# Emit an `_kai_<name>_thunk` that unpacks args from a `KaiValue**`
# and forwards them to the user-defined `kai_<name>`. One per user
# fn so its address can be taken when the fn is passed as a value.
fn llvm_emit_thunk(nm: String, arity: Int) : String {
  let thunk_sym = concat_all(["@_kai_", nm, "_thunk"])
  let target_sym = concat_all(["@kai_", nm])
  let load_lines = llvm_thunk_loads(0, arity, "")
  let call_args = llvm_thunk_call_args(0, arity, "")
  concat_all([
    "\ndefine %KaiValue* ", thunk_sym, "(%KaiValue* %self, %KaiValue** %args, i32 %n) {\n",
    load_lines,
    "  %r = call %KaiValue* ", target_sym, "(", call_args, ")\n",
    "  ret %KaiValue* %r\n",
    "}\n"
  ])
}

fn llvm_thunk_loads(i: Int, arity: Int, acc: String) : String {
  if i >= arity { acc }
  else {
    let gep = concat_all([
      "  %ap", int_to_string(i), " = getelementptr inbounds %KaiValue*, %KaiValue** %args, i32 ", int_to_string(i), "\n"
    ])
    let ld = concat_all([
      "  %a", int_to_string(i), " = load %KaiValue*, %KaiValue** %ap", int_to_string(i), "\n"
    ])
    llvm_thunk_loads(i + 1, arity, concat_all([acc, gep, ld]))
  }
}

fn llvm_thunk_call_args(i: Int, arity: Int, acc: String) : String {
  if i >= arity { acc }
  else {
    let sep = if i == 0 { "" } else { ", " }
    let piece = concat_all([sep, "%KaiValue* %a", int_to_string(i)])
    llvm_thunk_call_args(i + 1, arity, string_concat(acc, piece))
  }
}

# Result of compiling one top-level decl: the textual IR plus the
# id-counter to hand to the next decl. SSA registers within a fn
# are isolated to that fn (LLVM scopes them), but globals live at
# module scope and must have unique names, so the counter threads
# through all decls.
type LlvmDeclOut = { text: String, next_id: Int }

fn llvm_emit_fn(d: Decl, fns: [EFn], vs: [EVar], lams: [LamInfo], oo: [OpOffset], start_id: Int) : LlvmDeclOut {
  match d {
    DFn(_, nm, _, ps, _, _, body, _, _) -> {
      let locals0 = llvm_init_locals_from_params(ps)
      let e0 = LlvmEmit { ids: LlvmIdGen { next: start_id },
                          globals: "", body: "",
                          last_val: "", cur_label: "entry",
                          locals: locals0, fns: fns, vars_: vs, lams: lams,
                          op_offsets: oo }
      let e1 = llvm_emit_expr(e0, body)
      let sym = if nm == "main" { "@kai_main" } else { string_concat("@kai_", nm) }
      let arity = list_length(ps)
      let thunk = llvm_emit_thunk(nm, arity)
      let text = concat_all([
        e1.globals,
        "\n",
        "define %KaiValue* ", sym, "(", llvm_param_list(ps), ") {\n",
        e1.body,
        "  ret %KaiValue* ", e1.last_val, "\n",
        "}\n",
        thunk
      ])
      LlvmDeclOut { text: text, next_id: e1.ids.next }
    }
    _ -> LlvmDeclOut { text: "", next_id: start_id }
  }
}

fn llvm_emit_decls_loop(ds: [Decl], fns: [EFn], vs: [EVar], lams: [LamInfo], oo: [OpOffset], start_id: Int, acc: String) : LlvmDeclOut {
  match ds {
    [] -> LlvmDeclOut { text: acc, next_id: start_id }
    [d, ...rest] -> {
      let out = llvm_emit_fn(d, fns, vs, lams, oo, start_id)
      llvm_emit_decls_loop(rest, fns, vs, lams, oo, out.next_id, string_concat(acc, out.text))
    }
  }
}

# Emit a single lambda body as a top-level fn. Each lambda lives in
# `lams` with its params + captured-variable names. The generated fn
# has thunk signature `(self, args, n)` — args[i] reads the i-th
# param, `kaix_capture(self, i)` reads the i-th captured local. The
# body is then emitted under an env that pushes both as named regs.
fn llvm_emit_lambda_body(l: LamInfo, fns: [EFn], vs: [EVar], lams: [LamInfo], oo: [OpOffset], start_id: Int) : LlvmDeclOut {
  match l {
    LamInfo(id, _, _, params, caps, body) -> {
      let e0 = LlvmEmit { ids: LlvmIdGen { next: start_id },
                          globals: "", body: "",
                          last_val: "", cur_label: "entry",
                          locals: [], fns: fns, vars_: vs, lams: lams,
                          op_offsets: oo }
      let e1 = llvm_emit_lambda_param_loads(e0, params, 0)
      let e2 = llvm_emit_lambda_capture_loads(e1, caps, 0)
      let e3 = llvm_emit_expr(e2, body)
      let sym = concat_all(["@_kai_lam_", int_to_string(id)])
      let text = concat_all([
        e3.globals,
        "\n",
        "define %KaiValue* ", sym, "(%KaiValue* %self, %KaiValue** %args, i32 %n) {\n",
        e3.body,
        "  ret %KaiValue* ", e3.last_val, "\n",
        "}\n"
      ])
      LlvmDeclOut { text: text, next_id: e3.ids.next }
    }
  }
}

fn llvm_emit_lambda_param_loads(e: LlvmEmit, params: [Param], i: Int) : LlvmEmit {
  match params {
    [] -> e
    [p, ...rest] -> {
      let gep = llvm_fresh_reg(e)
      let gep_i = concat_all([
        "  ", gep.reg, " = getelementptr inbounds %KaiValue*, %KaiValue** %args, i32 ",
        int_to_string(i), "\n"
      ])
      let e1 = llvm_append_body(gep.e, gep_i)
      let ld = llvm_fresh_reg(e1)
      let ld_i = concat_all([
        "  ", ld.reg, " = load %KaiValue*, %KaiValue** ", gep.reg, "\n"
      ])
      let e2 = llvm_append_body(ld.e, ld_i)
      let e3 = llvm_push_local(e2, p.pname, ld.reg)
      llvm_emit_lambda_param_loads(e3, rest, i + 1)
    }
  }
}

fn llvm_emit_lambda_capture_loads(e: LlvmEmit, caps: [String], i: Int) : LlvmEmit {
  match caps {
    [] -> e
    [c, ...rest] -> {
      let r = llvm_fresh_reg(e)
      let instr = concat_all([
        "  ", r.reg, " = call %KaiValue* @kaix_capture(%KaiValue* %self, i32 ",
        int_to_string(i), ")\n"
      ])
      let e1 = llvm_append_body(r.e, instr)
      let e2 = llvm_push_local(e1, c, r.reg)
      llvm_emit_lambda_capture_loads(e2, rest, i + 1)
    }
  }
}

fn llvm_emit_lambda_bodies(lams: [LamInfo], fns: [EFn], vs: [EVar], oo: [OpOffset], start_id: Int, acc: String) : String {
  match lams {
    [] -> acc
    [l, ...rest] -> {
      let out = llvm_emit_lambda_body(l, fns, vs, lams, oo, start_id)
      llvm_emit_lambda_bodies(rest, fns, vs, oo, out.next_id, string_concat(acc, out.text))
    }
  }
}

fn llvm_build_globals_names(fns: [EFn], vs: [EVar], eff_names: [String], op_quals: [String]) : [String] = build_globals(fns, vs, eff_names, op_quals)

fn emit_program_llvm(path: String, src: String, raw_decls: [Decl], test_mode: Bool) : String {
  let alias_resolved = rewrite_alias_decls(raw_decls)
  let decls = alias_resolved
  let fns = register_fn_decls(decls)
  let vs = register_variants(decls)
  let eff_names = collect_effect_names(decls)
  let op_quals = collect_op_qualified_names(decls)
  let globals = llvm_build_globals_names(fns, vs, eff_names, op_quals)
  let st0 = lc_new(globals)
  let lc = collect_decls(decls, st0)
  let lams = lc.lams
  # m7c-a: emit `%EvX` struct declarations for every effect in
  # the program (user-declared + the builtins inject_builtin_effects
  # adds based on main's row). The structs are referenced by the
  # m7c-b/c handle and op-call lowerings; emitting them here keeps
  # the LLVM IR self-contained without forward declarations.
  let eff_structs = llvm_effect_struct_decls(decls)
  # m7c-c: compute (Eff.op → field index) for every declared
  # effect; the dispatcher in `llvm_emit_call` consults this to
  # GEP the right function pointer in the matching `%EvX` struct.
  # First three fields are handler_id / env / state, so op N is at
  # field 3 + N (in declaration order).
  let oo = compute_op_offsets(decls)
  let decls_out = llvm_emit_decls_loop(decls, fns, vs, lams, oo, 0, "")
  let lam_bodies = llvm_emit_lambda_bodies(lams, fns, vs, oo, decls_out.next_id, "")
  # m7c-d: emit each handler clause as a top-level LLVM function;
  # the handle prologue stores function pointers to these into
  # the matching `%EvX` field.
  let clauses_info = lc.clauses
  let clauses_out = llvm_emit_clause_bodies(clauses_info, fns, vs, lams, oo,
                                              decls_out.next_id, "")
  # m7c-d: emit the install/teardown wrappers the LLVM runtime's
  # `int main` calls. They push/pop default-handler evidence
  # nodes for any builtin (Console / Fail / Stdin / Env / File /
  # Mutable) that appears in main's row. When main has no
  # builtins the functions are no-ops.
  let main_row = main_row_labels(decls)
  let install = llvm_emit_main_install_defaults(main_row)
  let teardown = llvm_emit_main_teardown_defaults(main_row)
  concat_all([llvm_header(), eff_structs, "\n",
              decls_out.text, lam_bodies, clauses_out.text,
              install, teardown])
}

# m7c-c: per-decl walker that flattens every effect's ops into a
# `[OpOffset]` table keyed on the dotted "Eff.op" name. Handles
# both user-declared effects and the builtins inject_builtin_effects
# adds based on main's row.
fn compute_op_offsets(decls: [Decl]) : [OpOffset] =
  compute_op_offsets_loop(decls, [])

fn compute_op_offsets_loop(decls: [Decl], acc: [OpOffset]) : [OpOffset] {
  match decls {
    [] -> acc
    [d, ...rest] -> {
      let acc1 = match d {
        DEffect(_, name, _, ops, _, _) -> compute_op_offsets_for_eff(name, ops, 0, acc)
        _ -> acc
      }
      compute_op_offsets_loop(rest, acc1)
    }
  }
}

fn compute_op_offsets_for_eff(eff: String, ops: [EffectOp], idx: Int, acc: [OpOffset]) : [OpOffset] {
  match ops {
    [] -> acc
    [op, ...rest] -> match op {
      EOp(op_name, _, _, _, _, _) -> {
        let key = string_concat(eff, string_concat(".", op_name))
        # Field offset = 3 leading fields + position in op list.
        let acc1 = list_append(acc, [OO(key, 3 + idx)])
        compute_op_offsets_for_eff(eff, rest, idx + 1, acc1)
      }
    }
  }
}

fn lookup_op_offset(table: [OpOffset], key: String) : Option[Int] {
  match table {
    [] -> None
    [h, ...rest] -> match h {
      OO(k, n) -> if k == key { Some(n) } else { lookup_op_offset(rest, key) }
    }
  }
}

# ====================================================================
# module resolution (M6.1 — simple concat semantics)
# ====================================================================
#
# First cut of the import system. `import a.b.c` maps to loading
# `<dir-of-current-file>/a/b/c.kai` and concatenating its decls into
# the program. No namespacing, no aliases, no selective imports (the
# parser accepts them but this pass treats them as plain imports).
# Topological order via post-order DFS: an import's decls land in
# the flat list *before* the decls of the file that imported it, so
# the rest of the pipeline (name resolution, HM, emit) sees a single
# linear decl stream.
#
# Cycles are handled by a visited-set: re-imports are skipped, not
# reported. A → B → A still works — the second visit to A is a
# no-op.

type ResolveState = { visited: [String], decls: [Decl] }

fn rs_has(rs: ResolveState, p: String) : Bool = list_has(rs.visited, p)

fn rs_mark(rs: ResolveState, p: String) : ResolveState =
  ResolveState { visited: [p, ...rs.visited], decls: rs.decls }

fn rs_append_decls(rs: ResolveState, ds: [Decl]) : ResolveState =
  ResolveState { visited: rs.visited, decls: list_append(rs.decls, ds) }

# Directory portion of a path. "a/b/c.kai" -> "a/b". If no slash,
# returns "." (current dir).
fn dir_of(path: String) : String {
  let i = last_slash(path, string_length(path) - 1)
  if i < 0 { "." }
  else { string_slice(path, 0, i) }
}

fn last_slash(s: String, i: Int) : Int {
  if i < 0 { -1 }
  else {
    match char_at(s, i) {
      Some(c) -> if c == '/' { i } else { last_slash(s, i - 1) }
      None -> -1
    }
  }
}

# Map a dotted module path to a filesystem path relative to base_dir.
# "a.b.c" + "stage2" -> "stage2/a/b/c.kai".
fn module_to_path(base_dir: String, mod: String) : String {
  let rel = string_concat(dots_to_slashes(mod), ".kai")
  if base_dir == "." { rel }
  else { concat_all([base_dir, "/", rel]) }
}

fn dots_to_slashes(s: String) : String = dots_to_slashes_loop(s, 0, string_length(s), "")

fn dots_to_slashes_loop(s: String, i: Int, n: Int, acc: String) : String {
  if i >= n { acc }
  else {
    match char_at(s, i) {
      Some(c) -> {
        let piece = if c == '.' { "/" } else { "#{c}" }
        dots_to_slashes_loop(s, i + 1, n, string_concat(acc, piece))
      }
      None -> acc
    }
  }
}

# Drop every DImport from a decl list; the pass is destructive
# because after resolution the imports carry no semantic weight —
# the imported decls are already inlined into the flat list.
fn non_import_decls(ds: [Decl]) : [Decl] {
  match ds {
    [] -> []
    [d, ...rest] -> match d {
      DImport(_, _, _) -> non_import_decls(rest)
      _ -> [d, ...non_import_decls(rest)]
    }
  }
}

# Dotted module paths (`math.arith`) are resolved in order:
#   1. relative to the root file's directory (`base_dir`), then
#   2. each directory given via `--path`, in the order passed.
# The first candidate that exists wins. If none do, the caller
# reports the original `base_dir` path so the error message points
# to the most obvious location.
type CandidateFile = CF(String, Option[String])
#                      path    source (if read succeeded)

fn try_candidate(abs_path: String) : Option[String] / File {
  match read_file(abs_path) {
    Err(_)  -> None
    Ok(src) -> Some(src)
  }
}

fn try_candidates_loop(mod_path: String, dirs: [String], first_tried: String) : CandidateFile {
  match dirs {
    [] -> CF(first_tried, None)
    [d, ...rest] -> {
      let p = module_to_path(d, mod_path)
      match try_candidate(p) {
        Some(src) -> CF(p, Some(src))
        None      -> try_candidates_loop(mod_path, rest, first_tried)
      }
    }
  }
}

fn find_module_file(base_dir: String, mod_path: String, search_paths: [String]) : CandidateFile {
  let first_try = module_to_path(base_dir, mod_path)
  match try_candidate(first_try) {
    Some(src) -> CF(first_try, Some(src))
    None      -> try_candidates_loop(mod_path, search_paths, first_try)
  }
}

fn resolve_module(base_dir: String, mod_path: String, search_paths: [String], rs: ResolveState) : ResolveState / Console {
  let cf = find_module_file(base_dir, mod_path, search_paths)
  match cf {
    CF(abs_path, opt_src) -> {
      if rs_has(rs, abs_path) { rs }
      else {
        let rs1 = rs_mark(rs, abs_path)
        match opt_src {
          None -> {
            eprint("kaic: cannot open module '#{mod_path}' (tried #{abs_path}): no such file")
            rs1
          }
          Some(src) -> {
            let tokens = tokenize(src)
            let lex_errs = report_errors(abs_path, src, tokens)
            if lex_errs != 0 { rs1 }
            else {
              let parsed = parse_program(abs_path, src, tokens)
              match parsed.decls {
                None -> rs1
                Some(decls) -> {
                  let rs2 = process_imports(base_dir, decls, search_paths, rs1)
                  rs_append_decls(rs2, non_import_decls(decls))
                }
              }
            }
          }
        }
      }
    }
  }
}

fn process_imports(base_dir: String, decls: [Decl], search_paths: [String], rs: ResolveState) : ResolveState {
  match decls {
    [] -> rs
    [d, ...rest] -> {
      let rs1 = match d {
        DImport(ik, _, _) -> match ik {
          IkPath(p)         -> resolve_module(base_dir, p, search_paths, rs)
          IkAlias(p, _)     -> resolve_module(base_dir, p, search_paths, rs)
          IkSelective(p, _) -> resolve_module(base_dir, p, search_paths, rs)
        }
        _ -> rs
      }
      process_imports(base_dir, rest, search_paths, rs1)
    }
  }
}

# Given a root file's path and its parsed decls, return the flat
# decl list with every (transitively-)imported module's decls
# prepended in topological order and with every DImport stripped.
fn expand_imports(root_path: String, search_paths: [String], root_decls: [Decl]) : [Decl] {
  let base_dir = dir_of(root_path)
  let rs0 = ResolveState { visited: [root_path], decls: [] }
  let rs1 = process_imports(base_dir, root_decls, search_paths, rs0)
  list_append(rs1.decls, non_import_decls(root_decls))
}

# ====================================================================
# m12.8 — single-dispatch protocols
# ====================================================================
#
# Pre-resolve desugar pass that
#  1. expands `#derive(P, ...) type T = ...` into the underlying
#     `type T = ...` plus one synthetic `impl P for T` per derived
#     protocol;
#  2. validates the orphan rule and the single-impl-per-pair rule
#     across the program;
#  3. lowers each `impl P for T { fn op(args) = body ... }` into one
#     ordinary top-level DFn per method, named
#     `__pimpl_<P>_<TypeMangled>_<op>` so subsequent passes treat it
#     as a normal generic function;
#  4. emits a stub *dispatcher* DFn for every protocol op the
#     program declares, so the typer can resolve `op(x, ...)` as a
#     polymorphic call (the dispatcher's body panics — the post-
#     inference rewriting pass eliminates every reachable call to it
#     before code generation runs);
#  5. drops every DProtocol / DImpl / DDerive node from the decl
#     stream so existing visitors (most of which use a `_ -> ...`
#     catch-all over Decl) never see the new variants.
#
# The (protocol, type) -> impl_fn_name table built here is threaded
# forward to `resolve_protocol_calls`, the post-inference pass that
# replaces every `op(x, ...)` call with a direct call to the
# matching impl function. Calls that no impl matches survive the
# rewrite and surface the dispatcher's runtime panic — this is the
# v1 fall-back; the spec calls for a compile-time error there, but
# wiring the diagnostic into the inferencer is m12.8.x work.
#
# Coherence is purely compile-time: orphan + duplicate-impl checks
# run here, and the dispatch is `O(1)` (linear scan over a flat list
# small enough to be `O(1)` in practice; m12.8.x will hash it if the
# program ever grows enough to justify the bookkeeping).

type ProtoOpReg = POR(String, String, [Param], TypeExpr, Int, Int)
#                     proto    op_name params  ret      line col

type ProtoImplReg = PIR(String, String, String, String)
#                       proto    type    op_name impl_fn_name

type ProtocolReg = { ops: [ProtoOpReg], impls: [ProtoImplReg], op_names: [String] }

fn proto_reg_empty() : ProtocolReg =
  ProtocolReg { ops: [], impls: [], op_names: [] }

# m12.8: the type-mangling used in the impl-fn name. Walks a
# TypeExpr, collapsing it down to the head TyName (so `Money[u]`,
# `Money[USD]`, and `Money` all map to `Money`). Lists collapse to
# `List`. This gives a single impl per type-constructor — polymorphic
# impls cover all instantiations, mirroring the spec's "monomorphises
# per concrete instantiation just like any generic function" note.
fn proto_type_name(te: TypeExpr) : String {
  match te.tkind {
    TyName(name, _) -> name
    TyList(_)       -> "List"
    TyFn(_, _, _)   -> "Fn"
    # m12.5: `Decimal<USD>` and friends collapse to the base
    # constructor (`Decimal`); the unit annotation is invisible to
    # protocol dispatch (which is single-dispatch on the head TyName,
    # exactly as the spec describes for `impl Show for Money[u: Unit]`).
    TyDim(base, _)  -> proto_type_name(base)
  }
}

fn proto_mangled_fn(proto: String, type_name: String, op: String) : String =
  concat_all(["__pimpl_", proto, "_", type_name, "_", op])

# m12.8: kaikai-side name for the *dispatcher* function the lower
# pass synthesises for each protocol op. Prefixing with `__proto_`
# keeps the emitted C symbol (`kai___proto_<op>`) clear of runtime
# helpers like `kai_eq`, `kai_to_string`, `kai_lt` etc. that share
# common short names with protocol ops.
fn proto_dispatcher_name(op: String) : String = concat_all(["__proto_", op])

# Register every DProtocol decl the program declares. The op list
# becomes the universe of "names that look like ordinary fn calls but
# really need protocol dispatch".
fn collect_proto_decls(ds: [Decl], reg: ProtocolReg) : ProtocolReg {
  match ds {
    [] -> reg
    [d, ...rest] -> match d {
      DProtocol(_, name, ops, _, _) ->
        collect_proto_decls(rest, register_proto_ops(reg, name, ops))
      DDerive(_, inner, _, _) -> collect_proto_decls([inner, ...rest], reg)
      _ -> collect_proto_decls(rest, reg)
    }
  }
}

fn register_proto_ops(reg: ProtocolReg, proto: String, ops: [ProtoOp]) : ProtocolReg {
  match ops {
    [] -> reg
    [op, ...rest] -> match op {
      POp(opname, _, params, ret, line, col) -> {
        let entry = POR(proto, opname, params, ret, line, col)
        let names1 =
          if list_has(reg.op_names, opname) { reg.op_names }
          else { [opname, ...reg.op_names] }
        let reg1 = ProtocolReg {
          ops: [entry, ...reg.ops],
          impls: reg.impls,
          op_names: names1
        }
        register_proto_ops(reg1, proto, rest)
      }
    }
  }
}

fn proto_op_lookup(reg: ProtocolReg, name: String) : Option[ProtoOpReg] {
  proto_op_lookup_loop(reg.ops, name)
}

fn proto_op_lookup_loop(ops: [ProtoOpReg], target: String) : Option[ProtoOpReg] {
  match ops {
    [] -> None
    [op, ...rest] -> match op {
      POR(_, name, _, _, _, _) ->
        if name == target { Some(op) } else { proto_op_lookup_loop(rest, target) }
    }
  }
}

# Collect every protocol the program declares. Used by the
# orphan-rule validation: an `impl P for T` is allowed only if `P` is
# declared in the same compilation unit (here: in `decls`) or `T` is.
fn collect_proto_names(ds: [Decl], acc: [String]) : [String] {
  match ds {
    [] -> acc
    [d, ...rest] -> match d {
      DProtocol(_, name, _, _, _) -> collect_proto_names(rest, [name, ...acc])
      DDerive(_, inner, _, _) -> collect_proto_names([inner, ...rest], acc)
      _ -> collect_proto_names(rest, acc)
    }
  }
}

fn collect_local_type_names(ds: [Decl], acc: [String]) : [String] {
  match ds {
    [] -> acc
    [d, ...rest] -> match d {
      DType(_, name, _, _, _, _) -> collect_local_type_names(rest, [name, ...acc])
      DDerive(_, inner, _, _) -> collect_local_type_names([inner, ...rest], acc)
      _ -> collect_local_type_names(rest, acc)
    }
  }
}

# Builtin-primitive type names — `Int`, `Real`, etc. — are treated
# as "always local" for the purpose of the orphan rule when they
# appear as the impl target. This matches the spec: stdlib ships
# the canonical impls for primitives, and user code can still write
# `impl Show for [a]` (target = list-of-tparam) without colliding.
fn proto_builtin_type_names() : [String] =
  ["Int", "Real", "Bool", "Char", "String", "Unit",
   "List", "Option", "Result"]

# Validate: the orphan rule (protocol or target type must be local)
# and single-impl-per-(P,T) coherence. Reports each violation on
# stderr and returns the count of reported errors.
fn validate_impls(ds: [Decl], file: String,
                  proto_names: [String], local_types: [String]) : Int {
  validate_impls_loop(ds, file, proto_names, local_types, [], 0)
}

fn validate_impls_loop(ds: [Decl], file: String,
                       proto_names: [String], local_types: [String],
                       seen: [String], errs: Int) : Int / Console {
  match ds {
    [] -> errs
    [d, ...rest] -> match d {
      DImpl(pname, target, _, line, col) -> {
        let tname = proto_type_name(target)
        let key = concat_all([pname, "/", tname])
        let proto_local = list_has(proto_names, pname)
        let type_local = list_has(local_types, tname) or
                         list_has(proto_builtin_type_names(), tname)
        let errs1 =
          if not proto_local and not type_local {
            eprint(concat_all([
              file, ":", int_to_string(line), ":", int_to_string(col),
              ": error: orphan rule: `impl ", pname, " for ", tname,
              "` requires either the protocol or the target type to be declared in this compilation unit"]))
            errs + 1
          } else { errs }
        let errs2 =
          if list_has(seen, key) {
            eprint(concat_all([
              file, ":", int_to_string(line), ":", int_to_string(col),
              ": error: duplicate impl: `impl ", pname, " for ", tname,
              "` already exists in this compilation unit"]))
            errs1 + 1
          } else { errs1 }
        let proto_ok =
          if list_has(proto_names, pname) { true }
          else {
            eprint(concat_all([
              file, ":", int_to_string(line), ":", int_to_string(col),
              ": error: unknown protocol `", pname, "` in `impl`"]))
            false
          }
        let errs3 = if proto_ok { errs2 } else { errs2 + 1 }
        let seen1 = if list_has(seen, key) { seen } else { [key, ...seen] }
        validate_impls_loop(rest, file, proto_names, local_types, seen1, errs3)
      }
      DDerive(_, inner, _, _) ->
        validate_impls_loop([inner, ...rest], file, proto_names, local_types, seen, errs)
      _ -> validate_impls_loop(rest, file, proto_names, local_types, seen, errs)
    }
  }
}

# Walk every DImpl and (a) lower its methods into top-level DFns,
# (b) record (P, T) -> impl_fn_name in the registry. The fn body is
# the impl's original body verbatim; we only rename the function and
# leave the typer to do its work on the result.
fn lower_impls(ds: [Decl], reg: ProtocolReg, acc_fns: [Decl]) : LowerImplsRes {
  match ds {
    [] -> LowerImplsRes { reg: reg, fns: list_reverse(acc_fns) }
    [d, ...rest] -> match d {
      DImpl(pname, target, methods, _, _) -> {
        let tname = proto_type_name(target)
        let r = lower_impl_methods(pname, tname, methods, reg, acc_fns)
        lower_impls(rest, r.reg, r.fns)
      }
      DDerive(_, inner, _, _) -> lower_impls([inner, ...rest], reg, acc_fns)
      _ -> lower_impls(rest, reg, acc_fns)
    }
  }
}

type LowerImplsRes = { reg: ProtocolReg, fns: [Decl] }

# `acc_fns` accumulates in reverse; the caller list_reverses on
# return.
fn lower_impl_methods(pname: String, tname: String, methods: [Decl],
                      reg: ProtocolReg, acc_fns: [Decl]) : LowerImplsRes {
  match methods {
    [] -> LowerImplsRes { reg: reg, fns: acc_fns }
    [d, ...rest] -> match d {
      DFn(_, op_name, tparams, params, ret, row, body, line, col) -> {
        let mangled = proto_mangled_fn(pname, tname, op_name)
        let new_fn = DFn(false, mangled, tparams, params, ret, row, body, line, col)
        let entry = PIR(pname, tname, op_name, mangled)
        let reg1 = ProtocolReg {
          ops: reg.ops,
          impls: [entry, ...reg.impls],
          op_names: reg.op_names
        }
        lower_impl_methods(pname, tname, rest, reg1, [new_fn, ...acc_fns])
      }
      _ -> lower_impl_methods(pname, tname, rest, reg, acc_fns)
    }
  }
}

# Generate one stub-dispatcher DFn per protocol op so the resolver
# and typer can treat `op(x, ...)` as a regular polymorphic call.
# The body panics; the post-inference rewrite redirects every reach-
# able call to the matching `__pimpl_*` function.
fn generate_dispatchers(reg: ProtocolReg) : [Decl] =
  generate_dispatchers_loop(reg.ops, [])

fn generate_dispatchers_loop(ops: [ProtoOpReg], acc: [Decl]) : [Decl] {
  match ops {
    [] -> acc
    [op, ...rest] -> match op {
      POR(pname, opname, params, ret, line, col) -> {
        let already = dispatcher_in_acc(acc, opname)
        if already { generate_dispatchers_loop(rest, acc) }
        else {
          let stub = make_dispatcher_fn(pname, opname, params, ret, line, col)
          generate_dispatchers_loop(rest, [stub, ...acc])
        }
      }
    }
  }
}

fn dispatcher_in_acc(ds: [Decl], target: String) : Bool {
  let want = proto_dispatcher_name(target)
  match ds {
    [] -> false
    [d, ...rest] -> match d {
      DFn(_, n, _, _, _, _, _, _, _) ->
        if n == want { true } else { dispatcher_in_acc(rest, target) }
      _ -> dispatcher_in_acc(rest, target)
    }
  }
}

fn make_dispatcher_fn(pname: String, opname: String, params: [Param],
                       ret: TypeExpr, line: Int, col: Int) : Decl {
  let new_params = map(params, dispatcher_substitute_self_param)
  let new_ret = substitute_self_in_type(ret)
  let body = make_dispatcher_body(pname, opname, new_ret, line, col)
  DFn(true, proto_dispatcher_name(opname), [], new_params, Some(new_ret),
      REmpty, body, line, col)
}

# Synthesises a body that *typechecks* with the declared return type
# without invoking any prelude function (so the dispatcher does not
# pull `panic` into its row). The post-inference rewrite replaces
# every reachable call to this dispatcher; only protocols with no
# matching impl reach this body, in which case execution panics via
# the placeholder value the typer accepts but the runtime treats as
# unsound use.
fn make_dispatcher_body(pname: String, opname: String, ret: TypeExpr,
                          line: Int, col: Int) : Expr {
  let label = concat_all(["__protocol_dispatch_", pname, "_", opname])
  let arg = mk_expr(EStr(concat_all(["\"", label, "\""]), false), line, col)
  mk_expr(ECall(mk_expr(EVar("panic"), line, col), [arg]), line, col)
}

fn dispatcher_substitute_self_param(p: Param) : Param {
  match p.ptype {
    None -> p
    Some(te) -> Param { pname: p.pname, ptype: Some(substitute_self_in_type(te)),
                         pline: p.pline, pcol: p.pcol }
  }
}

fn substitute_self_in_type(te: TypeExpr) : TypeExpr {
  TypeExpr {
    tkind: substitute_self_in_kind(te.tkind),
    line: te.line, col: te.col
  }
}

fn substitute_self_in_kind(k: TyKind) : TyKind {
  match k {
    # `targs` (not `args`) — `args` is a prelude function name and the
    # stage-1 resolver does not let the pattern binding shadow the
    # prelude reference inside the body.
    TyName(name, targs) -> {
      let new_name = if name == "Self" { "proto_self" } else { name }
      TyName(new_name, map(targs, substitute_self_in_type))
    }
    TyList(inner) -> TyList(substitute_self_in_type(inner))
    TyFn(ps, ret, row) ->
      TyFn(map(ps, substitute_self_in_type), substitute_self_in_type(ret), row)
    # m12.5: substitute under the dimensioned base; the unit
    # expression is leaf data with no `Self` reference (units come
    # from the global unit table, not from the protocol's tparam).
    TyDim(base, u) -> TyDim(substitute_self_in_type(base), u)
  }
}

# m12.8.x: validate that, before expansion, every `#derive(P)` on a
# sum type can be discharged: each variant field's head type must
# already have a registered impl of `P` reachable from this
# compilation unit (an explicit `impl P for T`, another `#derive(P)`
# on `T`, or a builtin from `derive_builtin_impl`). Records keep the
# pre-existing v1 behaviour (synthesise the impl, fall through to
# the runtime panic if an inner field has no impl).
fn validate_derives(ds: [Decl], file: String) : Int {
  let future_impls = collect_future_impl_keys(ds, [])
  validate_derives_loop(ds, file, future_impls, 0)
}

fn collect_future_impl_keys(ds: [Decl], acc: [String]) : [String] {
  match ds {
    [] -> acc
    [d, ...rest] -> match d {
      DImpl(pname, target, _, _, _) ->
        collect_future_impl_keys(rest,
          [concat_all([pname, "/", proto_type_name(target)]), ...acc])
      DDerive(names, inner, _, _) -> {
        let acc1 = match inner {
          DType(_, tname, _, _, _, _) -> add_future_impl_keys(names, tname, acc)
          _ -> acc
        }
        collect_future_impl_keys(rest, acc1)
      }
      _ -> collect_future_impl_keys(rest, acc)
    }
  }
}

fn add_future_impl_keys(names: [String], tname: String, acc: [String]) : [String] {
  match names {
    [] -> acc
    [n, ...rest] ->
      add_future_impl_keys(rest, tname, [concat_all([n, "/", tname]), ...acc])
  }
}

# Builtin impls bundled with kaikai for primitive types, kept in
# sync with stdlib/protocols.kai. The validator treats these as
# always available so users do not have to redeclare `impl Eq for
# Int` in every fixture that derives Eq on a sum carrying Ints.
fn derive_builtin_impl(pname: String, tname: String) : Bool {
  if pname == "Eq" {
    list_has(["Int", "Real", "Bool", "String", "Char", "Unit"], tname)
  } else if pname == "Hash" {
    list_has(["Int", "String", "Bool", "Char"], tname)
  } else if pname == "Show" {
    list_has(["Int", "Real", "Bool", "String", "Unit", "Char"], tname)
  } else { false }
}

fn validate_derives_loop(ds: [Decl], file: String,
                          future_impls: [String], errs: Int) : Int {
  match ds {
    [] -> errs
    [d, ...rest] -> match d {
      DDerive(names, inner, line, col) -> {
        let errs1 = validate_derive_decl(names, inner, file, future_impls,
                                          line, col, errs)
        validate_derives_loop(rest, file, future_impls, errs1)
      }
      _ -> validate_derives_loop(rest, file, future_impls, errs)
    }
  }
}

fn validate_derive_decl(names: [String], inner: Decl, file: String,
                         future_impls: [String], dline: Int, dcol: Int,
                         errs: Int) : Int {
  match inner {
    DType(_, tname, _, body, _, _) -> match body {
      TBSum(variants) -> validate_derive_sum_protos(names, tname, variants,
                                                     file, future_impls,
                                                     dline, dcol, errs)
      _ -> errs
    }
    _ -> errs
  }
}

fn validate_derive_sum_protos(names: [String], tname: String, variants: [Variant],
                                file: String, future_impls: [String],
                                line: Int, col: Int, errs: Int) : Int {
  match names {
    [] -> errs
    [pname, ...rest] -> {
      let errs1 =
        if pname == "Eq" or pname == "Hash" {
          validate_derive_sum_variants(pname, tname, variants, file,
                                        future_impls, line, col, errs)
        } else { errs }
      validate_derive_sum_protos(rest, tname, variants, file, future_impls,
                                  line, col, errs1)
    }
  }
}

fn validate_derive_sum_variants(pname: String, tname: String, vs: [Variant],
                                 file: String, future_impls: [String],
                                 line: Int, col: Int, errs: Int) : Int {
  match vs {
    [] -> errs
    [v, ...rest] -> match v {
      Var(vname, vargs) -> {
        let errs1 = validate_derive_variant_args(pname, tname, vname, vargs,
                                                  0, file, future_impls,
                                                  line, col, errs)
        validate_derive_sum_variants(pname, tname, rest, file, future_impls,
                                      line, col, errs1)
      }
    }
  }
}

fn validate_derive_variant_args(pname: String, tname: String, vname: String,
                                 vargs: [TypeExpr], i: Int, file: String,
                                 future_impls: [String], line: Int, col: Int,
                                 errs: Int) : Int / Console {
  match vargs {
    [] -> errs
    [te, ...rest] -> {
      let head = proto_type_name(te)
      let key = concat_all([pname, "/", head])
      let ok = list_has(future_impls, key) or derive_builtin_impl(pname, head)
      let errs1 =
        if ok { errs }
        else {
          eprint(concat_all([
            file, ":", int_to_string(line), ":", int_to_string(col),
            ": error: cannot derive `", pname, "` for `", tname,
            "`: variant `", vname, "` field #", int_to_string(i),
            " has type `", head,
            "` which has no `impl ", pname, " for ", head,
            "` in this compilation unit"]))
          errs + 1
        }
      validate_derive_variant_args(pname, tname, vname, rest, i + 1, file,
                                    future_impls, line, col, errs1)
    }
  }
}

# Phase 1: expand each `DDerive(names, type_decl)` into its wrapped
# DType followed by one synthetic DImpl per derived protocol.
# DProtocol and ordinary DImpl decls pass through unchanged so the
# next pass can collect them.
fn expand_derives(ds: [Decl]) : [Decl] = expand_derives_loop(ds, [])

fn expand_derives_loop(ds: [Decl], acc: [Decl]) : [Decl] {
  match ds {
    [] -> list_reverse(acc)
    [d, ...rest] -> match d {
      DDerive(names, inner, _, _) -> {
        let derived = derive_impls_for(names, inner)
        expand_derives_loop(rest, list_append([inner, ...list_reverse(derived)], acc))
      }
      _ -> expand_derives_loop(rest, [d, ...acc])
    }
  }
}

# Phase 2: drop every DProtocol / DImpl from the decl stream after
# the impl-lowering pass has copied their content into ordinary
# DFns. DDerive nodes have already been replaced by `expand_derives`.
fn strip_protocols(ds: [Decl]) : [Decl] = strip_protocols_loop(ds, [])

fn strip_protocols_loop(ds: [Decl], acc: [Decl]) : [Decl] {
  match ds {
    [] -> list_reverse(acc)
    [d, ...rest] -> match d {
      DProtocol(_, _, _, _, _) -> strip_protocols_loop(rest, acc)
      DImpl(_, _, _, _, _)     -> strip_protocols_loop(rest, acc)
      DDerive(_, _, _, _)      -> strip_protocols_loop(rest, acc)
      _ -> strip_protocols_loop(rest, [d, ...acc])
    }
  }
}

# Generate structural impls for #derive(P, ...) on the wrapped
# DType. Walks the type body and synthesises one DImpl per derived
# protocol. Records produce field-by-field ops; sum types produce
# variant-by-variant match arms. Each synthesised impl body invokes
# the protocol's own ops on the inner fields, so the fields' types
# must already implement the same protocol — checked transitively
# by the typer / resolver after lowering.
fn derive_impls_for(names: [String], dt: Decl) : [Decl] {
  match dt {
    DType(_, tname, _, body, line, col) ->
      derive_impls_loop(names, tname, body, line, col, [])
    _ -> []
  }
}

fn derive_impls_loop(names: [String], tname: String, body: TypeBody,
                      line: Int, col: Int, acc: [Decl]) : [Decl] {
  match names {
    [] -> list_reverse(acc)
    [pname, ...rest] -> match derive_impl_for_protocol(pname, tname, body, line, col) {
      Some(d) -> derive_impls_loop(rest, tname, body, line, col, [d, ...acc])
      None    -> derive_impls_loop(rest, tname, body, line, col, acc)
    }
  }
}

# Synthesise an `impl P for T` for one of the supported derive
# protocols. v1 supports `Show` and `Eq` on records; `Show` on sum
# types. Other (P, body) combinations return None and surface as
# "no impl" at typer time.
fn derive_impl_for_protocol(pname: String, tname: String, body: TypeBody,
                             line: Int, col: Int) : Option[Decl] {
  if pname == "Show" {
    derive_show_impl(tname, body, line, col)
  } else if pname == "Eq" {
    derive_eq_impl(tname, body, line, col)
  } else if pname == "Hash" {
    derive_hash_impl(tname, body, line, col)
  } else if pname == "Ord" {
    derive_ord_impl(tname, body, line, col)
  } else {
    None
  }
}

fn derive_show_impl(tname: String, body: TypeBody, line: Int, col: Int) : Option[Decl] {
  match body {
    TBRecord(fields) -> {
      let body_expr = derive_show_record_body(tname, fields, line, col)
      Some(make_derived_impl("Show", tname, "show",
        [Param { pname: "x", ptype: Some(mk_ty(TyName(tname, []), line, col)),
                 pline: line, pcol: col }],
        mk_ty(TyName("String", []), line, col),
        body_expr, line, col))
    }
    TBSum(variants) -> {
      let body_expr = derive_show_sum_body(variants, line, col)
      Some(make_derived_impl("Show", tname, "show",
        [Param { pname: "x", ptype: Some(mk_ty(TyName(tname, []), line, col)),
                 pline: line, pcol: col }],
        mk_ty(TyName("String", []), line, col),
        body_expr, line, col))
    }
    _ -> None
  }
}

fn derive_show_record_body(tname: String, fields: [FieldDecl], line: Int, col: Int) : Expr {
  let parts = derive_show_record_parts(tname, fields, line, col)
  mk_expr(ECall(mk_expr(EVar("string_concat_all"), line, col),
                [mk_expr(EList(map(parts, (e: Expr) => ElPlain(e))), line, col)]),
          line, col)
}

fn derive_show_record_parts(tname: String, fields: [FieldDecl], line: Int, col: Int) : [Expr] {
  let head = mk_expr(EStr(concat_all(["\"", tname, " { \""]), false), line, col)
  let body_parts = derive_show_field_parts(fields, line, col, true)
  let tail = mk_expr(EStr("\" }\"", false), line, col)
  list_append([head, ...body_parts], [tail])
}

fn derive_show_field_parts(fields: [FieldDecl], line: Int, col: Int, first: Bool) : [Expr] {
  match fields {
    [] -> []
    [fd, ...rest] -> match fd {
      FD(name, _) -> {
        let prefix_s = if first { concat_all(["\"", name, ": \""]) }
                       else { concat_all(["\", ", name, ": \""]) }
        let prefix = mk_expr(EStr(prefix_s, false), line, col)
        let access = mk_expr(EField(mk_expr(EVar("x"), line, col), name), line, col)
        let call = mk_expr(ECall(mk_expr(EVar("show"), line, col), [access]), line, col)
        list_append([prefix, call], derive_show_field_parts(rest, line, col, false))
      }
    }
  }
}

fn derive_show_sum_body(variants: [Variant], line: Int, col: Int) : Expr {
  let scrut = mk_expr(EVar("x"), line, col)
  let arms = map(variants, (v) => derive_show_sum_arm(v, line, col))
  mk_expr(EMatch(scrut, arms), line, col)
}

fn derive_show_sum_arm(v: Variant, line: Int, col: Int) : Arm {
  match v {
    Var(name, vargs) -> {
      let pat_subs = derive_sum_pat_subs(vargs, 0, line, col)
      let pat = mk_pat(PVariant(name, pat_subs), line, col)
      let body = derive_show_sum_arm_body(name, vargs, line, col)
      Arm(pat, None, body)
    }
  }
}

fn derive_sum_pat_subs(vargs: [TypeExpr], i: Int, line: Int, col: Int) : [Pattern] {
  match vargs {
    [] -> []
    [_, ...rest] ->
      [mk_pat(PBind(concat_all(["a", int_to_string(i)])), line, col),
       ...derive_sum_pat_subs(rest, i + 1, line, col)]
  }
}

fn derive_show_sum_arm_body(name: String, vargs: [TypeExpr], line: Int, col: Int) : Expr {
  match vargs {
    [] -> mk_expr(EStr(concat_all(["\"", name, "\""]), false), line, col)
    _  -> {
      let head = mk_expr(EStr(concat_all(["\"", name, "(\""]), false), line, col)
      let tail = mk_expr(EStr("\")\"", false), line, col)
      let calls = derive_sum_arg_show_calls(vargs, 0, line, col, true)
      let parts = list_append([head, ...calls], [tail])
      mk_expr(ECall(mk_expr(EVar("string_concat_all"), line, col),
                    [mk_expr(EList(map(parts, (e: Expr) => ElPlain(e))), line, col)]),
              line, col)
    }
  }
}

fn derive_sum_arg_show_calls(vargs: [TypeExpr], i: Int, line: Int, col: Int, first: Bool) : [Expr] {
  match vargs {
    [] -> []
    [_, ...rest] -> {
      let prefix = if first { mk_expr(EStr("\"\"", false), line, col) }
                   else { mk_expr(EStr("\", \"", false), line, col) }
      let av = mk_expr(EVar(concat_all(["a", int_to_string(i)])), line, col)
      let call = mk_expr(ECall(mk_expr(EVar("show"), line, col), [av]), line, col)
      list_append([prefix, call], derive_sum_arg_show_calls(rest, i + 1, line, col, false))
    }
  }
}

fn derive_eq_impl(tname: String, body: TypeBody, line: Int, col: Int) : Option[Decl] {
  match body {
    TBRecord(fields) -> {
      let body_expr = derive_eq_record_body(fields, line, col)
      Some(make_derived_impl("Eq", tname, "eq",
        [Param { pname: "a", ptype: Some(mk_ty(TyName(tname, []), line, col)),
                 pline: line, pcol: col },
         Param { pname: "b", ptype: Some(mk_ty(TyName(tname, []), line, col)),
                 pline: line, pcol: col }],
        mk_ty(TyName("Bool", []), line, col),
        body_expr, line, col))
    }
    TBSum(variants) -> {
      let body_expr = derive_eq_sum_body(variants, line, col)
      Some(make_derived_impl("Eq", tname, "eq",
        [Param { pname: "a", ptype: Some(mk_ty(TyName(tname, []), line, col)),
                 pline: line, pcol: col },
         Param { pname: "b", ptype: Some(mk_ty(TyName(tname, []), line, col)),
                 pline: line, pcol: col }],
        mk_ty(TyName("Bool", []), line, col),
        body_expr, line, col))
    }
    _ -> None
  }
}

fn derive_eq_record_body(fields: [FieldDecl], line: Int, col: Int) : Expr {
  match fields {
    [] -> mk_expr(EBool(true), line, col)
    [fd, ...rest] -> derive_eq_record_chain(fd, rest, line, col)
  }
}

fn derive_eq_record_chain(head: FieldDecl, rest: [FieldDecl], line: Int, col: Int) : Expr {
  match head {
    FD(name, _) -> {
      let l_access = mk_expr(EField(mk_expr(EVar("a"), line, col), name), line, col)
      let r_access = mk_expr(EField(mk_expr(EVar("b"), line, col), name), line, col)
      let call = mk_expr(ECall(mk_expr(EVar("eq"), line, col), [l_access, r_access]),
                         line, col)
      match rest {
        [] -> call
        [next, ...more] -> {
          let tail_e = derive_eq_record_chain(next, more, line, col)
          mk_expr(EBinop("and", call, tail_e), line, col)
        }
      }
    }
  }
}

# m12.8.x: `#derive(Eq)` on a sum type. Outer-match on `a`, one arm
# per variant; each arm rematches `b` for the same variant
# (returning `eq(la_0, lb_0) and eq(la_1, lb_1) and ...`) with a
# wildcard arm returning `false`. Empty sums (no variants) are
# defensive; the parser does not produce them today.
fn derive_eq_sum_body(variants: [Variant], line: Int, col: Int) : Expr {
  match variants {
    [] -> mk_expr(EBool(false), line, col)
    _  -> {
      let scrut = mk_expr(EVar("a"), line, col)
      let arms = map(variants, (v) => derive_eq_sum_outer_arm(v, line, col))
      mk_expr(EMatch(scrut, arms), line, col)
    }
  }
}

fn derive_eq_sum_outer_arm(v: Variant, line: Int, col: Int) : Arm {
  match v {
    Var(name, vargs) -> {
      let pat_subs = derive_eq_sum_pat_subs("la_", vargs, 0, line, col)
      let pat = mk_pat(PVariant(name, pat_subs), line, col)
      let inner = derive_eq_sum_inner_match(name, vargs, line, col)
      Arm(pat, None, inner)
    }
  }
}

fn derive_eq_sum_inner_match(name: String, vargs: [TypeExpr], line: Int, col: Int) : Expr {
  let scrut = mk_expr(EVar("b"), line, col)
  let pat_subs = derive_eq_sum_pat_subs("lb_", vargs, 0, line, col)
  let match_pat = mk_pat(PVariant(name, pat_subs), line, col)
  let body = derive_eq_sum_field_chain(vargs, 0, line, col)
  let arm_match = Arm(match_pat, None, body)
  let arm_wild  = Arm(mk_pat(PWild, line, col), None,
                      mk_expr(EBool(false), line, col))
  mk_expr(EMatch(scrut, [arm_match, arm_wild]), line, col)
}

fn derive_eq_sum_pat_subs(prefix: String, vargs: [TypeExpr], i: Int,
                           line: Int, col: Int) : [Pattern] {
  match vargs {
    [] -> []
    [_, ...rest] ->
      [mk_pat(PBind(concat_all([prefix, int_to_string(i)])), line, col),
       ...derive_eq_sum_pat_subs(prefix, rest, i + 1, line, col)]
  }
}

fn derive_eq_sum_field_chain(vargs: [TypeExpr], i: Int, line: Int, col: Int) : Expr {
  match vargs {
    [] -> mk_expr(EBool(true), line, col)
    [_, ...rest] -> {
      let l = mk_expr(EVar(concat_all(["la_", int_to_string(i)])), line, col)
      let r = mk_expr(EVar(concat_all(["lb_", int_to_string(i)])), line, col)
      let call = mk_expr(ECall(mk_expr(EVar("eq"), line, col), [l, r]), line, col)
      match rest {
        [] -> call
        _  -> {
          let tail = derive_eq_sum_field_chain(rest, i + 1, line, col)
          mk_expr(EBinop("and", call, tail), line, col)
        }
      }
    }
  }
}

fn derive_hash_impl(tname: String, body: TypeBody, line: Int, col: Int) : Option[Decl] {
  match body {
    TBRecord(fields) -> {
      let body_expr = derive_hash_record_body(fields, line, col)
      Some(make_derived_impl("Hash", tname, "hash",
        [Param { pname: "x", ptype: Some(mk_ty(TyName(tname, []), line, col)),
                 pline: line, pcol: col }],
        mk_ty(TyName("Int", []), line, col),
        body_expr, line, col))
    }
    TBSum(variants) -> {
      let body_expr = derive_hash_sum_body(variants, line, col)
      Some(make_derived_impl("Hash", tname, "hash",
        [Param { pname: "x", ptype: Some(mk_ty(TyName(tname, []), line, col)),
                 pline: line, pcol: col }],
        mk_ty(TyName("Int", []), line, col),
        body_expr, line, col))
    }
    _ -> None
  }
}

fn derive_hash_record_body(fields: [FieldDecl], line: Int, col: Int) : Expr {
  match fields {
    [] -> mk_expr(EInt(0), line, col)
    [fd, ...rest] -> derive_hash_record_chain(fd, rest, line, col)
  }
}

fn derive_hash_record_chain(head: FieldDecl, rest: [FieldDecl], line: Int, col: Int) : Expr {
  match head {
    FD(name, _) -> {
      let access = mk_expr(EField(mk_expr(EVar("x"), line, col), name), line, col)
      let call = mk_expr(ECall(mk_expr(EVar("hash"), line, col), [access]), line, col)
      match rest {
        [] -> call
        [next, ...more] -> {
          let tail_e = derive_hash_record_chain(next, more, line, col)
          let mul = mk_expr(EBinop("*", call, mk_expr(EInt(31), line, col)), line, col)
          mk_expr(EBinop("+", mul, tail_e), line, col)
        }
      }
    }
  }
}

# m12.8.x: `#derive(Hash)` on a sum type. Match on the value, one arm
# per variant; each arm seeds the running accumulator with the
# variant's 1-based tag and folds in `hash(field)` using the same
# `acc * 31 + h` combination the record helper uses, so two values
# that are eq via the derived Eq hash to the same Int.
fn derive_hash_sum_body(variants: [Variant], line: Int, col: Int) : Expr {
  match variants {
    [] -> mk_expr(EInt(0), line, col)
    _  -> {
      let scrut = mk_expr(EVar("x"), line, col)
      let arms = derive_hash_sum_arms(variants, 1, line, col)
      mk_expr(EMatch(scrut, arms), line, col)
    }
  }
}

fn derive_hash_sum_arms(vs: [Variant], tag: Int, line: Int, col: Int) : [Arm] {
  match vs {
    [] -> []
    [v, ...rest] ->
      [derive_hash_sum_arm(v, tag, line, col),
       ...derive_hash_sum_arms(rest, tag + 1, line, col)]
  }
}

fn derive_hash_sum_arm(v: Variant, tag: Int, line: Int, col: Int) : Arm {
  match v {
    Var(name, vargs) -> {
      let pat_subs = derive_eq_sum_pat_subs("h_", vargs, 0, line, col)
      let pat = mk_pat(PVariant(name, pat_subs), line, col)
      let body = derive_hash_sum_arm_body(vargs, tag, line, col)
      Arm(pat, None, body)
    }
  }
}

fn derive_hash_sum_arm_body(vargs: [TypeExpr], tag: Int, line: Int, col: Int) : Expr {
  let head = mk_expr(EInt(tag), line, col)
  derive_hash_sum_chain(head, vargs, 0, line, col)
}

fn derive_hash_sum_chain(acc: Expr, vargs: [TypeExpr], i: Int,
                          line: Int, col: Int) : Expr {
  match vargs {
    [] -> acc
    [_, ...rest] -> {
      let v = mk_expr(EVar(concat_all(["h_", int_to_string(i)])), line, col)
      let h = mk_expr(ECall(mk_expr(EVar("hash"), line, col), [v]), line, col)
      let mul = mk_expr(EBinop("*", acc, mk_expr(EInt(31), line, col)), line, col)
      let next = mk_expr(EBinop("+", mul, h), line, col)
      derive_hash_sum_chain(next, rest, i + 1, line, col)
    }
  }
}

# m12.8.z: `#derive(Ord)` synthesises a lexicographic `cmp` for records
# (compare field-by-field in declaration order, return on the first
# non-zero result) and a position-then-payload `cmp` for sum types
# (variants ordered by their position in the declaration; for the
# same variant, payloads compared lexicographically). Either form
# delegates to `cmp` on the field / payload type, so the typer
# rejects the derive transitively if any sub-component lacks an
# `Ord` impl — naming the missing call site in the diagnostic.
fn derive_ord_impl(tname: String, body: TypeBody, line: Int, col: Int) : Option[Decl] {
  match body {
    TBRecord(fields) -> {
      let body_expr = derive_ord_record_body(fields, line, col)
      Some(make_derived_impl("Ord", tname, "cmp",
        [Param { pname: "a", ptype: Some(mk_ty(TyName(tname, []), line, col)),
                 pline: line, pcol: col },
         Param { pname: "b", ptype: Some(mk_ty(TyName(tname, []), line, col)),
                 pline: line, pcol: col }],
        mk_ty(TyName("Int", []), line, col),
        body_expr, line, col))
    }
    TBSum(variants) -> {
      let body_expr = derive_ord_sum_body(variants, line, col)
      Some(make_derived_impl("Ord", tname, "cmp",
        [Param { pname: "a", ptype: Some(mk_ty(TyName(tname, []), line, col)),
                 pline: line, pcol: col },
         Param { pname: "b", ptype: Some(mk_ty(TyName(tname, []), line, col)),
                 pline: line, pcol: col }],
        mk_ty(TyName("Int", []), line, col),
        body_expr, line, col))
    }
    _ -> None
  }
}

fn derive_ord_record_body(fields: [FieldDecl], line: Int, col: Int) : Expr {
  match fields {
    [] -> mk_expr(EInt(0), line, col)
    [fd, ...rest] -> derive_ord_record_chain(fd, rest, 0, line, col)
  }
}

fn derive_ord_record_chain(head: FieldDecl, rest: [FieldDecl], idx: Int,
                            line: Int, col: Int) : Expr {
  match head {
    FD(name, _) -> {
      let l_access = mk_expr(EField(mk_expr(EVar("a"), line, col), name), line, col)
      let r_access = mk_expr(EField(mk_expr(EVar("b"), line, col), name), line, col)
      let cmp_call = mk_expr(ECall(mk_expr(EVar("cmp"), line, col),
                                    [l_access, r_access]),
                             line, col)
      match rest {
        [] -> cmp_call
        [next, ...more] -> {
          let cvar = concat_all(["c", int_to_string(idx)])
          let pat = mk_pat(PBind(cvar), line, col)
          let let_stmt = SLet(pat, None, cmp_call)
          let cond = mk_expr(EBinop("!=", mk_expr(EVar(cvar), line, col),
                                          mk_expr(EInt(0), line, col)),
                             line, col)
          let then_e = mk_expr(EVar(cvar), line, col)
          let else_e = derive_ord_record_chain(next, more, idx + 1, line, col)
          let if_e = mk_expr(EIf(cond, then_e, Some(else_e)), line, col)
          mk_expr(EBlock([let_stmt], Some(if_e)), line, col)
        }
      }
    }
  }
}

fn derive_ord_sum_body(variants: [Variant], line: Int, col: Int) : Expr {
  let scrut = mk_expr(EVar("a"), line, col)
  let arms = derive_ord_sum_outer_arms(variants, variants, 0, line, col)
  mk_expr(EMatch(scrut, arms), line, col)
}

fn derive_ord_sum_outer_arms(remaining: [Variant], all_variants: [Variant],
                              idx: Int, line: Int, col: Int) : [Arm] {
  match remaining {
    [] -> []
    [v, ...rest] -> {
      let arm = derive_ord_sum_outer_arm(v, all_variants, idx, line, col)
      [arm, ...derive_ord_sum_outer_arms(rest, all_variants, idx + 1, line, col)]
    }
  }
}

fn derive_ord_sum_outer_arm(outer_v: Variant, all_variants: [Variant],
                             outer_idx: Int, line: Int, col: Int) : Arm {
  match outer_v {
    Var(name, vargs) -> {
      let outer_pat_subs = derive_ord_sum_pat_subs(vargs, "a", 0, line, col)
      let outer_pat = mk_pat(PVariant(name, outer_pat_subs), line, col)
      let inner = derive_ord_sum_inner_match(outer_v, outer_idx,
                                              all_variants, line, col)
      Arm(outer_pat, None, inner)
    }
  }
}

# Like `derive_sum_pat_subs`, but lets the caller pick the binder
# prefix so the inner match can use `b0/b1/...` instead of `a0/a1/...`.
fn derive_ord_sum_pat_subs(vargs: [TypeExpr], prefix: String, i: Int,
                            line: Int, col: Int) : [Pattern] {
  match vargs {
    [] -> []
    [_, ...rest] ->
      [mk_pat(PBind(concat_all([prefix, int_to_string(i)])), line, col),
       ...derive_ord_sum_pat_subs(rest, prefix, i + 1, line, col)]
  }
}

fn derive_ord_sum_inner_match(outer_v: Variant, outer_idx: Int,
                               all_variants: [Variant], line: Int, col: Int) : Expr {
  let scrut = mk_expr(EVar("b"), line, col)
  let arms = derive_ord_sum_inner_arms(outer_v, outer_idx, all_variants,
                                        0, line, col)
  mk_expr(EMatch(scrut, arms), line, col)
}

# Generates the inner-match arms for one outer variant. For each
# variant in the type's declaration, with index `idx`:
#   - idx <  outer_idx → that variant comes earlier in declaration
#                         order, so `cmp(outer, that) == 1`. Emit an
#                         explicit `Variant(_, _, ...) -> 1` arm.
#   - idx == outer_idx → same variant: emit `Variant(b0, b1, ...) ->
#                         <payload chain>`. After the self arm, fold
#                         every later variant under a single
#                         `_ -> -1` wildcard and stop.
fn derive_ord_sum_inner_arms(outer_v: Variant, outer_idx: Int,
                              variants: [Variant], idx: Int,
                              line: Int, col: Int) : [Arm] {
  match variants {
    [] -> []
    [v, ...rest] -> {
      if idx < outer_idx {
        let arm = derive_ord_sum_wild_arm(v, 1, line, col)
        [arm, ...derive_ord_sum_inner_arms(outer_v, outer_idx, rest,
                                            idx + 1, line, col)]
      } else if idx == outer_idx {
        let self_arm = derive_ord_sum_self_arm(outer_v, line, col)
        match rest {
          [] -> [self_arm]
          _  -> [self_arm, derive_ord_sum_default_arm(-1, line, col)]
        }
      } else {
        # Defensive: outer_idx is always within bounds, so this
        # branch is unreachable. Returning [] keeps the recursion
        # well-typed without an extra `panic`.
        []
      }
    }
  }
}

# `Variant(_, _, ...) -> <int>` — used for variants on the "wrong"
# side of the outer-vs-inner comparison.
fn derive_ord_sum_wild_arm(v: Variant, ret: Int, line: Int, col: Int) : Arm {
  match v {
    Var(name, vargs) -> {
      let pats = derive_ord_sum_wild_pats(vargs, line, col)
      let pat = mk_pat(PVariant(name, pats), line, col)
      Arm(pat, None, mk_expr(EInt(ret), line, col))
    }
  }
}

fn derive_ord_sum_wild_pats(vargs: [TypeExpr], line: Int, col: Int) : [Pattern] {
  match vargs {
    [] -> []
    [_, ...rest] ->
      [mk_pat(PWild, line, col),
       ...derive_ord_sum_wild_pats(rest, line, col)]
  }
}

# `_ -> <int>` — covers every variant after the outer's position.
fn derive_ord_sum_default_arm(ret: Int, line: Int, col: Int) : Arm {
  Arm(mk_pat(PWild, line, col), None, mk_expr(EInt(ret), line, col))
}

# `Variant(b0, b1, ...) -> <payload chain>` — the same-variant case.
# Payloads are compared field-by-field in declaration order; the
# first non-zero `cmp` wins.
fn derive_ord_sum_self_arm(v: Variant, line: Int, col: Int) : Arm {
  match v {
    Var(name, vargs) -> {
      let inner_pat_subs = derive_ord_sum_pat_subs(vargs, "b", 0, line, col)
      let pat = mk_pat(PVariant(name, inner_pat_subs), line, col)
      let body = derive_ord_payload_chain(vargs, 0, line, col)
      Arm(pat, None, body)
    }
  }
}

fn derive_ord_payload_chain(vargs: [TypeExpr], idx: Int,
                             line: Int, col: Int) : Expr {
  match vargs {
    [] -> mk_expr(EInt(0), line, col)
    [_, ...rest] -> {
      let av = mk_expr(EVar(concat_all(["a", int_to_string(idx)])), line, col)
      let bv = mk_expr(EVar(concat_all(["b", int_to_string(idx)])), line, col)
      let cmp_call = mk_expr(ECall(mk_expr(EVar("cmp"), line, col), [av, bv]),
                             line, col)
      match rest {
        [] -> cmp_call
        _  -> {
          let cvar = concat_all(["p", int_to_string(idx)])
          let pat = mk_pat(PBind(cvar), line, col)
          let let_stmt = SLet(pat, None, cmp_call)
          let cond = mk_expr(EBinop("!=", mk_expr(EVar(cvar), line, col),
                                          mk_expr(EInt(0), line, col)),
                             line, col)
          let then_e = mk_expr(EVar(cvar), line, col)
          let else_e = derive_ord_payload_chain(rest, idx + 1, line, col)
          let if_e = mk_expr(EIf(cond, then_e, Some(else_e)), line, col)
          mk_expr(EBlock([let_stmt], Some(if_e)), line, col)
        }
      }
    }
  }
}

fn make_derived_impl(pname: String, tname: String, opname: String,
                      params: [Param], ret: TypeExpr, body: Expr,
                      line: Int, col: Int) : Decl {
  let method = DFn(false, opname, [], params, Some(ret), REmpty, body, line, col)
  DImpl(pname, mk_ty(TyName(tname, []), line, col), [method], line, col)
}

# m12.8.z: pre-expansion validation for `#derive(Ord)`. Walks the
# decl stream once to collect every type that has — or will have
# after derivation — an `Ord` impl, then rejects any
# `#derive(Ord) type T` whose fields/payloads reference a type that
# does not appear in that set. The `T` itself is whitelisted to
# allow recursive types. Parametric type heads (`List`, `Option`,
# `Result`, `Fn`) collapse to their constructor name via
# `proto_type_name`, so a field of type `[Int]` looks like `List`
# in the providers set — and unless `impl Ord for List` is
# declared, the derive is rejected.
fn validate_derive_ord(decls: [Decl], file: String) : Int {
  let providers = collect_ord_providers(decls, [])
  validate_derive_ord_loop(decls, file, providers, 0)
}

fn collect_ord_providers(decls: [Decl], acc: [String]) : [String] {
  match decls {
    [] -> acc
    [d, ...rest] -> match d {
      DImpl(pname, target, _, _, _) ->
        if pname == "Ord" {
          collect_ord_providers(rest, [proto_type_name(target), ...acc])
        } else {
          collect_ord_providers(rest, acc)
        }
      DDerive(names, inner, _, _) -> match inner {
        DType(_, tname, _, _, _, _) ->
          if list_has(names, "Ord") {
            collect_ord_providers(rest, [tname, ...acc])
          } else {
            collect_ord_providers(rest, acc)
          }
        _ -> collect_ord_providers(rest, acc)
      }
      _ -> collect_ord_providers(rest, acc)
    }
  }
}

fn validate_derive_ord_loop(decls: [Decl], file: String,
                              providers: [String], errs: Int) : Int {
  match decls {
    [] -> errs
    [d, ...rest] -> match d {
      DDerive(names, inner, _, _) -> match inner {
        DType(_, tname, _, body, line, col) ->
          if list_has(names, "Ord") {
            let errs1 = validate_derive_ord_body(file, tname, body, providers,
                                                  line, col, errs)
            validate_derive_ord_loop(rest, file, providers, errs1)
          } else {
            validate_derive_ord_loop(rest, file, providers, errs)
          }
        _ -> validate_derive_ord_loop(rest, file, providers, errs)
      }
      _ -> validate_derive_ord_loop(rest, file, providers, errs)
    }
  }
}

fn validate_derive_ord_body(file: String, tname: String, body: TypeBody,
                              providers: [String], line: Int, col: Int,
                              errs: Int) : Int {
  match body {
    TBRecord(fields) -> validate_derive_ord_fields(file, tname, fields,
                                                     providers, line, col, errs)
    TBSum(variants) -> validate_derive_ord_variants(file, tname, variants,
                                                      providers, line, col, errs)
    # Aliases / effect-aliases never reach derive — `derive_ord_impl`
    # returns None for them and the existing pipeline handles the
    # resulting "no impl" surface elsewhere. Nothing to validate here.
    _ -> errs
  }
}

fn validate_derive_ord_fields(file: String, tname: String,
                                fields: [FieldDecl], providers: [String],
                                line: Int, col: Int, errs: Int) : Int {
  match fields {
    [] -> errs
    [fd, ...rest] -> match fd {
      FD(fname, ftype) -> {
        let errs1 = validate_derive_ord_one(file, tname, fname, "field",
                                              ftype, providers, line, col, errs)
        validate_derive_ord_fields(file, tname, rest, providers, line, col, errs1)
      }
    }
  }
}

fn validate_derive_ord_variants(file: String, tname: String,
                                  variants: [Variant], providers: [String],
                                  line: Int, col: Int, errs: Int) : Int {
  match variants {
    [] -> errs
    [v, ...rest] -> match v {
      Var(vname, vargs) -> {
        let errs1 = validate_derive_ord_payload(file, tname, vname, vargs, 0,
                                                  providers, line, col, errs)
        validate_derive_ord_variants(file, tname, rest, providers, line, col, errs1)
      }
    }
  }
}

fn validate_derive_ord_payload(file: String, tname: String, vname: String,
                                 vargs: [TypeExpr], idx: Int,
                                 providers: [String], line: Int, col: Int,
                                 errs: Int) : Int {
  match vargs {
    [] -> errs
    [vt, ...rest] -> {
      let label = concat_all([vname, " payload #", int_to_string(idx)])
      let errs1 = validate_derive_ord_one(file, tname, label, "variant",
                                            vt, providers, line, col, errs)
      validate_derive_ord_payload(file, tname, vname, rest, idx + 1,
                                    providers, line, col, errs1)
    }
  }
}

fn validate_derive_ord_one(file: String, tname: String, fname: String,
                             kind: String, ftype: TypeExpr,
                             providers: [String], line: Int, col: Int,
                             errs: Int) : Int / Console {
  let head = proto_type_name(ftype)
  if head == tname {
    errs
  } else if list_has(providers, head) {
    errs
  } else {
    eprint(concat_all([
      file, ":", int_to_string(line), ":", int_to_string(col),
      ": error: cannot `#derive(Ord)` for `", tname,
      "`: no `Ord` impl for ", kind, " `", fname, "` of type `", head,
      "` (declare `impl Ord for ", head, "` or `#derive(Ord)` on `", head, "`)"]))
    errs + 1
  }
}

# Top-level entry point. Hands the post-desugar decl stream back
# with protocols / impls lowered into ordinary fn decls, plus a
# threaded ProtocolReg the post-inference rewrite consumes.
type LoweredProtocols = { decls: [Decl], reg: ProtocolReg, errs: Int }

fn lower_protocols(decls: [Decl], file: String) : LoweredProtocols {
  # Step 0 — m12.8.x: validate `#derive(Eq/Hash)` on sum types: every
  # variant field's head type must already have an impl reachable in
  # this compilation unit. Reported errors short-circuit the typer
  # via `proto_errs > 0` in the driver.
  let pre_errs = validate_derives(decls, file)
  # Step 0b — m12.8.z: validate `#derive(Ord)` against available
  # impls *before* expansion. The synthesised `cmp` body delegates
  # to `cmp` on each field type, and the post-inference rewrite
  # silently routes missing-impl calls to the dispatcher's runtime
  # `panic` (a v1 tradeoff explained in §"resolve_protocol_calls").
  # That fallback is acceptable for hand-written impls but a poor
  # user experience for derived ones, where the field-level cause
  # isn't surfaced. This pass walks the original decl stream
  # (DDerive nodes still intact) and emits a clear typer-time error
  # naming the offending field/payload.
  let derive_errs = validate_derive_ord(decls, file)
  # Step 1 — expand `#derive(...)` annotations into synthetic DImpl
  # decls so subsequent steps see all impls uniformly.
  let expanded = expand_derives(decls)
  # Step 2 — coherence: orphan + duplicate-impl validation.
  let proto_names = collect_proto_names(expanded, [])
  let local_types = collect_local_type_names(expanded, [])
  let errs = pre_errs + derive_errs + validate_impls(expanded, file, proto_names, local_types)
  # Step 3 — collect every protocol op into the registry.
  let reg0 = collect_proto_decls(expanded, proto_reg_empty())
  # Step 4 — lower each DImpl method into a top-level DFn (mangled
  # name) and record the (P, T) -> impl_fn entry in the registry.
  let lower_res = lower_impls(expanded, reg0, [])
  # Step 5 — synthesise one dispatcher fn per protocol op so the
  # typer can resolve the call as ordinary polymorphic dispatch; the
  # post-inference rewrite redirects each reachable call to the
  # matching `__pimpl_*` direct call.
  let dispatchers = generate_dispatchers(lower_res.reg)
  # Step 6 — drop DProtocol / DImpl / DDerive from the decl stream.
  let stripped = strip_protocols(expanded)
  # Step 7 — rename every reachable `EVar(opname)` reference to its
  # safe dispatcher name (`__proto_<opname>`) so the C / LLVM emit
  # never produces `kai_<opname>` and collides with runtime helpers
  # like `kai_eq`, `kai_to_string`, `kai_lt`. The dispatcher fn was
  # registered under the same safe name in step 5; the post-inference
  # rewrite then redirects each reachable call to the matching
  # `__pimpl_<P>_<T>_<op>` direct call when the type is known.
  let user_renamed = rename_proto_calls_decls(stripped, lower_res.reg.op_names)
  let impl_renamed = rename_proto_calls_decls(lower_res.fns, lower_res.reg.op_names)
  let final_decls = list_append(user_renamed, list_append(impl_renamed, dispatchers))
  LoweredProtocols { decls: final_decls, reg: lower_res.reg, errs: errs }
}

# m12.8: pre-resolve renaming pass. Walks every DFn / DTest body and
# rewrites every `EVar(name)` whose name is a known protocol op into
# `EVar(__proto_<name>)` — but only when `name` is NOT bound by an
# enclosing local binder. Scope tracking is threaded as `bound:
# [String]`, the union of names introduced by the surrounding fn
# params, lambda params, handler-clause params, handler-return
# pattern, `let` / `var` binders, and `match` arm patterns.
#
# Without this guard the rewrite would shadow common parameter names
# like `cmp` in `list_sort_by(xs, cmp: (a, a) -> Int)`: every
# reference to the parameter inside the body would silently route to
# the protocol dispatcher (`__proto_cmp`) and panic at runtime since
# the receiver is generic in `a`. The bug surfaced in `demos/poker`
# via `list_sort` once `--prelude stdlib/protocols.kai` was added to
# the demo build.

fn rename_proto_calls_decls(ds: [Decl], op_names: [String]) : [Decl] =
  map(ds, (d) => rename_proto_calls_decl(d, op_names))

fn rename_proto_calls_decl(d: Decl, op_names: [String]) : Decl {
  match d {
    DFn(pub_, n, tps, ps, ret, row, body, l, c) -> {
      let bound = rename_param_names(ps, [])
      DFn(pub_, n, tps, ps, ret, row,
          rename_proto_calls_expr(body, op_names, bound), l, c)
    }
    DTest(desc, body, l, c) ->
      DTest(desc, rename_proto_calls_expr(body, op_names, []), l, c)
    _ -> d
  }
}

# Names introduced by a parameter list (fn / lambda / handler clause).
fn rename_param_names(ps: [Param], acc: [String]) : [String] {
  match ps {
    [] -> acc
    [p, ...rest] -> rename_param_names(rest, [p.pname, ...acc])
  }
}

# Names introduced by a single pattern. Mirrors `bind_pat` but
# accumulates into a `[String]` rather than a resolver Env.
fn rename_pat_names(p: Pattern, acc: [String]) : [String] {
  match p.pkind {
    PWild         -> acc
    PLit(_)       -> acc
    PBind(name)   -> [name, ...acc]
    PList(pats, opt_rest) -> {
      let a = rename_pats_names(pats, acc)
      match opt_rest { Some(r) -> [r, ...a] None -> a }
    }
    PVariant(_, subs)        -> rename_pats_names(subs, acc)
    PVariantRecord(_, fs)    -> rename_pfields_names(fs, acc)
    PRecord(fs)              -> rename_pfields_names(fs, acc)
    PHole(_)                 -> acc
    PAs(name, sub)           -> rename_pat_names(sub, [name, ...acc])
  }
}

fn rename_pats_names(ps: [Pattern], acc: [String]) : [String] {
  match ps {
    [] -> acc
    [p, ...rest] -> rename_pats_names(rest, rename_pat_names(p, acc))
  }
}

fn rename_pfields_names(fs: [PField], acc: [String]) : [String] {
  match fs {
    [] -> acc
    [pf, ...rest] -> match pf {
      PField(_, sub, _) -> rename_pfields_names(rest, rename_pat_names(sub, acc))
    }
  }
}

fn rename_proto_calls_expr(e: Expr, op_names: [String], bound: [String]) : Expr =
  Expr { kind: rename_proto_calls_kind(e.kind, op_names, bound),
         line: e.line, col: e.col, ty: e.ty }

fn rename_proto_calls_opt(o: Option[Expr], op_names: [String], bound: [String]) : Option[Expr] {
  match o {
    Some(e) -> Some(rename_proto_calls_expr(e, op_names, bound))
    None    -> None
  }
}

fn rename_proto_calls_arms(arms: [Arm], op_names: [String], bound: [String]) : [Arm] =
  map(arms, (a) => rename_proto_calls_arm(a, op_names, bound))

fn rename_proto_calls_arm(a: Arm, op_names: [String], bound: [String]) : Arm {
  match a {
    Arm(p, g, b) -> {
      let bound1 = rename_pat_names(p, bound)
      Arm(p, rename_proto_calls_opt(g, op_names, bound1),
            rename_proto_calls_expr(b, op_names, bound1))
    }
  }
}

# m12.8.x scope-aware: SLet / SVar bindings extend the bound set for
# every later stmt in the same block AND for the trailing expression.
# `rename_proto_calls_block` threads the running `bound` accumulator;
# stmts that don't bind (SExprStmt / SAssert / SIndexAssign) walk
# their sub-exprs under the current `bound` and pass it through
# unchanged.
fn rename_proto_calls_block(stmts: [Stmt], tail: Option[Expr],
                              op_names: [String], bound: [String]) : ExprKind =
  rename_proto_calls_block_loop(stmts, tail, op_names, bound, [])

type StmtsAcc = { stmts: [Stmt], bound: [String] }

fn rename_proto_calls_block_loop(stmts: [Stmt], tail: Option[Expr],
                                   op_names: [String], bound: [String],
                                   acc: [Stmt]) : ExprKind {
  match stmts {
    [] -> EBlock(list_reverse(acc),
                 rename_proto_calls_opt(tail, op_names, bound))
    [s, ...rest] -> {
      let r = rename_proto_calls_stmt(s, op_names, bound)
      rename_proto_calls_block_loop(rest, tail, op_names, r.bound,
                                       [r.s, ...acc])
    }
  }
}

type StmtTyped = { s: Stmt, bound: [String] }

fn rename_proto_calls_stmt(s: Stmt, op_names: [String], bound: [String]) : StmtTyped {
  match s {
    SLet(p, ann, rhs) -> {
      let new_rhs = rename_proto_calls_expr(rhs, op_names, bound)
      let bound1 = rename_pat_names(p, bound)
      StmtTyped { s: SLet(p, ann, new_rhs), bound: bound1 }
    }
    SAssert(c, m) ->
      StmtTyped {
        s: SAssert(rename_proto_calls_expr(c, op_names, bound),
                    rename_proto_calls_opt(m, op_names, bound)),
        bound: bound
      }
    SExprStmt(x) ->
      StmtTyped {
        s: SExprStmt(rename_proto_calls_expr(x, op_names, bound)),
        bound: bound
      }
    SIndexAssign(b, i, v, l, c) ->
      StmtTyped {
        s: SIndexAssign(rename_proto_calls_expr(b, op_names, bound),
                         rename_proto_calls_expr(i, op_names, bound),
                         rename_proto_calls_expr(v, op_names, bound), l, c),
        bound: bound
      }
    SVar(n, ty, rhs, l, c) -> {
      let new_rhs = rename_proto_calls_expr(rhs, op_names, bound)
      StmtTyped {
        s: SVar(n, ty, new_rhs, l, c),
        bound: [n, ...bound]
      }
    }
  }
}

fn rename_proto_calls_clauses(cs: [HClause], op_names: [String], bound: [String]) : [HClause] =
  map(cs, (c) => rename_proto_calls_clause(c, op_names, bound))

fn rename_proto_calls_clause(c: HClause, op_names: [String], bound: [String]) : HClause {
  match c {
    HC(n, ps, b, l, co) -> {
      let bound1 = rename_param_names(ps, bound)
      HC(n, ps, rename_proto_calls_expr(b, op_names, bound1), l, co)
    }
  }
}

fn rename_proto_calls_opt_return(o: Option[HReturn], op_names: [String], bound: [String]) : Option[HReturn] {
  match o {
    Some(r) -> Some(rename_proto_calls_return(r, op_names, bound))
    None    -> None
  }
}

fn rename_proto_calls_return(r: HReturn, op_names: [String], bound: [String]) : HReturn {
  match r {
    HR(p, b, l, c) -> HR(p, rename_proto_calls_expr(b, op_names, [p, ...bound]), l, c)
  }
}

fn rename_proto_calls_kind(k: ExprKind, op_names: [String], bound: [String]) : ExprKind {
  match k {
    # Rep invariant (b): a bare EVar referring to a protocol op rewrites
    # to its dispatcher only when the name is NOT bound by an enclosing
    # binder (lambda param, let/var, match pattern, handler clause
    # param, return-clause binder). Bound tracking is what
    # `validate_typer_invariants` cross-checks; this case is the
    # construction site.
    EVar(name) ->
      if list_has(op_names, name) and not list_has(bound, name) {
        EVar(proto_dispatcher_name(name))
      } else { k }
    # Scope-aware kinds. Each adds names to `bound` before recursing
    # into the bodies that they shadow.
    EBlock(stmts, tail) -> rename_proto_calls_block(stmts, tail, op_names, bound)
    ELambda(ps, b) -> {
      let bound1 = rename_param_names(ps, bound)
      ELambda(ps, rename_proto_calls_expr(b, op_names, bound1))
    }
    EMatch(scr, arms) -> EMatch(rename_proto_calls_expr(scr, op_names, bound),
                                  rename_proto_calls_arms(arms, op_names, bound))
    EHandle(body, eff_name, eff_tyargs, init_opt, alias_opt, clauses, ret_opt) ->
      EHandle(rename_proto_calls_expr(body, op_names, bound), eff_name, eff_tyargs,
              map_opt_expr(init_opt, (e) => rename_proto_calls_expr(e, op_names, bound)),
              alias_opt,
              rename_proto_calls_clauses(clauses, op_names, bound),
              rename_proto_calls_opt_return(ret_opt, op_names, bound))
    # All remaining kinds (ECall, EField, EIndex, EBinop, EUnop, EIf,
    # ERecordLit, EList, ERange, EPipe, EBang, ELitUnit) recurse purely
    # structurally without changing the bound set; the leaves return
    # unchanged. The shared visitor handles both — keeping invariant
    # (b)'s scope tracking concentrated in the explicit cases above
    # where it actually matters.
    _ -> map_expr_kind(k, (sub) => rename_proto_calls_expr(sub, op_names, bound))
  }
}

# ====================================================================
# m12.8 — post-inference protocol-call rewrite
# ====================================================================
#
# Once `infer_program` has populated `Expr.ty` on every node, walk
# the typed AST and replace every reachable
#
#   ECall(EVar("op"), [arg0, arg1, ...])
#
# (where `op` is a registered protocol op AND `arg0.ty` resolves to
# a concrete type-constructor name `T`) with
#
#   ECall(EVar("__pimpl_<P>_<T>_<op>"), [arg0, arg1, ...])
#
# The rewrite is purely syntactic — every callee already has a body
# in scope (lower_protocols emitted it), so the call links normally.
# Calls whose `arg0.ty` is unknown OR for which no impl exists fall
# through and execute the dispatcher fn's `panic` at runtime; the
# spec wants a compile-time error there but the v1 keeps the runtime
# fallback so partial programs (typed holes, generic helpers without
# concrete dispatch info) still build.

fn resolve_protocol_calls(typed: TypedProgram, reg: ProtocolReg) : TypedProgram {
  TypedProgram {
    decls: map(typed.decls, (d) => resolve_protocol_calls_decl(d, reg)),
    errs: typed.errs,
    insts: typed.insts,
    holes: typed.holes,
    prelude_len: typed.prelude_len
  }
}

fn resolve_protocol_calls_decl(d: Decl, reg: ProtocolReg) : Decl {
  match d {
    DFn(pub_, n, tps, ps, ret, row, body, l, c) ->
      DFn(pub_, n, tps, ps, ret, row, resolve_protocol_calls_expr(body, reg), l, c)
    DTest(desc, body, l, c) ->
      DTest(desc, resolve_protocol_calls_expr(body, reg), l, c)
    _ -> d
  }
}

fn resolve_protocol_calls_expr(e: Expr, reg: ProtocolReg) : Expr =
  Expr { kind: resolve_protocol_calls_kind(e.kind, reg, e.line, e.col),
         line: e.line, col: e.col, ty: e.ty }

fn resolve_protocol_calls_kind(k: ExprKind, reg: ProtocolReg,
                                line: Int, col: Int) : ExprKind {
  match k {
    # The only kind that needs special handling: a typed `ECall` whose
    # callee resolves to a registered protocol op + args[0].ty matches
    # a registered impl gets rewritten to `__pimpl_<P>_<T>_<op>`. All
    # other kinds recurse purely structurally — there is no scope
    # bookkeeping at this stage.
    ECall(callee, args_) -> {
      let new_args = map(args_, (a) => resolve_protocol_calls_expr(a, reg))
      let new_callee = resolve_protocol_calls_expr(callee, reg)
      let rewritten = try_rewrite_proto_call(new_callee, new_args, reg)
      match rewritten {
        Some(rk) -> rk
        None     -> ECall(new_callee, new_args)
      }
    }
    _ -> map_expr_kind(k, (sub) => resolve_protocol_calls_expr(sub, reg))
  }
}

# m12.8.x phase 2 (Bug 5): post-rewrite validation. After
# `resolve_protocol_calls` has rewritten every dispatchable
# `__proto_<op>(receiver, ...)` call into the matching
# `__pimpl_<P>_<T>_<op>` direct call, walk the typed AST and report
# any *remaining* dispatcher-shaped calls whose receiver type is
# concrete but has no impl. This is the compile-time error the
# `m12_8_y_postfix_no_impl` and similar negative fixtures expect.
# Calls whose receiver is still a TyVar (the polymorphic-helper
# fallthrough case the m12.8 v1 deliberately allowed) keep the
# dispatcher panic at runtime.
fn validate_resolved_protocols(typed: TypedProgram, reg: ProtocolReg,
                                file: String) : Int =
  validate_resolved_decls(typed.decls, reg, file, 0)

fn validate_resolved_decls(ds: [Decl], reg: ProtocolReg,
                            file: String, errs: Int) : Int {
  match ds {
    [] -> errs
    [d, ...rest] -> {
      let e1 = match d {
        DFn(_, _, _, _, _, _, body, _, _) ->
          validate_resolved_expr(body, reg, file, errs)
        DTest(_, body, _, _) ->
          validate_resolved_expr(body, reg, file, errs)
        _ -> errs
      }
      validate_resolved_decls(rest, reg, file, e1)
    }
  }
}

fn validate_resolved_expr(e: Expr, reg: ProtocolReg, file: String,
                           errs: Int) : Int {
  let e1 = validate_proto_call_at(e, reg, file, errs)
  validate_resolved_kind(e.kind, reg, file, e1)
}

fn validate_resolved_opt(o: Option[Expr], reg: ProtocolReg, file: String,
                          errs: Int) : Int {
  match o {
    Some(e) -> validate_resolved_expr(e, reg, file, errs)
    None    -> errs
  }
}

fn validate_resolved_exprs(es: [Expr], reg: ProtocolReg, file: String,
                            errs: Int) : Int {
  match es {
    [] -> errs
    [e, ...rest] -> {
      let e1 = validate_resolved_expr(e, reg, file, errs)
      validate_resolved_exprs(rest, reg, file, e1)
    }
  }
}

fn validate_resolved_arms(arms: [Arm], reg: ProtocolReg, file: String,
                           errs: Int) : Int {
  match arms {
    [] -> errs
    [a, ...rest] -> match a {
      Arm(_, g, b) -> {
        let e1 = validate_resolved_opt(g, reg, file, errs)
        let e2 = validate_resolved_expr(b, reg, file, e1)
        validate_resolved_arms(rest, reg, file, e2)
      }
    }
  }
}

fn validate_resolved_stmts(ss: [Stmt], reg: ProtocolReg, file: String,
                            errs: Int) : Int {
  match ss {
    [] -> errs
    [s, ...rest] -> {
      let e1 = match s {
        SLet(_, _, rhs) -> validate_resolved_expr(rhs, reg, file, errs)
        SAssert(c, m) -> {
          let x = validate_resolved_expr(c, reg, file, errs)
          validate_resolved_opt(m, reg, file, x)
        }
        SExprStmt(x) -> validate_resolved_expr(x, reg, file, errs)
        SIndexAssign(b, i, v, _, _) -> {
          let x = validate_resolved_expr(b, reg, file, errs)
          let y = validate_resolved_expr(i, reg, file, x)
          validate_resolved_expr(v, reg, file, y)
        }
        SVar(_, _, rhs, _, _) -> validate_resolved_expr(rhs, reg, file, errs)
      }
      validate_resolved_stmts(rest, reg, file, e1)
    }
  }
}

fn validate_resolved_clauses(cs: [HClause], reg: ProtocolReg,
                              file: String, errs: Int) : Int {
  match cs {
    [] -> errs
    [c, ...rest] -> match c {
      HC(_, _, b, _, _) -> {
        let e1 = validate_resolved_expr(b, reg, file, errs)
        validate_resolved_clauses(rest, reg, file, e1)
      }
    }
  }
}

fn validate_resolved_opt_return(o: Option[HReturn], reg: ProtocolReg,
                                 file: String, errs: Int) : Int {
  match o {
    Some(r) -> match r { HR(_, b, _, _) -> validate_resolved_expr(b, reg, file, errs) }
    None -> errs
  }
}

fn validate_resolved_fields(fs: [FieldInit], reg: ProtocolReg,
                             file: String, errs: Int) : Int {
  match fs {
    [] -> errs
    [f, ...rest] -> match f {
      FI(_, v) -> {
        let e1 = validate_resolved_expr(v, reg, file, errs)
        validate_resolved_fields(rest, reg, file, e1)
      }
    }
  }
}

fn validate_resolved_list_elems(els: [ListElem], reg: ProtocolReg,
                                 file: String, errs: Int) : Int {
  match els {
    [] -> errs
    [el, ...rest] -> {
      let e1 = match el {
        ElPlain(x)  -> validate_resolved_expr(x, reg, file, errs)
        ElSpread(x) -> validate_resolved_expr(x, reg, file, errs)
      }
      validate_resolved_list_elems(rest, reg, file, e1)
    }
  }
}

fn validate_resolved_kind(k: ExprKind, reg: ProtocolReg, file: String,
                           errs: Int) : Int {
  match k {
    ECall(c, args_) -> {
      let e1 = validate_resolved_expr(c, reg, file, errs)
      validate_resolved_exprs(args_, reg, file, e1)
    }
    EBlock(ss, t) -> {
      let e1 = validate_resolved_stmts(ss, reg, file, errs)
      validate_resolved_opt(t, reg, file, e1)
    }
    EIf(c, t_, eo) -> {
      let e1 = validate_resolved_expr(c, reg, file, errs)
      let e2 = validate_resolved_expr(t_, reg, file, e1)
      validate_resolved_opt(eo, reg, file, e2)
    }
    EBinop(_, a, b) -> {
      let e1 = validate_resolved_expr(a, reg, file, errs)
      validate_resolved_expr(b, reg, file, e1)
    }
    EUnop(_, x) -> validate_resolved_expr(x, reg, file, errs)
    EHandle(body, _, _, init_opt, _, clauses, ret_opt) -> {
      let e1 = validate_resolved_expr(body, reg, file, errs)
      let e2 = validate_resolved_opt(init_opt, reg, file, e1)
      let e3 = validate_resolved_clauses(clauses, reg, file, e2)
      validate_resolved_opt_return(ret_opt, reg, file, e3)
    }
    ELambda(_, b) -> validate_resolved_expr(b, reg, file, errs)
    EMatch(scr, arms) -> {
      let e1 = validate_resolved_expr(scr, reg, file, errs)
      validate_resolved_arms(arms, reg, file, e1)
    }
    EPipe(a, b) -> {
      let e1 = validate_resolved_expr(a, reg, file, errs)
      validate_resolved_expr(b, reg, file, e1)
    }
    EField(base, _) -> validate_resolved_expr(base, reg, file, errs)
    EIndex(a, b) -> {
      let e1 = validate_resolved_expr(a, reg, file, errs)
      validate_resolved_expr(b, reg, file, e1)
    }
    ERecordLit(_, fields) -> validate_resolved_fields(fields, reg, file, errs)
    EList(elems) -> validate_resolved_list_elems(elems, reg, file, errs)
    ERange(a, b, opt_step) -> {
      let e1 = validate_resolved_expr(a, reg, file, errs)
      let e2 = validate_resolved_expr(b, reg, file, e1)
      validate_resolved_opt(opt_step, reg, file, e2)
    }
    EBang(inner) -> validate_resolved_expr(inner, reg, file, errs)
    ELitUnit(inner, _) -> validate_resolved_expr(inner, reg, file, errs)
    _ -> errs
  }
}

fn validate_proto_call_at(e: Expr, reg: ProtocolReg, file: String,
                           errs: Int) : Int {
  match e.kind {
    ECall(callee, args_) -> match callee.kind {
      EVar(name) -> {
        let opname = strip_proto_dispatcher_prefix(name)
        # Only inspect calls that survived the rewrite as
        # `__proto_<op>(...)` (the prefix-strip yields a different
        # name) AND whose op is one of our registered protocol ops.
        if name == opname { errs }
        else if not list_has(reg.op_names, opname) { errs }
        else {
          match args_ {
            [] -> errs
            [self_arg, ...rest_args] -> match self_arg.ty {
              None -> errs
              Some(ty) -> match ty_head_name(ty) {
                None -> errs
                Some(tname) -> match find_impl(reg, opname, tname) {
                  Some(_) -> errs
                  None -> {
                    let pname = match proto_op_lookup(reg, opname) {
                      Some(po) -> match po { POR(pn, _, _, _, _, _) -> pn }
                      None -> "?"
                    }
                    diag_error(file, e.line, e.col,
                      concat_all(["no impl of `", pname,
                                  "` for type `", tname,
                                  "` (operation `", opname, "`)"]))
                    errs + 1
                  }
                }
              }
            }
          }
        }
      }
      _ -> errs
    }
    _ -> errs
  }
}

# ====================================================================
# m12.8.x post-Core REOPEN — Eric level 2: rep invariant verifiers
# ====================================================================
#
# Three walkers verify properties that should hold over the
# post-resolve typed AST. Each is a structural fold over Decl /
# Expr / Stmt / Arm / HClause / HReturn, accumulating an error
# count and (for invariant (b)) a lexical scope set. Diagnostics
# go to stderr via `diag_error`. Errors increment the count, so
# `compile_source` can fail the compile when any invariant breaks.
#
# These complement (not replace) the per-pass audits done in
# `7bd5a68`. They catch a class of bug at the boundary between
# passes — when one pass produces an AST node that violates an
# invariant the next pass assumes — without requiring a shared
# AST visitor refactor (deferred per CLAUDE.md "no premature
# abstraction").
#
# Invariants:
#   (a) Every Expr post-finalise has `Some(_)` ty annotation.
#       Catches the "discarded typed body" pattern (`10a1e7b`):
#       a pass that builds a new Expr from a sub-expr produced by
#       `synth` MUST use the typed sub-expr, not the original
#       (untyped) one. The original has `None` ty on its internal
#       nodes; finalise leaves `None` in place; this walker fires.
#   (b) Every `EVar(__proto_X)` reference has `X` outside every
#       enclosing binder. Catches the "scope-blind protocol
#       rename" pattern (`257b247`).
#   (c) Every `ELambda` whose `.ty` is `TyFnT` has an open row
#       tail. Catches the "closed lambda row" pattern (`b528655`).
#
# Wired into `compile_source` after `validate_resolved_protocols`,
# before perceus / monomorph / emit.

fn validate_typer_invariants(typed: TypedProgram, file: String) : Int =
  validate_inv_decls(typed.decls, file, 0)

fn validate_inv_decls(ds: [Decl], file: String, errs: Int) : Int {
  match ds {
    [] -> errs
    [d, ...rest] -> {
      let e1 = match d {
        DFn(_, _, _, ps, _, _, body, _, _) -> {
          let bound0 = inv_param_names(ps, [])
          validate_inv_expr(body, file, bound0, errs)
        }
        DTest(_, body, _, _) ->
          validate_inv_expr(body, file, [], errs)
        _ -> errs
      }
      validate_inv_decls(rest, file, e1)
    }
  }
}

fn inv_param_names(ps: [Param], acc: [String]) : [String] {
  match ps {
    [] -> acc
    [p, ...rest] -> inv_param_names(rest, [p.pname, ...acc])
  }
}

# Mirrors `bind_pat`/`pat_bindings` shape — accumulates pattern-
# bound names into a [String] for invariant (b)'s scope check.
fn inv_pat_names(p: Pattern, acc: [String]) : [String] {
  match p.pkind {
    PWild         -> acc
    PLit(_)       -> acc
    PBind(name)   -> [name, ...acc]
    PList(pats, opt_rest) -> {
      let a = inv_pats_names(pats, acc)
      match opt_rest { Some(r) -> [r, ...a] None -> a }
    }
    PVariant(_, subs)        -> inv_pats_names(subs, acc)
    PVariantRecord(_, fs)    -> inv_pfields_names(fs, acc)
    PRecord(fs)              -> inv_pfields_names(fs, acc)
    PHole(_)                 -> acc
    PAs(name, sub)           -> inv_pat_names(sub, [name, ...acc])
  }
}

fn inv_pats_names(ps: [Pattern], acc: [String]) : [String] {
  match ps {
    [] -> acc
    [p, ...rest] -> inv_pats_names(rest, inv_pat_names(p, acc))
  }
}

fn inv_pfields_names(fs: [PField], acc: [String]) : [String] {
  match fs {
    [] -> acc
    [pf, ...rest] -> match pf {
      PField(_, sub, _) -> inv_pfields_names(rest, inv_pat_names(sub, acc))
    }
  }
}

fn validate_inv_expr(e: Expr, file: String, bound: [String], errs: Int) : Int {
  # Invariant (a) — "every Expr has Some(ty) post-finalise" — was
  # too strict: post-typer rewrite passes (`try_rewrite_show_dim_real`,
  # `try_rewrite_proto_call`, the AST splicer in `desugar_interp`,
  # etc.) construct fresh `mk_expr(...)` nodes whose `ty` is None
  # by design — the rewriters are syntactic and have no typer
  # substitution to apply. A useful (a) needs a "this node was
  # constructed by a post-typer pass" tracker that today does not
  # exist. Deferred until that tracker is justified — the original
  # bug class (`10a1e7b`, discarded typed clause body) is already
  # covered by the audit done in `7bd5a68`.
  let e_bc = validate_inv_kind(e.kind, e.ty, file, e.line, e.col, bound, errs)
  validate_inv_subexprs(e.kind, file, bound, e_bc)
}

fn validate_inv_kind(k: ExprKind, ty: Option[Ty], file: String,
                      line: Int, col: Int, bound: [String], errs: Int) : Int {
  match k {
    EVar(name) -> {
      let opname = strip_proto_dispatcher_prefix(name)
      # Invariant (b): every `EVar(__proto_X)` reference has `X`
      # outside every enclosing binder. Catches the scope-blind
      # `rename_proto_calls` pattern (`257b247`).
      # Only check references that are dispatcher-shaped
      # (`__proto_X`); a bare user identifier whose name happens to
      # match a binder is fine.
      if name == opname { errs }
      else if list_has(bound, opname) {
        diag_error(file, line, col,
          concat_all(["rep invariant (b): protocol-dispatcher reference `",
                      name, "` shadows local binder `", opname,
                      "` in scope (rename pass missed scope tracking)"]))
        errs + 1
      } else { errs }
    }
    # Invariant (c) — "every `synth_lambda`-produced TyFnT has open
    # row tail" — was attempted as a post-finalise check on
    # ELambda's `.ty`. It over-fires: unification can legitimately
    # bind a fresh open row var to a closed row when the call site
    # expects a closed row (e.g., `list_sort_by`'s `cmp: (a, a) ->
    # Int` declares no row). Post-finalise we cannot distinguish
    # "the row was closed by default at construction" from "the row
    # was closed by unification to a concrete callee type". The
    # check belongs at the construction site (inside `synth_lambda`,
    # as an assertion on `lam_row.tail`), not as a post-hoc walker.
    # Keep audit at the construction site as the real defense; this
    # walker exits early on ELambda.
    _ -> errs
  }
}

fn validate_inv_subexprs(k: ExprKind, file: String, bound: [String], errs: Int) : Int {
  match k {
    ECall(c, xs) -> {
      let e1 = validate_inv_expr(c, file, bound, errs)
      validate_inv_exprs(xs, file, bound, e1)
    }
    EField(b, _) -> validate_inv_expr(b, file, bound, errs)
    EIndex(a, b) -> {
      let e1 = validate_inv_expr(a, file, bound, errs)
      validate_inv_expr(b, file, bound, e1)
    }
    EBinop(_, a, b) -> {
      let e1 = validate_inv_expr(a, file, bound, errs)
      validate_inv_expr(b, file, bound, e1)
    }
    EUnop(_, x) -> validate_inv_expr(x, file, bound, errs)
    EIf(c, t_, eo) -> {
      let e1 = validate_inv_expr(c, file, bound, errs)
      let e2 = validate_inv_expr(t_, file, bound, e1)
      match eo { Some(b) -> validate_inv_expr(b, file, bound, e2) None -> e2 }
    }
    EMatch(scr, arms) -> {
      let e1 = validate_inv_expr(scr, file, bound, errs)
      validate_inv_arms(arms, file, bound, e1)
    }
    ELambda(ps, body) -> {
      let bound1 = inv_param_names(ps, bound)
      validate_inv_expr(body, file, bound1, errs)
    }
    ERecordLit(_, fis) -> validate_inv_fields(fis, file, bound, errs)
    EList(els) -> validate_inv_list_elems(els, file, bound, errs)
    ERange(a, b, sopt) -> {
      let e1 = validate_inv_expr(a, file, bound, errs)
      let e2 = validate_inv_expr(b, file, bound, e1)
      match sopt { Some(s) -> validate_inv_expr(s, file, bound, e2) None -> e2 }
    }
    EBlock(stmts, tail) -> {
      let r = validate_inv_block(stmts, file, bound, errs)
      match tail { Some(t) -> validate_inv_expr(t, file, r.bound, r.errs) None -> r.errs }
    }
    EPipe(a, b) -> {
      let e1 = validate_inv_expr(a, file, bound, errs)
      validate_inv_expr(b, file, bound, e1)
    }
    EHandle(body, _, _, init_opt, alias_opt, clauses, ret_opt) -> {
      let e0 = match init_opt { Some(ie) -> validate_inv_expr(ie, file, bound, errs) None -> errs }
      let bound_body = match alias_opt { Some(a) -> [a, ...bound] None -> bound }
      let e1 = validate_inv_expr(body, file, bound_body, e0)
      let e2 = validate_inv_clauses(clauses, file, bound, e1)
      match ret_opt {
        Some(r) -> match r {
          HR(p, b, _, _) -> validate_inv_expr(b, file, [p, ...bound], e2)
        }
        None -> e2
      }
    }
    EBang(inner) -> validate_inv_expr(inner, file, bound, errs)
    ELitUnit(inner, _) -> validate_inv_expr(inner, file, bound, errs)
    _ -> errs
  }
}

fn validate_inv_exprs(xs: [Expr], file: String, bound: [String], errs: Int) : Int {
  match xs {
    [] -> errs
    [h, ...rest] -> validate_inv_exprs(rest, file, bound,
                                          validate_inv_expr(h, file, bound, errs))
  }
}

fn validate_inv_arms(arms: [Arm], file: String, bound: [String], errs: Int) : Int {
  match arms {
    [] -> errs
    [a, ...rest] -> match a {
      Arm(p, g, b) -> {
        let bound1 = inv_pat_names(p, bound)
        let e1 = match g { Some(gx) -> validate_inv_expr(gx, file, bound1, errs) None -> errs }
        let e2 = validate_inv_expr(b, file, bound1, e1)
        validate_inv_arms(rest, file, bound, e2)
      }
    }
  }
}

fn validate_inv_fields(fs: [FieldInit], file: String, bound: [String], errs: Int) : Int {
  match fs {
    [] -> errs
    [f, ...rest] -> match f {
      FI(_, v) -> validate_inv_fields(rest, file, bound,
                                          validate_inv_expr(v, file, bound, errs))
    }
  }
}

fn validate_inv_list_elems(els: [ListElem], file: String, bound: [String],
                              errs: Int) : Int {
  match els {
    [] -> errs
    [el, ...rest] -> {
      let e1 = match el {
        ElPlain(x)  -> validate_inv_expr(x, file, bound, errs)
        ElSpread(x) -> validate_inv_expr(x, file, bound, errs)
      }
      validate_inv_list_elems(rest, file, bound, e1)
    }
  }
}

type InvBlockRes = { errs: Int, bound: [String] }

fn validate_inv_block(stmts: [Stmt], file: String, bound: [String],
                         errs: Int) : InvBlockRes {
  match stmts {
    [] -> InvBlockRes { errs: errs, bound: bound }
    [s, ...rest] -> match s {
      SLet(p, _, rhs) -> {
        let e1 = validate_inv_expr(rhs, file, bound, errs)
        let bound1 = inv_pat_names(p, bound)
        validate_inv_block(rest, file, bound1, e1)
      }
      SVar(name, _, rhs, _, _) -> {
        let e1 = validate_inv_expr(rhs, file, bound, errs)
        validate_inv_block(rest, file, [name, ...bound], e1)
      }
      SAssert(c, m) -> {
        let e1 = validate_inv_expr(c, file, bound, errs)
        let e2 = match m { Some(mx) -> validate_inv_expr(mx, file, bound, e1) None -> e1 }
        validate_inv_block(rest, file, bound, e2)
      }
      SExprStmt(x) -> {
        let e1 = validate_inv_expr(x, file, bound, errs)
        validate_inv_block(rest, file, bound, e1)
      }
      SIndexAssign(b, i, v, _, _) -> {
        let e1 = validate_inv_expr(b, file, bound, errs)
        let e2 = validate_inv_expr(i, file, bound, e1)
        let e3 = validate_inv_expr(v, file, bound, e2)
        validate_inv_block(rest, file, bound, e3)
      }
    }
  }
}

fn validate_inv_clauses(cs: [HClause], file: String, bound: [String],
                          errs: Int) : Int {
  match cs {
    [] -> errs
    [c, ...rest] -> match c {
      HC(_, ps, b, _, _) -> {
        let bound1 = inv_param_names(ps, bound)
        let e1 = validate_inv_expr(b, file, bound1, errs)
        validate_inv_clauses(rest, file, bound, e1)
      }
    }
  }
}

fn try_rewrite_proto_call(callee: Expr, args_: [Expr],
                            reg: ProtocolReg) : Option[ExprKind] {
  match callee.kind {
    EVar(name) -> {
      let opname = strip_proto_dispatcher_prefix(name)
      if not list_has(reg.op_names, opname) { None }
      else {
        match args_ {
          [] -> None
          [self_arg, ...rest_] -> match self_arg.ty {
            None -> None
            Some(ty) -> match ty_head_name(ty) {
              None -> None
              Some(tname) -> {
                # m12.8 phase 2: special-case `show(x)` when `x : Real<u>`
                # with a concrete unit name. The parametric impl body in
                # stdlib/protocols.kai cannot bake the unit suffix on its
                # own (the body's `x.ty` keeps the impl-level UVar even
                # after inference, since the m4c monomorphiser is still
                # identity), so we synthesise the unit-aware expression
                # at the call site using the concrete arg type. Bare
                # `Real` falls through to the parametric body, which
                # returns just `real_to_string(x)` because `unit_name(x)`
                # emits "" for unresolved units.
                match try_rewrite_show_dim_real(opname, self_arg) {
                  Some(rk) -> Some(rk)
                  None -> match find_impl(reg, opname, tname) {
                    None -> None
                    Some(impl_fn) -> {
                      let new_callee = mk_expr(EVar(impl_fn), callee.line, callee.col)
                      Some(ECall(new_callee, args_))
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
    _ -> None
  }
}

# m12.8 phase 2: synthesise `string_concat(real_to_string(__strip_unit(arg)),
# " <UNIT>")` when the call is `show(arg)` and `arg : Real<u>` with a
# concrete unit. Returns None for bare `Real` / `Real<1>` / unresolved
# UVar — those cases either have nothing to suffix or cannot determine
# the unit at compile time, so they fall back to the parametric impl
# body's `real_to_string` path.
fn try_rewrite_show_dim_real(opname: String, arg: Expr) : Option[ExprKind] {
  if opname != "show" { None }
  else { match arg.ty {
    Some(t) -> match t {
      TyDimT(base, _) -> match base {
        TyReal -> {
          let unit_str = unit_name_of_ty(arg.ty)
          if string_length(unit_str) == 0 { None }
          else {
            let line = arg.line
            let col = arg.col
            let strip = mk_expr(ECall(mk_expr(EVar("__strip_unit"), line, col),
                                       [arg]), line, col)
            let bare  = mk_expr(ECall(mk_expr(EVar("real_to_string"), line, col),
                                       [strip]), line, col)
            let suffix_span = concat_all(["\" ", unit_str, "\""])
            let suffix = mk_expr(EStr(suffix_span, false), line, col)
            Some(ECall(mk_expr(EVar("string_concat"), line, col),
                        [bare, suffix]))
          }
        }
        _ -> None
      }
      _ -> None
    }
    None -> None
  } }
}

# Strip the `__proto_` dispatcher prefix the rename pass attaches.
# Names without the prefix pass through unchanged (so tests that
# bypass renaming still resolve).
fn strip_proto_dispatcher_prefix(name: String) : String {
  let pfx = "__proto_"
  let n_pfx = string_length(pfx)
  if string_length(name) <= n_pfx { name }
  else if string_slice(name, 0, n_pfx) == pfx {
    string_slice(name, n_pfx, string_length(name) - n_pfx)
  }
  else { name }
}

# Map an inferred Ty back to its canonical "head-constructor" name —
# the same mangling proto_type_name applies on the impl side. Lists,
# Option, Result, and primitive builtins get their canonical names;
# user-defined records / sums use TyCon's name.
fn ty_head_name(t: Ty) : Option[String] {
  match t {
    TyInt          -> Some("Int")
    TyReal         -> Some("Real")
    TyBool         -> Some("Bool")
    TyChar         -> Some("Char")
    TyString       -> Some("String")
    TyUnit         -> Some("Unit")
    TyListT(_)     -> Some("List")
    TyCon(name, _) -> Some(name)
    # m12.5: a dimensioned value dispatches on the underlying base
    # type's head — `Decimal<USD>` → `Decimal`, mirroring the
    # `proto_type_name` collapse on the syntactic side.
    TyDimT(base, _) -> ty_head_name(base)
    TyVarT(_)      -> None
    TyFnT(_, _, _) -> None
    TyAny          -> None
  }
}

# Walks the registry's impl table for a (protocol-op, type-name)
# match. The op-name search visits each impl entry's protocol's
# ops to find which protocol the op belongs to; for the v1 we look
# the op up first to know `pname`, then iterate impls for a matching
# (pname, tname).
fn find_impl(reg: ProtocolReg, opname: String, tname: String) : Option[String] {
  match proto_op_lookup(reg, opname) {
    None -> None
    Some(po) -> match po {
      POR(pname, _, _, _, _, _) -> find_impl_for(reg.impls, pname, tname, opname)
    }
  }
}

fn find_impl_for(impls: [ProtoImplReg], pname: String, tname: String,
                  opname: String) : Option[String] {
  match impls {
    [] -> None
    [it, ...rest] -> match it {
      PIR(p, t, op, fn_name) ->
        if p == pname and t == tname and op == opname { Some(fn_name) }
        else { find_impl_for(rest, pname, tname, opname) }
    }
  }
}

# ====================================================================
# cli + driver
# ====================================================================

type Mode
  = MDefault
  | MTokens
  | MAst
  | MTypes
  | MEnv
  | MInfer
  | MCheck
  | MDumpTyped
  | MDumpMono
  | MDumpMonoOut
  | MDumpLastUse
  | MHoles
  | MHolesJson
  | MEmitLlvm
  | MTest
  | MHelp
  | MVersion

type CliOptions = { mode: Mode, path: Option[String], preludes: [String],
                    strict_holes: Bool, search_paths: [String] }

fn cli_with_mode(opts: CliOptions, m: Mode) : CliOptions =
  CliOptions { mode: m, path: opts.path, preludes: opts.preludes,
               strict_holes: opts.strict_holes, search_paths: opts.search_paths }

fn cli_with_path(opts: CliOptions, p: String) : CliOptions =
  CliOptions { mode: opts.mode, path: Some(p), preludes: opts.preludes,
               strict_holes: opts.strict_holes, search_paths: opts.search_paths }

fn cli_with_prelude(opts: CliOptions, p: String) : CliOptions =
  CliOptions { mode: opts.mode, path: opts.path,
               preludes: list_append(opts.preludes, [p]),
               strict_holes: opts.strict_holes, search_paths: opts.search_paths }

fn cli_with_strict_holes(opts: CliOptions) : CliOptions =
  CliOptions { mode: opts.mode, path: opts.path, preludes: opts.preludes,
               strict_holes: true, search_paths: opts.search_paths }

fn cli_push_search_path(opts: CliOptions, sp: String) : CliOptions =
  CliOptions { mode: opts.mode, path: opts.path, preludes: opts.preludes,
               strict_holes: opts.strict_holes,
               search_paths: list_append(opts.search_paths, [sp]) }

fn parse_cli_loop(rest: [String], opts: CliOptions) : CliOptions / Console {
  match rest {
    [] -> opts
    [a, ...more] -> {
      if a == "--tokens" {
        parse_cli_loop(more, cli_with_mode(opts, MTokens))
      } else if a == "--ast" {
        parse_cli_loop(more, cli_with_mode(opts, MAst))
      } else if a == "--types" {
        parse_cli_loop(more, cli_with_mode(opts, MTypes))
      } else if a == "--env" {
        parse_cli_loop(more, cli_with_mode(opts, MEnv))
      } else if a == "--infer" {
        parse_cli_loop(more, cli_with_mode(opts, MInfer))
      } else if a == "--check" {
        parse_cli_loop(more, cli_with_mode(opts, MCheck))
      } else if a == "--dump-typed" {
        parse_cli_loop(more, cli_with_mode(opts, MDumpTyped))
      } else if a == "--dump-mono" {
        parse_cli_loop(more, cli_with_mode(opts, MDumpMono))
      } else if a == "--dump-mono-out" {
        parse_cli_loop(more, cli_with_mode(opts, MDumpMonoOut))
      } else if a == "--dump-last-use" {
        parse_cli_loop(more, cli_with_mode(opts, MDumpLastUse))
      } else if a == "--holes" {
        parse_cli_loop(more, cli_with_mode(opts, MHoles))
      } else if a == "--holes-json" {
        parse_cli_loop(more, cli_with_mode(opts, MHolesJson))
      } else if a == "--strict-holes" {
        parse_cli_loop(more, cli_with_strict_holes(opts))
      } else if a == "--emit=llvm" {
        parse_cli_loop(more, cli_with_mode(opts, MEmitLlvm))
      } else if a == "--test" {
        parse_cli_loop(more, cli_with_mode(opts, MTest))
      } else if a == "-h" or a == "--help" {
        parse_cli_loop(more, cli_with_mode(opts, MHelp))
      } else if a == "-V" or a == "--version" {
        parse_cli_loop(more, cli_with_mode(opts, MVersion))
      } else if a == "--prelude" {
        match more {
          [p, ...rest2] -> parse_cli_loop(rest2, cli_with_prelude(opts, p))
          [] -> {
            eprint("kaic1: --prelude requires a file argument")
            cli_with_mode(opts, MHelp)
          }
        }
      } else if a == "--path" {
        match more {
          [p, ...rest2] -> parse_cli_loop(rest2, cli_push_search_path(opts, p))
          [] -> {
            eprint("kaic2: --path requires a directory argument")
            cli_with_mode(opts, MHelp)
          }
        }
      } else {
        parse_cli_loop(more, cli_with_path(opts, a))
      }
    }
  }
}

fn parse_cli(argv: [String]) : CliOptions {
  parse_cli_loop(argv, CliOptions { mode: MDefault, path: None, preludes: [],
                                    strict_holes: false, search_paths: [] })
}

fn usage() : Unit / Console {
  eprint("usage: kaic2 [options] <file.kai>")
  eprint("  --prelude <file>   include <file>'s decls before the input")
  eprint("  --path <dir>       add <dir> to the module search path (repeatable)")
  eprint("  --tokens           print the token stream and exit")
  eprint("  --ast              parse and print the AST and exit")
  eprint("  --types            print declared top-level signatures and exit")
  eprint("  --env              print the full type environment (prelude + variants + decls)")
  eprint("  --infer            run HM inference over each fn body and dump the inferred type")
  eprint("  --check            run name resolution and HM inference; report errors and exit")
  eprint("  --dump-typed       run HM inference and dump the typed AST with per-node Ty")
  eprint("  --dump-mono        list call-site instantiations (name, loc, resolved type args)")
  eprint("  --dump-mono-out    list call-site instantiations with planned mangled monomorphic names")
  eprint("  --dump-last-use    list each fn parameter's last-use position (m5 #2 diagnostic)")
  eprint("  --holes            report every typed hole (`?` / `?name`) with expected type + scope")
  eprint("  --holes-json       same as --holes, but JSON array for machine consumption")
  eprint("  --strict-holes     treat every unfilled hole as a compilation error (default: warning)")
  eprint("  --emit=llvm        emit LLVM IR (.ll) instead of C; link with stage0/runtime_llvm.c")
  eprint("  --test             emit C wired to a test runner (runs test blocks)")
  eprint("  -h, --help         this help")
  eprint("  -V, --version      print version and exit")
}

# Parse a prelude file and return its decl list. On any error report
# to stderr and return None.
fn load_prelude(path: String) : Option[[Decl]] / Console + File {
  match read_file(path) {
    Err(msg) -> { eprint("kaic1: #{path}: #{msg}"); None }
    Ok(src) -> {
      let tokens = tokenize(src)
      let errs = report_errors(path, src, tokens)
      if errs != 0 { None }
      else {
        let parsed = parse_program(path, src, tokens)
        parsed.decls
      }
    }
  }
}

# Load every prelude file in `paths`, concatenating their decls in
# argument order. Returns None if any single load fails. Empty list
# yields Some([]).
fn load_preludes(paths: [String], acc: [Decl]) : Option[[Decl]] = match paths {
  [] -> Some(acc)
  [p, ...rest] -> match load_prelude(p) {
    None -> None
    Some(ds) -> load_preludes(rest, list_append(acc, ds))
  }
}

# m7a #7: builtin effect declarations. The runtime ships a default
# handler for these effects (Doc B §*Catalog*); the compiler injects
# the corresponding `effect` decls at the front of every program so
# the typer can resolve `Stdout.print(...)` etc. without the user
# writing a stdlib import. Each effect is only injected if the user
# (or an imported file) hasn't already declared it.
fn inject_builtin_effects(decls: [Decl]) : [Decl] = {
  let existing = collect_effect_names(decls)
  # m12.8.x phase 4 (Bug 6): the gate on which builtin effect decls
  # to inject is the union of every fn's declared row, not just
  # main's. Helper fns that declare `: Unit / Console` need Console
  # as a known effect even when main doesn't mention it.
  let used_row = collect_used_row_labels(decls)
  # m12.8 Phase 4b: Stdout / Stderr / Stdin are atomic DEffect
  # builtins; Console is the alias `Stdout + Stderr + Stdin` (per
  # stdlib/effects.kai's pinned catalog). User-declared aliases
  # (`type Io = Console + Env + File`, `type Net = Console + Stdin`,
  # etc.) can mention Console transitively, so the auto-inject must
  # not gate on a literal "Console" / "Stdout" appearance — the
  # alias resolver runs after this pass and pulls the labels in
  # via the alias graph. Inject all four unconditionally; downstream
  # passes see them as no-ops when nothing references them.
  let console_d = inject_unconditional(existing, "Console", builtin_console_decl())
  let stdout_d  = inject_unconditional(existing, "Stdout",  builtin_stdout_decl())
  let stderr_d  = inject_unconditional(existing, "Stderr",  builtin_stderr_decl())
  let fail_d    = inject_unconditional(existing, "Fail",    builtin_fail_decl())
  let stdin_d   = inject_unconditional(existing, "Stdin",   builtin_stdin_decl())
  let env_d     = inject_unconditional(existing, "Env",     builtin_env_decl())
  let file_d    = inject_unconditional(existing, "File",    builtin_file_decl())
  let random_d  = inject_unconditional(existing, "Random",  builtin_random_decl())
  # m7b #11: parametric stdlib effects (State[T], Reader[T], Writer[W])
  # have no runtime default handler — the user always writes an explicit
  # `with State[T](init)` form. Inject the declarations unconditionally
  # (gated only on "not already declared by the user"). The `Ev<Eff>`
  # struct is emitted alongside any declared effect; that is harmless
  # for parametric effects whose handlers are user-supplied.
  let state_d   = inject_unconditional(existing, "State",  builtin_state_decl())
  let reader_d  = inject_unconditional(existing, "Reader", builtin_reader_decl())
  let writer_d  = inject_unconditional(existing, "Writer", builtin_writer_decl())
  # m7b #2b: `Mutable` has a runtime default handler (the prelude
  # `kai_prelude_array_*` functions wrapped in clauses). Inject the
  # decl unconditionally so user code that intercepts mutation via
  # `handle ... with Mutable { ... }` (a body that absorbs the row
  # before main sees it) still resolves `Mutable.array_*` ops. The
  # default-handler setup is gated separately on `main`'s row in
  # `default_setups_for`.
  let mutable_d = inject_unconditional(existing, "Mutable", builtin_mutable_decl())
  # m8 #9: Link / Monitor — typer-side declarations only in v1; the
  # runtime registry + cross-fiber delivery land with the m8.x
  # cooperative scheduler.
  let link_d    = inject_unconditional(existing, "Link",    builtin_link_decl())
  let monitor_d = inject_unconditional(existing, "Monitor", builtin_monitor_decl())
  # m8 #2: Spawn ships the canonical pinning point op `yield()`. The
  # full op set (spawn / await / select / cancel) lands in #3, after
  # the per-op-generics shape is settled. inject_unconditional so the
  # typer always knows the effect exists — a helper declaring `/ Spawn`
  # in its row should compile regardless of whether `main` mentions
  # Spawn. The runtime default-handler push is still gated on main's
  # row in default_setups_for. (The same decoupling could be applied to
  # Console/Stdin/Env/File/Fail; that is an m7a #7 follow-up, not m8
  # scope.)
  let spawn_d   = inject_unconditional(existing, "Spawn",  builtin_spawn_decl())
  # m8 #4: Cancel — single op `raise() : Nothing`. Same
  # decoupling as Spawn: the typer always knows about it (so user-
  # written cleanup handlers `with Cancel { raise(_) -> ... }`
  # compile), but the runtime default-handler push is gated on main's
  # row in default_setups_for. Per Doc B §*Installation order*,
  # Cancel sits between the I/O group and Spawn (the root nursery
  # is what flags fibers for cancellation, but the Cancel handler
  # itself is the unwind target).
  let cancel_d  = inject_unconditional(existing, "Cancel", builtin_cancel_decl())
  # m8 #7: Actor[Msg] is parametric — no runtime default handler;
  # users always install their own (typically via stdlib/actor.kai's
  # `with_mailbox` helper).
  let actor_d   = inject_unconditional(existing, "Actor",  builtin_actor_decl())
  list_append(console_d,
    list_append(stdout_d,
      list_append(stderr_d,
        list_append(fail_d,
          list_append(stdin_d,
            list_append(env_d,
              list_append(file_d,
                list_append(random_d,
                  list_append(state_d,
                    list_append(reader_d,
                      list_append(writer_d,
                        list_append(mutable_d,
                          list_append(spawn_d,
                            list_append(cancel_d,
                              list_append(actor_d,
                                list_append(link_d,
                                  list_append(monitor_d, decls)))))))))))))))))
}

fn inject_one(main_row: [String], existing: [String],
              name: String, decl: Decl) : [Decl] {
  if list_has(main_row, name) and not list_has(existing, name) { [decl] }
  else { [] }
}

# m12.8.x phase 4 (Bug 6): aggregate every DFn's declared row labels
# (plus main's labels via main_row_labels). Used by
# `inject_builtin_effects` so a helper fn declaring `: Unit /
# Console` triggers the Console builtin injection even when main
# itself doesn't mention Console.
fn collect_used_row_labels(decls: [Decl]) : [String] {
  let main_row = main_row_labels(decls)
  collect_used_row_labels_loop(decls, main_row)
}

fn collect_used_row_labels_loop(decls: [Decl], acc: [String]) : [String] {
  match decls {
    [] -> acc
    [d, ...rest] -> match d {
      DFn(_, _, _, _, _, row, _, _, _) -> {
        let names = match row {
          REmpty       -> []
          RClosed(lbs) -> row_label_names(lbs)
          ROpen(_, lbs) -> row_label_names(lbs)
        }
        collect_used_row_labels_loop(rest, used_row_union(names, acc))
      }
      _ -> collect_used_row_labels_loop(rest, acc)
    }
  }
}

fn used_row_union(xs: [String], acc: [String]) : [String] {
  match xs {
    [] -> acc
    [x, ...rest] ->
      if list_has(acc, x) { used_row_union(rest, acc) }
      else { used_row_union(rest, [x, ...acc]) }
  }
}

# m7b #11: inject a builtin effect decl regardless of whether `main`'s
# row mentions it. Used for parametric stdlib effects that the user
# only ever reaches through an explicit `handle ... with Foo[T]` block.
fn inject_unconditional(existing: [String], name: String, decl: Decl) : [Decl] {
  if list_has(existing, name) { [] } else { [decl] }
}

fn ty_name_zero(name: String) : TypeExpr =
  TypeExpr { tkind: TyName(name, []), line: 0, col: 0 }

fn ty_named_zero(name: String, targs: [TypeExpr]) : TypeExpr =
  TypeExpr { tkind: TyName(name, targs), line: 0, col: 0 }

fn ty_list_zero(inner: TypeExpr) : TypeExpr =
  TypeExpr { tkind: TyList(inner), line: 0, col: 0 }

fn ty_option_string_zero() : TypeExpr =
  ty_named_zero("Option", [ty_name_zero("String")])

fn ty_result_string_string_zero() : TypeExpr =
  ty_named_zero("Result", [ty_name_zero("String"), ty_name_zero("String")])

fn ty_result_unit_string_zero() : TypeExpr =
  ty_named_zero("Result", [ty_name_zero("Unit"), ty_name_zero("String")])

fn ty_list_string_zero() : TypeExpr =
  ty_list_zero(ty_name_zero("String"))

fn param_string_zero(name: String) : Param =
  Param { pname: name, ptype: Some(ty_name_zero("String")),
          pline: 0, pcol: 0 }

# m7b #11: a parameter with an arbitrary TypeExpr annotation —
# used to declare parameterised effect ops whose param types
# reference an effect tparam (`set(v: T)`).
fn param_typed_zero(name: String, ty: TypeExpr) : Param =
  Param { pname: name, ptype: Some(ty), pline: 0, pcol: 0 }

# Names of every effect for which the compiler ships a built-in
# effect declaration (Doc B §*Catalog*). Kept in sync with the
# inject_builtin_effects helpers below; alias resolution accepts
# these as effect names whether or not the file already declared
# them via `effect`.
# m12.8 Phase 4b: `Console` is no longer a first-class effect — it
# is the auto-injected alias `Stdout + Stderr + Stdin`. Listing it
# here would let the alias resolver treat it as a leaf, short-
# circuiting the expansion. Other aliases (`Io`, user-declared) can
# still mention Console because the resolver routes through
# `cand_ns` for aliases.
fn builtin_effect_names() : [String] =
  ["Stdout", "Stderr", "Fail", "Stdin", "Env", "File", "Random", "State", "Reader", "Writer", "Mutable", "Spawn", "Cancel", "Actor", "Link", "Monitor"]

# m12.8 Phase 4b: `Console` is now an alias `type Console = Stdout +
# Stderr + Stdin` (per stdlib/effects.kai's pinned catalog), not a
# first-class effect. The atomic Stdout/Stderr/Stdin decls carry the
# actual ops; declaring `/ Console` in a row is an over-declaration
# that the alias resolver expands to the three atomic labels before
# the body-vs-declared subset check. Direct op calls of the form
# `Stdout.print(...)` no longer typecheck — users write
# `Stdout.print(...)` / `Stderr.eprint(...)` / `Stdin.read_line()`
# explicitly, or rely on the bare `print` / `eprint` / `read_line`
# sugar prelude that routes to the right atomic effect automatically.
fn builtin_console_decl() : Decl =
  DType(false, "Console", [], TBEffectAlias(["Stdout", "Stderr", "Stdin"]), 0, 0)

# m12.8 Phase 4b (atomic split): Stdout owns just `print`. The
# Stdout/Stderr split lets a user fn declare exactly the IO surface
# it touches. `Console` remains as the combined effect for
# backward-compat (over-declaration via alias subtyping).
fn builtin_stdout_decl() : Decl =
  DEffect(false, "Stdout", [],
    [EOp("print",  [], [param_string_zero("s")], ty_name_zero("Unit"), 0, 0)], 0, 0)

# m12.8 Phase 4b: Stderr owns just `eprint`.
fn builtin_stderr_decl() : Decl =
  DEffect(false, "Stderr", [],
    [EOp("eprint", [], [param_string_zero("s")], ty_name_zero("Unit"), 0, 0)], 0, 0)

fn builtin_fail_decl() : Decl =
  DEffect(false, "Fail", [],
    [
      EOp("fail", [], [param_string_zero("msg")], ty_name_zero("Nothing"), 0, 0)
    ], 0, 0)

fn builtin_stdin_decl() : Decl =
  DEffect(false, "Stdin", [],
    [EOp("read_line", [], [], ty_option_string_zero(), 0, 0)], 0, 0)

fn builtin_env_decl() : Decl =
  DEffect(false, "Env", [],
    [
      EOp("args", [], [], ty_list_string_zero(), 0, 0),
      EOp("var",  [], [param_string_zero("name")], ty_option_string_zero(), 0, 0)
    ], 0, 0)

fn builtin_file_decl() : Decl =
  DEffect(false, "File", [],
    [
      EOp("read_file", [],
          [param_string_zero("path")],
          ty_result_string_string_zero(), 0, 0),
      EOp("write_file", [],
          [param_string_zero("path"), param_string_zero("contents")],
          ty_result_unit_string_zero(), 0, 0)
    ], 0, 0)

# Random effect — Doc B §`Random`. v1 ships only `int_range`; the
# pinned catalog also lists `float()` and `bytes(n)` but those are
# deferred until a use case lands (juegos / sampling only need
# int_range; cripto goes through SecureRandom anyway). Default
# handler seeds PCG64 from time(NULL) ^ getpid() — see
# `kai_default_random_int_range` in stage0/runtime.h.
fn builtin_random_decl() : Decl =
  DEffect(false, "Random", [],
    [
      EOp("int_range", [],
          [Param { pname: "lo", ptype: Some(ty_name_zero("Int")),
                   pline: 0, pcol: 0 },
           Param { pname: "hi", ptype: Some(ty_name_zero("Int")),
                   pline: 0, pcol: 0 }],
          ty_name_zero("Int"), 0, 0)
    ], 0, 0)

# m7b #11: stdlib parameterised effects per Doc B §`State[T]` and
# §`Reader[T] and Writer[W]`. Each one gets its own evidence struct,
# its ops get polymorphic schemes via `add_effect_op_sigs`, and their
# clauses run as user-written handlers (no runtime default).
fn builtin_state_decl() : Decl =
  DEffect(false, "State", ["T"],
    [
      EOp("get", [], [], ty_name_zero("T"), 0, 0),
      EOp("set", [], [param_typed_zero("v", ty_name_zero("T"))],
          ty_name_zero("Unit"), 0, 0)
    ], 0, 0)

fn builtin_reader_decl() : Decl =
  DEffect(false, "Reader", ["T"],
    [
      EOp("ask", [], [], ty_name_zero("T"), 0, 0)
    ], 0, 0)

fn builtin_writer_decl() : Decl =
  DEffect(false, "Writer", ["W"],
    [
      EOp("tell", [], [param_typed_zero("w", ty_name_zero("W"))],
          ty_name_zero("Unit"), 0, 0)
    ], 0, 0)

# m7b #2b: `Mutable` effect — Doc B §`Mutable`. Per-op generics
# (#2a) make this declarable: each array op carries its own `[T]`,
# so a single handler instance serves every element type. The
# default handler (default_mutable_setup) wraps the prelude
# `kai_prelude_array_*` runtime functions and resumes.
#
# Divergence from Doc B: Doc B specifies
#   array_set[T](a, i, v) : Unit
# but stage 2's prelude `array_set` returns Array[T] (in-place
# mutation + return) so internal `xs = array_set(xs, i, v)` chains
# work. To keep stage 2's existing self-host code typing without
# rewriting every call site, the Mutable op signatures here mirror
# the prelude shape (Array[T] return). A future #2c can revisit
# this and migrate the compiler's internal callers if Doc B's Unit
# shape proves more idiomatic at the user surface.
#
# `ref_*` ops are deferred — kaikai has no surface `Ref[T]` type
# today (Doc B's Mutable.ref_* depends on it).
fn builtin_mutable_decl() : Decl =
  DEffect(false, "Mutable", [],
    [
      EOp("array_make", ["T"],
          [Param { pname: "n", ptype: Some(ty_name_zero("Int")),
                   pline: 0, pcol: 0 },
           param_typed_zero("init", ty_name_zero("T"))],
          ty_named_zero("Array", [ty_name_zero("T")]),
          0, 0),
      EOp("array_length", ["T"],
          [param_typed_zero("a", ty_named_zero("Array", [ty_name_zero("T")]))],
          ty_name_zero("Int"),
          0, 0),
      EOp("array_get", ["T"],
          [param_typed_zero("a", ty_named_zero("Array", [ty_name_zero("T")])),
           Param { pname: "i", ptype: Some(ty_name_zero("Int")),
                   pline: 0, pcol: 0 }],
          ty_name_zero("T"),
          0, 0),
      EOp("array_set", ["T"],
          [param_typed_zero("a", ty_named_zero("Array", [ty_name_zero("T")])),
           Param { pname: "i", ptype: Some(ty_name_zero("Int")),
                   pline: 0, pcol: 0 },
           param_typed_zero("v", ty_name_zero("T"))],
          ty_named_zero("Array", [ty_name_zero("T")]),
          0, 0),
      EOp("array_grow", ["T"],
          [param_typed_zero("a", ty_named_zero("Array", [ty_name_zero("T")])),
           Param { pname: "n", ptype: Some(ty_name_zero("Int")),
                   pline: 0, pcol: 0 },
           param_typed_zero("init", ty_name_zero("T"))],
          ty_named_zero("Array", [ty_name_zero("T")]),
          0, 0)
    ], 0, 0)

# m8 #7: Actor[Msg] — parameterised effect on the message type. Same
# m7b #11 machinery as State[T] / Reader[T] / Writer[W]: the effect-
# level tparam Msg substitutes into every op's signature. The user
# installs an Actor[Msg] handler via `with Actor[Msg](pid_value) {
# ... }`; the canonical wrapper `with_mailbox[Msg]` lives in
# stdlib/actor.kai. Doc B / docs/actors.md is the surface spec.
#
# `self()` returns the current actor's Pid; `send(p, m)` enqueues
# msg on p's mailbox; `receive()` dequeues from this actor's
# mailbox. v1 receives synchronously — calling receive() on an
# empty mailbox is a runtime error because the inline-eager
# scheduler can't suspend. Real blocking receive lands with the m8.x
# scheduler. Six-field EOp shape (op_tparams = [], no per-op generics
# beyond the effect-level Msg).
fn builtin_actor_decl() : Decl =
  DEffect(false, "Actor", ["Msg"],
    [
      EOp("self", [], [], ty_named_zero("Pid", [ty_name_zero("Msg")]), 0, 0),
      EOp("send", [],
          [param_typed_zero("pid", ty_named_zero("Pid", [ty_name_zero("Msg")])),
           param_typed_zero("msg", ty_name_zero("Msg"))],
          ty_name_zero("Unit"), 0, 0),
      EOp("receive", [], [], ty_name_zero("Msg"), 0, 0)
    ], 0, 0)

# m8 #9: Link — bidirectional supervision. `link(peer)` registers a
# bidirectional crash-propagation between the current actor and
# `peer`: if either crashes, the other receives `Cancel.raise()` at
# its next yield point. v1 declares the type surface but the cross-
# fiber propagation lands with the m8.x cooperative scheduler — in
# the inline-eager v1 a child fiber's panic aborts the program before
# any peer can react. The Doc spec uses `Pid[_]` (existential pid);
# v1 uses Pid[Nothing] which TyAny-erases the message type, giving
# the same "any pid" surface without needing existential types in
# the typer.
fn builtin_link_decl() : Decl =
  DEffect(false, "Link", [],
    [
      EOp("link", [], [param_typed_zero("peer", ty_named_zero("Pid", [ty_name_zero("Nothing")]))],
          ty_name_zero("Unit"), 0, 0)
    ], 0, 0)

# m8 #9: Monitor — unidirectional supervision. `monitor(target)`
# registers the current actor as an observer of `target`; when
# `target` terminates, a `MonitorDown(ref, cause)` message is
# delivered to the observer's own mailbox. `demonitor(ref)`
# withdraws the subscription. v1 declares the type surface; the
# runtime registry + delivery on termination land with the m8.x
# scheduler. Demos exercise the supervision *pattern* through the
# Actor[Msg] mailbox + spawn primitives directly.
fn builtin_monitor_decl() : Decl =
  DEffect(false, "Monitor", [],
    [
      EOp("monitor", [], [param_typed_zero("target", ty_named_zero("Pid", [ty_name_zero("Nothing")]))],
          ty_name_zero("MonitorRef"), 0, 0),
      EOp("demonitor", [], [param_typed_zero("ref", ty_name_zero("MonitorRef"))],
          ty_name_zero("Unit"), 0, 0)
    ], 0, 0)

# m8 #4: Cancel — single op `raise() : Nothing`. Doc B §`Cancel`.
# The default handler exits the program with a banner; user code
# installs its own `with Cancel { raise(resume) -> cleanup }` to
# catch the unwind and run cleanup. Cooperative-yield delivery
# (the scheduler injecting Cancel.raise() at the next op-call
# boundary) lands together with the m8.x ucontext or full-CPS
# scheduler. Six-field EOp shape (op_tparams = [], no per-op
# generics).
fn builtin_cancel_decl() : Decl =
  DEffect(false, "Cancel", [],
    [
      EOp("raise", [], [], ty_name_zero("Nothing"), 0, 0)
    ], 0, 0)

# m8 #2/#3: Spawn — non-parametric effect. Per Doc B §`Spawn`, the
# user-facing API is polymorphic (`spawn[T, e]`, `await[T]`, etc.).
# m7b #2a (per-op TYPE generics) is now in main, but Doc B's `spawn`
# also wants a per-op ROW generic (`/ e`), which is a separate
# extension. v1 sidesteps both by declaring spawn / await / select /
# cancel with type-erased parameter and return types
# (`Nothing` → TyAny in the typer); the polymorphic surface lives in
# `stdlib/spawn.kai` as fn-level wrappers (m7b #13 + m7b #14 give
# the type-param + lambda-row machinery the wrappers need).
# `yield()` is the canonical pinning point per Doc B §`Cancel` /
# Delivery points; it stays monomorphic.
#
# EOp shape is m7b #2a's six-field form (name, op_tparams, params,
# ret, line, col); none of these ops use per-op tparams in v1, so
# op_tparams stays []. Migration to the proper Doc B signatures is
# tracked in `docs/m8x-followup.md` item 7.
fn builtin_spawn_decl() : Decl =
  DEffect(false, "Spawn", [],
    [
      EOp("yield",  [], [], ty_name_zero("Unit"), 0, 0),
      EOp("spawn",  [], [param_typed_zero("thunk", ty_name_zero("Nothing"))],
                    ty_name_zero("Nothing"), 0, 0),
      EOp("await",  [], [param_typed_zero("fiber", ty_name_zero("Nothing"))],
                    ty_name_zero("Nothing"), 0, 0),
      EOp("select", [], [param_typed_zero("fibers", ty_name_zero("Nothing"))],
                    ty_name_zero("Nothing"), 0, 0),
      EOp("cancel", [], [param_typed_zero("fiber", ty_name_zero("Nothing"))],
                    ty_name_zero("Unit"), 0, 0)
    ], 0, 0)

fn compile_source(path: String, mode: Mode, strict_holes: Bool, search_paths: [String], src: String, prelude_decls: [Decl]) : Int / Console {
  let tokens = tokenize(src)
  let lex_errs = report_errors(path, src, tokens)
  match mode {
    MTokens -> {
      dump_tokens(src, tokens)
      lex_errs
    }
    MHelp -> { usage(); 0 }
    _ -> {
      if lex_errs != 0 { lex_errs }
      else {
        let parsed = parse_program(path, src, tokens)
        match parsed.decls {
          None -> 1
          Some(own_decls) -> {
            let expanded = expand_imports(path, search_paths, own_decls)
            let merged = list_append(prelude_decls, expanded)
            # m7b #1b + m12.8 Phase 4b — closed effect aliases. Resolve
            # every `type Foo = Eff1 + Eff2 + ...` (and `type Foo = Eff`
            # single-name form) into a flat label set and rewrite every
            # DFn's RowExpr to substitute alias names. Phase 4b: builtin
            # effect injection runs *first* so the auto-injected
            # `type Console = Stdout + Stderr` alias participates in
            # alias resolution alongside user-declared aliases. Builtin
            # effect names still participate in the namespace whether or
            # not the file declared an `effect` for them. Cycles and
            # non-effect labels in alias bodies are fatal.
            let injected = inject_builtin_effects(merged)
            let declared_effs = collect_effect_names(injected)
            let eff_names_for_alias = list_append(builtin_effect_names(), declared_effs)
            let alias_cands = collect_alias_cands(injected)
            let alias_res = resolve_alias_cands(alias_cands, eff_names_for_alias, path)
            let raw_decls = expand_aliases_in_decls(injected, alias_res.aliases)
            # m7b #6: pre-resolve desugar of `a[i]` and `a[i] := v` into
            # the underlying array_get / array_set calls. Runs before
            # name resolution so every downstream pass sees only the
            # core form. `--ast` keeps the raw decls so the dump shows
            # the sugar as written.
            # m7b #5b: pre-resolve desugar of `var name = init` into
            # `handle { rest } with State[T](init) as name { ... }`.
            # Runs after the index desugar so any `a[i]` inside a
            # `var`'s init or its rest-of-block has already been
            # lowered to a call.
            let indexed_decls = desugar_index_decls(raw_decls)
            let var_decls = desugar_var_decls(indexed_decls)
            # m12.8: lower protocols / impls / #derive into ordinary
            # top-level fns + a registry the post-inference rewrite
            # consumes. The registry-driven dispatch resolution runs
            # later, after `infer_program` populates `Expr.ty`.
            let lowered = lower_protocols(var_decls, path)
            # m12.8.x phase 2 (Bug 4): lift `#{x}` interp parts into
            # `string_concat_all([..., show(x), ...])` so the typer +
            # protocol-call rewrite see them. Conditional on `Show`
            # being declared (op_names contains "show"); otherwise
            # the legacy emit-time `kai_to_string` path remains.
            let all_decls = desugar_interp_decls(lowered.decls,
                                                  lowered.reg.op_names)
            let proto_reg = lowered.reg
            let proto_errs = lowered.errs
            if alias_res.errs > 0 { alias_res.errs }
            else if proto_errs > 0 { proto_errs }
            else {
            match mode {
              MAst -> { dump_program(raw_decls); 0 }
              MTypes -> { dump_types(own_decls); 0 }
              MEnv -> { dump_env(build_ty_env(all_decls).env); 0 }
              MInfer -> dump_infer(path, all_decls)
              MCheck -> {
                let chk = check_program(path, all_decls)
                if chk != 0 { chk } else { check_infer(path, all_decls) }
              }
              MDumpTyped -> {
                let chk = check_program(path, all_decls)
                if chk != 0 { chk } else { dump_typed(path, all_decls) }
              }
              MDumpMono -> {
                let chk = check_program(path, all_decls)
                if chk != 0 { chk } else { dump_mono(path, all_decls) }
              }
              MDumpMonoOut -> {
                let chk = check_program(path, all_decls)
                if chk != 0 { chk } else { dump_mono_out(path, all_decls) }
              }
              MDumpLastUse -> {
                let chk = check_program(path, all_decls)
                if chk != 0 { chk } else { dump_last_use(path, all_decls) }
              }
              MHoles -> {
                let chk = check_program(path, all_decls)
                if chk != 0 { chk } else { dump_holes(path, all_decls) }
              }
              MHolesJson -> {
                let chk = check_program(path, all_decls)
                if chk != 0 { chk } else { dump_holes_json(path, all_decls) }
              }
              _ -> {
                let chk = check_program(path, all_decls)
                if chk != 0 { chk }
                else {
                  let typed_prog0 = infer_program(path, all_decls, false)
                  # m12.8: post-inference protocol-call rewrite.
                  # `Expr.ty` is populated for every node now, so each
                  # `op(x, ...)` call can be redirected to the matching
                  # `__pimpl_<P>_<T>_<op>` direct call. Sites with
                  # unknown types fall through and execute the
                  # dispatcher fn's panic at runtime.
                  let typed_prog = resolve_protocol_calls(typed_prog0, proto_reg)
                  # m12.8.x phase 2 (Bug 5): walk the post-rewrite
                  # AST and report any `__proto_<op>` call whose
                  # receiver type is concrete but has no matching
                  # impl. Polymorphic helpers whose receiver is a
                  # TyVar at this point keep the v1 runtime
                  # fallthrough behaviour.
                  let dispatch_errs =
                    validate_resolved_protocols(typed_prog, proto_reg, path)
                  # m12.8.x post-Core REOPEN — Eric level 2: rep
                  # invariant verifier. Fails the compile when any of
                  # the three structural properties is violated. See
                  # `validate_typer_invariants` for the catalog.
                  let inv_errs = validate_typer_invariants(typed_prog, path)
                  if typed_prog.errs != 0 { typed_prog.errs }
                  else if dispatch_errs != 0 { dispatch_errs }
                  else if inv_errs != 0 { inv_errs }
                  else {
                    let hole_errs = if strict_holes { strict_holes_check(path, all_decls) } else { 0 }
                    if hole_errs != 0 { hole_errs }
                    else {
                      # m4c #1 — identity monomorphise. Hands typed decls
                      # to the next pass; semantics unchanged because the
                      # emitter does not read `Expr.ty`.
                      let mono_decls = monomorphise(typed_prog)
                      # m5 #1 — basic Perceus walker (identity).
                      # m5 #2-#4 fill in last-use analysis + dup/drop.
                      let perceus_decls = perceus_pass(mono_decls)
                      let test_mode = match mode { MTest -> true _ -> false }
                      let use_llvm = match mode { MEmitLlvm -> true _ -> false }
                      let out = if use_llvm {
                        emit_program_llvm(path, src, perceus_decls, test_mode)
                      } else {
                        emit_program(path, src, perceus_decls, test_mode)
                      }
                      print(out)
                      0
                    }
                  }
                }
              }
            }
            }
          }
        }
      }
    }
  }
}

fn run(opts: CliOptions) : Int / Console + File {
  match opts.mode {
    MHelp -> { usage(); 0 }
    MVersion -> { print("kaic2 stage 2 (self-hosted)"); 0 }
    _ -> match opts.path {
      None -> { usage(); 2 }
      Some(p) -> {
        # Bug multi-prelude (m12.8 v1): the previous implementation
        # held a single Option[String] and silently dropped all but
        # the last `--prelude` flag. Fixed: accumulate every prelude
        # and concatenate the loaded decls in argument order. Names
        # in later preludes shadow earlier ones (intentional —
        # callers pass `--prelude` in dependency order).
        let prelude_decls = load_preludes(opts.preludes, [])
        match prelude_decls {
          None -> 1
          Some(pds) -> match read_file(p) {
            Ok(src) -> compile_source(p, opts.mode, opts.strict_holes, opts.search_paths, src, pds)
            Err(msg) -> { eprint("kaic1: #{p}: #{msg}"); 1 }
          }
        }
      }
    }
  }
}

fn main() {
  let code = run(parse_cli(args()))
  exit(code)
}
