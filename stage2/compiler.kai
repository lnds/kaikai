    "    kai_evidence_push(&_kai_default_node_stdin, \"Stdin\", &_kai_default_ev_stdin);\n"
  ])

fn default_env_shims() : String =
  concat_all([
    "static KaiValue *_kai_default_env_args_shim(EvEnv *self, KaiCont *k) {\n",
    "    return kai_default_env_args(self, k);\n",
    "}\n",
    "static KaiValue *_kai_default_env_var_shim(EvEnv *self, KaiValue *kai_name, KaiCont *k) {\n",
    "    return kai_default_env_var(self, kai_name, k);\n",
