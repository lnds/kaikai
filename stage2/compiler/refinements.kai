# compiler/refinements.kai — refinement-type discharge: contract
# desugaring helpers, regex-predicate subsumption, the compile-time
# partial evaluator, and the issue #83 call-site substitution
# analysis.
#
# Extracted from main.kai under issue #677 Phase 1h (sub-lane H1).
# This is the static-analysis machinery that proves (or fails to
# prove) refinement predicates at compile time. It is NOT parsing:
# the parser produces `requires` / `ensures` / refined-param AST, and
# this module consumes that AST to either elide a runtime assert,
# keep it, or raise a static contradiction.
#
# What stays in main.kai (couples to the Parser)
#
# - `Contracts`, `parse_contracts_loop`, `check_pred_not_false`,
#   `maybe_wrap_pure` — these thread the `Parser` value (Contracts
#   carries `p: Parser`), so they live with the parser until parse.kai
#   extracts. `parse_contracts_loop` calls into `check_pred_not_false`
#   (also parser-coupled), which in turn calls this module's
#   `try_eval_pred`.
#
# Public surface (8 pub fns; everything else is module-private)
#
# - wrap_with_contracts — called from parse_decl to desugar a fn body.
# - find_impure_call / refinement_pure_names — the contract-purity
#   checker, reached from validate_contract_predicates.
# - synth_refine_pred_fn_name — the refinement-alias pred-fn name,
#   shared with the post-parse synthesiser in main.kai.
# - try_eval_int / try_eval_pred — the partial evaluator; try_eval_int
#   is also used by the `^` integer-power codegen (C and LLVM paths).
# - check_call_site_refinements / dump_call_elision — the issue #83
#   call-site analysis entry points, driven from main.kai's pipeline
#   and the --dump-call-elision flag.
#
# Cross-module dependencies
#
# - compiler.util — cat/concat_all, char_at_or_zero, list_has,
#   list_is_empty, string_lt, escape_str_body_for_c.
# - compiler.chars — ch_is_digit (the regex character-class parser).
# - compiler.ast — Expr / ExprKind / Decl / Stmt / Param / Arm /
#   FieldInit / ListElem / Pattern + the variant tags, plus the
#   constructor helper mk_expr.
# - compiler.intervals — Interval / Ival / ival_lt / ival_le /
#   ival_gt / ival_ge / ival_eq / ival_ne for the interval-based
#   entailment path.
#
# Single-line `#[doc(...)]` only — kaic1 still consumes the
# concatenated bundle and does not accept triple-quoted strings
# inside attributes (#677 Phase 2 retires that constraint once
# separate compilation lands).

import compiler.util
import compiler.chars
import compiler.ast
import compiler.intervals
import compiler.refine_help

# m12.6.x #3 v2: the synthesised pred-fn name for a refinement-type
# alias. Centralised so the call-site builder and the post-parse
# generator agree on the spelling.
#[doc("Mint the synthesised predicate-fn name for a refinement-type alias (`__ref_pred_<Type>`).")]
pub fn synth_refine_pred_fn_name(tyname: String) : String =
  string_concat("__ref_pred_", tyname)

# Enforce that a contract predicate (`requires` / `ensures`) calls
# only effect-pure functions. Walks the Expr tree once; the first
# call to a function whose declared effect row is non-empty lands as
# an error pointing at the offending span.
#
# Purity is NOT a hand-maintained name list: a function is pure iff
# its declared effect row is `REmpty` (the `: T` form with no `/ e`).
# That fact lives on the function's type, computed and checked by the
# effect system — the typer already rejects a `REmpty` signature whose
# body performs an effect. So we read the row off the callee's `DFn`
# in `decls` (which by construction includes the prelude + every
# imported module, so cross-module calls resolve) and admit the call
# when the row is empty. A callee that resolves to no `DFn` (operator
# desugar, compiler builtin) carries no effect row and is admitted:
# effects only ever enter through a fn with a non-empty row.
#
# What is allowed:
#  - Literals (Int, Real, Bool, Char, String, EUnit)
#  - EVar (parameter / `self` / `result` / outer locals)
#  - EField, EIndex (read-only access)
#  - EBinop, EUnop (the standard arithmetic / boolean operators)
#  - EIf (allowed for short-circuiting)
#  - ECall / EModCall whose callee is an effect-pure fn (row `REmpty`)

# True when `name` resolves to a `DFn` whose declared effect row is
# empty, or to no `DFn` at all (operator / builtin — no row to carry
# an effect). Threads `decls` as the resolution context; matches on
# the bare fn name (qualified calls land here with the op name only,
# the same key the typer's qualified env uses).
#[doc("True when a callee name is effect-pure: its DFn row is REmpty, or it resolves to no DFn.")]
pub fn callee_is_effect_pure(name: String, decls: [Decl]) : Bool =
  match decl_row_of_fn(name, decls) {
    None       -> true        # not a DFn — operator / builtin, no effect row
    Some(row)  -> match row {
      REmpty -> true
      _      -> false
    }
  }

# Find the declared effect row of the `DFn` named `name` in `decls`.
# `None` when no such `DFn` exists. Unwraps the decl wrappers
# (`DAttribPure` is gone, but `DDerive` / origin-tagged fns still
# nest a DFn) so a wrapped pure fn still resolves.
fn decl_row_of_fn(name: String, decls: [Decl]) : Option[RowExpr] {
  match decls {
    [] -> None
    [d, ...rest] -> match d {
      DFn(_, dn, _, _, _, row, _, _, _, _) ->
        if dn == name { Some(row) } else { decl_row_of_fn(name, rest) }
      _ -> decl_row_of_fn(name, rest)
    }
  }
}

# Walk an Expr looking for the first call whose callee is not
# effect-pure. Returns the offending name, or None when pure.
#[doc("Find the first call in an Expr to a non-effect-pure fn; None when the expression is pure.")]
pub fn find_impure_call(e: Expr, decls: [Decl]) : Option[String] {
  match e.kind {
    EInt(_) -> None
    EReal(_, _) -> None
    EFixed(_, _) -> None
    EBool(_) -> None
    EChar(_) -> None
    EStr(_, _) -> None
    EUnit -> None
    EVar(_) -> None
    EField(b, _) -> find_impure_call(b, decls)
    EIndex(a, b) -> match find_impure_call(a, decls) {
      Some(n) -> Some(n)
      None -> find_impure_call(b, decls)
    }
    EBinop(_, a, b) -> match find_impure_call(a, decls) {
      Some(n) -> Some(n)
      None -> find_impure_call(b, decls)
    }
    EUnop(_, x) -> find_impure_call(x, decls)
    EIf(c, t_, eo) -> match find_impure_call(c, decls) {
      Some(n) -> Some(n)
      None -> match find_impure_call(t_, decls) {
        Some(n) -> Some(n)
        None -> match eo {
          Some(eb) -> find_impure_call(eb, decls)
          None -> None
        }
      }
    }
    ECall(callee, args_) -> {
      let callee_check = match callee.kind {
        EVar(name) ->
          if callee_is_effect_pure(name, decls) { None }
          else { Some(name) }
        # Qualified calls (`module.op(...)`) land as EModCall carrying
        # the bare op name — the same key `decls` is indexed by.
        EModCall(_, name) ->
          if callee_is_effect_pure(name, decls) { None }
          else { Some(name) }
        _ -> Some("<expression>")
      }
      match callee_check {
        Some(n) -> Some(n)
        None -> find_impure_call_args(args_, decls)
      }
    }
    _ -> Some("<unsupported>")
  }
}

fn find_impure_call_args(args_: [Expr], decls: [Decl]) : Option[String] {
  match args_ {
    [] -> None
    [a, ...rest] -> match find_impure_call(a, decls) {
      Some(n) -> Some(n)
      None -> find_impure_call_args(rest, decls)
    }
  }
}

# m12.6.b: desugar contracts into asserts inside the body. The
# semantics are:
#   requires P  -> assert P at function entry
#   ensures  Q  -> assert Q after binding `result` to the body's value
# The combined shape is a single EBlock:
#   { assert P1; ...; let result = body; assert Q1; ...; result }
# The block's final expression is `result` so the function still
# returns the body's value. When both lists are empty, the body is
# returned unchanged so functions without contracts cost nothing.
#[doc("Desugar a fn body, wrapping it in requires/ensures asserts; returns the body unchanged when both contract lists are empty.")]
pub fn wrap_with_contracts(body: Expr, reqs: [Expr], enss: [Expr],
                       params: [Param], fn_name: String,
                       line: Int, col: Int) : Expr {
  if reqs == [] and enss == [] { body } else {
    let pp = collect_param_preds(params, [])
    let req_stmts = preds_to_asserts(reqs, [], "requires", pp, fn_name, params)
    if enss == [] {
      if req_stmts == [] { body }
      else { mk_expr(EBlock(req_stmts, Some(body)), line, col) }
    } else {
      # m12.6.c: bind `result` to the body's value so `ensures`
      # predicates can reference it. The shape is
      #   { req_asserts; let result = body; ens_asserts; result }
      let bind_pat = mk_pat(PBind("result"), line, col)
      let bind = SLet(bind_pat, None, body)
      let ens_stmts = preds_to_asserts(enss, [], "ensures", pp, fn_name, params)
      if req_stmts == [] and ens_stmts == [] { body }
      else {
        let res_var = mk_expr(EVar("result"), line, col)
        let stmts = list_append(req_stmts, [bind, ...ens_stmts])
        mk_expr(EBlock(stmts, Some(res_var)), line, col)
      }
    }
  }
}

fn preds_to_asserts(preds: [Expr], acc: [Stmt], kind: String,
                     param_preds: [ParamPred], fn_name: String,
                     params: [Param]) : [Stmt] {
  match preds {
    [] -> list_reverse(acc)
    # m12.6.d: drop trivially-true predicates at parse time.
    # m12.6.x #2: drop a predicate that is structurally identical to
    # some param's refinement — the type-system already guarantees
    # it. (Caller-side narrowing into the refined type is the proof
    # obligation; the callee body inherits the refinement for free.)
    # m12.6.x #8 v2 (#86): build a structured message containing the
    # clause kind, the function name, the rendered predicate text, and
    # the decl-site line/col. The leading `"requires violated` /
    # `"ensures violated` prefix is preserved so contract_assert_kind
    # / extract_requires_asserts (which key off the prefix) keep
    # working. Call-site span and runtime value formatting are
    # follow-up (see docs/refinements-and-contracts.md v2 sidebar).
    [p, ...rest] -> {
      if pred_entailed_by_params(p, param_preds) {
        preds_to_asserts(rest, acc, kind, param_preds, fn_name, params)
      } else { match try_eval_pred(p) {
        Some(true) -> preds_to_asserts(rest, acc, kind, param_preds, fn_name, params)
        _          -> {
          let msg_span = build_violation_msg_span(kind, fn_name, p, params)
          let msg = mk_expr(EStr(msg_span, false), p.line, p.col)
          preds_to_asserts(rest, [SAssert(p, Some(msg)), ...acc], kind, param_preds, fn_name, params)
        }
      } }
    }
  }
}

# m12.6.x #8 v2 (#86): assemble the multi-line panic message for a
# contract violation. The result is the *raw* EStr span (including
# surrounding double quotes and backslash-escaped newlines) so the
# emitter can pass it through as a C string literal unchanged. Format:
#
#   "requires violated in `<fn>`\nrequired: <pred>\ndeclared at line N, col C"
#
# When printed by `kai_prelude_panic` the `\n` escapes render as real
# line breaks, producing a multi-line diagnostic. The leading
# `"requires violated` / `"ensures violated` prefix is kept so the
# detectors at extract_requires_asserts / contract_assert_kind still
# classify the assert as contract-derived.
fn build_violation_msg_span(kind: String, fn_name: String, p: Expr,
                            params: [Param]) : String {
  let pred_text = escape_str_body_for_c(expr_show_pred(p))
  let fn_text = escape_str_body_for_c(fn_name)
  concat_all([
    "\"", kind, " violated in `", fn_text, "`",
    "\\nrequired: ", pred_text,
    "\\ndeclared at line ", int_to_string(p.line),
    ", col ", int_to_string(p.col),
    violation_help_suffix(kind, p, params), "\""
  ])
}

# Issue #750 (piece-3 of #86): the `help: narrow` suggestion. Only a
# `requires` clause whose predicate is the single-ident `<ident> <cmp>
# <literal>` shape (the same shape piece-2 attaches a runtime value to)
# carries a help line; `ensures` clauses reference `result`, not a
# param, so they never match and fall through to "". The base type comes
# from the offending param's declared annotation (see refine_help.kai),
# so an unannotated param also yields "" — piece-1 with no regression.
fn violation_help_suffix(kind: String, p: Expr, params: [Param]) : String {
  if kind != "requires" { "" }
  else { match contract_single_ident(p) {
    None -> ""
    Some(ident) -> requires_help_line(ident, p, params)
  } }
}

# m12.6.x #2: collect every refinement predicate that appears on a
# fn parameter's TypeExpr, paired with the owning parameter's name.
# Used by preds_to_asserts to omit a `requires` clause that just
# restates a param's refinement. The owning name lets the regex
# subsumption check (m12.6.x #7b) tie a param-side `self` reference
# back to the user-written param name on the requires side, and lets
# Issue #83's alpha + operator + interval entailment rewrite `self`
# to the param name on the fly before comparing canonical forms.
type ParamPred = PPair(String, Expr)
#                       ^pname  ^pred ast

fn collect_param_preds(params: [Param], acc: [ParamPred]) : [ParamPred] {
  match params {
    [] -> list_reverse(acc)
    [p, ...rest] -> match p.ptype {
      Some(t) -> match t.tkind {
        TyRefine(_, pred) -> collect_param_preds(rest, [PPair(p.pname, pred), ...acc])
        _ -> collect_param_preds(rest, acc)
      }
      None -> collect_param_preds(rest, acc)
    }
  }
}

# Issue #83: a `requires P` predicate is entailed by a refined-param
# predicate when any of the following discharges fires:
#   - bare structural equality (legacy m12.6.x #2 v1 case);
#   - regex subsumption (m12.6.x #7b — closes #157);
#   - canonical comparison + `self ↦ pname` substitution
#     (Issue #83 sub-cases 1 alpha + 2 operator);
#   - interval lattice (Issue #83, e.g. `requires x > 0` discharged
#     by `Int where x >= 1`).
# Sound by construction: every arm only returns `true` when the
# requires-side predicate is provably implied by the param-side one.
# When in doubt the runtime assert is preserved.
fn pred_entailed_by_params(pred: Expr, param_preds: [ParamPred]) : Bool {
  match param_preds {
    [] -> false
    [pp, ...rest] -> match pp {
      PPair(pname, pp_expr) -> {
        if expr_struct_eq(pred, pp_expr) { true }
        else if regex_pred_subsumed(pred, pname, pp_expr) { true }
        else {
          let canon_req = pred_canon(pred)
          let canon_ref = pred_canon(subst_self(pp_expr, pname))
          if expr_struct_eq(canon_req, canon_ref) { true }
          else if pred_entailed_by_refinement(canon_req, pname, canon_ref) { true }
          else { pred_entailed_by_params(pred, rest) }
        }
      }
    }
  }
}

# m12.6.x #7b — regex predicate subsumption (closes #157).
#
# When the requires-clause's `pred` is `matches(self, ~r/loose/)` and
# some param refinement `pp` is `matches(self, ~r/strict/)`, the
# requires assert is redundant iff L(strict) ⊆ L(loose). The full DFA-
# difference algorithm is decidable for the v1 regex subset (no
# backrefs, no lookaround); a future extension can lift the
# stdlib `regex_compile` engine into the typer for general
# containment.
#
# v1 ships a structural shape matcher: each side must match the
# anchored grammar `^ <atom> <quant>? $`, where atom is a single
# character class (or built-in escape) and quant is one of `+`, `*`,
# `?`, or `{n,m}`. Both sides must use the same quant. Containment
# then reduces to ASCII charset containment over 0..127. Anything
# outside this shape — alternation, concat, groups, anchored prefix
# `^acc_`, etc. — bails to false (the runtime assert is preserved,
# which is sound — we just don't drop it).
#
# The bound is the ~256-element shape (one ASCII charset per side);
# DFAs in the general algorithm are bounded at 1024 states. Since the
# structural matcher does no NFA->DFA construction, the bound never
# fires in v1 — but the entry point keeps the same fail-closed
# contract: `false` (= keep the assert) when in doubt.
fn regex_pred_subsumed(pred: Expr, pname: String, param_pred: Expr) : Bool {
  # Requires-side: the user-written receiver must equal the parameter
  # name. Param-side: the receiver is the parser-inserted `self`.
  match pred_regex_pattern_named(pred, pname) {
    None -> false
    Some(loose) -> match pred_regex_pattern_named(param_pred, "self") {
      None -> false
      Some(strict) -> regex_pattern_contains(loose, strict)
    }
  }
}


# Recognise an Expr of the shape `matches(<recv>, regex_compile_or_panic
# ("..."))` where `<recv>` is the bare ident `expected_recv`. Returns
# the raw pattern (sigil-body bytes) on a hit, None otherwise. The
# explicit receiver name keeps the regex-subsumption path sound when a
# function has multiple refined parameters: a param-side `self`
# refinement on `x` only entails a requires-side `matches(x, …)`,
# never `matches(y, …)`.
fn pred_regex_pattern_named(e: Expr, expected_recv: String) : Option[String] {
  match e.kind {
    ECall(callee, cargs) -> match callee.kind {
      EVar(name) ->
        if name == "matches" {
          match cargs {
            [recv, re] -> match recv.kind {
              EVar(rn) -> if rn == expected_recv { extract_regex_literal(re) } else { None }
              _ -> None
            }
            _ -> None
          }
        } else { None }
      _ -> None
    }
    _ -> None
  }
}

# `regex_compile_or_panic("...")` over a literal `EStr` pattern is the
# only shape the sigil desugar emits. Reach inside, strip the outer
# `"..."` quotes, and decode the two backslash escapes the sigil
# parser introduces (`\\` -> `\`, `\"` -> `"`).
fn extract_regex_literal(re: Expr) : Option[String] {
  match re.kind {
    ECall(callee, cargs) -> match callee.kind {
      EModCall(mod, fname) ->
        if mod == "regexp" and fname == "compile_or_panic" {
          match cargs {
            [arg0] -> match arg0.kind {
              EStr(span, false) -> Some(decode_regex_str_span(span))
              _ -> None
            }
            _ -> None
          }
        } else { None }
      _ -> None
    }
    _ -> None
  }
}

# Strip leading/trailing `"` and decode `\\`/`\"` back to literal `\`
# and `"`. Mirrors the encoding done by `regex_pattern_to_kai_str_body`
# in the sigil parser. Returns the empty string when the span is
# malformed (which `EStr(_, false)` never is in practice — the
# parser would have rejected it).
fn decode_regex_str_span(span: String) : String {
  let n = string_length(span)
  if n < 2 { "" } else { decode_regex_loop(span, 1, n - 1, "") }
}

fn decode_regex_loop(span: String, i: Int, end: Int, acc: String) : String {
  if i >= end { acc } else {
    let c = char_at_or_zero(span, i)
    if c == '\\' and i + 1 < end {
      let c2 = char_at_or_zero(span, i + 1)
      decode_regex_loop(span, i + 2, end, string_concat(acc, "#{c2}"))
    } else {
      decode_regex_loop(span, i + 1, end, string_concat(acc, "#{c}"))
    }
  }
}

# Top-level containment on raw pattern strings. Returns true iff
# every string accepted by `strict` is also accepted by `loose`.
# Conservative: returns false when either side falls outside the
# anchored-class shape the typer recognises in v1.
fn regex_pattern_contains(loose: String, strict: String) : Bool {
  match parse_anchored_class(loose) {
    None -> false
    Some(la) -> match parse_anchored_class(strict) {
      None -> false
      Some(sa) -> ac_contains(la, sa)
    }
  }
}

# Anchored-class shape: `^ <class> <quant>? $`. The class is a
# 128-bool ASCII mask (string of '0'/'1'). The quant is one of "+",
# "*", "?", "1" (no quant — must match exactly one char), or a
# `{n,m}` rendered as "n,m" (or "n," for unbounded). For v1 the
# matcher only proves containment when both sides share an
# *identical* quant string — strictly the same shape.
type AnchoredClass = RxAC(String, String)
#                       ^mask  ^quant

fn parse_anchored_class(pat: String) : Option[AnchoredClass] {
  let n = string_length(pat)
  # Require leading `^` and trailing `$`.
  if n < 2 { None }
  else if char_at_or_zero(pat, 0) != '^' { None }
  else if char_at_or_zero(pat, n - 1) != '$' { None }
  else {
    # Parse the class atom starting at position 1.
    match parse_class_atom(pat, 1, n - 1) {
      None -> None
      Some(atom) -> match atom {
        # PCA(mask, after) = mask, position after the atom
        PCA(mask, after) -> {
          let q = parse_quant(pat, after, n - 1)
          match q {
            QErr -> None
            QShape(quant, after_q) ->
              if after_q == n - 1 { Some(RxAC(mask, quant)) }
              else { None }
          }
        }
      }
    }
  }
}

# Parse a single class atom: either `[...]` (with optional `^`
# negation), or one of the built-in escapes `\d \w \s \D \W \S`, or a
# bare ASCII printable that is not a regex metachar. Returns the
# resulting 128-byte mask and the byte offset just past the atom.
type ParsedClassAtom = PCA(String, Int)

fn parse_class_atom(pat: String, i: Int, end: Int) : Option[ParsedClassAtom] {
  if i >= end { None } else {
    let c = char_at_or_zero(pat, i)
    if c == '[' { parse_bracket_class(pat, i + 1, end) }
    else if c == '\\' { parse_escape_atom(pat, i + 1, end) }
    else if c == '.' { Some(PCA(mask_dot(), i + 1)) }
    else if is_regex_meta(c) { None }
    else { Some(PCA(mask_single(c), i + 1)) }
  }
}

fn is_regex_meta(c: Char) : Bool =
  c == '^' or c == '$' or c == '|' or c == '(' or c == ')' or
  c == '[' or c == ']' or c == '{' or c == '}' or
  c == '*' or c == '+' or c == '?' or c == '.' or c == '\\'

# Parse the body of `[...]`, beginning at position `i` (just past the
# `[`). Returns the assembled mask and the position just past the
# closing `]`. Bails on malformed classes or anything beyond
# `[abc]` / `[^abc]` / `[a-z0-9]` shapes.
fn parse_bracket_class(pat: String, i: Int, end: Int) : Option[ParsedClassAtom] {
  let neg = if i < end and char_at_or_zero(pat, i) == '^' { true } else { false }
  let i1 = if neg { i + 1 } else { i }
  parse_bracket_body(pat, i1, end, mask_empty(), neg)
}

fn parse_bracket_body(pat: String, i: Int, end: Int, acc: String, neg: Bool) : Option[ParsedClassAtom] {
  if i >= end { None } else {
    let c = char_at_or_zero(pat, i)
    if c == ']' {
      let final_mask = if neg { mask_invert(acc) } else { acc }
      Some(PCA(final_mask, i + 1))
    } else {
      match parse_bracket_item(pat, i, end) {
        None -> None
        Some(item) -> match item {
          BItem(item_mask, after) ->
            parse_bracket_body(pat, after, end, mask_or(acc, item_mask), neg)
        }
      }
    }
  }
}

# A single item inside `[...]`: a char, an escape, or a range `a-z`.
type BracketItem = BItem(String, Int)

fn parse_bracket_item(pat: String, i: Int, end: Int) : Option[BracketItem] {
  if i >= end { None } else {
    let c = char_at_or_zero(pat, i)
    let first = if c == '\\' {
      match parse_class_escape(pat, i + 1, end) {
        None -> None
        Some(esc) -> Some(esc)
      }
    } else if c == ']' or c == '[' { None }
    else { Some(BFirst(mask_single(c), i + 1, c)) }
    match first {
      None -> None
      Some(f) -> match f {
        BFirst(m1, after1, lo) ->
          if after1 < end and char_at_or_zero(pat, after1) == '-' and
             after1 + 1 < end and char_at_or_zero(pat, after1 + 1) != ']' {
            let c2 = char_at_or_zero(pat, after1 + 1)
            if c2 == '\\' { None }
            else if char_to_int(c2) < char_to_int(lo) { None }
            else { Some(BItem(mask_range(lo, c2), after1 + 2)) }
          } else { Some(BItem(m1, after1)) }
        BClass(m1, after1) -> Some(BItem(m1, after1))
      }
    }
  }
}

# Wrapper for a parsed first-token inside a class. Either a single
# char (which may extend into a range) or a `\d`/`\w`/`\s` class
# (which never extends). The `Char` field is meaningful only for
# `BFirst` and is ignored for `BClass`.
type BracketFirst
  = BFirst(String, Int, Char)
  | BClass(String, Int)

fn parse_class_escape(pat: String, i: Int, end: Int) : Option[BracketFirst] {
  if i >= end { None } else {
    let c = char_at_or_zero(pat, i)
    match c {
      'd' -> Some(BClass(mask_digit(), i + 1))
      'D' -> Some(BClass(mask_invert(mask_digit()), i + 1))
      'w' -> Some(BClass(mask_word(), i + 1))
      'W' -> Some(BClass(mask_invert(mask_word()), i + 1))
      's' -> Some(BClass(mask_space(), i + 1))
      'S' -> Some(BClass(mask_invert(mask_space()), i + 1))
      'n' -> Some(BFirst(mask_single('\n'), i + 1, '\n'))
      't' -> Some(BFirst(mask_single('\t'), i + 1, '\t'))
      'r' -> Some(BFirst(mask_single('\r'), i + 1, '\r'))
      _ -> Some(BFirst(mask_single(c), i + 1, c))
    }
  }
}

# Outside a class: `\d \w \s` etc. produce a class atom with no
# follow-on range. Other escape chars produce a single-char atom.
fn parse_escape_atom(pat: String, i: Int, end: Int) : Option[ParsedClassAtom] {
  if i >= end { None } else {
    let c = char_at_or_zero(pat, i)
    match c {
      'd' -> Some(PCA(mask_digit(), i + 1))
      'D' -> Some(PCA(mask_invert(mask_digit()), i + 1))
      'w' -> Some(PCA(mask_word(), i + 1))
      'W' -> Some(PCA(mask_invert(mask_word()), i + 1))
      's' -> Some(PCA(mask_space(), i + 1))
      'S' -> Some(PCA(mask_invert(mask_space()), i + 1))
      'n' -> Some(PCA(mask_single('\n'), i + 1))
      't' -> Some(PCA(mask_single('\t'), i + 1))
      'r' -> Some(PCA(mask_single('\r'), i + 1))
      _ -> Some(PCA(mask_single(c), i + 1))
    }
  }
}

# Parse an optional quantifier just past a class atom. Returns
# QErr on a malformed `{n,m}`, QShape("1", i) when no quant is
# present (the atom matches exactly one occurrence), and
# QShape("+"|"*"|"?"|"n,m"|"n,", i + width) for the supported forms.
type QuantParse
  = QShape(String, Int)
  | QErr

fn parse_quant(pat: String, i: Int, end: Int) : QuantParse {
  if i >= end { QShape("1", i) } else {
    let c = char_at_or_zero(pat, i)
    match c {
      '+' -> QShape("+", i + 1)
      '*' -> QShape("*", i + 1)
      '?' -> QShape("?", i + 1)
      '{' -> parse_repeat_quant(pat, i + 1, end)
      _ -> QShape("1", i)
    }
  }
}

fn parse_repeat_quant(pat: String, i: Int, end: Int) : QuantParse {
  match parse_pat_int(pat, i, end) {
    None -> QErr
    Some(lo_p) -> match lo_p {
      IntParse(lo, after_lo) ->
        if after_lo >= end { QErr } else {
          let c = char_at_or_zero(pat, after_lo)
          match c {
            '}' -> QShape(concat_all([int_to_string(lo), ",", int_to_string(lo)]), after_lo + 1)
            ',' -> {
              if after_lo + 1 < end and char_at_or_zero(pat, after_lo + 1) == '}' {
                QShape(concat_all([int_to_string(lo), ","]), after_lo + 2)
              } else { match parse_pat_int(pat, after_lo + 1, end) {
                None -> QErr
                Some(hi_p) -> match hi_p {
                  IntParse(hi, after_hi) ->
                    if hi < lo { QErr }
                    else if after_hi >= end { QErr }
                    else if char_at_or_zero(pat, after_hi) != '}' { QErr }
                    else { QShape(concat_all([int_to_string(lo), ",", int_to_string(hi)]), after_hi + 1) }
                }
              } }
            }
            _ -> QErr
          }
        }
    }
  }
}

type IntParse = IntParse(Int, Int)

fn parse_pat_int(pat: String, i: Int, end: Int) : Option[IntParse] {
  parse_pat_int_loop(pat, i, end, 0, false)
}

fn parse_pat_int_loop(pat: String, i: Int, end: Int, acc: Int, any: Bool) : Option[IntParse] {
  if i >= end {
    if any { Some(IntParse(acc, i)) } else { None }
  } else {
    let c = char_at_or_zero(pat, i)
    if ch_is_digit(c) {
      parse_pat_int_loop(pat, i + 1, end, acc * 10 + char_to_int(c) - char_to_int('0'), true)
    } else {
      if any { Some(IntParse(acc, i)) } else { None }
    }
  }
}

# ASCII charset masks. Stored as a string of length 128 — '1' at
# position k means code point k is in the set.
fn mask_empty() : String = mask_const_loop(0, '0', "")
fn mask_full() : String = mask_const_loop(0, '1', "")

fn mask_const_loop(i: Int, ch: Char, acc: String) : String {
  if i >= 128 { acc }
  else { mask_const_loop(i + 1, ch, string_concat(acc, "#{ch}")) }
}

fn mask_single(c: Char) : String {
  let cp = char_to_int(c)
  if cp < 0 or cp >= 128 { mask_empty() }
  else { mask_set_bit(mask_empty(), cp) }
}

fn mask_range(lo: Char, hi: Char) : String {
  let lo_i = char_to_int(lo)
  let hi_i = char_to_int(hi)
  mask_range_loop(mask_empty(), lo_i, hi_i)
}

fn mask_range_loop(acc: String, i: Int, hi: Int) : String {
  if i > hi or i >= 128 { acc }
  else if i < 0 { mask_range_loop(acc, i + 1, hi) }
  else { mask_range_loop(mask_set_bit(acc, i), i + 1, hi) }
}

fn mask_set_bit(m: String, pos: Int) : String {
  if pos < 0 or pos >= 128 { m }
  else {
    let prefix = string_slice(m, 0, pos)
    let suffix = string_slice(m, pos + 1, 128 - pos - 1)
    concat_all([prefix, "1", suffix])
  }
}

fn mask_or(a: String, b: String) : String = mask_or_loop(a, b, 0, "")

fn mask_or_loop(a: String, b: String, i: Int, acc: String) : String {
  if i >= 128 { acc }
  else {
    let ca = char_at_or_zero(a, i)
    let cb = char_at_or_zero(b, i)
    let merged = if ca == '1' or cb == '1' { '1' } else { '0' }
    mask_or_loop(a, b, i + 1, string_concat(acc, "#{merged}"))
  }
}

fn mask_invert(m: String) : String = mask_invert_loop(m, 0, "")

fn mask_invert_loop(m: String, i: Int, acc: String) : String {
  if i >= 128 { acc }
  else {
    let c = char_at_or_zero(m, i)
    let flipped = if c == '1' { '0' } else { '1' }
    mask_invert_loop(m, i + 1, string_concat(acc, "#{flipped}"))
  }
}

# `[a-z]` ⊆ `[a-z0-9]` iff every '1' in the strict mask is also '1'
# in the loose mask. Linear scan over 128 positions.
fn mask_subset(strict: String, loose: String) : Bool = mask_subset_loop(strict, loose, 0)

fn mask_subset_loop(strict: String, loose: String, i: Int) : Bool {
  if i >= 128 { true }
  else {
    let s = char_at_or_zero(strict, i)
    let l = char_at_or_zero(loose, i)
    if s == '1' and l != '1' { false }
    else { mask_subset_loop(strict, loose, i + 1) }
  }
}

# `\d` -> [0-9].
fn mask_digit() : String = mask_range('0', '9')

# `\w` -> [A-Za-z0-9_].
fn mask_word() : String =
  mask_set_bit(mask_or(mask_or(mask_range('A', 'Z'), mask_range('a', 'z')),
                       mask_range('0', '9')),
               char_to_int('_'))

# `\s` -> [ \t\n\r\v\f]. We only mask the ASCII ones the v1 engine
# actually recognises (`rx_space_ranges` in stdlib/regexp.kai).
fn mask_space() : String =
  mask_set_bit(mask_set_bit(mask_set_bit(mask_set_bit(mask_empty(),
                                                       char_to_int(' ')),
                                          char_to_int('\t')),
                            char_to_int('\n')),
               char_to_int('\r'))

# `.` matches any non-newline ASCII char (RE2 default semantics).
fn mask_dot() : String = mask_invert(mask_single('\n'))

# Containment of two parsed AnchoredClass shapes. v1: identical
# quantifier strings + strict charset ⊆ loose charset is the
# only path that returns true. Anything else is conservative.
fn ac_contains(loose: AnchoredClass, strict: AnchoredClass) : Bool {
  match loose {
    RxAC(loose_mask, loose_q) -> match strict {
      RxAC(strict_mask, strict_q) ->
        if loose_q != strict_q { false }
        else { mask_subset(strict_mask, loose_mask) }
    }
  }
}

# Substitute every free `self` in `e` with `EVar(name)`. The
# refinement grammar only uses `self` as a stand-in for the value
# being refined, so we do not chase shadowing — `self` is never
# rebound by `let` / lambda / match inside a predicate.
fn subst_self(e: Expr, name: String) : Expr = match e.kind {
  EVar(s) -> if s == "self" { mk_expr(EVar(name), e.line, e.col) } else { e }
  EBinop(op, a, b) -> mk_expr(EBinop(op, subst_self(a, name), subst_self(b, name)), e.line, e.col)
  EUnop(op, x) -> mk_expr(EUnop(op, subst_self(x, name)), e.line, e.col)
  ECall(f, xs) -> mk_expr(ECall(subst_self(f, name), subst_self_list(xs, name)), e.line, e.col)
  _ -> e
}

fn subst_self_list(es: [Expr], name: String) : [Expr] = match es {
  [] -> []
  [h, ...t] -> [subst_self(h, name), ...subst_self_list(t, name)]
}

# Issue #83 sub-case 2: predicate canonicaliser. Normalises a
# comparison Expr so structurally-different but semantically-equal
# forms compare equal: `0 < x` → `x > 0`, `<=` ↔ flipped `>=`,
# `==` / `!=` argument order normalised lexicographically. Any
# non-comparison Expr is recursed into so a top-level `and` / `or`
# of comparisons is canonicalised arm-wise.
fn pred_canon(e: Expr) : Expr = match e.kind {
  EBinop(op, a, b) -> {
    let ca = pred_canon(a)
    let cb = pred_canon(b)
    if op == "<" { mk_expr(EBinop(">", cb, ca), e.line, e.col) }
    else if op == "<=" { mk_expr(EBinop(">=", cb, ca), e.line, e.col) }
    else if op == "==" or op == "!=" {
      if cmp_lt(ca, cb) { mk_expr(EBinop(op, ca, cb), e.line, e.col) }
      else { mk_expr(EBinop(op, cb, ca), e.line, e.col) }
    }
    else if op == "and" or op == "or" {
      mk_expr(EBinop(op, ca, cb), e.line, e.col)
    }
    else { mk_expr(EBinop(op, ca, cb), e.line, e.col) }
  }
  EUnop(op, x) -> mk_expr(EUnop(op, pred_canon(x)), e.line, e.col)
  _ -> e
}

# Total ordering used by `pred_canon` to break ties on symmetric
# operators. Variables sort by name; literals sort by value. An
# EVar always sorts before an EInt so `x == 0` canonicalises to
# `x == 0` (variable on the LHS), and two variables sort
# alphabetically.
fn cmp_lt(a: Expr, b: Expr) : Bool = match a.kind {
  EVar(an) -> match b.kind {
    EVar(bn) -> string_lt(an, bn)
    _ -> true
  }
  EInt(av) -> match b.kind {
    EVar(_) -> false
    EInt(bv) -> av < bv
    _ -> true
  }
  _ -> false
}

# Issue #83 sub-case 3 partial: when both predicates compare the
# same variable to a literal, use the interval lattice to decide
# entailment. Captures `x > 0` ⊢ `x > -1`, `x >= 1` ⊢ `x > 0`,
# `x != 0` ⊢ `x != 0` (already covered by struct_eq), etc. Both
# inputs are in canonical form (variable on the LHS for ordered
# comparisons).
fn pred_entailed_by_refinement(req: Expr, pname: String, ref_pred: Expr) : Bool {
  match interval_of_pred(ref_pred, pname) {
    None -> false
    Some(iv) -> match check_pred_with_interval(req, pname, iv) {
      Some(true) -> true
      _ -> false
    }
  }
}

# Read a refinement predicate as an interval over `pname`. Only
# the closed shapes we care about — `pname OP literal` — produce
# a non-trivial interval; anything else collapses to `None` so the
# caller falls back to structural matching.
fn interval_of_pred(e: Expr, pname: String) : Option[Interval] = match e.kind {
  EBinop(op, a, b) -> match a.kind {
    EVar(n) -> if n == pname {
      match try_eval_int(b) {
        None -> None
        Some(k) -> interval_from_cmp(op, k)
      }
    } else { None }
    _ -> None
  }
  _ -> None
}

# Turn `x OP k` into the tightest Int interval that satisfies it.
# `!=` is not expressible as a single closed interval; we return
# `None` so the caller defers to structural / call-site checks.
fn interval_from_cmp(op: String, k: Int) : Option[Interval] {
  if op == ">"  { Some(Ival(k + 1, ival_int_max_const())) }
  else if op == ">=" { Some(Ival(k, ival_int_max_const())) }
  else if op == "<"  { Some(Ival(ival_int_min_const(), k - 1)) }
  else if op == "<=" { Some(Ival(ival_int_min_const(), k)) }
  else if op == "==" { Some(Ival(k, k)) }
  else { None }
}

# Saturating sentinels for the interval lattice. The lattice does
# not track unbounded ranges precisely; these constants stand in for
# `+∞` / `-∞` and are large enough that any realistic Int comparison
# folds before reaching them.
fn ival_int_max_const() : Int = 9223372036854775807
fn ival_int_min_const() : Int = 0 - 9223372036854775807 - 1

# Discharge a `requires` predicate against a known interval for the
# refined param. Returns `Some(true)` when the request is provable,
# `Some(false)` if the interval witnesses a contradiction (caller
# treats it as "not entailed" — a `false` requires would have been
# rejected at parse time), and `None` when the predicate's shape
# escapes our analysis.
fn check_pred_with_interval(req: Expr, pname: String, iv: Interval) : Option[Bool] = match req.kind {
  EBinop(op, a, b) -> match a.kind {
    EVar(n) -> if n == pname {
      match try_eval_int(b) {
        None -> None
        Some(k) -> {
          let kiv = Ival(k, k)
          if op == ">"  { ival_gt(iv, kiv) }
          else if op == ">=" { ival_ge(iv, kiv) }
          else if op == "<"  { ival_lt(iv, kiv) }
          else if op == "<=" { ival_le(iv, kiv) }
          else if op == "==" { ival_eq(iv, kiv) }
          else if op == "!=" { ival_ne(iv, kiv) }
          else { None }
        }
      }
    } else { None }
    _ -> None
  }
  _ -> None
}


# Structural equality on Expr, ignoring line/col. Conservative: only
# the shapes the predicate-pure subset can produce are compared in
# detail; everything else falls back to false (so a future feature
# that produces a new ExprKind in predicate position is treated as
# "definitely not equal" rather than wrongly entailed).
fn expr_struct_eq(a: Expr, b: Expr) : Bool {
  match a.kind {
    EInt(av) -> match b.kind { EInt(bv) -> av == bv _ -> false }
    EReal(av, _) -> match b.kind { EReal(bv, _) -> av == bv _ -> false }
    EFixed(sa, _) -> match b.kind { EFixed(sb, _) -> sa == sb _ -> false }
    EBool(av) -> match b.kind { EBool(bv) -> av == bv _ -> false }
    EChar(av) -> match b.kind { EChar(bv) -> av == bv _ -> false }
    EStr(av, _) -> match b.kind { EStr(bv, _) -> av == bv _ -> false }
    EUnit -> match b.kind { EUnit -> true _ -> false }
    EVar(an) -> match b.kind { EVar(bn) -> an == bn _ -> false }
    EBinop(aop, al, ar) -> match b.kind {
      EBinop(bop, bl, br) -> aop == bop and expr_struct_eq(al, bl) and expr_struct_eq(ar, br)
      _ -> false
    }
    EUnop(aop, ai) -> match b.kind {
      EUnop(bop, bi) -> aop == bop and expr_struct_eq(ai, bi)
      _ -> false
    }
    EField(ab, an) -> match b.kind {
      EField(bb, bn) -> an == bn and expr_struct_eq(ab, bb)
      _ -> false
    }
    ECall(af, aa) -> match b.kind {
      ECall(bf, ba) -> expr_struct_eq(af, bf) and expr_list_struct_eq(aa, ba)
      _ -> false
    }
    _ -> false
  }
}

fn expr_list_struct_eq(a: [Expr], b: [Expr]) : Bool {
  match a {
    [] -> match b { [] -> true _ -> false }
    [ah, ...arest] -> match b {
      [] -> false
      [bh, ...brest] -> expr_struct_eq(ah, bh) and expr_list_struct_eq(arest, brest)
    }
  }
}

# m12.6.d: best-effort static evaluator for refinement / contract
# predicates. Returns Some(b) when the expression is a closed boolean
# expression reducible to a literal, None otherwise. Deliberately
# narrow: no symbolic reasoning, no SMT, no propagation through
# refined arguments — that's the next step (and the cliff the spec
# forbids in v1).
#[doc("Best-effort static evaluation of a closed boolean predicate Expr; Some(b) when it reduces to a literal, None otherwise.")]
pub fn try_eval_pred(e: Expr) : Option[Bool] {
  match e.kind {
    EBool(b) -> Some(b)
    EUnop(op, x) -> if op == "not" {
      match try_eval_pred(x) {
        Some(b) -> Some(not b)
        None    -> None
      }
    } else { None }
    EBinop(op, a, b) -> {
      if op == "and" {
        match try_eval_pred(a) {
          Some(false) -> Some(false)
          Some(true)  -> try_eval_pred(b)
          None        -> None
        }
      } else if op == "or" {
        match try_eval_pred(a) {
          Some(true)  -> Some(true)
          Some(false) -> try_eval_pred(b)
          None        -> None
        }
      } else if op == "==" or op == "!=" or op == "<" or op == "<=" or op == ">" or op == ">=" {
        match try_eval_int(a) {
          None    -> None
          Some(ai) -> match try_eval_int(b) {
            None    -> None
            Some(bi) -> Some(eval_int_cmp(op, ai, bi))
          }
        }
      } else { None }
    }
    _ -> None
  }
}

# Evaluate an Int-typed closed expression to a literal value.
#[doc("Fold a closed Int Expr (literals, +/-/*, unary negation) to a literal value; None when it is not closed.")]
pub fn try_eval_int(e: Expr) : Option[Int] {
  match e.kind {
    EInt(n) -> Some(n)
    EUnop(op, x) -> if op == "-" {
      match try_eval_int(x) {
        Some(v) -> Some(0 - v)
        None    -> None
      }
    } else { None }
    EBinop(op, a, b) -> match try_eval_int(a) {
      None    -> None
      Some(av) -> match try_eval_int(b) {
        None    -> None
        Some(bv) -> eval_int_op(op, av, bv)
      }
    }
    _ -> None
  }
}

fn eval_int_op(op: String, a: Int, b: Int) : Option[Int] {
  if op == "+" { Some(a + b) }
  else if op == "-" { Some(a - b) }
  else if op == "*" { Some(a * b) }
  else if op == "/" { if b == 0 { None } else { Some(a / b) } }
  else if op == "%" { if b == 0 { None } else { Some(a % b) } }
  else { None }
}

fn eval_int_cmp(op: String, a: Int, b: Int) : Bool {
  if op == "==" { a == b }
  else if op == "!=" { a != b }
  else if op == "<" { a < b }
  else if op == "<=" { a <= b }
  else if op == ">" { a > b }
  else if op == ">=" { a >= b }
  else { false }
}


# ====================================================================
# Issue #83 sub-case 3 — call-site substitution analysis
# ====================================================================
#
# Walks every user fn looking for `ECall(EVar(callee), args)` whose
# callee's `requires` clauses (or refined-param predicates) can be
# discharged at compile time from what we know about the args:
#
#   1. **Literal arg**: substitute the integer into the callee's
#      predicate and run `try_eval_pred`.
#   2. **Refined-binding arg**: when the arg is an `EVar(x)` whose
#      type is `TyRefine` in the caller's signature, the caller's
#      refinement (with `self ↦ x`) is checked against the callee's
#      predicate (with `param ↦ x`) using the same canonical /
#      interval-based entailment as the in-callee path.
#   3. **Unrefined-binding arg**: no info, leave the runtime assert
#      in place. Status quo.
#
# The analysis is intentionally a syntactic AST pass — it sees the
# parser's `TyRefine` shape directly, with no need for the
# `infer_program` substitution. Two outputs:
#
#   - `--dump-call-elision`: per call-site report, useful for
#     fixtures.
#   - `check_call_site_refinements`: when the caller passes a refined
#     binding whose refinement is strictly weaker than the callee's
#     pre, that's a static error pointing at the call site. No flag
#     needed; refining a parameter is opt-in already.

# A callee's contract entry: param name + predicate the caller must
# discharge for that param. For `requires P` the param is the special
# `__contract` (P uses param names directly); for refined params the
# param's name is the refinement's `self` stand-in.
type CalleeReq = CR(String, Expr)

type CalleeSig = CSig(String, [String], [CalleeReq])  # name, param names, requirements

# Build the table of fns with non-empty contracts. Tparam-rewritten
# fns (`with_protocol_tparams`) are skipped — protocol impls are
# resolved later in the pipeline and their contracts get re-emitted
# at that point.
fn collect_callee_sigs(decls: [Decl]) : [CalleeSig] {
  collect_callee_sigs_loop(decls, [])
}

fn collect_callee_sigs_loop(decls: [Decl], acc: [CalleeSig]) : [CalleeSig] {
  match decls {
    [] -> list_reverse(acc)
    [d, ...rest] -> match d {
      DFn(_, name, _, params, _, _, body, _, _, _) -> {
        let reqs = extract_callee_reqs(params, body)
        if list_is_empty(reqs) { collect_callee_sigs_loop(rest, acc) }
        else {
          let pnames = collect_param_names(params, [])
          collect_callee_sigs_loop(rest, [CSig(name, pnames, reqs), ...acc])
        }
      }
      _ -> collect_callee_sigs_loop(rest, acc)
    }
  }
}

fn collect_param_names(params: [Param], acc: [String]) : [String] = match params {
  [] -> list_reverse(acc)
  [p, ...rest] -> collect_param_names(rest, [p.pname, ...acc])
}

# Walk the body's leading asserts to recover the original `requires`
# predicates `wrap_with_contracts` desugared. They live at the front
# of an EBlock as `SAssert(pred, Some("requires violated..."))`. We
# stop at the first non-`requires` assert (so `ensures` asserts after
# `let result = body` aren't picked up). Refined-param predicates
# also produce a CalleeReq (with `self ↦ pname` already applied so
# downstream entailment treats them as ordinary predicates over the
# parameter).
fn extract_callee_reqs(params: [Param], body: Expr) : [CalleeReq] {
  let from_params = extract_param_refinement_reqs(params, [])
  let from_asserts = extract_requires_asserts(body)
  list_append(from_asserts, from_params)
}

fn extract_param_refinement_reqs(params: [Param], acc: [CalleeReq]) : [CalleeReq] {
  match params {
    [] -> list_reverse(acc)
    [p, ...rest] -> match p.ptype {
      Some(t) -> match t.tkind {
        TyRefine(_, pred) ->
          extract_param_refinement_reqs(rest, [CR(p.pname, subst_self(pred, p.pname)), ...acc])
        _ -> extract_param_refinement_reqs(rest, acc)
      }
      None -> extract_param_refinement_reqs(rest, acc)
    }
  }
}

fn extract_requires_asserts(body: Expr) : [CalleeReq] = match body.kind {
  EBlock(stmts, _) -> extract_requires_loop(stmts, [])
  _ -> []
}

fn extract_requires_loop(stmts: [Stmt], acc: [CalleeReq]) : [CalleeReq] {
  match stmts {
    [] -> list_reverse(acc)
    [s, ...rest] -> match s {
      SAssert(pred, Some(msg)) -> if assert_msg_is_requires(msg) {
        extract_requires_loop(rest, [CR("__requires", pred), ...acc])
      } else { list_reverse(acc) }
      _ -> list_reverse(acc)
    }
  }
}

fn assert_msg_is_requires(msg: Expr) : Bool = match msg.kind {
  EStr(s, _) -> string_starts_with_requires(s)
  _ -> false
}

# The desugared message is a quoted string of the form
# `"requires violated at line N"` (quotes included in EStr's raw
# span). Match the prefix `"requires` rather than calling
# string_starts_with_q which is defined later in the file but is
# semantically what we want.
fn string_starts_with_requires(s: String) : Bool {
  let n = string_length(s)
  if n < 10 { false } else {
    let c0 = char_at(s, 0)
    let c1 = char_at(s, 1)
    match c0 { Some(q) -> match c1 {
      Some(r) -> q == '"' and r == 'r' and starts_with_after_quote(s, 1, "requires")
      None -> false
    } None -> false }
  }
}

fn starts_with_after_quote(s: String, off: Int, prefix: String) : Bool {
  let n = string_length(prefix)
  pred_starts_with_loop(s, off, prefix, 0, n)
}

fn pred_starts_with_loop(s: String, soff: Int, prefix: String, poff: Int, n: Int) : Bool {
  if poff >= n { true }
  else {
    match char_at(s, soff) {
      Some(cs) -> match char_at(prefix, poff) {
        Some(cp) -> if cs == cp { pred_starts_with_loop(s, soff + 1, prefix, poff + 1, n) } else { false }
        None -> false
      }
      None -> false
    }
  }
}

# Refinement bindings visible inside a function body: each entry
# pairs a binding name with the (canonicalised, self-substituted)
# predicate the typer would attach to its TyRefine. Built from the
# enclosing fn's parameter list; `let` bindings without explicit
# refinement annotations contribute nothing (interval inference is
# the lattice's job, not this analysis).
type RefBinding = RBind(String, Expr)

fn collect_caller_refinements(params: [Param], acc: [RefBinding]) : [RefBinding] {
  match params {
    [] -> list_reverse(acc)
    [p, ...rest] -> match p.ptype {
      Some(t) -> match t.tkind {
        TyRefine(_, pred) ->
          collect_caller_refinements(rest, [RBind(p.pname, subst_self(pred, p.pname)), ...acc])
        _ -> collect_caller_refinements(rest, acc)
      }
      None -> collect_caller_refinements(rest, acc)
    }
  }
}

fn lookup_caller_refinement(refs: [RefBinding], name: String) : Option[Expr] {
  match refs {
    [] -> None
    [r, ...rest] -> match r {
      RBind(n, p) -> if n == name { Some(p) } else { lookup_caller_refinement(rest, name) }
    }
  }
}

# A single classification of a call-site relative to one of the
# callee's requirements. Fixtures pin these via `--dump-call-elision`.
type CallSiteStatus = CSElided | CSRuntime | CSLoose(String)

# Outcome record: callee name, param name (or "__requires"), the
# discharged predicate as it was tested, and the status.
type CallSiteReport = CSR(String, String, Expr, CallSiteStatus, Int, Int)

# Classify one (callee_param, caller_arg) discharge attempt.
#
# `req_pred` is the callee's predicate with the formal parameter
# name baked in (already substituted from `self`). `arg` is the AST
# expression at the call site. `caller_refs` is the refinement
# environment built from the enclosing fn's parameters.
fn classify_arg_vs_pred(req_pred: Expr, pname: String, arg: Expr,
                        caller_refs: [RefBinding]) : CallSiteStatus {
  match try_eval_int(arg) {
    Some(k) -> {
      let folded = pred_canon(subst_var(req_pred, pname, mk_int(k, arg.line, arg.col)))
      match try_eval_pred(folded) {
        Some(true) -> CSElided
        Some(false) -> CSLoose(concat_all(["literal ", int_to_string(k), " violates `", expr_show_pred(req_pred), "`"]))
        None -> CSRuntime
      }
    }
    None -> match arg.kind {
      EVar(arg_name) -> match lookup_caller_refinement(caller_refs, arg_name) {
        Some(caller_pred) -> {
          # Substitute both predicates to talk about the same name
          # (the arg's name) so structural / interval entailment
          # works without per-pair alpha matching.
          let req_in_arg = pred_canon(subst_var(req_pred, pname, mk_var(arg_name, arg.line, arg.col)))
          let caller_in_arg = pred_canon(caller_pred)
          if expr_struct_eq(req_in_arg, caller_in_arg) { CSElided }
          else if pred_entailed_by_refinement(req_in_arg, arg_name, caller_in_arg) { CSElided }
          else { CSLoose(concat_all([
                  "caller refinement `", expr_show_pred(caller_pred),
                  "` does not entail callee precondition `",
                  expr_show_pred(req_pred), "`"])) }
        }
        None -> CSRuntime
      }
      _ -> CSRuntime
    }
  }
}

fn mk_int(n: Int, line: Int, col: Int) : Expr = mk_expr(EInt(n), line, col)
fn mk_var(s: String, line: Int, col: Int) : Expr = mk_expr(EVar(s), line, col)

# Substitute every free `EVar(from)` in `e` with `to`. Mirrors
# `subst_self` but for an arbitrary name. Used to push a literal /
# binding into a callee's predicate before discharging it.
fn subst_var(e: Expr, from: String, to: Expr) : Expr = match e.kind {
  EVar(s) -> if s == from { to } else { e }
  EBinop(op, a, b) -> mk_expr(EBinop(op, subst_var(a, from, to), subst_var(b, from, to)), e.line, e.col)
  EUnop(op, x) -> mk_expr(EUnop(op, subst_var(x, from, to)), e.line, e.col)
  ECall(f, xs) -> mk_expr(ECall(subst_var(f, from, to), subst_var_list(xs, from, to)), e.line, e.col)
  _ -> e
}

fn subst_var_list(es: [Expr], from: String, to: Expr) : [Expr] = match es {
  [] -> []
  [h, ...t] -> [subst_var(h, from, to), ...subst_var_list(t, from, to)]
}

# Pretty-print a predicate Expr in the canonical comparison form used
# by `--dump-call-elision`. Falls back to `<expr>` for shapes outside
# the decidable subset so the output stays grep-friendly.
fn expr_show_pred(e: Expr) : String = match e.kind {
  EInt(n) -> int_to_string(n)
  EReal(r, _) -> real_to_string(r)
  EFixed(s, _) -> s
  EVar(s) -> s
  EBool(b) -> if b { "true" } else { "false" }
  EChar(c) -> concat_all(["'", "#{c}", "'"])
  # EStr carries the raw source span including surrounding quotes,
  # so pass it through unchanged. `is_triple` is irrelevant for a
  # predicate context (triple-quoted strings rarely appear here).
  EStr(s, _) -> s
  EBinop(op, a, b) -> concat_all([expr_show_pred(a), " ", op, " ", expr_show_pred(b)])
  EUnop(op, x) -> concat_all([op, " ", expr_show_pred(x)])
  _ -> "<expr>"
}

# Issue #86 (piece 2): when a contract predicate has the simple shape
# `<ident> <cmp> <literal>` (e.g. `b != 0.0`, `n >= 0`, `c == 'x'`),
# return the offending parameter so the emitter can attach the binding's
# runtime value to the violation panic. Returns None for any other shape
# (two idents, nested expressions, calls, unops) — the emitter then
# falls back to the value-less `kai_assert_check`, with no regression.
# The single-EVar / scalar-literal restriction is what lets the emitter
# safely reference the *one* already-bound local; richer predicates
# would need to evaluate sub-expressions, which the panic path must not
# do (re-emitting would double-evaluate side effects and break Perceus
# RC).
#
# A matched simple-shape predicate carries two nodes:
#   - the ident EVar node — its `mode` is the *repr oracle*. The emitter
#     mirrors exactly what `emit_expr` would do for this same node: a
#     raw-unboxed EVar reads from `kair_<name>`, a boxed one from
#     `kai_<name>`. Using the ident node's own mode (not the literal's)
#     guarantees the emitter and `emit_expr` agree on which C local
#     name exists — the local's repr is a property of the *binding*,
#     not of how the comparison happened to be lowered.
#   - the literal node — its `ty` is the *box-type oracle* for the raw
#     case (Perceus never rewrites a literal, so its `ty` is always
#     present, whereas a dup-wrapped ident node's `ty` may be blank).
pub type ContractIdent = CtrId(String, Expr, Expr)
#                              ^name  ^ident ^literal

pub fn contract_single_ident(pred: Expr) : Option[String] =
  match contract_single_ident_node(pred) {
    Some(ci) -> match ci { CtrId(nm, _, _) -> Some(nm) }
    None -> None
  }

# Simple-shape detector for the C / LLVM emitters: returns the binding
# name, the ident node (repr oracle), and the comparison literal (box-ty
# oracle) so they can attach the binding's runtime value to a
# contract-violation panic.
pub fn contract_single_ident_node(pred: Expr) : Option[ContractIdent] = match pred.kind {
  EBinop(op, a, b) ->
    if pred_op_is_cmp(op) {
      match expr_pred_ident_node(a) {
        Some(na) -> if expr_pred_is_scalar_lit(b) { Some(CtrId(ci_name(na), na, b)) } else { None }
        None -> match expr_pred_ident_node(b) {
          Some(nb) -> if expr_pred_is_scalar_lit(a) { Some(CtrId(ci_name(nb), nb, a)) } else { None }
          None -> None
        }
      }
    } else { None }
  _ -> None
}

fn ci_name(e: Expr) : String = match e.kind { EVar(s) -> s _ -> "?" }

# Does this EStr span (raw — includes the opening quote) start with the
# load-bearing `requires violated` contract prefix? The value-carrying
# panic path (issue #86 piece 2) is narrowed to `requires` because a
# requires-assert runs before the body consumes any param, so the
# offending binding's local is guaranteed live; an ensures-assert may
# reference an already-consumed param. Shared by the C and LLVM emitters.
pub fn assert_span_is_requires(span: String) : Bool =
  assert_span_prefix_loop(span, "\"requires violated", 0)

fn assert_span_prefix_loop(s: String, prefix: String, i: Int) : Bool {
  let pn = string_length(prefix)
  if i >= pn { true }
  else { match char_at(s, i) {
    None -> false
    Some(sc) -> match char_at(prefix, i) {
      None -> true
      Some(pc) -> if sc == pc { assert_span_prefix_loop(s, prefix, i + 1) } else { false }
    }
  } }
}

fn pred_op_is_cmp(op: String) : Bool =
  op == "==" or op == "!=" or op == "<" or op == ">" or op == "<=" or op == ">="

# Recover the bare ident node behind a predicate operand. By emit time
# the Perceus pass may have wrapped a non-last read as
# `__perceus_dup(<ident>)`; unwrap that one layer so the simple-shape
# detector still fires on `b != 0.0` whether or not `b` is read again
# later in the body. The returned node carries the `mode`/`ty` the
# emitter needs to pick boxed vs raw repr; the emitter only references
# the bound local, never re-emits this sub-expression.
fn expr_pred_ident_node(e: Expr) : Option[Expr] = match e.kind {
  EVar(_) -> Some(e)
  ECall(callee, args) -> match callee.kind {
    EVar(dn) -> if dn == "__perceus_dup" or dn == "__perceus_drop" {
      match args { [a] -> expr_pred_ident_node(a) _ -> None }
    } else { None }
    _ -> None
  }
  _ -> None
}

fn expr_pred_is_scalar_lit(e: Expr) : Bool = match e.kind {
  EInt(_) -> true
  EReal(_, _) -> true
  EFixed(_, _) -> true
  EBool(_) -> true
  EChar(_) -> true
  _ -> false
}

# Walk a body expression collecting reports for every ECall(EVar, ...).
# Calls into anonymous lambdas, method calls, etc. are skipped — the
# entailment table is keyed by fn name and we don't track higher-order
# values.
fn analyze_calls(e: Expr, sigs: [CalleeSig], caller_refs: [RefBinding],
                 acc: [CallSiteReport]) : [CallSiteReport] = match e.kind {
  ECall(callee, call_args) -> {
    let acc1 = analyze_calls_in_args(call_args, sigs, caller_refs, acc)
    match callee.kind {
      EVar(fname) -> match lookup_callee_sig(sigs, fname) {
        None -> acc1
        Some(cs) -> match cs {
          CSig(_, pnames, reqs) -> classify_call(fname, pnames, call_args, reqs, caller_refs, acc1, callee.line, callee.col)
        }
      }
      _ -> analyze_calls(callee, sigs, caller_refs, acc1)
    }
  }
  EBinop(_, a, b) -> analyze_calls(b, sigs, caller_refs, analyze_calls(a, sigs, caller_refs, acc))
  EUnop(_, x) -> analyze_calls(x, sigs, caller_refs, acc)
  EIf(c, t, eo) -> {
    let a1 = analyze_calls(c, sigs, caller_refs, acc)
    let a2 = analyze_calls(t, sigs, caller_refs, a1)
    match eo { None -> a2 Some(el) -> analyze_calls(el, sigs, caller_refs, a2) }
  }
  EBlock(stmts, tail) -> {
    let a1 = analyze_calls_in_stmts(stmts, sigs, caller_refs, acc)
    match tail { None -> a1 Some(t) -> analyze_calls(t, sigs, caller_refs, a1) }
  }
  EMatch(scr, arms) -> analyze_calls_in_arms(arms, sigs, caller_refs, analyze_calls(scr, sigs, caller_refs, acc))
  EField(b, _) -> analyze_calls(b, sigs, caller_refs, acc)
  EIndex(a, i) -> analyze_calls(i, sigs, caller_refs, analyze_calls(a, sigs, caller_refs, acc))
  EPipe(a, b) -> analyze_calls(b, sigs, caller_refs, analyze_calls(a, sigs, caller_refs, acc))
  EMapPipe(a, b) -> analyze_calls(b, sigs, caller_refs, analyze_calls(a, sigs, caller_refs, acc))
  EFlatMapPipe(a, b) -> analyze_calls(b, sigs, caller_refs, analyze_calls(a, sigs, caller_refs, acc))
  EFilterPipe(a, b) -> analyze_calls(b, sigs, caller_refs, analyze_calls(a, sigs, caller_refs, acc))
  EBang(x) -> analyze_calls(x, sigs, caller_refs, acc)
  ELambda(_, body) -> analyze_calls(body, sigs, caller_refs, acc)
  EList(elems) -> analyze_calls_in_list_elems(elems, sigs, caller_refs, acc)
  ERange(a, b, _) -> analyze_calls(b, sigs, caller_refs, analyze_calls(a, sigs, caller_refs, acc))
  ELitUnit(inner, _) -> analyze_calls(inner, sigs, caller_refs, acc)
  _ -> acc
}

fn analyze_calls_in_args(call_args: [Expr], sigs: [CalleeSig], caller_refs: [RefBinding],
                          acc: [CallSiteReport]) : [CallSiteReport] = match call_args {
  [] -> acc
  [a, ...rest] -> analyze_calls_in_args(rest, sigs, caller_refs, analyze_calls(a, sigs, caller_refs, acc))
}

fn analyze_calls_in_stmts(stmts: [Stmt], sigs: [CalleeSig], caller_refs: [RefBinding],
                           acc: [CallSiteReport]) : [CallSiteReport] = match stmts {
  [] -> acc
  [s, ...rest] -> {
    let acc1 = match s {
      SLet(_, _, e) -> analyze_calls(e, sigs, caller_refs, acc)
      SExprStmt(e) -> analyze_calls(e, sigs, caller_refs, acc)
      SAssert(c, opt_m) -> {
        let a1 = analyze_calls(c, sigs, caller_refs, acc)
        match opt_m { None -> a1 Some(m) -> analyze_calls(m, sigs, caller_refs, a1) }
      }
      _ -> acc
    }
    analyze_calls_in_stmts(rest, sigs, caller_refs, acc1)
  }
}

fn analyze_calls_in_arms(arms: [Arm], sigs: [CalleeSig], caller_refs: [RefBinding],
                          acc: [CallSiteReport]) : [CallSiteReport] = match arms {
  [] -> acc
  [a, ...rest] -> match a {
    Arm(_, _, body) -> analyze_calls_in_arms(rest, sigs, caller_refs, analyze_calls(body, sigs, caller_refs, acc))
  }
}

fn analyze_calls_in_list_elems(elems: [ListElem], sigs: [CalleeSig], caller_refs: [RefBinding],
                                acc: [CallSiteReport]) : [CallSiteReport] = match elems {
  [] -> acc
  [el, ...rest] -> {
    let acc1 = match el {
      ElPlain(e) -> analyze_calls(e, sigs, caller_refs, acc)
      ElSpread(e) -> analyze_calls(e, sigs, caller_refs, acc)
    }
    analyze_calls_in_list_elems(rest, sigs, caller_refs, acc1)
  }
}

fn lookup_callee_sig(sigs: [CalleeSig], name: String) : Option[CalleeSig] = match sigs {
  [] -> None
  [s, ...rest] -> match s {
    CSig(n, _, _) -> if n == name { Some(s) } else { lookup_callee_sig(rest, name) }
  }
}

# Drive the per-arg classification. For each requirement, find the
# arg the callee param it refers to maps to (positional, by name) and
# classify. `__requires` predicates are checked by substituting EVERY
# param name in the predicate with its corresponding arg before
# folding.
fn classify_call(fname: String, pnames: [String], call_args: [Expr], reqs: [CalleeReq],
                 caller_refs: [RefBinding], acc: [CallSiteReport],
                 line: Int, col: Int) : [CallSiteReport] = match reqs {
  [] -> acc
  [r, ...rest] -> match r {
    CR(pname, pred) -> {
      let status = if pname == "__requires" {
        classify_requires_clause(pred, pnames, call_args, caller_refs)
      } else {
        match arg_for_param(pnames, call_args, pname) {
          Some(arg) -> classify_arg_vs_pred(pred, pname, arg, caller_refs)
          None -> CSRuntime
        }
      }
      let rep = CSR(fname, pname, pred, status, line, col)
      classify_call(fname, pnames, call_args, rest, caller_refs, [rep, ...acc], line, col)
    }
  }
}

# A `requires` predicate may mention any param; substitute each param
# name with the corresponding arg expression (literal or refined
# binding) and either fold or check entailment.
fn classify_requires_clause(pred: Expr, pnames: [String], call_args: [Expr],
                             caller_refs: [RefBinding]) : CallSiteStatus {
  let subst = subst_params(pred, pnames, call_args)
  let folded = pred_canon(subst)
  match try_eval_pred(folded) {
    Some(true) -> CSElided
    Some(false) -> CSLoose(concat_all(["literal args violate `", expr_show_pred(pred), "`"]))
    None -> {
      # Try refinement-based discharge: if the substituted predicate
      # is a comparison whose only free var is a refined caller
      # binding, ask the lattice.
      match free_var_of_pred(folded) {
        Some(vname) -> match lookup_caller_refinement(caller_refs, vname) {
          Some(caller_pred) -> {
            let caller_canon = pred_canon(caller_pred)
            if expr_struct_eq(folded, caller_canon) { CSElided }
            else if pred_entailed_by_refinement(folded, vname, caller_canon) { CSElided }
            else { CSLoose(concat_all([
                    "caller refinement `", expr_show_pred(caller_pred),
                    "` does not entail callee precondition `",
                    expr_show_pred(pred), "`"])) }
          }
          None -> CSRuntime
        }
        None -> CSRuntime
      }
    }
  }
}

fn subst_params(pred: Expr, pnames: [String], call_args: [Expr]) : Expr = match pnames {
  [] -> pred
  [n, ...rest_n] -> match call_args {
    [] -> pred
    [a, ...rest_a] -> subst_params(subst_var(pred, n, a), rest_n, rest_a)
  }
}

fn arg_for_param(pnames: [String], call_args: [Expr], target: String) : Option[Expr] = match pnames {
  [] -> None
  [n, ...rest_n] -> match call_args {
    [] -> None
    [a, ...rest_a] -> if n == target { Some(a) } else { arg_for_param(rest_n, rest_a, target) }
  }
}

# Find the unique free variable of a comparison predicate, or None
# if it has zero or more than one. Used by classify_requires_clause
# to decide which caller refinement to consult.
fn free_var_of_pred(e: Expr) : Option[String] = match e.kind {
  EBinop(_, a, b) -> match free_var_of_pred(a) {
    Some(an) -> match free_var_of_pred(b) {
      Some(bn) -> if an == bn { Some(an) } else { None }
      None -> Some(an)
    }
    None -> free_var_of_pred(b)
  }
  EUnop(_, x) -> free_var_of_pred(x)
  EVar(s) -> Some(s)
  _ -> None
}

# Drive analyze_calls over a whole program. Each fn body is walked
# with the fn's own param refinements as the caller environment.
fn analyze_program_calls(decls: [Decl], sigs: [CalleeSig]) : [CallSiteReport] {
  analyze_program_calls_loop(decls, sigs, [])
}

fn analyze_program_calls_loop(decls: [Decl], sigs: [CalleeSig],
                                acc: [CallSiteReport]) : [CallSiteReport] = match decls {
  [] -> list_reverse(acc)
  [d, ...rest] -> match d {
    DFn(_, _, _, params, _, _, body, _, _, _) -> {
      let refs = collect_caller_refinements(params, [])
      let acc1 = analyze_calls(body, sigs, refs, acc)
      analyze_program_calls_loop(rest, sigs, acc1)
    }
    _ -> analyze_program_calls_loop(rest, sigs, acc)
  }
}

# `--dump-call-elision`: per-call-site report, one line per
# (callee, param) pair, in source order. Format mirrors
# `--dump-intervals`: `callee.param @line:col -> status`.
#[doc("Print the per-call-site refinement-elision report for the --dump-call-elision flag.")]
pub fn dump_call_elision(file: String, decls: [Decl]) : Int / Console {
  let sigs = collect_callee_sigs(decls)
  let reports = analyze_program_calls(decls, sigs)
  reports |> each(dump_call_elision_one)
  0
}

fn dump_call_elision_one(r: CallSiteReport) : Unit / Console = match r {
  CSR(fname, pname, pred, status, line, col) -> {
    let prefix = concat_all([fname, ".", pname, " @", int_to_string(line), ":",
                             int_to_string(col), " `", expr_show_pred(pred), "`"])
    match status {
      CSElided -> print("#{prefix} -> elided")
      CSRuntime -> print("#{prefix} -> runtime")
      CSLoose(reason) -> print("#{prefix} -> loose (#{reason})")
    }
  }
}

# Compile-time strictness: a refined binding passed where the callee
# wants a strictly stronger predicate is a static error. The reason
# string surfaces via the diagnostic so the user sees `>= 0 doesn't
# entail > 0`. Returns the number of errors emitted.
#[doc("Static check: error on each call passing a refined binding whose predicate is strictly weaker than the callee requires. Returns the error count.")]
pub fn check_call_site_refinements(file: String, decls: [Decl]) : Int / Console {
  let sigs = collect_callee_sigs(decls)
  let reports = analyze_program_calls(decls, sigs)
  check_call_site_loop(file, reports, 0)
}

fn check_call_site_loop(file: String, reports: [CallSiteReport], errs: Int) : Int / Console = match reports {
  [] -> errs
  [r, ...rest] -> match r {
    CSR(fname, _, _, status, line, col) -> match status {
      CSLoose(reason) -> {
        eprint("#{file}:#{int_to_string(line)}:#{int_to_string(col)}: error: call to `#{fname}`: #{reason}\n")
        check_call_site_loop(file, rest, errs + 1)
      }
      _ -> check_call_site_loop(file, rest, errs)
    }
  }
}

