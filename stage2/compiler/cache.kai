      match cache_hex_to_bool(buf, p1) {
        None -> None
        Some(cbp2) -> match cbp2 { CBP(ec_flag, p2) ->
          match cache_hex_to_string(buf, p2) {
            None -> None
            Some(csp1) -> match csp1 { CSP(name, p3) ->
              match cache_hex_to_string(buf, p3) {
                None -> None
                Some(csp2) -> match csp2 { CSP(csym, p4) ->
                  cache_hex_to_daxiom_tail(buf, p4, extc, ec_flag, name, csym)
                }
              }
            }
          }
        }
      }
    }
  }
}

fn cache_hex_to_daxiom_tail(buf: String, pos: Int, extc: Bool, ec_flag: Bool,
                              name: String, csym: String) : Option[CacheDeclPos] {
  match cache_hex_to_string_list(buf, pos) {
    None -> None
    Some(csl) -> match csl { CSLP(tps, p1) ->
      match cache_hex_to_param_list(buf, p1) {
        None -> None
        Some(cpl) -> match cpl { CPmLP(prms, p2) ->
          match cache_hex_to_typeexpr(buf, p2) {
            None -> None
            Some(ct) -> match ct { CTyP(rt, p3) ->
              match cache_hex_to_row(buf, p3) {
                None -> None
                Some(crw) -> match crw { CRowP(row, p4) ->
                  match cache_hex_to_int(buf, p4) {
                    None -> None
                    Some(cl) -> match cl { CIP(ln, p5) ->
                      match cache_hex_to_int(buf, p5) {
                        None -> None
                        Some(cc) -> match cc { CIP(cn, p6) ->
                          Some(CDP(DAxiom(extc, ec_flag, name, csym, tps,
                                          prms, rt, row, ln, cn), p6))
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}

fn cache_hex_to_dconst(buf: String, pos: Int) : Option[CacheDeclPos] {
  match cache_hex_to_bool(buf, pos) {
    None -> None
    Some(cbp) -> match cbp { CBP(is_pub, p1) ->
