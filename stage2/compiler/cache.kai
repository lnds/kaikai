        Some(csp) -> match csp { CSP(name, p2) ->
          match cache_hex_to_typeexpr(buf, p2) {
            None -> None
            Some(ct) -> match ct { CTyP(ty, p3) ->
              match cache_hex_to_expr(buf, p3) {
                None -> None
                Some(ce) -> match ce { CEP(body, p4) ->
                  match cache_hex_to_opt_string(buf, p4) {
                    None -> None
                    Some(cmo) -> match cmo { COSP(mo, p5) ->
                      match cache_hex_to_int(buf, p5) {
                        None -> None
                        Some(cl) -> match cl { CIP(ln, p6) ->
                          match cache_hex_to_int(buf, p6) {
                            None -> None
                            Some(cc) -> match cc { CIP(cn, p7) ->
                              Some(CDP(DConst(is_pub, name, ty, body, mo, ln, cn), p7))
