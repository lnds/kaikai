# compiler/kir_lower_walk.kai — the Expr→ANF recursion.
#
# `lower_expr ↔ lower_call ↔ lower_if/lower_match` are one mutual-recursion
# cycle; the module DAG cannot split a cycle, so they share this module
# (the same reason emit_expr/emit_stmt live together in emit_c). The
# NON-recursive base (state, name supply, type/decl walks, pure helpers)
# lives in `kir_lower.kai`, which this module imports — base ← walk only,
# so the import graph stays acyclic.
#
# This is the single semantics-bearing pass (design §5): ANF flattening +
# basic-block construction + sentinel decode + KRC placement, written ONCE
# so the two translators (KIR→C, KIR→LLVM) stay dumb.

import compiler.ast
import compiler.util
import compiler.fnreg
import compiler.emit_shared
import compiler.infer
import compiler.perceus
import compiler.region
import compiler.kir
import compiler.kir_lower
import compiler.kir_pat_alias
import compiler.kir_lower_reuse
import compiler.kir_lower_raw
import compiler.cell_promote
import compiler.loop_lower
import compiler.kir_lower_bind
import compiler.kir_lower_match
import compiler.kir_lower_lit
import compiler.kir_lower_rec
import compiler.kir_lower_variant
import compiler.vec_raw
import compiler.emit_tcrec_live

# --- The Expr walk ------------------------------------------------------
#
# The program/fn-level orchestration (`lower_to_kir`, the per-decl walk,
# and the lifted `KFnLambda` / `KFnClause` generation) lives in
# `kir_lower_fns.kai` — it drives ON `lower_expr` but `lower_expr` never
# calls back, so the split keeps the import graph acyclic and each file
# within the size cap. This module is the Expr-SCC: the mutual recursion
# `lower_expr ↔ lower_call ↔ lower_if/match/handle/list/...`.

# Lower an expression in BOXED position (the default — every value-bearing
# slot a call/record/list/return wants is a boxed `ptr`). MODE-SLAVE to the
# unbox pass (asu, Camino A): a `MUnboxed` Real node is a raw `f64` in a
# boxed context, so lower it RAW (`lower_expr_raw`) and BOX at the border
# (`real.box` → `kaix_real`). The boxed `KLet` carries `SBoxed`, identical
# to the oracle's `box_wrap(x.ty, raw)`. `MUnboxed` nodes outside the raw
# FORM set (see kir_lower_raw SCOPE) fall straight to the boxed dispatch.
# Non-`MUnboxed` nodes (the boxed families other lanes own) never enter
# the raw branch: purely additive.
pub fn lower_expr(x: Expr, st: LowerSt) : LRes / Console =
  if kir_node_is_raw(x) {
    match lower_expr_raw(x, st) {
      LRes(rawv, st1) -> bind_op(st1, KPrim(kir_raw_box_prim(x.ty), [rawv]), kpos_of(x))
    }
  } else { lower_expr_boxed(x, st) }

# The boxed-position dispatch (the original `lower_expr` body). Reached
# either directly (non-raw node) or as the boxed fallback inside the raw
# path (`lower_expr_raw`'s box→raw border lowers boxed here then unboxes).
fn lower_expr_boxed(x: Expr, st: LowerSt) : LRes / Console = match x.kind {
  # Atoms: no statement, the literal IS the value.
  EInt(n)            -> LRes(kir_int_atom(x, n), st)
  EReal(r, _)           -> LRes(KRealV(r), st)
  EFixed(span, ty)      -> LRes(KFixedV(span, ty), st)
  EBool(b)           -> LRes(KBoolV(b), st)
  EChar(c)           -> LRes(KCharV(c), st)
  EStr(span, _)      -> LRes(KStrV(span), st)
  EUnit              -> LRes(KUnitV, st)
  EUnder             -> LRes(KUnitV, st)
  EPlaceholder       -> LRes(KUnitV, st)
  EVar(name)         -> lower_var(name, st)

  # A call / constructor / perceus mark / sentinel — the dense dispatch.
  ECall(f, cargs)    -> match lower_vec_write_rec_fused(x, f, cargs, st) {
    Some(r) -> r
    None    -> lower_call(x, f, cargs, st)
  }

  # `e.field` → a field read over the base atom. When `base.ty` resolves to
  # a known record, the field's slot is a compile-time constant (layout is
  # canonical, declaration order) → `kai_op_field_at` indexed load, skipping
  # the `kai_op_field` strcmp. Unknown / polymorphic base type keeps strcmp.
  # The read increfs the field; the base arrives OWNED (perceus dups non-last
  # reads, transfers single-use, ctors return rc=1) and is no longer reachable
  # through the result, so drop it to balance — the C oracle's `kai_decref(_b)`
  # after the field load.
  EField(base, fname) -> match lower_vec_get_field_fused(x, base, fname, st) {
    Some(r) -> r
    None -> {
      let rb = lower_expr(base, st)
      match rb { LRes(bv, st1) ->
        match field_index_of(st1.recs, base.ty, fname) {
          Some(n) -> lower_field_read(st1, KPrim("kai_op_field_at", [bv, KIntV(n)]), bv, kpos_of(x))
          None    -> lower_field_read(st1, KPrim("kai_op_field", [bv, KStrV(fname)]), bv, kpos_of(x))
        } }
    }
  }

  # Binary / unary operators → a KPrim over their operand atoms. The
  # specific runtime helper is the translator's concern.
  EBinop(op, a, b)   -> {
    let ra = lower_expr(a, st)
    match ra { LRes(av, st1) -> {
      let rbv = lower_expr(b, st1)
      match rbv { LRes(bv, st2) -> bind_op(st2, KPrim(binop_prim(op, a), [av, bv]), kpos_of(x)) }
    } }
  }
  EUnop(op, a)       -> {
    let ra = lower_expr(a, st)
    match ra { LRes(av, st1) -> bind_op(st1, KPrim(unop_prim(op), [av]), kpos_of(x)) }
  }

  EIf(c, t, e_opt)   -> lower_if(x, c, t, e_opt, st)
  EMatch(scr, arms)  -> lower_match(x, scr, arms, st)
  EBlock(stmts, tail) -> lower_block(x, stmts, tail, st)

  # `[e0, e1, ..., ...spread]` → a cons/nil/append spine, reproducing the
  # C emitter's `emit_list_tail` shape (the oracle). Interpolation
  # desugars to `string_concat_all([parts])` long upstream, so closing
  # EList closes interpolation too.
  EList(elems)       -> lower_list(elems, kpos_of(x), st)

  # Unit-annotated literal (`1.0<USD>`) is codegen-erased to its inner.
  ELitUnit(inner, _) -> lower_expr(inner, st)

  # An unfilled hole / `todo!(msg)` lowers to a loud runtime panic stub
  # (mirror of the emitters: a binary with holes is runnable but aborts
  # on first reach). The message bundles the location like emit_c does.
  EHole(nm_opt)      -> lower_panic_stub(kir_hole_message(nm_opt, x), st)
  ETodo(msg)         -> lower_panic_stub(kir_quote(cat2("todo: ", msg)), st)
  EExternBody(_)     -> lower_panic_stub(kir_quote("extern body in expression position"), st)
  # Textual literals are minted away by the typer; reaching lowering is a
  # compiler bug.
  EIntLit(_)         -> lower_panic_stub(kir_quote("EIntLit reached lowering"), st)
  EDecimalLit(_)     -> lower_panic_stub(kir_quote("EDecimalLit reached lowering"), st)

  # `variants[T]()` — the typer baked the resolved nullary-ctor names in;
  # materialise them as a cons spine of nullary constructors (emit_c
  # `emit_variants_of_list`). Reuses the list lowering over synthetic
  # ctor-call elems.
  EVariantsOf(_, names) -> lower_variants_of(names, kpos_of(x), st)

  # A record literal `T { f: v, ... }` → a `kai_record(n, fields, names)`
  # allocation. Lower each field value (left-to-right), pairing with its
  # name; the translator builds the parallel value/name buffers.
  ERecordLit(_, fis) -> lower_record_lit(fis, kpos_of(x), st)

  # A range `lo..hi` / `lo..hi:step` → the runtime range builder.
  ERange(lo, hi, stp) -> lower_range(lo, hi, stp, kpos_of(x), st)

  # A qualified name in value position (`let f = mod.fn`) → a fn-value
  # closure or a nullary-ctor value (emit_c's EModCall value arm).
  EModCall(modn, name) -> lower_modcall_value(modn, name, kpos_of(x), st)

  # An inline lambda → a `KClosure` over its lifted-body thunk symbol
  # (`lam_symbol`), carrying its captures as atoms. The lifted body
  # itself is a separate `KFnLambda` (generated in `lower_to_kir`); here
  # we only build the closure value. The `LamInfo` is found by
  # (enclosing-fn, line, col) — the key the collector stamped.
  ELambda(_, _)      -> lower_lambda_ref(x, st)

  # An effect handler. Materialises the handler frame as a double fork
  # (install + setjmp-split + inline body + return clause), the same
  # block-building discipline as if/match (asu review). The clause bodies
  # are separate `KFnClause`s generated in `lower_to_kir`.
  EHandle(body, eff, _, init_opt, alias_opt, _, ret_opt) ->
    lower_handle(x, body, eff, init_opt, alias_opt, ret_opt, st)

  # Postfix `!` — Option/Result propagation. `expr!` unwraps the success
  # payload, or EARLY-RETURNS the whole `None`/`Err` from the enclosing fn
  # (mirror of emit_c's `emit_bang`). The discriminator (`Some` vs `Ok`) is
  # read from `inner.ty` via the shared `bang_success_variant`.
  EBang(inner)       -> lower_bang(x, inner, st)

  # Forms the resolve / desugar / typer passes rewrite away before codegen
  # (`EMapPipe`/`EFlatMapPipe`/`EFilterPipe` → ECall, `EPipe` desugared,
  # `EIndex` → call, `EUnder`/`EPlaceholder` pattern-only). These never
  # reach a post-perceus AST; lowering to unit keeps the match exhaustive
  # and mirrors the emitters' dead arms.
  #
  # `EPipe` SURVIVES to codegen: the typer (`infer.kai`'s `synth_pipe`)
  # rebuilds `EPipe(lhs, ECall(f, args))` / `EPipe(lhs, EModCall(m, f))`
  # rather than desugaring to `ECall`, leaving each emitter its own pipe
  # desugaring (emit_c has `emit_pipe_expr`, the byte-id oracle). `lower_pipe`
  # mirrors it: rewrite the pipe to the equivalent `ECall` with `lhs`
  # spliced in as the FIRST argument, then delegate to `lower_call` — so the
  # full named-call dispatch (ctor / core / efn / variant / kaix_apply)
  # is reused unchanged. The earlier burn-down-3 partial cut "trapped" only
  # because it built the `ECall` callee/args by hand and reached an unhandled
  # shape; routing through `lower_call` (the same path a non-piped call
  # takes) makes the multi-candidate combinators (`filter`/`map`/`each`)
  # fall out for free. Closes the pipe-lowering family (collatz / euler1 /
  # fizzbuzz / imc / capture output-mismatch + quicksort's infinite-recursion
  # SIGSEGV, where a lost `filter` left `sort(unit)` recursing on a non-
  # shrinking input).
  EPipe(lhs, rhs)    -> lower_pipe(x, lhs, rhs, st)

  # A promoted var cell in boxed position: a read boxes the raw register
  # at its scalar type; a write stores the raw value and yields unit. A
  # loop intrinsic pastes its pred/body lambda bodies into an inline
  # block loop in the enclosing fn (the C emitter's `for (;;)` mirror).
  EIntrinsic(inm, iargs) ->
    if is_cell_get(inm) {
      bind_op(st, KPrim(kir_raw_box_prim(x.ty), [KVar(lower_cell_reg(inm, st))]), kpos_of(x))
    }
    else if is_cell_set(inm) { lower_cell_set(x, inm, iargs, st) }
    else if is_loop_intrinsic(inm) { lower_loop_intrinsic(x, inm, iargs, st) }
    else { lower_unhandled(x, st) }

  # Forms the resolve / desugar / typer passes rewrite away before codegen
  # (`EMapPipe`/`EFlatMapPipe`/`EFilterPipe` → ECall, `EIndex` → call,
  # `EUnder`/`EPlaceholder` pattern-only). These never reach a post-perceus
  # AST; lowering to unit keeps the match exhaustive and mirrors the
  # emitters' dead arms.
  EMapPipe(_, _)     -> LRes(KUnitV, st)
  EFlatMapPipe(_, _) -> LRes(KUnitV, st)
  EFilterPipe(_, _)  -> LRes(KUnitV, st)
  EIndex(_, _)       -> LRes(KUnitV, st)

  # Anything else reaching here is a node codegen DOES handle that the
  # lowering has not yet covered — a silent unit would mis-lower it (the
  # Lane 0 gap class). Trap it loudly during development so the next
  # unhandled family cannot slip through unnoticed (lane discipline).
  _ -> lower_unhandled(x, st)
}

# Loud trap for an AST node the lowering does not yet cover but codegen
# does. Prints the kind + position to stderr and lowers to unit so the
# dump still completes; the parity gate (not "no panic") is what catches
# the divergence. Replaces the old silent catch-all (Lane 0 gap).
fn lower_unhandled(x: Expr, st: LowerSt) : LRes / Console {
  eprint(concat_all(["kir: unhandled expr kind ", kir_expr_kind_name(x.kind),
                     " at ", int_to_string(x.line), ":", int_to_string(x.col)]))
  LRes(KUnitV, st)
}

# --- raw (unboxed) Real/Int lowering (asu, Camino A + P1) --------------
#
# Lower `x` in RAW position: the result is a raw scalar — an `f64` (`SReal`)
# for Real, an `i64` (`SInt64`) for Int, or an i1/i32 (`SBool`) for a
# comparison — NOT a boxed `ptr`. Mirror of the C-direct oracle's
# `emit_expr_raw` / `emit_kind_raw`, over Real + Int arith/cmp (kir_lower_raw
# SCOPE). Two cases by `.mode`:
#   - `MUnboxed` node → it IS a natively-raw form (literal / raw EVar / raw
#     arith / raw cmp / raw neg): emit the raw op directly, no boxing.
#   - any other node in raw position → a BOXED value read raw (the box→raw
#     border, e.g. `self.re` field access, or an Int-returning UFn call in
#     an arith chain): lower boxed then unbox-borrow by type
#     (`real.unbox` → `kaix_real_field` / `int.unbox` → `kaix_int_field`,
#     non-consuming, the oracle's bare `(boxed)->as.r` / `(boxed)->as.i`).
# The mutual recursion `lower_expr ↔ lower_expr_raw` is why this lives in
# the Expr-SCC (not the pure `kir_lower_raw` helper module).
fn lower_expr_raw(x: Expr, st: LowerSt) : LRes / Console =
  match x.mode {
    MUnboxed -> lower_expr_raw_kind(x, st)
    _        -> lower_scalar_unbox_border(x, st)
  }

# Lower `x` raw at a KNOWN destination slot (a call arg at its param's raw
# slot). A `MUnboxed` node lowers raw by its own form; a boxed node crosses
# the border to the GIVEN slot, NOT one inferred from `x.ty`. The type-driven
# `lower_scalar_unbox_border` mis-routes when the arg's `.ty` is absent /
# unresolved (a generic-fn `EVar` the typer left untyped — `take(xs, mid)`
# where `mid`'s ref carries no `Ty`): it falls to `real.unbox` over a boxed
# Int, the `kaix_int_field(double)` verifier mismatch. Keying off the PARAM's
# slot (the callee's declared `SInt64`/`SReal`/`SBool`) is exact.
fn lower_expr_raw_at(x: Expr, slot: KSlot, st: LowerSt) : LRes / Console =
  match x.mode {
    MUnboxed -> lower_expr_raw_kind(x, st)
    _        -> lower_scalar_unbox_border_at(x, slot, st)
  }

# The box→raw border at a KNOWN slot: lower boxed, then unbox-borrow through
# the slot's prim (`int.unbox`/`real.unbox`/`bool.unbox`). A `SBoxed` slot is
# a lowering bug (a raw arg never targets a boxed param) — fall back to the
# plain boxed lowering so the value is at least well-formed.
fn lower_scalar_unbox_border_at(x: Expr, slot: KSlot, st: LowerSt) : LRes / Console = match slot {
  SInt64 -> match lower_expr_boxed(x, st) { LRes(bv, st1) -> bind_op_slot(st1, KPrim("int.unbox", [bv]), SInt64, kpos_of(x)) }
  SReal  -> match lower_expr_boxed(x, st) { LRes(bv, st1) -> bind_op_slot(st1, KPrim("real.unbox", [bv]), SReal, kpos_of(x)) }
  SBool  -> match lower_expr_boxed(x, st) { LRes(bv, st1) -> bind_op_slot(st1, KPrim("bool.unbox", [bv]), SBool, kpos_of(x)) }
  SChar  -> match lower_expr_boxed(x, st) { LRes(bv, st1) -> bind_op_slot(st1, KPrim("char.unbox", [bv]), SChar, kpos_of(x)) }
  _      -> lower_expr_boxed(x, st)
}

# A boxed scalar read in raw position: lower it boxed, then unbox-borrow its
# raw payload. The border is TYPE-DRIVEN — an Int node crosses through
# `int.unbox` (→ `kaix_int_field`, slot `SInt64`), a Bool through
# `bool.unbox` (→ `kaix_bool_field`, slot `SBool`), any other (Real) through
# `real.unbox` (→ `kaix_real_field`, slot `SReal`). NON-consuming in all
# cases — the box stays owned by its binding for the normal drop (the
# oracle's bare `(boxed)->as.i` / `(boxed)->as.b` / `(boxed)->as.r`). The
# type gate is load-bearing: a Real-only border would `real.unbox` a boxed
# Bool (`kaix_real_field` reading `as.r` off a Bool) — a silent miscompile +
# the LLVM type mismatch the verifier rejects. The Bool case is reached by a
# raw-Bool call arg (a `neg: Bool` param the callee unboxes — `lower_tcrec_
# args` lowers it raw at the param's `SBool` slot).
fn lower_scalar_unbox_border(x: Expr, st: LowerSt) : LRes / Console =
  if kir_ty_is_int(x.ty) {
    match lower_expr_boxed(x, st) {
      LRes(bv, st1) -> bind_op_slot(st1, KPrim("int.unbox", [bv]), SInt64, kpos_of(x))
    }
  } else if kir_ty_is_bool(x.ty) {
    match lower_expr_boxed(x, st) {
      LRes(bv, st1) -> bind_op_slot(st1, KPrim("bool.unbox", [bv]), SBool, kpos_of(x))
    }
  } else if kir_ty_is_char(x.ty) {
    match lower_expr_boxed(x, st) {
      LRes(bv, st1) -> bind_op_slot(st1, KPrim("char.unbox", [bv]), SChar, kpos_of(x))
    }
  } else {
    match lower_expr_boxed(x, st) {
      LRes(bv, st1) -> bind_op_slot(st1, KPrim("real.unbox", [bv]), SReal, kpos_of(x))
    }
  }

# The natively-raw forms (the `MUnboxed` kinds the unbox pass produces).
# Real arith / neg yield `SReal`; Int arith yields `SInt64`; comparison /
# logical yield `SBool`. A comparison routes to the f- or i-prim by OPERAND
# type. Anything else falls back to the type-driven box→raw border (a
# defensive unbox of its boxed form) — never a silent miscompile.
fn lower_expr_raw_kind(x: Expr, st: LowerSt) : LRes / Console = match x.kind {
  EReal(r, _) -> LRes(KRealV(r), st)
  EInt(n)     -> LRes(KIntV(n), st)
  EFixed(span, ty) -> LRes(KFixedV(span, ty), st)
  EBool(b)    -> LRes(KBoolV(b), st)
  EChar(c)    -> LRes(KCharV(c), st)
  EVar(name)  -> lower_var(name, st)
  ELitUnit(inner, _) -> lower_expr_raw(inner, st)
  # Arith routes by RESULT type (mirror of `kir_kind_is_raw`): a Real-typed
  # node lowers the f-family (`f+`, `SReal`), an Int-typed node the i-family
  # (`i+`, `SInt64`). Routing by op string alone would send Int `+` down the
  # Real `f+` path (a miscompile — `fadd` over i64 operands). A comparison
  # routes by OPERAND type (its result is Bool, not the scalar).
  EBinop(op, a, b) ->
    if kir_ty_is_real(x.ty) and kir_op_is_raw_freal_arith(op) {
      lower_raw_binop(x, kir_raw_arith_prim(op), SReal, a, b, st)
    }
    else if kir_ty_is_int(x.ty) and kir_op_is_raw_iint_arith(op) {
      lower_raw_binop(x, kir_raw_iarith_prim(op), SInt64, a, b, st)
    }
    else if kir_op_is_raw_cmp(op) {
      if kir_ty_is_int(a.ty) { lower_raw_binop(x, kir_raw_icmp_prim(op), SBool, a, b, st) }
      else { lower_raw_binop(x, kir_raw_cmp_prim(op), SBool, a, b, st) }
    }
    else if kir_op_is_raw_logical(op) { lower_raw_binop(x, kir_raw_logical_prim(op), SBool, a, b, st) }
    else { lower_scalar_unbox_border(x, st) }
  # Unary `-` is raw ONLY for Real (`fneg` over f64); an Int `-x` has no raw
  # `ineg` form in v1, so it crosses the box→raw border (boxed `kaix_neg`
  # then `int.unbox`). Routing every `-` to `fneg`/`SReal` would emit
  # `fneg ptr` over a boxed/i64 operand (the `int_cache_reuse_bump` crash:
  # a raw-Int `seen == -1` recursing into the `-1` unop). `not` stays raw
  # (i1 over a raw bool).
  EUnop(op, a) ->
    if op == "-" and kir_ty_is_real(x.ty) {
      match lower_expr_raw(a, st) {
        LRes(av, st1) -> bind_op_slot(st1, KPrim("fneg", [av]), SReal, kpos_of(x))
      }
    } else if op == "not" {
      match lower_expr_raw(a, st) {
        LRes(av, st1) -> bind_op_slot(st1, KPrim("bnot", [av]), SBool, kpos_of(x))
      }
    } else { lower_scalar_unbox_border(x, st) }
  # A call in raw position (`fib(n-1) + fib(n-2)` — each call is an arith
  # OPERAND, not a `let`-binder). Route it through the ORDINARY call dispatch:
  # `lower_direct_call` binds the result at the callee's return slot, so a
  # raw-return UFn lands its `i64`/`f64`/`i1` in a raw register and the
  # consuming `lower_raw_binop` reads it directly (`nemit_load_reg_as_int`,
  # no `kaix_int_field`) — eliminating the `kaix_int` box + `kaix_int_field`
  # unbox round-trip the old `_`-arm border emitted per call (the ~8× on
  # `fib`-tree recursion). A callee with a BOXED return resolves to an
  # `SBoxed` register; the consumer then unbox-borrows at the slot exactly
  # as the border did, so a non-raw callee keeps the prior behaviour. Mirror
  # of the oracle's `emit_kind_raw` ECall arm → `emit_ufn_raw_call`. RC: a
  # raw call result carries no refcount; perceus already skipped it (the
  # node is `MUnboxed`), so no KDup/KDrop lands on the raw register.
  ECall(f, cargs) -> lower_call(x, f, cargs, st)
  # A single-tail block transparently wraps its raw tail (no preceding
  # statements). A multi-statement block, or any other shape, is not a
  # natively-raw form: lower it boxed then unbox-borrow at the border.
  EBlock(stmts, tail) ->
    match stmts {
      [] -> match tail { Some(t) -> lower_expr_raw(t, st) None -> lower_scalar_unbox_border(x, st) }
      _  -> lower_scalar_unbox_border(x, st)
    }
  # A promoted var cell: a read is the raw register itself (resolving an
  # active shadow rename, like an `EVar` read); the init forwards its raw
  # literal.
  EIntrinsic(inm, iargs) ->
    if is_cell_get(inm) { LRes(KVar(lower_cell_reg(inm, st)), st) }
    else if inm == "__cell_init" { match iargs {
      [init] -> lower_expr_raw(init, st)
      _      -> lower_scalar_unbox_border(x, st)
    } }
    else { lower_scalar_unbox_border(x, st) }
  # The guard (`kir_node_is_raw`) only admits the FORMS above, so this arm is
  # reached only via internal recursion on a sub-operand the unbox pass left
  # boxed — lower it boxed and unbox-borrow its raw scalar (the box→raw
  # border, by type).
  _ -> lower_scalar_unbox_border(x, st)
}

# A promoted var cell's register: the surface binder name, resolving an
# active shadow rename exactly like an `EVar` read of a local.
fn lower_cell_reg(inm: String, st: LowerSt) : String = {
  let nm = cell_intrinsic_name(inm)
  match ls_lookup_rename(st, nm) { Some(reg) -> reg None -> nm }
}

fn cell_slot_of_ty(opt_t: Option[Ty]) : KSlot =
  if kir_ty_is_real(opt_t) { SReal }
  else if kir_ty_is_bool(opt_t) { SBool }
  else { SInt64 }

fn cell_unbox_prim(slot: KSlot) : String = match slot {
  SReal -> "real.unbox"
  SBool -> "bool.unbox"
  _     -> "int.unbox"
}

# A promoted var cell's write: store the raw value into the cell's
# register (an alloca — the same mutation KStore performs for TCO loop
# assigns). A raw value stores directly; a boxed value crosses the
# border (borrowing unbox) and is then dropped — the store owns the
# scalar, and a raw register carries no RC to hand the box to.
fn lower_cell_set(x: Expr, inm: String, iargs: [Expr], st: LowerSt) : LRes / Console = match iargs {
  [v] -> {
    let reg = lower_cell_reg(inm, st)
    match v.mode {
      MUnboxed -> match lower_expr_raw(v, st) {
        LRes(rv, st1) -> LRes(KUnitV, ls_emit(st1, KStore(reg, rv, kpos_of(x))))
      }
      _ -> {
        let slot = cell_slot_of_ty(v.ty)
        match lower_expr_boxed(v, st) {
          LRes(bv, st1) -> match bind_op_slot(st1, KPrim(cell_unbox_prim(slot), [bv]), slot, kpos_of(x)) {
            LRes(rv, st2) ->
              LRes(KUnitV, ls_emit(ls_emit(st2, KStore(reg, rv, kpos_of(x))),
                                   KRC(KDrop(bv), kpos_of(x))))
          }
        }
      }
    }
  }
  _ -> lower_unhandled(x, st)
}

# --- loop intrinsics (inline block loops) -------------------------------
#
# The loop combinator's pred/body arrive as literal nullary lambdas the
# collector never lifted (they are not closures); their bodies lower
# INLINE into cond/body blocks with a backedge, in the enclosing fn's
# frame — so a promoted var cell mutated by the loop is a plain alloca
# the backedge re-reads. RC inside the pasted bodies was computed under
# the closure discipline (per-iteration balance), same as the C paste.

fn lower_loop_intrinsic(x: Expr, inm: String, iargs: [Expr], st: LowerSt) : LRes / Console = match iargs {
  [_, a, b] ->
    if inm == "__loop_while" { lower_loop_while(x, loop_lam_body(a), loop_lam_body(b), st) }
    else if inm == "__loop_until" { lower_loop_until(x, loop_lam_body(a), loop_lam_body(b), st) }
    else if inm == "__loop_repeat" { lower_loop_repeat(x, a, loop_lam_body(b), st) }
    else { lower_unhandled(x, st) }
  _ -> lower_unhandled(x, st)
}

fn loop_lam_body(e: Expr) : Expr = match e.kind {
  ELambda(_, b) -> b
  _             -> e
}

# `while { pred } { body }`: cond block (backedge target) evaluates the
# pred and forks to body/exit; the body block re-enters the cond.
fn lower_loop_while(x: Expr, pred: Expr, body: Expr, st: LowerSt) : LRes / Console =
  match three_labels(st) { LSL3(lcond, lbody, lcont, st1) -> {
    let st2 = ls_seal(st1, KBr(lcond, kpos_of(x)), lcond)
    match lower_loop_cond(pred, st2) { LRes(cv, st3) -> {
      let st4 = ls_seal(st3, KCondBr(cv, lbody, lcont, kpos_of(x)), lbody)
      let st5 = lower_loop_body(body, st4)
      LRes(KUnitV, ls_seal(st5, KBr(lcond, kpos_of(x)), lcont))
    } }
  } }

# `until { pred } { body }`: body runs first, then the pred in the same
# block; exit when it holds.
fn lower_loop_until(x: Expr, pred: Expr, body: Expr, st: LowerSt) : LRes / Console =
  match three_labels(st) { LSL3(lbody, _, lcont, st1) -> {
    let st2 = ls_seal(st1, KBr(lbody, kpos_of(x)), lbody)
    let st3 = lower_loop_body(body, st2)
    match lower_loop_cond(pred, st3) { LRes(cv, st4) ->
      LRes(KUnitV, ls_seal(st4, KCondBr(cv, lcont, lbody, kpos_of(x)), lcont))
    }
  } }

# `repeat(n) { body }`: a raw i64 count-down register.
fn lower_loop_repeat(x: Expr, n: Expr, body: Expr, st: LowerSt) : LRes / Console =
  match lower_loop_count(n, st) { LRes(nv, st1) ->
    match ls_fresh_reg(st1) { LSReg(reg, st2) -> {
      let st3 = ls_emit(st2, KLet(reg, SInt64, KLitOp(nv), kpos_of(x)))
      match three_labels(st3) { LSL3(lcond, lbody, lcont, st4) -> {
        let st5 = ls_seal(st4, KBr(lcond, kpos_of(x)), lcond)
        match bind_op_slot(st5, KPrim("i>", [KVar(reg), KIntV(0)]), SBool, kpos_of(x)) { LRes(cv, st6) -> {
          let st7 = ls_seal(st6, KCondBr(cv, lbody, lcont, kpos_of(x)), lbody)
          let st8 = lower_loop_body(body, st7)
          match bind_op_slot(st8, KPrim("i-", [KVar(reg), KIntV(1)]), SInt64, kpos_of(x)) { LRes(dv, st9) -> {
            let st10 = ls_emit(st9, KStore(reg, dv, kpos_of(x)))
            LRes(KUnitV, ls_seal(st10, KBr(lcond, kpos_of(x)), lcont))
          } }
        } }
      } }
    } }
  }

# The loop condition: raw when the unbox pass marked it (an i1 the
# condbr reads directly), else boxed (the condbr truthy path) — the
# same split `lower_if` applies.
fn lower_loop_cond(pred: Expr, st: LowerSt) : LRes / Console =
  if kir_node_is_raw(pred) { lower_expr_raw(pred, st) }
  else { lower_expr(pred, st) }

# The loop body in statement position: its per-iteration value is
# discarded (a `KDo`, the SExprStmt shape).
fn lower_loop_body(body: Expr, st: LowerSt) : LowerSt / Console =
  match lower_expr(body, st) { LRes(v, st1) -> ls_emit(st1, KDo(KLitOp(v), kpos_of(body))) }

# The repeat count: raw when marked, else a boxed Int crossed at the
# border (borrowing unbox) and dropped — the count is consumed here.
fn lower_loop_count(n: Expr, st: LowerSt) : LRes / Console = match n.mode {
  MUnboxed -> lower_expr_raw(n, st)
  _ -> match lower_expr_boxed(n, st) {
    LRes(bv, st1) -> match bind_op_slot(st1, KPrim("int.unbox", [bv]), SInt64, kpos_of(n)) {
      LRes(rv, st2) -> LRes(rv, ls_emit(st2, KRC(KDrop(bv), kpos_of(n))))
    }
  }
}

# `a <op> b` raw binary op → one native instruction over two raw operands.
# Both operands lower raw (recursing through `lower_expr_raw`); the result
# register carries `slot` (SReal for arith, SBool for cmp/logical). No
# boxed `kaix_*` consume, so a multi-use operand never double-frees (the
# family's root bug).
fn lower_raw_binop(x: Expr, prim: String, slot: KSlot, a: Expr, b: Expr, st: LowerSt) : LRes / Console =
  match lower_expr_raw(a, st) { LRes(av, st1) ->
    match lower_expr_raw(b, st1) { LRes(bv, st2) ->
      bind_op_slot(st2, KPrim(prim, [av, bv]), slot, kpos_of(x))
    }
  }

# An `EVar` in value position resolves through the SAME cascade the
# C-direct oracle's `emit_ident_value` / const arm walks (and emit_llvm's
# `llvm_emit_fn_value`), in this order:
#   1. nullary constructor (`None` / `Red`) → a `KCon`. Must come FIRST: an
#      uppercase-initial registered variant is a ctor, not a local —
#      leaving it a bare `KVar` makes a backend look up a register never
#      bound (the C emitter materialises it via `kai_nullary`).
#   2. a LOCAL binder (param / capture / `let` / match binder) → a `KVar`
#      atom read. This is checked BEFORE const/fn-value so a local name
#      that collides with a top-level `const` / stdlib `pub fn` / core
#      builtin SHADOWS it (the locals-shadow-imports rule, #748/#749 — the
#      same rule emit_c applies via its `EmitCtx.lcs`). Without it, a param
#      named `init` (vs stdlib `list.init`), `foldl`'s `init`, etc. lowered
#      to a closure over the stdlib thunk; that closure then reached an
#      arithmetic op as a non-Int operand (the runtime-type-mismatch family).
#   3. top-level `const` (`ANSWER`, `real_pi`) → materialise its literal
#      body INLINE (a const is a literal with a name, not a function;
#      mirror of emit_c's `const_body_of` → `emit_expr(body)`). This needs
#      the recursion into `lower_expr`, so it lives here, not in the base.
#   4. first-class fn value — a top-level fn OR a core builtin with a
#      runtime thunk (`int_to_string` passed to `map`) → a `KClosure`
#      (`ls_fn_value`).
#   5. otherwise a genuine local binder not yet recorded → a `KVar` atom
#      read (the conservative fall-through).
# Before this, a const / core-value `EVar` fell through to a bare
# `KVar` the native walk aborted on as `unbound register`.
fn lower_var(name: String, st: LowerSt) : LRes / Console =
  if kir_name_is_ctor(name) and ls_variant_tag(st, name) > 0 {
    bind_op(st, KCon(name, ls_variant_tag(st, name), 0, [], false), KNoPos)
  } else if ls_is_local(st, name) {
    # #846 — a read inside a block that shadowed `name` resolves to the
    # fresh register the shadowing `let` was alpha-renamed to; outside any
    # active shadow it is the surface name verbatim.
    match ls_lookup_rename(st, name) {
      Some(reg) -> LRes(KVar(reg), st)
      None      -> LRes(KVar(name), st)
    }
  } else { match kir_const_body(st.consts, name) {
    Some(body) -> lower_expr(body, st)
    None       -> match ls_fn_value(st, name) {
      Some(FV(thunk, arity)) -> bind_op(st, KClosure(thunk, arity, []), KNoPos)
      None                   -> LRes(KVar(name), st)
    }
  } }

# Lower a list of expressions left-to-right (Risk 2a), collecting atoms.
pub fn lower_exprs(xs: [Expr], st: LowerSt, acc: [KVal]) : LResMany / Console = match xs {
  [] -> LResMany(acc, st)
  [e, ...rest] -> match lower_expr(e, st) {
    LRes(v, st1) -> lower_exprs(rest, st1, list_append(acc, [v]))
  }
}

# P3: lower a self-tail-call's args at the DESTINATION param slots. When
# the recursing fn has a raw signature, an arg whose param is raw lowers
# RAW (`lower_expr_raw` → a raw register, NO trailing `int.box`); the
# native back-edge then re-stores it raw with no `kaix_int`/`kaix_int_field`
# round-trip (the per-iteration re-box that kept the boxed loop ~20× slower
# than C even after the params themselves went raw). A boxed param keeps
# the boxed `lower_expr`. With no raw signature (`None`) this is exactly
# `lower_exprs`. The arg's type equals its param's type (a well-typed tail
# call), so `lower_expr_raw` yields the param's scalar slot.
# Lower each arg at its PARAM's KSlot (`param_slot_for` — `mask[i]` AND the
# type mapping to a raw KIR slot). An arg lowers RAW only when the param's
# slot is raw (`SInt64`/`SReal`/`SBool`); a `SBoxed` param keeps the boxed
# `lower_expr`. This is stricter than the bare `mask[i]`: a `Char`/`Handle`
# param is `mask=true` (unboxable) yet maps to `SBoxed` (no raw KIR register
# form), so lowering it raw would `real.unbox` a boxed Char (a miscompile —
# native returned 0 vs C's 5 on a `Char` param). Using the slot keeps the arg
# repr in lockstep with the param the callee declares (`lower_params_sig`).
fn lower_tcrec_args(xs: [Expr], sig: Option[UFnSig], st: LowerSt) : LResMany / Console =
  lower_tcrec_args_idx(xs, tcrec_ptys_of(sig), tcrec_mask_of(sig), st, [])

fn lower_tcrec_args_idx(xs: [Expr], ptys: [Ty], mask: [Bool], st: LowerSt, acc: [KVal]) : LResMany / Console = match xs {
  [] -> LResMany(acc, st)
  [e, ...rest] -> {
    let pslot = param_slot_for(ptys, mask)
    let trest = match ptys {
      [_, ...r] -> r
      [] -> []
    }
    let mrest = match mask {
      [_, ...r] -> r
      [] -> []
    }
    match lower_tcrec_arg(e, pslot, st) {
      LRes(v, st1) -> lower_tcrec_args_idx(rest, trest, mrest, st1, list_append(acc, [v]))
    }
  }
}

# Lower an arg at its PARAM's slot: a raw param slot crosses the box→raw
# border AT THAT SLOT (`lower_expr_raw_at` — exact, never inferred from the
# arg's `.ty`, which a generic-fn `EVar` may lack); a `SBoxed` param keeps
# the plain boxed `lower_expr`.
fn lower_tcrec_arg(e: Expr, pslot: KSlot, st: LowerSt) : LRes / Console = match pslot {
  SBoxed -> lower_expr(e, st)
  _      -> lower_expr_raw_at(e, pslot, st)
}

# The per-param type list of a (self-recursing) UFn sig, `[]` when None.
fn tcrec_ptys_of(sig: Option[UFnSig]) : [Ty] = match sig {
  Some(US(ptys, _, _)) -> ptys
  None -> []
}

# The per-param raw mask of a (self-recursing) UFn sig, `[]` when None.
fn tcrec_mask_of(sig: Option[UFnSig]) : [Bool] = match sig {
  Some(US(_, _, mask)) -> mask
  None -> []
}

# --- List literals (and interpolation, which desugars to a list) --------

# `[e0, ..., ...spread]` → a cons/nil/append spine. Reproduces the C
# emitter's `emit_list_tail` (the byte-id oracle): nil for the empty
# tail, `kai_cons(h, t)` for a plain head, `kai_core_list_append(h, t)`
# for a mid-list spread, and a `kai_incref(h)` fast-path for a trailing
# spread (O(1) ownership transfer, not an O(n) spine copy). Head is
# lowered before the tail to keep left-to-right evaluation order. Inside
# a region the cons cells bump-allocate: `kai_cons` becomes `kai_arena_cons`.
fn lower_list(elems: [ListElem], pos: KPos, st: LowerSt) : LRes / Console = match elems {
  [] -> bind_op(st, KPrim("kai_nil", []), pos)
  [el] -> lower_list_last(el, pos, st)
  [el, ...rest] -> match el {
    ElPlain(x)  -> lower_list_cons(x, rest, region_cons_prim(st), pos, st)
    ElSpread(x) -> lower_list_cons(x, rest, "kai_core_list_append", pos, st)
  }
}

# The cons prim for the current allocation context: the bump-arena ctor
# inside a region, the RC-heap ctor otherwise.
fn region_cons_prim(st: LowerSt) : String = if st.in_region { "kai_arena_cons" } else { "kai_cons" }

# The final element: a plain head conses onto `nil`; a trailing spread is
# `kai_incref(xs)` — unless `xs` is a `__perceus_dup(...)` (already owned;
# an outer incref would double-bump, issue #212), in which case the dup's
# own lowering is the result.
fn lower_list_last(el: ListElem, pos: KPos, st: LowerSt) : LRes / Console = match el {
  ElPlain(x) -> match lower_expr(x, st) { LRes(hdv, st1) ->
    match bind_op(st1, KPrim("kai_nil", []), pos) { LRes(nilv, st2) ->
      bind_op(st2, KPrim(region_cons_prim(st2), [hdv, nilv]), pos) } }
  ElSpread(x) -> if is_perceus_dup_expr(x) { lower_expr(x, st) }
    else { match lower_expr(x, st) { LRes(spv, st1) ->
      bind_op(st1, KPrim("kai_incref", [spv]), pos) } }
}

# A head (plain or spread) joined to the lowered rest by `prim`
# (`kai_cons` for a plain head, `kai_core_list_append` for a spread).
fn lower_list_cons(x: Expr, rest: [ListElem], prim: String, pos: KPos, st: LowerSt) : LRes / Console =
  match lower_expr(x, st) { LRes(hdv, st1) ->
    match lower_list(rest, pos, st1) { LRes(tlv, st2) ->
      bind_op(st2, KPrim(prim, [hdv, tlv]), pos) } }

# Is `x` a `__perceus_dup(arg)` call? (Issue #212: a spread over a dup is
# already owned, so the list spine must not re-incref it.) The callee name
# is compared with `==` (not a literal pattern — kaikai patterns do not
# bind string literals nested inside a constructor pattern).
fn is_perceus_dup_expr(x: Expr) : Bool = match x.kind {
  ECall(f, _) -> match f.kind { EVar(nm) -> nm == "__perceus_dup" _ -> false }
  _ -> false
}

# --- Holes / todo! → panic stub -----------------------------------------

# A runtime panic over a message string (the hole / todo lowering, and
# the match-non-exhaustive fallback shape). `msg` is an ALREADY-QUOTED
# source span (so `KStrV` round-trips it like a literal).
pub fn lower_panic_stub(msg: String, st: LowerSt) : LRes / Console =
  bind_op(st, KPrim("kai_core_panic", [KStrV(msg)]), KNoPos)

# Wrap a plain string in source-span quotes so `KStrV` treats it as a
# literal (the dumper / translator strip the quotes back off).
pub fn kir_quote(s: String) : String = cat3("\"", s, "\"")

# The hole panic message, bundling label + location like emit_c does.
fn kir_hole_message(nm_opt: Option[String], x: Expr) : String {
  let label = match nm_opt { Some(nm) -> cat2("?", nm) None -> "?" }
  kir_quote(concat_all(["unfilled hole: ", label, " at line ",
                        int_to_string(x.line), " col ", int_to_string(x.col)]))
}

# --- variants[T]() / record literal / range / modcall-value -------------

# `variants[T]()` → a cons spine of nullary constructors, one `KCon` per
# resolved name. Built tail-first so evaluation order matches emit_c.
fn lower_variants_of(names: [String], pos: KPos, st: LowerSt) : LRes / Console = match names {
  [] -> bind_op(st, KPrim("kai_nil", []), pos)
  [n, ...rest] -> {
    let tag = ls_variant_tag(st, n)
    match bind_op(st, KCon(n, tag, 0, [], false), pos) { LRes(hdv, st1) ->
      match lower_variants_of(rest, pos, st1) { LRes(tlv, st2) ->
        bind_op(st2, KPrim("kai_cons", [hdv, tlv]), pos) } }
  }
}

# `T { f0: v0, ... }` → a `KRecord` op carrying each (name, value-atom).
# Field values lower left-to-right; the translator emits the parallel
# value/name buffers `kai_record` takes. The desugar already normalised the
# field order to DECLARATION order (eval still in source order via its
# let-bind), so the layout reaching here is canonical — KIR does not reorder.
fn lower_record_lit(fis: [FieldInit], pos: KPos, st: LowerSt) : LRes / Console =
  match lower_field_inits(fis, st, []) { RecPlan(pairs, st1) ->
    bind_op(st1, KRecord(pairs, st1.in_region), pos) }

fn lower_field_inits(fis: [FieldInit], st: LowerSt, acc: [KFieldInit]) : RecPlan / Console = match fis {
  [] -> RecPlan(acc, st)
  [FI(fname, fe), ...rest] -> match lower_expr(fe, st) { LRes(v, st1) ->
    lower_field_inits(rest, st1, list_append(acc, [KFI(fname, v)])) }
}

# `lo..hi` / `lo..hi:step` → the runtime range builder prim.
fn lower_range(lo: Expr, hi: Expr, stp: Option[Expr], pos: KPos, st: LowerSt) : LRes / Console =
  match lower_expr(lo, st) { LRes(lov, st1) -> match lower_expr(hi, st1) { LRes(hiv, st2) ->
    match stp {
      None -> bind_op(st2, KPrim("kai_range", [lov, hiv]), pos)
      Some(se) -> match lower_expr(se, st2) { LRes(sv, st3) ->
        bind_op(st3, KPrim("kai_range_step", [lov, hiv, sv]), pos) }
    } } }

# A qualified name as a value: a nullary ctor → the ctor value; otherwise
# a fn-value closure over the qualified thunk (emit_c's EModCall arm).
fn lower_modcall_value(modn: String, name: String, pos: KPos, st: LowerSt) : LRes / Console =
  if kir_name_is_ctor(name) { bind_op(st, KCon(name, ls_variant_tag(st, name), 0, [], false), pos) }
  else { match ls_fn_value_qualified(st, modn, name) {
    FV(thunk, arity) -> bind_op(st, KClosure(thunk, arity, []), pos) } }

# An inline lambda use-site → a `KClosure` over `lam_symbol` with the
# captures lowered as atoms (each a read of the captured binder in the
# current scope). The `LamInfo` (id, params, caps) is looked up by
# (enclosing-fn, line, col). A miss means the collector and lowering
# disagree on the key — surface it loudly rather than emit a bad closure.
fn lower_lambda_ref(x: Expr, st: LowerSt) : LRes / Console =
  match find_lam(st.lams, st.enc_fn, x.line, x.col) {
    Some(LamInfo(_, ef, ln, cl, params, caps, _)) ->
      match lower_capture_atoms(caps, st, []) { LResMany(capvs, st1) ->
        bind_op(st1, KClosure(lam_symbol_at(ef, ln, cl),
                              list_length(params), capvs), kpos_of(x)) }
    None -> { eprint(concat_all(["kir: lambda info missing at ",
                                 int_to_string(x.line), ":", int_to_string(x.col)]));
              LRes(KUnitV, st) }
  }

# Lower each capture NAME to an atom (a read of that binder). Captures are
# surface identifiers free in the lambda body — `KVar` reads in the
# enclosing scope.
fn lower_capture_atoms(caps: [String], st: LowerSt, acc: [KVal]) : LResMany / Console = match caps {
  [] -> LResMany(acc, st)
  [c, ...rest] -> lower_capture_atoms(rest, st, list_append(acc, [KVar(c)]))
}

# --- Blocks -------------------------------------------------------------

# A block opens a lexical scope. Snapshot the shadow-rename map AND the
# local-name set on entry and restore both on exit (#846). A `let x` inside
# the block that shadows an outer `let x` records `x -> .tN` in `renames`
# so reads inside the block hit the fresh reg; restoring `renames` on exit
# makes a read of the OUTER `x` after the block resolve back to the outer
# reg. Restoring `locals` is what keeps a binder defined INSIDE the block
# from leaking into a SIBLING block: without it, a name bound in one block
# stays in `locals` (the set is append-only) and a same-name binder in the
# next block is wrongly seen as a shadow and needlessly renamed (the
# `__pcs_arm_ret` per-arm churn). `rc` is NOT restored (see
# `ls_set_renames` / `ls_set_locals`), so distinct fresh regs are minted
# monotonically and never alias.
fn lower_block(x: Expr, stmts: [Stmt], tail: Option[Expr], st: LowerSt) : LRes / Console =
  if block_is_region(st.regions, x.line, x.col) { lower_region_block(x, stmts, tail, st) }
  else { lower_plain_block(x, stmts, tail, st) }

fn lower_plain_block(x: Expr, stmts: [Stmt], tail: Option[Expr], st: LowerSt) : LRes / Console {
  let snap = st.renames
  let lsnap = st.locals
  let st1 = lower_stmts(stmts, st)
  # Invariant: every heap-allocated value bound to a dead `let` is decref'd
  # at scope exit — records, variants, lists, call results alike. Mirrors
  # the C oracle's `block_unused_lets` drops (boxed bindings only; a raw
  # scalar carries no rc).
  let st2 = lower_block_exit_drops(stmts, tail, st1)
  match tail {
    Some(e) -> match lower_expr(e, tcp_after_stmts(st2, stmts)) { LRes(v, st3) -> LRes(v, ls_set_locals(ls_set_renames(st3, snap), lsnap)) }
    None    -> LRes(KUnitV, ls_set_locals(ls_set_renames(st2, snap), lsnap))
  }
}

# A lexical `region { }` block: bump-allocate the body's ctors into a fresh
# arena, then free it wholesale at the brace. `in_region` is set for the
# body's extent, so every ctor lowered here routes to the arena. The tail
# value is deep-copied OUT of the arena (rc = 1) BEFORE the arena is popped
# — copy-before-pop is load-bearing (the arena free would dangle it). A
# scalar tail crosses the border as an immediate: `kaix_deep_copy_out` is a
# no-op on non-pointers, so the whole arena frees with zero copy traffic.
# The copy-out + pop are emitted AT THE JOIN — the point `lower_expr(tail)`
# returns to, which post-dominates any `if`/`match` fork inside the tail —
# so an early fork cannot skip the pop or free the value before the copy.
fn lower_region_block(x: Expr, stmts: [Stmt], tail: Option[Expr], st: LowerSt) : LRes / Console {
  let snap = st.renames
  let lsnap = st.locals
  let osnap = st.in_region
  let stp = ls_emit(ls_set_in_region(st, true), KDo(KCall("kaix_arena_push", []), kpos_of(x)))
  let st1 = lower_stmts(stmts, stp)
  let st2 = lower_block_exit_drops(stmts, tail, st1)
  match tail {
    Some(e) -> match lower_expr(e, tcp_after_stmts(st2, stmts)) { LRes(v, st3) -> {
      match bind_op(st3, KCall("kaix_deep_copy_out", [v]), kpos_of(x)) { LRes(cv, st4) -> {
        let st5 = ls_emit(ls_set_in_region(st4, osnap), KDo(KCall("kaix_arena_pop", []), kpos_of(x)))
        LRes(cv, ls_set_locals(ls_set_renames(st5, snap), lsnap))
      } }
    } }
    None -> {
      let st3 = ls_emit(ls_set_in_region(st2, osnap), KDo(KCall("kaix_arena_pop", []), kpos_of(x)))
      LRes(KUnitV, ls_set_locals(ls_set_renames(st3, snap), lsnap))
    }
  }
}

fn block_is_region(ms: [RegionMark], line: Int, col: Int) : Bool = match ms {
  [] -> false
  [m, ...rest] ->
    if rmark_line(m) == line and rmark_col(m) == col { true }
    else { block_is_region(rest, line, col) }
}

# Emit a `KDrop` for each dead `let`-binding whose RHS is a fresh boxed
# allocation. Same set the C emitter drops (`block_unused_lets`), minus the
# raw-scalar bindings (an `MUnboxed` rhs binds a raw register with no rc).
fn lower_block_exit_drops(stmts: [Stmt], tail: Option[Expr], st: LowerSt) : LowerSt / Console =
  lb_exit_drops_loop(block_unused_lets(stmts, tail), stmts, st)

fn lb_exit_drops_loop(names: [String], stmts: [Stmt], st: LowerSt) : LowerSt / Console = match names {
  [] -> st
  [nm, ...rest] ->
    if lb_binding_is_boxed(stmts, nm) {
      let reg = match ls_lookup_rename(st, nm) { Some(r) -> r None -> nm }
      lb_exit_drops_loop(rest, stmts, ls_emit(st, KRC(KDrop(KVar(reg)), KNoPos)))
    } else {
      lb_exit_drops_loop(rest, stmts, st)
    }
}

# True when `nm` is bound by a `let nm = <boxed rhs>` in `stmts`. A raw
# binding (`raw_let_slot` = Some, the `SReal`/`SBool`/`SInt64` register)
# carries no rc — dropping it would decref a non-pointer.
fn lb_binding_is_boxed(stmts: [Stmt], nm: String) : Bool = match stmts {
  [] -> false
  [s, ...rest] -> match s {
    SLet(pat, _, rhs) -> match pat.pkind {
      PBind(bn) -> if bn == nm {
                     match raw_let_slot(pat, rhs) { Some(_) -> false None -> true }
                   } else { lb_binding_is_boxed(rest, nm) }
      _         -> lb_binding_is_boxed(rest, nm)
    }
    _ -> lb_binding_is_boxed(rest, nm)
  }
}

# Bind the field-read op to a fresh register (captures the incref'd field
# BEFORE the base is dropped), then drop the owned base — mirror of the C
# oracle's `_f = kai_op_field_at(_b, n); kai_decref(_b)`.
fn lower_field_read(st: LowerSt, op: KOp, base: KVal, pos: KPos) : LRes / Console =
  match bind_op(st, op, pos) {
    LRes(fv, st1) -> LRes(fv, ls_emit(st1, KRC(KDrop(base), pos)))
  }

# ---- Vec raw element fusion (classifier verdict in vec_raw.kai) -----

# `vec_get(v, i).f` / `vec_get_borrow(v, i).f` on a REC carrier →
# `kai_vec_get_field(_borrow)(v, i, fidx)`. The helper's RC contract on
# (v, i) matches the vec_get variant it replaces; no record is built,
# so there is no base to drop.
fn lower_vec_get_field_fused(x: Expr, base: Expr, fname: String, st: LowerSt) : Option[LRes] / Console = match base.kind {
  ECall(f, cargs) -> match f.kind {
    EVar(callee) ->
      if callee == "vec_get" or callee == "vec_get_borrow" {
        match vec_rec_field_slot(st.recs, base.ty, fname) {
          Some(fidx) -> match cargs {
            [v, i] -> {
              let prim = if callee == "vec_get_borrow" { "kai_vec_get_field_borrow" }
                         else { "kai_vec_get_field" }
              let rv = lower_expr(v, st)
              match rv { LRes(vv, st1) -> {
                let ri = lower_expr(i, st1)
                match ri { LRes(iv, st2) ->
                  Some(bind_op(st2, KPrim(prim, [vv, iv, KIntV(fidx)]), kpos_of(x))) }
              } }
            }
            _ -> None
          }
          None -> None
        }
      } else { None }
    _ -> None
  }
  _ -> None
}

# `vec_push(v, Rec{..})` / `vec_set(v, i, Rec{..})` on a REC carrier →
# `kai_vec_push_rec_raw` / `kai_vec_set_rec_raw` over the unpacked
# field values; the record is never allocated and the uniqueness
# decision stays inside the runtime helper. Push carries (value, name)
# pairs after the arity (the PENDING classify needs the names); set
# writes an already-classified slot and carries values only.
fn lower_vec_write_rec_fused(x: Expr, f: Expr, cargs: [Expr], st: LowerSt) : Option[LRes] / Console = match f.kind {
  EVar(callee) ->
    if callee == "vec_push" {
      match cargs {
        [v, lit] -> match lit.kind {
          ERecordLit(_, fis) ->
            if vec_elem_is_rec_carrier(st.recs, lit.ty) {
              let rv = lower_expr(v, st)
              match rv { LRes(vv, st1) ->
                match lower_vec_rec_pairs(fis, st1, []) {
                  LResMany(pvs, st2) ->
                    Some(bind_op(st2,
                      KPrim("kai_vec_push_rec_raw", [vv, KIntV(list_length(fis)), ...pvs]),
                      kpos_of(x)))
                } }
            } else { None }
          _ -> None
        }
        _ -> None
      }
    } else if callee == "vec_set" {
      match cargs {
        [v, i, lit] -> match lit.kind {
          ERecordLit(_, fis) ->
            if vec_elem_is_rec_carrier(st.recs, lit.ty) {
              let rv = lower_expr(v, st)
              match rv { LRes(vv, st1) -> {
                let ri = lower_expr(i, st1)
                match ri { LRes(iv, st2) ->
                  match lower_vec_rec_vals(fis, st2, []) {
                    LResMany(fvs, st3) ->
                      Some(bind_op(st3,
                        KPrim("kai_vec_set_rec_raw", [vv, iv, KIntV(list_length(fis)), ...fvs]),
                        kpos_of(x)))
                  } }
              } }
            } else { None }
          _ -> None
        }
        _ -> None
      }
    } else { None }
  _ -> None
}

fn lower_vec_rec_pairs(fis: [FieldInit], st: LowerSt, acc: [KVal]) : LResMany / Console = match fis {
  []           -> LResMany(list_reverse(acc), st)
  [fi, ...rest] -> match fi {
    FI(nm, e) -> {
      let re = lower_expr(e, st)
      match re { LRes(ev, st1) -> lower_vec_rec_pairs(rest, st1, [KStrV(nm), ev, ...acc]) }
    }
  }
}

fn lower_vec_rec_vals(fis: [FieldInit], st: LowerSt, acc: [KVal]) : LResMany / Console = match fis {
  []           -> LResMany(list_reverse(acc), st)
  [fi, ...rest] -> match fi {
    FI(_, e) -> {
      let re = lower_expr(e, st)
      match re { LRes(ev, st1) -> lower_vec_rec_vals(rest, st1, [ev, ...acc]) }
    }
  }
}

fn lower_stmts(stmts: [Stmt], st: LowerSt) : LowerSt / Console = match stmts {
  [] -> st
  [s, ...rest] -> lower_stmts(rest, lower_stmt(s, st))
}

fn lower_stmt(s: Stmt, st: LowerSt) : LowerSt / Console = match s {
  # A `let x = <raw rhs>` where the rhs is `MUnboxed` (Real/Bool) binds a
  # RAW register (SReal/SBool) — mode-slave to the unbox pass, which marked
  # the binder raw and perceus skipped its RC. Lower the rhs raw and bind it
  # at its raw slot; the body's `EVar(x)` reads it raw (a sibling boxed use
  # boxes at its own border via `lower_expr`'s guard). A non-`PBind` raw
  # binder (destructure) cannot occur — a raw scalar has no fields — so only
  # the `PBind` shape takes the raw path; everything else stays boxed.
  SLet(pat, _, rhs) -> match raw_let_slot(pat, rhs) {
    Some(slot) -> match lower_expr_raw(rhs, st) {
      LRes(v, st1) -> lower_let_bind_raw(pat, v, slot, st1)
    }
    None -> match lower_expr(rhs, st) {
      LRes(v, st1) -> lower_let_bind(pat, v, st1)
    }
  }
  SExprStmt(x) -> match lower_expr(x, st) {
    LRes(v, st1) -> ls_emit(st1, KDo(KLitOp(v), kpos_of(x)))
  }
  # `assert cond` / `assert cond, "msg"` → `kai_assert_check(cond, msg)`,
  # the SAME runtime entry the C-direct oracle's `emit_assert_stmt` emits
  # (it consults `kai_test_in_progress` at runtime — abort outside a test,
  # longjmp to the harness inside one). The earlier `kai_assert(cond)`
  # one-arg form had no runtime symbol on the native path (`kaix_assert`
  # is undefined; only `kaix_assert_check` exists), so the object failed
  # to link — the whole missing-symbols family. The message is the literal
  # span when present, else `"assertion failed"` (mirror of the oracle's
  # `msg_lit`); the issue-#86 value-carrying form is a later refinement.
  SAssert(cond, opt_msg) -> match lower_expr(cond, st) {
    LRes(v, st1) -> ls_emit(st1, KDo(KPrim("kai_assert_check", [v, KStrV(kir_assert_msg(opt_msg))]), KNoPos))
  }
  _ -> st
}

# The assert message span (quote-wrapped, as `KStrV` carries it): a plain
# string-literal message keeps its source span; anything else (or no
# message) falls back to the generic `"assertion failed"`. Mirror of
# emit_c's `msg_lit`.
fn kir_assert_msg(opt_msg: Option[Expr]) : String = match opt_msg {
  Some(m) -> match m.kind {
    EStr(span, false) -> span
    _                 -> kir_quote("assertion failed")
  }
  None -> kir_quote("assertion failed")
}

# A `let x = rhs` takes the RAW path when `rhs` is a raw node (Real arith or
# a Real-comparison/logical) AND a plain `PBind` (a raw scalar has no fields
# to destructure). Returns the raw slot (SReal for a Real result, SBool for
# a comparison/logical result), or None to keep the boxed path. Mirror of
# perceus's `prc_pat_bindings_skip_raw` gate (a raw binder skips RC).
fn raw_let_slot(pat: Pattern, rhs: Expr) : Option[KSlot] = match pat.pkind {
  PBind(_) ->
    if kir_node_is_raw(rhs) {
      if kir_ty_is_real(rhs.ty) { Some(SReal) }
      else if kir_ty_is_int(rhs.ty) { Some(SInt64) }
      else if kir_ty_is_char(rhs.ty) { Some(SChar) }
      else { Some(SBool) }
    } else { None }
  _ -> None
}

# Bind a `PBind` name to an already-lowered RAW value at its raw slot. The
# `KLet` carries `slot` (SReal/SBool), so pass-1 allocates an `f64`/`i32`
# alloca and `EVar(name)` loads it raw. No RC: a raw scalar is not tracked.
fn lower_let_bind_raw(pat: Pattern, v: KVal, slot: KSlot, st: LowerSt) : LowerSt / Console = match pat.pkind {
  PBind(name) -> lower_let_pbind(name, slot, v, pat, st)
  _           -> ls_emit(st, KDo(KLitOp(v), KAt(pat.line, pat.col)))
}

# Bind a pattern to an already-lowered value. A plain `PBind(name)` aliases
# the value into `name`; a DESTRUCTURING pattern (`let { p: { x, y } } = b`,
# `let Some(x) = o`) reads each field/slot and recurses into nested
# sub-patterns — the SAME `bind_pattern_fields_any` path the variant match
# arms use. Before this, a record/variant `SLet` fell through to the
# value-discarding `KDo`, binding NOTHING, so the body's `EVar(x)` was an
# unbound register. Mirror of emit_c's `emit_pat_binds` over a let-bind.
# Bind a `PBind` name to an already-lowered value at `slot`. #846: when
# `name` already names a binder in scope, this `let` SHADOWS it. Binding a
# second `KLet(name, ...)` would reuse the outer binder's string-keyed
# alloca and clobber it; instead mint a fresh `.tN` register, bind the
# value there, and record `name -> .tN` in `renames` so reads inside the
# block resolve to the fresh reg. `lower_block` restores `renames` on exit
# so the outer `name` read afterwards still hits the outer reg. The rename
# is pushed AFTER `v` is lowered by the caller (the RHS reads the OUTER
# `name`, e.g. `let x = f(x)`), so no ordering hazard.
fn lower_let_pbind(name: String, slot: KSlot, v: KVal, pat: Pattern, st: LowerSt) : LowerSt / Console =
  if ls_is_local(st, name) {
    match ls_fresh_reg(st) {
      LSReg(reg, st1) -> {
        let st2 = ls_emit(st1, KLet(reg, slot, KLitOp(v), KAt(pat.line, pat.col)))
        ls_push_rename(st2, name, reg)
      }
    }
  } else { ls_emit(st, KLet(name, slot, KLitOp(v), KAt(pat.line, pat.col))) }

fn lower_let_bind(pat: Pattern, v: KVal, st: LowerSt) : LowerSt / Console = match pat.pkind {
  PBind(name)          -> lower_let_pbind(name, SBoxed, v, pat, st)
  PRecord(_)           -> bind_pattern_fields_any(pat, v, bind_body_none(), st)
  PVariant(_, _)       -> bind_pattern_fields_any(pat, v, bind_body_none(), st)
  PVariantRecord(_, _) -> bind_pattern_fields_any(pat, v, bind_body_none(), st)
  PAs(name, _)         -> bind_let_as(pat, name, v, st)
  _                    -> ls_emit(st, KDo(KLitOp(v), KAt(pat.line, pat.col)))
}

# A `let name @ pat = v`: alias `name` to the whole value, then bind the
# inner pattern against it.
fn bind_let_as(pat: Pattern, name: String, v: KVal, st: LowerSt) : LowerSt / Console = {
  let st1 = ls_emit(st, KLet(name, SBoxed, KLitOp(v), KAt(pat.line, pat.col)))
  bind_pattern_fields_any(as_inner(pat), v, bind_body_none(), st1)
}

# --- if -----------------------------------------------------------------

# `if c { t } else { e }`: condbr to two forked blocks, each storing its
# arm into a shared join register, then both branch to a continuation. The
# condition lowers here; the block-building (flat) is `lower_if_blocks`.
#
# Guard #3 (P1) — a RAW comparison/bool condition lowers RAW (an `SBool`
# i32 0/1 register), NOT boxed. The backend's `nemit_condbr` then branches
# on the i32 directly (`icmp ne 0`), skipping the `bool.box` (`kaix_bool`) +
# `kaix_truthy` round-trip the boxed path pays — the `i==0` / `i<N` loop
# header empties of calls. A non-raw (boxed Bool) condition keeps the boxed
# path. The `bind_op_slot(SBool)` inside `lower_expr_raw` yields a `KVar` of
# an `SBool` register; `nemit_condbr` reads the slot to pick its lowering.
fn lower_if(x: Expr, c: Expr, t: Expr, e_opt: Option[Expr], st: LowerSt) : LRes / Console {
  # The condition's reads refine the tcrec pending-release ledger before
  # either branch (and any goto inside one) lowers.
  if kir_node_is_raw(c) {
    match lower_expr_raw(c, st) { LRes(cv, st1) -> lower_if_blocks(x, cv, t, e_opt, tcp_after(st1, c)) }
  } else {
    match lower_expr(c, st) { LRes(cv, st1) -> lower_if_blocks(x, cv, t, e_opt, tcp_after(st1, c)) }
  }
}

# The `join` register is materialised with a `KLet` BEFORE the condbr so a
# translator reads it as a mutable slot (alloca) each branch's `KStore`
# writes — not an undeclared name to infer (Linus review #1).
#
# A RAW `if` (`if n<2 { n } else { fib(n-1)+fib(n-2) }` — the unbox pass
# marks the whole `EIf` `MUnboxed` when both arms AND the cond are raw)
# lowers the JOIN at the result's raw slot (`SInt64`/`SReal`), each arm
# stored raw. This mirrors the C oracle's raw ternary `(cond ? a : b)`: the
# `+`'s `i64` flows into the join WITHOUT a `kaix_int` box, and a raw-return
# `KRet` reads the join directly (no `kaix_int_field`). The box/unbox round-
# trip a boxed join forced on every `fib` arm is gone. A boxed `if` (the
# default, and any Bool/Char-typed raw `if` outside the Int/Real raw KIR
# scope) keeps the `SBoxed` join unchanged. RC: a raw join carries no
# refcount; the arms are `MUnboxed` (perceus skipped them), so no KDup/KDrop
# lands on the raw register.
fn lower_if_blocks(x: Expr, cv: KVal, t: Expr, e_opt: Option[Expr], st: LowerSt) : LRes / Console = {
  let js = if_join_slot(x)
  match ls_fresh_reg(st) { LSReg(join, st2) -> {
    let st_decl = ls_emit(st2, KLet(join, js, KLitOp(if_join_init(js)), kpos_of(x)))
    match three_labels(st_decl) { LSL3(lt, le, lcont, st3) -> {
      let st4 = ls_seal(st3, KCondBr(cv, lt, le, kpos_of(x)), lt)
      let st5 = lower_branch_into_slot(t, join, js, lcont, st4)
      let st6 = lower_else_into_slot(e_opt, join, js, lcont, le, st5)
      LRes(KVar(join), st6)
    } }
  } }
}

# The join register's slot: raw (`SInt64`/`SReal`) when the `if`-node is a
# raw-promoted Int/Real expression (`x.mode == MUnboxed` — both arms raw),
# else `SBoxed`. Bool/Char raw `if`s stay boxed (no raw KIR register form —
# the `kir_lower_raw` scope bound).
fn if_join_slot(x: Expr) : KSlot = match x.mode {
  MUnboxed -> if kir_ty_is_int(x.ty) { SInt64 } else if kir_ty_is_real(x.ty) { SReal } else { SBoxed }
  _        -> SBoxed
}

# The join's initial placeholder, matching its slot (the `KLet` decl must
# store a value of the alloca's type before the branches overwrite it).
fn if_join_init(slot: KSlot) : KVal = match slot {
  SInt64 -> KIntV(0)
  SReal  -> KRealV(0.0)
  _      -> KUnitV
}

# Lower one `if`-arm into the join register and branch to the continuation. A
# raw join (`SInt64`/`SReal`) lowers the arm RAW; a boxed join keeps the
# plain boxed `lower_expr`. The slot drives the choice so the store matches
# the alloca. (`lower_branch_into` is the boxed-only match variant.)
fn lower_branch_into_slot(e: Expr, join: String, js: KSlot, lcont: String, st: LowerSt) : LowerSt / Console =
  match if_branch_lower(e, js, st) { LRes(v, st1) ->
    ls_seal(ls_emit(st1, KStore(join, v, kpos_of(e))), KBr(lcont, kpos_of(e)), lcont) }

fn if_branch_lower(e: Expr, js: KSlot, st: LowerSt) : LRes / Console = match js {
  SBoxed -> lower_expr(e, st)
  _      -> lower_expr_raw(e, st)
}

fn lower_else_into_slot(e_opt: Option[Expr], join: String, js: KSlot, lcont: String,
                        le: String, st: LowerSt) : LowerSt / Console = match e_opt {
  Some(e) -> lower_branch_into_slot(e, join, js, lcont, reopen(st, le))
  None    -> ls_seal(ls_emit(reopen(st, le), KStore(join, KUnitV, KNoPos)),
                     KBr(lcont, KNoPos), lcont)
}

# Lower one branch (a MATCH arm body) into a BOXED join register and branch
# to the continuation. The match-lowering's join is always `SBoxed`.
fn lower_branch_into(e: Expr, join: String, lcont: String, st: LowerSt) : LowerSt / Console =
  match lower_expr(e, st) { LRes(v, st1) ->
    ls_seal(ls_emit(st1, KStore(join, v, kpos_of(e))), KBr(lcont, kpos_of(e)), lcont) }

# --- postfix `!` (Option/Result propagation) ----------------------------

# `expr!` — unwrap the success payload of an Option/Result, or EARLY-RETURN
# the whole `None`/`Err` from the enclosing fn (mirror of emit_c's
# `emit_bang`). Lower the inner value, read its tag, and `condbr` on
# "is it the success ctor": the success path projects slot 0 (the payload)
# into a join register; the fail path `KRet`s the inner value verbatim — the
# short-circuit. The success ctor (`Some` for `Option`, `Ok` for `Result`)
# is read from `inner.ty` via the shared `bang_success_variant`; a non-
# Option/Result type here is a typer-invariant violation, lowered to a loud
# panic stub like the oracle's `None` arm (never a silent miscompile).
fn lower_bang(x: Expr, inner: Expr, st: LowerSt) : LRes / Console =
  match bang_success_variant(inner.ty) {
    None       -> lower_panic_stub(kir_quote("internal: `!` on non-Option/Result reached kir lowering"), st)
    Some(ctor) -> match lower_expr(inner, st) { LRes(bv, st1) -> lower_bang_split(x, bv, ctor, st1) }
  }

# Build the success/fail fork over the lowered inner value `bv`. The join
# register holds the unwrapped payload; the success path stores `KProj(bv,0)`
# and branches to the continuation, the fail path early-returns `bv`. Mirror
# of `lower_if_blocks`, but the else-branch is a `KRet` (short-circuit), not
# a store-and-merge.
fn lower_bang_split(x: Expr, bv: KVal, ctor: String, st: LowerSt) : LRes / Console =
  match ls_fresh_reg(st) { LSReg(join, st1) -> {
    let st2 = ls_emit(st1, KLet(join, SBoxed, KLitOp(KUnitV), kpos_of(x)))
    match bind_op(st2, KPrim("kai_tag_eq", [bv, KIntV(ls_variant_tag(st2, ctor))]), kpos_of(x)) { LRes(cond, st3) ->
      match three_labels(st3) { LSL3(lok, lfail, lcont, st4) -> {
        # condbr seals the current block and opens `lfail` as the cursor.
        let st5 = ls_seal(st4, KCondBr(cond, lok, lfail, kpos_of(x)), lfail)
        # Fail block: short-circuit the enclosing fn with the unmatched value.
        let st6 = ls_seal(st5, KRet(bv, kpos_of(x)), lok)
        # Success block: project slot 0 (the payload) into a fresh register,
        # then store it into the join (`KStore` takes a `KVal`, so the `KProj`
        # op must be materialised first — same as the bind / sub-test paths).
        match bind_op(st6, KProj(bv, 0), kpos_of(x)) { LRes(payload, st7) -> {
          let st8 = ls_emit(st7, KStore(join, payload, kpos_of(x)))
          let st9 = ls_seal(st8, KBr(lcont, kpos_of(x)), lcont)
          LRes(KVar(join), st9)
        } }
      } } }
  } }

# --- match --------------------------------------------------------------

# `match scr { arms }`: switch on the scrutinee tag, one block per arm,
# each storing its body into a shared join and branching to a continuation.
# `match scr { arms }`: read the scrutinee tag (`KTagOf`) and switch on
# it (design §4.2 `KSwitch` over the tag atom). The scrutinee atom flows
# to the arm bodies for `KProj` field reads; the tag atom drives the
# switch terminator.
# Is the match scrutinee OWNED (a freshly-produced value the match consumes)
# or BORROWED (a value the callee inspects without taking ownership)? Perceus
# wraps a borrowed scrutinee in `__perceus_borrow(p)`; everything else is
# owned. This is the exact discriminant the C-direct oracle uses
# (`emit_c.kai` `match_borrow_inner`): an owned scrutinee is `kai_decref`ed at
# match exit, a borrowed one is not. The native path mirrored only the
# borrowed case (no exit drop) — leaking every owned scrutinee (the
# `variant_match` super-linear collapse, issue #855). `__strip_unit` does NOT
# count as borrow here (it erases a unit, whose decref short-circuits on the
# rc=MAX singleton), matching the oracle's `__perceus_borrow`-only test.
fn match_scr_is_borrowed(scr: Expr) : Bool = match scr.kind {
  ECall(callee, _) -> match callee.kind { EVar(nm) -> nm == "__perceus_borrow" _ -> false }
  _                -> false
}

fn lower_match(x: Expr, scr: Expr, arms: [Arm], st: LowerSt) : LRes / Console {
  let owned = not match_scr_is_borrowed(scr)
  # Evaluating the scrutinee may consume enclosing ledger binders — refine
  # before any arm seeds on top of the pending set.
  match lower_expr(scr, tcp_after(st, scr)) { LRes(scrv, st1) ->
    # Each specialised path runs `match_preamble` (which mints a FRESH per-match
    # `<join>$sd` exit-drop binder) and plants its OWN `match_finish` with that
    # binder — so nested matches never share one drop name. `lower_match` no
    # longer wraps a single `match_finish` here (that forced one shared literal).
    # GUARDS / all-binder dispatch (FIRST — overrides every specialised
    # path). A `match` arm carries an optional guard (`X if cond -> body`);
    # any backend's tag-switch / equality-tree assumes the matched arm is
    # the WINNER, but a guard can REJECT an arm AFTER its pattern matched,
    # so control must fall to the NEXT arm in source order — exactly the
    # C-direct oracle's linear `if (pat) { binds; if (truthy(g)) { … } }`
    # fail-chain (`emit_match_arm`). The O(1) switch is sound ONLY when the
    # tag alone decides the winner; a guard breaks that invariant. Likewise,
    # a `match` whose arms ALL bind (no discriminating pattern — `n if … ->`
    # / `n -> …`) has no tag to switch on: the variant path would emit
    # `KTagOf` over a scalar scrutinee (an Int / Real), which the native
    # backend deref-faults (`kaix_variant_tag_of` on a tagged Int → SIGSEGV).
    # Both cases route to the linear `lower_guard_chain` (asu review: the KIR
    # never needs to be cleverer than its oracle; exhaustivity is the typer's
    # job, so degrading to a linear chain is always sound).
    if match_has_any_guard(arms) or not match_has_discriminating_pattern(arms) {
      lower_guard_chain(x, arms, scrv, owned, st1)
    }
    # List patterns (`[]`, `[h, ...t]`, `[a, b, ...rest]`) need a length-
    # aware decision tree, not the variant tag-switch: cons arms of
    # different lengths share the `KAI_CONS` tag (kir_lower_match.kai).
    else if match_is_list(arms) { lower_list_match(x, arms, scrv, owned, st1) }
    # Literal patterns (`0`/`'c'`/`"s"`/`true`) need an EQUALITY decision
    # tree, not the variant tag-switch: a `PLit` is not a variant, so its
    # `arm_tag` is -1 and every literal arm would collapse into one default
    # block — an empty `KSwitch` that segfaults the native backend
    # (kir_lower_lit.kai). Dispatched after the list test so a `PList` never
    # reaches the literal chain.
    else if match_is_literal(arms) { lower_lit_match(x, arms, scrv, owned, st1) }
    # Record patterns (`{ x: 0, y }`, `{ x, y }`) need a FIELD-TEST decision
    # tree, not the variant tag-switch: a `PRecord` is not a variant, so its
    # `arm_tag` is -1 and every record arm would collapse into one default
    # block with its field binds never projected — an empty `KSwitch` plus a
    # free `unbound register` the native backend aborts on (kir_lower_rec.kai).
    # Dispatched after list + literal (a `PRecord` is neither) and before the
    # variant fallback; a `PVariantRecord` (`Some { x }`) is NOT a `PRecord`,
    # so it stays on the variant path below.
    else if match_is_record(arms) { lower_record_match(x, arms, scrv, owned, st1) }
    # The variant tag register carries `SInt32` (the raw `variant_tag`
    # word), NOT `SBoxed`: a `KSwitch` scrutinee must be an integer so the
    # native backend emits a real LLVM `switch`. The repr is decided here,
    # in the lowering, never re-derived by a backend (asu review).
    else { match bind_op_slot(st1, KTagOf(scrv), SInt32, kpos_of(x)) { LRes(tagv, st2) ->
      lower_match_blocks(x, arms, scrv, tagv, owned, st2) } } }
}

# Match-exit drop of the owned scrutinee, mirroring `emit_match_default_owned`
# (`emit_c.kai`): when the scrutinee is owned, decref `__pcs_scr_drop` in the
# continuation block (the post-dominator of every non-tail arm) before the
# join is read. A BORROWED match drops nothing (the caller still owns the
# value). The drop is sound with reuse arms: the runtime reuse helper increfs
# the donor cell when unique, so the single exit decref leaves a unique-RC
# result — identical to the C oracle. A self-tail arm seals before the
# continuation and never reaches this drop: its goto releases the skipped
# scrutinee via the pending-release ledger (`tcp_seed_arm`/`tcp_goto_drops`).
fn match_finish(owned: Bool, sd: String, r: LRes) : LRes =
  match_finish_tok(owned, sd, false, r)

# `match_finish` plus an optional `_arm_ru` token free (#872): a variant match
# with an arm-top-reuse arm captured the consumed scrutinee as a token; the
# TRMC-step tail consumes it (resets to null), but a non-step tail
# (`balance_left(ins(l,..),..)`) leaves it live — free it in the continuation
# (null-safe, no-op when consumed or when no arm-top fired). The exit drop of
# `sd` follows; for an arm-top arm `sd` was rebound to unit, so its drop is a
# no-op (the token was the disposer).
fn match_finish_tok(owned: Bool, sd: String, free_tok: Bool, r: LRes) : LRes =
  if owned {
    match r { LRes(v, st) -> {
      let st1 = if free_tok { ls_emit(st, KRC(KArmTokenFree, KNoPos)) } else { st }
      LRes(v, ls_emit(st1, KRC(KDrop(KVar(sd)), KNoPos)))
    } }
  } else { r }

# Tcrec goto-tail pending-release ledger — the native port of the C
# emitter's `EmitCtx.tcpend` discipline (emit_tcrec_live). A self-tail
# `KTcrecGoto` seals its block before control reaches the continuation
# where `match_finish` plants the owned-scrutinee drop, and after the arm's
# alias-binder dups — so the goto path must itself release every enclosing
# owned scrutinee register and this path's not-yet-consumed binder dups,
# for EVERY enclosing match level. An arm body that can reach a goto seeds
# `st.tcpend`; branch points refine it over the post-perceus AST (a
# consumed binder leaves the ledger); `lower_tcrec` drops each surviving
# entry just before sealing the back-edge. The filter is conservative
# toward "consumed" (see emit_tcrec_live): a stale entry can only
# under-release (a bounded leak), never over-release (a double-free).

# Seed the ledger entering an arm body, from the ENCLOSING pending set
# `pend0` (captured at match entry — a sibling arm's body lowering clobbers
# `st.tcpend`, so the enclosing value travels as a parameter, like `mscr0`).
# A goto-free body clears the ledger (it is never read there, and an empty
# ledger skips every refinement scan).
#
# `binders` MUST be exactly the set this arm structurally dup'd
# (`lm_dup_alias_binders`): the ledger releases a ref the bind took, so a
# binder bound WITHOUT a dup (a literal/record arm's whole-value alias, an
# arm-top token's children) must never be seeded — releasing it would free
# a live value (the over-release the C emitter cannot hit, because its
# `emit_pat_binds` increfs every alias bind).
#
# This match's OWN exit-drop register is seeded only when the arm is NOT
# all-tails-sentinel: an all-tails arm gets the pre-body drop
# (`match_selftail_scr_drop`), keeping its emission byte-identical to the
# pre-ledger lowering; seeding it too would release the scrutinee twice.
fn tcp_seed_arm(owned: Bool, sd: String, binders: [String],
                body: Expr, pend0: [String], st: LowerSt) : LowerSt =
  if not tcl_has_goto(body) { ls_set_tcpend(st, []) }
  else {
    let with_scr = if owned and not arm_body_all_tail_self_tcrec(body) {
      list_append(pend0, [tcl_scr_entry(sd)])
    } else { pend0 }
    ls_set_tcpend(st, tcl_push_binders(with_scr, binders))
  }

# Pre-body drop of the owned scrutinee for an arm whose EVERY tail leaf is
# a pure self-tail sentinel — such an arm never reaches the continuation
# drop, and the pre-body position keeps its emission identical to the C
# oracle's pre-injected `kai_decref(_scr)`. Arms with a non-goto tail keep
# the drop at the goto site via the ledger (the continuation still runs on
# their normal paths, so a pre-body drop would double-release there).
fn match_selftail_scr_drop(owned: Bool, sd: String, body: Expr, st: LowerSt) : LowerSt =
  if owned and arm_body_all_tail_self_tcrec(body) {
    ls_emit(st, KRC(KDrop(KVar(sd)), kpos_of(body)))
  } else { st }

# True iff EVERY tail leaf of `body` is a pure self-tail-call sentinel
# (`__kai_tcrec|`, the C oracle's `tcrec_tail_always_sentinel`). A
# `__kai_trmc|` step is NOT a leaf here, so a cons-modulo arm never
# satisfies this (its cell is consumed by the TRMC reuse + dropmask).
fn arm_body_all_tail_self_tcrec(body: Expr) : Bool = match body.kind {
  ECall(f, _) -> match f.kind { EVar(callee) -> es_tcrec_is_sentinel(callee) _ -> false }
  EIf(_, t, oe) -> match oe {
    None    -> false
    Some(e) -> arm_body_all_tail_self_tcrec(t) and arm_body_all_tail_self_tcrec(e)
  }
  EMatch(_, arms) -> arms_all_tail_self_tcrec(arms)
  EBlock(_, ot) -> match ot { None -> false Some(e) -> arm_body_all_tail_self_tcrec(e) }
  _ -> false
}

fn arms_all_tail_self_tcrec(arms: [Arm]) : Bool = match arms {
  []           -> false
  [Arm(_, _, body)] -> arm_body_all_tail_self_tcrec(body)
  [Arm(_, _, body), ...rest] -> arm_body_all_tail_self_tcrec(body) and arms_all_tail_self_tcrec(rest)
}

# Seed for an arm whose scrutinee/binder RC rides another discipline (a
# reuse arm's `__perceus_reuse_*` consumption, an arm-top token): only the
# ENCLOSING entries survive into the body — this match adds nothing.
fn tcp_seed_inherit(body: Expr, pend0: [String], st: LowerSt) : LowerSt =
  if tcl_has_goto(body) { ls_set_tcpend(st, pend0) } else { ls_set_tcpend(st, []) }

# Seed mirroring `lower_arm_rc`'s three branches: an arm-top-reuse arm and
# a `__perceus_reuse_*` arm add nothing (their RC rides the token / the
# reuse-gc set); only the structural-dup branch seeds this match's exit
# drop + its dup'd alias binders.
fn tcp_seed_after_arm_rc(owned: Bool, sd: String, p: Pattern, body: Expr,
                         pend0: [String], st: LowerSt) : LowerSt =
  if (owned and arm_is_top_reuse(p, body, st)) or arm_reuses(body, st) {
    tcp_seed_inherit(body, pend0, st)
  } else {
    tcp_seed_arm(owned, sd, pat_alias_binders(p, st.vs), body, pend0, st)
  }

# Refine the ledger across an already-evaluated expression / statement
# list — a no-op (and no scan) when the ledger is empty, the common case.
fn tcp_after(st: LowerSt, e: Expr) : LowerSt = match st.tcpend {
  [] -> st
  _  -> ls_set_tcpend(st, tcl_filter(st.tcpend, e))
}

fn tcp_after_stmts(st: LowerSt, ss: [Stmt]) : LowerSt = match st.tcpend {
  [] -> st
  _  -> ls_set_tcpend(st, tcl_filter_stmts(st.tcpend, ss))
}

# The goto-site releases: drop every pending entry the tail-call args do
# not consume — after the args are lowered (they may still dup-read the
# binders), before the back-edge seals. Binder entries resolve through the
# active shadow renames, like any other body read.
fn tcp_goto_drops(args: [Expr], st: LowerSt) : LowerSt = match st.tcpend {
  [] -> st
  _  -> tcp_drop_entries(tcl_goto_entries(st.tcpend, args), st)
}

fn tcp_drop_entries(es: [String], st: LowerSt) : LowerSt = match es {
  [] -> st
  [e, ...rest] -> {
    let nm = tcl_reg(e)
    let reg = if tcl_is_scr(e) { nm }
              else { match ls_lookup_rename(st, nm) { Some(r) -> r None -> nm } }
    tcp_drop_entries(rest, ls_emit(st, KRC(KDrop(KVar(reg)), KNoPos)))
  }
}

# True iff ANY tail leaf of `body` is a `__kai_trmc|` modulo-cons step sentinel
# (the C oracle's `trmc_body_has_step`). Such an arm's scrutinee cell is reused
# in place by a TRMC step on at least one path; the arm-top reuse token model
# (`KArmTopReuse`) captures the consumed cell once at the arm top so the step
# reuses it (or frees it on a non-step tail like `balance_left(ins(l,..),..)`).
# A pure self-tcrec body is NOT a step (its callee is `__kai_tcrec|`).
fn body_has_trmc_step(body: Expr) : Bool = match body.kind {
  ECall(f, _) -> match f.kind { EVar(callee) -> es_trmc_is_step_sentinel(callee) _ -> false }
  EIf(_, t, oe) -> body_has_trmc_step(t) or match oe { None -> false Some(e) -> body_has_trmc_step(e) }
  EMatch(_, arms) -> arms_have_trmc_step(arms)
  EBlock(_, ot) -> match ot { None -> false Some(e) -> body_has_trmc_step(e) }
  _ -> false
}

fn arms_have_trmc_step(arms: [Arm]) : Bool = match arms {
  []                         -> false
  [Arm(_, _, body), ...rest] -> if body_has_trmc_step(body) { true } else { arms_have_trmc_step(rest) }
}

# `match scr { [list patterns] }`: a fail-chain decision tree mirroring the
# C-direct (`emit_pat_test_list`) / LLVM (`llvm_emit_pat_list`) emitters.
# Each arm emits its cons/nil + length test into a block that branches to
# the arm body on success and to the next arm on failure; the head/tail
# `KProj` binds land in the matched-body block. A shared `join` register
# (materialised before the chain, like `lower_if`) collects each body's
# value. The chain ends `KUnreachable` — kaikai matches are exhaustive, so
# the final fail is dead (Linus review #3, as `lower_default_arm`).
fn lower_list_match(x: Expr, arms: [Arm], scrv: KVal, owned: Bool, st: LowerSt) : LRes / Console =
  match match_preamble(x, scrv, owned, st) { LSPre(join, sd, st1) ->
    match ls_fresh_label(st1) { LSLabel(lcont, st2) -> {
      let pend0 = st2.tcpend
      let st3 = lower_list_arms(arms, scrv, join, lcont, owned, sd, pend0, st2)
      match_finish(owned, sd, LRes(KVar(join), ls_set_tcpend(reopen(st3, lcont), pend0)))
    } } }

# The match prologue shared by the variant-switch and list-decision-tree
# paths: allocate the join slot, then alias the scrutinee under the
# synthetic `__pcs_scr` / `__pcs_scr_drop` names perceus's reuse recogniser
# refers to (the donor of a `KConReuse`). Without the alias the reuse donor
# is a free variable in the KIR (a correctness gap, not a backend concern);
# the direct emitters bind the same locals in their match-arm prologue
# (emit_c / emit_llvm `push_local("__pcs_scr", scr)`). The join register is
# materialised BEFORE the fork so a translator reads it as a mutable slot
# (alloca) each arm's `KStore` writes — not a name to infer (Linus #1).
# `owned` decides whether `__pcs_scr_drop` is declared: only an OWNED match
# binds it (the scrutinee it must decref at exit), and `match_finish` drops it
# in the continuation block. A BORROWED match never binds it (the caller still
# owns the value), so `match_finish` is a no-op there. `__pcs_scr` (the reuse-
# donor alias) is ALWAYS declared: perceus's reuse recogniser refers to it
# regardless of ownership.
# The owned scrutinee's exit-drop binder is FRESH per match (`<join>$sd`), not
# the fixed literal `__pcs_scr_drop`. Two NESTED owned matches (e.g.
# `list_cmp_loop`'s outer-on-`a` / inner-on-`b`) would otherwise both bind the
# same name; the native register table dedupes by name into ONE alloca, so the
# inner `= b` store clobbers the outer `= a`, and the outer exit drop frees `b`
# a second time (the `max([T])` double-free vs `min([T])` survives-by-leak). The
# C oracle avoids it via lexically-shadowed `_scr` statement-expressions; a fresh
# per-match name gives the native flat table the same isolation. `__pcs_scr` (the
# reuse-donor alias perceus's recogniser refers to by that exact name) stays
# fixed — it is not the drop binder and a reuse arm has no exit drop.
fn scr_drop_name(join: String) : String = cat2(join, "$sd")

fn match_preamble(x: Expr, scrv: KVal, owned: Bool, st: LowerSt) : LSPre =
  match ls_fresh_reg(st) { LSReg(join, st1) -> {
    let sd = scr_drop_name(join)
    let st_alias = ls_emit(st1, KLet("__pcs_scr", SBoxed, KLitOp(scrv), kpos_of(x)))
    # Publish this match's drop binder so a TRMC cons-modulo step (or a reuse
    # fork's `reuse_neutralise_exit_drop`) lowered inside an arm body drops the
    # right register. A sibling arm that runs a NESTED match leaves `mscr` at
    # the nested `<join>$sd`; `lower_variant_groups` restores this match's `mscr`
    # before each group so a later reuse-fork arm reads the enclosing binder, not
    # the stale nested one (#1229). Only an owned match has an exit drop; a
    # borrowed match leaves `mscr` as the enclosing one.
    let st_pub = if owned { ls_set_mscr(st_alias, sd) } else { st_alias }
    # Exit-drop binder. The C oracle consumes the scrutinee LINEARLY — `_scr = sc`
    # (no dup), one match-exit decref — and a live-binder scrutinee already
    # arrives wrapped in a perceus producer-side dup, so the exit drop frees that
    # dup and the original survives. A blanket dup here over-increfs and blocks
    # the cons cascade (free never reaches zero — issue #868). A reuse-arm match
    # is no longer special-cased: the `KConReuse` path now grows the SHARED-donor
    # per-child incref (`kai_incref_if_shared`, #872), so the old scrutinee dup
    # that masked the under-incref as a leak is dead — every owned match binds
    # the exit-drop binder bare.
    let st_scr = if owned {
                   ls_emit(st_pub, KLet(sd, SBoxed, KLitOp(scrv), kpos_of(x)))
                 } else { st_pub }
    LSPre(join, sd, ls_emit(st_scr, KLet(join, SBoxed, KLitOp(KUnitV), kpos_of(x))))
  } }

# Lower each list arm in order. The arm's test seals the current block into
# a condbr (body vs the fresh fail label); the body lowers into the join +
# branches to `lcont`; the next arm reopens the fail label. A catch-all arm
# matches unconditionally and ends the chain (later arms are dead). With no
# catch-all the last fail label is sealed `KUnreachable`.
#
# Issue #858 — after `lm_emit_arm` binds the arm's alias binders (head /
# tail / rest, all borrows of the scrutinee slots), emit a structural
# `KDup` for each, mirroring the C-direct oracle's `kai_incref` on
# `is_alias=true` cons binds. Gated on `owned ∧ ¬arm_body_uses_reuse`:
# only an OWNED match plants the exit `__pcs_scr_drop` the dup balances,
# and a reuse arm consumes the scrutinee through `__perceus_reuse_*` (which
# owns the kept children's RC) so a dup there would double-incref.
fn lower_list_arms(arms: [Arm], scrv: KVal, join: String, lcont: String,
                   owned: Bool, sd: String, pend0: [String], st: LowerSt) : LowerSt / Console = match arms {
  [] -> ls_seal(st, KUnreachable(KNoPos), lcont)
  [Arm(p, _, body), ...rest] -> match ls_fresh_label(st) { LSLabel(body_lbl, st1) ->
    match lm_emit_arm(p, scrv, body_lbl, arm_reuses(body, st1), st1) { LMArm(st_body, fail_lbl) -> {
      # A non-reuse owned arm structurally dups EVERY alias binder it reaches
      # over a borrow path — the flat cons head/tail PLUS nested-variant slot
      # binders at any depth (`pat_alias_binders`, the sole mirror of the
      # oracle's `emit_pat_binds` alias set). All are `KProj` borrows the exit
      # `__pcs_scr_drop` would free before a self-tail arm body reads them. A
      # reuse arm instead publishes its head/tail binders as the reuse-gc set
      # so the `KConReuse` shared path increfs them (the C oracle's
      # shared-branch `incref(_scr->head/tail)`), else the match-exit drop
      # frees them.
      let st_dup = if not arm_reuses(body, st_body) {
        # Owned OR borrowed (issue #1127 rule 4): dup every alias binder so a
        # bound child carries its own ref before flowing to an owned position.
        # Only a reuse arm (else) hands that RC to `__perceus_reuse_*`.
        lm_dup_alias_binders(pat_alias_binders(p, st_body.vs), KAt(p.line, p.col), st_body)
      } else {
        # Reuse arm (dual-branch): the DECONSTRUCTED sub-binders of a head are
        # incref'd UNCONDITIONALLY — the oracle's `emit_pat_binds` is_alias
        # path increfs them in both the unique and the shared branch, so they
        # leave the condbr; only the DIRECT cons slots (published as reuse_gc)
        # differ per branch (borrow in unique, dup in shared). Emitting the
        # decon dups here (outside the fork) keeps the fork managing only the
        # direct slots.
        let st_decon = lm_dup_alias_binders(pat_decon_alias_binders(p, st_body.vs), KAt(p.line, p.col), st_body)
        set_reuse_gc_for_arm(p, body, st_decon)
      }
      let st_drop = if arm_reuses(body, st_dup) { tcp_seed_inherit(body, pend0, st_dup) }
                    else { tcp_seed_arm(owned, sd, pat_alias_binders(p, st_dup.vs), body, pend0, st_dup) }
      let st_done = lower_branch_into(body, join, lcont, match_selftail_scr_drop(owned, sd, body, st_drop))
      if list_arm_is_catchall(p) { st_done }
      else { lower_list_arms(rest, scrv, join, lcont, owned, sd, pend0, reopen(st_done, fail_lbl)) }
    } } }
}

# `match scr { <literal patterns> }`: an equality-test fail-chain mirroring
# the C-direct oracle's boxed-scrutinee path (`emit_pat_test`'s `kai_op_eq`
# arm) and structurally identical to `lower_list_match`. Each literal arm
# emits `condbr (kai_eq_raw scr lit) ? body : next`; the catch-all binds the
# whole scrutinee and ends the chain. The join slot + `__pcs_scr` alias come
# from the shared `match_preamble`; the chain ends `KUnreachable` when no
# catch-all is present (the typer made the match exhaustive — e.g.
# `true`/`false` — so the final fail is dead, Linus review #3).
fn lower_lit_match(x: Expr, arms: [Arm], scrv: KVal, owned: Bool, st: LowerSt) : LRes / Console =
  match match_preamble(x, scrv, owned, st) { LSPre(join, sd, st1) ->
    match ls_fresh_label(st1) { LSLabel(lcont, st2) -> {
      let pend0 = st2.tcpend
      let st3 = lower_lit_arms(arms, scrv, join, lcont, owned, sd, pend0, st2)
      match_finish(owned, sd, LRes(KVar(join), ls_set_tcpend(reopen(st3, lcont), pend0)))
    } } }

# Lower each literal arm in order, exactly like `lower_list_arms`: the arm's
# test seals the current block into a condbr (body vs a fresh fail label);
# the body lowers into the join + branches to `lcont`; the next arm reopens
# the fail label. A catch-all arm matches unconditionally and ends the chain
# (later arms are dead). With no catch-all the last fail label is sealed
# `KUnreachable`.
fn lower_lit_arms(arms: [Arm], scrv: KVal, join: String, lcont: String,
                  owned: Bool, sd: String, pend0: [String], st: LowerSt) : LowerSt / Console = match arms {
  [] -> ls_seal(st, KUnreachable(KNoPos), lcont)
  [Arm(p, _, body), ...rest] -> match ls_fresh_label(st) { LSLabel(body_lbl, st1) ->
    match lit_emit_arm(p, scrv, body_lbl, st1) { LMArm(st_body, fail_lbl) -> {
      # A literal arm's catch-all binder aliases the scrutinee with NO
      # bind-incref (lit_emit_arm), so only the exit-drop entry is seeded.
      let st_drop = tcp_seed_arm(owned, sd, [], body, pend0, st_body)
      let st_done = lower_branch_into(body, join, lcont, match_selftail_scr_drop(owned, sd, body, st_drop))
      if lit_arm_is_catchall(p) { st_done }
      else { lower_lit_arms(rest, scrv, join, lcont, owned, sd, pend0, reopen(st_done, fail_lbl)) }
    } } }
}

# `match scr { <record patterns> }`: a field-test fail-chain mirroring the
# C-direct oracle's `emit_pat_test_record` (a `kai_op_field_borrow` +
# `kai_op_eq` conjunction per arm) and structurally identical to
# `lower_lit_match`. Each arm with literal fields emits a conjunction of
# `condbr (kai_eq_raw (field_borrow scr name) lit)` tests, projects its
# binding fields on the success path, then lowers its body; an arm with no
# literal fields is a catch-all that binds its fields and ends the chain.
# The join slot + `__pcs_scr` alias come from the shared `match_preamble`;
# the chain ends `KUnreachable` when no catch-all is present (the typer made
# the match exhaustive, so the final fail is dead, Linus review #3).
fn lower_record_match(x: Expr, arms: [Arm], scrv: KVal, owned: Bool, st: LowerSt) : LRes / Console =
  match match_preamble(x, scrv, owned, st) { LSPre(join, sd, st1) ->
    match ls_fresh_label(st1) { LSLabel(lcont, st2) -> {
      let pend0 = st2.tcpend
      let st3 = lower_record_arms(arms, scrv, join, lcont, owned, sd, pend0, st2)
      match_finish(owned, sd, LRes(KVar(join), ls_set_tcpend(reopen(st3, lcont), pend0)))
    } } }

# Lower each record arm in order, exactly like `lower_lit_arms`: the arm's
# field tests seal the current block into a condbr chain (body vs a fresh
# fail label); the body lowers into the join + branches to `lcont`; the next
# arm reopens the fail label. A catch-all arm (a record with no literal
# fields, or a non-record pattern) matches unconditionally and ends the
# chain (later arms are dead). With no catch-all the last fail label is
# sealed `KUnreachable`.
fn lower_record_arms(arms: [Arm], scrv: KVal, join: String, lcont: String,
                     owned: Bool, sd: String, pend0: [String], st: LowerSt) : LowerSt / Console = match arms {
  [] -> ls_seal(st, KUnreachable(KNoPos), lcont)
  [Arm(p, _, body), ...rest] -> match ls_fresh_label(st) { LSLabel(body_lbl, st1) ->
    match rec_emit_arm(p, scrv, body_lbl, st1) { LMArm(st_body, fail_lbl) -> {
      # Record-arm field binds arrive OWNED (`kai_op_field` increfs) but are
      # not part of the structural-dup set; seed only the exit-drop entry
      # (an unconsumed field binder on a goto path stays a bounded leak).
      let st_drop = tcp_seed_arm(owned, sd, [], body, pend0, st_body)
      let st_done = lower_branch_into(body, join, lcont, match_selftail_scr_drop(owned, sd, body, st_drop))
      if rec_arm_is_catchall(p) { st_done }
      else { lower_record_arms(rest, scrv, join, lcont, owned, sd, pend0, reopen(st_done, fail_lbl)) }
    } } }
}

# Build the switch + per-arm blocks + default + continuation, given the
# already-lowered scrutinee atom and tag register (`match_preamble` set up
# the join slot + `__pcs_scr` alias). The default block is `KUnreachable`:
# kaikai matches are exhaustive, so the switch never falls through; emitting
# a unit store there would silently make a non-exhaustive program return ()
# instead of trapping (Linus review #3).
fn lower_match_blocks(x: Expr, arms: [Arm], scrv: KVal, tagv: KVal, owned: Bool, st: LowerSt) : LRes / Console =
  match match_preamble(x, scrv, owned, st) { LSPre(join, sd, st_decl) ->
    match two_labels(st_decl) { LSL2(lcont, ldef, st4) ->
      match plan_arms(arms, st4, []) { ArmPlan(cases, st5) -> {
        let pend0 = st5.tcpend
        let st6 = ls_seal(st5, KSwitch(tagv, cases, ldef, kpos_of(x)), ldef)
        # The default block holds the catch-all arm's body (a `_` or other
        # non-variant pattern → tag -1, routed here rather than to a
        # duplicate switch case). With no catch-all the match is variant-
        # exhaustive, so the default is `KUnreachable` (Linus review #3).
        let st7 = lower_default_arm(arms, scrv, join, lcont, ldef, owned, sd, pend0, st6)
        # One switch case per DISTINCT tag (plan_arms dedups). A tag matched
        # by one arm lowers its body directly in the case block; a tag SHARED
        # by N arms (`Exited(0)`/`Exited(_)`) opens a sub-fail-chain in the
        # case block that discriminates on the payload (kir_lower_variant).
        let st8 = lower_variant_groups(cases, arms, scrv, join, lcont, ldef, owned, sd, st6.mscr, pend0, st7)
        match_finish_tok(owned, sd, arms_have_arm_top(arms, st8), LRes(KVar(join), ls_set_tcpend(reopen(st8, lcont), pend0)))
      } } } }

# True iff any arm of this variant match captures an arm-top reuse token, so
# the continuation must free an unconsumed token (#872).
fn arms_have_arm_top(arms: [Arm], st: LowerSt) : Bool = match arms {
  []                         -> false
  [Arm(p, _, body), ...rest] -> if arm_is_top_reuse(p, body, st) { true } else { arms_have_arm_top(rest, st) }
}

# One switch case per DISTINCT variant tag, in first-appearance order.
# Non-variant arms (tag -1, e.g. a wildcard `_`) get NO case — they are the
# default block (`lower_default_arm`). A tag SHARED by several arms
# (`Exited(0)` / `Exited(_)`) gets ONE case whose block holds a sub-fail-
# chain (`lower_variant_groups`); emitting a case per arm would create the
# duplicate i32 switch entry LLVM rejects (the `Duplicate integer as switch
# case` native-parity family). The case label is the GROUP block; each
# group's arms are recovered by tag in `lower_variant_groups`.
fn plan_arms(arms: [Arm], st: LowerSt, acc: [KCase]) : ArmPlan / Console = match arms {
  [] -> ArmPlan(acc, st)
  [Arm(p, _, _), ...rest] -> {
    let tag = arm_tag(p, st)
    if tag < 0 { plan_arms(rest, st, acc) }
    else if kcase_has_tag(acc, tag) { plan_arms(rest, st, acc) }
    else { match ls_fresh_label(st) { LSLabel(lbl, st1) ->
      plan_arms(rest, st1, list_append(acc, [KC(tag, lbl)])) } }
  }
}

# Has a switch case for `tag` already been planned? (dedup of a shared tag).
fn kcase_has_tag(cases: [KCase], tag: Int) : Bool = match cases {
  [] -> false
  [KC(t, _), ...rest] -> if t == tag { true } else { kcase_has_tag(rest, tag) }
}

# Lower the catch-all arm's body into the default block, or seal it
# `KUnreachable` when the match is variant-exhaustive. This path now only
# runs for a VARIANT match with a single wildcard/binder default arm:
# literal-discriminated dispatch (`match n { 0 -> ...; 1 -> ... }`) is
# diverted to `lower_lit_match` (kir_lower_lit.kai) BEFORE this switch is
# built, so multiple non-variant arms no longer collapse into one default.
# The default arm runs when no variant case matched. Its PATTERN may bind
# the whole scrutinee: a `PBind(s)` whole-value binder, a `PNarrow(x, T)`
# refinement-narrowed binder (`x : LowerSlug -> shout(x)` — the typer's
# `where`-predicate match arm), or a `PAs(name, sub)`. Before binding the
# name to `scrv`, the body's `EVar(x)`/`EVar(s)` was an unbound register.
# A `PWild`/`PLit` default binds nothing. Destructuring (variant / record)
# default patterns also bind via `bind_pattern_fields_any`.
fn lower_default_arm(arms: [Arm], scrv: KVal, join: String, lcont: String,
                     ldef: String, owned: Bool, sd: String, pend0: [String], st: LowerSt) : LowerSt / Console =
  match first_default_arm(arms) {
    Some(Arm(p, _, body)) -> {
      let st_def = bind_default_pattern(p, scrv, body, reopen(st, ldef))
      # Issue #858 — the default arm's pattern (a `_`-tag binder / as-name /
      # destructure) aliases the scrutinee like a variant arm; restore the
      # oracle's structural pointer-slot incref so the owned exit drop balances.
      let st_rc = lower_arm_rc(p, body, sd, owned, st_def)
      let st_drop = tcp_seed_after_arm_rc(owned, sd, p, body, pend0, st_rc)
      lower_branch_into(body, join, lcont, match_selftail_scr_drop(owned, sd, body, st_drop))
    }
    None -> ls_seal(reopen(st, ldef), KUnreachable(KNoPos), lcont)
  }

# Alias a match-arm binder to the whole scrutinee. When `name` already names
# a register in scope (a fn param / outer binder of the SAME name — `match n {
# 0 -> ..; n if n < 0 -> .. }` over a param `n`), a second `KLet(name, ...)`
# would reuse the outer register's string-keyed alloca and, if their slots
# differ, widen and corrupt it (the native register table is name-keyed). So
# mint a fresh `.tN` register and record `name -> .tN` so the arm's guard +
# body reads resolve to it — exactly `lower_let_pbind`'s shadow discipline.
fn bind_scr_alias(name: String, scrv: KVal, pos: KPos, st: LowerSt) : LowerSt / Console =
  if ls_is_local(st, name) {
    match ls_fresh_reg(st) { LSReg(reg, st1) ->
      ls_push_rename(ls_emit(st1, KLet(reg, SBoxed, KLitOp(scrv), pos)), name, reg) }
  } else { ls_emit(st, KLet(name, SBoxed, KLitOp(scrv), pos)) }

# Bind the default arm's pattern to the whole scrutinee. A plain / narrowed
# binder aliases `scrv`; an as-pattern aliases then descends; a
# destructuring pattern reuses the field-bind path; wildcard/literal bind
# nothing.
fn bind_default_pattern(p: Pattern, scrv: KVal, body: Expr, st: LowerSt) : LowerSt / Console = match p.pkind {
  PBind(name)          -> bind_scr_alias(name, scrv, KAt(p.line, p.col), st)
  PNarrow(name, _)     -> bind_scr_alias(name, scrv, KAt(p.line, p.col), st)
  PAs(name, _)         -> bind_pattern_fields_any(as_inner(p), scrv, body, bind_scr_alias(name, scrv, KAt(p.line, p.col), st))
  PVariant(_, _)       -> bind_pattern_fields_any(p, scrv, body, st)
  PVariantRecord(_, _) -> bind_pattern_fields_any(p, scrv, body, st)
  PRecord(_)           -> bind_pattern_fields_any(p, scrv, body, st)
  _                    -> st
}

fn first_default_arm(arms: [Arm]) : Option[Arm] = match arms {
  [] -> None
  [a, ...rest] -> match a { Arm(p, _, _) -> if arm_is_default(p) { Some(a) } else { first_default_arm(rest) } }
}

# The pattern an arm dispatches on, looking through an as-pattern's binder
# (`a @ A` / `a: A` after the typer's narrow rewrite dispatch on `A`). The
# binder is bound separately by `bind_default_pattern`; here only the inner
# pattern's discriminant decides the arm's tag / default classification.
fn arm_disc_pat(p: Pattern) : Pattern = match p.pkind {
  PAs(_, inner) -> arm_disc_pat(inner)
  _             -> p
}

fn arm_is_default(p: Pattern) : Bool = match (arm_disc_pat(p)).pkind {
  PVariant(_, _)       -> false
  PVariantRecord(_, _) -> false
  _                    -> true
}

# The variant tag an arm matches. Non-variant patterns carry tag -1 so
# `plan_arms` routes them to the default path instead of a switch case.
fn arm_tag(p: Pattern, st: LowerSt) : Int = match (arm_disc_pat(p)).pkind {
  PVariant(name, _)       -> ls_variant_tag(st, name)
  PVariantRecord(name, _) -> ls_variant_tag(st, name)
  _                       -> 0 - 1
}

# Lower the body block(s) for each switch case. One case per distinct tag
# (plan_arms dedups); its arms are recovered from `arms` by tag, preserving
# source order. A tag matched by ONE arm lowers that arm's binds + body
# directly in the case block. A tag SHARED by N arms opens a sub-fail-chain
# in the case block: each discriminating arm tests its payload
# (`var_emit_subtests`) and branches to its own body on success / the next
# arm on failure; the tag's catch-all arm (`Exited(_)`) ends the chain
# unconditionally. The chain's final fail routes to `ldef` (the switch
# default): "no arm of this tag matched" is exactly "fell through the
# switch" — `ldef` carries the global `_` body or is `KUnreachable` when the
# match is exhaustive (Linus review #3, mirror of `lower_default_arm`).
# `mscr0` is this match's `mscr` as of the preamble (its own `<join>$sd` when
# owned, else the enclosing match's). It is restored before EACH group: a prior
# group's body may run a nested match that leaves `mscr` pointing at ITS
# `<join>$sd`, and a reuse-fork arm (`condbr kaix_check_unique`, no
# `match_preamble` of its own) reads the stale name in
# `reuse_neutralise_exit_drop` — storing/dropping the wrong register, a raw
# scalar from the nested arm freed as a pointer (#1229).
fn lower_variant_groups(cases: [KCase], arms: [Arm], scrv: KVal, join: String,
                        lcont: String, ldef: String, owned: Bool, sd: String, mscr0: String, pend0: [String], st: LowerSt) : LowerSt / Console = match cases {
  [] -> st
  [KC(tag, lbl), ...crest] -> {
    let group = arms_with_tag(arms, tag, st)
    let st1 = lower_one_group(group, scrv, join, lcont, lbl, ldef, owned, sd, mscr0, pend0, ls_set_mscr(st, mscr0))
    lower_variant_groups(crest, arms, scrv, join, lcont, ldef, owned, sd, mscr0, pend0, st1)
  }
}

# Issue #858 — structural incref of an owned variant arm's POINTER-kind
# sub-binders (Int/Real slots are read unboxed by the oracle, so they are
# excluded by slot kind via `st.vs`), mirroring the oracle's `kai_incref` on
# `is_alias=true` pointer-slot variant-arg binds. The set is RECURSIVE
# (`pat_alias_binders`): a binder inside a discriminating nested sub-pattern
# is also a KProj borrow of the scrutinee's storage — a flat top-level set
# would leave it un-dup'd, so a callee consuming it frees the still-referenced
# slot of a live decl (use-after-free on the second lookup). Emitted after the
# arm's binds, before the body lowers. Gated on `owned ∧ ¬arm_body_uses_reuse`
# exactly like the list path: a reuse arm consumes the scrutinee through
# `__perceus_reuse_*` (rb-tree `ins`), where a structural dup would
# double-incref kept children.
# The structural dup is required whenever the scrutinee is NOT consumed by a
# reuse helper — for an OWNED match (the exit `__pcs_scr_drop` would free the
# borrowed slots) AND for a BORROWED one (issue #1127 rule 4: a bound child
# of a borrowed scrutinee flows to an owned position and needs its own ref,
# exactly the C oracle's unconditional `is_alias` incref). Only a reuse arm
# suppresses it (the reuse helper owns the kept children's RC). `owned` still
# gates the exit-drop elsewhere; it must NOT gate this dup.
# A ctor under a live region never reuses a cell in place — it bump-allocates
# fresh so the arena frees it wholesale, and per-node RC vanishes. So the reuse
# recognisers (dual-branch `KConReuse`, arm-top token) are inert under a region:
# every arm takes the plain alias-dup path and `lower_reuse` emits a fresh arena
# ctor. Reusing in place would fresh-alloc the shared branch on the RC heap,
# reintroducing the per-node incref the region exists to eliminate.
fn arm_reuses(body: Expr, st: LowerSt) : Bool =
  arm_body_uses_reuse(body) and not st.in_region

fn dup_variant_arm_binders(p: Pattern, body: Expr, owned: Bool, st: LowerSt) : LowerSt / Console =
  if not arm_reuses(body, st) {
    lm_dup_alias_binders(pat_alias_binders(p, st.vs), KAt(p.line, p.col), st)
  } else { st }

# native variant reuse leak (#872) — publish a reuse arm's scrutinee pointer
# binders so the `KConReuse` lowered inside `body` (possibly under an `if`)
# emits the shared-donor incref of each embedded kept child. A non-reuse arm
# clears the set so a sibling arm's stale names never leak in. The set carries
# top-level slots AND one-level nested grand-children (the rotation kept
# children) — exactly the borrowed leaves the rebuild embeds.
fn set_reuse_gc_for_arm(p: Pattern, body: Expr, st: LowerSt) : LowerSt =
  if arm_reuses(body, st) {
    ls_set_rnested(ls_set_reuse_gc(st, reuse_scrutinee_binders(p, st.vs)),
                   pat_reuse_nested(p, st.vs))
  } else { ls_set_rnested(ls_set_reuse_gc(st, []), RNInone) }

# The scrutinee pointer-binders the `KConReuse` shared path protects, by
# pattern shape. A `PList` cons arm keeps its DIRECT slots (head + tail) — the
# deconstructed sub-binders are already dup'd unconditionally outside the fork,
# so the reuse-gc set covers only the per-branch direct slots. A variant
# rotation embeds kept children at ANY depth (a two-level rotation reaches
# grand-grand-children), so it publishes the FULL alias set; `reuse_gc_uses`
# then filters to the ones the rebuild actually re-embeds. Either way the
# C oracle increfs each kept child in its shared branch, so a reuse over a
# SHARED donor needs the same per-child incref or the match-exit
# `decref(donor)` frees the borrowed children.
fn reuse_scrutinee_binders(p: Pattern, vs: [EVar]) : [String] = match p.pkind {
  PList(_, _) -> pat_direct_alias_slots(p, vs)
  _           -> pat_alias_binders(p, vs)
}

# True iff this arm should capture its consumed scrutinee as an arm-top reuse
# token (#872): a PVariant arm whose body has a `__kai_trmc|` step on some tail
# (`Node(c, ins(l,..),..)`) and binds ≥1 pointer child. The TRMC step reuses the
# token in place; a non-step tail (`balance_left(ins(l,..),..)`) frees it. The C
# oracle's `try_arm_top_reuse` predicate.
fn arm_is_top_reuse(p: Pattern, body: Expr, st: LowerSt) : Bool = match p.pkind {
  PVariant(_, _) -> not st.in_region and body_has_trmc_step(body) and not list_is_empty_s(pat_direct_alias_slots(p, st.vs))
  _              -> false
}

fn list_is_empty_s(xs: [String]) : Bool = match xs { [] -> true _ -> false }

# Emit an owned arm's RC prologue, branching on shape:
#  - arm-top reuse: capture the consumed scrutinee as `_arm_ru` + shared-incref
#    the kept ptr children, then NEUTRALISE the match-exit drop by rebinding the
#    exit-drop register `sd` to unit (the token is the sole disposer). No #858
#    dup (the token model owns the kept children's RC).
#  - a `__perceus_reuse_*` arm: publish the reuse-gc set (the `KConReuse` path
#    emits the shared incref); no #858 dup.
#  - otherwise: the #858 structural dup of pointer-slot alias binders.
fn lower_arm_rc(p: Pattern, body: Expr, sd: String, owned: Bool, st: LowerSt) : LowerSt / Console =
  if owned and arm_is_top_reuse(p, body, st) {
    let st1 = ls_emit(st, KRC(KArmTopReuse(KVar(sd), variant_arm_arity(p, st.vs),
                                           pat_direct_alias_slots(p, st.vs)), kpos_of(body)))
    ls_emit(st1, KStore(sd, KUnitV, kpos_of(body)))
  } else {
    set_reuse_gc_for_arm(p, body, dup_variant_arm_binders(p, body, owned, st))
  }

# The rebuild arity for the arm-top token: the matched ctor's slot count.
fn variant_arm_arity(p: Pattern, vs: [EVar]) : Int = match p.pkind {
  PVariant(cname, subs) -> match pa_payload_tys(vs, cname) { [] -> list_length(subs) ts -> list_length(ts) }
  _                     -> 0
}

# The VARIANT arms whose top-level tag is `tag`, in source order.
fn arms_with_tag(arms: [Arm], tag: Int, st: LowerSt) : [Arm] = match arms {
  [] -> []
  [a, ...rest] -> match a { Arm(p, _, _) ->
    if arm_is_default(p) or arm_tag(p, st) != tag { arms_with_tag(rest, tag, st) }
    else { [a, ...arms_with_tag(rest, tag, st)] } }
}

# Lower one tag group into its case block `lbl`. A lone arm that does NOT
# discriminate on its payload (`Some(x)`, `Ok(_)`) binds its fields and
# lowers its body directly — the common case, keeping the switch O(1) with
# no extra branch (the tag alone decided the winner). A lone arm that DOES
# discriminate on its payload (`Some(91)`, `Some(Red)` — a literal / nullary-
# ctor / nested-variant slot) must still TEST that slot: the tag-switch only
# proved the constructor, not the sub-pattern, so a bare jump would match
# every `Some(_)` (the lone-arm-skips-sub-test miscompile — `Some(91)` would
# capture `Some(49)`). Such an arm routes through the same sub-fail-chain a
# shared tag uses, with the single arm's miss falling to `ldef` (the switch
# default = the global `_` body or `KUnreachable`). A shared tag (N>1 arms)
# always opens the chain.
fn lower_one_group(group: [Arm], scrv: KVal, join: String, lcont: String,
                   lbl: String, ldef: String, owned: Bool, sd: String, mscr0: String, pend0: [String], st: LowerSt) : LowerSt / Console = match group {
  [Arm(p, g, body)] ->
    if var_arm_is_tag_catchall(p) {
      let st_arm = reopen(st, lbl)
      let st_bound = bind_pattern_fields(p, scrv, body, st_arm)
      let st_rc = lower_arm_rc(p, body, sd, owned, st_bound)
      let st_drop = tcp_seed_after_arm_rc(owned, sd, p, body, pend0, st_rc)
      lower_branch_into(body, join, lcont, match_selftail_scr_drop(owned, sd, body, st_drop))
    } else { lower_group_chain([Arm(p, g, body)], scrv, join, lcont, lbl, ldef, owned, sd, mscr0, pend0, reopen(st, lbl)) }
  _ -> lower_group_chain(group, scrv, join, lcont, lbl, ldef, owned, sd, mscr0, pend0, reopen(st, lbl))
}

# The sub-fail-chain for a tag shared by N>1 arms. Each arm: if it
# discriminates on its payload, test it (`condbr` to its body on match / a
# fresh fail label on mismatch); if it is the tag's catch-all, branch
# unconditionally to its body (ending the chain — later arms are dead, which
# the typer's redundancy check forbids). After binding its fields, the arm's
# body lowers into the shared join. The last fail label routes to `ldef`.
fn lower_group_chain(group: [Arm], scrv: KVal, join: String, lcont: String,
                     fail_lbl: String, ldef: String, owned: Bool, sd: String, mscr0: String, pend0: [String], st: LowerSt) : LowerSt / Console = match group {
  [] -> ls_seal(reopen(st, fail_lbl), KBr(ldef, KNoPos), ldef)
  [Arm(p, _, body), ...rest] -> match ls_fresh_label(reopen(ls_set_mscr(st, mscr0), fail_lbl)) { LSLabel(body_lbl, st1) ->
    if var_arm_is_tag_catchall(p) {
      # Catch-all of this tag: branch straight to the body; later arms dead.
      let st2 = ls_seal(st1, KBr(body_lbl, KNoPos), body_lbl)
      let st3 = bind_pattern_fields(p, scrv, body, reopen(st2, body_lbl))
      let st3d = lower_arm_rc(p, body, sd, owned, st3)
      let st3dd = tcp_seed_after_arm_rc(owned, sd, p, body, pend0, st3d)
      lower_branch_into(body, join, lcont, match_selftail_scr_drop(owned, sd, body, st3dd))
    } else {
      match ls_fresh_label(st1) { LSLabel(next_fail, st2) -> {
        let st4 = emit_arm_subtests_and_binds(p, scrv, body, body_lbl, next_fail, st2)
        let st4d = lower_arm_rc(p, body, sd, owned, st4)
        let st4dd = tcp_seed_after_arm_rc(owned, sd, p, body, pend0, st4d)
        let st5 = lower_branch_into(body, join, lcont, match_selftail_scr_drop(owned, sd, body, st4dd))
        lower_group_chain(rest, scrv, join, lcont, next_fail, ldef, owned, sd, mscr0, pend0, st5)
      } }
    } }
}

# Emit a discriminating variant arm's payload sub-tests + field binds,
# routing a miss to `fail_lbl` and leaving the cursor at `body_lbl` with the
# arm's binders in scope. The common case is `var_emit_subtests` (the test)
# followed by `bind_pattern_fields` (the bind) — TEST precedes BIND, as the
# oracle does. The exception is a payload slot that is itself a LIST PATTERN
# (`Some([x, y])`): a list pattern interleaves its length test with its
# head/tail binds (`lm_emit_cells`), so it cannot be split into a test pass
# then a bind pass. Such a slot is lowered by `lm_emit_cells` against the
# PROJECTED slot value — the list decision-tree machinery (kir_lower_match)
# entered from a variant slot, the mirror of how a nested variant head re-
# enters the variant machinery from a list cell. This seam lives in the walk
# (not kir_lower_variant) because only the walk imports BOTH kir_lower_variant
# and kir_lower_match — variant cannot call lm_emit_cells without an import
# cycle (variant <- match). A slot-list arm has exactly one discriminating
# slot (the list); a mixed multi-slot payload with a list stays the documented
# subset gap (`bind_unsupported_nested` traps loud, never silent-wrong).
fn emit_arm_subtests_and_binds(p: Pattern, scrv: KVal, body: Expr, body_lbl: String,
                               fail_lbl: String, st: LowerSt) : LowerSt / Console =
  match var_arm_lone_list_slot(p) {
    Some(VLSlot(idx, pats, opt_rest)) ->
      match var_proj_slot(scrv, idx, p, st) { LRes(slotv, st1) -> {
        let st2 = reopen(lm_emit_cells(pats, opt_rest, slotv, body_lbl, fail_lbl, false, st1), body_lbl)
        # The list slot's own head/tail names bound via lm_emit_cells; the
        # sibling binder/wildcard slots still need their KLet. A PList slot is
        # a no-op in bind_pattern_fields, so this binds the siblings only.
        bind_pattern_fields(p, scrv, body, st2)
      } }
    None -> {
      let st3 = var_emit_subtests(p, scrv, body_lbl, fail_lbl, st)
      bind_pattern_fields(p, scrv, body, st3)
    }
  }

# --- Guarded / all-binder match: the linear fail-chain ------------------
#
# The general decision tree for a `match` that carries ANY arm guard, or
# whose arms all bind (no tag to switch on). Mirrors the C-direct oracle's
# `emit_match_arm` exactly: a linear chain, in source order, of
#   pattern-test → bind → [guard-test] → body | next-arm
# No `KTagOf` / `KSwitch`: the scrutinee may be a scalar (Int / Real) whose
# `variant_tag` word is meaningless. Each arm:
#   1. tests its pattern (`guard_emit_pat_test`); a non-discriminating
#      pattern (PBind / PWild / PNarrow / PAs / PHole) always matches, so
#      its "fail" label IS its body label (no branch);
#   2. binds the pattern's names (`bind_pattern_fields`) — BEFORE the guard,
#      which reads them (`n if n % 2 == 0`);
#   3. if guarded, evaluates the guard and `condbr`s to the body on truthy /
#      the next arm's fail label on falsy (the guard can reject post-match);
#   4. lowers its body into the shared `join`, then branches to `lcont`.
# The chain's final fail seals `KUnreachable` — the typer guarantees the
# match is exhaustive, so the last arm (unguarded or a catch-all) always
# matches and the trailing fail is dead (Linus review #3, as the other
# chains). The binds are pure slot aliases (`KLitOp(scrv)` / `KProj`), so a
# rejected guard's unused binder owns nothing — no drop is owed (the oracle
# emits none either; byte-id parity by construction).
fn lower_guard_chain(x: Expr, arms: [Arm], scrv: KVal, owned: Bool, st: LowerSt) : LRes / Console =
  match match_preamble(x, scrv, owned, st) { LSPre(join, sd, st1) ->
    match ls_fresh_label(st1) { LSLabel(lcont, st2) -> {
      let pend0 = st2.tcpend
      let st3 = lower_guard_arms(arms, scrv, join, lcont, owned, sd, pend0, st2)
      match_finish(owned, sd, LRes(KVar(join), ls_set_tcpend(reopen(st3, lcont), pend0)))
    } } }

# Each arm pre-allocates `next_fail`, the block where the REST of the chain
# starts. Both the pattern test (mismatch) AND the guard (falsy) route there,
# so a rejected arm — for either reason — falls to the next in source order
# (the oracle's `if (pat) { binds; if (truthy(g)) {…} }` fall-through). The
# terminal arm (the typer guarantees one matches) seals `next_fail`
# `KUnreachable`. Keeping `next_fail` distinct from the body label is what
# lets a guarded BINDER arm (`n if … ->`) fail to the next arm rather than
# loop back onto its own body.
fn lower_guard_arms(arms: [Arm], scrv: KVal, join: String, lcont: String,
                    owned: Bool, sd: String, pend0: [String], st: LowerSt) : LowerSt / Console = match arms {
  # No arms left: control reaches here only through the previous arm's
  # `next_fail` (the block currently open, `st.cl`). The typer guarantees
  # the match is exhaustive, so this fall-through is dead — seal it
  # `KUnreachable` (the LLVM verifier rejects an open block with no
  # terminator). A fresh dead successor is opened and immediately discarded
  # by the caller's `reopen(lcont)`.
  [] -> match ls_fresh_label(st) { LSLabel(dead, st1) ->
    ls_seal(st1, KUnreachable(KNoPos), dead) }
  [Arm(p, opt_guard, body), ...rest] -> match ls_fresh_label(st) { LSLabel(next_fail, st0) ->
    match guard_emit_pat_test(p, scrv, next_fail, st0) {
      LMArm(st_body, _) -> {
        # The arm's binder may shadow-rename an outer name; that rename is
        # scoped to THIS arm's guard + body. Snapshot before binding so the
        # rest of the chain (lowered at `next_fail`) does not inherit it.
        let rsnap = st_body.renames
        let st_alias = bind_default_pattern(p, scrv, body, st_body)
        # A whole-value / as / destructure binder aliases the owned scrutinee;
        # without the structural pointer-slot incref (`lower_arm_rc`, as the
        # variant + default arms already emit) the match-exit `KDrop(sd)` frees
        # the cell the binder transfers to the result — a use-after-free.
        let st_rc = lower_arm_rc(p, body, sd, owned, st_alias)
        let st_bound = tcp_seed_after_arm_rc(owned, sd, p, body, pend0, st_rc)
        let st_done = match opt_guard {
          None -> lower_branch_into(body, join, lcont, match_selftail_scr_drop(owned, sd, body, st_bound))
          Some(g) -> match ls_fresh_label(st_bound) { LSLabel(run_lbl, stg) ->
            match lower_expr(g, stg) { LRes(gv, stg1) -> {
              # Guard truthy → run the body; falsy → `next_fail` (next arm).
              # `KCondBr` takes the boxed guard value directly (the backend's
              # condbr lowering reads it through `kaix_truthy`, as `lower_if`).
              # The guard's reads refine the ledger before the body lowers.
              let st_fork = ls_seal(stg1, KCondBr(gv, run_lbl, next_fail, kpos_of(g)), run_lbl)
              lower_branch_into(body, join, lcont,
                                match_selftail_scr_drop(owned, sd, body, tcp_after(reopen(st_fork, run_lbl), g)))
            } } }
        }
        # The next arm continues at `next_fail`. If this arm always matched
        # (a binder with NO guard), control never falls through — `next_fail`
        # is dead, sealed `KUnreachable` (the typer forbids a reachable arm
        # after an unconditional one). Otherwise the rest of the chain lowers
        # starting at `next_fail`.
        let arm_is_terminal = guard_pat_always_matches(p) and match opt_guard { None -> true Some(_) -> false }
        if arm_is_terminal {
          ls_seal(reopen(st_done, next_fail), KUnreachable(KNoPos), next_fail)
        } else {
          lower_guard_arms(rest, scrv, join, lcont, owned, sd, pend0, ls_set_renames(reopen(st_done, next_fail), rsnap))
        }
      } } }
}

# Emit ONLY the pattern test for a guard-chain arm, routing a MISMATCH to
# the caller-supplied `fail_lbl` (the next arm's start). The bind + guard are
# threaded by the caller after this returns. Opens a FRESH body label, seals
# a `condbr (test) ? body : fail_lbl`, and returns `LMArm(st_at_body, _)` (the
# fail label is the caller's, echoed back unused). A non-discriminating
# pattern (always matches) just branches to its fresh body — its mismatch
# edge is dead, so `fail_lbl` stays live for the guard / the next arm.
fn guard_emit_pat_test(p: Pattern, scrv: KVal, fail_lbl: String,
                       st: LowerSt) : LMArm / Console =
  match p.pkind {
    PLit(lit) -> match ls_fresh_label(st) { LSLabel(body_lbl, st1) -> {
      let st2 = guard_lit_test(lit, scrv, body_lbl, fail_lbl, st1)
      LMArm(reopen(st2, body_lbl), fail_lbl)
    } }
    # Top-level variant: test the constructor tag, then (when a sub-pattern
    # discriminates — `Some(0) if g`) the payload sub-slots, all routing a
    # miss to `fail_lbl`. A plain `Some(n)` (no discriminating sub) reduces
    # to the bare tag test.
    PVariant(cname, subs) -> match ls_fresh_label(st) { LSLabel(body_lbl, st1) -> {
      let st2 = guard_emit_variant_test(cname, subs, scrv, body_lbl, fail_lbl, p, st1)
      LMArm(reopen(st2, body_lbl), fail_lbl)
    } }
    PVariantRecord(cname, _) -> match ls_fresh_label(st) { LSLabel(body_lbl, st1) -> {
      let st2 = var_seal_tag_of(scrv, cname, body_lbl, fail_lbl, p, st1)
      LMArm(reopen(st2, body_lbl), fail_lbl)
    } }
    # An as-pattern emits the inner pattern's test (the binder is bound after,
    # by `bind_default_pattern`); `a @ A` tests the `A` tag, `a @ _` passes.
    PAs(_, inner) -> guard_emit_pat_test(inner, scrv, fail_lbl, st)
    # Non-discriminating: always matches — branch straight to a fresh body.
    PWild        -> guard_pat_passthrough(p, fail_lbl, st)
    PBind(_)     -> guard_pat_passthrough(p, fail_lbl, st)
    PNarrow(_, _) -> guard_pat_passthrough(p, fail_lbl, st)
    PHole(_)     -> guard_pat_passthrough(p, fail_lbl, st)
    # PList / PRecord guarded arms are not yet covered by the linear chain
    # (their test machinery owns its own fail label, which does not compose
    # with the chain's `fail_lbl` without a block-reopen hazard). Trap loud
    # rather than miscompile — the families this lane closes (Int/Real binder
    # guards, variant guards) do not hit this; if one appears, it surfaces
    # here instead of silently diverging (lane discipline).
    PList(_, _) -> { eprint("kir: guarded list-pattern arm not yet lowered"); guard_pat_passthrough(p, fail_lbl, st) }
    PRecord(_)  -> { eprint("kir: guarded record-pattern arm not yet lowered"); guard_pat_passthrough(p, fail_lbl, st) }
    _ -> guard_pat_passthrough(p, fail_lbl, st)
  }

# `kai_eq_raw scr lit` → condbr body/fail. The literal-slot equality test,
# inlined here (kir_lower_lit's `lit_emit_test` is module-private). Mirror
# of `var_seal_eq` for the whole scrutinee.
fn guard_lit_test(lit: Expr, scrv: KVal, body_lbl: String, fail_lbl: String,
                  st: LowerSt) : LowerSt / Console =
  match bind_op(st, KPrim("kai_eq_raw", [scrv, lit_atom(lit)]), KAt(lit.line, lit.col)) {
    LRes(cond, st1) -> ls_seal(st1, KCondBr(cond, body_lbl, fail_lbl, KAt(lit.line, lit.col)), fail_lbl)
  }

# Test a top-level variant pattern: its constructor tag, then (when a
# sub-pattern discriminates — `Some(0)`) the payload sub-slots, all routing
# a miss to `fail_lbl`. A plain `Some(n)` (no discriminating sub) is just
# the tag test. Mirrors `var_seal_variant`'s top-level shape but tests the
# scrutinee directly (no enclosing slot to project).
fn guard_emit_variant_test(cname: String, subs: [Pattern], scrv: KVal,
                           body_lbl: String, fail_lbl: String, p: Pattern,
                           st: LowerSt) : LowerSt / Console =
  if any_discriminating(subs) {
    match ls_fresh_label(st) { LSLabel(sub_lbl, st1) -> {
      let st2 = var_seal_tag_of(scrv, cname, sub_lbl, fail_lbl, p, st1)
      var_emit_slot_tests(cname, subs, scrv, 0, body_lbl, fail_lbl, reopen(st2, sub_lbl))
    } }
  } else { var_seal_tag_of(scrv, cname, body_lbl, fail_lbl, p, st) }

# A pattern that always matches: open one fresh body label, branch to it.
# `fail_lbl` (the next arm's start) is echoed back untouched — the binder's
# mismatch edge is dead, but the GUARD (if any) still routes there.
fn guard_pat_passthrough(p: Pattern, fail_lbl: String, st: LowerSt) : LMArm / Console =
  match ls_fresh_label(st) { LSLabel(body_lbl, st1) ->
    LMArm(reopen(ls_seal(st1, KBr(body_lbl, KAt(p.line, p.col)), body_lbl), body_lbl), fail_lbl) }

# Does this pattern match every value (no test needed)? An as-pattern matches
# every value iff its inner pattern does (`a @ A` discriminates on `A`; `a @ _`
# does not).
fn guard_pat_always_matches(p: Pattern) : Bool = match p.pkind {
  PWild         -> true
  PBind(_)      -> true
  PNarrow(_, _) -> true
  PAs(_, inner) -> guard_pat_always_matches(inner)
  PHole(_)      -> true
  _             -> false
}

# Does `arms` carry any arm guard (`X if cond -> …`)?
fn match_has_any_guard(arms: [Arm]) : Bool = match arms {
  [] -> false
  [Arm(_, Some(_), _), ..._] -> true
  [Arm(_, None, _), ...rest] -> match_has_any_guard(rest)
}

# Does any arm discriminate by a real pattern (tag / literal / structure)?
# A `match` with NONE — every arm a binder / wildcard — has no tag to
# switch on (its scrutinee may be a scalar), so it routes to the linear
# chain rather than the `KTagOf` path that would deref-fault on an Int.
fn match_has_discriminating_pattern(arms: [Arm]) : Bool = match arms {
  [] -> false
  [Arm(p, _, _), ...rest] ->
    if guard_pat_always_matches(p) { match_has_discriminating_pattern(rest) }
    else { true }
}

# --- Effect handlers ----------------------------------------------------

# Materialise an effect handler as a double fork (asu review): a join
# `result` slot, then `install eff` + `setjmp eff` + `condbr` splitting
# the normal body path from the longjmp-discard path. The body lowers
# INLINE (it runs in the handle's frame, capturing the whole scope), pops
# the evidence on its normal exit, and stores into `result`; the discard
# path stores the discarded value. The return clause (if any) lowers
# inline over `result` at the merge. The clause bodies are separate
# `KFnClause`s (generated in `lower_to_kir`).
fn lower_handle(x: Expr, body: Expr, eff: String, init_opt: Option[Expr],
                alias_opt: Option[String], ret_opt: Option[HReturn], st: LowerSt) : LRes / Console {
  let sym = cat3("_kai_handler_", int_to_string(x.line), cat2("_", int_to_string(x.col)))
  match lower_init_opt(init_opt, st) { LResOpt(initv, st1) ->
    match ls_fresh_reg(st1) { LSReg(result, st2) -> {
      let st3 = ls_emit(st2, KLet(result, SBoxed, KLitOp(KUnitV), kpos_of(x)))
      let st4 = ls_emit(st3, KInstall(eff, sym, initv, alias_opt, kpos_of(x)))
      # A handle carrying `init` state is stateful — its return clause sees
      # `state`/`log` (gated in `lower_handle_ret` via `KBindEvState`).
      let stateful = match initv { Some(_) -> true None -> false }
      # `sym` (the install-site id) threads into the setjmp/pop so each site's
      # evidence-frame storage is named per-SITE, not per-EFFECT: two nested
      # handlers of the same effect must NOT share a `__node_<eff>` alloca, or
      # the second push self-cycles the parent chain (refs #789).
      lower_handle_fork(x, body, eff, sym, result, stateful, ret_opt, st4)
    } } }
}

# The setjmp split: `condbr (setjmp eff) ? Ldiscard : Lbody`. Lbody runs
# the body inline, pops, stores; Ldiscard stores the longjmp-returned
# value; both branch to Lret, where the return clause lowers over result.
# `stateful` (the handle carries `init` state) gates the return clause's
# `state`/`log` bind — threaded from `lower_handle` where `init_opt` is known.
fn lower_handle_fork(x: Expr, body: Expr, eff: String, sym: String, result: String,
                     stateful: Bool, ret_opt: Option[HReturn], st: LowerSt) : LRes / Console =
  match bind_op(st, KSetjmp(eff, sym), kpos_of(x)) { LRes(jmpv, st1) ->
    match three_labels(st1) { LSL3(ldisc, lbody, lret, st2) -> {
      let st3 = ls_seal(st2, KCondBr(jmpv, ldisc, lbody, kpos_of(x)), lbody)
      let st4 = lower_handle_body(body, eff, sym, result, lret, st3)
      let st5 = lower_handle_discard(sym, result, lret, ldisc, st4)
      lower_handle_ret(eff, sym, result, stateful, ret_opt, lret, st5)
    } } }

# Lbody: lower the body inline, store it into result, pop the evidence,
# branch to the merge. The pop sits on the NORMAL exit only — the
# discard path's longjmp already unwound past it (asu soundness note).
fn lower_handle_body(body: Expr, eff: String, sym: String, result: String, lret: String, st: LowerSt) : LowerSt / Console =
  match lower_expr(body, st) { LRes(bv, st1) -> {
    let st2 = ls_emit(st1, KStore(result, bv, kpos_of(body)))
    let st3 = ls_emit(st2, KPop(eff, sym, kpos_of(body)))
    ls_seal(st3, KBr(lret, kpos_of(body)), lret)
  } }

# Ldiscard: the value the longjmp landed with becomes the result (the
# clause already produced it and popped the evidence). The runtime hands
# it back through the handler's discard slot — modelled as a unit store
# placeholder the backend fills from the landing pad.
# The discard slot is per install-SITE (`__kai_discard_<sym>`), not a single
# `__kai_discard`: nested same-effect handles each own a jmp_buf+discard slot,
# and the landing pad (setjmp != 0) of site N must read SITE N's discarded
# value. The name MUST agree with `nfx_discard_reg(sym)` in emit_native_fx.kai
# (the alloca the install reserves under the same string).
fn lower_handle_discard(sym: String, result: String, lret: String, ldisc: String, st: LowerSt) : LowerSt / Console {
  let st1 = ls_emit(reopen(st, ldisc), KStore(result, KVar(cat2("__kai_discard_", sym)), KNoPos))
  ls_seal(st1, KBr(lret, KNoPos), lret)
}

# Lret: apply the return clause (if any) inline over `result`, binding its
# param to the body result; the clause body's value is the handle's
# value. With no return clause the result passes through unchanged. A
# STATEFUL handle's return clause body may reference `state`/`log` (the
# handler's final state) — emit `KBindEvState(eff, sym)` BEFORE lowering rexpr so
# those registers resolve (mirror of emit_c's `kai_state = _ev.state` /
# emit_llvm's GEP-load-push prologue). Stateless / no-return handles skip it.
fn lower_handle_ret(eff: String, sym: String, result: String, stateful: Bool,
                    ret_opt: Option[HReturn], lret: String, st: LowerSt) : LRes / Console =
  match ret_opt {
    None -> LRes(KVar(result), reopen(st, lret))
    Some(HR(pname, rexpr, _, _)) -> {
      let st0 = reopen(st, lret)
      let st1 = if stateful { ls_emit(st0, KBindEvState(eff, sym, KNoPos)) } else { st0 }
      let st2 = ls_emit(st1, KLet(pname, SBoxed, KLitOp(KVar(result)), KNoPos))
      lower_expr(rexpr, st2)
    }
  }

fn lower_init_opt(init_opt: Option[Expr], st: LowerSt) : LResOpt / Console = match init_opt {
  None    -> LResOpt(None, st)
  Some(e) -> match lower_expr(e, st) { LRes(v, st1) -> LResOpt(Some(v), st1) }
}

# --- Calls: dispatch by callee shape -----------------------------------

fn lower_call(x: Expr, f: Expr, cargs: [Expr], st: LowerSt) : LRes / Console = match f.kind {
  EVar(callee) -> lower_named_call(x, callee, cargs, st)
  EModCall(modn, name) ->
    if kir_name_is_ctor(name) { lower_ctor_call(x, name, cargs, st) }
    # A cross-module `extern "C" fn` (`myffi.abs`) resolves to its mangled
    # wrapper `kai_myffi__abs`, not the bare `myffi__abs` — the wrapper calls
    # the bare extern `abs`, so the two must not share a symbol.
    else if name_in_list(st.ffi, name) { lower_direct_call(x, ffi_wrapper_sym(name, Some(modn)), cargs, st) }
    else { lower_direct_call(x, c_sym(name, Some(modn)), cargs, st) }
  _ -> {
    let rf = lower_expr(f, st)
    match rf { LRes(fv, st1) -> match lower_exprs(cargs, st1, []) {
      LResMany(avs, st2) -> bind_op(st2, KCallIndirect(fv, avs), kpos_of(x)) } }
  }
}

# `lhs |> rhs` — splice `lhs` in as the FIRST argument of the call `rhs`
# names, then delegate to `lower_call`. This is the post-perceus desugar
# the C-direct oracle (`emit_pipe_expr`) does at codegen, reproduced node-
# for-node so the two backends agree:
#   - `lhs |> f(a, b)`        → `f(lhs, a, b)`        (ECall callee splice)
#   - `lhs |> mod.g(a)`       → `mod.g(lhs, a)`       (EModCall callee splice)
#   - `lhs |> f`  / `mod.g`   → `f(lhs)` / `mod.g(lhs)` (bare callee)
#   - `lhs |> <expr>`         → `(<expr>)(lhs)`        (indirect, kaix_apply)
# A spliced `ECall` carries the SAME callee `Expr` the typer resolved
# (variant / core / efn / local), so `lower_call`'s dispatch picks the
# right shape with no special-casing — the burn-down-3 lesson: route through
# `lower_call`, do not hand-build the callee. The synthetic `ECall` reuses
# `rhs`'s position so a lowering error still points at the user's call.
fn lower_pipe(x: Expr, lhs: Expr, rhs: Expr, st: LowerSt) : LRes / Console = match rhs.kind {
  ECall(f, cargs) -> lower_call(x, f, [lhs, ...cargs], st)
  EVar(_)         -> lower_call(x, rhs, [lhs], st)
  EModCall(_, _)  -> lower_call(x, rhs, [lhs], st)
  _ -> {
    let rf = lower_expr(rhs, st)
    match rf { LRes(fv, st1) -> match lower_expr(lhs, st1) {
      LRes(av, st2) -> bind_op(st2, KCallIndirect(fv, [av]), kpos_of(x)) } }
  }
}

# The dense dispatch: perceus marks → KRC; sentinels → terminators;
# resume → resume terminator; constructor / ordinary call otherwise. The
# string-matching lives in the pure `classify_callee` (base); the walk
# only routes the resulting `CalleeKind` to its lowering.
fn lower_named_call(x: Expr, callee: String, cargs: [Expr], st: LowerSt) : LRes / Console =
  match split_eff_op(callee, st.effs) {
    Some(EffOp(eff, op)) -> lower_perform(x, eff, op, cargs, st)
    None                 -> lower_named_call_kind(x, callee, cargs, st)
  }

# Dispatch a non-effect-op bare call by its `CalleeKind`.
fn lower_named_call_kind(x: Expr, callee: String, cargs: [Expr], st: LowerSt) : LRes / Console =
  match classify_callee(callee) {
    CkDup       -> lower_rc_unary(cargs, KDupMk, st)
    CkDrop      -> lower_rc_unary(cargs, KDropMk, st)
    CkBorrow    -> lower_borrow_through(cargs, st)
    CkReuse     -> lower_reuse(x, callee, cargs, st)
    CkTrmcStep  -> lower_trmc_step(x, callee, cargs, st)
    CkTrmcApply -> lower_trmc_apply(x, cargs, st)
    CkTcrec     -> lower_tcrec(x, callee, cargs, st)
    CkResume    -> lower_resume(x, cargs, st)
    # `__strip_unit(e)` is a compile-time unit erasure — identity at
    # runtime, so lower the inner expr directly (like `__perceus_borrow`).
    CkStripUnit -> lower_borrow_through(cargs, st)
    # `unit_name(e)` is COMPILE-TIME reflection (m12.8.x phase 2): the unit is
    # phantom (no runtime value carries it), so it CANNOT be a runtime call —
    # the C-direct oracle inlines the canonical unit symbol as a `kai_str`
    # literal read from the arg's `.ty` (emit_c's `unit_name` case). Without
    # this, the KIR fell `unit_name` to a direct call to `kaix_core_unit_name`
    # — a shim that has no unit to read → empty string, so `#{t}` over a
    # `Real<s>` dropped its ` s` suffix (the Show-for-Real<u> display).
    CkUnitName  -> lower_unit_name(cargs, st)
    # `__perceus_apply_borrow(f, args...)` (#1130) — a borrowing indirect
    # call: `f` is invoked WITHOUT being consumed. perceus rewrites a
    # `f(args)` through a `^`-borrowed function-typed param into this
    # sentinel; the closure ref stays with the caller (dropped after last
    # use), so no per-call KDup/KDrop of the closure. Lower `f` as the
    # closure value and the rest as owned call args → `KCallIndirectBorrow`.
    CkApplyBorrow -> lower_apply_borrow(x, cargs, st)
    # `__perceus_owned_borrow(g)` — an owned value in a borrowed slot whose
    # birth ref the caller drops after the call. The mark itself lowers
    # transparently to the inner value; the enclosing call site emits the
    # post-call KDrop (`ob_drop_after`).
    CkOwnedBorrow -> lower_borrow_through(cargs, st)
    CkCtor      -> lower_ctor_call(x, callee, cargs, st)
    # A bare callee that resolves to a top-level fn is a direct call; one
    # that does not is a LOCAL binder holding a function value (a param /
    # let-bound closure like `dec` in `dec(buf, pos)`) → call it through
    # `kaix_apply`. The same EFn-table test as `lower_var` (locals are
    # never in the table).
    CkDirect    -> lower_callee_dispatch(x, callee, cargs, st)
  }

# An effect op call `Eff.op(args)` → a `KPerform`. The dispatch (evidence
# lookup + clause call) is the backend's; `KPerform` carries the effect,
# op, and args, plus the non-local-discard semantics (asu review).
fn lower_perform(x: Expr, eff: String, op: String, cargs: [Expr], st: LowerSt) : LRes / Console =
  match lower_exprs(cargs, st, []) { LResMany(avs, st1) ->
    bind_op(st1, KPerform(eff, op, avs), kpos_of(x)) }

# --- Perceus RC marks → first-class KRC statements (§4.7) ---------------

pub type RCKind = KDupMk | KDropMk

fn lower_rc_unary(cargs: [Expr], kind: RCKind, st: LowerSt) : LRes / Console = match cargs {
  [a] -> match lower_expr(a, st) { LRes(v, st1) -> {
    let op = match kind { KDupMk -> KDup(v) KDropMk -> KDrop(v) }
    let st2 = ls_emit(st1, KRC(op, kpos_of(a)))
    # `__perceus_dup(x)` evaluates to `x`; drop evaluates to unit.
    match kind { KDupMk -> LRes(v, st2) KDropMk -> LRes(KUnitV, st2) }
  } }
  _ -> LRes(KUnitV, st)
}

# `__perceus_borrow(e)` reads `e` without an RC op — transparent.
fn lower_borrow_through(cargs: [Expr], st: LowerSt) : LRes / Console = match cargs {
  [a] -> lower_expr(a, st)
  _   -> LRes(KUnitV, st)
}

# `__perceus_apply_borrow(f, args...)` (#1130) — borrowing indirect call.
# The first arg is the closure value, invoked WITHOUT being consumed; the
# rest are the owned call arguments. Emits `KCallIndirectBorrow` (routed to
# `kaix_apply_borrow` on native / `kai_apply_borrow` on the C oracle).
fn lower_apply_borrow(x: Expr, cargs: [Expr], st: LowerSt) : LRes / Console = match cargs {
  [fe, ...rest] ->
    match lower_expr(fe, st) { LRes(fv, st1) ->
      match lower_exprs(rest, st1, []) {
        LResMany(avs, st2) -> bind_op(st2, KCallIndirectBorrow(fv, avs), kpos_of(x)) } }
  _ -> LRes(KUnitV, st)
}

# `unit_name(e)` — compile-time reflection on the dimensioned argument. Reads
# the canonical unit symbol from the arg's finalised `.ty` (`unit_name_of_ty`,
# the SAME extractor emit_c's `unit_name` case uses) and lowers to a constant
# `KStrV` literal — never a runtime call. A bare `Real` / unresolved unit-var
# yields the empty string (defensive, like the oracle), so user code that
# calls `unit_name` on an undimensioned value stays well-defined.
fn lower_unit_name(cargs: [Expr], st: LowerSt) : LRes / Console = match cargs {
  [a] -> LRes(KStrV(kir_quote(unit_name_of_ty(a.ty))), st)
  _   -> LRes(KUnitV, st)
}

# `__perceus_reuse_*(scr, rbld...)`: donor scrutinee + rebuild. The `callee`
# (`__perceus_reuse_{variant,cons,record}`) is the authoritative reuse-kind
# tag — perceus stamped it from the pattern shape — so each reuse routes to
# its own move-semantics runtime helper. The record form needs its rebuild's
# field NAMES, so it decodes the `ERecordLit` into a `KRecordReuse`; the
# variant/cons forms share the slot-init `KConReuse`. (The original native
# bug routed every reuse — record included — through the variant helper.)
fn lower_reuse(x: Expr, callee: String, cargs: [Expr], st: LowerSt) : LRes / Console = match cargs {
  [scr, ...rbld] ->
    # Under a live region the donor is never reused in place: the rebuild
    # bump-allocates a fresh cell in the arena (`KCon` carries `in_region`),
    # and the old donor dies wholesale with the arena — no `KConReuse`, no
    # per-node RC. The donor is a scrutinee alias (`__pcs_scr`), not an owned
    # ref, so it needs no lowering here; the match's exit drop reclaims it
    # (a no-op on the arena's immortal-rc cells).
    if st.in_region { lower_reuse_fresh(x, rbld, st) }
    else { match lower_expr(scr, st) { LRes(donor, st1) ->
      if callee == "__perceus_reuse_record" { lower_reuse_record(x, donor, rbld, st1) }
      else { lower_reuse_rebuild(x, reuse_kind_of(callee), donor, rbld, st1) } } }
  _ -> LRes(KUnitV, st)
}

fn reuse_kind_of(callee: String) : KReuseKind =
  if callee == "__perceus_reuse_cons" { RkCons } else { RkVariant }

# The region rebuild: lower the reconstruction expression as an ordinary ctor.
# `st.in_region` is live, so the `KCon`/cons/record it emits routes to the
# arena — a fresh bump-alloc, no donor reuse. The rebuild is always a single
# expression (a ctor call or a record literal), the same shape perceus wraps.
fn lower_reuse_fresh(x: Expr, rbld: [Expr], st: LowerSt) : LRes / Console = match rbld {
  [one] -> lower_expr(one, st)
  _     -> LRes(KUnitV, st)
}

# A single-element rebuild whose head is an `EVar`/`EModCall` constructor is
# a variant reuse; otherwise it is a cons reuse (`reuse_cons` passes
# head+tail directly). The `"Cons"` fallback only fires for the cons shape —
# perceus never emits a reuse over a non-ctor `ECall`, so the fallback's tag
# is correct for cons and unreachable for anything else (Linus review nit).
fn lower_reuse_rebuild(x: Expr, rk: KReuseKind, donor: KVal, rbld: [Expr], st: LowerSt) : LRes / Console = match rbld {
  [one] -> match one.kind {
    ECall(cf, cas) -> match cf.kind {
      EVar(cn)         -> lower_reuse_con(x, rk, donor, cn, cas, st)
      EModCall(_m, cn) -> lower_reuse_con(x, rk, donor, cn, cas, st)
      _ -> lower_reuse_con(x, rk, donor, "Cons", rbld, st)
    }
    _ -> lower_reuse_con(x, rk, donor, "Cons", rbld, st)
  }
  _ -> lower_reuse_con(x, rk, donor, "Cons", rbld, st)
}

# native variant reuse leak (#872). Two backend-distinct reuse shapes:
#
#  - FLAT (bijective) rebuild — every rebuild slot is a direct top-level kept
#    child or a scalar. `KConReuse` reuses the donor cell IN PLACE. A SHARED
#    donor fresh-allocs and keeps a borrowed reference to each kept child, which
#    the match-exit `kai_decref(donor)` cascade would free — so emit one
#    `kai_incref_if_shared(donor, child)` per embedded use (multiset). A unique
#    donor moves its children in place (no incref). This is half A of #872.
#
#  - NESTED (non-bijective) rebuild — a rebuild slot is a fresh sub-ctor that
#    embeds GRAND-children of a deconstructed inner cell (the rb-tree rotation
#    `Node(_, Node(Red, lx, ..), ..) -> Node(.., Node(.., lx, ..), ..)`). The C
#    oracle reuses BOTH the outer cell and the inner cell (Koka 2-of-3 token
#    reuse). Native mirrors it with a dual-branch fork
#    (`lower_reuse_nested_dual`) when the arm's slot plan is available
#    (`st.rnested`): the UNIQUE branch steals the inner cell's shell through
#    the outer's slot, settles the per-slot RC (kir_lower_reuse), donates the
#    token to the first same-arity sub-ctor and overwrites the outer in
#    place; the SHARED branch — and any arm whose pattern the plan does not
#    cover — keeps the fresh-alloc path (`lower_reuse_nested_fresh`): fresh
#    outer + one unconditional `dup` per embedded borrowed leaf (multiset),
#    the match-exit `kai_decref(donor)` cascade reclaiming donor + inner +
#    originals.
# The shared-donor incref of each kept child must precede `lower_exprs`: a
# rebuild arg that CONSUMES a kept child (`inc(l)`, `ins(l, ..)`) reuses it
# in place inside the call, so the incref has to land BEFORE the call runs —
# else the call mutates the donor's still-live child. Emitting it after the
# args (as the old `emit_reuse_gc_increfs(.., st1)` did) protected only
# children embedded by reference, not children threaded through a call. The
# nested-rotation path keeps its own ordering (the dup precedes nothing it
# consumes — `KCon` fresh-allocs).
fn lower_reuse_con(x: Expr, rk: KReuseKind, donor: KVal, cn: String, cargs: [Expr], st: LowerSt) : LRes / Console = {
  let nested = reuse_kind_is_variant(rk) and reuse_has_nested_ctor(cargs)
  if nested {
    match st.rnested {
      RNI(oarity, nslot, n_inner, directs, grands) ->
        # In-place overwrite requires the donor and rebuilt ctor to share an
        # arity; a mismatch keeps the fresh path (the shared branch would be
        # taken inside `kaix_variant_reuse_at` anyway, but the inner steal
        # must not run against a donor the rebuild cannot absorb).
        if list_length(cargs) == oarity {
          lower_reuse_nested_dual(x, donor, cn, cargs, nslot, n_inner, directs, grands, st)
        } else { lower_reuse_nested_fresh(x, cn, cargs, st) }
      RNInone -> lower_reuse_nested_fresh(x, cn, cargs, st)
    }
  } else if reuse_kind_is_variant(rk) {
    lower_reuse_flat_fork(x, donor, cn, cargs, st)
  } else {
    lower_reuse_dual(x, rk, donor, cn, cargs, st)
  }
}

# Flat variant reuse (no nested sub-ctor). The kept-binder increfs are
# unconditional (`kaix_incref_if_shared` — a no-op on a unique donor) and
# the args lower ONCE before the fork; the branches share the atoms, so
# nothing evaluates or dups twice. The fork exists only so the UNIQUE
# branch can take the exit-drop-neutralised MOVE (`RkVariantMove`, no
# survive-the-drop incref — the C oracle's `_r = _scr; _scr = NULL`); the
# SHARED branch fresh-allocs and leaves the donor for the match-exit
# cascade, exactly the old single-body shim's else path.
fn lower_reuse_flat_fork(x: Expr, donor: KVal, cn: String, cargs: [Expr], st: LowerSt) : LRes / Console =
  match ls_fresh_reg(st) { LSReg(rjoin, st0) -> {
    let pos = kpos_of(x)
    let st_gc = emit_reuse_gc_increfs(donor, reuse_gc_uses(cargs, st0.reuse_gc), pos, st0)
    match lower_exprs(cargs, st_gc, []) { LResMany(avs, st1) -> {
      let st_decl = ls_emit(st1, KLet(rjoin, SBoxed, KLitOp(KUnitV), pos))
      match bind_op(st_decl, KCall("kaix_check_unique", [donor]), pos) { LRes(uv, st_u) ->
        match three_labels(st_u) { LSL3(l_uniq, l_shared, l_join, st_l) -> {
          let st_fork = ls_seal(st_l, KCondBr(uv, l_uniq, l_shared, pos), l_uniq)
          let st_ub = match bind_op(st_fork, KConReuse(RkVariantMove, donor, cn, ls_variant_tag(st_fork, cn), typed_inits(avs, cn, st_fork)), pos) { LRes(ru, st_u2) ->
            ls_seal(ls_emit(reuse_neutralise_exit_drop(st_u2, pos), KStore(rjoin, ru, pos)), KBr(l_join, pos), l_shared) }
          let st_sb = match bind_op(st_ub, KCon(cn, ls_variant_tag(st_ub, cn), ls_ctor_mask(st_ub, cn), typed_inits(avs, cn, st_ub), st_ub.in_region), pos) { LRes(rs, st_s2) ->
            ls_seal(ls_emit(st_s2, KStore(rjoin, rs, pos)), KBr(l_join, pos), l_join) }
          LRes(KVar(rjoin), st_sb)
        } } }
    } }
  } }

# The fresh-alloc nested rebuild: fresh outer + one unconditional dup per
# embedded borrowed leaf; the match-exit `decref(donor)` reclaims
# donor + inner + originals. The shared branch of the dual fork below, and
# the whole rebuild for arms the slot plan does not cover.
fn lower_reuse_nested_fresh(x: Expr, cn: String, cargs: [Expr], st: LowerSt) : LRes / Console =
  # The first nested sub-ctor consumes the cross-call donor (inner stage
  # off — there is no stolen shell on the fresh path). The donor's
  # uniqueness is independent of this scrutinee's, so the shared branch
  # still absorbs the caller's shell — the C backend's shared-branch site.
  match lower_reuse_args_donate(cargs, "", 0, true, false, st, []) { LResDon(avs, _, st1) -> {
    let tag = ls_variant_tag(st1, cn)
    let st_dup = emit_reuse_leaf_dups(reuse_gc_uses(cargs, st1.reuse_gc), kpos_of(x), st1)
    bind_op(st_dup, KCon(cn, tag, ls_ctor_mask(st1, cn), typed_inits(avs, cn, st1), st1.in_region), kpos_of(x))
  } }

# Rebuild args + the lowered atoms, plus whether the inner token was donated.
type LResDon = LResDon([KVal], Bool, LowerSt)

# The dual-branch nested rotation reuse (mirrors emit_c's Koka 2-of-3 token
# reuse: outer `_scr` overwrite + `_ru_inner` donation). Arm binds are
# borrows, so the UNIQUE branch owns every old reference of the donated
# outer shell and — conditionally, via the steal — of the inner cell:
#   1. project the inner cell and steal its shell (`KTokenSteal`; null when
#      the inner is shared, after its non-recursive rc--);
#   2. settle the RC per slot plan (`rn_direct_acct` / `rn_grand_acct`) so
#      each embedded use owns exactly one reference;
#   3. lower the rebuild args, donating the token to the first same-arity
#      sub-ctor (`KConAt` rebuilds into the shell; a null token falls back
#      to a fresh alloc inside the runtime); an undonated token is freed;
#   4. overwrite the outer in place (`KConReuse` — its incref balances the
#      match-exit drop).
# The SHARED branch is the fresh path. Args are lowered TWICE (textual
# duplication, evaluated once — the branches are mutually exclusive),
# exactly like `lower_reuse_dual` below.
fn lower_reuse_nested_dual(x: Expr, donor: KVal, cn: String, cargs: [Expr],
                           nslot: Int, n_inner: Int, directs: [RNSlot], grands: [RNSlot],
                           st: LowerSt) : LRes / Console =
  match ls_fresh_reg(st) { LSReg(rjoin, st0) -> {
    let pos = kpos_of(x)
    let uses = reuse_gc_uses(cargs, st0.reuse_gc)
    let st_decl = ls_emit(st0, KLet(rjoin, SBoxed, KLitOp(KUnitV), pos))
    match bind_op(st_decl, KCall("kaix_check_unique", [donor]), pos) { LRes(uv, st_u) ->
      match three_labels(st_u) { LSL3(l_uniq, l_shared, l_join, st_l) -> {
        let st_fork = ls_seal(st_l, KCondBr(uv, l_uniq, l_shared, pos), l_uniq)
        # UNIQUE: steal the inner shell, settle RC, rebuild donating, overwrite.
        # A flat pattern (`nslot < 0`, the recolor-wrap shape) has no inner
        # cell — only the outer overwrite applies. The inner cell and token
        # are threaded as REGISTER NAMES (a fresh `KVar` per use), never one
        # KVal atom reused across helper calls — the stage1-built compiler
        # miscompiles that shape.
        let st_ub = if nslot < 0 {
          let st_a = rn_direct_acct(directs, donor, uses, pos, st_fork)
          # The recolor-wrap shape has no inner steal; the nested rebuild
          # cell consumes the cross-call donor instead (inner stage off).
          match lower_reuse_args_donate(cargs, "", 0, true, false, st_a, []) { LResDon(avs_u, _, st_d) ->
            match bind_op(st_d, KConReuse(RkVariantMove, donor, cn, ls_variant_tag(st_d, cn), typed_inits(avs_u, cn, st_d)), pos) { LRes(ru, st_u2) ->
              ls_seal(ls_emit(reuse_neutralise_exit_drop(st_u2, pos), KStore(rjoin, ru, pos)), KBr(l_join, pos), l_shared) } }
        } else { match ls_fresh_reg(st_fork) { LSReg(innerreg, st_r1) ->
          match ls_fresh_reg(st_r1) { LSReg(tokreg, st_r) -> {
          let st_i = ls_emit(st_r, KLet(innerreg, SBoxed, KProj(donor, nslot), pos))
          let st_t = ls_emit(st_i, KLet(tokreg, SBoxed, KTokenSteal(KVar(innerreg), n_inner), pos))
          let st_a = rn_grand_acct(grands, innerreg, tokreg, uses, pos,
                       rn_direct_acct(directs, donor, uses, pos, st_t))
          match lower_reuse_args_donate(cargs, tokreg, n_inner, false, false, st_a, []) {
            LResDon(avs_u, donated, st_d) -> {
              let st_f = if donated { st_d } else { ls_emit(st_d, KRC(KFreeToken(KVar(tokreg)), pos)) }
              match bind_op(st_f, KConReuse(RkVariantMove, donor, cn, ls_variant_tag(st_f, cn), typed_inits(avs_u, cn, st_f)), pos) { LRes(ru, st_u2) ->
                ls_seal(ls_emit(reuse_neutralise_exit_drop(st_u2, pos), KStore(rjoin, ru, pos)), KBr(l_join, pos), l_shared) }
            } }
        } } } }
        # SHARED: the fresh path, joined into `rjoin`.
        let st_sb = match lower_reuse_nested_fresh(x, cn, cargs, st_ub) { LRes(rs, st_s) ->
          ls_seal(ls_emit(st_s, KStore(rjoin, rs, pos)), KBr(l_join, pos), l_join) }
        LRes(KVar(rjoin), st_sb)
      } } }
  } }

# Lower the rebuild args, donating the inner token to the FIRST top-level
# sub-ctor whose arity matches the stolen shell (`RkTokenVariant`), and the
# fn's CROSS-CALL donor token to the NEXT sub-ctor (`RkDonorVariant` — the
# fresh cell the caller's donated shell pays for; degrades to a fresh alloc
# when no donor arrived). Exactly one consumer each; the caller frees an
# undonated inner token, the fn exit frees an unconsumed donor. `tokreg` is
# the inner token's register name (fresh `KVar` per use); `donated = true`
# at entry disables the inner stage (the fresh path, which has no stolen
# shell). Returns the INNER-donation flag only.
fn lower_reuse_args_donate(es: [Expr], tokreg: String, n_inner: Int, donated: Bool,
                           ddone: Bool, st: LowerSt, acc: [KVal]) : LResDon / Console = match es {
  [] -> LResDon(acc, donated, st)
  [e, ...rest] -> match donate_ctor_name(e, n_inner, donated) {
    Some(cn2) -> match e.kind {
      ECall(_, cas) -> match lower_exprs(cas, st, []) { LResMany(avs, st1) -> {
        let tokv = KVar(tokreg)
        match bind_op(st1, KConReuse(RkTokenVariant, tokv, cn2, ls_variant_tag(st1, cn2), typed_inits(avs, cn2, st1)), kpos_of(e)) { LRes(v, st2) ->
          lower_reuse_args_donate(rest, tokreg, n_inner, true, ddone, st2, list_append(acc, [v])) }
      } }
      # Unreachable (donate_ctor_name proved ECall); lower normally.
      _ -> match lower_expr(e, st) { LRes(v, st1) ->
        lower_reuse_args_donate(rest, tokreg, n_inner, donated, ddone, st1, list_append(acc, [v])) }
    }
    None -> match donor_ctor_name(e, donated and not ddone) {
      Some(cn3) -> match e.kind {
        ECall(_, cas) -> match lower_exprs(cas, st, []) { LResMany(avs, st1) ->
          match bind_op(st1, KConReuse(RkDonorVariant, KUnitV, cn3, ls_variant_tag(st1, cn3), typed_inits(avs, cn3, st1)), kpos_of(e)) { LRes(v, st2) ->
            lower_reuse_args_donate(rest, tokreg, n_inner, donated, true, st2, list_append(acc, [v])) } }
        _ -> match lower_expr(e, st) { LRes(v, st1) ->
          lower_reuse_args_donate(rest, tokreg, n_inner, donated, ddone, st1, list_append(acc, [v])) }
      }
      None -> match lower_expr(e, st) { LRes(v, st1) ->
        lower_reuse_args_donate(rest, tokreg, n_inner, donated, ddone, st1, list_append(acc, [v])) }
    }
  }
}

# The ctor name of a rebuild arg that can absorb the CROSS-CALL donor: any
# nested sub-ctor call, once the inner token has been placed (`ready`) and
# while the donor is unconsumed. No arity filter — the donor's arity is the
# caller's, checked at runtime by `kai_variant_at` (fresh alloc on
# mismatch), exactly the C backend's rewrite of the first remaining fresh
# cell.
fn donor_ctor_name(e: Expr, ready: Bool) : Option[String] =
  if not ready { None }
  else { match e.kind {
    ECall(cf, cas) ->
      if list_length(cas) > 0 {
        match cf.kind {
          EVar(c)        -> if kir_name_is_ctor(c) { Some(c) } else { None }
          EModCall(_, c) -> if kir_name_is_ctor(c) { Some(c) } else { None }
          _              -> None
        }
      } else { None }
    _ -> None
  } }

# The ctor name of a rebuild arg that can absorb the inner token: a direct
# ctor call of the stolen shell's arity, while the token is still available.
fn donate_ctor_name(e: Expr, n_inner: Int, donated: Bool) : Option[String] =
  if donated { None }
  else { match e.kind {
    ECall(cf, cas) ->
      if list_length(cas) == n_inner {
        match cf.kind {
          EVar(c)        -> if kir_name_is_ctor(c) { Some(c) } else { None }
          EModCall(_, c) -> if kir_name_is_ctor(c) { Some(c) } else { None }
          _              -> None
        }
      } else { None }
    _ -> None
  } }

# The genuine dual-branch reuse (mirrors emit_c's emit_match_arm_reuse_cons /
# _variant). The single-body `kai_reuse_or_alloc_*` shim cannot mirror C's
# per-branch binding mode: the UNIQUE branch binds the DIRECT scrutinee slots
# BORROW (no incref) and rebuilds in place (store RAW, no decref of the old
# slot — the borrow gave up no ownership), while the SHARED branch binds them
# OWNED (dup) and fresh-allocs. Borrow-no-incref and store-raw-no-decref are
# the two halves of one saving and must go together — mixing an owned bind
# with a raw store leaks, a borrow bind with a decref-store double-frees. The
# DECONSTRUCTED sub-binders were already dup'd unconditionally by the caller
# (they are incref'd in both branches, per the oracle's is_alias path), so the
# fork manages only the direct slots (`st.reuse_gc`). The body's rebuild args
# are lowered TWICE (textual duplication, evaluated once — the branches are
# mutually exclusive), exactly as C interpolates h_new_c/t_new_c in both arms.
fn lower_reuse_dual(x: Expr, rk: KReuseKind, donor: KVal, cn: String, cargs: [Expr], st: LowerSt) : LRes / Console =
  match ls_fresh_reg(st) { LSReg(rjoin, st0) -> {
    let pos = kpos_of(x)
    let st_decl = ls_emit(st0, KLet(rjoin, SBoxed, KLitOp(KUnitV), pos))
    match bind_op(st_decl, KCall("kaix_check_unique", [donor]), pos) { LRes(uv, st_u) ->
      match three_labels(st_u) { LSL3(l_uniq, l_shared, l_join, st_l) -> {
        let st_fork = ls_seal(st_l, KCondBr(uv, l_uniq, l_shared, pos), l_uniq)
        # UNIQUE: direct slots stay borrows (no dup); rebuild; reuse in place.
        let st_ub = match lower_exprs(cargs, st_fork, []) { LResMany(avs_u, st_u1) -> {
          let tag_u = ls_variant_tag(st_u1, cn)
          match bind_op(st_u1, KConReuse(rk, donor, cn, tag_u, typed_inits(avs_u, cn, st_u1)), pos) { LRes(ru, st_u2) ->
            ls_seal(ls_emit(st_u2, KStore(rjoin, ru, pos)), KBr(l_join, pos), l_shared) } } }
        # SHARED: dup the direct slots (owned), rebuild, fresh-alloc. A cons
        # rebuild allocates a real KAI_CONS cell (`kai_cons`) — `Cons` is the
        # builtin list ctor, not a registered variant, so a `KCon` here would
        # build a variant-shaped cell whose `as.cons` reads are garbage.
        let st_sd = emit_direct_dups(st.reuse_gc, pos, st_ub)
        let st_sb = match lower_exprs(cargs, st_sd, []) { LResMany(avs_s, st_s1) ->
          match bind_op(st_s1, reuse_fresh_op(rk, cn, avs_s, st_s1), pos) { LRes(rs, st_s2) ->
            ls_seal(ls_emit(st_s2, KStore(rjoin, rs, pos)), KBr(l_join, pos), l_join) } }
        LRes(KVar(rjoin), st_sb)
      } } }
  } }

# Neutralise the enclosing match's exit drop after a UNIQUE-branch in-place
# move: the rewritten cell IS the result (`RkVariantMove` returns it at
# rc==1, no survive-the-drop incref), so rebind the exit-drop register to
# unit — the C oracle's `_r = _scr; _scr = NULL`. The shared branch leaves
# the register live, and a borrowed match (`mscr` empty) emits nothing.
fn reuse_neutralise_exit_drop(st: LowerSt, pos: KPos) : LowerSt =
  if st.mscr == "" { st } else { ls_emit(st, KStore(st.mscr, KUnitV, pos)) }

# The shared branch's fresh allocation: a real cons cell for a cons rebuild
# (`Cons` is the builtin list ctor, not a registered variant), a variant
# ctor otherwise.
fn reuse_fresh_op(rk: KReuseKind, cn: String, avs: [KVal], st: LowerSt) : KOp = match rk {
  RkCons    -> KPrim("kai_cons", avs)
  RkVariant -> KCon(cn, ls_variant_tag(st, cn), ls_ctor_mask(st, cn), typed_inits(avs, cn, st), st.in_region)
  # A token/donor/move rebuild never forks (kai_variant_at handles its own
  # null case; the move is minted inside the unique branch only).
  RkTokenVariant -> KCon(cn, ls_variant_tag(st, cn), ls_ctor_mask(st, cn), typed_inits(avs, cn, st), st.in_region)
  RkDonorVariant -> KCon(cn, ls_variant_tag(st, cn), ls_ctor_mask(st, cn), typed_inits(avs, cn, st), st.in_region)
  RkVariantMove  -> KCon(cn, ls_variant_tag(st, cn), ls_ctor_mask(st, cn), typed_inits(avs, cn, st), st.in_region)
}

# Dup each direct scrutinee slot (head `PBind` / `...rest`) for the shared
# branch, resolving through any active shadow like `emit_reuse_gc_increfs`.
fn emit_direct_dups(directs: [String], pos: KPos, st: LowerSt) : LowerSt = match directs {
  []           -> st
  [n, ...rest] -> {
    let reg = match ls_lookup_rename(st, n) { Some(r) -> r None -> n }
    emit_direct_dups(rest, pos, ls_emit(st, KRC(KDup(KVar(reg)), pos)))
  }
}

fn reuse_kind_is_variant(rk: KReuseKind) : Bool = match rk { RkVariant -> true RkCons -> false RkTokenVariant -> false RkDonorVariant -> false RkVariantMove -> true }

# True iff any rebuild arg is a nested ctor call (the non-bijective rotation
# shape). Such a rebuild embeds grand-children of a deconstructed inner cell.
fn reuse_has_nested_ctor(cargs: [Expr]) : Bool = match cargs {
  []           -> false
  [e, ...rest] -> if expr_is_ctor_call(e) { true } else { reuse_has_nested_ctor(rest) }
}

fn expr_is_ctor_call(e: Expr) : Bool = match e.kind {
  ECall(cf, _) -> match cf.kind {
    EVar(c)        -> kir_name_is_ctor(c)
    EModCall(_, c) -> kir_name_is_ctor(c)
    _              -> false
  }
  _ -> false
}

# Emit one `KIncrefIfShared(donor, KVar(name))` per name in `uses` (a multiset:
# a binder embedded twice appears twice). Order vs the reuse op is irrelevant —
# nothing mutates the donor between, so each helper's `check_unique` agrees with
# the reuse op's own (asu sign-off). Names only, never the donor itself.
fn emit_reuse_gc_increfs(donor: KVal, uses: [String], pos: KPos, st: LowerSt) : LowerSt = match uses {
  []           -> st
  [n, ...rest] -> {
    # Resolve the binder to its active shadow register, mirroring `lower_var`,
    # so a shadowed kept child increfs the register the rebuild actually read.
    let reg = match ls_lookup_rename(st, n) { Some(r) -> r None -> n }
    emit_reuse_gc_increfs(donor, rest, pos,
      ls_emit(st, KRC(KIncrefIfShared(donor, KVar(reg)), pos)))
  }
}

# Unconditional `dup` per embedded borrowed leaf for the FRESH-alloc nested path
# (multiset). The whole outer is fresh-allocated, so each embedded scrutinee
# child needs its own ref; the match-exit `kai_decref(donor)` cascade then frees
# the donor + inner + the original child refs, leaving the dup as the result's.
fn emit_reuse_leaf_dups(uses: [String], pos: KPos, st: LowerSt) : LowerSt = match uses {
  []           -> st
  [n, ...rest] -> {
    let reg = match ls_lookup_rename(st, n) { Some(r) -> r None -> n }
    emit_reuse_leaf_dups(rest, pos, ls_emit(st, KRC(KDup(KVar(reg)), pos)))
  }
}

# The multiset of scrutinee pointer-binder USES the rebuild args reach —
# EVERY occurrence, whatever shape carries it (a call arg, a nested ctor,
# a match scrutinee, an if branch, a block tail). A kept child used
# anywhere still needs the shared-donor incref: when the donor is shared,
# the reuse fresh-allocs the rebuild but the donor keeps its own reference
# to the child, and the use would consume / reuse-in-place that
# still-aliased child. A use this walk misses is a child freed while the
# shared donor's slot still points at it — the donor's later cascade then
# frees or reads freed memory. `KIncrefIfShared` is conditional, so a
# unique donor pays nothing and the use MOVEs the child as before.
# `pcs_collect_uses_expr` (scoped to the binder names) is the same
# full-coverage walker perceus's own dup discipline runs on.
fn reuse_gc_uses(cargs: [Expr], gc: [String]) : [String] / Console = match gc {
  [] -> []
  _  -> reuse_gc_uses_exprs(cargs, gc, [])
}

fn reuse_gc_uses_exprs(es: [Expr], gc: [String], acc: [String]) : [String] / Console = match es {
  []           -> acc
  [e, ...rest] -> reuse_gc_uses_exprs(rest, gc,
                    reuse_gc_use_names(pcs_collect_uses_expr(e, gc, false, []), gc, acc))
}

# The collector grows its scope with lambda params, so it returns their
# uses too — keep only the names that are actually donor binders.
fn reuse_gc_use_names(us: [Use], gc: [String], acc: [String]) : [String] = match us {
  []           -> acc
  [u, ...rest] -> match u {
    U(nm, _, _, _) ->
      if name_in_list(gc, nm) { reuse_gc_use_names(rest, gc, [nm, ...acc]) }
      else { reuse_gc_use_names(rest, gc, acc) }
  }
}

# The record-reuse rebuild is an `ERecordLit` (perceus wraps it directly);
# decode its (name, value) field inits into a `KRecordReuse` so the backend
# donates the unique scrutinee cell via `kaix_reuse_or_alloc_record` (which
# carries the parallel name array `kai_record` needs). A malformed rebuild
# (not an `ERecordLit`) cannot arise — perceus only wraps record literals —
# so fall back to unit defensively.
fn lower_reuse_record(x: Expr, donor: KVal, rbld: [Expr], st: LowerSt) : LRes / Console = match rbld {
  [one] -> match one.kind {
    ERecordLit(_, fis) -> match lower_field_inits(fis, st, []) { RecPlan(pairs, st1) ->
      bind_op(st1, KRecordReuse(donor, pairs), kpos_of(x)) }
    _ -> LRes(KUnitV, st)
  }
  _ -> LRes(KUnitV, st)
}

# --- Constructors / direct calls ---------------------------------------

# Lower a ctor call, each arg AT ITS SLOT: a kind-1 Int slot lowers its arg RAW
# (`lower_expr_raw_at SInt64` — no trailing `int.box`, so a raw `k` flows
# straight into the `.i64` word instead of `int.box(k)` then unbox), everything
# else boxed. Mirror of `lower_tcrec_args` for the ctor-arg ABI: the slot init
# `SIInt64`/`SIBoxed` matches the arg's lowered repr, so the emitter never
# re-boxes a raw scalar just to store it raw again (the rb-tree hot-path box).
fn lower_ctor_call(x: Expr, name: String, cargs: [Expr], st: LowerSt) : LRes / Console = {
  let tys = match evar_payload_tys(st.vs, name) { Some(t) -> t None -> [] }
  match lower_ctor_args(cargs, name, tys, st, []) { LCtorInits(inits, st1) ->
    bind_op(st1, KCon(name, ls_variant_tag(st1, name), ls_ctor_mask(st1, name), inits, st1.in_region), kpos_of(x)) }
}

# Per-slot ctor-arg lowering result: the slot inits + threaded state.
type LCtorInits = LCtorInits([KSlotInit], LowerSt)

fn lower_ctor_args(cargs: [Expr], name: String, tys: [TypeExpr], st: LowerSt, acc: [KSlotInit]) : LCtorInits / Console =
  match cargs {
    [] -> LCtorInits(acc, st)
    [e, ...rest] -> {
      let trest = match tys {
        [_, ...r] -> r
        [] -> []
      }
      let k = lower_ctor_slot_kind(st, name, tys)
      # A user-ctor kind-1 Int slot lowers RAW; a kind-2 Real / kind-3 enum
      # slot lowers boxed but is WRAPPED at its kind so the emitter stores the
      # raw f64 bits / immediate tag word; builtins + boxed slots stay boxed.
      if k == 1 {
        match lower_expr_raw_at(e, SInt64, st) { LRes(v, st1) ->
          lower_ctor_args(rest, name, trest, st1, list_append(acc, [SIInt64(v)])) }
      } else if k == 2 {
        match lower_expr(e, st) { LRes(v, st1) ->
          lower_ctor_args(rest, name, trest, st1, list_append(acc, [SIReal(v)])) }
      } else if k == 3 {
        # Literal-ctor peephole (the C `{.i64 = tag}` mirror): a bare nullary
        # user-ctor arg (`Red`) contributes its tag as an immediate — no
        # singleton load + tag re-read. Anything else lowers boxed and the
        # emitter takes the tag at the border (`kaix_take_enum`).
        match lower_enum_slot_arg(e, st) { LRes(v, st1) ->
          lower_ctor_args(rest, name, trest, st1, list_append(acc, [SIEnum(v)])) }
      } else {
        match lower_expr(e, st) { LRes(v, st1) ->
          lower_ctor_args(rest, name, trest, st1, list_append(acc, [SIBoxed(v)])) }
      }
    }
  }

# The slot kind of the head slot of `tys` for a USER ctor; builtins classify
# 0 (boxed — the runtime owns their slot layout). Same resolver as
# `slot_kind_of` / `ls_ctor_mask` (`variant_slot_kind` over `st.enums`).
fn lower_ctor_slot_kind(st: LowerSt, name: String, tys: [TypeExpr]) : Int =
  if evar_find_tag(st.vs, name) < user_variant_tag_base() { 0 }
  else { match tys {
    [t, ..._] -> variant_slot_kind(t, st.enums)
    []        -> 0
  } }

# An enum-slot ctor arg. A bare `EVar` naming a NULLARY user ctor (not
# shadowed by a local) lowers to its tag immediate (`KIntV`); everything else
# lowers boxed (the emitter's `kaix_take_enum` reads whatever tag it carries).
fn lower_enum_slot_arg(e: Expr, st: LowerSt) : LRes / Console = match e.kind {
  EVar(nm) ->
    if not ls_is_local(st, nm) and kir_name_is_ctor(nm) {
      match evar_find(st.vs, nm) {
        Some(ar) ->
          if ar == 0 {
            let tag = evar_find_tag(st.vs, nm)
            if tag >= user_variant_tag_base() { LRes(KIntV(tag), st) }
            else { lower_expr(e, st) }
          } else { lower_expr(e, st) }
        None -> lower_expr(e, st)
      }
    } else { lower_expr(e, st) }
  _ -> lower_expr(e, st)
}

# `sym` is the already-resolved mangled symbol. Resolve the callee's UFnSig
# once: it drives BOTH ends of the P3 raw-scalar ABI at this call site.
#
# ARGS — lower each at the callee's PARAM slot (`lower_tcrec_args`, shared
# with the self-tail-call back-edge): a raw param gets its arg lowered RAW
# (`fib(n-1)` passes the `i64` directly, no `int.box` → `kaix_int_field`
# round-trip at the callee boundary), a boxed param keeps the boxed atom.
# Without this the args round-tripped (`int.box(n-1)` then the callee's
# `nemit_raw_args` unbox-borrowed back) — the other half of the residual.
#
# RESULT — bind at the callee's RETURN slot, not the unconditional `SBoxed`
# of `bind_op`: a raw-return UFn lands its `i64` in a raw register, so a
# consuming `i+` reads it directly (`nemit_load_reg_as_int`) and a boxed use
# boxes once at the border (`nemit_load_reg_boxed` → `kaix_int`, the oracle's
# `box_wrap`). A non-raw callee (FFI wrapper, effectful / generic / proto fn
# → `None` sig) lowers args + result exactly as before (all boxed).
#
# RC: a raw `i64`/`f64`/`i1` carries NO refcount. Perceus already skips a raw
# arg / result — the unbox pass marks them `MUnboxed`, so neither the raw
# args nor the raw result register attract a KDup/KDrop. The raw slots here
# only change the repr, never the RC plan.
fn lower_direct_call(x: Expr, sym: String, cargs: [Expr], st: LowerSt) : LRes / Console = {
  let sig = lookup_ufn_by_csym(st.fns, sym)
  match lower_tcrec_args(cargs, sig, st) { LResMany(avs, st1) ->
    ob_drop_after(bind_op_slot(st1, KCall(sym, avs), ret_slot_of_sig(sig), kpos_of(x)),
                  cargs, avs, kpos_of(x)) }
}

# A `__perceus_owned_borrow`-marked arg lowered to its inner value: the
# callee borrows it and no binder holds it, so the caller releases the
# birth ref right after the call (the C oracle's statement-expression
# decref). The drop must follow the call op — before it is a UAF.
fn ob_is_marked(a: Expr) : Bool = match a.kind {
  ECall(callee, _) -> match callee.kind {
    EVar(nm) -> nm == "__perceus_owned_borrow"
    _        -> false
  }
  _ -> false
}

fn ob_drop_after(r: LRes, cargs: [Expr], avs: [KVal], pos: KPos) : LRes = match r {
  LRes(v, st) -> LRes(v, ob_drop_go(st, cargs, avs, pos))
}

fn ob_drop_go(st: LowerSt, cargs: [Expr], avs: [KVal], pos: KPos) : LowerSt = match cargs {
  []           -> st
  [c, ...crest] -> match avs {
    []           -> st
    [v, ...vrest] -> {
      let st1 = if ob_is_marked(c) { ls_emit(st, KRC(KDrop(v), pos)) } else { st }
      ob_drop_go(st1, crest, vrest, pos)
    }
  }
}

# Route a bare-name call: a top-level fn or a core builtin is a direct
# `KCall`; anything else is a local binder holding a function value, so
# call it indirectly through `KCallIndirect` (a `kaix_apply`).
# A LOCAL binder used as a callee (`let f = ...; f(x)`, a param `f(...)`)
# is an indirect `kaix_apply`, even when its name collides with a
# top-level fn — the local shadows the global (#748/#749). Checked before
# `callee_is_direct` so the shadow is honoured (same rule as `lower_var`).
fn lower_callee_dispatch(x: Expr, callee: String, cargs: [Expr], st: LowerSt) : LRes / Console =
  if not ls_is_local(st, callee) and callee_is_direct(st, callee) {
    lower_direct_call(x, c_sym_of_callee_st(st, callee), cargs, st)
  } else {
    match lower_exprs(cargs, st, []) { LResMany(avs, st1) ->
      ob_drop_after(bind_op(st1, KCallIndirect(KVar(callee), avs), kpos_of(x)),
                    cargs, avs, kpos_of(x)) }
  }

# --- Resume / sentinels → typed terminators ----------------------------

# `resume(v)` lowers to an EXPRESSION-call (`bind_op`), NOT a terminator —
# the block stays OPEN so a non-tail resume (`let _ = resume(()) resume(())`)
# materialises the SECOND call in the same block; the runtime's one-shot
# check then fires on it (the m7a #6d native gap). The block's `KRet` is
# supplied by the clause's `ls_finish` close, exactly as the C-direct oracle
# lets the C function's normal return sequence the resume call. The op result
# is the resume value (usable by a deep handler's `let x = resume(v)`).
fn lower_resume(x: Expr, cargs: [Expr], st: LowerSt) : LRes / Console = match cargs {
  [a] -> match lower_expr(a, st) { LRes(av, st1) ->
    bind_op(st1, KResumeOp(KVar("k"), av), kpos_of(x)) }
  [a, s] -> match lower_expr(a, st) { LRes(av, st1) -> match lower_expr(s, st1) {
    LRes(sv, st2) -> bind_op(st2, KResume2Op(KVar("k"), av, sv), kpos_of(x)) } }
  _ -> LRes(KUnitV, st)
}

# `__kai_tcrec|<sym>|<dropmask>|<p0>|...` → KTcrecGoto (seals the block).
# Invariant (Linus review #2): `tcrec_rewrite_decls` plants the call args
# in the SAME order as the loop params `p0..pN`, so the ordinal index from
# `assigns_of(avs, 0, …)` IS the slot index — the pipe's `_pnames` are
# redundant here and deliberately unused. If that producer ever reorders,
# this assumption breaks silently; the dropmask is a bitfield over the same
# p0..pN ordering, so the two must stay aligned.
fn lower_tcrec(x: Expr, callee: String, cargs: [Expr], st: LowerSt) : LRes / Console =
  match es_tcrec_split_pipe(callee) {
    [_, sym, dropmask_str, ..._pnames] -> match lower_tcrec_args(cargs, lookup_ufn_by_csym(st.fns, sym), st) {
      LResMany(avs, st1) ->
        # The goto leaves every enclosing match block, skipping their
        # continuation scrutinee drops and this path's unconsumed binder
        # dups — release the pending ledger entries before the back-edge.
        seal_tail(tcp_goto_drops(cargs, st1),
                  KTcrecGoto(cat3("_kai_", sym, "_entry"), assigns_of(avs, 0, []),
                             es_tcrec_parse_decimal(dropmask_str), kpos_of(x)))
    }
    _ -> LRes(KUnitV, st)
  }

# `__kai_trmc|<sym>|<holeslot>|<cname>|<dropmask>|<p0>|...` → KTrmcStep.
# Same ordinal-index invariant as `lower_tcrec` (Linus review #2): `_pnames`
# are unused; cargs order == slot order, guaranteed by the rewrite producer.
#
# CRITICAL — the self-call is the back-edge, NEVER a value (mirror the C
# oracle `emit_trmc_cons_step`/`emit_trmc_variant_step`). The ctor-args are
# `[..non-hole.., self_call, ..non-hole..]` with the self-call `ECall(_, sa)`
# at index `hole_slot`. Lowering ALL cargs (the old bug) emits the recursion
# `t = sym(t)` into the KIR, defeating TRMC. Instead:
#   - the NON-hole args (the real head value(s)) lower as values → `head_vals`;
#     the backend builds the cell from them with NULL at the hole slot.
#   - the hole-slot arg's `ECall(_, sa)` args lower → loop-param rebinds
#     (`assigns`), exactly as `lower_tcrec` does for an ordinary self-tail-call.
# The dropmask threads identically to `KTcrecGoto` (it reconciles the
# exit-drops the goto skips); the hole-slot arg is never materialised, so it
# carries no ref to drop.
fn lower_trmc_step(x: Expr, callee: String, cargs: [Expr], st: LowerSt) : LRes / Console =
  match es_tcrec_split_pipe(callee) {
    [_, sym, hole_str, cname, dropmask_str, ..._pnames] -> {
      let hole = es_tcrec_parse_decimal(hole_str)
      # Lower the non-hole ctor args (head value(s)) left-to-right, then the
      # self-call's args (the rebinds) — preserving evaluation order.
      match lower_exprs(trmc_drop_nth(cargs, hole, 0, []), st, []) {
        LResMany(heads, st1) ->
          lower_trmc_seal(x, sym, hole, cname, es_tcrec_parse_decimal(dropmask_str),
                          heads, trmc_self_args(cargs, hole), st1)
      }
    }
    _ -> LRes(KUnitV, st)
  }

# Lower the self-call's args into the loop-param rebinds and seal the step.
# Split out of `lower_trmc_step` so the head/rebind lowerings sit at one
# nesting level each (the back-edge mirrors `lower_tcrec`'s `KTcrecGoto`).
fn lower_trmc_seal(x: Expr, sym: String, hole: Int, cname: String, dropmask: Int,
                   heads: [KVal], self_args: [Expr], st: LowerSt) : LRes / Console =
  # P3: lower the rebinds at the recursing fn's param slots (raw for a raw
  # param), so the TRMC back-edge re-stores them raw — no per-step
  # `kaix_int` re-box. Same `lower_tcrec_args` the `KTcrecGoto` path uses.
  match lower_tcrec_args(self_args, lookup_ufn_by_csym(st.fns, sym), st) {
    LResMany(reb, st1) -> {
      # The variant ctor tag is resolved here (as `KCon` resolves it), so the
      # backend builds the spine cell without a name→tag table. The builtin-
      # cons spine (`__kai_cons` / `__kai_cons_s`) is not a registered variant
      # → tag -1 (its backend path is cons-specific and ignores the tag).
      let tag = if trmc_cname_is_cons(cname) { 0 - 1 } else { ls_variant_tag(st1, cname) }
      # The full slot mask of the spine ctor (0 for the builtin cons spine),
      # so the native step lays each slot at its kind like KCon/KConReuse do —
      # the same `ls_ctor_mask` (`variant_slot_mask`) the fresh route reads.
      let slot_mask = if trmc_cname_is_cons(cname) { 0 } else { ls_ctor_mask(st1, cname) }
      # The `__kai_cons_s` reuse-cons step drops the consumed scrutinee; its
      # register is THIS match's fresh `<join>$sd` (st.mscr), not the old fixed
      # `__pcs_scr_drop` literal (which aliased nested matches in the native
      # flat table). `__kai_cons` (no `_s`) has nothing to free → "".
      seal_tail(st1, KTrmcStep(cat3("_kai_", sym, "_entry"), hole, cname, tag, slot_mask, dropmask,
                               heads, assigns_of(reb, 0, []), st1.mscr, st1.in_region, kpos_of(x)))
    }
  }

fn trmc_cname_is_cons(cname: String) : Bool =
  cname == "__kai_cons" or cname == "__kai_cons_s"

# The ctor args minus the hole slot, in slot order — the real head value(s)
# the backend uses to build the spine cell (NULL plugged at the hole).
fn trmc_drop_nth(xs: [Expr], hole: Int, i: Int, acc: [Expr]) : [Expr] = match xs {
  [] -> acc
  [a, ...rest] ->
    if i == hole { trmc_drop_nth(rest, hole, i + 1, acc) }
    else         { trmc_drop_nth(rest, hole, i + 1, list_append(acc, [a])) }
}

# The self-call's arguments, read from the hole-slot ctor arg. The producer
# always plants `ECall(EVar(sym), self_args)` there; any other shape (or an
# out-of-range hole) yields no rebinds, matching the C oracle's `_ -> []`.
fn trmc_self_args(xs: [Expr], hole: Int) : [Expr] = match xs {
  [] -> []
  [a, ...rest] ->
    if hole == 0 { match a.kind { ECall(_, sa) -> sa _ -> [] } }
    else         { trmc_self_args(rest, hole - 1) }
}

# `__kai_trmc_apply(leaf)` → KTrmcApply (plug leaf into the open hole).
#
# A `KTrmcApply` is a terminal RET — it does NOT flow to the match's L0
# continuation where `match_finish` plants the owned-scrutinee exit drop. When
# the leaf is a variant CON-REUSE of the scrutinee (`Node(Red, ins(l,..),..)` —
# reuse-in-place increfs the donor to survive that exit drop), skipping the drop
# leaves the reused cell with an inflated rc → one leaked node per recursion
# level (#872). Emit the scrutinee drop here, before the terminal, mirroring the
# token free in `nemit_trmc_apply`. Gated on a reuse-of-scrutinee leaf so a cons
# spine (`map`/`filter`, whose scrutinee the step already dropped) is untouched.
fn lower_trmc_apply(x: Expr, cargs: [Expr], st: LowerSt) : LRes / Console = match cargs {
  [leaf] -> match lower_expr(leaf, st) { LRes(lv, st1) -> {
    let st2 = if st1.mscr == "" or not trmc_apply_leaf_reuses_scr(leaf) { st1 }
              else { ls_emit(st1, KRC(KDrop(KVar(st1.mscr)), kpos_of(x))) }
    seal_tail(st2, KTrmcApply(lv, kpos_of(x))) } }
  _ -> LRes(KUnitV, st)
}

# True iff the trmc-apply leaf is a variant con-reuse of the match scrutinee
# (`__perceus_reuse_variant(scr, ..)`) — the shape that increfs the donor and so
# needs the exit drop the terminal RET skips.
fn trmc_apply_leaf_reuses_scr(leaf: Expr) : Bool = match leaf.kind {
  ECall(cf, _) -> match cf.kind { EVar(nm) -> nm == "__perceus_reuse_variant" _ -> false }
  _            -> false
}
