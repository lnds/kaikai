  }
}

fn si_after_tps(buf: String, pos: Int, nm: String, tps: [String]) : Option[CacheSIPos] {
  match cache_hex_to_var_list(buf, pos) {
    None -> None
    Some(c) -> match c { CVarLP(vs, p) -> si_after_vars(buf, p, nm, tps, vs) }
  }
}

fn si_after_vars(buf: String, pos: Int, nm: String, tps: [String],
                  vs: [Variant]) : Option[CacheSIPos] {
  match cache_hex_to_opt_string(buf, pos) {
    None -> None
    Some(c) -> match c { COSP(mo, p) -> Some(CSIP(SI(nm, tps, vs, mo), p)) }
  }
}

#[doc("Decode a `[SumInfo]` payload chunk at `pos`.")]
pub fn cache_hex_to_suminfo_list(buf: String, pos: Int) : Option[CacheSILPos] {
  match cache_hex_to_u32(buf, pos) {
    None -> None
    Some(c) -> match c { CIP(n, p2) -> di_collect_si(buf, p2, n, []) }
