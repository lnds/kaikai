#[doc("""
Round-trip serde for a whole `ModuleEnvDelta` and for the
`TypecheckedModule` a per-module cache hit restores.

`compiler.cache_delta` renders a delta *canonically*, for the interface
hash. This module renders it *faithfully*: original var ids, original
table order, so a restored delta seeds an importer's typer env exactly
as the fresh one would. The two treatments are deliberately separate —
canonicalization proves interface identity, fidelity proves the restored
artifact emits the same C.

Wire conventions follow `compiler.cache`: lists emit `u32 length + each
element`, records emit fields in declaration order.
""")]

import compiler.ast
import compiler.cache
import compiler.cache_ast
import compiler.infer
import compiler.cache_delta
import compiler.cache_typed

pub type CacheMDPos  = CMDP(ModuleEnvDelta, Int)
pub type CacheTCMPos = CTCMP(TypecheckedModule, Int)

pub type CacheUIPos   = CUIP(UnionInfo, Int)
pub type CacheUILPos  = CUILP([UnionInfo], Int)
pub type CacheOEAPos  = COEAP(OpEffArity, Int)
pub type CacheOEALPos = COEALP([OpEffArity], Int)
pub type CacheRIPos2  = CRIP2(RecInfo, Int)
pub type CacheRILPos2 = CRILP2([RecInfo], Int)
pub type CacheSIPos   = CSIP(SumInfo, Int)
pub type CacheSILPos  = CSILP([SumInfo], Int)
pub type CacheOTEPos  = COTEP(OpToEff, Int)
pub type CacheOTELPos = COTELP([OpToEff], Int)
pub type CacheUAEPos  = CUAEP(UAliasEntry, Int)
pub type CacheUAELPos = CUAELP([UAliasEntry], Int)
pub type CacheCEPos   = CCEP(CtorEntry, Int)
pub type CacheCELPos  = CCELP([CtorEntry], Int)

fn di_len_prefixed(chunks: [String]) : String =
  concat_all([cache_u32_to_hex(list_length(chunks)), concat_all(chunks)])

# ---- UnionInfo --------------------------------------------------------

fn cache_hex_to_unioninfo(buf: String, pos: Int) : Option[CacheUIPos] {
  match cache_hex_to_string(buf, pos) {
    None -> None
    Some(c) -> match c { CSP(nm, p) -> ui_after_name(buf, p, nm) }
  }
}

fn ui_after_name(buf: String, pos: Int, nm: String) : Option[CacheUIPos] {
  match cache_hex_to_tyr_list(buf, pos) {
    None -> None
    Some(c) -> match c { CTyRLP(tys, p) -> ui_after_tys(buf, p, nm, tys) }
  }
}

fn ui_after_tys(buf: String, pos: Int, nm: String, tys: [Ty]) : Option[CacheUIPos] {
  match cache_hex_to_int(buf, pos) {
    None -> None
    Some(c) -> match c { CIP(l, p) -> ui_after_line(buf, p, nm, tys, l) }
  }
}

fn ui_after_line(buf: String, pos: Int, nm: String, tys: [Ty],
                  l: Int) : Option[CacheUIPos] {
  match cache_hex_to_int(buf, pos) {
    None -> None
    Some(c) -> match c { CIP(col, p) -> Some(CUIP(UI(nm, tys, l, col), p)) }
  }
}

#[doc("Decode a `[UnionInfo]` payload chunk at `pos`.")]
pub fn cache_hex_to_unioninfo_list(buf: String, pos: Int) : Option[CacheUILPos] {
  match cache_hex_to_u32(buf, pos) {
    None -> None
    Some(c) -> match c { CIP(n, p2) -> di_collect_ui(buf, p2, n, []) }
  }
}

fn di_collect_ui(buf: String, pos: Int, remaining: Int,
                  acc: [UnionInfo]) : Option[CacheUILPos] {
  if remaining <= 0 { Some(CUILP(list_reverse(acc), pos)) }
  else {
    match cache_hex_to_unioninfo(buf, pos) {
      None -> None
      Some(c) -> match c { CUIP(u, p2) ->
        di_collect_ui(buf, p2, remaining - 1, [u, ...acc]) }
    }
  }
}

# ---- OpEffArity -------------------------------------------------------

fn cache_hex_to_opeffarity(buf: String, pos: Int) : Option[CacheOEAPos] {
  match cache_hex_to_string(buf, pos) {
    None -> None
    Some(c) -> match c { CSP(nm, p) -> match cache_hex_to_int(buf, p) {
      None -> None
      Some(c2) -> match c2 { CIP(n, p2) -> Some(COEAP(OEA(nm, n), p2)) }
    } }
  }
}

#[doc("Decode an `[OpEffArity]` payload chunk at `pos`.")]
pub fn cache_hex_to_opeffarity_list(buf: String, pos: Int) : Option[CacheOEALPos] {
  match cache_hex_to_u32(buf, pos) {
    None -> None
    Some(c) -> match c { CIP(n, p2) -> di_collect_oea(buf, p2, n, []) }
  }
}

fn di_collect_oea(buf: String, pos: Int, remaining: Int,
                   acc: [OpEffArity]) : Option[CacheOEALPos] {
  if remaining <= 0 { Some(COEALP(list_reverse(acc), pos)) }
  else {
    match cache_hex_to_opeffarity(buf, pos) {
      None -> None
      Some(c) -> match c { COEAP(a, p2) ->
        di_collect_oea(buf, p2, remaining - 1, [a, ...acc]) }
    }
  }
}

# ---- RecInfo ----------------------------------------------------------

fn cache_hex_to_recinfo(buf: String, pos: Int) : Option[CacheRIPos2] {
  match cache_hex_to_string(buf, pos) {
    None -> None
    Some(c) -> match c { CSP(nm, p) -> ri_after_name(buf, p, nm) }
  }
}

fn ri_after_name(buf: String, pos: Int, nm: String) : Option[CacheRIPos2] {
  match cache_hex_to_string_list(buf, pos) {
    None -> None
    Some(c) -> match c { CSLP(tps, p) -> ri_after_tps(buf, p, nm, tps) }
  }
}

fn ri_after_tps(buf: String, pos: Int, nm: String, tps: [String]) : Option[CacheRIPos2] {
  match cache_hex_to_fd_list(buf, pos) {
    None -> None
    Some(c) -> match c { CFDLP(fds, p) -> ri_after_fields(buf, p, nm, tps, fds) }
  }
}

fn ri_after_fields(buf: String, pos: Int, nm: String, tps: [String],
                    fds: [FieldDecl]) : Option[CacheRIPos2] {
  match cache_hex_to_opt_string(buf, pos) {
    None -> None
    Some(c) -> match c { COSP(mo, p) -> Some(CRIP2(RI(nm, tps, fds, mo), p)) }
  }
}

#[doc("Decode a `[RecInfo]` payload chunk at `pos`.")]
pub fn cache_hex_to_recinfo_list(buf: String, pos: Int) : Option[CacheRILPos2] {
  match cache_hex_to_u32(buf, pos) {
    None -> None
    Some(c) -> match c { CIP(n, p2) -> di_collect_ri(buf, p2, n, []) }
  }
}

fn di_collect_ri(buf: String, pos: Int, remaining: Int,
                  acc: [RecInfo]) : Option[CacheRILPos2] {
  if remaining <= 0 { Some(CRILP2(list_reverse(acc), pos)) }
  else {
    match cache_hex_to_recinfo(buf, pos) {
      None -> None
      Some(c) -> match c { CRIP2(r, p2) ->
        di_collect_ri(buf, p2, remaining - 1, [r, ...acc]) }
    }
  }
}

# ---- SumInfo ----------------------------------------------------------

fn cache_hex_to_suminfo(buf: String, pos: Int) : Option[CacheSIPos] {
  match cache_hex_to_string(buf, pos) {
    None -> None
    Some(c) -> match c { CSP(nm, p) -> si_after_name(buf, p, nm) }
