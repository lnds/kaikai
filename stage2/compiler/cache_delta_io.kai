# ---- OpToEff / UAliasEntry / CtorEntry --------------------------------

fn cache_hex_to_optoeff(buf: String, pos: Int) : Option[CacheOTEPos] {
  match cache_hex_to_string(buf, pos) {
    None -> None
    Some(c) -> match c { CSP(op, p) -> match cache_hex_to_string(buf, p) {
      None -> None
      Some(c2) -> match c2 { CSP(eff, p2) -> Some(COTEP(OEFP(op, eff), p2)) }
    } }
  }
}

#[doc("Decode an `[OpToEff]` payload chunk at `pos`.")]
pub fn cache_hex_to_optoeff_list(buf: String, pos: Int) : Option[CacheOTELPos] {
  match cache_hex_to_u32(buf, pos) {
    None -> None
    Some(c) -> match c { CIP(n, p2) -> di_collect_ote(buf, p2, n, []) }
  }
