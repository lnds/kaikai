# compiler/protos.kai — m12.8 single-dispatch protocols.
#
# Named `protos`, not `protocols`: the module binding is the last
# dotted segment, and `protocols` is already reserved by the implicit
# stdlib core (`stdlib/protocols.kai`, the user-facing Show / Eq /
# Ord / Hash impls). Importing `compiler.protocols` resolves to that
# already-registered stdlib module instead of this file, hiding the AST
# variant namespace and producing ~330 "unknown variant" errors. The
# flat bundle masks the clash (one global namespace); the modular kaic2
# build exposes it — the N1/N3 "modular build exposes what the bundle
# hides" lesson, here landing on the module name itself.
#
# Extracted from main.kai under issue #677 Phase 1p, promoted ahead of
# the N2 monomorph lane: the abandoned monomorph-extract lane discovered
# ~537 LOC / 31 fns of protocol-resolve coupling (`monomorphise` calls
# `resolve_protocol_calls_decl`) that the original section analysis #692
# missed. Mirroring that surface meant duplicating the whole protocol
# module; pre-sinking only the `resolve_*` fns would have split one
# cohesive domain. The integrator decision: extract the protocol system
# whole first, then re-run N2 importing it downward.
#
# What this module owns — the complete m12.8 single-dispatch protocol
# system, three contiguous sub-sections that share the same domain:
#
#   A. Definition + lowering (pre-resolve desugar). Expands
#      `#[derive(P)]` into synthetic `impl P for T`, validates the
#      orphan + single-impl-per-pair rules, lowers each `impl` method
#      into one ordinary `__pimpl_<P>_<TypeMangled>_<op>` DFn, emits a
#      stub *dispatcher* DFn per protocol op (so the typer resolves
#      `op(x, ...)` polymorphically), and drops the DProtocol / DImpl /
#      DDerive nodes from the decl stream. Entry: `lower_protocols`.
#
#   B. Post-inference protocol-call rewrite. After inference has
#      attached types, `resolve_protocol_calls` (+ `_decl`) replaces
#      every `op(x, ...)` with a direct call to the matching impl fn;
#      calls no impl matches survive and surface the dispatcher's
#      runtime panic (the v1 fall-back). `validate_resolved_protocols`
#      catches the static unresolved cases at compile time.
#
#   C. Post-Core REOPEN — Eric level 2 rep-invariant verifiers
#      (`validate_typer_invariants`): structural checks over the typed
#      program guarding the AST representation invariants the typer is
#      expected to maintain.
#
# Coherence is purely compile-time: orphan + duplicate-impl checks run
# in (A), and dispatch is `O(1)` (linear scan over a flat impl list
# small enough to be `O(1)` in practice).
#
# The protocol-registry types (ProtoOpReg, ProtoTPReg, ProtoImplReg,
# ProtoOriginReg, ProtocolReg) were sunk into compiler/ast.kai in issue
# #677 phase 1n0 — they cross into the infer public surface and are
# produced by this block, so ast.kai is their shared downward home.
# This module only *uses* them.
#
# Public surface (1 type + 12 fns):
#   - `OpAr` — (op_name, arity) pair; the desugar interp pass takes it
#     in its signatures, so it crosses the module boundary by value.
#   - `lower_protocols` — pass (A) entry, called from the driver.
#   - `op_arities_from_ops` / `collect_local_fn_arities` /
#     `filter_shadowed_ops` / `rename_proto_calls_decls` — the pre-typer
#     arity-aware rename machinery the driver re-runs over the
#     post-interp-desugar decl stream (issue #443).
#   - `proto_dispatcher_name` — the `__proto_<op>` name builder, called
#     by the interp-desugar pass (still in main) to stringify `#{...}`.
#   - `resolve_protocol_calls` / `resolve_protocol_calls_decl` — pass
#     (B) entry; `_decl` is the per-decl hook the N2 monomorph lane will
#     import (the coupling that re-sequenced this lane).
#   - `validate_resolved_protocols` / `validate_resolved_decls` — the
#     post-rewrite static-coherence check (full program + per-decl).
#   - `validate_typer_invariants` — pass (C) entry, called from the
#     driver after inference.
#   - `string_to_lower_ascii` — ASCII lowercaser; the LLVM/C emitter
#     (still in main) lowercases effect names with it.
#
# Bundle order: ... infer, fnreg, unbox, perceus, **protos**, main.
# Imports compiler.ast for the AST nodes + Proto*Reg types + `mk_expr` /
# `mk_pat` / `mk_ty`, compiler.diag for `diag_error`, compiler.util for
# `concat_all` / `list_has`, compiler.modules for `fn_param_names` /
# `decl_home_hint_reset`, compiler.infer for `TypedProgram` /
# `arg_names_match`. The AST-functor family (`proto_map_expr_kind`), the
# type display (`proto_type_expr_display` / `proto_unit_expr_display`),
# `proto_join_with`, and the dispatcher-marker builder
# (`proto_mk_dispatch_body`) are mirrored downward glue with the
# `proto_*` prefix, copied verbatim from the canonical definitions still
# resident in main / infer (single consumer each here ⇒ mirror, not sink,
# per the phase-1m `dsg_` discipline).

import compiler.ast
import compiler.kinds
import compiler.diag
import compiler.util
import compiler.impl_index
import compiler.modules
import compiler.infer
import compiler.layout_derive
import compiler.layout_validate

# ====================================================================
# Law wrappers (`laws <Theory>` / `axiom <Theory>`).
#
# The parser emits `DProtoLaws(theory, DProtocol, …)` and
# `DImplAxiom(theory, DImpl, …)` wrappers. `strip_law_wrappers` unwraps
# them to the bare protocol/impl and records the associations, so no
# downstream pass ever sees the wrapper — the same discipline
# `lower_axioms` uses for `DAxiom`. The law engine reads the registry to
# autogenerate per-impl property checks (except impls marked `axiom`).
# ====================================================================

# `protocol_name -> theory` and the impls exempted by `axiom <Theory>`.
pub type LawReg = LR([ProtoLaw], [AxiomImpl])
pub type ProtoLaw = PL(String, String)          # protocol, theory
pub type AxiomImpl = AI(String, String, String) # protocol, type-head, theory

pub fn law_reg_protocols(r: LawReg) : [ProtoLaw] = match r { LR(ps, _) -> ps }
pub fn law_reg_axioms(r: LawReg) : [AxiomImpl] = match r { LR(_, xs) -> xs }

#[doc("The theory a protocol declares its ops obey via `laws`, if any.")]
pub fn law_theory_of(r: LawReg, proto: String) : Option[String] =
  law_theory_loop(law_reg_protocols(r), proto)

fn law_theory_loop(ps: [ProtoLaw], proto: String) : Option[String] = match ps {
  [] -> None
  [PL(p, thy), ...rest] -> if p == proto { Some(thy) } else { law_theory_loop(rest, proto) }
}

#[doc("True when `impl P for <head>` is exempted from law-checks by an `axiom` clause.")]
pub fn law_impl_axiomed(r: LawReg, proto: String, head: String) : Bool =
  law_axiom_loop(law_reg_axioms(r), proto, head)

fn law_axiom_loop(xs: [AxiomImpl], proto: String, head: String) : Bool = match xs {
  [] -> false
  [AI(p, t, _), ...rest] -> if p == proto and t == head { true } else { law_axiom_loop(rest, proto, head) }
}

#[doc("""
Unwrap every `DProtoLaws` / `DImplAxiom` wrapper to its bare inner decl,
returning the flattened decl stream and the law registry. Runs before
any other Decl walker so downstream passes see only plain
protocols/impls, mirroring `lower_axioms`.
""")]
pub fn strip_law_wrappers(decls: [Decl]) : StrippedLaws =
  strip_law_loop(decls, [], [], [])

pub type StrippedLaws = SL([Decl], LawReg)

pub fn strip_sl_decls(s: StrippedLaws) : [Decl] = match s { SL(ds, _) -> ds }
pub fn strip_sl_reg(s: StrippedLaws) : LawReg = match s { SL(_, r) -> r }

fn strip_law_loop(decls: [Decl], acc: [Decl], laws: [ProtoLaw],
                  axioms: [AxiomImpl]) : StrippedLaws = match decls {
  [] -> SL(list_reverse(acc), LR(list_reverse(laws), list_reverse(axioms)))
  [d, ...rest] -> match d {
    DProtoLaws(thy, DProtocol(a, name, b, c, l, cc), _, _) ->
      strip_law_loop(rest, [DProtocol(a, name, b, c, l, cc), ...acc],
                     [PL(name, thy), ...laws], axioms)
    DImplAxiom(thy, DImpl(pname, pa, target, ms, l, cc), _, _) ->
      strip_law_loop(rest, [DImpl(pname, pa, target, ms, l, cc), ...acc],
                     laws, [AI(pname, proto_type_name(target), thy), ...axioms])
    _ -> strip_law_loop(rest, [d, ...acc], laws, axioms)
  }
}

# ====================================================================
# Downward glue mirrors (proto_ prefix) — copied verbatim from the
# canonical definitions still resident in main / infer. Mirrored rather
# than sunk because each has a single consumer in this module.
# ====================================================================

fn proto_join_with(xs: [String], sep: String) : String = string_join(xs, sep)

# Mirror of `type_expr_display` (main) — renders a TypeExpr as
# user-readable text for protocol coherence diagnostics.
fn proto_type_expr_display(t: TypeExpr) : String {
  match t.tkind {
    TyName(name, []) -> name
    TyName(name, ts) -> concat_all([name, "[", proto_join_with(map(ts, proto_type_expr_display), ", "), "]"])
    TyList(inner) -> concat_all(["[", proto_type_expr_display(inner), "]"])
    TyFn(ps, ret, _) -> concat_all([
      "(", proto_join_with(map(ps, proto_type_expr_display), ", "), ") -> ", proto_type_expr_display(ret)
    ])
    TyDim(base, u) -> concat_all([proto_type_expr_display(base), "<", proto_unit_expr_display(u), ">"])
    TyRefine(base, _) -> concat_all([proto_type_expr_display(base), " where <pred>"])
    # issue #772: compound row as a type argument — render bare labels.
    TyRow(row) -> proto_row_expr_display(row)
  }
}

# issue #772: render a row's labels/tail as a bare `A + B + tail`
# string — the shape a compound row takes in a `[...]` argument list.
fn proto_row_expr_display(r: RowExpr) : String {
  match r {
    REmpty -> ""
    RClosed(labels) -> proto_join_with(map(labels, proto_row_label_name), " + ")
    ROpen(tail, labels) ->
      if labels == [] { tail }
      else { concat_all([proto_join_with(map(labels, proto_row_label_name), " + "), " + ", tail]) }
  }
}

fn proto_row_label_name(rl: RowLabel) : String = match rl { RL(n, _) -> n }

# Mirror of `unit_expr_display` (main) — renders a UnitExprT as text.
fn proto_unit_expr_display(u: UnitExprT) : String {
  match u {
    UOne -> "1"
    USym(s) -> kind_sym_mangle(s)
    UMul(a, b) -> match b {
      UInv(b_inner) -> match a {
        UOne -> concat_all(["1/", proto_unit_expr_display(b_inner)])
        _    -> concat_all([proto_unit_expr_display(a), "/", proto_unit_expr_display(b_inner)])
      }
      UOne -> proto_unit_expr_display(a)
      _ -> match a {
        UOne -> proto_unit_expr_display(b)
        UInv(a_inner) -> concat_all([proto_unit_expr_display(b), "/", proto_unit_expr_display(a_inner)])
        _ -> concat_all([proto_unit_expr_display(a), " ", proto_unit_expr_display(b)])
      }
    }
    UInv(a) -> concat_all(["1/", proto_unit_expr_display(a)])
    UPow(a, n) -> concat_all([proto_unit_expr_display(a), "^", int_to_string(n)])
    UJoin(a, b) -> concat_all([proto_unit_expr_display(a), " + ", proto_unit_expr_display(b)])
    UVar(n) -> cat2("?u", int_to_string(n))
    UDims(us) -> proto_unit_exprs_display(us)
  }
}

fn proto_unit_exprs_display(us: [UnitExprT]) : String = match us {
  [] -> ""
  [u] -> proto_unit_expr_display(u)
  [u, ...rest] -> concat_all([proto_unit_expr_display(u), ", ", proto_unit_exprs_display(rest)])
}

# Mirror of `mk_proto_dispatch_body` (main) — builds the ETodo
# dispatcher marker. The `"__kai_proto_dispatch__:"` prefix MUST stay
# byte-identical: the desugar + emitter sides read it back.
fn proto_mk_dispatch_body(pname: String, opname: String, line: Int, col: Int) : Expr =
  mk_expr(ETodo(concat_all(["__kai_proto_dispatch__:", pname, ":", opname])), line, col)

# AST-functor family mirror (`proto_map_*`) — copied verbatim from the
# `inf_map_*` family in compiler/infer.kai.
fn proto_map_arm_exprs(a: Arm, f: (Expr) -> Expr) : Arm {
  match a {
    Arm(p, g, b) -> Arm(p, proto_map_opt_expr(g, f), f(b))
  }
}

fn proto_map_clause_exprs(c: HClause, f: (Expr) -> Expr) : HClause {
  match c {
    HC(n, ps, b, l, co) -> HC(n, ps, f(b), l, co)
  }
}

fn proto_map_elem_exprs(el: ListElem, f: (Expr) -> Expr) : ListElem {
  match el {
    ElPlain(x)  -> ElPlain(f(x))
    ElSpread(x) -> ElSpread(f(x))
  }
}

fn proto_map_field_exprs(fi: FieldInit, f: (Expr) -> Expr) : FieldInit {
  match fi {
    FI(n, v) -> FI(n, f(v))
  }
}

fn proto_map_opt_expr(opt: Option[Expr], f: (Expr) -> Expr) : Option[Expr] {
  match opt {
    Some(e) -> Some(f(e))
    None    -> None
  }
}

fn proto_map_opt_return_exprs(opt: Option[HReturn], f: (Expr) -> Expr) : Option[HReturn] {
  match opt {
    Some(r) -> Some(proto_map_return_exprs(r, f))
    None    -> None
  }
}

fn proto_map_return_exprs(r: HReturn, f: (Expr) -> Expr) : HReturn {
  match r {
    HR(p, b, l, c) -> HR(p, f(b), l, c)
  }
}

fn proto_map_stmt_exprs(s: Stmt, f: (Expr) -> Expr) : Stmt {
  match s {
    SLet(p, ann, rhs)           -> SLet(p, ann, f(rhs))
    SAssert(c, m)               -> SAssert(f(c), proto_map_opt_expr(m, f))
    SExprStmt(x)                -> SExprStmt(f(x))
    SIndexAssign(b, i, v, l, c) -> SIndexAssign(f(b), f(i), f(v), l, c)
    SVar(n, ty, rhs, l, c)      -> SVar(n, ty, f(rhs), l, c)
    SUse(n, l, c)               -> SUse(n, l, c)
  }
}

fn proto_map_expr_kind(k: ExprKind, f: (Expr) -> Expr) : ExprKind {
  match k {
    EInt(_)        -> k
    EReal(_, _)       -> k
    EIntLit(_)        -> k
    EDecimalLit(_)    -> k
    EFixed(_, _)      -> k
    EBool(_)       -> k
    EChar(_)       -> k
    EStr(_, _)     -> k
    EUnit          -> k
    EVar(_)        -> k
    EUnder         -> k
    EPlaceholder   -> k
    EHole(_)       -> k
    ETodo(_)       -> k
    EExternBody(_) -> k
    EVariantsOf(_, _) -> k
    EModCall(_, _) -> k
    EIntrinsic(name, args_) -> EIntrinsic(name, map(args_, f))
    ECall(callee, args_) -> ECall(f(callee), map(args_, f))
    EField(base, name)   -> EField(f(base), name)
    EIndex(a, b)         -> EIndex(f(a), f(b))
    EBinop(op, a, b)     -> EBinop(op, f(a), f(b))
    EUnop(op, x)         -> EUnop(op, f(x))
    EIf(c, t_, eo)       -> EIf(f(c), f(t_), proto_map_opt_expr(eo, f))
    EMatch(scr, arms)    -> EMatch(f(scr), map(arms, (a) => proto_map_arm_exprs(a, f)))
    ELambda(ps, b)       -> ELambda(ps, f(b))
    ERecordLit(name, fs) -> ERecordLit(name, map(fs, (fi) => proto_map_field_exprs(fi, f)))
    EList(els)           -> EList(map(els, (el) => proto_map_elem_exprs(el, f)))
    ERange(a, b, opt_step) -> ERange(f(a), f(b), proto_map_opt_expr(opt_step, f))
    EBlock(stmts, tail)  -> EBlock(map(stmts, (s) => proto_map_stmt_exprs(s, f)),
                                    proto_map_opt_expr(tail, f))
    EPipe(a, b)          -> EPipe(f(a), f(b))
    EMapPipe(a, b)       -> EMapPipe(f(a), f(b))
    EFlatMapPipe(a, b)   -> EFlatMapPipe(f(a), f(b))
    EFilterPipe(a, b)    -> EFilterPipe(f(a), f(b))
    EHandle(body, eff_name, eff_tyargs, init_opt, alias_opt, clauses, ret_opt) ->
      EHandle(f(body), eff_name, eff_tyargs,
              proto_map_opt_expr(init_opt, f), alias_opt,
              map(clauses, (c) => proto_map_clause_exprs(c, f)),
              proto_map_opt_return_exprs(ret_opt, f))
    ELitUnit(inner, u)   -> ELitUnit(f(inner), u)
    EBang(inner)         -> EBang(f(inner))
  }
}

# ====================================================================
# m12.8 — single-dispatch protocols (body)
# ====================================================================

fn proto_reg_empty() : ProtocolReg =
  ProtocolReg { ops: [], impls: [], op_names: [], tparams: [], origins: [],
                impl_index: impl_index_empty() }

# m12.8: the type-mangling used in the impl-fn name. Walks a
# TypeExpr, collapsing it down to the head TyName (so `Money[u]`,
# `Money[USD]`, and `Money` all map to `Money`). Lists collapse to
# `List`. This gives a single impl per type-constructor — polymorphic
# impls cover all instantiations, mirroring the spec's "monomorphises
# per concrete instantiation just like any generic function" note.
#[doc("The single-dispatch head name of a `TypeExpr` (`Money[USD]` → `Money`, `[T]` → `List`).")]
pub fn proto_type_name(te: TypeExpr) : String {
  match te.tkind {
    TyName(name, _) -> name
    TyList(_)       -> "List"
    TyFn(_, _, _)   -> "Fn"
    # m12.5: `Decimal<USD>` and friends collapse to the base
    # constructor (`Decimal`); the unit annotation is invisible to
    # protocol dispatch (which is single-dispatch on the head TyName,
    # exactly as the spec describes for `impl Show for Money[u: Measure]`).
    TyDim(base, _)  -> proto_type_name(base)
    # m12.6.a: refinements collapse to the underlying base for protocol
    # dispatch — `Int where >= 0` and `Int` resolve to the same `impl`.
    TyRefine(base, _) -> proto_type_name(base)
    # issue #772: a compound row is never a protocol-dispatch head; it
    # only appears as a type argument. Return a name no `impl` matches.
    TyRow(_) -> "Row"
  }
}

fn proto_mangled_fn(proto: String, type_name: String, op: String) : String =
  concat_all(["__pimpl_", proto, "_", type_name, "_", op])

# Issue #180: heterogeneous-aware mangling. The legacy un-parametrised
# form `impl Show for Int` (arg_names == []) keeps the original
# `__pimpl_<P>_<T>_<op>` symbol. The homogeneous parametrised form
# `impl Add[Complex] for Complex` (arg_names == [type_name]) also keeps
# it (so it stays interchangeable with the un-parametrised form). Only
# heterogeneous impls (e.g. `impl Add[Real] for Complex`) get a
# `__a_<arg_name>...` suffix that disambiguates the dispatch table.
fn proto_impl_mangled_with_args(proto: String, type_name: String,
                                  op: String, arg_names: [String]) : String {
  let needs_suffix = match arg_names {
    [] -> false
    [a] -> a != type_name
    _  -> true
  }
  if needs_suffix {
    concat_all(["__pimpl_", proto, "_", type_name, "_", op,
                "__a_", arg_names_mangle(arg_names)])
  } else {
    proto_mangled_fn(proto, type_name, op)
  }
}

fn arg_names_mangle(args: [String]) : String = match args {
  [] -> ""
  [a] -> a
  [a, ...rest] -> concat_all([a, "_", arg_names_mangle(rest)])
}

# m12.8: kaikai-side name for the *dispatcher* function the lower
# pass synthesises for each protocol op. Prefixing with `__proto_`
# keeps the emitted C symbol (`kai___proto_<op>`) clear of runtime
# helpers like `kai_op_eq`, `kai_to_string`, `kai_op_lt` etc. that share
# common short names with protocol ops.
#[doc("kaikai name of the polymorphic dispatcher DFn for protocol op `op` (`__proto_<op>`).")]
pub fn proto_dispatcher_name(op: String) : String = concat_all(["__proto_", op])

# A protocol's home module, keyed by name. Built once from the merged
# decl stream's home-anchor analysis; `collect_proto_decls` consults it
# instead of inferring the home from the running `cur_mod`.
type ProtoHome = PH(String, Option[String])

# The home module of each DProtocol, recovered with the SAME back-
# propagating home-anchor analysis `validate_pub_access` uses. A bare
# forward stream (the legacy approach) mis-tags any DProtocol that
# precedes the first anchored DFn of its file: a user protocol declared
# before `fn main` inherits the last core's module instead of the
# root file's, and every core protocol shifts to the preceding
# module. `imports_home_anchors` assigns one home per decl in source
# order with the back-propagation that fixes both.
fn proto_homes_from_decls(ds: [Decl], target_mod: String) : [ProtoHome] = {
  let homes = imports_home_anchors(ds, target_mod, target_mod, [])
  proto_homes_zip(ds, homes, target_mod, [])
}

fn proto_homes_zip(ds: [Decl], homes: [HomeAnchor], target_mod: String,
                   acc: [ProtoHome]) : [ProtoHome] = match ds {
  [] -> acc
  [d, ...rest] -> match homes {
    [] -> acc
    [h, ...hrest] -> {
      let acc1 = proto_home_record(d, ha_home(h), target_mod, acc)
      proto_homes_zip(rest, hrest, target_mod, acc1)
    }
  }
}

# Record a `(proto_name, home)` for `d` when it is (or wraps) a
# DProtocol. `home == target_mod` canonicalises to `None`, matching the
# rest of the root file's untagged decls.
fn proto_home_record(d: Decl, home: String, target_mod: String,
                     acc: [ProtoHome]) : [ProtoHome] = match d {
  DProtocol(_, name, _, _, _, _) -> {
    let mo = if home == target_mod { None } else { Some(home) }
    [PH(name, mo), ...acc]
  }
  DDerive(_, inner, _, _)  -> proto_home_record(inner, home, target_mod, acc)
  DUnstable(inner, _, _)   -> proto_home_record(inner, home, target_mod, acc)
  DProtoLaws(_, inner, _, _) -> proto_home_record(inner, home, target_mod, acc)
  DImplAxiom(_, inner, _, _) -> proto_home_record(inner, home, target_mod, acc)
  DConstructor(inner, _, _) -> proto_home_record(inner, home, target_mod, acc)
  _ -> acc
}

fn proto_home_lookup(homes: [ProtoHome], name: String) : Option[String] = match homes {
  [] -> None
  [PH(n, mo), ...rest] -> if n == name { mo } else { proto_home_lookup(rest, name) }
}

# Register every DProtocol decl the program declares. The op list
# becomes the universe of "names that look like ordinary fn calls but
# really need protocol dispatch".
#
# Issue #597 boundary tagging: each registered DProtocol records its
# home module. DProtocol carries no `module_origin` field of its own (v1
# of #510 only added the field to DFn), so the home is recovered up
# front via `proto_homes_from_decls` (the back-propagating home-anchor
# analysis) and looked up by name here. The `origins` table feeds
# `make_dispatcher_fn` so each synthesised dispatcher inherits the
# originating module's tag, AND the #962 directional-visibility cut,
# which needs a user protocol's origin to be exactly `None`.
fn collect_proto_decls(ds: [Decl], reg: ProtocolReg,
                        target_mod: String) : ProtocolReg {
  collect_proto_decls_h(ds, reg, proto_homes_from_decls(ds, target_mod))
}

fn collect_proto_decls_h(ds: [Decl], reg: ProtocolReg,
                          homes: [ProtoHome]) : ProtocolReg {
  match ds {
    [] -> reg
    [d, ...rest] -> match d {
      DProtocol(_, name, tparams, ops, _, _) -> {
        let proto_mo = proto_home_lookup(homes, name)
        let reg1 = ProtocolReg {
          ops: reg.ops, impls: reg.impls, op_names: reg.op_names,
          tparams: [PTPR(name, tparams), ...reg.tparams],
          origins: [PrOR(name, proto_mo), ...reg.origins],
          impl_index: reg.impl_index
        }
        collect_proto_decls_h(rest, register_proto_ops(reg1, name, ops), homes)
      }
      DDerive(_, inner, _, _) ->
        collect_proto_decls_h([inner, ...rest], reg, homes)
      DUnstable(inner, _, _) ->
        collect_proto_decls_h([inner, ...rest], reg, homes)
      DProtoLaws(_, inner, _, _) ->
        collect_proto_decls_h([inner, ...rest], reg, homes)
      DImplAxiom(_, inner, _, _) ->
        collect_proto_decls_h([inner, ...rest], reg, homes)
      DConstructor(inner, _, _) ->
        collect_proto_decls_h([inner, ...rest], reg, homes)
      _ -> collect_proto_decls_h(rest, reg, homes)
    }
  }
}

fn register_proto_ops(reg: ProtocolReg, proto: String, ops: [ProtoOp]) : ProtocolReg {
  match ops {
    [] -> reg
    [op, ...rest] -> match op {
      POp(opname, _, params, ret, line, col) -> {
        let entry = POR(proto, opname, params, ret, line, col)
        let names1 =
          if list_has(reg.op_names, opname) { reg.op_names }
          else { [opname, ...reg.op_names] }
        let reg1 = ProtocolReg {
          ops: [entry, ...reg.ops],
          impls: reg.impls,
          op_names: names1,
          tparams: reg.tparams,
          origins: reg.origins,
          impl_index: reg.impl_index
        }
        register_proto_ops(reg1, proto, rest)
      }
    }
  }
}

# Issue #597: lookup a protocol's home module in the registry. Returns
# `None` for root-file protocols (so the synthesised dispatcher stays
# `mo = None`, matching the rest of the root file's untagged decls) or
# `Some(mod)` for protocols imported from a core / module.
fn proto_origin_lookup(origins: [ProtoOriginReg], proto: String) : Option[String] {
  match origins {
    [] -> None
    [h, ...rest] -> match h {
      PrOR(p, mo) -> if p == proto { mo } else { proto_origin_lookup(rest, proto) }
    }
  }
}

fn proto_op_lookup(reg: ProtocolReg, name: String) : Option[ProtoOpReg] {
  proto_op_lookup_loop(reg.ops, name)
}

fn proto_op_lookup_loop(ops: [ProtoOpReg], target: String) : Option[ProtoOpReg] {
  match ops {
    [] -> None
    [op, ...rest] -> match op {
      POR(_, name, _, _, _, _) ->
        if name == target { Some(op) } else { proto_op_lookup_loop(rest, target) }
    }
  }
}

# Issue #546: two protocols may declare an op with the same name
# (`protocol Speak { sound(x: Self) }` + `protocol Move { sound(x: Self) }`).
# kaikai resolves protocol ops by bare name, so the call site `sound(x)`
# carries no protocol — only the receiver's type disambiguates. The
# single-result `proto_op_lookup` above fixes the protocol to whichever
# was declared first, which makes the static rewrite search impls in the
# wrong protocol and leave a misdispatched residual. `proto_ops_lookup_all`
# returns EVERY POR matching the name (registry order) so the rewrite can
# try each candidate protocol and pick the one with an impl for the
# receiver type.
fn proto_ops_lookup_all(reg: ProtocolReg, name: String) : [ProtoOpReg] =
  proto_ops_lookup_all_loop(reg.ops, name)

fn proto_ops_lookup_all_loop(ops: [ProtoOpReg], target: String) : [ProtoOpReg] {
  match ops {
    [] -> []
    [op, ...rest] -> match op {
      POR(_, name, _, _, _, _) ->
        if name == target { [op, ...proto_ops_lookup_all_loop(rest, target)] }
        else { proto_ops_lookup_all_loop(rest, target) }
    }
  }
}

# Collect every protocol the program declares. Used by the
# orphan-rule validation: an `impl P for T` is allowed only if `P` is
# declared in the same compilation unit (here: in `decls`) or `T` is.
fn collect_proto_names(ds: [Decl], acc: [String]) : [String] {
  match ds {
    [] -> acc
    [d, ...rest] -> match d {
      DProtocol(_, name, _, _, _, _) -> collect_proto_names(rest, [name, ...acc])
      DDerive(_, inner, _, _) -> collect_proto_names([inner, ...rest], acc)
      DUnstable(inner, _, _) -> collect_proto_names([inner, ...rest], acc)
      DProtoLaws(_, inner, _, _) -> collect_proto_names([inner, ...rest], acc)
      DImplAxiom(_, inner, _, _) -> collect_proto_names([inner, ...rest], acc)
      DConstructor(inner, _, _) -> collect_proto_names([inner, ...rest], acc)
      _ -> collect_proto_names(rest, acc)
    }
  }
}

fn collect_local_type_names(ds: [Decl], acc: [String]) : [String] {
  match ds {
    [] -> acc
    [d, ...rest] -> match d {
      DType(_, name, _, _, _, _, _, _) -> collect_local_type_names(rest, [name, ...acc])
      DDerive(_, inner, _, _) -> collect_local_type_names([inner, ...rest], acc)
      DUnstable(inner, _, _) -> collect_local_type_names([inner, ...rest], acc)
      DProtoLaws(_, inner, _, _) -> collect_local_type_names([inner, ...rest], acc)
      DImplAxiom(_, inner, _, _) -> collect_local_type_names([inner, ...rest], acc)
      DConstructor(inner, _, _) -> collect_local_type_names([inner, ...rest], acc)
      _ -> collect_local_type_names(rest, acc)
    }
  }
}

# Builtin-primitive type names — `Int`, `Real`, etc. — are treated
# as "always local" for the purpose of the orphan rule when they
# appear as the impl target. This matches the spec: stdlib ships
# the canonical impls for primitives, and user code can still write
# `impl Show for [a]` (target = list-of-tparam) without colliding.
fn proto_builtin_type_names() : [String] =
  ["Int", "Real", "Bool", "Char", "String", "Unit",
   "List", "Option", "Result"]

# Validate: the orphan rule (protocol or target type must be local)
# and single-impl-per-(P,T) coherence. Reports each violation on
# stderr and returns the count of reported errors.
fn validate_impls(ds: [Decl], file: String,
                  proto_names: [String], local_types: [String]) : Int / Console {

  validate_impls_loop(ds, file, proto_names, local_types, [], 0)
}

fn validate_impls_loop(ds: [Decl], file: String,
                       proto_names: [String], local_types: [String],
                       seen: [String], errs: Int) : Int / Console {
  match ds {
    [] -> errs
    [d, ...rest] -> match d {
      DImpl(pname, proto_args, target, _, line, col) -> {
        let tname = proto_type_name(target)
        # Issue #180: duplicate-impl key includes the proto-arg names so
        # `impl Add[Real] for Complex` and `impl Add[Complex] for Complex`
        # coexist. Legacy `impl P for T` (proto_args == []) maps to the
        # homogeneous default `[T]` for keying.
        let arg_names = match proto_args {
          [] -> [tname]
          _  -> map(proto_args, proto_type_name)
        }
        let key = concat_all([pname, "/", tname, "[", arg_names_mangle(arg_names), "]"])
        let proto_local = list_has(proto_names, pname)
        let type_local = list_has(local_types, tname) or
                         list_has(proto_builtin_type_names(), tname)
        let errs1 =
          if not proto_local and not type_local {
            eprint(concat_all([
              file, ":", int_to_string(line), ":", int_to_string(col),
              ": error: orphan rule: `impl ", pname, " for ", tname,
              "` requires either the protocol or the target type to be declared in this compilation unit"]))
            errs + 1
          } else { errs }
        let errs2 =
          if list_has(seen, key) {
            eprint(concat_all([
              file, ":", int_to_string(line), ":", int_to_string(col),
              ": error: duplicate impl: `impl ", pname, " for ", tname,
              "` already exists in this compilation unit"]))
            errs1 + 1
          } else { errs1 }
        let proto_ok =
          if list_has(proto_names, pname) { true }
          else {
            eprint(concat_all([
              file, ":", int_to_string(line), ":", int_to_string(col),
              ": error: unknown protocol `", pname, "` in `impl`"]))
            false
          }
        let errs3 = if proto_ok { errs2 } else { errs2 + 1 }
        let seen1 = if list_has(seen, key) { seen } else { [key, ...seen] }
        validate_impls_loop(rest, file, proto_names, local_types, seen1, errs3)
      }
      DDerive(_, inner, _, _) ->
        validate_impls_loop([inner, ...rest], file, proto_names, local_types, seen, errs)
      DUnstable(inner, _, _) ->
        validate_impls_loop([inner, ...rest], file, proto_names, local_types, seen, errs)
      DProtoLaws(_, inner, _, _) ->
        validate_impls_loop([inner, ...rest], file, proto_names, local_types, seen, errs)
      DImplAxiom(_, inner, _, _) ->
        validate_impls_loop([inner, ...rest], file, proto_names, local_types, seen, errs)
      DConstructor(inner, _, _) ->
        validate_impls_loop([inner, ...rest], file, proto_names, local_types, seen, errs)
      _ -> validate_impls_loop(rest, file, proto_names, local_types, seen, errs)
    }
  }
}

# Issue #535 — impl method validation against protocol declaration.
#
# Three failure shapes the dispatch resolver previously accepted silently:
#   1. missing required method — `impl P for T { fn foo(...) }` when `P`
#      also declares `bar`. Calls to `bar(t)` get the dispatcher stub and
#      panic at runtime.
#   2. signature mismatch — `impl P for T` whose `foo` returns or accepts
#      a type the protocol does not declare. Calls would type-check on
#      the wrong shape and corrupt downstream inference.
#   3. arity mismatch — `impl P for T`'s `foo` has fewer params than
#      `protocol P` declares. Extra arguments at the call site silently
#      drop.
#
# Implementation strategy:
#   - Required-method check: per protocol, collect every op name; per
#     impl, verify each is provided. Reports one error per missing op.
#   - Arity check: param-count comparison. The protocol's first param
#     position is `Self` by convention; the impl provides the concrete
#     type. Counts must match.
#   - Signature check (conservative, v1): compare param types and return
#     type by *head-name* via `proto_type_name` after Self substitution.
#     This collapses `Real<u>` and `Real` to the same head, `[T]` and
#     `[Int]` to `List`, etc. — matching what the dispatch mangling does
#     today. Deep structural / refinement comparison is deferred to a
#     follow-up that wires the typer's unifier into pre-typer
#     validation. Head-name comparison is enough to flag the bug-class
#     fixtures (`String` vs `Int`, etc.) without breaking polymorphic
#     stdlib impls whose tparams are not visible here.
#
# Unknown protocol names are silently skipped — `validate_impls_loop`
# above already reports those.

fn validate_impl_methods(ds: [Decl], file: String,
                         reg: ProtocolReg) : Int / Console {
  validate_impl_methods_loop(ds, file, reg, 0)
}

fn validate_impl_methods_loop(ds: [Decl], file: String,
                              reg: ProtocolReg, errs: Int) : Int / Console {
  match ds {
    [] -> errs
    [d, ...rest] -> match d {
      DImpl(pname, proto_args, target, methods, line, col) -> {
        let tname = proto_type_name(target)
        let proto_ops = proto_ops_for(reg.ops, pname, [])
        if proto_ops == [] {
          validate_impl_methods_loop(rest, file, reg, errs)
        } else {
          # Protocol tparams substitute against the impl's bracket
          # arguments. Legacy `impl P for T` (`proto_args == []`) is
          # treated as the homogeneous default: every protocol tparam
          # collapses to the target head. Heterogeneous
          # `impl P[Real, Int] for T` aligns positionally.
          let proto_tps = proto_tparams_for(reg.tparams, pname)
          let arg_heads = match proto_args {
            [] -> []
            _  -> map(proto_args, proto_type_name)
          }
          let all_op_names = proto_op_names(proto_ops, [])
          let e1 = check_missing_methods(proto_ops, methods, pname, tname,
                                         all_op_names,
                                         file, line, col, errs)
          let e2 = check_impl_methods(methods, proto_ops, pname, tname,
                                       proto_tps, arg_heads, file, e1)
          validate_impl_methods_loop(rest, file, reg, e2)
        }
      }
      DDerive(_, inner, _, _) ->
        validate_impl_methods_loop([inner, ...rest], file, reg, errs)
      DUnstable(inner, _, _) ->
        validate_impl_methods_loop([inner, ...rest], file, reg, errs)
      DProtoLaws(_, inner, _, _) ->
        validate_impl_methods_loop([inner, ...rest], file, reg, errs)
      DImplAxiom(_, inner, _, _) ->
        validate_impl_methods_loop([inner, ...rest], file, reg, errs)
      DConstructor(inner, _, _) ->
        validate_impl_methods_loop([inner, ...rest], file, reg, errs)
      _ -> validate_impl_methods_loop(rest, file, reg, errs)
    }
  }
}

# All protocol ops for `pname`, returned in declaration order (the
# registry stores them reversed; we flip back here so error messages
# follow source order).
fn proto_ops_for(ops: [ProtoOpReg], pname: String,
                 acc: [ProtoOpReg]) : [ProtoOpReg] {
  match ops {
    [] -> acc
    [op, ...rest] -> match op {
      POR(p, _, _, _, _, _) ->
        if p == pname { proto_ops_for(rest, pname, [op, ...acc]) }
        else { proto_ops_for(rest, pname, acc) }
    }
  }
}

fn proto_op_names(ops: [ProtoOpReg], acc: [String]) : [String] {
  match ops {
    [] -> acc
    [op, ...rest] -> match op {
      POR(_, name, _, _, _, _) -> proto_op_names(rest, [name, ...acc])
    }
  }
}

# Look up the protocol's tparam names (the `[a]` in `protocol Add[a]`).
# Returns `[]` for monomorphic protocols.
fn proto_tparams_for(tps: [ProtoTPReg], pname: String) : [String] {
  match tps {
    [] -> []
    [t, ...rest] -> match t {
      PTPR(p, names) ->
        if p == pname { names } else { proto_tparams_for(rest, pname) }
    }
  }
}

# Shape 1: every protocol op must have a matching method in the impl.
fn check_missing_methods(proto_ops: [ProtoOpReg], methods: [Decl],
                         pname: String, tname: String,
                         all_op_names: [String],
                         file: String, line: Int, col: Int,
                         errs: Int) : Int / Console {
  match proto_ops {
    [] -> errs
    [op, ...rest] -> match op {
      POR(_, opname, _, _, _, _) -> {
        let errs1 =
          if impl_has_method(methods, opname) { errs }
          else {
            eprint(concat_all([
              file, ":", int_to_string(line), ":", int_to_string(col),
              ": error: impl `", pname, " for ", tname,
              "` is missing required method `", opname, "`"]))
            eprint(concat_all([
              "  = note: protocol `", pname,
              "` declares operations: ", proto_join_with(all_op_names, ", ")]))
            errs + 1
          }
        check_missing_methods(rest, methods, pname, tname, all_op_names,
                              file, line, col, errs1)
      }
    }
  }
}

fn impl_has_method(methods: [Decl], opname: String) : Bool {
  match methods {
    [] -> false
    [d, ...rest] -> match d {
      DFn(_, name, _, _, _, _, _, _, _, _) ->
        if name == opname { true } else { impl_has_method(rest, opname) }
      _ -> impl_has_method(rest, opname)
    }
  }
}

# Shapes 2 + 3: walk each impl method; if it matches a protocol op,
# check arity and head-name compatibility. Methods that match no
# protocol op are reported as unknown.
fn check_impl_methods(methods: [Decl], proto_ops: [ProtoOpReg],
                      pname: String, tname: String,
                      proto_tps: [String], arg_heads: [String],
                      file: String, errs: Int) : Int / Console {
  match methods {
    [] -> errs
    [d, ...rest] -> match d {
      DFn(_, op_name, _, params, ret_opt, _, _, line, col, _) -> {
        let errs1 = match find_proto_op(proto_ops, op_name) {
          None -> {
            eprint(concat_all([
              file, ":", int_to_string(line), ":", int_to_string(col),
              ": error: impl `", pname, " for ", tname,
              "` declares method `", op_name,
              "` which is not an operation of protocol `", pname, "`"]))
            errs + 1
          }
          Some(op) -> match op {
            POR(_, _, proto_params, proto_ret, _, _) -> {
              let pa = list_length(params)
              let pp = list_length(proto_params)
              let e_ar =
                if pa == pp { errs }
                else {
                  eprint(concat_all([
                    file, ":", int_to_string(line), ":", int_to_string(col),
                    ": error: impl method `", op_name, "` in `",
                    pname, " for ", tname,
                    "` has arity ", int_to_string(pa),
                    " but protocol declares arity ", int_to_string(pp)]))
                  errs + 1
                }
              if pa == pp {
                check_sig_heads(params, proto_params, ret_opt, proto_ret,
                                op_name, pname, tname,
                                proto_tps, arg_heads,
                                file, line, col, e_ar)
              } else { e_ar }
            }
          }
        }
        check_impl_methods(rest, proto_ops, pname, tname, proto_tps, arg_heads,
                           file, errs1)
      }
      _ -> check_impl_methods(rest, proto_ops, pname, tname,
                              proto_tps, arg_heads, file, errs)
    }
  }
}

fn find_proto_op(ops: [ProtoOpReg], target: String) : Option[ProtoOpReg] {
  match ops {
    [] -> None
    [op, ...rest] -> match op {
      POR(_, name, _, _, _, _) ->
        if name == target { Some(op) } else { find_proto_op(rest, target) }
    }
  }
}

# Head-name comparison of impl vs protocol signature. `Self` in the
# protocol substitutes to `tname`; each protocol tparam `Ai`
# substitutes to `arg_heads[i]` (or `tname` when `arg_heads == []`,
# the homogeneous default per the lower_impls rule). Unannotated impl
# params (`ptype == None`) are not checked — the typer infers them; a
# pre-typer pass has no signal to compare against.
fn check_sig_heads(impl_params: [Param], proto_params: [Param],
                   impl_ret_opt: Option[TypeExpr], proto_ret: TypeExpr,
                   op_name: String, pname: String, tname: String,
                   proto_tps: [String], arg_heads: [String],
                   file: String, line: Int, col: Int,
                   errs: Int) : Int / Console {
  let e_params = check_sig_param_heads(impl_params, proto_params, tname,
                                        proto_tps, arg_heads,
                                        op_name, pname, file, errs)
  # Return-type check applies only when the impl is homogeneous w.r.t.
  # the protocol's tparams. Heterogeneous impls (`impl P[Other] for T`
  # with Other != T) often produce a *promoted* result type that the
  # protocol's `Self` return cannot express — stdlib's
  # `impl Add[Complex] for Real { fn add(...) : Complex }` is the
  # canonical case. Validating the return there requires a protocol-
  # level `Result` tparam or HKT, both out of scope for v1. The
  # parameter-position checks above still catch genuine signature
  # drift (wrong `self`/`rhs` types) — the leak here is only when
  # the impl rewrites the return shape for a known good reason.
  if heterogeneous_impl(arg_heads, tname) { e_params }
  else { match impl_ret_opt {
    None -> e_params
    Some(impl_ret) -> {
      let ih = proto_type_name(impl_ret)
      let ph = sig_head_subst(proto_ret, tname, proto_tps, arg_heads)
      if ih == ph { e_params }
      else {
        eprint(concat_all([
          file, ":", int_to_string(line), ":", int_to_string(col),
          ": error: impl method `", op_name, "` in `",
          pname, " for ", tname,
          "` returns `", proto_type_expr_display(impl_ret),
          "` but protocol declares return type `", ph, "`"]))
        e_params + 1
      }
    }
  } }
}

# An impl is heterogeneous iff it carries explicit bracket args and
# at least one of them differs from the target head. Legacy un-
# parametrised impls (`arg_heads == []`) are homogeneous by
# definition. Same-as-target args (`impl Add[Complex] for Complex`)
# round-trip through the homogeneous default, so they are not
# heterogeneous either.
fn heterogeneous_impl(arg_heads: [String], tname: String) : Bool {
  match arg_heads {
    [] -> false
    [h, ...rest] -> if h != tname { true } else { heterogeneous_impl(rest, tname) }
  }
}

fn check_sig_param_heads(impl_ps: [Param], proto_ps: [Param], tname: String,
                         proto_tps: [String], arg_heads: [String],
                         op_name: String, pname: String,
                         file: String, errs: Int) : Int / Console {
  match impl_ps {
    [] -> errs
    [ip, ...irest] -> match proto_ps {
      [] -> errs
      [pp, ...prest] -> {
        let errs1 = match ip.ptype {
          None -> errs
          Some(it) -> {
            let ih = proto_type_name(it)
            let ph = match pp.ptype {
              None -> ih
              Some(pt) -> sig_head_subst(pt, tname, proto_tps, arg_heads)
            }
            if ih == ph { errs }
            else {
              eprint(concat_all([
                file, ":", int_to_string(ip.pline), ":", int_to_string(ip.pcol),
                ": error: impl method `", op_name, "` in `",
                pname, " for ", tname,
                "`: parameter `", ip.pname,
                "` has type `", proto_type_expr_display(it),
                "` but protocol declares `", ph, "`"]))
              errs + 1
            }
          }
        }
        check_sig_param_heads(irest, prest, tname, proto_tps, arg_heads,
                              op_name, pname, file, errs1)
      }
    }
  }
}

# Substitute `Self` and protocol tparams against the impl target +
# bracket args, then collapse to the head name. Anything that doesn't
# bind (free tparam outside the protocol's own list, etc.) falls
# through to the standard `proto_type_name` collapse — head-name
# comparison is intentionally permissive about unresolved variables.
fn sig_head_subst(t: TypeExpr, tname: String,
                  proto_tps: [String], arg_heads: [String]) : String {
  match t.tkind {
    TyName(n, _) ->
      if n == "Self" { tname }
      else { match tparam_subst(n, proto_tps, arg_heads, tname) {
        Some(h) -> h
        None    -> proto_type_name(t)
      } }
    _ -> proto_type_name(t)
  }
}

# Position-aligned lookup: `proto_tps[i]` -> `arg_heads[i]`. When
# `arg_heads == []` (legacy un-parametrised impl), every protocol
# tparam falls back to the target head — the homogeneous default
# encoded in `lower_impls`. A tparam's stored name may carry a kind
# marker (`s#Shape`); the surface name is compared, so a `[s: Shape]`
# carrier binds `s := <target head>` exactly as a bare `[a]` does.
fn tparam_subst(n: String, tps: [String], heads: [String],
                tname: String) : Option[String] {
  match tps {
    [] -> None
    [t, ...trest] -> match heads {
      [] -> if tp_strip_kind(t) == n { Some(tname) } else { tparam_subst(n, trest, [], tname) }
      [h, ...hrest] ->
        if tp_strip_kind(t) == n { Some(h) } else { tparam_subst(n, trest, hrest, tname) }
    }
  }
}

# Walk every DImpl and (a) lower its methods into top-level DFns,
# (b) record (P, T) -> impl_fn_name in the registry. The fn body is
# the impl's original body verbatim; we only rename the function and
# leave the typer to do its work on the result.
fn lower_impls(ds: [Decl], reg: ProtocolReg, acc_fns: [Decl]) : LowerImplsRes {
  match ds {
    [] -> LowerImplsRes { reg: reg, fns: list_reverse(acc_fns) }
    [d, ...rest] -> match d {
      DImpl(pname, proto_args, target, methods, _, _) -> {
        let tname = proto_type_name(target)
        # Issue #180: derive the per-impl proto-arg name list. Empty
        # input list = legacy form, treated as `Ai = Self` (= [tname]).
        let arg_names = match proto_args {
          [] -> []
          _  -> map(proto_args, proto_type_name)
        }
        let r = lower_impl_methods(pname, tname, arg_names, methods, reg, acc_fns)
        lower_impls(rest, r.reg, r.fns)
      }
      DDerive(_, inner, _, _) -> lower_impls([inner, ...rest], reg, acc_fns)
      DUnstable(inner, _, _) -> lower_impls([inner, ...rest], reg, acc_fns)
      DProtoLaws(_, inner, _, _) -> lower_impls([inner, ...rest], reg, acc_fns)
      DImplAxiom(_, inner, _, _) -> lower_impls([inner, ...rest], reg, acc_fns)
      DConstructor(inner, _, _) -> lower_impls([inner, ...rest], reg, acc_fns)
      _ -> lower_impls(rest, reg, acc_fns)
    }
  }
}

type LowerImplsRes = { reg: ProtocolReg, fns: [Decl] }

# `acc_fns` accumulates in reverse; the caller list_reverses on
# return.
fn lower_impl_methods(pname: String, tname: String, arg_names: [String],
                      methods: [Decl],
                      reg: ProtocolReg, acc_fns: [Decl]) : LowerImplsRes {
  match methods {
    [] -> LowerImplsRes { reg: reg, fns: acc_fns }
    [d, ...rest] -> match d {
      DFn(_, op_name, tparams, params, ret, row, body, line, col, mo) -> {
        # Issue #180: only the heterogeneous case (Ai != Self) augments
        # the mangled name. The default-Self form keeps the legacy
        # mangling so `impl Add for Complex` and `impl Add[Complex] for
        # Complex` produce the same impl-fn name.
        let mangled = proto_impl_mangled_with_args(pname, tname, op_name, arg_names)
        let new_fn = DFn(false, mangled, tparams, params, ret, row, body, line, col, mo)
        let ret_head = match ret { Some(rte) -> proto_type_name(rte)  None -> tname }
        let entry = PIR(pname, tname, op_name, mangled, arg_names, ret_head)
        let reg1 = ProtocolReg {
          ops: reg.ops,
          impls: [entry, ...reg.impls],
          op_names: reg.op_names,
          tparams: reg.tparams,
          origins: reg.origins,
          impl_index: reg.impl_index
        }
        lower_impl_methods(pname, tname, arg_names, rest, reg1, [new_fn, ...acc_fns])
      }
      _ -> lower_impl_methods(pname, tname, arg_names, rest, reg, acc_fns)
    }
  }
}

# Generate one stub-dispatcher DFn per protocol op so the resolver
# and typer can treat `op(x, ...)` as a regular polymorphic call.
# The body panics; the post-inference rewrite redirects every reach-
# able call to the matching `__pimpl_*` function.
#
# Issue #597 boundary tagging: each dispatcher inherits the home
# module of the originating DProtocol via `reg.origins`. Root-file
# protocols still resolve to `mo = None`, so root-file selfhost
# stays byte-identical. Core protocols (the common case in
# `stdlib/protocols.kai`) now produce dispatchers tagged with the
# core's basename so a cache loader can partition post-cascade
# decls back into their original core/user segments.
fn generate_dispatchers(reg: ProtocolReg) : [Decl] =
  generate_dispatchers_loop(reg.ops, reg.origins,
                            op_arities_from_ops(reg.ops), [])

fn generate_dispatchers_loop(ops: [ProtoOpReg], origins: [ProtoOriginReg],
                                arities: [OpAr], acc: [Decl]) : [Decl] {
  match ops {
    [] -> acc
    [op, ...rest] -> match op {
      POR(pname, opname, params, ret, line, col) -> {
        # Dedup by the arity-resolved dispatcher NAME, not the bare op
        # name: an arity-ambiguous op (`f/1` + `f/2`) yields two
        # distinct dispatcher names, so both survive; same-arity
        # collisions still collapse to one shared dispatcher.
        let disp = proto_dispatcher_name_at(arities, opname, list_length(params))
        let already = dispatcher_named_in_acc(acc, disp)
        if already { generate_dispatchers_loop(rest, origins, arities, acc) }
        else {
          let mo = proto_origin_lookup(origins, pname)
          let stub = make_dispatcher_fn(pname, opname, disp, params, ret, line, col, mo)
          generate_dispatchers_loop(rest, origins, arities, [stub, ...acc])
        }
      }
    }
  }
}

fn dispatcher_named_in_acc(ds: [Decl], want: String) : Bool {
  match ds {
    [] -> false
    [d, ...rest] -> match d {
      DFn(_, n, _, _, _, _, _, _, _, _) ->
        if n == want { true } else { dispatcher_named_in_acc(rest, want) }
      _ -> dispatcher_named_in_acc(rest, want)
    }
  }
}

# `disp_name` is the arity-resolved dispatcher symbol (may carry an
# `__a<N>` suffix); `opname` is the original op name, kept for the
# dispatch tag so the post-inference rewrite and emit resolve the impl
# by the protocol's true op name.
fn make_dispatcher_fn(pname: String, opname: String, disp_name: String,
                       params: [Param], ret: TypeExpr, line: Int, col: Int,
                       mo: Option[String]) : Decl {
  let new_params = map(params, dispatcher_substitute_self_param)
  let new_ret = substitute_self_in_type(ret)
  let body = make_dispatcher_body(pname, opname, new_ret, line, col)
  DFn(true, disp_name, [], new_params, Some(new_ret),
      REmpty, body, line, col, mo)
}

# Synthesises an `ETodo` body tagged `__kai_proto_dispatch__:<P>:<op>`.
# The typer keeps treating the dispatcher as a regular polymorphic fn
# (ETodo is the same magic shape `body_is_ffi_extern` uses for FFI
# shims, see `proto_dispatch_tag` above). When the C / LLVM emit
# encounters this body, it generates a runtime-dispatch shim that
# looks up the matching `__pimpl_*` in the impl-table by
# `(proto_id, head_tag(self))` and tail-calls it — option C from
# `docs/protocols.md`. Post-inference rewrite still redirects every
# monomorphic call site directly to `__pimpl_<P>_<T>_<op>`, so the
# runtime lookup only runs when the type stays polymorphic past mono
# (e.g. inside the body of `impl[T : Show] Show for [T]`).
fn make_dispatcher_body(pname: String, opname: String, ret: TypeExpr,
                          line: Int, col: Int) : Expr =
  proto_mk_dispatch_body(pname, opname, line, col)

fn dispatcher_substitute_self_param(p: Param) : Param {
  match p.ptype {
    None -> p
    Some(te) -> Param { pname: p.pname, ptype: Some(substitute_self_in_type(te)),
                         pline: p.pline, pcol: p.pcol, pborrow: p.pborrow }
  }
}

fn substitute_self_in_type(te: TypeExpr) : TypeExpr {
  TypeExpr {
    tkind: substitute_self_in_kind(te.tkind),
    line: te.line, col: te.col
  }
}

fn substitute_self_in_kind(k: TyKind) : TyKind {
  match k {
    # `targs` (not `args`) — `args` is a core function name and the
    # stage-1 resolver does not let the pattern binding shadow the
    # core reference inside the body.
    TyName(name, targs) -> {
      let new_name = if name == "Self" { "proto_self" } else { name }
      TyName(new_name, map(targs, substitute_self_in_type))
    }
    TyList(inner) -> TyList(substitute_self_in_type(inner))
    TyFn(ps, ret, row) ->
      TyFn(map(ps, substitute_self_in_type), substitute_self_in_type(ret), row)
    # m12.5: substitute under the dimensioned base; the unit
    # expression is leaf data with no `Self` reference (units come
    # from the global unit table, not from the protocol's tparam).
    TyDim(base, u) -> TyDim(substitute_self_in_type(base), u)
    # m12.6.a: predicates do not contain TypeExpr nodes that mention
    # Self, so the predicate is left intact.
    TyRefine(base, p) -> TyRefine(substitute_self_in_type(base), p)
    # issue #772: a compound row carries effect labels, not `Self` —
    # passed through unchanged, matching the `TyFn` row above.
    TyRow(row) -> TyRow(row)
  }
}

# m12.8.x: validate that, before expansion, every `#derive(P)` on a
# sum type can be discharged: each variant field's head type must
# already have a registered impl of `P` reachable from this
# compilation unit (an explicit `impl P for T`, another `#derive(P)`
# on `T`, or a builtin from `derive_builtin_impl`). Records keep the
# pre-existing v1 behaviour (synthesise the impl, fall through to
# the runtime panic if an inner field has no impl).
fn validate_derives(ds: [Decl], file: String) : Int / Console {

  let future_impls = collect_future_impl_keys(ds, [])
  validate_derives_loop(ds, file, future_impls, 0)
}

fn collect_future_impl_keys(ds: [Decl], acc: [String]) : [String] {
  match ds {
    [] -> acc
    [d, ...rest] -> match d {
      DImpl(pname, _, target, _, _, _) ->
        collect_future_impl_keys(rest,
          [concat_all([pname, "/", proto_type_name(target)]), ...acc])
      DDerive(names, inner, _, _) -> {
        let acc1 = match inner {
          DType(_, tname, _, _, _, _, _, _) -> add_future_impl_keys(names, tname, acc)
          _ -> acc
        }
        collect_future_impl_keys(rest, acc1)
      }
      DUnstable(inner, _, _) ->
        collect_future_impl_keys([inner, ...rest], acc)
      DProtoLaws(_, inner, _, _) ->
        collect_future_impl_keys([inner, ...rest], acc)
      DImplAxiom(_, inner, _, _) ->
        collect_future_impl_keys([inner, ...rest], acc)
      DConstructor(inner, _, _) ->
        collect_future_impl_keys([inner, ...rest], acc)
      _ -> collect_future_impl_keys(rest, acc)
    }
  }
}

fn add_future_impl_keys(names: [String], tname: String, acc: [String]) : [String] {
  match names {
    [] -> acc
    [n, ...rest] ->
      add_future_impl_keys(rest, tname, [concat_all([n, "/", tname]), ...acc])
  }
}

# Builtin impls bundled with kaikai for primitive types, kept in
# sync with stdlib/protocols.kai. The validator treats these as
# always available so users do not have to redeclare `impl Eq for
# Int` in every fixture that derives Eq on a sum carrying Ints.
#[doc("True iff kaikai bundles a structural builtin impl of `pname` for primitive head `tname` (Eq/Show/Ord/Hash over Int/Real/String/... and fixed-width ints).")]
pub fn derive_builtin_impl(pname: String, tname: String) : Bool {
  if pname == "Eq" {
    list_has(["Int", "Real", "Bool", "String", "Char", "Unit"], tname) or is_fixed_width_name(tname)
  } else if pname == "Hash" {
    list_has(["Int", "Real", "String", "Bool", "Char"], tname) or is_fixed_width_name(tname)
  } else if pname == "Show" {
    list_has(["Int", "Real", "Bool", "String", "Unit", "Char"], tname) or is_fixed_width_name(tname)
  } else if pname == "Ord" {
    is_fixed_width_name(tname)
  } else { false }
}

fn validate_derives_loop(ds: [Decl], file: String,
                          future_impls: [String], errs: Int) : Int / Console {

  match ds {
    [] -> errs
    [d, ...rest] -> match d {
      DDerive(names, inner, line, col) -> {
        let errs1 = validate_derive_decl(names, inner, file, future_impls,
                                          line, col, errs)
        validate_derives_loop(rest, file, future_impls, errs1)
      }
      DUnstable(inner, _, _) ->
        validate_derives_loop([inner, ...rest], file, future_impls, errs)
      DProtoLaws(_, inner, _, _) ->
        validate_derives_loop([inner, ...rest], file, future_impls, errs)
      DImplAxiom(_, inner, _, _) ->
        validate_derives_loop([inner, ...rest], file, future_impls, errs)
      DConstructor(inner, _, _) ->
        validate_derives_loop([inner, ...rest], file, future_impls, errs)
      _ -> validate_derives_loop(rest, file, future_impls, errs)
    }
  }
}

fn validate_derive_decl(names: [String], inner: Decl, file: String,
                         future_impls: [String], dline: Int, dcol: Int,
                         errs: Int) : Int / Console {

  match inner {
    DType(_, tname, _, body, _, _, _, _) -> match body {
      TBSum(variants) -> validate_derive_sum_protos(names, tname, variants,
                                                     file, future_impls,
                                                     dline, dcol, errs)
      _ -> errs
    }
    _ -> errs
  }
}

fn validate_derive_sum_protos(names: [String], tname: String, variants: [Variant],
                                file: String, future_impls: [String],
                                line: Int, col: Int, errs: Int) : Int / Console {

  match names {
    [] -> errs
    [pname, ...rest] -> {
      let errs1 =
        if pname == "Eq" or pname == "Hash" {
          validate_derive_sum_variants(pname, tname, variants, file,
                                        future_impls, line, col, errs)
        } else { errs }
      validate_derive_sum_protos(rest, tname, variants, file, future_impls,
                                  line, col, errs1)
    }
  }
}

fn validate_derive_sum_variants(pname: String, tname: String, vs: [Variant],
                                 file: String, future_impls: [String],
                                 line: Int, col: Int, errs: Int) : Int / Console {

  match vs {
    [] -> errs
    [v, ...rest] -> match v {
      Var(vname, vargs) -> {
        let errs1 = validate_derive_variant_args(pname, tname, vname, vargs,
                                                  0, file, future_impls,
                                                  line, col, errs)
        validate_derive_sum_variants(pname, tname, rest, file, future_impls,
                                      line, col, errs1)
      }
    }
  }
}

fn validate_derive_variant_args(pname: String, tname: String, vname: String,
                                 vargs: [TypeExpr], i: Int, file: String,
                                 future_impls: [String], line: Int, col: Int,
                                 errs: Int) : Int / Console {
  match vargs {
    [] -> errs
    [te, ...rest] -> {
      let head = proto_type_name(te)
      let key = concat_all([pname, "/", head])
      let ok = list_has(future_impls, key) or derive_builtin_impl(pname, head)
      let errs1 =
        if ok { errs }
        else {
          eprint(concat_all([
            file, ":", int_to_string(line), ":", int_to_string(col),
            ": error: cannot derive `", pname, "` for `", tname,
            "`: variant `", vname, "` field #", int_to_string(i),
            " has type `", head,
            "` which has no `impl ", pname, " for ", head,
            "` in this compilation unit"]))
          errs + 1
        }
      validate_derive_variant_args(pname, tname, vname, rest, i + 1, file,
                                    future_impls, line, col, errs1)
    }
  }
}

# Phase 1: expand each `DDerive(names, type_decl)` into its wrapped
# DType followed by one synthetic DImpl per derived protocol.
# DProtocol and ordinary DImpl decls pass through unchanged so the
# next pass can collect them.
fn expand_derives(ds: [Decl]) : [Decl] = expand_derives_loop(ds, [])

fn expand_derives_loop(ds: [Decl], acc: [Decl]) : [Decl] {
  match ds {
    [] -> list_reverse(acc)
    [d, ...rest] -> match d {
      DDerive(names, inner, _, _) -> {
        let derived = derive_impls_for(names, inner)
        expand_derives_loop(rest, list_append([inner, ...list_reverse(derived)], acc))
      }
      DUnstable(inner, _, _) ->
        expand_derives_loop([inner, ...rest], acc)
      # Preserve the wrapper: the `#[constructor]` registry is collected
      # in the typer, so unwrapping here (as DUnstable does) would lose
      # it. The inner is a plain fn — no derives to expand.
      DProtoLaws(_, _, _, _) -> expand_derives_loop(rest, [d, ...acc])
      DImplAxiom(_, _, _, _) -> expand_derives_loop(rest, [d, ...acc])
      DConstructor(_, _, _) -> expand_derives_loop(rest, [d, ...acc])
      _ -> expand_derives_loop(rest, [d, ...acc])
    }
  }
}

# Phase 2: drop every DProtocol / DImpl from the decl stream after
# the impl-lowering pass has copied their content into ordinary
# DFns. DDerive nodes have already been replaced by `expand_derives`.
fn strip_protocols(ds: [Decl]) : [Decl] = strip_protocols_loop(ds, [])

fn strip_protocols_loop(ds: [Decl], acc: [Decl]) : [Decl] {
  match ds {
    [] -> list_reverse(acc)
    [d, ...rest] -> match d {
      DProtocol(_, _, _, _, _, _) -> strip_protocols_loop(rest, acc)
      DImpl(_, _, _, _, _, _)     -> strip_protocols_loop(rest, acc)
      DDerive(_, _, _, _)      -> strip_protocols_loop(rest, acc)
      _ -> strip_protocols_loop(rest, [d, ...acc])
    }
  }
}

# Generate structural impls for #derive(P, ...) on the wrapped
# DType. Walks the type body and synthesises one DImpl per derived
# protocol. Records produce field-by-field ops; sum types produce
# variant-by-variant match arms. Each synthesised impl body invokes
# the protocol's own ops on the inner fields, so the fields' types
# must already implement the same protocol — checked transitively
# by the typer / resolver after lowering.
fn derive_impls_for(names: [String], dt: Decl) : [Decl] {
  match dt {
    DType(_, tname, _, body, line, col, _, _) ->
      derive_impls_loop(names, tname, body, line, col, [])
    _ -> []
  }
}

fn derive_impls_loop(names: [String], tname: String, body: TypeBody,
                      line: Int, col: Int, acc: [Decl]) : [Decl] {
  match names {
    [] -> list_reverse(acc)
    [pname, ...rest] -> {
      let ds = derive_impl_for_protocol(pname, tname, body, line, col)
      derive_impls_loop(rest, tname, body, line, col,
                        list_append(list_reverse(ds), acc))
    }
  }
}

# Synthesise zero or more decls for `#derive(P) type T = ...`. v1
# supports `Show`, `Eq`, `Hash`, `Ord`, and `BinSerialize` on records
# and sum types. The returned list is empty when the (P, body)
# combination is unsupported (the resolver / typer surfaces that as
# "no impl"). Most protocols return a single `DImpl`; `BinSerialize`
# additionally returns a top-level `<tname>_from_bytes` shim because
# v1 single-dispatch cannot route a return-type-only call (issue
# #459 §"Two design routes" + the `Serialize` prologue in
# `stdlib/protocols.kai`).
fn derive_impl_for_protocol(pname: String, tname: String, body: TypeBody,
                             line: Int, col: Int) : [Decl] {
  if pname == "Show" {
    option_to_list(derive_show_impl(tname, body, line, col))
  } else if pname == "Eq" {
    option_to_list(derive_eq_impl(tname, body, line, col))
  } else if pname == "Hash" {
    option_to_list(derive_hash_impl(tname, body, line, col))
  } else if pname == "Ord" {
    option_to_list(derive_ord_impl(tname, body, line, col))
  } else if pname == "BinSerialize" {
    derive_binserialize_impl(tname, body, line, col)
  } else if pname == "Layout" {
    derive_layout_impl(tname, body, line, col)
  } else {
    []
  }
}

fn option_to_list(o: Option[Decl]) : [Decl] = match o {
  None    -> []
  Some(d) -> [d]
}

fn derive_show_impl(tname: String, body: TypeBody, line: Int, col: Int) : Option[Decl] {
  match body {
    TBRecord(fields) -> {
      let body_expr = derive_show_record_body(tname, fields, line, col)
      Some(make_derived_impl("Show", tname, "show",
        [Param { pname: "x", ptype: Some(mk_ty(TyName(tname, []), line, col)),
                 pline: line, pcol: col, pborrow: false }],
        mk_ty(TyName("String", []), line, col),
        body_expr, line, col))
    }
    TBSum(variants) -> {
      let body_expr = derive_show_sum_body(variants, line, col)
      Some(make_derived_impl("Show", tname, "show",
        [Param { pname: "x", ptype: Some(mk_ty(TyName(tname, []), line, col)),
                 pline: line, pcol: col, pborrow: false }],
        mk_ty(TyName("String", []), line, col),
        body_expr, line, col))
    }
    _ -> None
  }
}

fn derive_show_record_body(tname: String, fields: [FieldDecl], line: Int, col: Int) : Expr {
  let parts = derive_show_record_parts(tname, fields, line, col)
  mk_expr(ECall(mk_expr(EVar("string_concat_all"), line, col),
                [mk_expr(EList(map(parts, (e: Expr) => ElPlain(e))), line, col)]),
          line, col)
}

fn derive_show_record_parts(tname: String, fields: [FieldDecl], line: Int, col: Int) : [Expr] {
  let head = mk_expr(EStr(concat_all(["\"", tname, " { \""]), false), line, col)
  let body_parts = derive_show_field_parts(fields, line, col, true)
  let tail = mk_expr(EStr("\" }\"", false), line, col)
  list_append([head, ...body_parts], [tail])
}

fn derive_show_field_parts(fields: [FieldDecl], line: Int, col: Int, first: Bool) : [Expr] {
  match fields {
    [] -> []
    [fd, ...rest] -> match fd {
      FD(_, name, _) -> {
        let prefix_s = if first { concat_all(["\"", name, ": \""]) }
                       else { concat_all(["\", ", name, ": \""]) }
        let prefix = mk_expr(EStr(prefix_s, false), line, col)
        let access = mk_expr(EField(mk_expr(EVar("x"), line, col), name), line, col)
        let call = mk_expr(ECall(mk_expr(EVar("show"), line, col), [access]), line, col)
        list_append([prefix, call], derive_show_field_parts(rest, line, col, false))
      }
    }
  }
}

fn derive_show_sum_body(variants: [Variant], line: Int, col: Int) : Expr {
  let scrut = mk_expr(EVar("x"), line, col)
  let arms = map(variants, (v) => derive_show_sum_arm(v, line, col))
  mk_expr(EMatch(scrut, arms), line, col)
}

fn derive_show_sum_arm(v: Variant, line: Int, col: Int) : Arm {
  match v {
    Var(name, vargs) -> {
      let pat_subs = derive_sum_pat_subs(vargs, 0, line, col)
      let pat = mk_pat(PVariant(name, pat_subs), line, col)
      let body = derive_show_sum_arm_body(name, vargs, line, col)
      Arm(pat, None, body)
    }
  }
}

fn derive_sum_pat_subs(vargs: [TypeExpr], i: Int, line: Int, col: Int) : [Pattern] {
  match vargs {
    [] -> []
    [_, ...rest] ->
      [mk_pat(PBind(concat_all(["a", int_to_string(i)])), line, col),
       ...derive_sum_pat_subs(rest, i + 1, line, col)]
  }
}

fn derive_show_sum_arm_body(name: String, vargs: [TypeExpr], line: Int, col: Int) : Expr {
  match vargs {
    [] -> mk_expr(EStr(concat_all(["\"", name, "\""]), false), line, col)
    _  -> {
      let head = mk_expr(EStr(concat_all(["\"", name, "(\""]), false), line, col)
      let tail = mk_expr(EStr("\")\"", false), line, col)
      let calls = derive_sum_arg_show_calls(vargs, 0, line, col, true)
      let parts = list_append([head, ...calls], [tail])
      mk_expr(ECall(mk_expr(EVar("string_concat_all"), line, col),
                    [mk_expr(EList(map(parts, (e: Expr) => ElPlain(e))), line, col)]),
              line, col)
    }
  }
}

fn derive_sum_arg_show_calls(vargs: [TypeExpr], i: Int, line: Int, col: Int, first: Bool) : [Expr] {
  match vargs {
    [] -> []
    [_, ...rest] -> {
      let prefix = if first { mk_expr(EStr("\"\"", false), line, col) }
                   else { mk_expr(EStr("\", \"", false), line, col) }
      let av = mk_expr(EVar(concat_all(["a", int_to_string(i)])), line, col)
      let call = mk_expr(ECall(mk_expr(EVar("show"), line, col), [av]), line, col)
      list_append([prefix, call], derive_sum_arg_show_calls(rest, i + 1, line, col, false))
    }
  }
}

fn derive_eq_impl(tname: String, body: TypeBody, line: Int, col: Int) : Option[Decl] {
  match body {
    TBRecord(fields) -> {
      let body_expr = derive_eq_record_body(fields, line, col)
      Some(make_derived_impl("Eq", tname, "eq",
        [Param { pname: "a", ptype: Some(mk_ty(TyName(tname, []), line, col)),
                 pline: line, pcol: col, pborrow: false },
         Param { pname: "b", ptype: Some(mk_ty(TyName(tname, []), line, col)),
                 pline: line, pcol: col, pborrow: false }],
        mk_ty(TyName("Bool", []), line, col),
        body_expr, line, col))
    }
    TBSum(variants) -> {
      let body_expr = derive_eq_sum_body(variants, line, col)
      Some(make_derived_impl("Eq", tname, "eq",
        [Param { pname: "a", ptype: Some(mk_ty(TyName(tname, []), line, col)),
                 pline: line, pcol: col, pborrow: false },
         Param { pname: "b", ptype: Some(mk_ty(TyName(tname, []), line, col)),
                 pline: line, pcol: col, pborrow: false }],
        mk_ty(TyName("Bool", []), line, col),
        body_expr, line, col))
    }
    _ -> None
  }
}

fn derive_eq_record_body(fields: [FieldDecl], line: Int, col: Int) : Expr {
  match fields {
    [] -> mk_expr(EBool(true), line, col)
    [fd, ...rest] -> derive_eq_record_chain(fd, rest, line, col)
  }
}

fn derive_eq_record_chain(head: FieldDecl, rest: [FieldDecl], line: Int, col: Int) : Expr {
  match head {
    FD(_, name, _) -> {
      let l_access = mk_expr(EField(mk_expr(EVar("a"), line, col), name), line, col)
      let r_access = mk_expr(EField(mk_expr(EVar("b"), line, col), name), line, col)
      let call = mk_expr(ECall(mk_expr(EVar("eq"), line, col), [l_access, r_access]),
                         line, col)
      match rest {
        [] -> call
        [next, ...more] -> {
          let tail_e = derive_eq_record_chain(next, more, line, col)
          mk_expr(EBinop("and", call, tail_e), line, col)
        }
      }
    }
  }
}

# m12.8.x: `#derive(Eq)` on a sum type. Outer-match on `a`, one arm
# per variant; each arm rematches `b` for the same variant
# (returning `eq(la_0, lb_0) and eq(la_1, lb_1) and ...`) with a
# wildcard arm returning `false`. Empty sums (no variants) are
# defensive; the parser does not produce them today.
fn derive_eq_sum_body(variants: [Variant], line: Int, col: Int) : Expr {
  match variants {
    [] -> mk_expr(EBool(false), line, col)
    _  -> {
      let scrut = mk_expr(EVar("a"), line, col)
      let arms = map(variants, (v) => derive_eq_sum_outer_arm(v, line, col))
      mk_expr(EMatch(scrut, arms), line, col)
    }
  }
}

fn derive_eq_sum_outer_arm(v: Variant, line: Int, col: Int) : Arm {
  match v {
    Var(name, vargs) -> {
      let pat_subs = derive_eq_sum_pat_subs("la_", vargs, 0, line, col)
      let pat = mk_pat(PVariant(name, pat_subs), line, col)
      let inner = derive_eq_sum_inner_match(name, vargs, line, col)
      Arm(pat, None, inner)
    }
  }
}

fn derive_eq_sum_inner_match(name: String, vargs: [TypeExpr], line: Int, col: Int) : Expr {
  let scrut = mk_expr(EVar("b"), line, col)
  let pat_subs = derive_eq_sum_pat_subs("lb_", vargs, 0, line, col)
  let match_pat = mk_pat(PVariant(name, pat_subs), line, col)
  let body = derive_eq_sum_field_chain(vargs, 0, line, col)
  let arm_match = Arm(match_pat, None, body)
  let arm_wild  = Arm(mk_pat(PWild, line, col), None,
                      mk_expr(EBool(false), line, col))
  mk_expr(EMatch(scrut, [arm_match, arm_wild]), line, col)
}

fn derive_eq_sum_pat_subs(prefix: String, vargs: [TypeExpr], i: Int,
                           line: Int, col: Int) : [Pattern] {
  match vargs {
    [] -> []
    [_, ...rest] ->
      [mk_pat(PBind(concat_all([prefix, int_to_string(i)])), line, col),
       ...derive_eq_sum_pat_subs(prefix, rest, i + 1, line, col)]
  }
}

fn derive_eq_sum_field_chain(vargs: [TypeExpr], i: Int, line: Int, col: Int) : Expr {
  match vargs {
    [] -> mk_expr(EBool(true), line, col)
    [_, ...rest] -> {
      let l = mk_expr(EVar(concat_all(["la_", int_to_string(i)])), line, col)
      let r = mk_expr(EVar(concat_all(["lb_", int_to_string(i)])), line, col)
      let call = mk_expr(ECall(mk_expr(EVar("eq"), line, col), [l, r]), line, col)
      match rest {
        [] -> call
        _  -> {
          let tail = derive_eq_sum_field_chain(rest, i + 1, line, col)
          mk_expr(EBinop("and", call, tail), line, col)
        }
      }
    }
  }
}

fn derive_hash_impl(tname: String, body: TypeBody, line: Int, col: Int) : Option[Decl] {
  match body {
    TBRecord(fields) -> {
      let body_expr = derive_hash_record_body(fields, line, col)
      Some(make_derived_impl("Hash", tname, "hash",
        [Param { pname: "x", ptype: Some(mk_ty(TyName(tname, []), line, col)),
                 pline: line, pcol: col, pborrow: false }],
        mk_ty(TyName("Int", []), line, col),
        body_expr, line, col))
    }
    TBSum(variants) -> {
      let body_expr = derive_hash_sum_body(variants, line, col)
      Some(make_derived_impl("Hash", tname, "hash",
        [Param { pname: "x", ptype: Some(mk_ty(TyName(tname, []), line, col)),
                 pline: line, pcol: col, pborrow: false }],
        mk_ty(TyName("Int", []), line, col),
        body_expr, line, col))
    }
    _ -> None
  }
}

fn derive_hash_record_body(fields: [FieldDecl], line: Int, col: Int) : Expr {
  match fields {
    [] -> mk_expr(EInt(0), line, col)
    [fd, ...rest] -> derive_hash_record_chain(fd, rest, line, col)
  }
}

fn derive_hash_record_chain(head: FieldDecl, rest: [FieldDecl], line: Int, col: Int) : Expr {
  match head {
    FD(_, name, _) -> {
      let access = mk_expr(EField(mk_expr(EVar("x"), line, col), name), line, col)
      let call = mk_expr(ECall(mk_expr(EVar("hash"), line, col), [access]), line, col)
      match rest {
        [] -> call
        [next, ...more] -> {
          let tail_e = derive_hash_record_chain(next, more, line, col)
          let mul = mk_expr(EBinop("*", call, mk_expr(EInt(31), line, col)), line, col)
          mk_expr(EBinop("+", mul, tail_e), line, col)
        }
      }
    }
  }
}

# m12.8.x: `#derive(Hash)` on a sum type. Match on the value, one arm
# per variant; each arm seeds the running accumulator with the
# variant's 1-based tag and folds in `hash(field)` using the same
# `acc * 31 + h` combination the record helper uses, so two values
# that are eq via the derived Eq hash to the same Int.
fn derive_hash_sum_body(variants: [Variant], line: Int, col: Int) : Expr {
  match variants {
    [] -> mk_expr(EInt(0), line, col)
    _  -> {
      let scrut = mk_expr(EVar("x"), line, col)
      let arms = derive_hash_sum_arms(variants, 1, line, col)
      mk_expr(EMatch(scrut, arms), line, col)
    }
  }
}

fn derive_hash_sum_arms(vs: [Variant], tag: Int, line: Int, col: Int) : [Arm] {
  match vs {
    [] -> []
    [v, ...rest] ->
      [derive_hash_sum_arm(v, tag, line, col),
       ...derive_hash_sum_arms(rest, tag + 1, line, col)]
  }
}

fn derive_hash_sum_arm(v: Variant, tag: Int, line: Int, col: Int) : Arm {
  match v {
    Var(name, vargs) -> {
      let pat_subs = derive_eq_sum_pat_subs("h_", vargs, 0, line, col)
      let pat = mk_pat(PVariant(name, pat_subs), line, col)
      let body = derive_hash_sum_arm_body(vargs, tag, line, col)
      Arm(pat, None, body)
    }
  }
}

fn derive_hash_sum_arm_body(vargs: [TypeExpr], tag: Int, line: Int, col: Int) : Expr {
  let head = mk_expr(EInt(tag), line, col)
  derive_hash_sum_chain(head, vargs, 0, line, col)
}

fn derive_hash_sum_chain(acc: Expr, vargs: [TypeExpr], i: Int,
                          line: Int, col: Int) : Expr {
  match vargs {
    [] -> acc
    [_, ...rest] -> {
      let v = mk_expr(EVar(concat_all(["h_", int_to_string(i)])), line, col)
      let h = mk_expr(ECall(mk_expr(EVar("hash"), line, col), [v]), line, col)
      let mul = mk_expr(EBinop("*", acc, mk_expr(EInt(31), line, col)), line, col)
      let next = mk_expr(EBinop("+", mul, h), line, col)
      derive_hash_sum_chain(next, rest, i + 1, line, col)
    }
  }
}

# m12.8.z: `#derive(Ord)` synthesises three methods to satisfy the
# stdlib `protocol Ord { cmp, min, max }`:
#
#   - `cmp(a, b) : Int` — the load-bearing comparator. Records are
#     lexicographic (compare each field in declaration order, return
#     the first non-zero); sum types are variants-by-position with a
#     payload-lexicographic tie-breaker inside the same variant.
#   - `min(a, b) : Self` — `if cmp(a, b) <= 0 { a } else { b }`,
#     derived from the synthesised `cmp` above.
#   - `max(a, b) : Self` — `if cmp(a, b) >= 0 { a } else { b }`.
#
# `cmp` delegates to each field/payload's own `cmp`, so the typer
# transitively rejects the derive if any sub-component lacks an
# `Ord` impl — naming the missing call site in the diagnostic.
# `min` and `max` only call the just-synthesised `cmp`, so they
# carry no extra requirement on sub-types.
fn derive_ord_impl(tname: String, body: TypeBody, line: Int, col: Int) : Option[Decl] {
  match body {
    TBRecord(fields) ->
      Some(derive_ord_make_impl(tname, derive_ord_record_body(fields, line, col), line, col))
    TBSum(variants) ->
      Some(derive_ord_make_impl(tname, derive_ord_sum_body(variants, line, col), line, col))
    _ -> None
  }
}

# Build the three-method `impl Ord for T` given a ready-to-use `cmp`
# body expression. Factored out so the record / sum arms above share
# the impl assembly, and so `min` / `max` are produced in one place.
fn derive_ord_make_impl(tname: String, cmp_body: Expr, line: Int, col: Int) : Decl {
  let self_ty = mk_ty(TyName(tname, []), line, col)
  let int_ty = mk_ty(TyName("Int", []), line, col)
  let params2 = [
    Param { pname: "a", ptype: Some(self_ty), pline: line, pcol: col, pborrow: false },
    Param { pname: "b", ptype: Some(self_ty), pline: line, pcol: col, pborrow: false }
  ]
  let cmp_method = DFn(false, "cmp", [], params2, Some(int_ty), REmpty,
                          cmp_body, line, col, None)
  # Body of min: `if cmp(a, b) <= 0 { a } else { b }`.
  # Body of max: `if cmp(a, b) >= 0 { a } else { b }`.
  let a_var = mk_expr(EVar("a"), line, col)
  let b_var = mk_expr(EVar("b"), line, col)
  let zero = mk_expr(EInt(0), line, col)
  let cmp_call_min = mk_expr(ECall(mk_expr(EVar("cmp"), line, col),
                                       [a_var, b_var]), line, col)
  let cmp_call_max = mk_expr(ECall(mk_expr(EVar("cmp"), line, col),
                                       [a_var, b_var]), line, col)
  let min_body = mk_expr(EIf(
    mk_expr(EBinop("<=", cmp_call_min, zero), line, col),
    a_var, Some(b_var)), line, col)
  let max_body = mk_expr(EIf(
    mk_expr(EBinop(">=", cmp_call_max, zero), line, col),
    a_var, Some(b_var)), line, col)
  let min_method = DFn(false, "min", [], params2, Some(self_ty), REmpty,
                          min_body, line, col, None)
  let max_method = DFn(false, "max", [], params2, Some(self_ty), REmpty,
                          max_body, line, col, None)
  DImpl("Ord", [], self_ty, [cmp_method, min_method, max_method], line, col)
}

fn derive_ord_record_body(fields: [FieldDecl], line: Int, col: Int) : Expr {
  match fields {
    [] -> mk_expr(EInt(0), line, col)
    [fd, ...rest] -> derive_ord_record_chain(fd, rest, 0, line, col)
  }
}

fn derive_ord_record_chain(head: FieldDecl, rest: [FieldDecl], idx: Int,
                            line: Int, col: Int) : Expr {
  match head {
    FD(_, name, _) -> {
      let l_access = mk_expr(EField(mk_expr(EVar("a"), line, col), name), line, col)
      let r_access = mk_expr(EField(mk_expr(EVar("b"), line, col), name), line, col)
      let cmp_call = mk_expr(ECall(mk_expr(EVar("cmp"), line, col),
                                    [l_access, r_access]),
                             line, col)
      match rest {
        [] -> cmp_call
        [next, ...more] -> {
          let cvar = concat_all(["c", int_to_string(idx)])
          let pat = mk_pat(PBind(cvar), line, col)
          let let_stmt = SLet(pat, None, cmp_call)
          let cond = mk_expr(EBinop("!=", mk_expr(EVar(cvar), line, col),
                                          mk_expr(EInt(0), line, col)),
                             line, col)
          let then_e = mk_expr(EVar(cvar), line, col)
          let else_e = derive_ord_record_chain(next, more, idx + 1, line, col)
          let if_e = mk_expr(EIf(cond, then_e, Some(else_e)), line, col)
          mk_expr(EBlock([let_stmt], Some(if_e)), line, col)
        }
      }
    }
  }
}

fn derive_ord_sum_body(variants: [Variant], line: Int, col: Int) : Expr {
  let scrut = mk_expr(EVar("a"), line, col)
  let arms = derive_ord_sum_outer_arms(variants, variants, 0, line, col)
  mk_expr(EMatch(scrut, arms), line, col)
}

fn derive_ord_sum_outer_arms(remaining: [Variant], all_variants: [Variant],
                              idx: Int, line: Int, col: Int) : [Arm] {
  match remaining {
    [] -> []
    [v, ...rest] -> {
      let arm = derive_ord_sum_outer_arm(v, all_variants, idx, line, col)
      [arm, ...derive_ord_sum_outer_arms(rest, all_variants, idx + 1, line, col)]
    }
  }
}

fn derive_ord_sum_outer_arm(outer_v: Variant, all_variants: [Variant],
                             outer_idx: Int, line: Int, col: Int) : Arm {
  match outer_v {
    Var(name, vargs) -> {
      let outer_pat_subs = derive_ord_sum_pat_subs(vargs, "a", 0, line, col)
      let outer_pat = mk_pat(PVariant(name, outer_pat_subs), line, col)
      let inner = derive_ord_sum_inner_match(outer_v, outer_idx,
                                              all_variants, line, col)
      Arm(outer_pat, None, inner)
    }
  }
}

# Like `derive_sum_pat_subs`, but lets the caller pick the binder
# prefix so the inner match can use `b0/b1/...` instead of `a0/a1/...`.
fn derive_ord_sum_pat_subs(vargs: [TypeExpr], prefix: String, i: Int,
                            line: Int, col: Int) : [Pattern] {
  match vargs {
    [] -> []
    [_, ...rest] ->
      [mk_pat(PBind(concat_all([prefix, int_to_string(i)])), line, col),
       ...derive_ord_sum_pat_subs(rest, prefix, i + 1, line, col)]
  }
}

fn derive_ord_sum_inner_match(outer_v: Variant, outer_idx: Int,
                               all_variants: [Variant], line: Int, col: Int) : Expr {
  let scrut = mk_expr(EVar("b"), line, col)
  let arms = derive_ord_sum_inner_arms(outer_v, outer_idx, all_variants,
                                        0, line, col)
  mk_expr(EMatch(scrut, arms), line, col)
}

# Generates the inner-match arms for one outer variant. For each
# variant in the type's declaration, with index `idx`:
#   - idx <  outer_idx → that variant comes earlier in declaration
#                         order, so `cmp(outer, that) == 1`. Emit an
#                         explicit `Variant(_, _, ...) -> 1` arm.
#   - idx == outer_idx → same variant: emit `Variant(b0, b1, ...) ->
#                         <payload chain>`. After the self arm, fold
#                         every later variant under a single
#                         `_ -> -1` wildcard and stop.
fn derive_ord_sum_inner_arms(outer_v: Variant, outer_idx: Int,
                              variants: [Variant], idx: Int,
                              line: Int, col: Int) : [Arm] {
  match variants {
    [] -> []
    [v, ...rest] -> {
      if idx < outer_idx {
        let arm = derive_ord_sum_wild_arm(v, 1, line, col)
        [arm, ...derive_ord_sum_inner_arms(outer_v, outer_idx, rest,
                                            idx + 1, line, col)]
      } else if idx == outer_idx {
        let self_arm = derive_ord_sum_self_arm(outer_v, line, col)
        match rest {
          [] -> [self_arm]
          _  -> [self_arm, derive_ord_sum_default_arm(-1, line, col)]
        }
      } else {
        # Defensive: outer_idx is always within bounds, so this
        # branch is unreachable. Returning [] keeps the recursion
        # well-typed without an extra `panic`.
        []
      }
    }
  }
}

# `Variant(_, _, ...) -> <int>` — used for variants on the "wrong"
# side of the outer-vs-inner comparison.
fn derive_ord_sum_wild_arm(v: Variant, ret: Int, line: Int, col: Int) : Arm {
  match v {
    Var(name, vargs) -> {
      let pats = derive_ord_sum_wild_pats(vargs, line, col)
      let pat = mk_pat(PVariant(name, pats), line, col)
      Arm(pat, None, mk_expr(EInt(ret), line, col))
    }
  }
}

fn derive_ord_sum_wild_pats(vargs: [TypeExpr], line: Int, col: Int) : [Pattern] {
  match vargs {
    [] -> []
    [_, ...rest] ->
      [mk_pat(PWild, line, col),
       ...derive_ord_sum_wild_pats(rest, line, col)]
  }
}

# `_ -> <int>` — covers every variant after the outer's position.
fn derive_ord_sum_default_arm(ret: Int, line: Int, col: Int) : Arm {
  Arm(mk_pat(PWild, line, col), None, mk_expr(EInt(ret), line, col))
}

# `Variant(b0, b1, ...) -> <payload chain>` — the same-variant case.
# Payloads are compared field-by-field in declaration order; the
# first non-zero `cmp` wins.
fn derive_ord_sum_self_arm(v: Variant, line: Int, col: Int) : Arm {
  match v {
    Var(name, vargs) -> {
      let inner_pat_subs = derive_ord_sum_pat_subs(vargs, "b", 0, line, col)
      let pat = mk_pat(PVariant(name, inner_pat_subs), line, col)
      let body = derive_ord_payload_chain(vargs, 0, line, col)
      Arm(pat, None, body)
    }
  }
}

fn derive_ord_payload_chain(vargs: [TypeExpr], idx: Int,
                             line: Int, col: Int) : Expr {
  match vargs {
    [] -> mk_expr(EInt(0), line, col)
    [_, ...rest] -> {
      let av = mk_expr(EVar(concat_all(["a", int_to_string(idx)])), line, col)
      let bv = mk_expr(EVar(concat_all(["b", int_to_string(idx)])), line, col)
      let cmp_call = mk_expr(ECall(mk_expr(EVar("cmp"), line, col), [av, bv]),
                             line, col)
      match rest {
        [] -> cmp_call
        _  -> {
          let cvar = concat_all(["p", int_to_string(idx)])
          let pat = mk_pat(PBind(cvar), line, col)
          let let_stmt = SLet(pat, None, cmp_call)
          let cond = mk_expr(EBinop("!=", mk_expr(EVar(cvar), line, col),
                                          mk_expr(EInt(0), line, col)),
                             line, col)
          let then_e = mk_expr(EVar(cvar), line, col)
          let else_e = derive_ord_payload_chain(rest, idx + 1, line, col)
          let if_e = mk_expr(EIf(cond, then_e, Some(else_e)), line, col)
          mk_expr(EBlock([let_stmt], Some(if_e)), line, col)
        }
      }
    }
  }
}

fn make_derived_impl(pname: String, tname: String, opname: String,
                      params: [Param], ret: TypeExpr, body: Expr,
                      line: Int, col: Int) : Decl {
  let method = DFn(false, opname, [], params, Some(ret), REmpty, body, line, col, None)
  DImpl(pname, [], mk_ty(TyName(tname, []), line, col), [method], line, col)
}

# issue #459: `#derive(BinSerialize)` for records and sum types.
# Synthesises a two-method `impl BinSerialize for T` (`to_bytes`
# dispatches on Self via the first arg, `from_bytes` cannot — see
# the wrapper rationale below) plus a top-level `<lower(tname)>_from_bytes`
# shim that gives the user a non-overloaded entry point. Field /
# payload decoding routes to `__pimpl_BinSerialize_<TypeHead>_from_bytes`
# directly because v1 single-dispatch picks the impl from the first
# argument's type, and `from_bytes(buf, pos)` would always pick the
# `Array` impl on the buffer — which does not exist and never should
# (the buffer head and the encoded type's head would collide).
# Post-#487 the buffer type is `Array[Byte]` (was `[Byte]`); the
# combinator surface stays the same.
fn derive_binserialize_impl(tname: String, body: TypeBody,
                              line: Int, col: Int) : [Decl] {
  match body {
    TBRecord(fields) -> {
      let to_b = derive_binser_record_to_bytes(fields, line, col)
      let from_b = derive_binser_record_from_bytes(tname, fields, line, col)
      let impl_d = make_binser_impl(tname, to_b, from_b, line, col)
      let shim_d = derive_binser_shim(tname, line, col)
      [impl_d, shim_d]
    }
    TBSum(variants) -> {
      let to_b = derive_binser_sum_to_bytes(variants, line, col)
      let from_b = derive_binser_sum_from_bytes(tname, variants, line, col)
      let impl_d = make_binser_impl(tname, to_b, from_b, line, col)
      let shim_d = derive_binser_shim(tname, line, col)
      [impl_d, shim_d]
    }
    _ -> []
  }
}

# `impl BinSerialize for T { fn to_bytes ... fn from_bytes ... }`
#
# Uses `Array[Byte]` for the buffer carrier so `from_bytes` reads land
# on O(1) `array_get` — the substrate the Phase A cache (#452)
# requires, per the #487 refactor. `Byte` is a first-class nominal
# primitive after Lane 4 + PR #476; the previous `Byte = Int`
# transparent alias is gone. `byte_to_int` / `int_to_byte` are the
# explicit conversions when interoperating with `Int` data.
fn make_binser_impl(tname: String, to_b: Expr, from_b: Expr,
                     line: Int, col: Int) : Decl {
  let self_ty = mk_ty(TyName(tname, []), line, col)
  let byte_arr = mk_ty(TyName("Array", [mk_ty(TyName("Byte", []), line, col)]), line, col)
  let int_ty = mk_ty(TyName("Int", []), line, col)
  let str_ty = mk_ty(TyName("String", []), line, col)
  let cur_ty = mk_ty(TyName("BinCursor", [self_ty]), line, col)
  let res_ty = mk_ty(TyName("Result", [cur_ty, str_ty]), line, col)
  let to_params = [Param { pname: "self", ptype: Some(self_ty),
                            pline: line, pcol: col, pborrow: false }]
  let from_params = [Param { pname: "buf", ptype: Some(byte_arr),
                              pline: line, pcol: col, pborrow: false },
                     Param { pname: "pos", ptype: Some(int_ty),
                              pline: line, pcol: col, pborrow: false }]
  let to_method = DFn(false, "to_bytes", [], to_params, Some(byte_arr),
                      REmpty, to_b, line, col, None)
  let from_method = DFn(false, "from_bytes", [], from_params, Some(res_ty),
                        REmpty, from_b, line, col, None)
  DImpl("BinSerialize", [], self_ty, [to_method, from_method], line, col)
}

# `fn <lower(tname)>_from_bytes(buf: Array[Byte], pos: Int)
#       : Result[BinCursor[T], String]`
# wrapping the mangled per-impl name. The shim decouples the user's
# call site from the dispatcher's first-arg constraint and gives the
# diagnostic stack a stable function name when the decode fails.
fn derive_binser_shim(tname: String, line: Int, col: Int) : Decl {
  let self_ty = mk_ty(TyName(tname, []), line, col)
  let byte_arr = mk_ty(TyName("Array", [mk_ty(TyName("Byte", []), line, col)]), line, col)
  let int_ty = mk_ty(TyName("Int", []), line, col)
  let str_ty = mk_ty(TyName("String", []), line, col)
  let cur_ty = mk_ty(TyName("BinCursor", [self_ty]), line, col)
  let res_ty = mk_ty(TyName("Result", [cur_ty, str_ty]), line, col)
  let params = [Param { pname: "buf", ptype: Some(byte_arr),
                         pline: line, pcol: col, pborrow: false },
                Param { pname: "pos", ptype: Some(int_ty),
                         pline: line, pcol: col, pborrow: false }]
  let mangled = proto_mangled_fn("BinSerialize", tname, "from_bytes")
  let body = mk_expr(ECall(mk_expr(EVar(mangled), line, col),
                            [mk_expr(EVar("buf"), line, col),
                             mk_expr(EVar("pos"), line, col)]),
                     line, col)
  DFn(true, concat_all([string_to_lower_ascii(tname), "_from_bytes"]),
      [], params, Some(res_ty), REmpty, body, line, col, None)
}

# Lowercase every ASCII byte of `tname` so the shim name
# (`<lower(tname)>_from_bytes`) is a valid all-lowercase identifier
# even for types like `Point`, `MyAST`, or `IntMaybe`. We do NOT
# insert underscores between cased segments — the simple form
# `intmaybe_from_bytes`, `myast_from_bytes` is unambiguous and
# avoids tangling with the snake_case convention enforced
# elsewhere by the resolver. Non-ASCII bytes pass through.
#[doc("ASCII-only lowercaser; used by the emitter to fold effect names.")]
pub fn string_to_lower_ascii(s: String) : String =
  string_to_lower_ascii_loop(s, 0, string_length(s), "")

fn string_to_lower_ascii_loop(s: String, i: Int, n: Int, acc: String) : String = {
  if i >= n { acc }
  else { match char_at(s, i) {
    None    -> acc
    Some(c) -> {
      let nc = char_to_int(c)
      let lc = if nc >= 65 and nc <= 90 { int_to_char(nc + 32) } else { c }
      string_to_lower_ascii_loop(s, i + 1, n, string_concat(acc, "#{lc}"))
    }
  } }
}

# --- field encoders / decoders --------------------------------------
#
# For most field types the encode emits `to_bytes(value)` and the
# decode emits `__pimpl_BinSerialize_<Head>_from_bytes(buf, pos)`.
# Three families need combinator support because their head type
# either collides with the buffer (`List`) or lacks a usable single-
# dispatch impl (`Option`, `Char`) — see
# `docs/binserialize-collections-design.md`. For those we emit
# `bin_list_to_bytes(value, { x -> <encode(elem, x)> })` and the
# analogous decode shape, recursing into the element type so nested
# `[[Int]]` / `Option[[String]]` produce correctly stacked lambdas.

# `derive_binser_encode_expr` and `derive_binser_decode_call` emit
# multiple `ELambda` nodes when the field is a nested
# collection/option. The lambda lifter (`find_lam`,
# `stage2/compiler.kai:13359`) keys each lambda by its
# `(line, col)` position, and a duplicate position causes the
# emitter to reuse the same `_kai_lam_<id>` symbol for distinct
# lambdas. The derive site has no real source position for these
# synthesised lambdas, so we bump `col` per-lambda along three axes
# that must not collide: field index (handled by callers), encoder
# vs decoder direction (offsets 1 / 5), and nesting depth (each
# depth bumps by 8). 8 = 4*2 leaves room for both encoder and
# decoder lambdas at every depth.
fn derive_binser_encode_expr(value: Expr, ftype: TypeExpr,
                               line: Int, col: Int) : Expr =
  derive_binser_encode_expr_at(value, ftype, line, col, 0)

fn derive_binser_encode_expr_at(value: Expr, ftype: TypeExpr,
                                  line: Int, col: Int, depth: Int) : Expr {
  match ftype.tkind {
    TyList(elem) -> {
      let lcol = col + depth * 8 + 1
      let xparam = Param { pname: "__bx", ptype: None, pline: line, pcol: lcol, pborrow: false }
      let xvar = mk_expr(EVar("__bx"), line, lcol)
      let body = derive_binser_encode_expr_at(xvar, elem, line, col, depth + 1)
      let enc_lam = mk_expr(ELambda([xparam], body), line, lcol)
      mk_expr(ECall(mk_expr(EVar("bin_list_to_bytes"), line, col),
                    [value, enc_lam]), line, col)
    }
    TyName(tn, targs) ->
      if tn == "Option" {
        match targs {
          [elem] -> {
            let lcol = col + depth * 8 + 1
            let xparam = Param { pname: "__bx", ptype: None, pline: line, pcol: lcol, pborrow: false }
            let xvar = mk_expr(EVar("__bx"), line, lcol)
            let body = derive_binser_encode_expr_at(xvar, elem, line, col,
                                                     depth + 1)
            let enc_lam = mk_expr(ELambda([xparam], body), line, lcol)
            mk_expr(ECall(mk_expr(EVar("bin_option_to_bytes"), line, col),
                          [value, enc_lam]), line, col)
          }
          _ -> derive_binser_encode_mangled(value, ftype, line, col)
        }
      } else if tn == "Char" {
        mk_expr(ECall(mk_expr(EVar("bin_char_to_bytes"), line, col),
                      [value]), line, col)
      } else {
        derive_binser_encode_mangled(value, ftype, line, col)
      }
    _ -> derive_binser_encode_mangled(value, ftype, line, col)
  }
}

# For non-collection / non-Char fields the derive emits a direct call
# to the mangled per-type encoder symbol rather than the protocol
# dispatcher `to_bytes`. Calls inside a lambda body (the closure that
# `bin_list_to_bytes` / `bin_option_to_bytes` receive) cannot rely on
# the dispatcher because the monomorpher does not propagate the
# instantiated type into the lambda body's free-call resolution. The
# mangled name routes statically to the correct impl regardless.
# Mirrors the symmetric `derive_binser_decode_mangled` helper used by
# the decoder chain.
fn derive_binser_encode_mangled(value: Expr, ftype: TypeExpr,
                                  line: Int, col: Int) : Expr {
  let mangled = proto_mangled_fn("BinSerialize",
                                   proto_type_name(ftype), "to_bytes")
  mk_expr(ECall(mk_expr(EVar(mangled), line, col), [value]), line, col)
}

fn derive_binser_decode_call(buf_e: Expr, pos_e: Expr, ftype: TypeExpr,
                               line: Int, col: Int) : Expr =
  derive_binser_decode_call_at(buf_e, pos_e, ftype, line, col, 0)

fn derive_binser_decode_call_at(buf_e: Expr, pos_e: Expr, ftype: TypeExpr,
                                  line: Int, col: Int, depth: Int) : Expr {
  match ftype.tkind {
    TyList(elem) -> {
      let lcol = col + depth * 8 + 5
      let bparam = Param { pname: "__bb", ptype: None, pline: line, pcol: lcol, pborrow: false }
      let pparam = Param { pname: "__bp", ptype: None, pline: line, pcol: lcol, pborrow: false }
      let bvar = mk_expr(EVar("__bb"), line, lcol)
      let pvar = mk_expr(EVar("__bp"), line, lcol)
      let body = derive_binser_decode_call_at(bvar, pvar, elem, line, col,
                                                depth + 1)
      let dec_lam = mk_expr(ELambda([bparam, pparam], body), line, lcol)
      mk_expr(ECall(mk_expr(EVar("bin_list_from_bytes"), line, col),
                    [buf_e, pos_e, dec_lam]), line, col)
    }
    TyName(tn, targs) ->
      if tn == "Option" {
        match targs {
          [elem] -> {
            let lcol = col + depth * 8 + 5
            let bparam = Param { pname: "__bb", ptype: None, pline: line, pcol: lcol, pborrow: false }
            let pparam = Param { pname: "__bp", ptype: None, pline: line, pcol: lcol, pborrow: false }
            let bvar = mk_expr(EVar("__bb"), line, lcol)
            let pvar = mk_expr(EVar("__bp"), line, lcol)
            let body = derive_binser_decode_call_at(bvar, pvar, elem, line, col,
                                                      depth + 1)
            let dec_lam = mk_expr(ELambda([bparam, pparam], body), line, lcol)
            mk_expr(ECall(mk_expr(EVar("bin_option_from_bytes"), line, col),
                          [buf_e, pos_e, dec_lam]), line, col)
          }
          _ -> derive_binser_decode_mangled(buf_e, pos_e, ftype, line, col)
        }
      } else if tn == "Char" {
        mk_expr(ECall(mk_expr(EVar("bin_char_from_bytes"), line, col),
                      [buf_e, pos_e]), line, col)
      } else {
        derive_binser_decode_mangled(buf_e, pos_e, ftype, line, col)
      }
    _ -> derive_binser_decode_mangled(buf_e, pos_e, ftype, line, col)
  }
}

fn derive_binser_decode_mangled(buf_e: Expr, pos_e: Expr, ftype: TypeExpr,
                                  line: Int, col: Int) : Expr {
  let mangled = proto_mangled_fn("BinSerialize",
                                   proto_type_name(ftype), "from_bytes")
  mk_expr(ECall(mk_expr(EVar(mangled), line, col), [buf_e, pos_e]), line, col)
}

# --- record encoder -------------------------------------------------
#
# `to_bytes(self) = array_concat_bytes(to_bytes(self.f1),
#                    array_concat_bytes(to_bytes(self.f2), ...))`
#
# Empty record returns an empty `Array[Byte]` via `array_make(0, bin_byte(0))`.
# For most fields each `to_bytes(self.fK)` call rides the protocol
# dispatcher because the first arg's type IS the field's type.
# List/Option/Char fields route through `derive_binser_encode_expr`
# instead (see above).
fn derive_binser_record_to_bytes(fields: [FieldDecl], line: Int, col: Int) : Expr {
  match fields {
    [] -> empty_byte_array_expr(line, col)
    [fd, ...rest] -> derive_binser_record_to_bytes_chain(fd, rest, 0, line, col)
  }
}

# Build `array_make(0, bin_byte(0))` — the canonical empty
# `Array[Byte]` literal the derive emits for empty-record / empty-
# payload cases. The runtime allocates a zero-length backing slot;
# the sentinel `bin_byte(0)` is never observed.
fn empty_byte_array_expr(line: Int, col: Int) : Expr {
  let zero = mk_expr(ECall(mk_expr(EVar("bin_byte"), line, col),
                            [mk_expr(EInt(0), line, col)]), line, col)
  mk_expr(ECall(mk_expr(EVar("array_make"), line, col),
                [mk_expr(EInt(0), line, col), zero]), line, col)
}

# Build `array_one_byte(bin_byte(idx))` — the canonical single-byte
# tag the sum encoder emits for variant tags.
fn one_byte_tag_expr(idx: Int, line: Int, col: Int) : Expr {
  let tag_byte = mk_expr(ECall(mk_expr(EVar("bin_byte"), line, col),
                                [mk_expr(EInt(idx), line, col)]),
                          line, col)
  mk_expr(ECall(mk_expr(EVar("array_one_byte"), line, col), [tag_byte]),
          line, col)
}

# `idx` is bumped per field so that any lambdas the encoder emits for
# different fields land at distinct `(line, col)` positions and the
# lambda lifter (`find_lam`) can tell them apart. Each field gets a
# 16-column slot; nested encoder/decoder lambdas inside one field
# bump within that slot via `derive_binser_encode_expr` /
# `derive_binser_decode_call`.
fn derive_binser_record_to_bytes_chain(head: FieldDecl, rest: [FieldDecl],
                                         idx: Int, line: Int, col: Int) : Expr {
  match head {
    FD(_, name, ftype) -> {
      let fcol = col + idx * 16
      let access = mk_expr(EField(mk_expr(EVar("self"), line, fcol), name),
                            line, fcol)
      let head_call = derive_binser_encode_expr(access, ftype, line, fcol)
      match rest {
        [] -> head_call
        [next, ...more] -> {
          let tail = derive_binser_record_to_bytes_chain(next, more, idx + 1,
                                                          line, col)
          mk_expr(ECall(mk_expr(EVar("array_concat_bytes"), line, col),
                        [head_call, tail]), line, col)
        }
      }
    }
  }
}

# --- record decoder -------------------------------------------------
#
# Threaded chain of `match __pimpl_BinSerialize_<Tk>_from_bytes(buf, posK) {
#   Err(m) -> Err(m); Ok(p_K) -> ... }` ending in
# `Ok((T { f1: p_1.fst, ..., fN: p_N.fst }, posN))`.
#
# Empty record short-circuits to `Ok((T {}, pos))` so the empty-fields
# case still emits a valid impl.
fn derive_binser_record_from_bytes(tname: String, fields: [FieldDecl],
                                     line: Int, col: Int) : Expr {
  let pos0 = mk_expr(EVar("pos"), line, col)
  match fields {
    [] -> derive_binser_record_ok_value(tname, [], pos0, line, col)
    _  -> derive_binser_record_decode_chain(tname, fields, fields, 0, pos0,
                                              line, col)
  }
}

# `remaining` walks left-to-right; `all_fields` is captured so the
# final `Ok` builder can construct the record literal in declaration
# order. `pos_e` is the expression naming the current cursor (`pos`
# initially, then `pK.snd` for the K-th field).
fn derive_binser_record_decode_chain(tname: String, remaining: [FieldDecl],
                                       all_fields: [FieldDecl], idx: Int,
                                       pos_e: Expr, line: Int, col: Int) : Expr {
  match remaining {
    [] -> derive_binser_record_ok_value(tname, all_fields, pos_e, line, col)
    [fd, ...rest] -> match fd {
      FD(_, _, ftype) -> {
        # Per-field column slot — see `derive_binser_record_to_bytes_chain`
        # comment. Decoder lambdas land 1 column inside the encoder
        # slot so encoder/decoder for the same field are also distinct.
        let fcol = col + idx * 16 + 1
        let buf_e = mk_expr(EVar("buf"), line, fcol)
        let call = derive_binser_decode_call(buf_e, pos_e, ftype, line, fcol)
        let pvar = concat_all(["p", int_to_string(idx)])
        let next_pos = mk_expr(EField(mk_expr(EVar(pvar), line, col), "pos"),
                                line, col)
        let then_e = derive_binser_record_decode_chain(tname, rest, all_fields,
                                                        idx + 1, next_pos,
                                                        line, col)
        derive_binser_match_result(call, pvar, then_e, line, col)
      }
    }
  }
}

# Build `Ok(BinCursor { value: T { f1: p0.value, ... }, pos: pos_e })`.
fn derive_binser_record_ok_value(tname: String, fields: [FieldDecl],
                                   pos_e: Expr, line: Int, col: Int) : Expr {
  let parts = derive_binser_record_field_inits(fields, 0, line, col)
  let rec_e = mk_expr(ERecordLit(tname, parts), line, col)
  let cur_e = mk_expr(ERecordLit("BinCursor",
                                [FI("value", rec_e),
                                 FI("pos", pos_e)]), line, col)
  mk_expr(ECall(mk_expr(EVar("Ok"), line, col), [cur_e]), line, col)
}

fn derive_binser_record_field_inits(fields: [FieldDecl], i: Int,
                                      line: Int, col: Int) : [FieldInit] {
  match fields {
    [] -> []
    [fd, ...rest] -> match fd {
      FD(_, name, _) -> {
        let v = mk_expr(EField(mk_expr(EVar(concat_all(["p", int_to_string(i)])),
                                        line, col), "value"),
                         line, col)
        [FI(name, v),
         ...derive_binser_record_field_inits(rest, i + 1, line, col)]
      }
    }
  }
}

# Wrap an `Err(m) -> Err(m); Ok(pvar) -> then_e` match around a
# Result-producing decode call.
fn derive_binser_match_result(call: Expr, pvar: String, then_e: Expr,
                                line: Int, col: Int) : Expr {
  let err_pat = mk_pat(PVariant("Err", [mk_pat(PBind("m"), line, col)]),
                        line, col)
  let err_arm = Arm(err_pat, None,
                    mk_expr(ECall(mk_expr(EVar("Err"), line, col),
                                  [mk_expr(EVar("m"), line, col)]),
                            line, col))
  let ok_pat = mk_pat(PVariant("Ok", [mk_pat(PBind(pvar), line, col)]),
                       line, col)
  let ok_arm = Arm(ok_pat, None, then_e)
  mk_expr(EMatch(call, [err_arm, ok_arm]), line, col)
}

# --- sum encoder ----------------------------------------------------
#
# `match self {
#    V0 -> array_one_byte(bin_byte(0));
#    V1(p0) -> array_concat_bytes(array_one_byte(bin_byte(1)), to_bytes(p0));
#    V2(p0, p1) -> array_concat_bytes(array_one_byte(bin_byte(2)),
#                    array_concat_bytes(to_bytes(p0), to_bytes(p1)));
#    ... }`
#
# Tag is the variant's declaration index encoded as a single byte.
# Sum types with more than 256 variants are out of v1 scope; they
# would silently truncate today (open follow-up: switch to a varint
# tag if real users hit this).
fn derive_binser_sum_to_bytes(variants: [Variant], line: Int, col: Int) : Expr {
  match variants {
    [] -> empty_byte_array_expr(line, col)
    _  -> {
      let scrut = mk_expr(EVar("self"), line, col)
      let arms = derive_binser_sum_to_bytes_arms(variants, 0, line, col)
      mk_expr(EMatch(scrut, arms), line, col)
    }
  }
}

fn derive_binser_sum_to_bytes_arms(variants: [Variant], idx: Int,
                                     line: Int, col: Int) : [Arm] {
  match variants {
    [] -> []
    [v, ...rest] ->
      [derive_binser_sum_to_bytes_arm(v, idx, line, col),
       ...derive_binser_sum_to_bytes_arms(rest, idx + 1, line, col)]
  }
}

fn derive_binser_sum_to_bytes_arm(v: Variant, idx: Int,
                                    line: Int, col: Int) : Arm {
  match v {
    Var(name, vargs) -> {
      let pat_subs = derive_binser_sum_pat_subs(vargs, "p", 0, line, col)
      let pat = mk_pat(PVariant(name, pat_subs), line, col)
      let body = derive_binser_sum_to_bytes_body(vargs, idx, line, col)
      Arm(pat, None, body)
    }
  }
}

fn derive_binser_sum_pat_subs(vargs: [TypeExpr], prefix: String, i: Int,
                                line: Int, col: Int) : [Pattern] {
  match vargs {
    [] -> []
    [_, ...rest] ->
      [mk_pat(PBind(concat_all([prefix, int_to_string(i)])), line, col),
       ...derive_binser_sum_pat_subs(rest, prefix, i + 1, line, col)]
  }
}

# `array_concat_bytes(array_one_byte(bin_byte(tag)),
#                     array_concat_bytes(to_bytes(p0), ...))`.
# Empty payload collapses to just `array_one_byte(bin_byte(tag))`.
fn derive_binser_sum_to_bytes_body(vargs: [TypeExpr], idx: Int,
                                     line: Int, col: Int) : Expr {
  let tag = one_byte_tag_expr(idx, line, col)
  match vargs {
    [] -> tag
    _  -> {
      # Per-variant column window so lambdas emitted inside different
      # variants land at distinct `(line, col)` positions and the
      # lambda lifter can tell them apart. 256-column window leaves
      # room for ~16 fields each carrying nested encoder/decoder
      # lambdas. Sum types with > 256 variants will overflow; that
      # is the same limit `derive_binser_sum_to_bytes` already imposes
      # via the single-byte tag (out of v1 scope).
      let vcol = col + idx * 256
      let payload = derive_binser_sum_to_bytes_payload(vargs, 0, line, vcol)
      mk_expr(ECall(mk_expr(EVar("array_concat_bytes"), line, col), [tag, payload]),
              line, col)
    }
  }
}

fn derive_binser_sum_to_bytes_payload(vargs: [TypeExpr], i: Int,
                                        line: Int, col: Int) : Expr {
  match vargs {
    [] -> empty_byte_array_expr(line, col)
    [vt, ...rest] -> {
      let fcol = col + i * 16
      let v = mk_expr(EVar(concat_all(["p", int_to_string(i)])), line, fcol)
      let head = derive_binser_encode_expr(v, vt, line, fcol)
      match rest {
        [] -> head
        _  -> {
          let tail = derive_binser_sum_to_bytes_payload(rest, i + 1, line, col)
          mk_expr(ECall(mk_expr(EVar("array_concat_bytes"), line, col), [head, tail]),
                  line, col)
        }
      }
    }
  }
}

# --- sum decoder ----------------------------------------------------
#
# `match bin_byte_at(buf, pos) {
#   Err(m) -> Err(m)
#   Ok(__tag) ->
#     if __tag == 0 { <decode V0 payload> }
#     else if __tag == 1 { <decode V1 payload> }
#     ...
#     else { Err("BinSerialize <tname>: invalid tag") }
# }`
#
# Each per-variant payload chain is identical in shape to the
# record-field chain: thread `__pimpl_BinSerialize_<Tk>_from_bytes`
# Result-matches and end with `Ok((Variant(p0.fst, p1.fst, ...), posN))`.
fn derive_binser_sum_from_bytes(tname: String, variants: [Variant],
                                  line: Int, col: Int) : Expr {
  let tag_call = mk_expr(ECall(mk_expr(EVar("bin_byte_at"), line, col),
                                [mk_expr(EVar("buf"), line, col),
                                 mk_expr(EVar("pos"), line, col)]),
                          line, col)
  let inner_pos = mk_expr(EBinop("+", mk_expr(EVar("pos"), line, col),
                                       mk_expr(EInt(1), line, col)),
                           line, col)
  let chain = derive_binser_sum_tag_chain(tname, variants, 0, inner_pos,
                                            line, col)
  derive_binser_match_result(tag_call, "__tag", chain, line, col)
}

fn derive_binser_sum_tag_chain(tname: String, variants: [Variant], idx: Int,
                                  start_pos: Expr, line: Int, col: Int) : Expr {
  match variants {
    [] -> mk_expr(ECall(mk_expr(EVar("Err"), line, col),
                         [mk_expr(EStr(concat_all(
                            ["\"BinSerialize ", tname, ": invalid tag\""]),
                            false), line, col)]),
                   line, col)
    [v, ...rest] -> {
      # `__tag` is a Byte after Lane 4; promote to Int via
      # `byte_to_int` so the `==` comparison stays Int-Int (we
      # already enumerate tags as Int indices) without needing a
      # `byte_eq` rewrite at every variant.
      let tag_i = mk_expr(ECall(mk_expr(EVar("byte_to_int"), line, col),
                                  [mk_expr(EVar("__tag"), line, col)]),
                           line, col)
      let cond = mk_expr(EBinop("==", tag_i,
                                       mk_expr(EInt(idx), line, col)),
                          line, col)
      # Per-variant decoder window mirrors the encoder offset in
      # `derive_binser_sum_to_bytes_body`. Add 128 (half the 256-col
      # window) so encoder and decoder lambdas for the same variant
      # don't collide either.
      let vcol = col + idx * 256 + 128
      let then_e = derive_binser_sum_payload_decode(tname, v, start_pos,
                                                      line, vcol)
      let else_e = derive_binser_sum_tag_chain(tname, rest, idx + 1,
                                                  start_pos, line, col)
      mk_expr(EIf(cond, then_e, Some(else_e)), line, col)
    }
  }
}

# Same shape as record-decode chain, but the final `Ok` builds a
# constructor call `Variant(p0.value, p1.value, ...)` instead of a
# record literal.
fn derive_binser_sum_payload_decode(tname: String, v: Variant,
                                      start_pos: Expr, line: Int, col: Int) : Expr {
  match v {
    Var(name, vargs) -> match vargs {
      [] -> {
        let ctor = mk_expr(EVar(name), line, col)
        let cur = mk_expr(ERecordLit("BinCursor",
                                    [FI("value", ctor),
                                     FI("pos", start_pos)]), line, col)
        mk_expr(ECall(mk_expr(EVar("Ok"), line, col), [cur]), line, col)
      }
      _  -> derive_binser_sum_decode_chain(name, vargs, vargs, 0, start_pos,
                                             line, col)
    }
  }
}

fn derive_binser_sum_decode_chain(vname: String, remaining: [TypeExpr],
                                    all_vargs: [TypeExpr], idx: Int,
                                    pos_e: Expr, line: Int, col: Int) : Expr {
  match remaining {
    [] -> {
      let args = derive_binser_sum_ctor_args(all_vargs, 0, line, col)
      let ctor = mk_expr(ECall(mk_expr(EVar(vname), line, col), args), line, col)
      let cur = mk_expr(ERecordLit("BinCursor",
                                  [FI("value", ctor),
                                   FI("pos", pos_e)]), line, col)
      mk_expr(ECall(mk_expr(EVar("Ok"), line, col), [cur]), line, col)
    }
    [vt, ...rest] -> {
      let fcol = col + idx * 16 + 1
      let buf_e = mk_expr(EVar("buf"), line, fcol)
      let call = derive_binser_decode_call(buf_e, pos_e, vt, line, fcol)
      let pvar = concat_all(["p", int_to_string(idx)])
      let next_pos = mk_expr(EField(mk_expr(EVar(pvar), line, col), "pos"),
                              line, col)
      let then_e = derive_binser_sum_decode_chain(vname, rest, all_vargs,
                                                     idx + 1, next_pos,
                                                     line, col)
      derive_binser_match_result(call, pvar, then_e, line, col)
    }
  }
}

fn derive_binser_sum_ctor_args(vargs: [TypeExpr], i: Int,
                                 line: Int, col: Int) : [Expr] {
  match vargs {
    [] -> []
    [_, ...rest] ->
      [mk_expr(EField(mk_expr(EVar(concat_all(["p", int_to_string(i)])),
                               line, col), "value"), line, col),
       ...derive_binser_sum_ctor_args(rest, i + 1, line, col)]
  }
}

# Pre-expansion validator for `#derive(BinSerialize)`. Same shape as
# `validate_derive_ord`: collect every type that has — or will have —
# a BinSerialize impl, then reject any derive whose fields/payloads
# reference a type outside that set. The type itself is whitelisted
# (recursive types are legal). The user gets a typer-time message
# pointing at the offending field instead of the dispatcher's
# generic runtime panic.
fn validate_derive_binserialize(decls: [Decl], file: String) : Int / Console {

  let providers = collect_binser_providers(decls, [])
  validate_derive_binser_loop(decls, file, providers, 0)
}

fn collect_binser_providers(decls: [Decl], acc: [String]) : [String] {
  match decls {
    [] -> acc
    [d, ...rest] -> match d {
      DImpl(pname, _, target, _, _, _) ->
        if pname == "BinSerialize" {
          collect_binser_providers(rest, [proto_type_name(target), ...acc])
        } else {
          collect_binser_providers(rest, acc)
        }
      DDerive(names, inner, _, _) -> match inner {
        DType(_, tname, _, _, _, _, _, _) ->
          if list_has(names, "BinSerialize") {
            collect_binser_providers(rest, [tname, ...acc])
          } else {
            collect_binser_providers(rest, acc)
          }
        _ -> collect_binser_providers(rest, acc)
      }
      DUnstable(inner, _, _) ->
        collect_binser_providers([inner, ...rest], acc)
      DProtoLaws(_, inner, _, _) ->
        collect_binser_providers([inner, ...rest], acc)
      DImplAxiom(_, inner, _, _) ->
        collect_binser_providers([inner, ...rest], acc)
      DConstructor(inner, _, _) ->
        collect_binser_providers([inner, ...rest], acc)
      _ -> collect_binser_providers(rest, acc)
    }
  }
}

fn validate_derive_binser_loop(decls: [Decl], file: String,
                                 providers: [String], errs: Int) : Int / Console {

  match decls {
    [] -> errs
    [d, ...rest] -> match d {
      DDerive(names, inner, _, _) -> match inner {
        DType(_, tname, _, body, line, col, _, _) ->
          if list_has(names, "BinSerialize") {
            let errs1 = validate_derive_binser_body(file, tname, body,
                                                     providers, line, col, errs)
            validate_derive_binser_loop(rest, file, providers, errs1)
          } else {
            validate_derive_binser_loop(rest, file, providers, errs)
          }
        _ -> validate_derive_binser_loop(rest, file, providers, errs)
      }
      DUnstable(inner, _, _) ->
        validate_derive_binser_loop([inner, ...rest], file, providers, errs)
      DProtoLaws(_, inner, _, _) ->
        validate_derive_binser_loop([inner, ...rest], file, providers, errs)
      DImplAxiom(_, inner, _, _) ->
        validate_derive_binser_loop([inner, ...rest], file, providers, errs)
      DConstructor(inner, _, _) ->
        validate_derive_binser_loop([inner, ...rest], file, providers, errs)
      _ -> validate_derive_binser_loop(rest, file, providers, errs)
    }
  }
}

fn validate_derive_binser_body(file: String, tname: String, body: TypeBody,
                                 providers: [String], line: Int, col: Int,
                                 errs: Int) : Int / Console {

  match body {
    TBRecord(fields) -> validate_derive_binser_fields(file, tname, fields,
                                                        providers, line, col, errs)
    TBSum(variants) -> validate_derive_binser_variants(file, tname, variants,
                                                         providers, line, col, errs)
    _ -> errs
  }
}

fn validate_derive_binser_fields(file: String, tname: String,
                                   fields: [FieldDecl], providers: [String],
                                   line: Int, col: Int, errs: Int) : Int / Console {

  match fields {
    [] -> errs
    [fd, ...rest] -> match fd {
      FD(_, fname, ftype) -> {
        let errs1 = validate_derive_binser_one(file, tname, fname, "field",
                                                 ftype, providers, line, col, errs)
        validate_derive_binser_fields(file, tname, rest, providers,
                                        line, col, errs1)
      }
    }
  }
}

fn validate_derive_binser_variants(file: String, tname: String,
                                     variants: [Variant], providers: [String],
                                     line: Int, col: Int, errs: Int) : Int / Console {

  match variants {
    [] -> errs
    [v, ...rest] -> match v {
      Var(vname, vargs) -> {
        let errs1 = validate_derive_binser_payload(file, tname, vname, vargs, 0,
                                                     providers, line, col, errs)
        validate_derive_binser_variants(file, tname, rest, providers,
                                          line, col, errs1)
      }
    }
  }
}

fn validate_derive_binser_payload(file: String, tname: String, vname: String,
                                    vargs: [TypeExpr], idx: Int,
                                    providers: [String], line: Int, col: Int,
                                    errs: Int) : Int / Console {

  match vargs {
    [] -> errs
    [vt, ...rest] -> {
      let label = concat_all([vname, " payload #", int_to_string(idx)])
      let errs1 = validate_derive_binser_one(file, tname, label, "variant",
                                               vt, providers, line, col, errs)
      validate_derive_binser_payload(file, tname, vname, rest, idx + 1,
                                       providers, line, col, errs1)
    }
  }
}

fn validate_derive_binser_one(file: String, tname: String, fname: String,
                                kind: String, ftype: TypeExpr,
                                providers: [String], line: Int, col: Int,
                                errs: Int) : Int / Console {
  let head = proto_type_name(ftype)
  if head == tname {
    errs
  } else if list_has(providers, head) {
    errs
  } else if binser_builtin_impl(head) {
    errs
  } else if binser_collection_head(head) {
    # `List` and `Option` route through `bin_list_*` / `bin_option_*`
    # combinators emitted by the derive. Validate that the element
    # type still has a usable impl/derive, recursively.
    validate_derive_binser_collection_elem(file, tname, fname, kind, ftype,
                                             head, providers, line, col, errs)
  } else {
    eprint(concat_all([
      file, ":", int_to_string(line), ":", int_to_string(col),
      ": error: cannot `#[derive(BinSerialize)]` for `", tname,
      "`: no `BinSerialize` impl for ", kind, " `", fname, "` of type `", head,
      "` (declare `impl BinSerialize for ", head,
      "` or `#[derive(BinSerialize)]` on `", head, "`)"]))
    errs + 1
  }
}

fn binser_collection_head(head: String) : Bool =
  head == "List" or head == "Option"

# Pre-expansion validator for `#[derive(Layout)]`. `derive_layout_impl`
# returns no decls when the record is not Layout-bearing, so without this
# pass the omission surfaces only as a missing `to_bytes` at the first
# call site. Walks the original decl stream and reports each offending
# field with the remedy that applies to it.
fn validate_derive_layout(decls: [Decl], file: String) : Int / Console =
  validate_derive_layout_loop(decls, file, 0)

fn validate_derive_layout_loop(decls: [Decl], file: String,
                                 errs: Int) : Int / Console {
  match decls {
    [] -> errs
    [d, ...rest] -> match d {
      DDerive(names, inner, _, _) -> match inner {
        DType(_, tname, _, body, line, col, _, _) ->
          if list_has(names, "Layout") {
            let errs1 = validate_derive_layout_body(file, tname, body,
                                                     line, col, errs)
            validate_derive_layout_loop(rest, file, errs1)
          } else {
            validate_derive_layout_loop(rest, file, errs)
          }
        _ -> validate_derive_layout_loop(rest, file, errs)
      }
      DUnstable(inner, _, _) ->
        validate_derive_layout_loop([inner, ...rest], file, errs)
      DProtoLaws(_, inner, _, _) ->
        validate_derive_layout_loop([inner, ...rest], file, errs)
      DImplAxiom(_, inner, _, _) ->
        validate_derive_layout_loop([inner, ...rest], file, errs)
      DConstructor(inner, _, _) ->
        validate_derive_layout_loop([inner, ...rest], file, errs)
      _ -> validate_derive_layout_loop(rest, file, errs)
    }
  }
}

fn validate_derive_layout_body(file: String, tname: String, body: TypeBody,
                                 line: Int, col: Int, errs: Int) : Int / Console {
  match body {
    TBRecord(fields) -> match fields {
      [] -> {
        eprint(concat_all([
          file, ":", int_to_string(line), ":", int_to_string(col),
          ": error: cannot `#[derive(Layout)]` for `", tname,
          "`: a Layout record needs at least one field"]))
        errs + 1
      }
      _ -> validate_derive_layout_fields(file, tname, fields, line, col, errs)
    }
    _ -> {
      eprint(concat_all([
        file, ":", int_to_string(line), ":", int_to_string(col),
        ": error: cannot `#[derive(Layout)]` for `", tname,
        "`: Layout applies to records, not sum types"]))
      errs + 1
    }
  }
}

fn validate_derive_layout_fields(file: String, tname: String,
                                   fields: [FieldDecl], line: Int, col: Int,
                                   errs: Int) : Int / Console {
  match fields {
    [] -> errs
    [fd, ...rest] -> {
      let errs1 = validate_derive_layout_one(file, tname, fd, line, col, errs)
      validate_derive_layout_fields(file, tname, rest, line, col, errs1)
    }
  }
}

fn validate_derive_layout_one(file: String, tname: String, fd: FieldDecl,
                                line: Int, col: Int, errs: Int) : Int / Console {
  let rej = layout_reject_of(fd)
  if layout_reject_is_err(rej) {
    match fd {
      FD(_, fname, ftype) -> {
        eprint(concat_all([
          file, ":", int_to_string(line), ":", int_to_string(col),
          ": error: cannot `#[derive(Layout)]` for `", tname,
          "`: field `", fname, "` of type `", layout_head_name(ftype),
          "` is not Layout-bearing: ", layout_reject_why(rej)]))
        errs + 1
      }
    }
  } else { errs }
}

# `TyList(elem)` and `Option[elem]` are valid only when `elem` is
# itself a builtin, a collection (recursive case for `[[Foo]]`), or a
# provider in scope. Anything else is reported as missing — but the
# message names the *element* type, not the outer `List`/`Option`,
# because the user's mental model is "BinSerialize for Foo is what
# I need to add".
fn validate_derive_binser_collection_elem(file: String, tname: String,
                                            fname: String, kind: String,
                                            ftype: TypeExpr, head: String,
                                            providers: [String], line: Int,
                                            col: Int, errs: Int) : Int / Console {
  let elem_opt = binser_collection_elem(ftype)
  match elem_opt {
    None -> {
      # `Option` without a type arg, or other malformed shape. Report
      # against the outer head so the user knows the shape is wrong.
      eprint(concat_all([
        file, ":", int_to_string(line), ":", int_to_string(col),
        ": error: cannot `#[derive(BinSerialize)]` for `", tname,
        "`: ", kind, " `", fname, "` has shape `", head,
        "` without an element type"]))
      errs + 1
    }
    Some(elem) -> validate_derive_binser_one(file, tname, fname, kind, elem,
                                                providers, line, col, errs)
  }
}

fn binser_collection_elem(ftype: TypeExpr) : Option[TypeExpr] {
  match ftype.tkind {
    TyList(elem) -> Some(elem)
    TyName(tn, targs) ->
      if tn == "Option" {
        match targs {
          [elem] -> Some(elem)
          _ -> None
        }
      } else { None }
    _ -> None
  }
}

# Atomic types with hand-written impls in stdlib/protocols.kai.
# Mirrors `derive_builtin_impl` for Eq/Hash/Show; kept separate to
# avoid coupling BinSerialize's whitelist to the protocols that
# pre-existed it. `Byte` rides the `Int` impl by virtue of Lane 4's
# nominal-but-byte-castable design. `Char` rides a hand-written
# `bin_char_*` pair the derive routes to directly.
fn binser_builtin_impl(tname: String) : Bool =
  list_has(["Int", "Real", "Bool", "String", "Byte", "Char"], tname)

# m12.8.z: pre-expansion validation for `#derive(Ord)`. Walks the
# decl stream once to collect every type that has — or will have
# after derivation — an `Ord` impl, then rejects any
# `#derive(Ord) type T` whose fields/payloads reference a type that
# does not appear in that set. The `T` itself is whitelisted to
# allow recursive types. Parametric type heads (`List`, `Option`,
# `Result`, `Fn`) collapse to their constructor name via
# `proto_type_name`, so a field of type `[Int]` looks like `List`
# in the providers set — and unless `impl Ord for List` is
# declared, the derive is rejected.
fn validate_derive_ord(decls: [Decl], file: String) : Int / Console {

  let providers = collect_ord_providers(decls, [])
  validate_derive_ord_loop(decls, file, providers, 0)
}

fn collect_ord_providers(decls: [Decl], acc: [String]) : [String] {
  match decls {
    [] -> acc
    [d, ...rest] -> match d {
      DImpl(pname, _, target, _, _, _) ->
        if pname == "Ord" {
          collect_ord_providers(rest, [proto_type_name(target), ...acc])
        } else {
          collect_ord_providers(rest, acc)
        }
      DDerive(names, inner, _, _) -> match inner {
        DType(_, tname, _, _, _, _, _, _) ->
          if list_has(names, "Ord") {
            collect_ord_providers(rest, [tname, ...acc])
          } else {
            collect_ord_providers(rest, acc)
          }
        _ -> collect_ord_providers(rest, acc)
      }
      DUnstable(inner, _, _) ->
        collect_ord_providers([inner, ...rest], acc)
      DProtoLaws(_, inner, _, _) ->
        collect_ord_providers([inner, ...rest], acc)
      DImplAxiom(_, inner, _, _) ->
        collect_ord_providers([inner, ...rest], acc)
      DConstructor(inner, _, _) ->
        collect_ord_providers([inner, ...rest], acc)
      _ -> collect_ord_providers(rest, acc)
    }
  }
}

fn validate_derive_ord_loop(decls: [Decl], file: String,
                              providers: [String], errs: Int) : Int / Console {

  match decls {
    [] -> errs
    [d, ...rest] -> match d {
      DDerive(names, inner, _, _) -> match inner {
        DType(_, tname, _, body, line, col, _, _) ->
          if list_has(names, "Ord") {
            let errs1 = validate_derive_ord_body(file, tname, body, providers,
                                                  line, col, errs)
            validate_derive_ord_loop(rest, file, providers, errs1)
          } else {
            validate_derive_ord_loop(rest, file, providers, errs)
          }
        _ -> validate_derive_ord_loop(rest, file, providers, errs)
      }
      DUnstable(inner, _, _) ->
        validate_derive_ord_loop([inner, ...rest], file, providers, errs)
      DProtoLaws(_, inner, _, _) ->
        validate_derive_ord_loop([inner, ...rest], file, providers, errs)
      DImplAxiom(_, inner, _, _) ->
        validate_derive_ord_loop([inner, ...rest], file, providers, errs)
      DConstructor(inner, _, _) ->
        validate_derive_ord_loop([inner, ...rest], file, providers, errs)
      _ -> validate_derive_ord_loop(rest, file, providers, errs)
    }
  }
}

fn validate_derive_ord_body(file: String, tname: String, body: TypeBody,
                              providers: [String], line: Int, col: Int,
                              errs: Int) : Int / Console {

  match body {
    TBRecord(fields) -> validate_derive_ord_fields(file, tname, fields,
                                                     providers, line, col, errs)
    TBSum(variants) -> validate_derive_ord_variants(file, tname, variants,
                                                      providers, line, col, errs)
    # Aliases / effect-aliases never reach derive — `derive_ord_impl`
    # returns None for them and the existing pipeline handles the
    # resulting "no impl" surface elsewhere. Nothing to validate here.
    _ -> errs
  }
}

fn validate_derive_ord_fields(file: String, tname: String,
                                fields: [FieldDecl], providers: [String],
                                line: Int, col: Int, errs: Int) : Int / Console {

  match fields {
    [] -> errs
    [fd, ...rest] -> match fd {
      FD(_, fname, ftype) -> {
        let errs1 = validate_derive_ord_one(file, tname, fname, "field",
                                              ftype, providers, line, col, errs)
        validate_derive_ord_fields(file, tname, rest, providers, line, col, errs1)
      }
    }
  }
}

fn validate_derive_ord_variants(file: String, tname: String,
                                  variants: [Variant], providers: [String],
                                  line: Int, col: Int, errs: Int) : Int / Console {

  match variants {
    [] -> errs
    [v, ...rest] -> match v {
      Var(vname, vargs) -> {
        let errs1 = validate_derive_ord_payload(file, tname, vname, vargs, 0,
                                                  providers, line, col, errs)
        validate_derive_ord_variants(file, tname, rest, providers, line, col, errs1)
      }
    }
  }
}

fn validate_derive_ord_payload(file: String, tname: String, vname: String,
                                 vargs: [TypeExpr], idx: Int,
                                 providers: [String], line: Int, col: Int,
                                 errs: Int) : Int / Console {

  match vargs {
    [] -> errs
    [vt, ...rest] -> {
      let label = concat_all([vname, " payload #", int_to_string(idx)])
      let errs1 = validate_derive_ord_one(file, tname, label, "variant",
                                            vt, providers, line, col, errs)
      validate_derive_ord_payload(file, tname, vname, rest, idx + 1,
                                    providers, line, col, errs1)
    }
  }
}

fn validate_derive_ord_one(file: String, tname: String, fname: String,
                             kind: String, ftype: TypeExpr,
                             providers: [String], line: Int, col: Int,
                             errs: Int) : Int / Console {
  let head = proto_type_name(ftype)
  if head == tname {
    errs
  } else if list_has(providers, head) {
    errs
  } else {
    eprint(concat_all([
      file, ":", int_to_string(line), ":", int_to_string(col),
      ": error: cannot `#[derive(Ord)]` for `", tname,
      "`: no `Ord` impl for ", kind, " `", fname, "` of type `", head,
      "` (declare `impl Ord for ", head, "` or `#[derive(Ord)]` on `", head, "`)"]))
    errs + 1
  }
}

# Top-level entry point. Hands the post-desugar decl stream back
# with protocols / impls lowered into ordinary fn decls, plus a
# threaded ProtocolReg the post-inference rewrite consumes.
#[doc("Result of pass A: the decl stream with impls lowered, the threaded ProtocolReg, and an error count.")]
pub type LoweredProtocols = { decls: [Decl], reg: ProtocolReg, errs: Int }

#[doc("Pass A: expand #[derive], validate coherence, lower impls + emit dispatchers, strip protocol decls.")]
pub fn lower_protocols(decls: [Decl], file: String,
                     target_mod: String) : LoweredProtocols / Console {

  # Step 0 — m12.8.x: validate `#derive(Eq/Hash)` on sum types: every
  # variant field's head type must already have an impl reachable in
  # this compilation unit. Reported errors short-circuit the typer
  # via `proto_errs > 0` in the driver.
  let pre_errs = validate_derives(decls, file)
  # Step 0b — m12.8.z: validate `#derive(Ord)` against available
  # impls *before* expansion. The synthesised `cmp` body delegates
  # to `cmp` on each field type, and the post-inference rewrite
  # silently routes missing-impl calls to the dispatcher's runtime
  # `panic` (a v1 tradeoff explained in §"resolve_protocol_calls").
  # That fallback is acceptable for hand-written impls but a poor
  # user experience for derived ones, where the field-level cause
  # isn't surfaced. This pass walks the original decl stream
  # (DDerive nodes still intact) and emits a clear typer-time error
  # naming the offending field/payload.
  let derive_errs = validate_derive_ord(decls, file) +
                    validate_derive_binserialize(decls, file) +
                    validate_derive_layout(decls, file)
  # Step 1 — expand `#derive(...)` annotations into synthetic DImpl
  # decls so subsequent steps see all impls uniformly.
  let expanded = expand_derives(decls)
  # Step 2 — coherence: orphan + duplicate-impl validation.
  let proto_names = collect_proto_names(expanded, [])
  let local_types = collect_local_type_names(expanded, [])
  let coh_errs = validate_impls(expanded, file, proto_names, local_types)
  # Step 3 — collect every protocol op into the registry.
  # Issue #597 boundary tagging: each DProtocol's home module is
  # recorded in `reg.origins` via the back-propagating home-anchor
  # analysis (DProtocol carries no `mo` field of its own).
  let reg0 = collect_proto_decls(expanded, proto_reg_empty(), target_mod)
  # Step 3b — issue #535: validate each impl block against its
  # protocol's declared operations (missing methods, wrong arity,
  # head-name signature mismatch). Runs after the registry is built so
  # impl methods can be cross-referenced against POR entries.
  let impl_errs = validate_impl_methods(expanded, file, reg0)
  let errs = pre_errs + derive_errs + coh_errs + impl_errs
  # Step 4 — lower each DImpl method into a top-level DFn (mangled
  # name) and record the (P, T) -> impl_fn entry in the registry.
  let lower_res = lower_impls(expanded, reg0, [])
  # Step 5 — synthesise one dispatcher fn per protocol op so the
  # typer can resolve the call as ordinary polymorphic dispatch; the
  # post-inference rewrite redirects each reachable call to the
  # matching `__pimpl_*` direct call.
  let dispatchers = generate_dispatchers(lower_res.reg)
  # Step 6 — drop DProtocol / DImpl / DDerive from the decl stream.
  let stripped = strip_protocols(expanded)
  # Step 7 — rename every reachable `EVar(opname)` reference to its
  # safe dispatcher name (`__proto_<opname>`) so the C / LLVM emit
  # never produces `kai_<opname>` and collides with runtime helpers
  # like `kai_op_eq`, `kai_to_string`, `kai_op_lt`. The dispatcher fn was
  # registered under the same safe name in step 5; the post-inference
  # rewrite then redirects each reachable call to the matching
  # `__pimpl_<P>_<T>_<op>` direct call when the type is known.
  # Resolver-arity (lane: resolver-arity): project the registry's
  # POR list into [OpAr] once so the rewriter can compare against
  # `length(args)` at every call site without re-walking the registry.
  # Resolver-local-shadow refinement: drop any op entry whose
  # `(name, arity)` is already provided by a top-level DFn in the
  # compilation unit. Same-arity collisions like `fn show(s: [Int])`
  # vs `protocol Show { show(x: Self) }` resolve to the local fn; the
  # protocol stays reachable through a qualified call. The arity-1
  # `pub fn min(xs)` / arity-2 `Ord.min(a, b)` split is preserved as
  # before — different arities never get filtered.
  let raw_op_arities = op_arities_from_ops(lower_res.reg.ops)
  # Directional visibility (#962): a body homed in a named module (core
  # / core) may only be rewritten against ops whose protocol is
  # itself core-origin; a root-file decl (user) sees every op. This is
  # the cut that keeps a once-typed core independent of any user file.
  let core_op_arities = core_origin_op_arities(lower_res.reg.ops, lower_res.reg.origins)
  # Per-module shadow guard: collect each top-level fn with its home
  # module so a core helper (`complex::add`) shadows the bare op
  # only inside its own module, never in the user's file.
  let local_fns = collect_local_fn_arities_mo(stripped)
  let user_renamed = rename_proto_calls_decls_mo(stripped, raw_op_arities, core_op_arities, local_fns, target_mod)
  let impl_renamed = rename_proto_calls_decls_mo(lower_res.fns, raw_op_arities, core_op_arities, local_fns, target_mod)
  let final_decls = list_append(user_renamed, list_append(impl_renamed, dispatchers))
  # Index the now-final impl table once; the post-inference rewrite's
  # per-spec scans consult it instead of walking `reg.impls` linearly.
  let indexed_reg = reg_with_impl_index(lower_res.reg)
  LoweredProtocols { decls: final_decls, reg: indexed_reg, errs: errs }
}

# Attach a freshly-built `ImplIndex` to a finalised registry. The impl
# table is immutable past this point, so the index built here serves
# every subsequent lookup.
fn reg_with_impl_index(reg: ProtocolReg) : ProtocolReg =
  ProtocolReg { ops: reg.ops, impls: reg.impls, op_names: reg.op_names,
                tparams: reg.tparams, origins: reg.origins,
                impl_index: build_impl_index(reg.impls) }

# m12.8 + resolver-arity: pre-resolve renaming pass. Walks every DFn /
# DTest body and rewrites every `EVar(name)` whose name is a known
# protocol op into `EVar(__proto_<name>)` — but only when `name` is
# NOT bound by an enclosing local binder. Scope tracking is threaded
# as `bound: [String]`, the union of names introduced by the
# surrounding fn params, lambda params, handler-clause params,
# handler-return pattern, `let` / `var` binders, and `match` arm
# patterns.
#
# Without this guard the rewrite would shadow common parameter names
# like `cmp` in `list_sort_by(xs, cmp: (a, a) -> Int)`: every
# reference to the parameter inside the body would silently route to
# the protocol dispatcher (`__proto_cmp`) and panic at runtime since
# the receiver is generic in `a`. The bug surfaced in `demos/poker`
# via `list_sort` once `--core stdlib/protocols.kai` was added to
# the demo build.
#
# Resolver-arity refinement (lane: resolver-arity): when the rewrite
# target is the CALLEE of `ECall(EVar(name), args)`, the rewrite
# only fires when `length(args)` matches a declared arity for that
# op. This keeps a same-named module function with a different arity
# reachable — e.g., `pub fn max(xs: [Int])` in `stdlib/core/list.kai`
# coexists with `Ord.max(a: Self, b: Self)` in `stdlib/protocols.kai`
# because `max(xs)` (arity 1) does not match the protocol op's arity
# 2 and is therefore left alone for the typer to resolve against the
# EFn table. Each protocol op is threaded as `OpAr(name, arity)`
# rather than the original `[String]`; the bare-EVar case (first-class
# fn reference) stays arity-independent and keeps the original
# "any matching name routes to the dispatcher" behaviour so partial
# application of an op like `let f = cmp` still resolves.

# Protocol op signature pair `(name, arity)` consumed by the
# arity-aware rewriter.
#[doc("An (op_name, arity) pair threaded into the arity-aware protocol-call rename pass.")]
pub type OpAr = OpAr(String, Int)

# A top-level fn's `(name, arity, module)`. The shadow guard is
# per-module: a free `pub fn add` in `math/complex` shadows the bare
# `add` op only inside complex's own bodies, not in a user file that
# merely imports it. Without the module key, any core helper
# homonymous with a protocol op (`complex::add`) would shadow that op
# program-wide and the call would bind the concrete helper instead of
# the polymorphic dispatcher.
#[doc("A top-level fn's (name, arity, module) used by the per-module shadow guard.")]
pub type LFnAr = LFnAr(String, Int, Option[String])

# Project the registry's POR list into `[OpAr]`. Done once at the
# `lower_protocols` boundary; the rewriter then threads it.
#[doc("Project the registry's protocol ops into their (name, arity) pairs.")]
pub fn op_arities_from_ops(ops: [ProtoOpReg]) : [OpAr] {
  match ops {
    [] -> []
    [op, ...rest] -> match op {
      POR(_, name, params, _, _, _) ->
        [OpAr(name, list_length(params)), ...op_arities_from_ops(rest)]
    }
  }
}

# Directional visibility (#962): the same projection, but keeping only
# ops whose declaring protocol has a named home module. A protocol
# defined in the root file is tagged `origin = None` (root file is the
# user); excluding those from a core body's rewrite set is exactly the
# "core never sees the user" invariant that makes reusing a once-typed
# core sound. The discriminant is the PROTOCOL'S origin, never the impl
# provider — so legitimate polymorphic dispatch (a core body calls a
# core op, the user supplies the impl) is untouched: the core op's
# protocol is still core-origin and survives the filter.
fn core_origin_op_arities(ops: [ProtoOpReg], origins: [ProtoOriginReg]) : [OpAr] {
  match ops {
    [] -> []
    [op, ...rest] -> match op {
      POR(proto, name, params, _, _, _) -> match proto_origin_lookup(origins, proto) {
        None -> core_origin_op_arities(rest, origins)
        Some(_) -> [OpAr(name, list_length(params)), ...core_origin_op_arities(rest, origins)]
      }
    }
  }
}

# Project an `[OpAr]` set down to the bare names it carries. Feeds the
# bare-EVar value-position shadow in the non-module rename rerun.
#[doc("Project an (name, arity) op set down to its bare names.")]
pub fn op_ar_names(arities: [OpAr]) : [String] {
  match arities {
    [] -> []
    [a, ...rest] -> match a {
      OpAr(n, _) -> [n, ...op_ar_names(rest)]
    }
  }
}

# Bare-name membership — true when at least one op has `target` as
# its name, regardless of arity. Used by the bare-EVar branch where
# no call shape constrains arity.
fn op_ar_has_name(arities: [OpAr], target: String) : Bool {
  match arities {
    [] -> false
    [a, ...rest] -> match a {
      OpAr(n, _) -> if n == target { true } else { op_ar_has_name(rest, target) }
    }
  }
}

# True when at least one op named `target` declares arity `n`. Used
# by the ECall branch to decide whether to rewrite the callee to its
# dispatcher (match) or leave it for normal name resolution (no match).
fn op_ar_match(arities: [OpAr], target: String, n: Int) : Bool {
  match arities {
    [] -> false
    [a, ...rest] -> match a {
      OpAr(name, ar) ->
        if name == target and ar == n { true }
        else { op_ar_match(rest, target, n) }
    }
  }
}

# True when `target` is declared by two protocols at DIFFERENT arities
# (`P { f(x) }` + `Q { f(a, b) }`). A single `__proto_f` dispatcher
# cannot carry two incompatible signatures, so the rename + dispatcher
# generation switch to arity-suffixed names (`__proto_f__a1`) for such
# a name. Same-arity collisions (the common case — `Ring.add` vs
# `Add.add`, both arity 2) keep the unsuffixed `__proto_<op>` and the
# runtime impl-table disambiguates by `head_tag(self)`.
fn op_name_arity_ambiguous(arities: [OpAr], target: String) : Bool =
  op_name_arity_ambiguous_loop(arities, target, -1)

fn op_name_arity_ambiguous_loop(arities: [OpAr], target: String,
                                  seen: Int) : Bool {
  match arities {
    [] -> false
    [a, ...rest] -> match a {
      OpAr(name, ar) ->
        if name == target {
          if seen >= 0 and ar != seen { true }
          else { op_name_arity_ambiguous_loop(rest, target, ar) }
        } else {
          op_name_arity_ambiguous_loop(rest, target, seen)
        }
    }
  }
}

# Dispatcher name for an op call resolved at a known arity. Unsuffixed
# `__proto_<op>` unless the name is arity-ambiguous, in which case the
# arity is appended so the two protocols' ops land on distinct
# dispatchers. Keeping the unsuffixed form for the common case is what
# preserves the selfhost byte-id.
fn proto_dispatcher_name_at(arities: [OpAr], op: String, arity: Int) : String {
  if op_name_arity_ambiguous(arities, op) {
    concat_all(["__proto_", op, "__a", int_to_string(arity)])
  } else {
    proto_dispatcher_name(op)
  }
}

# Hanga Roa shadow guard for the post-typer protocol-call rewrite.
# Returns `true` when the rewrite must back off because the callee
# is a bare-name call whose `(name, arity)` matches a top-level fn.
# Prefixed dispatchers (`__proto_<op>`) bypass the guard — they were
# synthesised specifically to land on the impl-table dispatch (by
# `lower_protocols`'s rename pass for non-shadowed call sites, and
# by `desugar_interp_decls` to stringify `#{...}` interpolations).
fn proto_call_is_shadowed(callee_name: String, arity: Int,
                            local_arities: [OpAr]) : Bool {
  let pfx = "__proto_"
  let n_pfx = string_length(pfx)
  let is_prefixed = string_length(callee_name) > n_pfx and
                    string_slice(callee_name, 0, n_pfx) == pfx
  if is_prefixed { false }
  else { op_ar_match(local_arities, callee_name, arity) }
}

# Resolver-arity / local-shadow (lane: resolver-local-shadow): collect
# every top-level `DFn` in the compilation unit as `(name, arity)`. A
# protocol op whose `(name, arity)` matches one of these is considered
# locally shadowed: the user (or stdlib) has provided their own fn by
# that name, so the rewriter should leave call sites alone and let the
# typer's normal name resolution pick the local DFn. The protocol
# remains reachable through a qualified call (e.g. `Show.show(x)`).
#
# The collection runs at the `lower_protocols` boundary on the
# pre-stripped decl stream, where impl methods are still nested inside
# `DImpl` (only ordinary top-level fns and `DAttribPure(DFn(..))`
# wrappers surface here). The resulting set is then used to filter
# `op_arities` *before* the rewrite, so each entry that is shadowed by
# a same-name same-arity local DFn drops out and never participates in
# the per-call rewrite logic.
#[doc("Collect every top-level DFn's (name, arity) so shadowed protocol ops can be excluded.")]
pub fn collect_local_fn_arities(ds: [Decl]) : [OpAr] {
  match ds {
    [] -> []
    [d, ...rest] -> match d {
      DFn(_, name, _, ps, _, _, _, _, _, _) ->
        [OpAr(name, list_length(ps)), ...collect_local_fn_arities(rest)]
      _ -> collect_local_fn_arities(rest)
    }
  }
}

# Per-module variant: each top-level DFn carries its home module so the
# shadow guard fires only against fns in the same module as the call
# site (see `LFnAr`).
#[doc("Collect every top-level DFn's (name, arity, module) for the per-module shadow guard.")]
pub fn collect_local_fn_arities_mo(ds: [Decl]) : [LFnAr] {
  match ds {
    [] -> []
    [d, ...rest] -> match d {
      DFn(_, name, _, ps, _, _, _, _, _, mo) ->
        [LFnAr(name, list_length(ps), mo), ...collect_local_fn_arities_mo(rest)]
      _ -> collect_local_fn_arities_mo(rest)
    }
  }
}

# Project the `[LFnAr]` set down to the `[OpAr]` shadows visible to a
# call site in module `mo`: a fn shadows only when it lives in the same
# module. `None` (root file) shadows only root-file call sites. This is
# the dominion fix for the global-shadow bug — `complex::add` no longer
# masks the `add` op outside complex.
#[doc("The (name, arity) shadows visible to a call site in module `mo`.")]
pub fn local_arities_for_mo(fns: [LFnAr], mo: Option[String]) : [OpAr] {
  match fns {
    [] -> []
    [f, ...rest] -> match f {
      LFnAr(name, ar, fmo) ->
        if opt_str_eq(fmo, mo) {
          [OpAr(name, ar), ...local_arities_for_mo(rest, mo)]
        } else {
          local_arities_for_mo(rest, mo)
        }
    }
  }
}

# Same as `local_arities_for_mo` but canonicalises each fn's module
# against `target_mod` first, so a root-file `pub fn` tagged
# `Some(target_mod)` lands in the same bucket as an untagged root call
# site (`canon_mo` maps both to `None`).
fn local_arities_for_mo_canon(fns: [LFnAr], mo: Option[String],
                               target_mod: String) : [OpAr] {
  match fns {
    [] -> []
    [f, ...rest] -> match f {
      LFnAr(name, ar, fmo) ->
        if opt_str_eq(canon_mo(fmo, target_mod), mo) {
          [OpAr(name, ar), ...local_arities_for_mo_canon(rest, mo, target_mod)]
        } else {
          local_arities_for_mo_canon(rest, mo, target_mod)
        }
    }
  }
}

# Names of every top-level fn in module `mo` (any arity). Feeds the
# bare-EVar value-position shadow: a local `fn one(n)` must win over a
# nullary protocol op `one()` when the bare name is used as a value, the
# same way a root fn shadows a stdlib `pub fn` on the call path. Arity
# is intentionally ignored here — a value reference carries no call
# shape to disambiguate by, so any same-named local fn shadows.
fn local_names_for_mo_canon(fns: [LFnAr], mo: Option[String],
                             target_mod: String) : [String] {
  match fns {
    [] -> []
    [f, ...rest] -> match f {
      LFnAr(name, _, fmo) ->
        if opt_str_eq(canon_mo(fmo, target_mod), mo) {
          [name, ...local_names_for_mo_canon(rest, mo, target_mod)]
        } else {
          local_names_for_mo_canon(rest, mo, target_mod)
        }
    }
  }
}

fn opt_str_eq(a: Option[String], b: Option[String]) : Bool {
  match a {
    None -> match b { None -> true _ -> false }
    Some(x) -> match b { None -> false Some(y) -> x == y }
  }
}

# Drop every op entry whose `(name, arity)` exists in `locals`. Same
# `(name, arity)` pair means a user-visible DFn shadows the protocol
# op; the rewrite should skip those call sites entirely so the local
# fn wins. A protocol op whose arity differs from the local DFn (the
# `min(xs)` / `Ord.min(a, b)` case) is preserved here and continues to
# rely on `op_ar_match`'s arity check at the call site.
#[doc("Drop protocol-op arities that a same-(name, arity) local fn shadows.")]
pub fn filter_shadowed_ops(ops: [OpAr], locals: [OpAr]) : [OpAr] {
  match ops {
    [] -> []
    [op, ...rest] -> match op {
      OpAr(n, a) ->
        if op_ar_match(locals, n, a) {
          filter_shadowed_ops(rest, locals)
        } else {
          [op, ...filter_shadowed_ops(rest, locals)]
        }
    }
  }
}

#[doc("Rewrite non-shadowed protocol-op call sites to the `__proto_<op>` dispatcher across all decls.")]
pub fn rename_proto_calls_decls(ds: [Decl], op_arities: [OpAr],
                                 local_names: [String]) : [Decl] =
  map(ds, (d) => rename_proto_calls_decl(d, op_arities, local_names))

# Per-module rename: each decl is rewritten against the raw op set
# filtered by the shadows of that decl's OWN module. A `pub fn add` in
# `complex` shadows `add` inside complex bodies but leaves the user's
# `add(a, b)` to reach `__proto_add`.
#[doc("Per-module variant of `rename_proto_calls_decls`: shadows are module-scoped.")]
# `target_mod` is the compilation unit's own module: a root-file decl
# carries `mo = None` OR `mo = Some(target_mod)` inconsistently (a `pub`
# fn gets tagged, a private one stays None), so both must canonicalise
# to the same "root" bucket — else a `pub fn show` (tagged) fails to
# shadow `Show.show` in `fn main` (untagged).
#[doc("Per-module variant of `rename_proto_calls_decls`: shadows are module-scoped.")]
pub fn rename_proto_calls_decls_mo(ds: [Decl], raw_ops: [OpAr],
                                    core_ops: [OpAr], local_fns: [LFnAr],
                                    target_mod: String) : [Decl] =
  rename_proto_calls_decls_mo_loop(ds, raw_ops, core_ops, local_fns, target_mod,
                                    ShadowByMod { entries: [], has_root: false,
                                                  root_ops: [], root_names: [] }, [])

# The (filtered_ops, names) pair a decl rewrites against depends only on
# its canonical module bucket — `local_fns`, the op sets and `target_mod`
# are invariant across the whole list. A self-compile carries thousands
# of decls but tens of distinct modules, so recomputing the per-module
# shadow set per decl is the same O(n²) retention #907/#912 fixed on the
# emit / KIR paths. Memoise the pair by module origin: one entry per
# distinct module, an `O(1)` lookup per decl.
#
# Directional visibility (#962): a root-file decl (`dmo = None`, the
# user) rewrites against `raw_ops` (every op); a named-module decl (core
# / core) rewrites against `core_ops` (only core-origin ops) so no
# user `protocol` can reach into a core body.
type ShadowByMod = { entries: [ShadowEntry], has_root: Bool,
                     root_ops: [OpAr], root_names: [String] }
type ShadowEntry = { key: String, ops: [OpAr], names: [String] }

fn sbm_lookup(entries: [ShadowEntry], k: String) : Option[ShadowEntry] = match entries {
  [] -> None
  [e, ...rest] -> if e.key == k { Some(e) } else { sbm_lookup(rest, k) }
}

type ShadowResult = { cache: ShadowByMod, ops: [OpAr], names: [String] }

fn shadow_for_mo(c: ShadowByMod, dmo: Option[String], raw_ops: [OpAr],
                 core_ops: [OpAr], local_fns: [LFnAr], target_mod: String) : ShadowResult = match dmo {
  None ->
    if c.has_root { ShadowResult { cache: c, ops: c.root_ops, names: c.root_names } }
    else {
      let ops = filter_shadowed_ops(raw_ops, local_arities_for_mo_canon(local_fns, None, target_mod))
      let names = local_names_for_mo_canon(local_fns, None, target_mod)
      ShadowResult { cache: ShadowByMod { entries: c.entries, has_root: true, root_ops: ops, root_names: names },
                     ops: ops, names: names }
    }
  Some(m) -> match sbm_lookup(c.entries, m) {
    Some(e) -> ShadowResult { cache: c, ops: e.ops, names: e.names }
    None    -> {
      let ops = filter_shadowed_ops(core_ops, local_arities_for_mo_canon(local_fns, dmo, target_mod))
      let names = local_names_for_mo_canon(local_fns, dmo, target_mod)
      ShadowResult { cache: ShadowByMod { entries: [ShadowEntry { key: m, ops: ops, names: names }, ...c.entries],
                                          has_root: c.has_root, root_ops: c.root_ops, root_names: c.root_names },
                     ops: ops, names: names }
    }
  }
}

fn rename_proto_calls_decls_mo_loop(ds: [Decl], raw_ops: [OpAr], core_ops: [OpAr],
                                     local_fns: [LFnAr], target_mod: String,
                                     c: ShadowByMod, acc: [Decl]) : [Decl] = match ds {
  [] -> list_reverse(acc)
  [d, ...rest] -> {
    let dmo = canon_mo(decl_module(d), target_mod)
    let r = shadow_for_mo(c, dmo, raw_ops, core_ops, local_fns, target_mod)
    let renamed = rename_proto_calls_decl(d, r.ops, r.names)
    rename_proto_calls_decls_mo_loop(rest, raw_ops, core_ops, local_fns, target_mod, r.cache,
                                     [renamed, ...acc])
  }
}

# Collapse `Some(target_mod)` and `None` to a single canonical `None`
# (the root bucket); foreign modules keep their `Some(name)`.
fn canon_mo(mo: Option[String], target_mod: String) : Option[String] {
  match mo {
    None -> None
    Some(m) -> if m == target_mod { None } else { Some(m) }
  }
}

# A decl's home module. `DFn` carries it; `DTest`/`DBench`/`DCheck` are
# always authored in the root file, so `None`.
fn decl_module(d: Decl) : Option[String] {
  match d {
    DFn(_, _, _, _, _, _, _, _, _, mo) -> mo
    _ -> None
  }
}

fn rename_proto_calls_decl(d: Decl, op_arities: [OpAr], local_names: [String]) : Decl {
  match d {
    DFn(pub_, n, tps, ps, ret, row, body, l, c, mo) -> {
      let bound = rename_param_names(ps, [])
      DFn(pub_, n, tps, ps, ret, row,
          rename_proto_calls_expr(body, op_arities, local_names, bound), l, c, mo)
    }
    DTest(desc, body, l, c) ->
      DTest(desc, rename_proto_calls_expr(body, op_arities, local_names, []), l, c)
    DBench(desc, body, l, c) ->
      DBench(desc, rename_proto_calls_expr(body, op_arities, local_names, []), l, c)
    DCheck(desc, ps, body, l, c) ->
      DCheck(desc, ps, rename_proto_calls_expr(body, op_arities, local_names, fn_param_names(ps)), l, c)
    _ -> d
  }
}

# Names introduced by a parameter list (fn / lambda / handler clause).
fn rename_param_names(ps: [Param], acc: [String]) : [String] {
  match ps {
    [] -> acc
    [p, ...rest] -> rename_param_names(rest, [p.pname, ...acc])
  }
}

# Names introduced by a single pattern. Mirrors `bind_pat` but
# accumulates into a `[String]` rather than a resolver Env.
fn rename_pat_names(p: Pattern, acc: [String]) : [String] {
  match p.pkind {
    PWild         -> acc
    PLit(_)       -> acc
    PRange(_, _)  -> acc
    PBind(name)   -> [name, ...acc]
    PList(pats, opt_rest) -> {
      let a = rename_pats_names(pats, acc)
      match opt_rest { Some(r) -> [r, ...a] None -> a }
    }
    PVariant(_, subs)        -> rename_pats_names(subs, acc)
    PVariantRecord(_, fs)    -> rename_pfields_names(fs, acc)
    PRecord(fs)              -> rename_pfields_names(fs, acc)
    PHole(_)                 -> acc
    PAs(name, sub)           -> rename_pat_names(sub, [name, ...acc])
    PNarrow(name, _)         -> [name, ...acc]
  }
}

fn rename_pats_names(ps: [Pattern], acc: [String]) : [String] {
  match ps {
    [] -> acc
    [p, ...rest] -> rename_pats_names(rest, rename_pat_names(p, acc))
  }
}

fn rename_pfields_names(fs: [PField], acc: [String]) : [String] {
  match fs {
    [] -> acc
    [pf, ...rest] -> match pf {
      PField(_, sub, _) -> rename_pfields_names(rest, rename_pat_names(sub, acc))
    }
  }
}

fn rename_proto_calls_expr(e: Expr, op_arities: [OpAr], local_names: [String], bound: [String]) : Expr =
  Expr { kind: rename_proto_calls_kind(e.kind, op_arities, local_names, bound),
         line: e.line, col: e.col, ty: e.ty, mode: e.mode }

fn rename_proto_calls_opt(o: Option[Expr], op_arities: [OpAr], local_names: [String], bound: [String]) : Option[Expr] {
  match o {
    Some(e) -> Some(rename_proto_calls_expr(e, op_arities, local_names, bound))
    None    -> None
  }
}

fn rename_proto_calls_arms(arms: [Arm], op_arities: [OpAr], local_names: [String], bound: [String]) : [Arm] =
  map(arms, (a) => rename_proto_calls_arm(a, op_arities, local_names, bound))

fn rename_proto_calls_arm(a: Arm, op_arities: [OpAr], local_names: [String], bound: [String]) : Arm {
  match a {
    Arm(p, g, b) -> {
      let bound1 = rename_pat_names(p, bound)
      Arm(p, rename_proto_calls_opt(g, op_arities, local_names, bound1),
            rename_proto_calls_expr(b, op_arities, local_names, bound1))
    }
  }
}

# m12.8.x scope-aware: SLet / SVar bindings extend the bound set for
# every later stmt in the same block AND for the trailing expression.
# `rename_proto_calls_block` threads the running `bound` accumulator;
# stmts that don't bind (SExprStmt / SAssert / SIndexAssign) walk
# their sub-exprs under the current `bound` and pass it through
# unchanged.
fn rename_proto_calls_block(stmts: [Stmt], tail: Option[Expr],
                              op_arities: [OpAr], local_names: [String], bound: [String]) : ExprKind =
  rename_proto_calls_block_loop(stmts, tail, op_arities, local_names, bound, [])

type StmtsAcc = { stmts: [Stmt], bound: [String] }

fn rename_proto_calls_block_loop(stmts: [Stmt], tail: Option[Expr],
                                   op_arities: [OpAr], local_names: [String], bound: [String],
                                   acc: [Stmt]) : ExprKind {
  match stmts {
    [] -> EBlock(list_reverse(acc),
                 rename_proto_calls_opt(tail, op_arities, local_names, bound))
    [s, ...rest] -> {
      let r = rename_proto_calls_stmt(s, op_arities, local_names, bound)
      rename_proto_calls_block_loop(rest, tail, op_arities, local_names, r.bound,
                                       [r.s, ...acc])
    }
  }
}

type StmtTyped = { s: Stmt, bound: [String] }

fn rename_proto_calls_stmt(s: Stmt, op_arities: [OpAr], local_names: [String], bound: [String]) : StmtTyped {
  match s {
    SLet(p, ann, rhs) -> {
      let new_rhs = rename_proto_calls_expr(rhs, op_arities, local_names, bound)
      let bound1 = rename_pat_names(p, bound)
      StmtTyped { s: SLet(p, ann, new_rhs), bound: bound1 }
    }
    SAssert(c, m) ->
      StmtTyped {
        s: SAssert(rename_proto_calls_expr(c, op_arities, local_names, bound),
                    rename_proto_calls_opt(m, op_arities, local_names, bound)),
        bound: bound
      }
    SExprStmt(x) ->
      StmtTyped {
        s: SExprStmt(rename_proto_calls_expr(x, op_arities, local_names, bound)),
        bound: bound
      }
    SIndexAssign(b, i, v, l, c) ->
      StmtTyped {
        s: SIndexAssign(rename_proto_calls_expr(b, op_arities, local_names, bound),
                         rename_proto_calls_expr(i, op_arities, local_names, bound),
                         rename_proto_calls_expr(v, op_arities, local_names, bound), l, c),
        bound: bound
      }
    SVar(n, ty, rhs, l, c) -> {
      let new_rhs = rename_proto_calls_expr(rhs, op_arities, local_names, bound)
      StmtTyped {
        s: SVar(n, ty, new_rhs, l, c),
        bound: [n, ...bound]
      }
    }
    # m7e §25: SUse stripped pre-resolve; nothing to rewrite, no
    # bindings introduced.
    SUse(n, l, c) -> StmtTyped { s: SUse(n, l, c), bound: bound }
  }
}

fn rename_proto_calls_clauses(cs: [HClause], op_arities: [OpAr], local_names: [String], bound: [String]) : [HClause] =
  map(cs, (c) => rename_proto_calls_clause(c, op_arities, local_names, bound))

fn rename_proto_calls_clause(c: HClause, op_arities: [OpAr], local_names: [String], bound: [String]) : HClause {
  match c {
    HC(n, ps, b, l, co) -> {
      let bound1 = rename_param_names(ps, bound)
      HC(n, ps, rename_proto_calls_expr(b, op_arities, local_names, bound1), l, co)
    }
  }
}

fn rename_proto_calls_opt_return(o: Option[HReturn], op_arities: [OpAr], local_names: [String], bound: [String]) : Option[HReturn] {
  match o {
    Some(r) -> Some(rename_proto_calls_return(r, op_arities, local_names, bound))
    None    -> None
  }
}

fn rename_proto_calls_return(r: HReturn, op_arities: [OpAr], local_names: [String], bound: [String]) : HReturn {
  match r {
    HR(p, b, l, c) -> HR(p, rename_proto_calls_expr(b, op_arities, local_names, [p, ...bound]), l, c)
  }
}

fn rename_proto_calls_kind(k: ExprKind, op_arities: [OpAr], local_names: [String], bound: [String]) : ExprKind {
  match k {
    # Rep invariant (b): a bare EVar referring to a protocol op rewrites
    # to its dispatcher only when the name is NOT bound by an enclosing
    # binder (lambda param, let/var, match pattern, handler clause
    # param, return-clause binder). Bound tracking is what
    # `validate_typer_invariants` cross-checks; this case is the
    # construction site.
    #
    # A same-named local fn also shadows here. Value position carries no
    # call shape, so a `fn one(n)` shadows the nullary op `one()` even at
    # a different arity — mirroring the root-fn-over-stdlib shadow on the
    # call path. (The call path below stays arity-aware: `Ord.min(a, b)`
    # still reaches the dispatcher next to a local `fn min(xs)`.)
    EVar(name) -> {
      let shadowed = list_has(bound, name) or list_has(local_names, name)
      if op_ar_has_name(op_arities, name) and not shadowed {
        EVar(proto_dispatcher_name(name))
      } else { k }
    }
    # Resolver-arity (lane: resolver-arity): when a call's callee is a
    # bare EVar matching a protocol op name, only rewrite to the
    # dispatcher when the call's argument count matches a declared
    # arity for that op. Otherwise the callee is left verbatim so the
    # typer's normal name resolution can find a same-named module
    # function with a different arity (e.g. `pub fn max(xs)` arity 1
    # vs `Ord.max(a, b)` arity 2). The args still walk under the
    # standard rewrite (they may themselves call protocol ops).
    ECall(callee, args_) -> match callee.kind {
      EVar(name) -> {
        let is_op = op_ar_has_name(op_arities, name)
        let bound_locally = list_has(bound, name)
        let arity = list_length(args_)
        let arity_ok = op_ar_match(op_arities, name, arity)
        let preserve_callee = is_op and not bound_locally and not arity_ok
        let new_args = map(args_, (a) => rename_proto_calls_expr(a, op_arities, local_names, bound))
        if preserve_callee {
          # Same name as a protocol op but the call's arity matches
          # neither variant. Keep the callee EVar untouched; the
          # arity-1-list-fn case (e.g. `max(xs)`) lands here when
          # `Ord.max(a, b)` is the only protocol op.
          ECall(callee, new_args)
        } else if is_op and not bound_locally {
          # Matched a protocol op at this arity. Rename to the
          # arity-resolved dispatcher (suffixed only when the name is
          # arity-ambiguous), bypassing the structural EVar branch so
          # the arity of THIS call selects the dispatcher.
          let disp = proto_dispatcher_name_at(op_arities, name, arity)
          ECall(mk_expr(EVar(disp), callee.line, callee.col), new_args)
        } else {
          # No protocol-op collision (or a locally-bound name): fall
          # through to the structural recursion unchanged.
          ECall(rename_proto_calls_expr(callee, op_arities, local_names, bound), new_args)
        }
      }
      _ -> ECall(rename_proto_calls_expr(callee, op_arities, local_names, bound),
                  map(args_, (a) => rename_proto_calls_expr(a, op_arities, local_names, bound)))
    }
    # Scope-aware kinds. Each adds names to `bound` before recursing
    # into the bodies that they shadow.
    EBlock(stmts, tail) -> rename_proto_calls_block(stmts, tail, op_arities, local_names, bound)
    ELambda(ps, b) -> {
      let bound1 = rename_param_names(ps, bound)
      ELambda(ps, rename_proto_calls_expr(b, op_arities, local_names, bound1))
    }
    EMatch(scr, arms) -> EMatch(rename_proto_calls_expr(scr, op_arities, local_names, bound),
                                  rename_proto_calls_arms(arms, op_arities, local_names, bound))
    EHandle(body, eff_name, eff_tyargs, init_opt, alias_opt, clauses, ret_opt) ->
      EHandle(rename_proto_calls_expr(body, op_arities, local_names, bound), eff_name, eff_tyargs,
              proto_map_opt_expr(init_opt, (e) => rename_proto_calls_expr(e, op_arities, local_names, bound)),
              alias_opt,
              rename_proto_calls_clauses(clauses, op_arities, local_names, bound),
              rename_proto_calls_opt_return(ret_opt, op_arities, local_names, bound))
    # All remaining kinds (EField, EIndex, EBinop, EUnop, EIf,
    # ERecordLit, EList, ERange, EPipe, EBang, ELitUnit) recurse purely
    # structurally without changing the bound set; the leaves return
    # unchanged. The shared visitor handles both — keeping invariant
    # (b)'s scope tracking concentrated in the explicit cases above
    # where it actually matters.
    _ -> proto_map_expr_kind(k, (sub) => rename_proto_calls_expr(sub, op_arities, local_names, bound))
  }
}

# ====================================================================
# m12.8 — post-inference protocol-call rewrite
# ====================================================================
#
# Once `infer_program` has populated `Expr.ty` on every node, walk
# the typed AST and replace every reachable
#
#   ECall(EVar("op"), [arg0, arg1, ...])
#
# (where `op` is a registered protocol op AND `arg0.ty` resolves to
# a concrete type-constructor name `T`) with
#
#   ECall(EVar("__pimpl_<P>_<T>_<op>"), [arg0, arg1, ...])
#
# The rewrite is purely syntactic — every callee already has a body
# in scope (lower_protocols emitted it), so the call links normally.
# Calls whose `arg0.ty` is unknown OR for which no impl exists fall
# through and execute the dispatcher fn's `panic` at runtime; the
# spec wants a compile-time error there but the v1 keeps the runtime
# fallback so partial programs (typed holes, generic helpers without
# concrete dispatch info) still build.

#[doc("Pass B: rewrite every resolved `op(x, ...)` to its matching impl fn across the typed program.")]
pub fn resolve_protocol_calls(typed: TypedProgram, reg: ProtocolReg,
                            local_arities: [OpAr]) : TypedProgram {
  TypedProgram {
    decls: map(typed.decls, (d) => resolve_protocol_calls_decl(d, reg, local_arities)),
    errs: typed.errs,
    insts: typed.insts,
    holes: typed.holes,
    row_holes: typed.row_holes,
    core_len: typed.core_len,
    toplevel_len: typed.toplevel_len,
    module_doc: typed.module_doc,
    diags: typed.diags,
    op_res: typed.op_res
  }
}

#[doc("Per-decl hook of pass B; the N2 monomorph lane imports this to rewrite during monomorphisation.")]
pub fn resolve_protocol_calls_decl(d: Decl, reg: ProtocolReg,
                                 local_arities: [OpAr]) : Decl {
  match d {
    DFn(pub_, n, tps, ps, ret, row, body, l, c, mo) ->
      DFn(pub_, n, tps, ps, ret, row,
          resolve_protocol_calls_expr(body, reg, local_arities), l, c, mo)
    DTest(desc, body, l, c) ->
      DTest(desc, resolve_protocol_calls_expr(body, reg, local_arities), l, c)
    DBench(desc, body, l, c) ->
      DBench(desc, resolve_protocol_calls_expr(body, reg, local_arities), l, c)
    DCheck(desc, ps, body, l, c) ->
      DCheck(desc, ps, resolve_protocol_calls_expr(body, reg, local_arities), l, c)
    _ -> d
  }
}

fn resolve_protocol_calls_expr(e: Expr, reg: ProtocolReg,
                                 local_arities: [OpAr]) : Expr {
  let new_kind = resolve_protocol_calls_kind(e.kind, reg, local_arities,
                                               e.ty, e.line, e.col)
  # Issue #180: a `Real + Complex` binop was typed by the generic
  # dispatcher as `Self` (the LHS head, Real) — wrong, the heterogeneous
  # `impl Add[Complex] for Real` returns `Complex`. The rewrite above
  # has now redirected the call to that impl's `__pimpl_*` symbol; read
  # the impl's declared return head and, when it differs from the node's
  # dispatcher-derived type, correct it. This runs before unboxing, so
  # the unbox pass then sees `Complex` (boxed) instead of `Real`
  # (unboxed) and emits a `KaiValue*` record load rather than reading
  # the Complex record as a raw `double`. The impl's return IS the
  # promotion target (Int -> Real -> Complex); no type hierarchy is
  # needed beyond what the impl already declares.
  let new_ty = proto_rewrite_corrected_ty(new_kind, e.ty, reg)
  Expr { kind: new_kind, line: e.line, col: e.col, ty: new_ty, mode: e.mode }
}

# When `kind` is a rewritten `ECall(EVar("__pimpl_..."), _)` whose impl
# declares a return head differing from `cur_ty`, return the corrected
# `Some(TyCon(None, ret_head, []))`. Otherwise return `cur_ty` unchanged.
fn proto_rewrite_corrected_ty(kind: ExprKind, cur_ty: Option[Ty], reg: ProtocolReg) : Option[Ty] {
  match kind {
    ECall(callee, _) -> match callee.kind {
      EVar(sym) -> {
        let pool = if ii_built(reg.impl_index) { ii_sym_bucket(reg.impl_index, sym) }
                   else { reg.impls }
        let rh = impl_ret_head_by_sym(pool, sym)
        if rh == "" { cur_ty }
        else {
          let cur_head = match cur_ty {
            Some(t) -> match ty_head_name(t) { Some(n) -> n  None -> "" }
            None    -> ""
          }
          if rh == cur_head { cur_ty }
          else { Some(TyCon(None, rh, [])) }
        }
      }
      _ -> cur_ty
    }
    _ -> cur_ty
  }
}

# Find the registered impl whose mangled fn name is `sym` and return
# its declared return head; "" when `sym` is not an impl symbol.
fn impl_ret_head_by_sym(impls: [ProtoImplReg], sym: String) : String {
  match impls {
    [] -> ""
    [it, ...rest] -> match it {
      PIR(_, _, _, mg, _, rh) ->
        if mg == sym { rh } else { impl_ret_head_by_sym(rest, sym) }
    }
  }
}

fn resolve_protocol_calls_kind(k: ExprKind, reg: ProtocolReg,
                                local_arities: [OpAr],
                                ret_ty: Option[Ty],
                                line: Int, col: Int) : ExprKind {
  match k {
    # The only kind that needs special handling: a typed `ECall` whose
    # callee resolves to a registered protocol op + args[0].ty matches
    # a registered impl gets rewritten to `__pimpl_<P>_<T>_<op>`. All
    # other kinds recurse purely structurally — there is no scope
    # bookkeeping at this stage.
    ECall(callee, args_) -> {
      let new_args = map(args_, (a) => resolve_protocol_calls_expr(a, reg, local_arities))
      let new_callee = resolve_protocol_calls_expr(callee, reg, local_arities)
      # Issue #180: pass the call's inferred return type so dispatchers
      # whose only Self informant is the return position (e.g.
      # `from(x) : Self` against a `let x : T = from(...)` annotation)
      # can resolve `Self` from that pin.
      let rewritten = try_rewrite_proto_call_with_ret(new_callee, new_args,
                                                       reg, local_arities, ret_ty)
      match rewritten {
        Some(rk) -> rk
        None     -> ECall(new_callee, new_args)
      }
    }
    # `==` / `!=` / `<` / `>` / `<=` / `>=` are sugar for Eq.eq / Ord.cmp.
    # The typer leaves them as the structural builtin EBinop; here, with
    # concrete operand types (post-monomorph per spec), rewrite to the
    # custom impl when the left operand's type carries one. Fully
    # structural types (no custom impl — the common case, e.g. the
    # compiler's own Expr/Stmt) keep the builtin EBinop unchanged.
    EBinop(op, l, r) -> {
      let nl = resolve_protocol_calls_expr(l, reg, local_arities)
      let nr = resolve_protocol_calls_expr(r, reg, local_arities)
      prc_rewrite_cmp_binop(op, nl, nr, reg)
    }
    _ -> proto_map_expr_kind(k, (sub) => resolve_protocol_calls_expr(sub, reg, local_arities))
  }
}

# Rewrite a comparison binop to a custom-impl call when the left
# operand's type has one. `==`/`!=` → Eq.eq (`!=` wraps in `not`);
# `<`/`>`/`<=`/`>=` → Ord.cmp reduced to Bool against 0. Any other op,
# or an operand type with no custom impl, is left as the structural
# builtin EBinop (which lowers to kai_op_eq_v / direct compare).
fn prc_rewrite_cmp_binop(op: String, l: Expr, r: Expr, reg: ProtocolReg) : ExprKind {
  if op == "==" or op == "!=" {
    match prc_cmp_custom_head(reg, "Eq", l.ty) {
      None -> EBinop(op, l, r)
      Some(head) -> {
        let mangled = concat_all(["__pimpl_Eq_", head, "_eq"])
        let eqcall = prc_mk_ty(ECall(mk_expr(EVar(mangled), l.line, l.col), [l, r]),
                               l.line, l.col, Some(TyBool))
        if op == "==" {
          ECall(mk_expr(EVar(mangled), l.line, l.col), [l, r])
        } else {
          EUnop("not", eqcall)
        }
      }
    }
  } else if op == "<" or op == ">" or op == "<=" or op == ">=" {
    match prc_cmp_custom_head(reg, "Ord", l.ty) {
      None -> EBinop(op, l, r)
      Some(head) -> {
        let mangled = concat_all(["__pimpl_Ord_", head, "_cmp"])
        let cmpcall = prc_mk_ty(ECall(mk_expr(EVar(mangled), l.line, l.col), [l, r]),
                                l.line, l.col, Some(TyInt))
        let zero = prc_mk_ty(EInt(0), l.line, l.col, Some(TyInt))
        EBinop(op, cmpcall, zero)
      }
    }
  } else {
    EBinop(op, l, r)
  }
}

# Build an Expr with an explicit type annotation. `mk_expr` defaults
# `ty` to None; the cmp rewrite pins TyBool / TyInt so downstream
# passes see concrete types.
fn prc_mk_ty(k: ExprKind, line: Int, col: Int, ty: Option[Ty]) : Expr =
  Expr { kind: k, line: line, col: col, ty: ty, mode: MUnknown }

# Head type name iff `proto` (Eq / Ord) has a user `impl proto for T`
# registered for the operand's root type. `None` when the type is
# fully structural (no custom impl) or unresolved → keep the builtin.
# v1 checks the root type only; a contained field with a custom impl
# is a documented follow-up (the compiler's own comparisons are all
# fully structural, so root-only suffices for self-host correctness).
fn prc_cmp_custom_head(reg: ProtocolReg, proto: String, ty: Option[Ty]) : Option[String] {
  match ty {
    None -> None
    Some(t) -> match prc_ty_head_name(t) {
      None -> None
      Some(head) ->
        if prc_reg_has_impl(reg, proto, head) { Some(head) } else { None }
    }
  }
}

# Root head name of a Ty, for impl-table lookup. Only nominal TyCon
# heads can carry a user impl; everything else returns None.
fn prc_ty_head_name(t: Ty) : Option[String] {
  match t {
    TyCon(_, name, _) -> Some(name)
    _ -> None
  }
}

# True iff `reg` holds an `impl proto for head` entry. The index
# narrows the scan to the `(proto, head)` bucket; the same membership
# predicate then runs over that short list (or the full table when the
# index is the unbuilt placeholder), so the answer is unchanged.
#[doc("True iff `reg` holds an `impl proto for head` entry (user or derive-synthesised); O(1) via the impl index when built.")]
pub fn prc_reg_has_impl(reg: ProtocolReg, proto: String, head: String) : Bool =
  if ii_built(reg.impl_index) {
    prc_impls_has(ii_key_bucket(reg.impl_index, proto, head), proto, head)
  } else {
    prc_impls_has(reg.impls, proto, head)
  }

fn prc_impls_has(impls: [ProtoImplReg], proto: String, head: String) : Bool {
  match impls {
    [] -> false
    [pir, ...rest] -> match pir {
      PIR(p, t, _, _, _, _) ->
        if p == proto and t == head { true }
        else { prc_impls_has(rest, proto, head) }
    }
  }
}

# m12.8.x phase 2 (Bug 5): post-rewrite validation. After
# `resolve_protocol_calls` has rewritten every dispatchable
# `__proto_<op>(receiver, ...)` call into the matching
# `__pimpl_<P>_<T>_<op>` direct call, walk the typed AST and report
# any *remaining* dispatcher-shaped calls whose receiver type is
# concrete but has no impl. This is the compile-time error the
# `m12_8_y_postfix_no_impl` and similar negative fixtures expect.
# Calls whose receiver is still a TyVar (the polymorphic-helper
# fallthrough case the m12.8 v1 deliberately allowed) keep the
# dispatcher panic at runtime.
#[doc("Post-rewrite static-coherence check over the whole typed program.")]
pub fn validate_resolved_protocols(typed: TypedProgram, reg: ProtocolReg,
                                file: String) : Int / Console + File =


  validate_resolved_decls(typed.decls, reg, file, 0)

#[doc("Post-rewrite static-coherence check over a decl list (used after monomorphisation).")]
pub fn validate_resolved_decls(ds: [Decl], reg: ProtocolReg,
                            file: String, errs: Int) : Int / Console + File {


  match ds {
    [] -> errs
    [d, ...rest] -> {
      let e1 = match d {
        DFn(_, _, _, _, _, _, body, _, _, _) ->
          validate_resolved_expr(body, reg, file, errs)
        DTest(_, body, _, _) ->
          validate_resolved_expr(body, reg, file, errs)
        DBench(_, body, _, _) ->
          validate_resolved_expr(body, reg, file, errs)
        DCheck(_, _, body, _, _) ->
          validate_resolved_expr(body, reg, file, errs)
        _ -> errs
      }
      validate_resolved_decls(rest, reg, file, e1)
    }
  }
}

fn validate_resolved_expr(e: Expr, reg: ProtocolReg, file: String,
                           errs: Int) : Int / Console + File {


  let e1 = validate_proto_call_at(e, reg, file, errs)
  validate_resolved_kind(e.kind, reg, file, e1)
}

fn validate_resolved_opt(o: Option[Expr], reg: ProtocolReg, file: String,
                          errs: Int) : Int / Console + File {


  match o {
    Some(e) -> validate_resolved_expr(e, reg, file, errs)
    None    -> errs
  }
}

fn validate_resolved_exprs(es: [Expr], reg: ProtocolReg, file: String,
                            errs: Int) : Int / Console + File {


  match es {
    [] -> errs
    [e, ...rest] -> {
      let e1 = validate_resolved_expr(e, reg, file, errs)
      validate_resolved_exprs(rest, reg, file, e1)
    }
  }
}

fn validate_resolved_arms(arms: [Arm], reg: ProtocolReg, file: String,
                           errs: Int) : Int / Console + File {


  match arms {
    [] -> errs
    [a, ...rest] -> match a {
      Arm(_, g, b) -> {
        let e1 = validate_resolved_opt(g, reg, file, errs)
        let e2 = validate_resolved_expr(b, reg, file, e1)
        validate_resolved_arms(rest, reg, file, e2)
      }
    }
  }
}

fn validate_resolved_stmts(ss: [Stmt], reg: ProtocolReg, file: String,
                            errs: Int) : Int / Console + File {


  match ss {
    [] -> errs
    [s, ...rest] -> {
      let e1 = match s {
        SLet(_, _, rhs) -> validate_resolved_expr(rhs, reg, file, errs)
        SAssert(c, m) -> {
          let x = validate_resolved_expr(c, reg, file, errs)
          validate_resolved_opt(m, reg, file, x)
        }
        SExprStmt(x) -> validate_resolved_expr(x, reg, file, errs)
        SIndexAssign(b, i, v, _, _) -> {
          let x = validate_resolved_expr(b, reg, file, errs)
          let y = validate_resolved_expr(i, reg, file, x)
          validate_resolved_expr(v, reg, file, y)
        }
        SVar(_, _, rhs, _, _) -> validate_resolved_expr(rhs, reg, file, errs)
        # m7e §25: SUse has no expression to validate.
        SUse(_, _, _) -> errs
      }
      validate_resolved_stmts(rest, reg, file, e1)
    }
  }
}

fn validate_resolved_clauses(cs: [HClause], reg: ProtocolReg,
                              file: String, errs: Int) : Int / Console + File {


  match cs {
    [] -> errs
    [c, ...rest] -> match c {
      HC(_, _, b, _, _) -> {
        let e1 = validate_resolved_expr(b, reg, file, errs)
        validate_resolved_clauses(rest, reg, file, e1)
      }
    }
  }
}

fn validate_resolved_opt_return(o: Option[HReturn], reg: ProtocolReg,
                                 file: String, errs: Int) : Int / Console + File {


  match o {
    Some(r) -> match r { HR(_, b, _, _) -> validate_resolved_expr(b, reg, file, errs) }
    None -> errs
  }
}

fn validate_resolved_fields(fs: [FieldInit], reg: ProtocolReg,
                             file: String, errs: Int) : Int / Console + File {


  match fs {
    [] -> errs
    [f, ...rest] -> match f {
      FI(_, v) -> {
        let e1 = validate_resolved_expr(v, reg, file, errs)
        validate_resolved_fields(rest, reg, file, e1)
      }
    }
  }
}

fn validate_resolved_list_elems(els: [ListElem], reg: ProtocolReg,
                                 file: String, errs: Int) : Int / Console + File {


  match els {
    [] -> errs
    [el, ...rest] -> {
      let e1 = match el {
        ElPlain(x)  -> validate_resolved_expr(x, reg, file, errs)
        ElSpread(x) -> validate_resolved_expr(x, reg, file, errs)
      }
      validate_resolved_list_elems(rest, reg, file, e1)
    }
  }
}

fn validate_resolved_kind(k: ExprKind, reg: ProtocolReg, file: String,
                           errs: Int) : Int / Console + File {


  match k {
    ECall(c, args_) -> {
      let e1 = validate_resolved_expr(c, reg, file, errs)
      validate_resolved_exprs(args_, reg, file, e1)
    }
    EBlock(ss, t) -> {
      let e1 = validate_resolved_stmts(ss, reg, file, errs)
      validate_resolved_opt(t, reg, file, e1)
    }
    EIf(c, t_, eo) -> {
      let e1 = validate_resolved_expr(c, reg, file, errs)
      let e2 = validate_resolved_expr(t_, reg, file, e1)
      validate_resolved_opt(eo, reg, file, e2)
    }
    EBinop(_, a, b) -> {
      let e1 = validate_resolved_expr(a, reg, file, errs)
      validate_resolved_expr(b, reg, file, e1)
    }
    EUnop(_, x) -> validate_resolved_expr(x, reg, file, errs)
    EHandle(body, _, _, init_opt, _, clauses, ret_opt) -> {
      let e1 = validate_resolved_expr(body, reg, file, errs)
      let e2 = validate_resolved_opt(init_opt, reg, file, e1)
      let e3 = validate_resolved_clauses(clauses, reg, file, e2)
      validate_resolved_opt_return(ret_opt, reg, file, e3)
    }
    ELambda(_, b) -> validate_resolved_expr(b, reg, file, errs)
    EMatch(scr, arms) -> {
      let e1 = validate_resolved_expr(scr, reg, file, errs)
      validate_resolved_arms(arms, reg, file, e1)
    }
    EPipe(a, b) -> {
      let e1 = validate_resolved_expr(a, reg, file, errs)
      validate_resolved_expr(b, reg, file, e1)
    }
    EMapPipe(a, b) -> {
      let e1 = validate_resolved_expr(a, reg, file, errs)
      validate_resolved_expr(b, reg, file, e1)
    }
    EFlatMapPipe(a, b) -> {
      let e1 = validate_resolved_expr(a, reg, file, errs)
      validate_resolved_expr(b, reg, file, e1)
    }
    EFilterPipe(a, b) -> {
      let e1 = validate_resolved_expr(a, reg, file, errs)
      validate_resolved_expr(b, reg, file, e1)
    }
    EField(base, _) -> validate_resolved_expr(base, reg, file, errs)
    EIndex(a, b) -> {
      let e1 = validate_resolved_expr(a, reg, file, errs)
      validate_resolved_expr(b, reg, file, e1)
    }
    ERecordLit(_, fields) -> validate_resolved_fields(fields, reg, file, errs)
    EList(elems) -> validate_resolved_list_elems(elems, reg, file, errs)
    ERange(a, b, opt_step) -> {
      let e1 = validate_resolved_expr(a, reg, file, errs)
      let e2 = validate_resolved_expr(b, reg, file, e1)
      validate_resolved_opt(opt_step, reg, file, e2)
    }
    EBang(inner) -> validate_resolved_expr(inner, reg, file, errs)
    ELitUnit(inner, _) -> validate_resolved_expr(inner, reg, file, errs)
    _ -> errs
  }
}

fn validate_proto_call_at(e: Expr, reg: ProtocolReg, file: String,
                           errs: Int) : Int / Console + File {


  match e.kind {
    ECall(callee, args_) -> match callee.kind {
      EVar(name) -> {
        let opname = strip_proto_dispatcher_prefix(name)
        # Only inspect calls that survived the rewrite as
        # `__proto_<op>(...)` (the prefix-strip yields a different
        # name) AND whose op is one of our registered protocol ops.
        if name == opname { errs }
        else if not list_has(reg.op_names, opname) { errs }
        else {
          match args_ {
            [] -> errs
            [self_arg, ..._rest_args] -> match self_arg.ty {
              None -> errs
              Some(ty) -> match ty_head_name(ty) {
                None -> errs
                # Collision-aware: an impl under ANY protocol declaring
                # `opname` clears the call (the bare name carries no
                # protocol, so `Ring.add` and `Add.add` are both valid
                # targets for `add`).
                Some(tname) -> match find_impl_any_proto(reg, opname, tname) {
                  Some(_) -> errs
                  None -> {
                    let pname = first_proto_of_op(reg, opname)
                    diag_error(file, e.line, e.col,
                      concat_all(["no impl of `", pname,
                                  "` for type `", tname,
                                  "` (operation `", opname, "`)"]))
                    errs + 1
                  }
                }
              }
            }
          }
        }
      }
      _ -> errs
    }
    _ -> errs
  }
}

# ====================================================================
# m12.8.x post-Core REOPEN — Eric level 2: rep invariant verifiers
# ====================================================================
#
# Three walkers verify properties that should hold over the
# post-resolve typed AST. Each is a structural fold over Decl /
# Expr / Stmt / Arm / HClause / HReturn, accumulating an error
# count and (for invariant (b)) a lexical scope set. Diagnostics
# go to stderr via `diag_error`. Errors increment the count, so
# `compile_source` can fail the compile when any invariant breaks.
#
# These complement (not replace) the per-pass audits done in
# `7bd5a68`. They catch a class of bug at the boundary between
# passes — when one pass produces an AST node that violates an
# invariant the next pass assumes — without requiring a shared
# AST visitor refactor (deferred per CLAUDE.md "no premature
# abstraction").
#
# Invariants:
#   (a) Every Expr post-finalise has `Some(_)` ty annotation.
#       Catches the "discarded typed body" pattern (`10a1e7b`):
#       a pass that builds a new Expr from a sub-expr produced by
#       `synth` MUST use the typed sub-expr, not the original
#       (untyped) one. The original has `None` ty on its internal
#       nodes; finalise leaves `None` in place; this walker fires.
#   (b) Every `EVar(__proto_X)` reference has `X` outside every
#       enclosing binder. Catches the "scope-blind protocol
#       rename" pattern (`257b247`).
#   (c) Every `ELambda` whose `.ty` is `TyFnT` has an open row
#       tail. Catches the "closed lambda row" pattern (`b528655`).
#
# Wired into `compile_source` after `validate_resolved_protocols`,
# before perceus / monomorph / emit.

#[doc("Pass C: Eric level-2 rep-invariant verifier over the typed program.")]
pub fn validate_typer_invariants(typed: TypedProgram, file: String) : Int / Console + File =


  validate_inv_decls(typed.decls, file, 0)

fn validate_inv_decls(ds: [Decl], file: String, errs: Int) : Int / Console + File {


  match ds {
    [] -> errs
    [d, ...rest] -> {
      let e1 = match d {
        DFn(_, _, _, ps, _, _, body, _, _, _) -> {
          let bound0 = inv_param_names(ps, [])
          validate_inv_expr(body, file, bound0, errs)
        }
        DTest(_, body, _, _) ->
          validate_inv_expr(body, file, [], errs)
        DBench(_, body, _, _) ->
          validate_inv_expr(body, file, [], errs)
        DCheck(_, ps, body, _, _) -> {
          let bound0 = inv_param_names(ps, [])
          validate_inv_expr(body, file, bound0, errs)
        }
        _ -> errs
      }
      validate_inv_decls(rest, file, e1)
    }
  }
}

fn inv_param_names(ps: [Param], acc: [String]) : [String] {
  match ps {
    [] -> acc
    [p, ...rest] -> inv_param_names(rest, [p.pname, ...acc])
  }
}

# Mirrors `bind_pat`/`pat_bindings` shape — accumulates pattern-
# bound names into a [String] for invariant (b)'s scope check.
fn inv_pat_names(p: Pattern, acc: [String]) : [String] {
  match p.pkind {
    PWild         -> acc
    PLit(_)       -> acc
    PRange(_, _)  -> acc
    PBind(name)   -> [name, ...acc]
    PList(pats, opt_rest) -> {
      let a = inv_pats_names(pats, acc)
      match opt_rest { Some(r) -> [r, ...a] None -> a }
    }
    PVariant(_, subs)        -> inv_pats_names(subs, acc)
    PVariantRecord(_, fs)    -> inv_pfields_names(fs, acc)
    PRecord(fs)              -> inv_pfields_names(fs, acc)
    PHole(_)                 -> acc
    PAs(name, sub)           -> inv_pat_names(sub, [name, ...acc])
    PNarrow(name, _)         -> [name, ...acc]
  }
}

fn inv_pats_names(ps: [Pattern], acc: [String]) : [String] {
  match ps {
    [] -> acc
    [p, ...rest] -> inv_pats_names(rest, inv_pat_names(p, acc))
  }
}

fn inv_pfields_names(fs: [PField], acc: [String]) : [String] {
  match fs {
    [] -> acc
    [pf, ...rest] -> match pf {
      PField(_, sub, _) -> inv_pfields_names(rest, inv_pat_names(sub, acc))
    }
  }
}

fn validate_inv_expr(e: Expr, file: String, bound: [String], errs: Int) : Int / Console + File {


  # Invariant (a) — "every Expr has Some(ty) post-finalise" — was
  # too strict: post-typer rewrite passes (`try_rewrite_proto_call`,
  # the AST splicer in `desugar_interp`, etc.) construct fresh
  # `mk_expr(...)` nodes whose `ty` is None
  # by design — the rewriters are syntactic and have no typer
  # substitution to apply. A useful (a) needs a "this node was
  # constructed by a post-typer pass" tracker that today does not
  # exist. Deferred until that tracker is justified — the original
  # bug class (`10a1e7b`, discarded typed clause body) is already
  # covered by the audit done in `7bd5a68`.
  let e_bc = validate_inv_kind(e.kind, e.ty, file, e.line, e.col, bound, errs)
  validate_inv_subexprs(e.kind, file, bound, e_bc)
}

fn validate_inv_kind(k: ExprKind, ty: Option[Ty], file: String,
                      line: Int, col: Int, bound: [String], errs: Int) : Int / Console + File {


  match k {
    EVar(name) -> {
      let opname = strip_proto_dispatcher_prefix(name)
      # Invariant (b): every `EVar(__proto_X)` reference has `X`
      # outside every enclosing binder. Catches the scope-blind
      # `rename_proto_calls` pattern (`257b247`).
      # Only check references that are dispatcher-shaped
      # (`__proto_X`); a bare user identifier whose name happens to
      # match a binder is fine.
      if name == opname { errs }
      else if list_has(bound, opname) {
        diag_error(file, line, col,
          concat_all(["rep invariant (b): protocol-dispatcher reference `",
                      name, "` shadows local binder `", opname,
                      "` in scope (rename pass missed scope tracking)"]))
        errs + 1
      } else { errs }
    }
    # Invariant (c) — "every `synth_lambda`-produced TyFnT has open
    # row tail" — was attempted as a post-finalise check on
    # ELambda's `.ty`. It over-fires: unification can legitimately
    # bind a fresh open row var to a closed row when the call site
    # expects a closed row (e.g., `list_sort_by`'s `cmp: (a, a) ->
    # Int` declares no row). Post-finalise we cannot distinguish
    # "the row was closed by default at construction" from "the row
    # was closed by unification to a concrete callee type". The
    # check belongs at the construction site (inside `synth_lambda`,
    # as an assertion on `lam_row.tail`), not as a post-hoc walker.
    # Keep audit at the construction site as the real defense; this
    # walker exits early on ELambda.
    _ -> errs
  }
}

fn validate_inv_subexprs(k: ExprKind, file: String, bound: [String], errs: Int) : Int / Console + File {


  match k {
    ECall(c, xs) -> {
      let e1 = validate_inv_expr(c, file, bound, errs)
      validate_inv_exprs(xs, file, bound, e1)
    }
    EField(b, _) -> validate_inv_expr(b, file, bound, errs)
    EIndex(a, b) -> {
      let e1 = validate_inv_expr(a, file, bound, errs)
      validate_inv_expr(b, file, bound, e1)
    }
    EBinop(_, a, b) -> {
      let e1 = validate_inv_expr(a, file, bound, errs)
      validate_inv_expr(b, file, bound, e1)
    }
    EUnop(_, x) -> validate_inv_expr(x, file, bound, errs)
    EIf(c, t_, eo) -> {
      let e1 = validate_inv_expr(c, file, bound, errs)
      let e2 = validate_inv_expr(t_, file, bound, e1)
      match eo { Some(b) -> validate_inv_expr(b, file, bound, e2) None -> e2 }
    }
    EMatch(scr, arms) -> {
      let e1 = validate_inv_expr(scr, file, bound, errs)
      validate_inv_arms(arms, file, bound, e1)
    }
    ELambda(ps, body) -> {
      let bound1 = inv_param_names(ps, bound)
      validate_inv_expr(body, file, bound1, errs)
    }
    ERecordLit(_, fis) -> validate_inv_fields(fis, file, bound, errs)
    EList(els) -> validate_inv_list_elems(els, file, bound, errs)
    ERange(a, b, sopt) -> {
      let e1 = validate_inv_expr(a, file, bound, errs)
      let e2 = validate_inv_expr(b, file, bound, e1)
      match sopt { Some(s) -> validate_inv_expr(s, file, bound, e2) None -> e2 }
    }
    EBlock(stmts, tail) -> {
      let r = validate_inv_block(stmts, file, bound, errs)
      match tail { Some(t) -> validate_inv_expr(t, file, r.bound, r.errs) None -> r.errs }
    }
    EPipe(a, b) -> {
      let e1 = validate_inv_expr(a, file, bound, errs)
      validate_inv_expr(b, file, bound, e1)
    }
    EMapPipe(a, b) -> {
      let e1 = validate_inv_expr(a, file, bound, errs)
      validate_inv_expr(b, file, bound, e1)
    }
    EFlatMapPipe(a, b) -> {
      let e1 = validate_inv_expr(a, file, bound, errs)
      validate_inv_expr(b, file, bound, e1)
    }
    EFilterPipe(a, b) -> {
      let e1 = validate_inv_expr(a, file, bound, errs)
      validate_inv_expr(b, file, bound, e1)
    }
    EHandle(body, _, _, init_opt, alias_opt, clauses, ret_opt) -> {
      let e0 = match init_opt { Some(ie) -> validate_inv_expr(ie, file, bound, errs) None -> errs }
      let bound_body = match alias_opt { Some(a) -> [a, ...bound] None -> bound }
      let e1 = validate_inv_expr(body, file, bound_body, e0)
      let e2 = validate_inv_clauses(clauses, file, bound, e1)
      match ret_opt {
        Some(r) -> match r {
          HR(p, b, _, _) -> validate_inv_expr(b, file, [p, ...bound], e2)
        }
        None -> e2
      }
    }
    EBang(inner) -> validate_inv_expr(inner, file, bound, errs)
    ELitUnit(inner, _) -> validate_inv_expr(inner, file, bound, errs)
    _ -> errs
  }
}

fn validate_inv_exprs(xs: [Expr], file: String, bound: [String], errs: Int) : Int / Console + File {


  match xs {
    [] -> errs
    [h, ...rest] -> validate_inv_exprs(rest, file, bound,
                                          validate_inv_expr(h, file, bound, errs))
  }
}

fn validate_inv_arms(arms: [Arm], file: String, bound: [String], errs: Int) : Int / Console + File {


  match arms {
    [] -> errs
    [a, ...rest] -> match a {
      Arm(p, g, b) -> {
        let bound1 = inv_pat_names(p, bound)
        let e1 = match g { Some(gx) -> validate_inv_expr(gx, file, bound1, errs) None -> errs }
        let e2 = validate_inv_expr(b, file, bound1, e1)
        validate_inv_arms(rest, file, bound, e2)
      }
    }
  }
}

fn validate_inv_fields(fs: [FieldInit], file: String, bound: [String], errs: Int) : Int / Console + File {


  match fs {
    [] -> errs
    [f, ...rest] -> match f {
      FI(_, v) -> validate_inv_fields(rest, file, bound,
                                          validate_inv_expr(v, file, bound, errs))
    }
  }
}

fn validate_inv_list_elems(els: [ListElem], file: String, bound: [String],
                              errs: Int) : Int / Console + File {


  match els {
    [] -> errs
    [el, ...rest] -> {
      let e1 = match el {
        ElPlain(x)  -> validate_inv_expr(x, file, bound, errs)
        ElSpread(x) -> validate_inv_expr(x, file, bound, errs)
      }
      validate_inv_list_elems(rest, file, bound, e1)
    }
  }
}

type InvBlockRes = { errs: Int, bound: [String] }

fn validate_inv_block(stmts: [Stmt], file: String, bound: [String],
                         errs: Int) : InvBlockRes / Console + File {


  match stmts {
    [] -> InvBlockRes { errs: errs, bound: bound }
    [s, ...rest] -> match s {
      SLet(p, _, rhs) -> {
        let e1 = validate_inv_expr(rhs, file, bound, errs)
        let bound1 = inv_pat_names(p, bound)
        validate_inv_block(rest, file, bound1, e1)
      }
      SVar(name, _, rhs, _, _) -> {
        let e1 = validate_inv_expr(rhs, file, bound, errs)
        validate_inv_block(rest, file, [name, ...bound], e1)
      }
      SAssert(c, m) -> {
        let e1 = validate_inv_expr(c, file, bound, errs)
        let e2 = match m { Some(mx) -> validate_inv_expr(mx, file, bound, e1) None -> e1 }
        validate_inv_block(rest, file, bound, e2)
      }
      SExprStmt(x) -> {
        let e1 = validate_inv_expr(x, file, bound, errs)
        validate_inv_block(rest, file, bound, e1)
      }
      SIndexAssign(b, i, v, _, _) -> {
        let e1 = validate_inv_expr(b, file, bound, errs)
        let e2 = validate_inv_expr(i, file, bound, e1)
        let e3 = validate_inv_expr(v, file, bound, e2)
        validate_inv_block(rest, file, bound, e3)
      }
      # m7e §25: SUse has no expression and binds nothing.
      SUse(_, _, _) -> validate_inv_block(rest, file, bound, errs)
    }
  }
}

fn validate_inv_clauses(cs: [HClause], file: String, bound: [String],
                          errs: Int) : Int / Console + File {


  match cs {
    [] -> errs
    [c, ...rest] -> match c {
      HC(_, ps, b, _, _) -> {
        let bound1 = inv_param_names(ps, bound)
        let e1 = validate_inv_expr(b, file, bound1, errs)
        validate_inv_clauses(rest, file, bound, e1)
      }
    }
  }
}

# Issue #341 Form 1: recover the concrete dispatch head from a
# return-typed op against the inferred return `Ty`. Three cases by how
# many times `Self` occurs in the declared return:
#
#   0 — the op's declared return is a concrete type (`op() : Int` for a
#       `protocol P { op() : Int }` whose impl target is keyed by that
#       head). The dispatch head is the inferred return's head directly,
#       preserving the pre-#341 `ty_head_name(ret_ty)` behaviour.
#   1 — `Self` appears once, possibly NESTED: `default() : Self` reads
#       the inferred head; `from_string(s) : Result[Self, String]` aligns
#       `Result[Self, String]` against `Result[Int, String]` and reads
#       the head at Self's position (`Int`).
#   >1 — a multi-Self return (`(Self, Self)`) has no single dispatch
#       head, so we decline and leave the runtime dispatcher in place.
#
# Returns None when the shapes do not align (the inferred return is
# still a tyvar, or a structural mismatch the unifier would have
# already rejected).
fn self_head_in_ret(declared: TypeExpr, inferred: Ty) : Option[String] {
  let n = te_self_count(declared)
  if n == 0 { ty_head_name(inferred) }
  else if n == 1 { align_self_head(declared, inferred) }
  else { None }
}

# Count the `Self` mentions in a declared return TypeExpr. Used to gate
# `self_head_in_ret` to the single-Self case.
fn te_self_count(te: TypeExpr) : Int = te_kind_self_count(te.tkind)

fn te_kind_self_count(k: TyKind) : Int {
  match k {
    TyName(name, targs) ->
      (if name == "Self" { 1 } else { 0 }) + te_list_self_count(targs)
    TyList(inner) -> te_self_count(inner)
    TyFn(ps, r, _) -> te_list_self_count(ps) + te_self_count(r)
    TyDim(base, _) -> te_self_count(base)
    TyRefine(base, _) -> te_self_count(base)
    # issue #772: a compound row carries effect labels, never `Self`.
    TyRow(_) -> 0
  }
}

fn te_list_self_count(tes: [TypeExpr]) : Int = match tes {
  [] -> 0
  [t, ...rest] -> te_self_count(t) + te_list_self_count(rest)
}

# Parallel walk of a declared TypeExpr (carrying `Self`) against the
# inferred concrete Ty, returning `ty_head_name` of the inferred type
# at the position the declared shape names `Self`. The two shapes are
# the same constructor at every step (the typer already unified them),
# so the walk pairs children positionally and recurses until it lands
# on the `Self` leaf.
fn align_self_head(declared: TypeExpr, inferred: Ty) : Option[String] {
  match declared.tkind {
    TyName(name, targs) ->
      if name == "Self" { ty_head_name(inferred) }
      else { align_self_in_args(targs, ty_con_args(inferred)) }
    TyList(inner) -> {
      match inferred {
        TyListT(elem) -> align_self_head(inner, elem)
        _             -> None
      }
    }
    TyDim(base, _)    -> align_self_head(base, ty_strip_dim(inferred))
    TyRefine(base, _) -> align_self_head(base, ty_strip_refine(inferred))
    TyFn(_, _, _)     -> None
    # issue #772: a compound row is never a `Self`-bearing position.
    TyRow(_)          -> None
  }
}

# Walk paired declared/inferred argument lists; the one carrying `Self`
# (guaranteed unique by the `te_self_count == 1` gate) yields the head.
fn align_self_in_args(decls: [TypeExpr], infs: [Ty]) : Option[String] {
  match decls {
    [] -> None
    [d, ...drest] -> {
      match infs {
        []           -> None
        [i, ...irest] ->
          if te_self_count(d) == 1 { align_self_head(d, i) }
          else { align_self_in_args(drest, irest) }
      }
    }
  }
}

# The type arguments of a constructor-headed inferred Ty, in the same
# positional order the declared `TyName(_, targs)` enumerates them.
# Non-constructor types (a still-unresolved tyvar) yield `[]`, so the
# paired walk runs dry and the caller declines.
# `tas` (not `args`): a binding named `args` resolves to the core
# `args()` CLI-arguments builtin, not the bound pattern variable
# (the param-shadow trap), silently returning a closure here.
fn ty_con_args(t: Ty) : [Ty] {
  match t {
    TyCon(_, _, tas)   -> tas
    TyListT(elem)      -> [elem]
    TyDimT(base, _)    -> ty_con_args(base)
    TyRefineT(base, _) -> ty_con_args(base)
    _                  -> []
  }
}

fn ty_strip_dim(t: Ty) : Ty = match t {
  TyDimT(base, _) -> base
  _               -> t
}

fn ty_strip_refine(t: Ty) : Ty = match t {
  TyRefineT(base, _) -> base
  _                  -> t
}

# Issue #180: variant accepting the call's surrounding return type so
# `from(x) : Self`-style ops can resolve Self via the expected type
# rather than the (absent) Self argument. Falls back to the legacy
# arg-driven dispatch when ret_ty is None or Self is informed by args.
#
# Issue #341 Form 1: Self may sit NESTED in the return type
# (`from_string(s) : Result[Self, String]`), so the candidate-specific
# Self head is recovered per op via `self_head_in_ret` rather than from
# the outermost `ty_head_name(ret_ty)` (which would read `Result`).
fn try_rewrite_proto_call_with_ret(callee: Expr, args_: [Expr],
                                     reg: ProtocolReg,
                                     local_arities: [OpAr],
                                     ret_ty: Option[Ty]) : Option[ExprKind] {
  match try_rewrite_proto_call(callee, args_, reg, local_arities) {
    Some(rk) -> Some(rk)
    None -> {
      # Last-ditch: recover Self from the return type's Self position.
      match ret_ty {
        None -> None
        Some(ty) -> match callee.kind {
          EVar(name) -> {
            let opname = strip_proto_dispatcher_prefix(name)
            if not list_has(reg.op_names, opname) { None }
            # Hanga Roa shadow guard: a bare call to a name that
            # also names a top-level fn of matching arity must
            # resolve to that fn, not to the protocol impl.
            # Prefixed callees (`__proto_<op>`) bypass this check
            # — they were synthesised specifically to land on the
            # impl-table dispatch.
            else if proto_call_is_shadowed(name, list_length(args_), local_arities) {
              None
            }
            else {
              # Issue #546: a return-typed op (`from(x) : Self`) may
              # also be declared by more than one protocol. Try each
              # candidate against its own return-derived Self type.
              # Decline while any argument's type is still unresolved
              # (no head) — dispatching then would be premature.
              match args_head_names(args_) {
                None -> None
                Some(_) ->
                  try_rewrite_ret_candidates(proto_ops_lookup_all(reg, opname),
                                             callee, args_, reg, opname, ty)
              }
            }
          }
          _ -> None
        }
      }
    }
  }
}

# Issue #546: the return-typed-Self counterpart of
# `try_rewrite_proto_candidates`. Walks every protocol declaring
# `opname` and returns the first whose impl table matches the
# return-derived Self + the other args. Each candidate recovers its own
# Self head from its declared return type aligned against `ret_ty`
# (issue #341 Form 1), so a nested-Self return (`Result[Self, String]`)
# dispatches correctly. `None` when no candidate matches, preserving
# the prior behaviour.
fn try_rewrite_ret_candidates(cands: [ProtoOpReg], callee: Expr,
                               args_: [Expr], reg: ProtocolReg,
                               opname: String, ret_ty: Ty) : Option[ExprKind] {
  match cands {
    [] -> None
    [po, ...rest] -> match po {
      POR(pname, _, params, ret_te, _, _) ->
        # Arity guard: skip a candidate whose arity differs from the
        # call (an arity-ambiguous name reaches both protocols' POR).
        if list_length(params) != list_length(args_) {
          try_rewrite_ret_candidates(rest, callee, args_, reg, opname, ret_ty)
        }
        # Only ops whose Self is informed SOLELY by the return position
        # are dispatched here. When Self also appears in a parameter
        # (`show(x: Self) : String`), arg-driven dispatch in
        # `try_rewrite_proto_call` owns it; second-guessing via the
        # return head would misroute a no-impl receiver (e.g. `Bare`
        # with no `impl Show`) onto an unrelated impl whose head happens
        # to equal the concrete return head (`String`).
        else if not proto_op_self_only_in_return(params, ret_te,
                       proto_shape_carriers(reg.tparams, pname)) {
          try_rewrite_ret_candidates(rest, callee, args_, reg, opname, ret_ty)
        } else {
          match self_head_in_ret(ret_te, ret_ty) {
            None -> try_rewrite_ret_candidates(rest, callee, args_, reg,
                                               opname, ret_ty)
            Some(self_name) ->
              match find_impl_by_recv(impl_pool(reg, pname, self_name), pname, opname, self_name) {
                Some(impl_fn) -> {
                  let new_callee = mk_expr(EVar(impl_fn), callee.line, callee.col)
                  Some(ECall(new_callee, args_))
                }
                None -> try_rewrite_ret_candidates(rest, callee, args_, reg,
                                                   opname, ret_ty)
              }
          }
        }
    }
  }
}

fn try_rewrite_proto_call(callee: Expr, args_: [Expr],
                            reg: ProtocolReg,
                            local_arities: [OpAr]) : Option[ExprKind] {
  match callee.kind {
    EVar(name) -> {
      let opname = strip_proto_dispatcher_prefix(name)
      if not list_has(reg.op_names, opname) { None }
      # Hanga Roa shadow guard: see `proto_call_is_shadowed`.
      # Prefixed dispatchers (`__proto_<op>`) bypass the guard.
      else if proto_call_is_shadowed(name, list_length(args_), local_arities) {
        None
      }
      else {
        # Issue #180: with heterogeneous P[A] dispatch, the receiver
        # is no longer always args[0]. We need to consider every
        # argument as a candidate Self and find the impl whose
        # arg-name list matches the OTHER arguments.
        #
        # Issue #546: when two protocols declare an op with the same
        # name, the bare-name call site carries no protocol — only the
        # receiver type disambiguates. Iterate every protocol declaring
        # this op and pick the first that has an impl for the receiver.
        try_rewrite_proto_candidates(proto_ops_lookup_all(reg, opname),
                                     callee, args_, reg, opname)
      }
    }
    _ -> None
  }
}

# Issue #546: try each protocol declaring `opname` in registry order,
# returning the first whose impl table has an entry for the receiver
# type. Candidates whose Self appears only in the return position carry
# no arg-borne Self information, so they are skipped here and left to
# the `_with_ret` wrapper. Returning `None` when no candidate matches
# preserves the prior single-protocol behaviour (residual dispatcher
# kept for the polymorphic / no-impl paths).
fn try_rewrite_proto_candidates(cands: [ProtoOpReg], callee: Expr,
                                 args_: [Expr], reg: ProtocolReg,
                                 opname: String) : Option[ExprKind] {
  match cands {
    [] -> None
    [po, ...rest] -> match po {
      POR(pname, _, params, ret, _, _) -> {
        # Arity guard: a name declared by two protocols at different
        # arities (`P { f(x) }` + `Q { f(a, b) }`) yields one POR per
        # protocol here. Only the candidate whose arity matches the
        # call can be the target — skipping the rest is what stops a
        # 1-arg call landing on the 2-arg impl.
        if list_length(params) != list_length(args_) {
          try_rewrite_proto_candidates(rest, callee, args_, reg, opname)
        }
        # When Self (or the protocol's `Shape` carrier) appears only in
        # the op's return position (e.g. `from(x: a) : Self`), the args
        # carry no dispatch information — defer to the caller-provided
        # ret_ty (the `_with_ret` wrapper).
        else if proto_op_self_only_in_return(params, ret,
                  proto_shape_carriers(reg.tparams, pname)) {
          try_rewrite_proto_candidates(rest, callee, args_, reg, opname)
        } else {
          match find_proto_impl_for_args(reg, pname, opname, args_) {
            Some(impl_fn) -> {
              let new_callee = mk_expr(EVar(impl_fn), callee.line, callee.col)
              Some(ECall(new_callee, args_))
            }
            None -> try_rewrite_proto_candidates(rest, callee, args_, reg, opname)
          }
        }
      }
    }
  }
}

# Issue #180: returns true when none of the op's parameter types
# contains `Self` (nor the protocol's `Shape` carrier), i.e. dispatch
# is informed only by the return type. Such ops can only be dispatched
# via the surrounding expected type (typed-hole error otherwise).
fn proto_op_self_only_in_return(params: [Param], ret: TypeExpr,
                                carriers: [String]) : Bool {
  not list_any(params, (p) => match p.ptype {
    Some(te) -> te_mentions_self_or_carrier(te, carriers)
    None -> false
  })
}

# The surface names of a protocol's `Shape`-kind tparams — the dispatch
# carriers whose applied form `s[A]` a call resolves against, mirroring
# how `Self` informs an ordinary protocol's dispatch.
fn proto_shape_carriers(tps: [ProtoTPReg], pname: String) : [String] =
  shape_carrier_names(proto_tparams_for(tps, pname), [])

# True when a protocol quantifies over a `Shape` carrier — dispatch is
# single on the container, so a two-arg op is not heterogeneous.
fn proto_is_shape_carrier(tps: [ProtoTPReg], pname: String) : Bool =
  match proto_shape_carriers(tps, pname) { [] -> false _ -> true }

fn shape_carrier_names(names: [String], acc: [String]) : [String] = match names {
  [] -> list_reverse(acc)
  [n, ...rest] ->
    if tp_kind_is_shape(n) { shape_carrier_names(rest, [tp_strip_kind(n), ...acc]) }
    else { shape_carrier_names(rest, acc) }
}

fn list_any(xs: [Param], f: (Param) -> Bool) : Bool = match xs {
  [] -> false
  [x, ...rest] -> if f(x) { true } else { list_any(rest, f) }
}

fn te_mentions_self(te: TypeExpr) : Bool = te_kind_mentions_self(te.tkind)

fn te_kind_mentions_self(k: TyKind) : Bool {
  match k {
    TyName(name, targs) ->
      if name == "Self" { true }
      else { te_list_mentions_self(targs) }
    TyList(inner) -> te_mentions_self(inner)
    TyFn(ps, r, _) -> te_list_mentions_self(ps) or te_mentions_self(r)
    TyDim(base, _) -> te_mentions_self(base)
    TyRefine(base, _) -> te_mentions_self(base)
    # issue #772: a compound row carries effect labels, never `Self`.
    TyRow(_) -> false
  }
}

# As `te_mentions_self` but also treats a `Shape`-carrier head as a
# dispatch informant: `xs: s[A]` with `s` the protocol carrier makes the
# op arg-dispatched, exactly as `xs: Self` would.
fn te_mentions_self_or_carrier(te: TypeExpr, carriers: [String]) : Bool =
  te_kind_mentions_self_or_carrier(te.tkind, carriers)

fn te_kind_mentions_self_or_carrier(k: TyKind, carriers: [String]) : Bool {
  match k {
    TyName(name, targs) ->
      if name == "Self" or list_has(carriers, name) { true }
      else { te_list_mentions_self_or_carrier(targs, carriers) }
    TyList(inner) -> te_mentions_self_or_carrier(inner, carriers)
    TyFn(ps, r, _) -> te_list_mentions_self_or_carrier(ps, carriers) or
                      te_mentions_self_or_carrier(r, carriers)
    TyDim(base, _) -> te_mentions_self_or_carrier(base, carriers)
    TyRefine(base, _) -> te_mentions_self_or_carrier(base, carriers)
    TyRow(_) -> false
  }
}

fn te_list_mentions_self_or_carrier(tes: [TypeExpr], carriers: [String]) : Bool = match tes {
  [] -> false
  [t, ...rest] -> if te_mentions_self_or_carrier(t, carriers) { true }
                  else { te_list_mentions_self_or_carrier(rest, carriers) }
}

fn te_list_mentions_self(tes: [TypeExpr]) : Bool = match tes {
  [] -> false
  [t, ...rest] -> if te_mentions_self(t) { true } else { te_list_mentions_self(rest) }
}

# Issue #180: walk the impl table looking for the impl whose
# (receiver, [arg names]) matches the typed argument expressions.
# Pass 1 honours the proto-arg list on the impl entry — this catches
# both the homogeneous default (arg_names=[] treated as [recv]) AND
# heterogeneous matches (`impl Add[Real] for Complex`). Pass 2 (only
# for 2-arg binops) flips the receiver and tries the mirror impl.
# Beyond two args (single-dispatch ops with multiple non-receiver
# parameters like `pow_int(self, exp)`), only Pass 1 with
# `arg_names_match` against [recv] applies — `find_impl_legacy`
# does that. The legacy `find_impl_for` (no arg-name filter) is
# kept around for unrelated callers.
# The impl candidates a `(proto, recv)` lookup must consider: the
# `(proto, recv)` bucket when the index is built, else the whole table.
# Every `find_impl_*` filter keys on `t == recv`, so the bucket holds
# exactly the entries the linear scan would not skip, in the same order.
fn impl_pool(reg: ProtocolReg, pname: String, recv: String) : [ProtoImplReg] =
  if ii_built(reg.impl_index) { ii_key_bucket(reg.impl_index, pname, recv) }
  else { reg.impls }

fn find_proto_impl_for_args(reg: ProtocolReg, pname: String, opname: String,
                             args_: [Expr]) : Option[String] {
  # A `Shape`-carrier protocol dispatches single, on the container arg;
  # its ops carry ordinary function parameters (`map(xs, f)`) whose types
  # have no dispatch head. Read the head from the first container-typed
  # argument and ignore the rest, so a function arg does not veto the
  # lookup the way `args_head_names` (all-or-nothing) would.
  if proto_is_shape_carrier(reg.tparams, pname) {
    match first_container_head(args_) {
      None -> None
      Some(a) -> find_impl_homogeneous(impl_pool(reg, pname, a), pname, opname, a)
    }
  } else {
  let names = args_head_names(args_)
  match names {
    None -> None
    Some(ns) -> match ns {
      [] -> None
      [a] -> find_impl_homogeneous(impl_pool(reg, pname, a), pname, opname, a)
      [a, b] -> {
        # A `Shape` carrier is the single dispatch container, NOT a
        # heterogeneous proto-arg — its ops (`map(xs, f)`) take an
        # ordinary function as the second parameter, so dispatch stays
        # single on the container `a`.
        let proto_takes_args = proto_has_tparams(reg.tparams, pname) and
                               not proto_is_shape_carrier(reg.tparams, pname)
        if not proto_takes_args {
          # Single-dispatch op whose second parameter is part of the
          # op shape (`Numeric.pow_int(Self, Int)` etc.). Only the
          # homogeneous (recv=a) lookup applies; the second arg is
          # not a proto-arg.
          find_impl_homogeneous(impl_pool(reg, pname, a), pname, opname, a)
        } else {
          # Pass 1a: heterogeneous (recv=a, proto_args=[b]) — covers
          #          `impl Add[Real] for Complex` for Complex + Real.
          # Pass 1b: homogeneous (recv=a) — covers `impl Add for
          #          Complex` for Complex + Complex.
          match find_impl_with_args(impl_pool(reg, pname, a), pname, opname, a, [b]) {
            Some(fn_name) -> Some(fn_name)
            None -> {
              match find_impl_homogeneous(impl_pool(reg, pname, a), pname, opname, a) {
                Some(fn_name) ->
                  if a == b { Some(fn_name) }
                  else { find_impl_with_args(impl_pool(reg, pname, b), pname, opname, b, [a]) }
                None -> find_impl_with_args(impl_pool(reg, pname, b), pname, opname, b, [a])
              }
            }
          }
        }
      }
      [a, ..._rest] -> find_impl_homogeneous(impl_pool(reg, pname, a), pname, opname, a)
    }
  }
  }
}

# The head name of the first argument that carries a concrete type
# constructor (a container), skipping function-typed and unresolved
# args. This is the dispatch receiver for a `Shape`-carrier op.
fn first_container_head(args_: [Expr]) : Option[String] = match args_ {
  [] -> None
  [e, ...rest] -> match e.ty {
    Some(ty) -> match ty_head_name(ty) {
      Some(n) -> Some(n)
      None    -> first_container_head(rest)
    }
    None -> first_container_head(rest)
  }
}

# Find the impl entry whose `arg_names` is empty (legacy default) or
# is exactly `[recv]` (homogeneous parametrised form). Heterogeneous
# entries are skipped.
fn find_impl_homogeneous(impls: [ProtoImplReg], pname: String,
                          opname: String, recv: String) : Option[String] {
  match impls {
    [] -> None
    [it, ...rest] -> match it {
      PIR(p, t, o, fn_name, ans, _) ->
        if p == pname and t == recv and o == opname and is_homogeneous_args(ans, recv) {
          Some(fn_name)
        } else {
          find_impl_homogeneous(rest, pname, opname, recv)
        }
    }
  }
}

fn is_homogeneous_args(reg_args: [String], recv: String) : Bool = match reg_args {
  [] -> true
  [a] -> a == recv
  _ -> false
}

# Issue #180: returns true when the protocol declared one or more
# `[A]` type parameters. `protocol Add[a]` returns true; `protocol
# Numeric` returns false.
fn proto_has_tparams(tps: [ProtoTPReg], pname: String) : Bool = match tps {
  [] -> false
  [t, ...rest] -> match t {
    PTPR(p, params) ->
      if p == pname {
        match params { [] -> false _ -> true }
      } else {
        proto_has_tparams(rest, pname)
      }
  }
}

fn args_head_names(args_: [Expr]) : Option[[String]] = match args_ {
  [] -> Some([])
  [e, ...rest] -> match e.ty {
    None -> None
    Some(ty) -> match ty_head_name(ty) {
      None -> None
      Some(n) -> match args_head_names(rest) {
        None -> None
        Some(ns) -> Some([n, ...ns])
      }
    }
  }
}

fn find_impl_with_args(impls: [ProtoImplReg], pname: String, opname: String,
                        recv: String, args: [String]) : Option[String] {
  match impls {
    [] -> None
    [it, ...rest] -> match it {
      PIR(p, t, o, fn_name, ans, _) ->
        if p == pname and t == recv and o == opname and arg_names_match(ans, recv, args) {
          Some(fn_name)
        } else {
          find_impl_with_args(rest, pname, opname, recv, args)
        }
    }
  }
}

# Issue #341 Form 1: receiver-only impl lookup for a return-typed op
# whose Self lives in the return position (`from_string(s) : Result[
# Self, String]`). `find_impl_with_args` cannot serve here — its
# `arg_names_match` treats the lone non-Self argument as the receiver
# (so `["String"]` would have to equal recv `"Int"`, which never
# holds). The op's params are genuine non-Self arguments already
# unified by the typer; single-dispatch v1 keys each impl uniquely on
# `(protocol, op, Self-type)`, so matching on those three is sound.
fn find_impl_by_recv(impls: [ProtoImplReg], pname: String, opname: String,
                      recv: String) : Option[String] {
  match impls {
    [] -> None
    [it, ...rest] -> match it {
      PIR(p, t, o, fn_name, _, _) ->
        if p == pname and t == recv and o == opname { Some(fn_name) }
        else { find_impl_by_recv(rest, pname, opname, recv) }
    }
  }
}

# Strip the `__proto_` dispatcher prefix the rename pass attaches.
# Names without the prefix pass through unchanged (so tests that
# bypass renaming still resolve).
fn strip_proto_dispatcher_prefix(name: String) : String {
  let pfx = "__proto_"
  let n_pfx = string_length(pfx)
  if string_length(name) <= n_pfx { name }
  else if string_slice(name, 0, n_pfx) == pfx {
    strip_arity_suffix(string_slice(name, n_pfx, string_length(name) - n_pfx))
  }
  else { name }
}

# Drop the `__a<N>` arity suffix an arity-ambiguous dispatcher carries
# (`f__a1` -> `f`). Scans the trailing digit run, then checks the `__a`
# marker right before it. Names without the shape pass through, so an
# op literally named `x__a` (no digits) is untouched.
fn strip_arity_suffix(name: String) : String {
  let n = string_length(name)
  let digit_start = scan_trailing_digits(name, n)
  let marker = "__a"
  let m = string_length(marker)
  if digit_start < n and digit_start >= m and
     string_slice(name, digit_start - m, m) == marker {
    string_slice(name, 0, digit_start - m)
  } else { name }
}

# Index of the first char of the trailing digit run (== `n` when the
# last char is not a digit). Walks backward from `n`.
fn scan_trailing_digits(s: String, n: Int) : Int {
  if n <= 0 { 0 }
  else {
    match char_at(s, n - 1) {
      Some(c) -> if c >= '0' and c <= '9' { scan_trailing_digits(s, n - 1) }
                 else { n }
      None -> n
    }
  }
}

# Map an inferred Ty back to its canonical "head-constructor" name —
# the same mangling proto_type_name applies on the impl side. Lists,
# Option, Result, and primitive builtins get their canonical names;
# user-defined records / sums use TyCon's name.
#[doc("Root head name of a Ty for impl-table lookup (Int, List, the TyCon name, ...); None for tyvars/unions and other non-nominal heads.")]
pub fn ty_head_name(t: Ty) : Option[String] {
  match t {
    TyInt          -> Some("Int")
    TyReal         -> Some("Real")
    TyBool         -> Some("Bool")
    TyChar         -> Some("Char")
    TyString       -> Some("String")
    TyUnit         -> Some("Unit")
    TyByte           -> Some("Byte")
    TyInt32          -> Some("Int32")
    TyUInt32         -> Some("UInt32")
    TyUInt64         -> Some("UInt64")
    TyInt128         -> Some("Int128")
    TyHandle         -> Some("Handle")
    TyListT(_)     -> Some("List")
    TyCon(_, name, _) -> Some(name)
    # m12.5: a dimensioned value dispatches on the underlying base
    # type's head — `Decimal<USD>` → `Decimal`, mirroring the
    # `proto_type_name` collapse on the syntactic side.
    TyDimT(base, _) -> ty_head_name(base)
    # m12.6.x #1: refinements are transparent for protocol dispatch
    # — `Int where >= 0` and `Int` resolve to the same `impl`.
    TyRefineT(base, _) -> ty_head_name(base)
    TyVarT(_)      -> None
    # an unresolved shape app has no concrete head; dispatch is post-mono
    # once the shape var binds to a constructor, exactly like `TyVarT`.
    TyShapeApp(_, _) -> None
    TyFnT(_, _, _) -> None
    TyAny          -> None
    # issue #187 phase 1: a union has no single head type, so
    # protocol dispatch declines — Phase 2's resolver is what
    # forbids `impl P for Union` declarations; here we just signal
    # "no canonical head" the same way TyVarT does so callers fall
    # back to the diagnostic path.
    TyUnion(_)     -> None
  }
}

# Walks the registry's impl table for a (protocol-op, type-name)
# match. The op-name search visits each impl entry's protocol's
# ops to find which protocol the op belongs to; for the v1 we look
# the op up first to know `pname`, then iterate impls for a matching
# (pname, tname).
fn find_impl(reg: ProtocolReg, opname: String, tname: String) : Option[String] {
  match proto_op_lookup(reg, opname) {
    None -> None
    Some(po) -> match po {
      POR(pname, _, _, _, _, _) -> find_impl_for(impl_pool(reg, pname, tname), pname, tname, opname)
    }
  }
}

# Collision-aware: `opname` may be declared by several protocols
# (`add` by `Add[a]` and a user `Ring`). Returns an impl when ANY
# declaring protocol has one for `tname`, so the post-rewrite
# validator does not fix the protocol to the wrong one and flag a
# spurious "no impl". Returns the owning protocol name alongside.
fn find_impl_any_proto(reg: ProtocolReg, opname: String,
                        tname: String) : Option[ImplHit] =
  find_impl_any_proto_loop(proto_ops_lookup_all(reg, opname), reg, opname, tname)

#[doc("A resolved impl hit: the owning protocol and the impl fn symbol.")]
pub type ImplHit = ImplHit(String, String)

fn find_impl_any_proto_loop(cands: [ProtoOpReg], reg: ProtocolReg,
                             opname: String, tname: String) : Option[ImplHit] {
  match cands {
    [] -> None
    [po, ...rest] -> match po {
      POR(pname, _, _, _, _, _) ->
        match find_impl_for(impl_pool(reg, pname, tname), pname, tname, opname) {
          Some(fn_name) -> Some(ImplHit(pname, fn_name))
          None -> find_impl_any_proto_loop(rest, reg, opname, tname)
        }
    }
  }
}

# First protocol name declaring `opname` (for diagnostics only).
fn first_proto_of_op(reg: ProtocolReg, opname: String) : String {
  match proto_ops_lookup_all(reg, opname) {
    [] -> "?"
    [po, ..._rest] -> match po { POR(pn, _, _, _, _, _) -> pn }
  }
}

fn find_impl_for(impls: [ProtoImplReg], pname: String, tname: String,
                  opname: String) : Option[String] {
  match impls {
    [] -> None
    [it, ...rest] -> match it {
      PIR(p, t, op, fn_name, _, _) ->
        if p == pname and t == tname and op == opname { Some(fn_name) }
        else { find_impl_for(rest, pname, tname, opname) }
    }
  }
}
