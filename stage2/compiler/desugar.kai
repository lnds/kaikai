# compiler/desugar.kai — kaikai pre-typer AST->AST desugar passes:
# positional-record sugar, the `var` rewriter + const/refinement/
# contract lowering, `use Effect` desugar, the cap-binding nursery
# rewrite, and the brand-mismatch validator.
#
# Extracted from main.kai under issue #677 Phase 1m — the fifth
# "vertical pipeline" extraction, after the 11 leaf modules and the
# module system (Phase 1l, PR #690). The cross-section analysis is in
# docs/lane-desugar-cross-section-analysis.md and the retro in
# docs/lane-experience-issue-677-phase1m.md.
#
# The cut, in one sentence
#
# Every pass here is a pure AST->AST (or AST->error-count) transform
# the driver (`compile_source` in main.kai) invokes DOWNWARD, in this
# order: positional records -> `var` rewrite -> `use Effect` ->
# const refs -> nursery cap rewrite -> brand-mismatch check, with the
# refinement/contract lowering threaded alongside. main.kai keeps a
# downward-only import: it calls into this module, this module never
# calls back.
#
# What this module owns (six sub-sections, A-E of the brief; F left in
# main, see below)
#
# - A. Positional-record sugar (issue #266): `Foo(a, b)` calls whose
#   head names a record type are rewritten to `Foo { f1: a, f2: b }`
#   record literals against the record table (`[RecInfo]`). Entry:
#   `desugar_pos_records_decls`. The `dpr_*` walkers recurse the AST.
# - B. The `var` rewriter (m7b #5b) + the lowering helpers that ride
#   alongside it: `desugar_var_decls` (var -> Ref-cell), the const
#   thunk lowering (`lower_consts` / `lower_const_one`), axiom
#   lowering (`lower_axioms` / `lower_axiom_one`), const-ref forcing
#   (`desugar_const_refs_decls`), refinement pred-fn synthesis
#   (`synthesize_refine_pred_fns`), pattern-narrow lowering
#   (`lower_pattern_narrow_decls`), and contract-predicate validation
#   (`validate_contract_predicates_decls`).
# - C. `use Effect` desugar (m7e §25): strip file-level `use` decls
#   and rewrite bare op references in their scope to qualified
#   `Eff.op` calls. Entry: `desugar_use_decls`.
# - D. Cap-binding nursery rewrite (m7b #4, issue #71(b) prereq):
#   `nursery { n -> body }` strips the cap param and rewrites
#   `n.<op>` to `Spawn.<op>`, minting a fresh BrandId per scope.
#   Entry: `rewrite_nursery_caps_decls`; produces the brand registry.
# - E. Brand-mismatch check (issue #71(b)): walks fn bodies with a
#   brand-attribution environment and rejects sibling-nursery cap
#   confusion at consume sites. Entry:
#   `check_nursery_brand_mismatch_decls`. Consumes the registry D
#   produces, so the driver must run D before E.
#
# Sub-section F (m12.8.x phase 2 string-interpolation lift) STAYS in
# main.kai. It depends on the emit-aware interp scanner
# (`iscan_collect` -> `raw_lit_for_c` -> `escape_str_body_for_c`,
# the C-literal escaper), so the `IpLit` parts it consumes carry a
# precomputed escaped-for-C field that only the emit layer produces.
# Lifting F would drag the emit layer into desugar; it extracts
# cleanly only once a shared scanner/string-lift layer exists. The
# scanner is also used by emit (`emit_interp_parts`), reinforcing that
# it is a transverse service, not a desugar sub-pass.
#
# Shared types promoted to compiler.ast: `RecInfo` (the record table
# entry, ctor `RI`) plus its pure lookups (`rec_find` /
# `rec_find_with_field` / `collect_records`) moved to ast.kai under
# the shared-AST-adjacent-types rule. The positional-record sugar
# consumes `[RecInfo]` in 16 signatures NOW; the typer consumes it 49x
# (the record table threaded through inference) and the future infer
# lane will too. ast.kai is the only home both can import without a
# lateral arrow.
#
# Local mirrors (downward-glue rule): the passes call AST-generic
# helpers and trivial string/tag helpers that live in main.kai and are
# used ubiquitously there (the `map_*` AST functor family, 25 callers;
# `pat_bindings`, 19; the `rename_*` binder walkers; `string_starts_
# with_q`, 7; the `ffi_extern_tag` / `ffi_extern_tag_prefix` string
# constants the FFI-shim emitter also reads). Rather than `pub`-export
# them upward (inverting the arrow), they are mirrored locally with a
# `dsg_` prefix so the flat bundle does not mint duplicate C symbols
# against main's copies. The `ffi_extern_tag` mirror is a string
# literal constant ("__kai_ffi__") — the contract between the axiom
# lowering (producer, here) and the FFI-shim emitter (consumer, main);
# the mirror cannot diverge because both spell the same literal.
#
# Public surface (18): the pass entry points the driver invokes
# (`desugar_pos_records_decls`, `desugar_var_decls`,
# `validate_var_uses_decls`, `desugar_use_decls`,
# `desugar_const_refs_decls`, `collect_const_names_decls`,
# `synthesize_refine_pred_fns`, `collect_refine_alias_names`,
# `lower_pattern_narrow_decls`, `extract_pure_names_decls`,
# `validate_contract_predicates_decls`, `rewrite_nursery_caps_decls`,
# `check_nursery_brand_mismatch_decls`, `dump_brands`, `lower_axioms`,
# `lower_consts`) plus `lower_axiom_one` / `lower_const_one` which the
# module-origin tagging in main (`tag_decl_module_origin`) invokes.

import compiler.util
import compiler.diag
import compiler.ast
import compiler.modules
import compiler.refinements

# ====================================================================
# Local mirrors of main.kai helpers (downward-glue rule)
# ====================================================================
#
# These mirror main.kai helpers the passes below call downward. The
# `dsg_` prefix keeps the flat bundle from minting duplicate C symbols
# against main's own copies. They depend only on already-imported
# symbols (the AST types from compiler.ast, `string_length` /
# `char_at` from the prelude), so the mirrors are exact and carry no
# further coupling. main.kai keeps its own copies for its own use.

fn dsg_map_expr_kind(k: ExprKind, f: (Expr) -> Expr) : ExprKind {
  match k {
    # Leaves: no sub-Expr to recurse into.
    EInt(_)        -> k
    EReal(_)       -> k
    EBool(_)       -> k
    EChar(_)       -> k
    EStr(_, _)     -> k
    EUnit          -> k
    EVar(_)        -> k
    EUnder         -> k
    EPlaceholder   -> k
    EHole(_)       -> k
    ETodo(_)       -> k
    # `EVariantsOf(TypeExpr, [String])` carries no sub-Expr (only a
    # TypeExpr and a resolved-names list, neither of which the
    # visitor traverses). Same shape as EHole/ETodo for the
    # purposes of the structural recursion.
    EVariantsOf(_, _) -> k
    # m6.2 Phase 2.1: qualified module call carries no sub-Exprs
    # (both fields are plain Strings), so `f` has nothing to apply.
    EModCall(_, _) -> k
    # Issue #556: intrinsic args ARE sub-Exprs, so the visitor recurs.
    EIntrinsic(name, args_) -> EIntrinsic(name, map(args_, f))
    # Composites: apply f to every direct sub-Expr.
    ECall(callee, args_) -> ECall(f(callee), map(args_, f))
    EField(base, name)   -> EField(f(base), name)
    EIndex(a, b)         -> EIndex(f(a), f(b))
    EBinop(op, a, b)     -> EBinop(op, f(a), f(b))
    EUnop(op, x)         -> EUnop(op, f(x))
    EIf(c, t_, eo)       -> EIf(f(c), f(t_), dsg_map_opt_expr(eo, f))
    EMatch(scr, arms)    -> EMatch(f(scr), map(arms, (a) => dsg_map_arm_exprs(a, f)))
    ELambda(ps, b)       -> ELambda(ps, f(b))
    ERecordLit(name, fs) -> ERecordLit(name, map(fs, (fi) => dsg_map_field_exprs(fi, f)))
    EList(els)           -> EList(map(els, (el) => dsg_map_elem_exprs(el, f)))
    ERange(a, b, opt_step) -> ERange(f(a), f(b), dsg_map_opt_expr(opt_step, f))
    EBlock(stmts, tail)  -> EBlock(map(stmts, (s) => dsg_map_stmt_exprs(s, f)),
                                    dsg_map_opt_expr(tail, f))
    EPipe(a, b)          -> EPipe(f(a), f(b))
    EMapPipe(a, b)       -> EMapPipe(f(a), f(b))
    EFlatMapPipe(a, b)   -> EFlatMapPipe(f(a), f(b))
    EFilterPipe(a, b)    -> EFilterPipe(f(a), f(b))
    EHandle(body, eff_name, eff_tyargs, init_opt, alias_opt, clauses, ret_opt) ->
      EHandle(f(body), eff_name, eff_tyargs,
              dsg_map_opt_expr(init_opt, f), alias_opt,
              map(clauses, (c) => dsg_map_clause_exprs(c, f)),
              dsg_map_opt_return_exprs(ret_opt, f))
    ELitUnit(inner, u)   -> ELitUnit(f(inner), u)
    EBang(inner)         -> EBang(f(inner))
  }
}

fn dsg_map_opt_expr(opt: Option[Expr], f: (Expr) -> Expr) : Option[Expr] {
  match opt {
    Some(e) -> Some(f(e))
    None    -> None
  }
}

fn dsg_map_stmt_exprs(s: Stmt, f: (Expr) -> Expr) : Stmt {
  match s {
    SLet(p, ann, rhs)           -> SLet(p, ann, f(rhs))
    SAssert(c, m)               -> SAssert(f(c), dsg_map_opt_expr(m, f))
    SExprStmt(x)                -> SExprStmt(f(x))
    SIndexAssign(b, i, v, l, c) -> SIndexAssign(f(b), f(i), f(v), l, c)
    SVar(n, ty, rhs, l, c)      -> SVar(n, ty, f(rhs), l, c)
    # m7e §25: SUse has no sub-expression — pass through unchanged.
    SUse(n, l, c)               -> SUse(n, l, c)
  }
}

fn dsg_map_arm_exprs(a: Arm, f: (Expr) -> Expr) : Arm {
  match a {
    Arm(p, g, b) -> Arm(p, dsg_map_opt_expr(g, f), f(b))
  }
}

fn dsg_map_field_exprs(fi: FieldInit, f: (Expr) -> Expr) : FieldInit {
  match fi {
    FI(n, v) -> FI(n, f(v))
  }
}

fn dsg_map_elem_exprs(el: ListElem, f: (Expr) -> Expr) : ListElem {
  match el {
    ElPlain(x)  -> ElPlain(f(x))
    ElSpread(x) -> ElSpread(f(x))
  }
}

fn dsg_map_clause_exprs(c: HClause, f: (Expr) -> Expr) : HClause {
  match c {
    HC(n, ps, b, l, co) -> HC(n, ps, f(b), l, co)
  }
}

fn dsg_map_opt_return_exprs(opt: Option[HReturn], f: (Expr) -> Expr) : Option[HReturn] {
  match opt {
    Some(r) -> Some(dsg_map_return_exprs(r, f))
    None    -> None
  }
}

fn dsg_map_return_exprs(r: HReturn, f: (Expr) -> Expr) : HReturn {
  match r {
    HR(p, b, l, c) -> HR(p, f(b), l, c)
  }
}

fn dsg_pat_bindings(pat: Pattern, acc: [String]) : [String] {
  match pat.pkind {
    PWild -> acc
    PLit(_) -> acc
    PBind(name) -> [name, ...acc]
    PList(pats, opt_rest) -> {
      let acc1 = dsg_pat_bindings_loop(pats, acc)
      match opt_rest {
        Some(rname) -> [rname, ...acc1]
        None -> acc1
      }
    }
    PVariant(_, subs) -> dsg_pat_bindings_loop(subs, acc)
    PVariantRecord(_, fields) -> dsg_pfield_bindings_loop(fields, acc)
    PRecord(fields) -> dsg_pfield_bindings_loop(fields, acc)
    PHole(_) -> acc
    PAs(name, sub) -> dsg_pat_bindings(sub, [name, ...acc])
    PNarrow(name, _) -> [name, ...acc]
  }
}

# Like `dsg_pat_bindings`, but if the pattern is a single `PBind` and
# the let's RHS is `MUnboxed`, the binding is a raw C scalar and
# must NOT enter the Perceus tracking scope. All other shapes —
# destructured lets, wildcards, literals — defer to the standard
# `dsg_pat_bindings` walker. See `docs/unboxing-phase2-design.md` §3
# (boundary tactic) for the coordination contract.

fn dsg_pat_bindings_loop(ps: [Pattern], acc: [String]) : [String] {
  match ps {
    [] -> acc
    [p, ...rest] -> dsg_pat_bindings_loop(rest, dsg_pat_bindings(p, acc))
  }
}

fn dsg_pfield_bindings_loop(fs: [PField], acc: [String]) : [String] {
  match fs {
    [] -> acc
    [f, ...rest] -> match f {
      PField(_, sub, _) -> dsg_pfield_bindings_loop(rest, dsg_pat_bindings(sub, acc))
    }
  }
}

fn dsg_rename_param_names(ps: [Param], acc: [String]) : [String] {
  match ps {
    [] -> acc
    [p, ...rest] -> dsg_rename_param_names(rest, [p.pname, ...acc])
  }
}

# Names introduced by a single pattern. Mirrors `bind_pat` but
# accumulates into a `[String]` rather than a resolver Env.

fn dsg_rename_pat_names(p: Pattern, acc: [String]) : [String] {
  match p.pkind {
    PWild         -> acc
    PLit(_)       -> acc
    PBind(name)   -> [name, ...acc]
    PList(pats, opt_rest) -> {
      let a = dsg_rename_pats_names(pats, acc)
      match opt_rest { Some(r) -> [r, ...a] None -> a }
    }
    PVariant(_, subs)        -> dsg_rename_pats_names(subs, acc)
    PVariantRecord(_, fs)    -> dsg_rename_pfields_names(fs, acc)
    PRecord(fs)              -> dsg_rename_pfields_names(fs, acc)
    PHole(_)                 -> acc
    PAs(name, sub)           -> dsg_rename_pat_names(sub, [name, ...acc])
    PNarrow(name, _)         -> [name, ...acc]
  }
}

fn dsg_rename_pats_names(ps: [Pattern], acc: [String]) : [String] {
  match ps {
    [] -> acc
    [p, ...rest] -> dsg_rename_pats_names(rest, dsg_rename_pat_names(p, acc))
  }
}

fn dsg_rename_pfields_names(fs: [PField], acc: [String]) : [String] {
  match fs {
    [] -> acc
    [pf, ...rest] -> match pf {
      PField(_, sub, _) -> dsg_rename_pfields_names(rest, dsg_rename_pat_names(sub, acc))
    }
  }
}

fn dsg_string_starts_with_q(s: String, prefix: String) : Bool =
  dsg_starts_with_loop(s, prefix, 0)

fn dsg_starts_with_loop(s: String, prefix: String, i: Int) : Bool {
  let pn = string_length(prefix)
  if i >= pn { true }
  else { match char_at(s, i) {
    None -> false
    Some(sc) -> match char_at(prefix, i) {
      None -> true
      Some(pc) -> if sc == pc { dsg_starts_with_loop(s, prefix, i + 1) } else { false }
    }
  } }
}

fn dsg_ffi_extern_tag() : String = "__kai_ffi__"

fn dsg_ffi_extern_tag_prefix() : String = "__kai_ffi__:"

# ====================================================================
# Desugar passes (sub-sections A-E)
# ====================================================================

# issue #266 — positional record construction sugar
# ====================================================================
#
# `T { v1, v2 }` desugars to `T { f1: v1, f2: v2 }` using `T`'s
# declared field order. The parser (parse_record_pos_loop) tags each
# positional value with a `__pos_<i>__` field-name sentinel; this
# pass rewrites those sentinels into the real field names by
# consulting the record-decl table.
#
# Validation is reported here and gated upstream of all later passes
# so a downstream walker never sees a sentinel field name. Two
# diagnostics:
#   * unknown record name → "unknown record type T"
#   * arity mismatch → "T expects N positional fields, got M"
# Mixed positional + named is rejected by the parser before it ever
# reaches this pass.

#[doc("Result of the positional-record desugar over a decl stream: the rewritten decls plus an error count.")]
pub type DPRDecls = { decls: [Decl], errs: Int }

#[doc("Issue #266 positional-record sugar: rewrite `Foo(a, b)` calls to `Foo { f1: a, f2: b }` record literals using the record table; the entry point the driver invokes.")]
pub fn desugar_pos_records_decls(ds: [Decl], file: String) : DPRDecls / Console + File {

  let recs = collect_records(ds)
  desugar_pos_records_loop(ds, recs, file, [], 0)
}

fn desugar_pos_records_loop(ds: [Decl], recs: [RecInfo], file: String, acc: [Decl], errs: Int) : DPRDecls / Console + File {

  match ds {
    [] -> DPRDecls { decls: list_reverse(acc), errs: errs }
    [d, ...rest] -> {
      let r = desugar_pos_records_decl(d, recs, file, errs)
      desugar_pos_records_loop(rest, recs, file, [r.decl, ...acc], r.errs)
    }
  }
}

type DPRDecl = { decl: Decl, errs: Int }

fn desugar_pos_records_decl(d: Decl, recs: [RecInfo], file: String, errs: Int) : DPRDecl / Console + File {

  match d {
    DFn(pub_, n, tps, ps, ret, row, body, l, c, mo) -> {
      let r = dpr_expr(body, recs, file, errs)
      DPRDecl { decl: DFn(pub_, n, tps, ps, ret, row, r.expr, l, c, mo), errs: r.errs }
    }
    DTest(desc, body, l, c) -> {
      let r = dpr_expr(body, recs, file, errs)
      DPRDecl { decl: DTest(desc, r.expr, l, c), errs: r.errs }
    }
    DBench(desc, body, l, c) -> {
      let r = dpr_expr(body, recs, file, errs)
      DPRDecl { decl: DBench(desc, r.expr, l, c), errs: r.errs }
    }
    DCheck(desc, params, body, l, c) -> {
      let r = dpr_expr(body, recs, file, errs)
      DPRDecl { decl: DCheck(desc, params, r.expr, l, c), errs: r.errs }
    }
    _ -> DPRDecl { decl: d, errs: errs }
  }
}

type DPRExpr = { expr: Expr, errs: Int }
type DPRStmts = { stmts: [Stmt], errs: Int }
type DPRStmt = { stmt: Stmt, errs: Int }
type DPROpt = { opt: Option[Expr], errs: Int }
type DPRExprs = { exprs: [Expr], errs: Int }
type DPRFields = { fields: [FieldInit], errs: Int }
type DPRArm = { arm: Arm, errs: Int }
type DPRArms = { arms: [Arm], errs: Int }

fn dpr_expr(e: Expr, recs: [RecInfo], file: String, errs: Int) : DPRExpr / Console + File {

  let kr = dpr_kind(e.kind, e.line, e.col, recs, file, errs)
  DPRExpr { expr: Expr { kind: kr.expr.kind, line: e.line, col: e.col, ty: e.ty, mode: e.mode },
            errs: kr.errs }
}

fn dpr_opt(o: Option[Expr], recs: [RecInfo], file: String, errs: Int) : DPROpt / Console + File {

  match o {
    Some(e) -> {
      let r = dpr_expr(e, recs, file, errs)
      DPROpt { opt: Some(r.expr), errs: r.errs }
    }
    None -> DPROpt { opt: None, errs: errs }
  }
}

fn dpr_exprs(es: [Expr], recs: [RecInfo], file: String, errs: Int) : DPRExprs / Console + File {

  match es {
    [] -> DPRExprs { exprs: [], errs: errs }
    [h, ...rest] -> {
      let rh = dpr_expr(h, recs, file, errs)
      let rt = dpr_exprs(rest, recs, file, rh.errs)
      DPRExprs { exprs: [rh.expr, ...rt.exprs], errs: rt.errs }
    }
  }
}

fn dpr_fields(fs: [FieldInit], recs: [RecInfo], file: String, errs: Int) : DPRFields / Console + File {

  match fs {
    [] -> DPRFields { fields: [], errs: errs }
    [f, ...rest] -> match f {
      FI(nm, val) -> {
        let rv = dpr_expr(val, recs, file, errs)
        let rt = dpr_fields(rest, recs, file, rv.errs)
        DPRFields { fields: [FI(nm, rv.expr), ...rt.fields], errs: rt.errs }
      }
    }
  }
}

fn dpr_stmts(ss: [Stmt], recs: [RecInfo], file: String, errs: Int) : DPRStmts / Console + File {

  match ss {
    [] -> DPRStmts { stmts: [], errs: errs }
    [h, ...rest] -> {
      let rh = dpr_stmt(h, recs, file, errs)
      let rt = dpr_stmts(rest, recs, file, rh.errs)
      DPRStmts { stmts: [rh.stmt, ...rt.stmts], errs: rt.errs }
    }
  }
}

fn dpr_stmt(s: Stmt, recs: [RecInfo], file: String, errs: Int) : DPRStmt / Console + File {

  match s {
    SLet(p, ann, rhs) -> {
      let r = dpr_expr(rhs, recs, file, errs)
      DPRStmt { stmt: SLet(p, ann, r.expr), errs: r.errs }
    }
    SAssert(c, m) -> {
      let rc = dpr_expr(c, recs, file, errs)
      let rm = dpr_opt(m, recs, file, rc.errs)
      DPRStmt { stmt: SAssert(rc.expr, rm.opt), errs: rm.errs }
    }
    SExprStmt(x) -> {
      let r = dpr_expr(x, recs, file, errs)
      DPRStmt { stmt: SExprStmt(r.expr), errs: r.errs }
    }
    SIndexAssign(b, i, v, l, c) -> {
      let rb = dpr_expr(b, recs, file, errs)
      let ri = dpr_expr(i, recs, file, rb.errs)
      let rv = dpr_expr(v, recs, file, ri.errs)
      DPRStmt { stmt: SIndexAssign(rb.expr, ri.expr, rv.expr, l, c), errs: rv.errs }
    }
    SVar(n, ty, rhs, l, c) -> {
      let r = dpr_expr(rhs, recs, file, errs)
      DPRStmt { stmt: SVar(n, ty, r.expr, l, c), errs: r.errs }
    }
    SUse(n, l, c) -> DPRStmt { stmt: SUse(n, l, c), errs: errs }
  }
}

fn dpr_arm(a: Arm, recs: [RecInfo], file: String, errs: Int) : DPRArm / Console + File {

  match a {
    Arm(p, g, b) -> {
      let rg = dpr_opt(g, recs, file, errs)
      let rb = dpr_expr(b, recs, file, rg.errs)
      DPRArm { arm: Arm(p, rg.opt, rb.expr), errs: rb.errs }
    }
  }
}

fn dpr_arms(arms: [Arm], recs: [RecInfo], file: String, errs: Int) : DPRArms / Console + File {

  match arms {
    [] -> DPRArms { arms: [], errs: errs }
    [h, ...rest] -> {
      let rh = dpr_arm(h, recs, file, errs)
      let rt = dpr_arms(rest, recs, file, rh.errs)
      DPRArms { arms: [rh.arm, ...rt.arms], errs: rt.errs }
    }
  }
}

# Returned from dpr_kind so we can co-thread the kind and an error
# count without using `dsg_map_expr_kind` (which has no error channel).
type DPRKind = { expr: Expr, errs: Int }

fn dpr_kind(k: ExprKind, line: Int, col: Int, recs: [RecInfo], file: String, errs: Int) : DPRKind / Console + File {

  match k {
    # The interesting case: rewrite positional record literals using
    # the record's declared field order. issue #326 also intercepts
    # the `...src, x: 10, ...` spread sugar here — a spread literal
    # is rewritten into `{ let s = src; T { f1: s.f1, ..., x: 10, ... } }`
    # so the expanded record-lit lands in the existing emit path.
    ERecordLit(name, fis) -> {
      # Recurse into sub-exprs FIRST so nested positional records
      # already have real field names by the time we look at this
      # node's own arity.
      let rfis = dpr_fields(fis, recs, file, errs)
      let is_spread = match rfis.fields {
        [] -> false
        [f0, ..._rest_] -> match f0 { FI(nm0, _) -> is_spread_field_marker(nm0) }
      }
      if is_spread {
        let r = dpr_record_spread(name, rfis.fields, line, col, recs, file, rfis.errs)
        DPRKind { expr: r.expr, errs: r.errs }
      } else {
        let renamed = dpr_record_lit(name, rfis.fields, line, col, recs, file, rfis.errs)
        DPRKind { expr: mk_expr(ERecordLit(name, renamed.fields), line, col), errs: renamed.errs }
      }
    }
    EBlock(stmts, tail) -> {
      let rs = dpr_stmts(stmts, recs, file, errs)
      let rt = dpr_opt(tail, recs, file, rs.errs)
      DPRKind { expr: mk_expr(EBlock(rs.stmts, rt.opt), line, col), errs: rt.errs }
    }
    ECall(callee, args_) -> {
      let rc = dpr_expr(callee, recs, file, errs)
      let ra = dpr_exprs(args_, recs, file, rc.errs)
      DPRKind { expr: mk_expr(ECall(rc.expr, ra.exprs), line, col), errs: ra.errs }
    }
    EField(base, nm) -> {
      let r = dpr_expr(base, recs, file, errs)
      DPRKind { expr: mk_expr(EField(r.expr, nm), line, col), errs: r.errs }
    }
    EIndex(a, b) -> {
      let ra = dpr_expr(a, recs, file, errs)
      let rb = dpr_expr(b, recs, file, ra.errs)
      DPRKind { expr: mk_expr(EIndex(ra.expr, rb.expr), line, col), errs: rb.errs }
    }
    EBinop(op, a, b) -> {
      let ra = dpr_expr(a, recs, file, errs)
      let rb = dpr_expr(b, recs, file, ra.errs)
      DPRKind { expr: mk_expr(EBinop(op, ra.expr, rb.expr), line, col), errs: rb.errs }
    }
    EUnop(op, x) -> {
      let r = dpr_expr(x, recs, file, errs)
      DPRKind { expr: mk_expr(EUnop(op, r.expr), line, col), errs: r.errs }
    }
    EIf(c, t_, eo) -> {
      let rc = dpr_expr(c, recs, file, errs)
      let rt = dpr_expr(t_, recs, file, rc.errs)
      let re = dpr_opt(eo, recs, file, rt.errs)
      DPRKind { expr: mk_expr(EIf(rc.expr, rt.expr, re.opt), line, col), errs: re.errs }
    }
    EMatch(scr, arms) -> {
      let rs = dpr_expr(scr, recs, file, errs)
      let ra = dpr_arms(arms, recs, file, rs.errs)
      DPRKind { expr: mk_expr(EMatch(rs.expr, ra.arms), line, col), errs: ra.errs }
    }
    ELambda(ps, body) -> {
      let r = dpr_expr(body, recs, file, errs)
      DPRKind { expr: mk_expr(ELambda(ps, r.expr), line, col), errs: r.errs }
    }
    EList(els) -> {
      let r = dpr_list_elems(els, recs, file, errs)
      DPRKind { expr: mk_expr(EList(r.elems), line, col), errs: r.errs }
    }
    ERange(a, b, opt_step) -> {
      let ra = dpr_expr(a, recs, file, errs)
      let rb = dpr_expr(b, recs, file, ra.errs)
      let rs = dpr_opt(opt_step, recs, file, rb.errs)
      DPRKind { expr: mk_expr(ERange(ra.expr, rb.expr, rs.opt), line, col), errs: rs.errs }
    }
    EPipe(a, b) -> {
      let ra = dpr_expr(a, recs, file, errs)
      let rb = dpr_expr(b, recs, file, ra.errs)
      DPRKind { expr: mk_expr(EPipe(ra.expr, rb.expr), line, col), errs: rb.errs }
    }
    EMapPipe(a, b) -> {
      let ra = dpr_expr(a, recs, file, errs)
      let rb = dpr_expr(b, recs, file, ra.errs)
      DPRKind { expr: mk_expr(EMapPipe(ra.expr, rb.expr), line, col), errs: rb.errs }
    }
    EFlatMapPipe(a, b) -> {
      let ra = dpr_expr(a, recs, file, errs)
      let rb = dpr_expr(b, recs, file, ra.errs)
      DPRKind { expr: mk_expr(EFlatMapPipe(ra.expr, rb.expr), line, col), errs: rb.errs }
    }
    EFilterPipe(a, b) -> {
      let ra = dpr_expr(a, recs, file, errs)
      let rb = dpr_expr(b, recs, file, ra.errs)
      DPRKind { expr: mk_expr(EFilterPipe(ra.expr, rb.expr), line, col), errs: rb.errs }
    }
    ELitUnit(inner, u) -> {
      let r = dpr_expr(inner, recs, file, errs)
      DPRKind { expr: mk_expr(ELitUnit(r.expr, u), line, col), errs: r.errs }
    }
    EBang(inner) -> {
      let r = dpr_expr(inner, recs, file, errs)
      DPRKind { expr: mk_expr(EBang(r.expr), line, col), errs: r.errs }
    }
    EHandle(body, eff_name, eff_tyargs, init_opt, alias_opt, clauses, ret_opt) -> {
      let rb = dpr_expr(body, recs, file, errs)
      let ri = dpr_opt(init_opt, recs, file, rb.errs)
      let rc = dpr_clauses(clauses, recs, file, ri.errs)
      let rr = dpr_opt_ret(ret_opt, recs, file, rc.errs)
      DPRKind {
        expr: mk_expr(EHandle(rb.expr, eff_name, eff_tyargs, ri.opt, alias_opt, rc.clauses, rr.ret), line, col),
        errs: rr.errs
      }
    }
    _ -> DPRKind { expr: mk_expr(k, line, col), errs: errs }
  }
}

type DPRElems = { elems: [ListElem], errs: Int }

fn dpr_list_elems(els: [ListElem], recs: [RecInfo], file: String, errs: Int) : DPRElems / Console + File {

  match els {
    [] -> DPRElems { elems: [], errs: errs }
    [el, ...rest] -> {
      let rh = match el {
        ElPlain(e)  -> {
          let r = dpr_expr(e, recs, file, errs)
          DPRElems { elems: [ElPlain(r.expr)], errs: r.errs }
        }
        ElSpread(e) -> {
          let r = dpr_expr(e, recs, file, errs)
          DPRElems { elems: [ElSpread(r.expr)], errs: r.errs }
        }
      }
      let rt = dpr_list_elems(rest, recs, file, rh.errs)
      DPRElems { elems: list_append(rh.elems, rt.elems), errs: rt.errs }
    }
  }
}

type DPRClauses = { clauses: [HClause], errs: Int }

fn dpr_clauses(cs: [HClause], recs: [RecInfo], file: String, errs: Int) : DPRClauses / Console + File {

  match cs {
    [] -> DPRClauses { clauses: [], errs: errs }
    [c, ...rest] -> match c {
      HC(n, ps, body, l, co) -> {
        let rb = dpr_expr(body, recs, file, errs)
        let rt = dpr_clauses(rest, recs, file, rb.errs)
        DPRClauses { clauses: [HC(n, ps, rb.expr, l, co), ...rt.clauses], errs: rt.errs }
      }
    }
  }
}

type DPROptRet = { ret: Option[HReturn], errs: Int }

fn dpr_opt_ret(or_: Option[HReturn], recs: [RecInfo], file: String, errs: Int) : DPROptRet / Console + File {

  match or_ {
    Some(r) -> match r {
      HR(p, b, l, c) -> {
        let rb = dpr_expr(b, recs, file, errs)
        DPROptRet { ret: Some(HR(p, rb.expr, l, c)), errs: rb.errs }
      }
    }
    None -> DPROptRet { ret: None, errs: errs }
  }
}

# Rewrite `[FI("__pos_0__", e0), ...]` into named `[FI(field0, e0), ...]`
# using the record's declared field order. Reports diagnostics for
# unknown record names and arity mismatches.
fn dpr_record_lit(name: String, fis: [FieldInit], line: Int, col: Int, recs: [RecInfo], file: String, errs: Int) : DPRFields / Console + File {

  let is_pos = match fis {
    [] -> false
    [f, ..._rest] -> match f { FI(nm, _) -> is_pos_field_marker(nm) }
  }
  if not is_pos {
    DPRFields { fields: fis, errs: errs }
  } else {
    # Positional record-lit: every field is a `__pos_<i>__` marker
    # at this point, so probing by field name does not disambiguate
    # same-(name, arity) collisions. Fall back to the bare-name
    # lookup; the field-set tie-breaker activates downstream in
    # `synth_record_lit` after positional → named rewriting.
    match rec_find(recs, name) {
      None -> {
        diag_error(file, line, col,
          string_concat("unknown record type `",
            string_concat(name,
              "` for positional construction; declare the type or use named-field form")))
        DPRFields { fields: fis, errs: errs + 1 }
      }
      Some(ri) -> match ri {
        RI(_, _, fds, _) -> {
          let n_pos = list_length(fis)
          let n_decl = list_length(fds)
          if n_pos != n_decl {
            diag_error(file, line, col,
              concat_all([ "`", name, "` expects ", int_to_string(n_decl),
                           " positional fields, got ", int_to_string(n_pos) ]))
            DPRFields { fields: fis, errs: errs + 1 }
          } else {
            DPRFields { fields: rename_pos_fields(fis, fds), errs: errs }
          }
        }
      }
    }
  }
}

fn rename_pos_fields(fis: [FieldInit], fds: [FieldDecl]) : [FieldInit] {
  match fis {
    [] -> []
    [fi, ...frest] -> match fds {
      [] -> [fi, ...frest]
      [fd, ...drest] -> match fi {
        FI(_, val) -> match fd {
          FD(_, real_name, _) -> [FI(real_name, val), ...rename_pos_fields(frest, drest)]
        }
      }
    }
  }
}

# issue #326 — expand `T { ...src, x: 10, y: 20 }` into a let-block:
#
#     {
#       let __spread_src_<line>_<col>__ = src
#       T { f1: __spread_src_*.f1, ..., x: 10, y: 20, ... }
#     }
#
# The let captures `src` once so a side-effecting source expression
# isn't replayed across N field accesses. The fields are emitted
# in declared order: an override wins over the spread copy. Errors:
#   * unknown record type for `T` → "unknown record type T"
#   * any override field that isn't a declared field of `T`
#   * duplicate override of the same field

fn dpr_record_spread(
  name: String,
  fis: [FieldInit],
  line: Int,
  col: Int,
  recs: [RecInfo],
  file: String,
  errs: Int
) : DPRSpread / Console + File {

  # Split: head FI is the spread sentinel carrying `src`; rest are
  # named overrides (parser already rejected pun / positional /
  # second-spread, so each FI here pairs a real field name with an
  # already-recursed expression).
  match fis {
    [] -> DPRSpread { expr: mk_expr(ERecordLit(name, fis), line, col), errs: errs }
    [head, ...overrides] -> match head {
      FI(_marker, src) -> {
        # Issue #648 — probe by the first override's field name to
        # disambiguate same-(name, arity) record collisions. Falls
        # back to bare lookup when no overrides accompany the spread
        # (rare).
        let probe = match overrides {
          [] -> ""
          [ov, ..._] -> match ov { FI(fnm, _) -> fnm }
        }
        let lookup = if probe == "" {
          rec_find(recs, name)
        } else {
          rec_find_with_field(recs, name, -1, probe)
        }
        match lookup {
          None -> {
            diag_error(file, line, col,
              concat_all(["unknown record type `", name,
                          "` in `...` spread; declare the type before constructing it"]))
            DPRSpread { expr: mk_expr(ERecordLit(name, fis), line, col), errs: errs + 1 }
          }
          Some(ri) -> match ri {
            RI(_, tparams, fds, _) -> {
              # Diagnose duplicate overrides (same field listed twice).
              let dup_errs = check_spread_dup_overrides(overrides, [], file, line, col, 0)
              # Diagnose overrides naming a field not declared on `T`.
              let bad_errs = check_spread_unknown_overrides(overrides, fds, name, file, line, col, 0)
              let errs1 = errs + dup_errs + bad_errs
              if dup_errs + bad_errs > 0 {
                DPRSpread { expr: mk_expr(ERecordLit(name, fis), line, col), errs: errs1 }
              } else {
                let var_name = spread_src_var_name(line, col)
                let bind_pat = mk_pat(PBind(var_name), line, col)
                # Annotate the let with `T` for non-generic records so
                # the existing nominal let-annotation check fires when
                # `src : Q` with `Q != T` — spec's "spread source must
                # match record type" reusing the typer's normal error
                # path. Skipped for generic records: `T[a, b]` cannot
                # be spelled without committing to a concrete arg
                # tuple, so we let the typer infer and rely on its
                # field-by-field check instead.
                let ann_opt = match tparams {
                  []           -> Some(mk_ty(TyName(name, []), line, col))
                  [_, ..._rest] -> None
                }
                let bind_stmt = SLet(bind_pat, ann_opt, src)
                let var_ref = mk_expr(EVar(var_name), line, col)
                let expanded = expand_spread_fields(fds, overrides, var_ref, line, col)
                let lit = mk_expr(ERecordLit(name, expanded), line, col)
                DPRSpread { expr: mk_expr(EBlock([bind_stmt], Some(lit)), line, col), errs: errs1 }
              }
            }
          }
        }
      }
    }
  }
}

type DPRSpread = { expr: Expr, errs: Int }

# Build a stable, position-derived var name for the spread source.
# Two literals on the same line/col can't collide because the parser
# rules them out at the source level; nesting is fine because each
# spread sits inside its own EBlock scope.
fn spread_src_var_name(line: Int, col: Int) : String =
  concat_all(["__spread_src_", int_to_string(line), "_", int_to_string(col), "__"])

# Walk declared field order; for each field, prefer the override
# expression if present, else `var_ref.field_name`.
fn expand_spread_fields(
  fds: [FieldDecl],
  overrides: [FieldInit],
  var_ref: Expr,
  line: Int,
  col: Int
) : [FieldInit] {
  match fds {
    [] -> []
    [fd, ...rest] -> match fd {
      FD(_, fname, _) -> {
        let val = match find_override(overrides, fname) {
          Some(ov) -> ov
          None -> mk_expr(EField(var_ref, fname), line, col)
        }
        [FI(fname, val), ...expand_spread_fields(rest, overrides, var_ref, line, col)]
      }
    }
  }
}

fn find_override(overrides: [FieldInit], name: String) : Option[Expr] {
  match overrides {
    [] -> None
    [h, ...rest] -> match h {
      FI(n, val) -> if n == name { Some(val) } else { find_override(rest, name) }
    }
  }
}

# Returns an error count. Each duplicated override name is reported
# once (subsequent occurrences are flagged at their first repeat).
fn check_spread_dup_overrides(
  overrides: [FieldInit],
  seen: [String],
  file: String,
  line: Int,
  col: Int,
  errs: Int
) : Int / Console + File {

  match overrides {
    [] -> errs
    [h, ...rest] -> match h {
      FI(n, _) -> {
        if str_in_list(n, seen) {
          diag_error(file, line, col,
            concat_all(["record-spread override `", n,
                        "` listed more than once"]))
          check_spread_dup_overrides(rest, seen, file, line, col, errs + 1)
        } else {
          check_spread_dup_overrides(rest, [n, ...seen], file, line, col, errs)
        }
      }
    }
  }
}

fn check_spread_unknown_overrides(
  overrides: [FieldInit],
  fds: [FieldDecl],
  rec_name: String,
  file: String,
  line: Int,
  col: Int,
  errs: Int
) : Int / Console + File {

  match overrides {
    [] -> errs
    [h, ...rest] -> match h {
      FI(n, _) -> {
        if field_decl_has(fds, n) {
          check_spread_unknown_overrides(rest, fds, rec_name, file, line, col, errs)
        } else {
          diag_error(file, line, col,
            concat_all(["record-spread override `", n,
                        "` is not a field of `", rec_name, "`"]))
          check_spread_unknown_overrides(rest, fds, rec_name, file, line, col, errs + 1)
        }
      }
    }
  }
}

fn field_decl_has(fds: [FieldDecl], name: String) : Bool {
  match fds {
    [] -> false
    [h, ...rest] -> match h {
      FD(_, n, _) -> if n == name { true } else { field_decl_has(rest, name) }
    }
  }
}

fn str_in_list(s: String, xs: [String]) : Bool {
  match xs {
    [] -> false
    [h, ...rest] -> if h == s { true } else { str_in_list(s, rest) }
  }
}

# ====================================================================
# m7b #5b: pre-resolve desugar of `var name [: T] = init`
# ====================================================================
#
# Doc B §`State[T]` *Syntax note* and Doc C §m7b #5 mandate this
# lowering: a block
#
#   { stmt0; ...; var name [: T] = init; rest_stmts; tail_expr }
#
# becomes
#
#   { stmt0; ...; handle { rest_stmts; tail_expr } with State[T](init) as name {
#       get(resume)    -> resume(state)
#       set(v, resume) -> resume((), v)
#       return(x)      -> x
#     } }
#
# Doc B locality: the `with` consumes `State[T]` inside the function,
# so the function's effect row is unchanged (no `+ State[T]` leaking
# out). When `T` is omitted, synth_handle infers it from the init's
# inferred type — see the `eff_tyargs == []` fallback in synth_handle.
#
# Nested `var`s nest handlers, innermost first: the recursion finds
# the head SVar in each block, wraps everything that follows it under
# a fresh State[T] handler, and recurses into that wrapped block — so
# a second `var` inside the rest produces a second handler nested
# inside the first.

# m12.7: rewrite every `axiom name(params) : T / row` into a regular
# `fn name(params) : T / row = todo!("axiom <name> not bound")`. The
# `todo!` (m7d §1) body inherits "any type fits" inference and a
# runtime `kai_prelude_panic`, matching the §4 spec ("by default,
# calling an axiom at runtime aborts via `kai_prelude_panic`"). The
# typer / monomorphiser / emitter therefore see only ordinary fns
# and need no DAxiom-specific handling.
#[doc("m12.7: rewrite every `DAxiom` decl into the equivalent `DFn` so the rest of the pipeline sees a plain function.")]
pub fn lower_axioms(ds: [Decl]) : [Decl] = map(ds, lower_axiom_one)

# Issue #269: lower every `DConst(is_pub, name, ty, body, l, c)` to
# the legacy `DAttribPure(DFn arity-0)` shape so the rest of the
# pipeline (typer, monomorphiser, emitters) keeps seeing the form
# it was already wired for. The dedicated `DConst` variant exists at
# the parser surface to give consts a structural identity (the
# downstream typer/emitter integration that drops the function-call
# indirection is intentionally deferred — see the variant's comment
# in the Decl enum). Runs early in the driver, alongside `lower_axioms`.
#[doc("Rewrite every `DConst` decl into a zero-arg `DFn` thunk that the const-ref desugar then forces at use sites.")]
pub fn lower_consts(ds: [Decl]) : [Decl] = map(ds, lower_const_one)

#[doc("Lower a single `DConst` to a zero-arg `DFn` thunk.")]
pub fn lower_const_one(d: Decl) : Decl {
  match d {
    DConst(is_pub, name, ty, body, l, c) -> {
      let dfn = DFn(is_pub, name, [], [], Some(ty), REmpty, body, l, c, None)
      DAttribPure(dfn, l, c)
    }
    _ -> d
  }
}

#[doc("Lower a single `DAxiom` to a `DFn`, tagging the body as an FFI shim when the axiom carries an `extern` form.")]
pub fn lower_axiom_one(d: Decl) : Decl {
  match d {
    DAxiom(is_pub, extern_c, name, c_sym_over, tparams, params, ret_ty, row, l, c) -> {
      # m12.7.x FFI v1: an `extern "C" fn` (or legacy `[<extern_c>]`
      # axiom) lowers to a DFn whose body is a magic `ETodo` whose
      # message tags it as an FFI shim. The C / LLVM `emit_fn_body`
      # paths detect the tag and synthesise a real `extern "C"`
      # call instead of the default `kai_prelude_panic` body.
      # Typer-side `ETodo` still type-checks as "any type fits", so
      # the FFI shim's typed signature is what flows into call sites.
      #
      # Issue #261: when `c_sym_over` is non-empty, encode it inside
      # the magic tag (`__kai_ffi__:<override>`) so the C / LLVM
      # emitters can read it back when synthesising the call site
      # without a second AST field carrying the override.
      let msg =
        if extern_c {
          if string_length(c_sym_over) > 0 {
            string_concat(dsg_ffi_extern_tag_prefix(), c_sym_over)
          } else { dsg_ffi_extern_tag() }
        }
        else { string_concat("axiom ", string_concat(name, " not bound")) }
      let body = mk_expr(ETodo(msg), l, c)
      DFn(is_pub, name, tparams, params, Some(ret_ty), row, body, l, c, None)
    }
    _ -> d
  }
}

#[doc("Collect the names of `#[pure]`-wrapped zero-arg fns (the const set) that `desugar_const_refs_decls` later forces.")]
pub fn collect_const_names_decls(decls: [Decl]) : [String] =
  collect_const_names_loop(decls, [])

fn collect_const_names_loop(decls: [Decl], acc: [String]) : [String] {
  match decls {
    [] -> list_reverse(acc)
    [d, ...rest] -> match d {
      DAttribPure(inner, _, _) -> match inner {
        DFn(_, name, _, [], _, _, _, _, _, _) ->
          collect_const_names_loop(rest, [name, ...acc])
        _ -> collect_const_names_loop(rest, acc)
      }
      _ -> collect_const_names_loop(rest, acc)
    }
  }
}

# §29 const desugar: rewrite every `EVar(name)` reference in any
# Expr position (fn body, type-refinement predicate, contract
# predicate via SAssert in body, match-arm guard) where `name`
# matches a declared const into `ECall(EVar(name), [])` so the
# resolver/typer treats it as a zero-arg fn call. Operates on the
# whole decl stream after collect_const_names_decls produces the
# const-name list.
#[doc("§29 const desugar: rewrite every `EVar(NAME)` reference to a zero-arg const into `ECall(EVar(NAME), [])` so it forces the thunk.")]
pub fn desugar_const_refs_decls(decls: [Decl], const_names: [String]) : [Decl] =
  map(decls, (d) => desugar_const_refs_decl(d, const_names))

fn desugar_const_refs_decl(d: Decl, const_names: [String]) : Decl {
  match d {
    DFn(p, n, tps, ps, ret, row, body, l, c, mo) -> {
      let ps2 = map(ps, (pm) => desugar_const_refs_param(pm, const_names))
      let ret2 = match ret {
        Some(t) -> Some(desugar_const_refs_typeexpr(t, const_names))
        None -> None
      }
      # Issue #269: a fn parameter `x` shadows any `const x` in scope.
      # Subtract param names from `const_names` before walking the body
      # so `EVar(x)` in the body resolves to the parameter, not a
      # zero-arg call to the const. Without this filter, `repeat(x: a, ...)`
      # in stdlib breaks any program that declares `const x`.
      let body_names = list_minus_names(const_names, fn_param_names(ps))
      DFn(p, n, tps, ps2, ret2, row,
          desugar_const_refs_expr(body, body_names), l, c, mo)
    }
    DTest(desc, body, l, c) -> DTest(desc, desugar_const_refs_expr(body, const_names), l, c)
    DBench(desc, body, l, c) -> DBench(desc, desugar_const_refs_expr(body, const_names), l, c)
    DCheck(desc, params, body, l, c) -> {
      let body_names = list_minus_names(const_names, fn_param_names(params))
      DCheck(desc, params, desugar_const_refs_expr(body, body_names), l, c)
    }
    DType(p, n, tps, body, l, c, mo) -> DType(p, n, tps,
                                            desugar_const_refs_typebody(body, const_names),
                                            l, c, mo)
    DAttribPure(inner, l, c) -> DAttribPure(desugar_const_refs_decl(inner, const_names), l, c)
    _ -> d
  }
}

# Issue #269: subtract `removed` from `names`. Used to drop locally-
# bound names from the const-rewrite list when entering a binding
# scope (fn params, lambda params, SLet binders, match-arm pattern
# binders). Linear in `names * removed`; the lists stay tiny so a
# more-clever set is not worth the complexity.
fn list_minus_names(names: [String], removed: [String]) : [String] {
  match names {
    [] -> []
    [h, ...rest] ->
      if list_has(removed, h) { list_minus_names(rest, removed) }
      else { [h, ...list_minus_names(rest, removed)] }
  }
}

fn desugar_const_refs_param(pm: Param, const_names: [String]) : Param {
  match pm.ptype {
    Some(t) -> Param { pname: pm.pname,
                        ptype: Some(desugar_const_refs_typeexpr(t, const_names)),
                        pline: pm.pline, pcol: pm.pcol }
    None -> pm
  }
}

fn desugar_const_refs_typebody(b: TypeBody, const_names: [String]) : TypeBody {
  match b {
    TBAlias(t) -> TBAlias(desugar_const_refs_typeexpr(t, const_names))
    TBRecord(fields) -> TBRecord(map(fields, (fd) => desugar_const_refs_field(fd, const_names)))
    _ -> b
  }
}

fn desugar_const_refs_field(fd: FieldDecl, const_names: [String]) : FieldDecl {
  match fd {
    FD(is_pub, name, ty) -> FD(is_pub, name, desugar_const_refs_typeexpr(ty, const_names))
  }
}

fn desugar_const_refs_typeexpr(t: TypeExpr, const_names: [String]) : TypeExpr {
  match t.tkind {
    TyRefine(base, pred) ->
      mk_ty(TyRefine(desugar_const_refs_typeexpr(base, const_names),
                      desugar_const_refs_expr(pred, const_names)),
            t.line, t.col)
    TyDim(base, u) ->
      mk_ty(TyDim(desugar_const_refs_typeexpr(base, const_names), u), t.line, t.col)
    TyList(inner) ->
      mk_ty(TyList(desugar_const_refs_typeexpr(inner, const_names)), t.line, t.col)
    TyName(n, tas) ->
      mk_ty(TyName(n, map(tas, (a) => desugar_const_refs_typeexpr(a, const_names))),
            t.line, t.col)
    TyFn(ps, ret, row) ->
      mk_ty(TyFn(map(ps, (p) => desugar_const_refs_typeexpr(p, const_names)),
                  desugar_const_refs_typeexpr(ret, const_names), row),
            t.line, t.col)
  }
}

fn desugar_const_refs_expr(e: Expr, const_names: [String]) : Expr {
  let new_kind = match e.kind {
    EVar(name) ->
      if list_has(const_names, name) {
        ECall(mk_expr(EVar(name), e.line, e.col), [])
      } else { e.kind }
    # §29 v2: rewrite identifiers inside `#{...}` interpolation
    # spans textually so the legacy emit-time path that re-parses
    # the EStr span sees `NAME()` instead of `NAME`.
    EStr(span, is_triple) ->
      EStr(rewrite_const_refs_in_span(span, const_names), is_triple)
    # §29 v3 pattern-side: rewrite a match arm whose pattern is a
    # bare `PBind(name)` matching a const into a wildcard bind plus
    # a synthesised guard `__cv == NAME()`. AND-combines with any
    # explicit `if user_pred`. This makes `match n { ZERO -> ... }`
    # work as comparison instead of silently binding. Pattern binders
    # are subtracted from `const_names` before walking the arm body
    # / guard so a parameter-like binder shadows the const correctly
    # (issue #269).
    EMatch(scr, arms) ->
      EMatch(desugar_const_refs_expr(scr, const_names),
              map(arms, (a) => desugar_const_refs_arm(a, const_names)))
    # Issue #269: lambda params shadow consts in the body. Subtract
    # before recursing.
    ELambda(ps, body) -> {
      let inner_names = list_minus_names(const_names, fn_param_names(ps))
      ELambda(ps, desugar_const_refs_expr(body, inner_names))
    }
    # Issue #269: walk a block left-to-right, growing the shadow set
    # as we encounter `let pat = rhs` / `var name = init` / `use Eff`
    # binders. The RHS of an SLet/SVar is evaluated BEFORE the bind
    # takes effect, so it sees the pre-binding name set; subsequent
    # statements (and the tail expression) see the post-binding set.
    EBlock(stmts, tail) -> {
      let r = desugar_const_refs_block_stmts(stmts, const_names, [])
      let final_names = r.names
      let tail2 = match tail {
        None -> None
        Some(te) -> Some(desugar_const_refs_expr(te, final_names))
      }
      EBlock(r.stmts, tail2)
    }
    _ -> dsg_map_expr_kind(e.kind, (sub) => desugar_const_refs_expr(sub, const_names))
  }
  Expr { kind: new_kind, line: e.line, col: e.col, ty: e.ty, mode: e.mode }
}

# Issue #269: scope-aware traversal of a block's statement list.
# Returns the rewritten statements plus the (post-block) const-name
# set that the block's tail expression should see. Each binding
# statement narrows the set going forward.
type ConstStmtsRes = { stmts: [Stmt], names: [String] }

fn desugar_const_refs_block_stmts(stmts: [Stmt], names: [String],
                                    acc: [Stmt]) : ConstStmtsRes {
  match stmts {
    [] -> ConstStmtsRes { stmts: list_reverse(acc), names: names }
    [s, ...rest] -> {
      let s2 = desugar_const_refs_stmt(s, names)
      let names2 = match s {
        SLet(pat, _, _) -> list_minus_names(names, pat_binders(pat, []))
        SVar(n, _, _, _, _) -> list_minus_names(names, [n])
        _ -> names
      }
      desugar_const_refs_block_stmts(rest, names2, [s2, ...acc])
    }
  }
}

fn desugar_const_refs_stmt(s: Stmt, names: [String]) : Stmt {
  match s {
    SLet(pat, ann, rhs) ->
      SLet(pat, ann, desugar_const_refs_expr(rhs, names))
    SAssert(c, om) ->
      SAssert(desugar_const_refs_expr(c, names),
               match om { None -> None Some(m) -> Some(desugar_const_refs_expr(m, names)) })
    SExprStmt(e) -> SExprStmt(desugar_const_refs_expr(e, names))
    SIndexAssign(b, i, v, l, c) ->
      SIndexAssign(desugar_const_refs_expr(b, names),
                    desugar_const_refs_expr(i, names),
                    desugar_const_refs_expr(v, names), l, c)
    SVar(n, ty, rhs, l, c) ->
      SVar(n, ty, desugar_const_refs_expr(rhs, names), l, c)
    SUse(n, l, c) -> SUse(n, l, c)
  }
}

fn desugar_const_refs_arm(a: Arm, const_names: [String]) : Arm {
  match a {
    Arm(pat, opt_g, body) -> {
      # Issue #269: pattern binders shadow consts in the arm body
      # and guard. Subtract before recursing. The const-comparison
      # rewrite (`arm_for_const_or_pass`) still inspects the
      # pre-shadow `const_names` so a `match n { ZERO -> ... }` arm
      # whose pattern matches a const name still synthesises the
      # equality guard — the synthesised binder (`__cv_NAME`) is
      # not a kaikai-visible name and never collides with a
      # parameter shadow.
      let inner_names = list_minus_names(const_names, pat_binders(pat, []))
      let body2 = desugar_const_refs_expr(body, inner_names)
      let g2_orig = match opt_g {
        Some(g) -> Some(desugar_const_refs_expr(g, inner_names))
        None -> None
      }
      desugar_const_refs_arm_pat(pat, g2_orig, body2, const_names)
    }
  }
}

fn desugar_const_refs_arm_pat(pat: Pattern, opt_g: Option[Expr], body: Expr,
                                const_names: [String]) : Arm {
  # Both PBind(name) (lowercase pattern bind) and PVariant(name, [])
  # (uppercase parsed as zero-arg variant) participate. The user
  # writes `MAX_PORT` and the parser's lex-time uppercase rule
  # produces a PVariant; for const semantics we treat it like a
  # bind that compares.
  match pat.pkind {
    PBind(name) -> arm_for_const_or_pass(pat, name, [], opt_g, body, const_names)
    PVariant(name, subs) ->
      if subs == [] {
        arm_for_const_or_pass(pat, name, [], opt_g, body, const_names)
      } else { Arm(pat, opt_g, body) }
    _ -> Arm(pat, opt_g, body)
  }
}

fn arm_for_const_or_pass(pat: Pattern, name: String, _ignored: [Pattern],
                           opt_g: Option[Expr], body: Expr,
                           const_names: [String]) : Arm {
  if not list_has(const_names, name) { Arm(pat, opt_g, body) }
  else {
    let cv_name = string_concat("__cv_", name)
    let new_pat = mk_pat(PBind(cv_name), pat.line, pat.col)
    let cv_var = mk_expr(EVar(cv_name), pat.line, pat.col)
    let const_call = mk_expr(ECall(mk_expr(EVar(name), pat.line, pat.col), []),
                              pat.line, pat.col)
    let extra_guard = mk_expr(EBinop("==", cv_var, const_call), pat.line, pat.col)
    let combined = match opt_g {
      None -> Some(extra_guard)
      Some(ug) -> Some(mk_expr(EBinop("and", extra_guard, ug),
                                 pat.line, pat.col))
    }
    Arm(new_pat, combined, body)
  }
}

# §29 v2 textual rewrite. Walks the span byte-by-byte. State is
# the index `i` and a Bool `inside` (true while we're between `#{`
# and the matching `}`). Inside a segment we look for identifiers;
# every identifier whose lexeme matches a const name gets a `()`
# suffix appended. Outside segments the bytes are copied verbatim.
fn rewrite_const_refs_in_span(span: String, names: [String]) : String {
  let n = string_length(span)
  rcr_main(span, names, n, 0, "", false)
}

fn rcr_main(span: String, names: [String], n: Int, i: Int, acc: String, inside: Bool) : String {
  if i >= n { acc } else { rcr_step(span, names, n, i, acc, inside) }
}

fn rcr_step(span: String, names: [String], n: Int, i: Int, acc: String, inside: Bool) : String {
  let c = char_at_or_zero(span, i)
  if not inside { rcr_outside(span, names, n, i, acc, c) }
  else { rcr_inn(span, names, n, i, acc, c) }
}

# char_at_or_zero moved to compiler/util.kai (issue #677 phase 1h H1a).

fn rcr_outside(span: String, names: [String], n: Int, i: Int, acc: String, c: Char) : String {
  if char_to_int(c) == 35 { rcr_after_hash(span, names, n, i, acc) }
  else { rcr_main(span, names, n, i + 1, append_char(acc, c), false) }
}

# Char `#` at position i. Check if next char is `{` to switch into
# interp mode; otherwise copy the `#` literally.
fn rcr_after_hash(span: String, names: [String], n: Int, i: Int, acc: String) : String {
  let nxt = char_at_or_zero(span, i + 1)
  if char_to_int(nxt) == 123 {
    rcr_main(span, names, n, i + 2, cat2(cat2(acc, "#"), "{"), true)
  } else {
    rcr_main(span, names, n, i + 1, append_char(acc, '#'), false)
  }
}

fn rcr_inn(span: String, names: [String], n: Int, i: Int, acc: String, c: Char) : String {
  if char_to_int(c) == 125 {
    rcr_main(span, names, n, i + 1, cat2(acc, "}"), false)
  } else {
    rcr_innc(span, names, n, i, acc, c)
  }
}

fn rcr_innc(span: String, names: [String], n: Int, i: Int, acc: String, c: Char) : String {
  if ch_is_alpha(c) {
    rcr_inid(span, names, n, i, acc)
  } else {
    rcr_main(span, names, n, i + 1, append_char(acc, c), true)
  }
}

fn rcr_inid(span: String, names: [String], n: Int, i: Int, acc: String) : String {
  let id_end = scan_ident_end(span, n, i + 1)
  let ident = string_slice(span, i, id_end - i)
  let has = list_has(names, ident)
  let suffix = if has { "()" } else { "" }
  rcr_main(span, names, n, id_end, cat2(acc, cat2(ident, suffix)), true)
}

fn scan_ident_end(span: String, n: Int, i: Int) : Int {
  if i >= n { i } else { scan_ident_step(span, n, i) }
}

fn scan_ident_step(span: String, n: Int, i: Int) : Int {
  let c = char_at_or_zero(span, i)
  if ch_is_alnum(c) { scan_ident_end(span, n, i + 1) }
  else { i }
}

# append_char moved to compiler/util.kai (issue #677 phase 1h H1a).

# m12.6.x #3 v2: synthesise a refinement-predicate fn for every
# `type X = Base where pred` alias. The fn is named
# `__ref_pred_X(self: Base) : Bool` and carries the same predicate
# expression the user wrote. Wrapped in `DAttribPure` so the
# refinement-pure validator admits calls to it inside contract
# predicates. parse_optional_arm_refine references this name when
# it sees `match { p : X -> ... }`; the resolver later binds the
# call to this synthesised fn.
# Issue #597 boundary tagging: thread `target_mod` so each synthesised
# `__ref_pred_X` inherits the home module of the originating `DType`.
# `DType` carries no `module_origin` field of its own, so the home is
# recovered by streaming through `decl_home_hint_reset` (same algorithm
# `validate_pub_access` uses for non-DFn decls). A refinement alias
# declared in `stdlib/foo.kai` now produces `__ref_pred_X` tagged with
# `mo = Some("foo")` instead of mixing into the root file's untagged
# decl set; root-file refinements still produce `mo = None`.
#[doc("m12.6 refinements: synthesise the predicate fn backing each `type T = base where pred` refinement alias.")]
pub fn synthesize_refine_pred_fns(decls: [Decl], target_mod: String) : [Decl] =
  synth_refine_loop(decls, target_mod, target_mod, [])

fn synth_refine_loop(decls: [Decl], target_mod: String, cur_mod: String,
                       acc: [Decl]) : [Decl] {
  match decls {
    [] -> list_reverse(acc)
    [d, ...rest] -> {
      let next_mod = decl_home_hint_reset(d, cur_mod, target_mod)
      let parent_mo =
        if next_mod == target_mod { None } else { Some(next_mod) }
      let extra = synth_refine_for_decl(d, parent_mo)
      let acc1 = list_append(extra, [d, ...acc])
      synth_refine_loop(rest, target_mod, next_mod, acc1)
    }
  }
}

fn synth_refine_for_decl(d: Decl, parent_mo: Option[String]) : [Decl] {
  match d {
    DType(_, name, _, body, l, c, _) -> match body {
      TBAlias(t) -> match t.tkind {
        TyRefine(base, pred) ->
          [build_refine_pred_fn(name, base, pred, l, c, parent_mo)]
        _ -> []
      }
      _ -> []
    }
    _ -> []
  }
}

fn build_refine_pred_fn(tyname: String, base: TypeExpr, pred: Expr,
                          l: Int, c: Int, mo: Option[String]) : Decl {
  let fn_name = synth_refine_pred_fn_name(tyname)
  let self_param = Param { pname: "self", ptype: Some(base),
                            pline: l, pcol: c }
  let ret_ty = mk_ty(TyName("Bool", []), l, c)
  let dfn = DFn(false, fn_name, [], [self_param], Some(ret_ty),
                 REmpty, pred, l, c, mo)
  DAttribPure(dfn, l, c)
}

# issue #187 phase 3: lower `PNarrow(name, TyName(t, []))` whose
# `t` is a refinement-type alias (m12.6.x) back into the legacy
# shape `PBind(name) + guard __ref_pred_t(name)`. The parser emits
# `PNarrow` uniformly because at parse time we can't tell whether
# `t` names a refinement alias or a union-component nominal type;
# this pass disambiguates after `synthesize_refine_pred_fns` has
# populated the alias namespace. Non-refinement narrowings stay as
# `PNarrow` for the typer's union-component check.
#[doc("Collect refinement-alias type names so the pattern-narrow lowering knows which `PNarrow` heads are refinement checks.")]
pub fn collect_refine_alias_names(decls: [Decl]) : [String] =
  collect_refine_alias_loop(decls, [])

fn collect_refine_alias_loop(decls: [Decl], acc: [String]) : [String] {
  match decls {
    [] -> list_reverse(acc)
    [d, ...rest] -> match d {
      DType(_, name, _, body, _, _, _) -> match body {
        TBAlias(t) -> match t.tkind {
          TyRefine(_, _) -> collect_refine_alias_loop(rest, [name, ...acc])
          _ -> collect_refine_alias_loop(rest, acc)
        }
        _ -> collect_refine_alias_loop(rest, acc)
      }
      _ -> collect_refine_alias_loop(rest, acc)
    }
  }
}

#[doc("m12.6 refinements: lower `PNarrow(name, alias)` patterns into a binder plus a predicate guard against the alias's synthesised pred fn.")]
pub fn lower_pattern_narrow_decls(decls: [Decl], aliases: [String]) : [Decl] =
  map(decls, (d) => lower_narrow_decl(d, aliases))

fn lower_narrow_decl(d: Decl, aliases: [String]) : Decl {
  match d {
    DFn(p, n, tps, ps, ret, row, body, l, c, mo) ->
      DFn(p, n, tps, ps, ret, row, lower_narrow_expr(body, aliases), l, c, mo)
    DTest(desc, body, l, c) -> DTest(desc, lower_narrow_expr(body, aliases), l, c)
    DBench(desc, body, l, c) -> DBench(desc, lower_narrow_expr(body, aliases), l, c)
    DCheck(desc, params, body, l, c) -> DCheck(desc, params, lower_narrow_expr(body, aliases), l, c)
    DAttribPure(inner, l, c) -> DAttribPure(lower_narrow_decl(inner, aliases), l, c)
    _ -> d
  }
}

fn lower_narrow_expr(e: Expr, aliases: [String]) : Expr {
  match e.kind {
    EMatch(scr, arms) -> {
      let scr2 = lower_narrow_expr(scr, aliases)
      let arms2 = map(arms, (a) => lower_narrow_arm(a, aliases))
      mk_expr(EMatch(scr2, arms2), e.line, e.col)
    }
    _ -> {
      let new_kind = dsg_map_expr_kind(e.kind, (sub) => lower_narrow_expr(sub, aliases))
      mk_expr(new_kind, e.line, e.col)
    }
  }
}

fn lower_narrow_arm(a: Arm, aliases: [String]) : Arm {
  match a {
    Arm(pat, guard, body) -> {
      let body1 = lower_narrow_expr(body, aliases)
      let guard1 = match guard {
        None -> None
        Some(g) -> Some(lower_narrow_expr(g, aliases))
      }
      match pat.pkind {
        PNarrow(name, ty) -> match ty.tkind {
          TyName(tyname, []) ->
            if list_has(aliases, tyname) {
              # Restore the m12.6.x shape: bind + synthesised pred call.
              let var_e = mk_expr(EVar(name), pat.line, pat.col)
              let pred_fn = mk_expr(EVar(synth_refine_pred_fn_name(tyname)),
                                     pat.line, pat.col)
              let call = mk_expr(ECall(pred_fn, [var_e]), pat.line, pat.col)
              let new_guard = match guard1 {
                None -> Some(call)
                Some(g) -> Some(mk_expr(EBinop("and", call, g), call.line, call.col))
              }
              Arm(mk_pat(PBind(name), pat.line, pat.col), new_guard, body1)
            } else {
              Arm(pat, guard1, body1)
            }
          _ -> Arm(pat, guard1, body1)
        }
        _ -> Arm(pat, guard1, body1)
      }
    }
  }
}

# m12.6.x #5(a) result: extracted refinement-pure fn names + the
# decls list with every DAttribPure unwrapped to its inner DFn so
# downstream passes see ordinary fns.
#[doc("Result of pure-name extraction: the user-declared pure fn names plus the decls they were taken from.")]
pub type PureExtract = { names: [String], decls: [Decl] }

#[doc("m12.6 contracts: extract user-declared `#[pure]` fn names so contract-predicate validation can check purity.")]
pub fn extract_pure_names_decls(decls: [Decl]) : PureExtract =
  extract_pure_names_loop(decls, [], [])

fn extract_pure_names_loop(decls: [Decl], names_acc: [String],
                            decls_acc: [Decl]) : PureExtract {
  match decls {
    [] -> PureExtract { names: list_reverse(names_acc),
                        decls: list_reverse(decls_acc) }
    [d, ...rest] -> match d {
      DAttribPure(inner, _, _) -> match inner {
        DFn(_, n, _, _, _, _, _, _, _, _) ->
          extract_pure_names_loop(rest, [n, ...names_acc], [inner, ...decls_acc])
        _ -> extract_pure_names_loop(rest, names_acc, [inner, ...decls_acc])
      }
      _ -> extract_pure_names_loop(rest, names_acc, [d, ...decls_acc])
    }
  }
}

# m12.6.x #5(a): post-parse validation of contract predicates.
# Walks every DFn body looking for SAsserts whose msg span tags
# them as contract-derived (`"requires violated at ..."` or
# `"ensures violated at ..."`) and runs find_impure_call on each
# cond using `closed_pure_names ++ user_pure_names`. Returns the
# error count; the driver folds it into the program's exit code.
#[doc("m12.6 contracts: reject `requires`/`ensures` predicates that call non-pure functions; returns the error count.")]
pub fn validate_contract_predicates_decls(decls: [Decl], user_pure: [String],
                                       file: String) : Int / Console {

  let combined = list_append(refinement_pure_names(), user_pure)
  validate_contract_decls_loop(decls, combined, file, 0)
}

fn validate_contract_decls_loop(decls: [Decl], pure_names: [String],
                                 file: String, errs: Int) : Int / Console {

  match decls {
    [] -> errs
    [d, ...rest] -> match d {
      DFn(_, _, _, _, _, _, body, _, _, _) -> {
        let de = validate_contract_expr(body, pure_names, file)
        validate_contract_decls_loop(rest, pure_names, file, errs + de)
      }
      _ -> validate_contract_decls_loop(rest, pure_names, file, errs)
    }
  }
}

fn validate_contract_expr(e: Expr, pure_names: [String], file: String) : Int / Console {

  match e.kind {
    EBlock(stmts, opt_tail) -> {
      let s_errs = validate_contract_stmts(stmts, pure_names, file, 0)
      let t_errs = match opt_tail {
        Some(t) -> validate_contract_expr(t, pure_names, file)
        None -> 0
      }
      s_errs + t_errs
    }
    EIf(c, t_, eo) -> {
      let c_e = validate_contract_expr(c, pure_names, file)
      let t_e = validate_contract_expr(t_, pure_names, file)
      let e_e = match eo {
        Some(eb) -> validate_contract_expr(eb, pure_names, file)
        None -> 0
      }
      c_e + t_e + e_e
    }
    EMatch(scr, arms) -> {
      let scr_e = validate_contract_expr(scr, pure_names, file)
      validate_contract_arms(arms, pure_names, file, scr_e)
    }
    ECall(f, args_) -> {
      let fe = validate_contract_expr(f, pure_names, file)
      validate_contract_exprs(args_, pure_names, file, fe)
    }
    ELambda(_, body) -> validate_contract_expr(body, pure_names, file)
    EBinop(_, a, b) -> validate_contract_expr(a, pure_names, file) +
                        validate_contract_expr(b, pure_names, file)
    EUnop(_, x) -> validate_contract_expr(x, pure_names, file)
    EField(b, _) -> validate_contract_expr(b, pure_names, file)
    _ -> 0
  }
}

fn validate_contract_exprs(es: [Expr], pure_names: [String], file: String, acc: Int) : Int / Console {

  match es {
    [] -> acc
    [e, ...rest] -> validate_contract_exprs(rest, pure_names, file,
                                             acc + validate_contract_expr(e, pure_names, file))
  }
}

fn validate_contract_arms(arms: [Arm], pure_names: [String], file: String, acc: Int) : Int / Console {

  match arms {
    [] -> acc
    [a, ...rest] -> match a {
      Arm(_, opt_g, body) -> {
        let g_e = match opt_g {
          Some(g) -> validate_contract_expr(g, pure_names, file)
          None -> 0
        }
        let b_e = validate_contract_expr(body, pure_names, file)
        validate_contract_arms(rest, pure_names, file, acc + g_e + b_e)
      }
    }
  }
}

fn validate_contract_stmts(stmts: [Stmt], pure_names: [String], file: String, acc: Int) : Int / Console {

  match stmts {
    [] -> acc
    [s, ...rest] -> {
      let se = validate_contract_stmt(s, pure_names, file)
      validate_contract_stmts(rest, pure_names, file, acc + se)
    }
  }
}

fn validate_contract_stmt(s: Stmt, pure_names: [String], file: String) : Int / Console {

  match s {
    SAssert(cond, opt_msg) -> {
      let kind_opt = contract_assert_kind(opt_msg)
      let body_e = validate_contract_expr(cond, pure_names, file)
      match kind_opt {
        None -> body_e
        Some(kind) -> match find_impure_call(cond, pure_names) {
          None -> body_e
          Some(name) -> {
            diag_error_from_src(file, "", cond.line, cond.col,
              concat_all([
                "`", kind, "` predicate calls non-pure function `", name,
                "`. Refinement / contract predicates may only call ",
                "the closed pure-prelude set or fns marked ",
                "`[<refinement_pure>]`."
              ]))
            body_e + 1
          }
        }
      }
    }
    SLet(_, _, rhs) -> validate_contract_expr(rhs, pure_names, file)
    SExprStmt(x) -> validate_contract_expr(x, pure_names, file)
    SIndexAssign(b, i, v, _, _) ->
      validate_contract_expr(b, pure_names, file) +
      validate_contract_expr(i, pure_names, file) +
      validate_contract_expr(v, pure_names, file)
    _ -> 0
  }
}

# Detect a contract-derived SAssert by matching the msg span shape
# preds_to_asserts emits. Returns the kind string, or None for
# user-written asserts.
fn contract_assert_kind(opt_msg: Option[Expr]) : Option[String] {
  match opt_msg {
    None -> None
    Some(m) -> match m.kind {
      EStr(span, false) ->
        if dsg_string_starts_with_q(span, "\"requires violated") { Some("requires") }
        else if dsg_string_starts_with_q(span, "\"ensures violated") { Some("ensures") }
        else { None }
      _ -> None
    }
  }
}

#[doc("m7b #5b: pre-resolve desugar of `var name [: T] = init` into a Ref-cell let plus get/set rewrites; the per-program entry point.")]
pub fn desugar_var_decls(ds: [Decl]) : [Decl] = map(ds, desugar_var_decl)

fn desugar_var_decl(d: Decl) : Decl {
  match d {
    DFn(pub_, n, tps, ps, ret, row, body, l, c, mo) ->
      DFn(pub_, n, tps, ps, ret, row, desugar_var_expr(body), l, c, mo)
    DTest(desc, body, l, c) -> DTest(desc, desugar_var_expr(body), l, c)
    DBench(desc, body, l, c) -> DBench(desc, desugar_var_expr(body), l, c)
    DCheck(desc, params, body, l, c) -> DCheck(desc, params, desugar_var_expr(body), l, c)
    _ -> d
  }
}

# Pre-desugar validation: walk every fn / test body looking for bare
# `EVar(name)` references where `name` is currently bound by an
# enclosing `var name = init` (an SVar that has not yet been desugared
# into the State[T] handler). The legitimate uses are
# `name.get()` / `name.set(v)` (capability access) and `name := <expr>`
# (cap write — the parser already lowers it before we get here, so it
# surfaces as `name.set(v)`). Any other bare read leaks the cap binder
# to the emitter as `kai_<name>`, which the linker rejects with an
# unhelpful `undeclared identifier` from `cc`. Reporting at this layer
# turns the post-cc opaque link error into a typed-hole-style hint at
# the use site — a Tier 3 (LLM authorability) requirement.
#
# Scope rules: SLet, lambda params, match arm patterns, fn params,
# nested SVar with the same name, and handler `as` aliases all shadow
# a `var` binder. Bare reads under those scopes are NOT flagged.
#[doc("m7b #5b: reject `var` rebinds that escape their defining scope before the rewrite runs; returns the error count.")]
pub fn validate_var_uses_decls(ds: [Decl], file: String) : Int / Console + File {

  validate_var_decls_loop(ds, file, 0)
}

fn validate_var_decls_loop(ds: [Decl], file: String, errs: Int) : Int / Console + File {

  match ds {
    [] -> errs
    [d, ...rest] -> {
      let e1 = match d {
        DFn(_, _, _, ps, _, _, body, _, _, _) -> {
          let pnames = dsg_rename_param_names(ps, [])
          validate_var_in_expr(body, caps_minus_names([], pnames), file, errs)
        }
        DTest(_, body, _, _) -> validate_var_in_expr(body, [], file, errs)
        DBench(_, body, _, _) -> validate_var_in_expr(body, [], file, errs)
        DCheck(_, ps, body, _, _) -> {
          let pnames = dsg_rename_param_names(ps, [])
          validate_var_in_expr(body, caps_minus_names([], pnames), file, errs)
        }
        _ -> errs
      }
      validate_var_decls_loop(rest, file, e1)
    }
  }
}

fn caps_remove_name(caps: [String], n: String) : [String] {
  match caps {
    [] -> []
    [h, ...rest] ->
      if h == n { caps_remove_name(rest, n) }
      else      { [h, ...caps_remove_name(rest, n)] }
  }
}

fn caps_minus_names(caps: [String], names: [String]) : [String] {
  match names {
    [] -> caps
    [n, ...rest] -> caps_minus_names(caps_remove_name(caps, n), rest)
  }
}

fn validate_var_in_expr(e: Expr, caps: [String], file: String, errs: Int) : Int / Console + File {

  validate_var_in_kind(e.kind, caps, e.line, e.col, file, errs)
}

fn validate_var_in_opt(o: Option[Expr], caps: [String], file: String, errs: Int) : Int / Console + File {

  match o {
    Some(e) -> validate_var_in_expr(e, caps, file, errs)
    None    -> errs
  }
}

fn validate_var_in_exprs(es: [Expr], caps: [String], file: String, errs: Int) : Int / Console + File {

  match es {
    [] -> errs
    [h, ...rest] -> {
      let e1 = validate_var_in_expr(h, caps, file, errs)
      validate_var_in_exprs(rest, caps, file, e1)
    }
  }
}

fn validate_var_in_list_elem(le: ListElem, caps: [String], file: String, errs: Int) : Int / Console + File {

  match le {
    ElPlain(e) -> validate_var_in_expr(e, caps, file, errs)
    ElSpread(e) -> validate_var_in_expr(e, caps, file, errs)
  }
}

fn validate_var_in_list_elems(les: [ListElem], caps: [String], file: String, errs: Int) : Int / Console + File {

  match les {
    [] -> errs
    [h, ...rest] -> {
      let e1 = validate_var_in_list_elem(h, caps, file, errs)
      validate_var_in_list_elems(rest, caps, file, e1)
    }
  }
}

fn validate_var_in_field(f: FieldInit, caps: [String], file: String, errs: Int) : Int / Console + File {

  match f {
    FI(_, value) -> validate_var_in_expr(value, caps, file, errs)
  }
}

fn validate_var_in_fields(fs: [FieldInit], caps: [String], file: String, errs: Int) : Int / Console + File {

  match fs {
    [] -> errs
    [h, ...rest] -> {
      let e1 = validate_var_in_field(h, caps, file, errs)
      validate_var_in_fields(rest, caps, file, e1)
    }
  }
}

fn validate_var_in_arm(a: Arm, caps: [String], file: String, errs: Int) : Int / Console + File {

  match a {
    Arm(p, g, b) -> {
      let names = dsg_rename_pat_names(p, [])
      let caps1 = caps_minus_names(caps, names)
      let e1 = validate_var_in_opt(g, caps1, file, errs)
      validate_var_in_expr(b, caps1, file, e1)
    }
  }
}

fn validate_var_in_arms(arms: [Arm], caps: [String], file: String, errs: Int) : Int / Console + File {

  match arms {
    [] -> errs
    [h, ...rest] -> {
      let e1 = validate_var_in_arm(h, caps, file, errs)
      validate_var_in_arms(rest, caps, file, e1)
    }
  }
}

fn validate_var_in_clause(c: HClause, caps: [String], file: String, errs: Int) : Int / Console + File {

  match c {
    HC(_, ps, b, _, _) -> {
      let pnames = dsg_rename_param_names(ps, [])
      validate_var_in_expr(b, caps_minus_names(caps, pnames), file, errs)
    }
  }
}

fn validate_var_in_clauses(cs: [HClause], caps: [String], file: String, errs: Int) : Int / Console + File {

  match cs {
    [] -> errs
    [h, ...rest] -> {
      let e1 = validate_var_in_clause(h, caps, file, errs)
      validate_var_in_clauses(rest, caps, file, e1)
    }
  }
}

fn validate_var_in_return(r: HReturn, caps: [String], file: String, errs: Int) : Int / Console + File {

  match r {
    HR(p, b, _, _) -> validate_var_in_expr(b, caps_remove_name(caps, p), file, errs)
  }
}

fn validate_var_in_kind(k: ExprKind, caps: [String], line: Int, col: Int, file: String, errs: Int) : Int / Console + File {

  match k {
    EVar(n) ->
      if list_has(caps, n) {
        diag_error(file, line, col, concat_all([
          "`", n, "` is a State capability bound by `var ", n, " = ...` — bare reads are not allowed"
        ]))
        diag_help(concat_all([
          "use `@", n, "` to read the cell, `", n, " := <expr>` to write it; cap binders are not ordinary locals"
        ]))
        errs + 1
      } else { errs }
    ECall(callee, args_) -> match callee.kind {
      EField(base, fname) -> match base.kind {
        EVar(n) ->
          if list_has(caps, n) and (fname == "get" or fname == "set") {
            # Legitimate cap usage. Skip the base; the get/set is the
            # whole point of the binder. Validate the args under the
            # same scope so nested misuses still surface.
            validate_var_in_exprs(args_, caps, file, errs)
          } else {
            let e1 = validate_var_in_expr(callee, caps, file, errs)
            validate_var_in_exprs(args_, caps, file, e1)
          }
        _ -> {
          let e1 = validate_var_in_expr(callee, caps, file, errs)
          validate_var_in_exprs(args_, caps, file, e1)
        }
      }
      _ -> {
        let e1 = validate_var_in_expr(callee, caps, file, errs)
        validate_var_in_exprs(args_, caps, file, e1)
      }
    }
    EBlock(stmts, tail) -> validate_var_in_block(stmts, tail, caps, file, errs)
    ELambda(ps, body) -> {
      let pnames = dsg_rename_param_names(ps, [])
      validate_var_in_expr(body, caps_minus_names(caps, pnames), file, errs)
    }
    EMatch(scr, arms) -> {
      let e1 = validate_var_in_expr(scr, caps, file, errs)
      validate_var_in_arms(arms, caps, file, e1)
    }
    EHandle(body, _, _, init_opt, alias_opt, clauses, ret_opt) -> {
      let e1 = validate_var_in_opt(init_opt, caps, file, errs)
      let body_caps = match alias_opt {
        Some(a) -> caps_remove_name(caps, a)
        None    -> caps
      }
      let e2 = validate_var_in_expr(body, body_caps, file, e1)
      let e3 = validate_var_in_clauses(clauses, caps, file, e2)
      match ret_opt {
        Some(r) -> validate_var_in_return(r, caps, file, e3)
        None    -> e3
      }
    }
    EField(base, _) -> validate_var_in_expr(base, caps, file, errs)
    EIndex(b, i) -> {
      let e1 = validate_var_in_expr(b, caps, file, errs)
      validate_var_in_expr(i, caps, file, e1)
    }
    EBinop(_, a, b) -> {
      let e1 = validate_var_in_expr(a, caps, file, errs)
      validate_var_in_expr(b, caps, file, e1)
    }
    EUnop(_, x) -> validate_var_in_expr(x, caps, file, errs)
    EIf(c, t_, eo) -> {
      let e1 = validate_var_in_expr(c, caps, file, errs)
      let e2 = validate_var_in_expr(t_, caps, file, e1)
      validate_var_in_opt(eo, caps, file, e2)
    }
    EList(elems) -> validate_var_in_list_elems(elems, caps, file, errs)
    EPipe(a, b) -> {
      let e1 = validate_var_in_expr(a, caps, file, errs)
      validate_var_in_expr(b, caps, file, e1)
    }
    EMapPipe(a, b) -> {
      let e1 = validate_var_in_expr(a, caps, file, errs)
      validate_var_in_expr(b, caps, file, e1)
    }
    EFlatMapPipe(a, b) -> {
      let e1 = validate_var_in_expr(a, caps, file, errs)
      validate_var_in_expr(b, caps, file, e1)
    }
    EFilterPipe(a, b) -> {
      let e1 = validate_var_in_expr(a, caps, file, errs)
      validate_var_in_expr(b, caps, file, e1)
    }
    ERange(a, b, opt_step) -> {
      let e1 = validate_var_in_expr(a, caps, file, errs)
      let e2 = validate_var_in_expr(b, caps, file, e1)
      validate_var_in_opt(opt_step, caps, file, e2)
    }
    ERecordLit(_, fields) -> validate_var_in_fields(fields, caps, file, errs)
    EBang(inner) -> validate_var_in_expr(inner, caps, file, errs)
    ELitUnit(inner, _) -> validate_var_in_expr(inner, caps, file, errs)
    _ -> errs
  }
}

fn validate_var_in_block(stmts: [Stmt], tail: Option[Expr], caps: [String], file: String, errs: Int) : Int / Console + File {

  match stmts {
    [] -> validate_var_in_opt(tail, caps, file, errs)
    [s, ...rest] -> match s {
      SLet(p, _, rhs) -> {
        let e1 = validate_var_in_expr(rhs, caps, file, errs)
        let names = dsg_rename_pat_names(p, [])
        validate_var_in_block(rest, tail, caps_minus_names(caps, names), file, e1)
      }
      SVar(n, _, rhs, _, _) -> {
        # The init is evaluated under the *outer* caps (a `var n = n`
        # is a self-shadow only after the binder appears, F# / Rust
        # convention).
        let e1 = validate_var_in_expr(rhs, caps, file, errs)
        # From this point the new var binder shadows any same-named
        # outer cap and adds itself to the live set.
        let caps1 = [n, ...caps_remove_name(caps, n)]
        validate_var_in_block(rest, tail, caps1, file, e1)
      }
      SExprStmt(x) -> {
        let e1 = validate_var_in_expr(x, caps, file, errs)
        validate_var_in_block(rest, tail, caps, file, e1)
      }
      SIndexAssign(b, i, v, _, _) -> {
        let e1 = validate_var_in_expr(b, caps, file, errs)
        let e2 = validate_var_in_expr(i, caps, file, e1)
        let e3 = validate_var_in_expr(v, caps, file, e2)
        validate_var_in_block(rest, tail, caps, file, e3)
      }
      SAssert(c, m) -> {
        let e1 = validate_var_in_expr(c, caps, file, errs)
        let e2 = validate_var_in_opt(m, caps, file, e1)
        validate_var_in_block(rest, tail, caps, file, e2)
      }
      SUse(_, _, _) -> validate_var_in_block(rest, tail, caps, file, errs)
    }
  }
}

fn desugar_var_expr(e: Expr) : Expr =
  Expr { kind: desugar_var_kind(e.kind, e.line, e.col),
         line: e.line, col: e.col, ty: e.ty, mode: e.mode }

fn desugar_var_opt(opt: Option[Expr]) : Option[Expr] {
  match opt {
    Some(e) -> Some(desugar_var_expr(e))
    None    -> None
  }
}

# Recurse into a non-block stmt's expressions. Used for stmts that
# appear *before* the head SVar of a block — they cannot reference the
# cell the var introduces, but their inner blocks (lambdas, ifs, match
# arms, etc.) may declare their own `var`s.
fn desugar_var_stmt(s: Stmt) : Stmt {
  match s {
    SLet(pat, ann, rhs) -> SLet(pat, ann, desugar_var_expr(rhs))
    SAssert(c, m) -> SAssert(desugar_var_expr(c), desugar_var_opt(m))
    SExprStmt(x) -> SExprStmt(desugar_var_expr(x))
    SIndexAssign(b, i, v, l, c) ->
      SIndexAssign(desugar_var_expr(b), desugar_var_expr(i),
                   desugar_var_expr(v), l, c)
    # SVar at this site means it sits at non-head position relative to
    # the wrapping pass. desugar_var_block consumes head-position SVars;
    # any residual one here is rewritten to a `let` so the resolver does
    # not see a stray SVar (defensive — should not occur in well-formed
    # input).
    SVar(n, _, rhs, _, _) -> SLet(mk_pat(PBind(n), 0, 0), None,
                                   desugar_var_expr(rhs))
    # m7e §25: SUse pass through.
    SUse(n, l, c) -> SUse(n, l, c)
  }
}

# Build the canonical `with State[?T](init) as name { ... }` clauses
# Doc B §`State[T]` *Syntax note* prescribes for a `var` lowering.
#
# `state` in the clause body is an alias of the C-level `self->state`
# pointer. Returning it bare via `resume(state)` makes the caller the
# *consumer* of `self->state` — the next op call will then read
# freed memory (manifests as `type mismatch in +` once the slot byte
# pattern stops looking like a KAI_INT). To keep the slot alive
# across iterations we dup the slot value on every read; the caller
# consumes the dup, `self->state` keeps its original refcount.
# The set clause's `resume(unit, v)` writes `v` into `self->state`
# directly (handled by `emit_expr`'s `resume(a, ns)` lowering) so no
# dup is needed there — the new value is owned by `self->state`
# after the assign.
fn var_canonical_clauses(line: Int, col: Int) : [HClause] {
  let p_resume = Param { pname: "resume", ptype: None, pline: line, pcol: col }
  let p_v      = Param { pname: "v",      ptype: None, pline: line, pcol: col }
  let resume_e = mk_expr(EVar("resume"), line, col)
  let state_e  = mk_expr(EVar("state"),  line, col)
  let dup_e    = mk_expr(EVar("__perceus_dup"), line, col)
  let state_dup = mk_expr(ECall(dup_e, [state_e]), line, col)
  let unit_e   = mk_expr(EUnit,           line, col)
  let v_e      = mk_expr(EVar("v"),       line, col)
  let get_body = mk_expr(ECall(resume_e, [state_dup]), line, col)
  let set_body = mk_expr(ECall(resume_e, [unit_e, v_e]), line, col)
  [
    HC("get", [p_resume], get_body, line, col),
    HC("set", [p_v, p_resume], set_body, line, col)
  ]
}

fn var_canonical_return(line: Int, col: Int) : HReturn {
  HR("x", mk_expr(EVar("x"), line, col), line, col)
}

# m7b #16 — variable specialisation. Doc B §`State[T]` *Performance*
# promised that a `var x = init; @x; x := v` block compiles to a
# stack slot, not a chain of handler invocations. The specialised
# form replaces the canonical `with State[T] as x` handler with:
#   let x_slot = array_make(1, init)
#   { rest_with_n.get() → array_get(x_slot, 0)
#         and n.set(v)   → { let _ = array_set(x_slot, 0, v); () } }
# Trigger conditions per Doc C §*Variable specialisation*:
#   1. canonical handler shape (always true — emitted by us);
#   2. no multi-shot resume (always true — canonical clauses);
#   3. `name` only appears as `name.get()` / `name.set(v)` callee
#      (no escape into a closure or argument);
#   4. `init` is a "normal expression" — no op calls.
# Conditions 1 and 2 hold by construction; this section adds the
# conservative checks for 3 and 4 plus the rewrite.

# Trigger 4: init is a normal expression. Conservative subset:
# literals, EVar (refers to a local or global value), prelude
# arithmetic / unary, calls whose callee is a non-effect EVar.
# Anything else (op call, lambda, handle, match, if, block, list,
# record, etc.) is rejected so the canonical handler runs instead.
fn init_is_safe(e: Expr) : Bool {
  match e.kind {
    EInt(_) -> true
    EReal(_) -> true
    EBool(_) -> true
    EChar(_) -> true
    EStr(_, _) -> true
    EUnit -> true
    EVar(_) -> true
    EBinop(_, a, b) -> init_is_safe(a) and init_is_safe(b)
    EUnop(_, x) -> init_is_safe(x)
    ECall(callee, args_) -> {
      let callee_ok = match callee.kind {
        EVar(_) -> true
        _ -> false
      }
      callee_ok and init_args_safe(args_)
    }
    _ -> false
  }
}

fn init_args_safe(es: [Expr]) : Bool {
  match es {
    [] -> true
    [h, ...rest] -> if init_is_safe(h) { init_args_safe(rest) } else { false }
  }
}

# Trigger 3: name appears in body ONLY as the immediate base of a
# `name.get` or `name.set` field on the callee of a call. Any other
# occurrence — closure capture, function-argument position, plain
# value reference — is treated as escape and disables specialisation.
fn body_escapes(name: String, e: Expr) : Bool {
  match e.kind {
    EInt(_) -> false
    EReal(_) -> false
    EBool(_) -> false
    EChar(_) -> false
    EStr(_, _) -> false
    EUnit -> false
    EUnder -> false
    EPlaceholder -> false
    EHole(_) -> false
    ETodo(_) -> false
    EVar(n) -> n == name
    ECall(callee, args_) -> {
      let callee_is_get_set = match callee.kind {
        EField(base, fname) -> match base.kind {
          EVar(n) ->
            if n == name and (fname == "get" or fname == "set") { true }
            else { false }
          _ -> false
        }
        _ -> false
      }
      let callee_escape =
        if callee_is_get_set { false } else { body_escapes(name, callee) }
      callee_escape or args_escape(name, args_)
    }
    EField(base, _) -> body_escapes(name, base)
    EIndex(a, b) -> body_escapes(name, a) or body_escapes(name, b)
    EBinop(_, a, b) -> body_escapes(name, a) or body_escapes(name, b)
    EUnop(_, x) -> body_escapes(name, x)
    EIf(c, t_, eo) -> body_escapes(name, c) or body_escapes(name, t_) or opt_escapes(name, eo)
    EBlock(stmts, tail) -> stmts_escape(name, stmts) or opt_escapes(name, tail)
    EPipe(a, b) -> body_escapes(name, a) or body_escapes(name, b)
    EMapPipe(a, b) -> body_escapes(name, a) or body_escapes(name, b)
    EFlatMapPipe(a, b) -> body_escapes(name, a) or body_escapes(name, b)
    EFilterPipe(a, b) -> body_escapes(name, a) or body_escapes(name, b)
    EMatch(scr, arms) -> body_escapes(name, scr) or arms_escape(name, arms)
    ELambda(_, _) -> contains_var(name, e)
    EList(elems) -> elems_escape(name, elems)
    ERange(a, b, opt_step) -> body_escapes(name, a) or body_escapes(name, b) or opt_escapes(name, opt_step)
    ERecordLit(_, fields) -> fields_escape(name, fields)
    EHandle(body, _, _, init_opt, _, clauses, ret_opt) -> body_escapes(name, body) or opt_escapes(name, init_opt) or clauses_escape(name, clauses) or ret_opt_escapes(name, ret_opt)
    EBang(inner) -> body_escapes(name, inner)
    ELitUnit(inner, _) -> body_escapes(name, inner)
    # m7e §11: `variants[T]()` has no value-level sub-expressions —
    # nothing can mention `name` inside it.
    EVariantsOf(_, _) -> false
    # m6.2 Phase 2.1: qualified module call mentions a module name and
    # a function name as plain strings, never the local `name`.
    EModCall(_, _) -> false
    EIntrinsic(_, args_) -> args_escape(name, args_)
  }
}

fn args_escape(name: String, es: [Expr]) : Bool {
  match es {
    [] -> false
    [h, ...rest] -> if body_escapes(name, h) { true } else { args_escape(name, rest) }
  }
}

fn opt_escapes(name: String, opt: Option[Expr]) : Bool {
  match opt {
    None -> false
    Some(e) -> body_escapes(name, e)
  }
}

fn stmts_escape(name: String, ss: [Stmt]) : Bool {
  match ss {
    [] -> false
    [s, ...rest] -> if stmt_escapes(name, s) { true } else { stmts_escape(name, rest) }
  }
}

fn stmt_escapes(name: String, s: Stmt) : Bool {
  match s {
    SLet(_, _, rhs) -> body_escapes(name, rhs)
    SAssert(c, msg) -> body_escapes(name, c) or opt_escapes(name, msg)
    SExprStmt(x) -> body_escapes(name, x)
    SIndexAssign(b, i, v, _, _) ->
      body_escapes(name, b) or body_escapes(name, i) or body_escapes(name, v)
    SVar(_, _, rhs, _, _) -> body_escapes(name, rhs)
    # m7e §25: SUse has no expr — name cannot escape through it.
    SUse(_, _, _) -> false
  }
}

fn arms_escape(name: String, arms: [Arm]) : Bool {
  match arms {
    [] -> false
    [a, ...rest] -> if arm_escapes(name, a) { true } else { arms_escape(name, rest) }
  }
}

fn arm_escapes(name: String, a: Arm) : Bool {
  match a {
    Arm(_, opt_g, b) -> opt_escapes(name, opt_g) or body_escapes(name, b)
  }
}

fn elems_escape(name: String, es: [ListElem]) : Bool {
  match es {
    [] -> false
    [el, ...rest] -> match el {
      ElPlain(x)  -> if body_escapes(name, x) { true } else { elems_escape(name, rest) }
      ElSpread(x) -> if body_escapes(name, x) { true } else { elems_escape(name, rest) }
    }
  }
}

fn fields_escape(name: String, fs: [FieldInit]) : Bool {
  match fs {
    [] -> false
    [f, ...rest] -> match f {
      FI(_, v) -> if body_escapes(name, v) { true } else { fields_escape(name, rest) }
    }
  }
}

fn clauses_escape(name: String, cs: [HClause]) : Bool {
  match cs {
    [] -> false
    [c, ...rest] -> match c {
      HC(_, _, b, _, _) ->
        if body_escapes(name, b) { true } else { clauses_escape(name, rest) }
    }
  }
}

fn ret_opt_escapes(name: String, opt: Option[HReturn]) : Bool {
  match opt {
    None -> false
    Some(r) -> match r { HR(_, b, _, _) -> body_escapes(name, b) }
  }
}

# Conservative containment check used by the lambda branch of
# `body_escapes`: a closure that mentions `name` at all is treated
# as escape (we have no way to prove the closure does not outlive
# the handle). Returns true if `name` appears anywhere in `e`.
fn contains_var(name: String, e: Expr) : Bool {
  match e.kind {
    EVar(n) -> n == name
    ECall(c, args_) -> contains_var(name, c) or any_contains(name, args_)
    EField(b, _) -> contains_var(name, b)
    EIndex(a, b) -> contains_var(name, a) or contains_var(name, b)
    EBinop(_, a, b) -> contains_var(name, a) or contains_var(name, b)
    EUnop(_, x) -> contains_var(name, x)
    EIf(c, t_, eo) -> contains_var(name, c) or contains_var(name, t_) or opt_contains(name, eo)
    EBlock(stmts, tail) -> stmts_contain(name, stmts) or opt_contains(name, tail)
    EMatch(scr, arms) -> contains_var(name, scr) or arms_contain(name, arms)
    ELambda(_, b) -> contains_var(name, b)
    EList(elems) -> elems_contain(name, elems)
    ERange(a, b, opt_step) ->
      contains_var(name, a) or contains_var(name, b) or opt_contains(name, opt_step)
    ERecordLit(_, fields) -> fields_contain(name, fields)
    EPipe(a, b) -> contains_var(name, a) or contains_var(name, b)
    EMapPipe(a, b) -> contains_var(name, a) or contains_var(name, b)
    EFlatMapPipe(a, b) -> contains_var(name, a) or contains_var(name, b)
    EFilterPipe(a, b) -> contains_var(name, a) or contains_var(name, b)
    EHandle(body, _, _, init_opt, _, clauses, ret_opt) -> contains_var(name, body) or opt_contains(name, init_opt) or clauses_contain(name, clauses) or ret_opt_contains(name, ret_opt)
    EBang(inner) -> contains_var(name, inner)
    _ -> false
  }
}

fn any_contains(name: String, es: [Expr]) : Bool {
  match es {
    [] -> false
    [h, ...rest] -> if contains_var(name, h) { true } else { any_contains(name, rest) }
  }
}

fn opt_contains(name: String, opt: Option[Expr]) : Bool {
  match opt { None -> false  Some(e) -> contains_var(name, e) }
}

fn stmts_contain(name: String, ss: [Stmt]) : Bool {
  match ss {
    [] -> false
    [s, ...rest] -> if stmt_contains(name, s) { true } else { stmts_contain(name, rest) }
  }
}

fn stmt_contains(name: String, s: Stmt) : Bool {
  match s {
    SLet(_, _, rhs) -> contains_var(name, rhs)
    SAssert(c, msg) -> contains_var(name, c) or opt_contains(name, msg)
    SExprStmt(x) -> contains_var(name, x)
    SIndexAssign(b, i, v, _, _) ->
      contains_var(name, b) or contains_var(name, i) or contains_var(name, v)
    SVar(_, _, rhs, _, _) -> contains_var(name, rhs)
    # m7e §25: SUse has no expression — never contains a value-level name.
    SUse(_, _, _) -> false
  }
}

fn arms_contain(name: String, arms: [Arm]) : Bool {
  match arms {
    [] -> false
    [a, ...rest] -> match a {
      Arm(_, g, b) ->
        if opt_contains(name, g) or contains_var(name, b) { true }
        else { arms_contain(name, rest) }
    }
  }
}

fn elems_contain(name: String, es: [ListElem]) : Bool {
  match es {
    [] -> false
    [el, ...rest] -> match el {
      ElPlain(x)  -> if contains_var(name, x) { true } else { elems_contain(name, rest) }
      ElSpread(x) -> if contains_var(name, x) { true } else { elems_contain(name, rest) }
    }
  }
}

fn fields_contain(name: String, fs: [FieldInit]) : Bool {
  match fs {
    [] -> false
    [f, ...rest] -> match f {
      FI(_, v) -> if contains_var(name, v) { true } else { fields_contain(name, rest) }
    }
  }
}

fn clauses_contain(name: String, cs: [HClause]) : Bool {
  match cs {
    [] -> false
    [c, ...rest] -> match c {
      HC(_, _, b, _, _) ->
        if contains_var(name, b) { true } else { clauses_contain(name, rest) }
    }
  }
}

fn ret_opt_contains(name: String, opt: Option[HReturn]) : Bool {
  match opt { None -> false  Some(r) -> match r { HR(_, b, _, _) -> contains_var(name, b) } }
}

# Specialise a body: rewrite every `name.get()` to
# `array_get(slot_var, 0)` and every `name.set(v)` to a unit-typed
# block `{ let _ = array_set(slot_var, 0, v); () }`. The slot_var
# name is `<name>__slot`. Other expressions pass through.
fn specialise_body(name: String, slot_name: String, e: Expr) : Expr {
  Expr { kind: specialise_kind(name, slot_name, e.kind, e.line, e.col),
         line: e.line, col: e.col, ty: e.ty, mode: e.mode }
}

fn specialise_kind(name: String, slot_name: String, k: ExprKind, line: Int, col: Int) : ExprKind {
  match k {
    # The only kind that needs special handling: a call site that
    # matches `name.get()` or `name.set(v)` gets lowered to
    # `array_get(slot, 0)` / `array_set(slot, 0, v)`. All other
    # kinds (and non-matching ECalls) recurse purely structurally.
    ECall(callee, args_) -> {
      let getset = match callee.kind {
        EField(base, fname) -> match base.kind {
          EVar(n) ->
            if n == name and fname == "get" { Some("get") }
            else if n == name and fname == "set" { Some("set") }
            else { None }
          _ -> None
        }
        _ -> None
      }
      match getset {
        Some(op) -> {
          let slot_e = mk_expr(EVar(slot_name), line, col)
          let zero = mk_expr(EInt(0), line, col)
          if op == "get" {
            ECall(mk_expr(EVar("array_get"), line, col), [slot_e, zero])
          } else {
            # `name.set(v)`: emit `{ let _ = array_set(slot, 0, v); () }`
            # so the result type stays Unit (matches the canonical clause).
            let v = match args_ {
              [a, ..._ignore] -> specialise_body(name, slot_name, a)
              [] -> mk_expr(EUnit, line, col)
            }
            let set_call = mk_expr(
              ECall(mk_expr(EVar("array_set"), line, col), [slot_e, zero, v]),
              line, col)
            let let_pat = mk_pat(PWild, line, col)
            let let_stmt = SLet(let_pat, None, set_call)
            EBlock([let_stmt], Some(mk_expr(EUnit, line, col)))
          }
        }
        None ->
          ECall(specialise_body(name, slot_name, callee),
                map(args_, (a) => specialise_body(name, slot_name, a)))
      }
    }
    _ -> dsg_map_expr_kind(k, (sub) => specialise_body(name, slot_name, sub))
  }
}

# Walk a block's stmts looking for the first SVar. Returns the rewritten
# (stmts, tail) pair: every stmt before the first SVar is structurally
# desugared (so lambdas / inner blocks inside their expressions still
# get their own `var`s rewritten), and from the SVar onward the rest
# of the block becomes the body of a fresh `with State[T](init) as name`
# handler. If no SVar is present, recursion proceeds structurally.
fn desugar_var_block(stmts: [Stmt], tail: Option[Expr]) : ExprKind {
  match stmts {
    [] -> EBlock([], desugar_var_opt(tail))
    [s, ...rest] -> match s {
      SVar(name, ty, init, line, col) -> {
        let init_d = desugar_var_expr(init)
        let inner_kind = desugar_var_block(rest, tail)
        let inner_expr = mk_expr(inner_kind, line, col)
        # m7b #16 — try variable specialisation first. When all
        # trigger conditions hold, lower the var to a 1-element
        # array slot (prelude `array_*`, no `Mutable` row) instead
        # of the canonical State[T] handler. The conditions:
        #   * init is a "normal expression" (init_is_safe)
        #   * `name` only appears as `name.get`/`name.set` callee
        #     in the body (body_escapes is false)
        # When either fails, fall back to the canonical handler so
        # captures, escapes, and complex inits still work.
        if init_is_safe(init_d) and not body_escapes(name, inner_expr) {
          let slot_name = string_concat(name, "__slot")
          let slot_init = mk_expr(
            ECall(mk_expr(EVar("array_make"), line, col),
                  [mk_expr(EInt(1), line, col), init_d]),
            line, col)
          let let_pat = mk_pat(PBind(slot_name), line, col)
          let let_stmt = SLet(let_pat, None, slot_init)
          let body_spec = specialise_body(name, slot_name, inner_expr)
          EBlock([let_stmt], Some(body_spec))
        } else {
          let tyargs = match ty { Some(t) -> [t] None -> [] }
          let clauses = var_canonical_clauses(line, col)
          let ret = var_canonical_return(line, col)
          let handle_kind = EHandle(inner_expr, "State", tyargs,
                                     Some(init_d), Some(name),
                                     clauses, Some(ret))
          EBlock([], Some(mk_expr(handle_kind, line, col)))
        }
      }
      _ -> {
        let s_d = desugar_var_stmt(s)
        let inner_kind = desugar_var_block(rest, tail)
        match inner_kind {
          EBlock(rest_stmts, rest_tail) ->
            EBlock([s_d, ...rest_stmts], rest_tail)
          _ -> EBlock([s_d], Some(mk_expr(inner_kind, 0, 0)))
        }
      }
    }
  }
}

fn desugar_var_kind(k: ExprKind, line: Int, col: Int) : ExprKind {
  match k {
    # EBlock is the only kind that needs special handling: a head
    # SVar inside the block lifts to a fresh `with State[T](init)`
    # handler, which `desugar_var_block` builds. Stmts before the
    # head SVar still recurse into their inner expressions.
    EBlock(stmts, tail) -> desugar_var_block(stmts, tail)
    _ -> dsg_map_expr_kind(k, desugar_var_expr)
  }
}

# ====================================================================
# m7e §25 — `use Effect` desugar
# ====================================================================
#
# `use Effect` opens an effect's ops for bare-name resolution. After
# this pass every `EVar(op_name)` that resolves unambiguously to an
# op of an effect open in scope is rewritten into the qualified
# form `EField(EVar(eff_name), op_name)`. Downstream the existing
# `desugar_op_calls` pass turns it into `EVar("eff_name.op_name")`.
#
# Scopes (innermost wins, search outward):
#   * Block-level: an `SUse(name, _, _)` mid-block opens the effect
#     for the rest of that block (subsequent stmts + tail).
#   * Function-level: a use at the top of a fn body opens it for
#     the whole body.
#   * File-level: a `DUse(name, _, _)` top-level decl opens the
#     effect across every fn body in the file.
#
# Collisions: if the same op name is exported by two different
# effects in scope, the rewrite emits a typer-style ambiguity error
# and leaves the bare name in place so the downstream resolver
# still complains about an undefined name (deterministic behaviour).
#
# DUse / SUse are stripped from the output AST. Pattern bindings and
# locally-bound names shadow opens as expected — the rewrite walks
# the existing dsg_pat_bindings / param-name machinery and will not
# rewrite a name that is locally bound.

# Per-effect op table built once per program.
type EffOps = EffOps(String, [String])

fn use_collect_eff_ops(decls: [Decl]) : [EffOps] {
  match decls {
    [] -> []
    [d, ...rest] -> match d {
      DEffect(_, name, _, ops, _, _, _) ->
        [EffOps(name, use_op_names(ops, [])), ...use_collect_eff_ops(rest)]
      _ -> use_collect_eff_ops(rest)
    }
  }
}

fn use_op_names(ops: [EffectOp], acc: [String]) : [String] {
  match ops {
    [] -> list_reverse(acc)
    [op, ...rest] -> match op {
      EOp(n, _, _, _, _, _) -> use_op_names(rest, [n, ...acc])
    }
  }
}

# Look up the effect names that own a given op name within the
# active opens. Returns the list of effect names; callers handle
# zero-/one-/many-result cases.
fn use_owners_of(table: [EffOps], opens: [String], op_name: String) : [String] =
  use_owners_of_loop(table, opens, op_name, [])

fn use_owners_of_loop(table: [EffOps], opens: [String], op_name: String,
                        acc: [String]) : [String] {
  match opens {
    [] -> list_reverse(acc)
    [eff, ...rest] -> {
      let owns = match use_eff_lookup(table, eff) {
        Some(ops) -> list_has(ops, op_name)
        None      -> false
      }
      if owns { use_owners_of_loop(table, rest, op_name, [eff, ...acc]) }
      else    { use_owners_of_loop(table, rest, op_name, acc) }
    }
  }
}

fn use_eff_lookup(table: [EffOps], target: String) : Option[[String]] {
  match table {
    [] -> None
    [h, ...rest] -> match h {
      EffOps(n, ops) -> if n == target { Some(ops) } else { use_eff_lookup(rest, target) }
    }
  }
}

# m7e §25: collect file-level DUse names; everything else passes
# through. Returns (file_opens, decls_without_DUse).
type UseSplit = { file_opens: [String], decls: [Decl] }

fn use_split_decls(decls: [Decl], opens: [String], acc: [Decl]) : UseSplit {
  match decls {
    [] -> UseSplit { file_opens: list_reverse(opens), decls: list_reverse(acc) }
    [d, ...rest] -> match d {
      DUse(name, _, _) -> use_split_decls(rest, [name, ...opens], acc)
      _                -> use_split_decls(rest, opens, [d, ...acc])
    }
  }
}

# Per-Expr rewrite. `opens` is the effective list of effect names
# active at this point (file-level + outer block-level + fn-level
# + this block's prior SUse declarations). `bound` is the list of
# locally-bound names that shadow opens. `table` and `file` are
# threaded through for diagnostics. `errs_ref` is captured by mutable
# state via a record return.
type UseRw = { expr: Expr, errs: Int }

fn use_rewrite_expr(e: Expr, table: [EffOps], opens: [String],
                      bound: [String], file: String, errs: Int) : UseRw / Console + File {


  let r = use_rewrite_kind(e.kind, table, opens, bound, file, errs,
                            e.line, e.col)
  UseRw { expr: Expr { kind: r.expr.kind, line: e.line, col: e.col,
                       ty: e.ty, mode: e.mode },
          errs: r.errs }
}

fn use_rewrite_kind(k: ExprKind, table: [EffOps], opens: [String],
                      bound: [String], file: String, errs: Int,
                      line: Int, col: Int) : UseRw / Console + File {


  match k {
    EVar(name) -> {
      if list_has(bound, name) {
        UseRw { expr: mk_expr(EVar(name), line, col), errs: errs }
      } else {
        let owners = use_owners_of(table, opens, name)
        match owners {
          []        -> UseRw { expr: mk_expr(EVar(name), line, col), errs: errs }
          [eff]     -> {
            # Rewrite to `EField(EVar(eff), name)`; desugar_op_calls
            # later flattens it to `EVar("eff.name")`.
            let base = mk_expr(EVar(eff), line, col)
            UseRw { expr: mk_expr(EField(base, name), line, col), errs: errs }
          }
          [eff1, eff2, ...___] -> {
            diag_error(file, line, col,
              "ambiguous bare name `#{name}`: opened by both `#{eff1}` and `#{eff2}`")
            diag_help("qualify explicitly (e.g. `#{eff1}.#{name}` or `#{eff2}.#{name}`) or remove one of the `use` declarations")
            UseRw { expr: mk_expr(EVar(name), line, col), errs: errs + 1 }
          }
        }
      }
    }
    ELambda(ps, body) -> {
      let pn = use_param_names(ps, [])
      let body_bound = list_append(bound, pn)
      let rb = use_rewrite_expr(body, table, opens, body_bound, file, errs)
      UseRw { expr: mk_expr(ELambda(ps, rb.expr), line, col), errs: rb.errs }
    }
    EBlock(stmts, tail) -> {
      let r = use_rewrite_block(stmts, tail, table, opens, bound, file, errs,
                                  [], opens)
      UseRw { expr: mk_expr(EBlock(r.stmts, r.tail), line, col), errs: r.errs }
    }
    EMatch(scr, arms) -> {
      let rs = use_rewrite_expr(scr, table, opens, bound, file, errs)
      let ra = use_rewrite_arms(arms, table, opens, bound, file, rs.errs)
      UseRw { expr: mk_expr(EMatch(rs.expr, ra.arms), line, col), errs: ra.errs }
    }
    EHandle(body, eff_name, eff_tas, init_opt, alias, clauses, ret_opt) -> {
      let rb = use_rewrite_expr(body, table, opens,
                                 use_alias_bound(alias, bound), file, errs)
      let ri = match init_opt {
        None    -> UseRw { expr: mk_expr(EUnit, line, col), errs: rb.errs }
        Some(e) -> use_rewrite_expr(e, table, opens, bound, file, rb.errs)
      }
      let init_out = match init_opt { None -> None Some(_) -> Some(ri.expr) }
      let rc = use_rewrite_clauses(clauses, table, opens, bound, file, ri.errs)
      let rr = use_rewrite_opt_return(ret_opt, table, opens, bound, file, rc.errs)
      UseRw {
        expr: mk_expr(EHandle(rb.expr, eff_name, eff_tas, init_out, alias,
                                rc.clauses, rr.ret),
                       line, col),
        errs: rr.errs
      }
    }
    _ -> {
      let _st = UseRw { expr: mk_expr(k, line, col), errs: errs }
      let rk = dsg_map_expr_kind(k, (sub) => sub)   # placeholder to avoid recursion
      let _ = rk
      let mapped = use_rewrite_kind_default(k, table, opens, bound, file,
                                              errs, line, col)
      mapped
    }
  }
}

# Default-case dispatcher: applies use_rewrite_expr to every direct
# sub-Expr via the shared visitor's children, threading the error
# count.
type UseRwAcc = { errs: Int }

fn use_rewrite_kind_default(k: ExprKind, table: [EffOps], opens: [String],
                              bound: [String], file: String, errs: Int,
                              line: Int, col: Int) : UseRw / Console + File {


  # Build a closure-with-mutable-counter via record-based helper
  # functions. `acc_ref` is updated in-place by hooking through the
  # recursion.
  let acc0 = UseRwAcc { errs: errs }
  let pair = use_rewrite_recurse(k, table, opens, bound, file, acc0)
  UseRw { expr: mk_expr(pair.kind, line, col), errs: pair.acc.errs }
}

# Manual recursion: walk the same kinds dsg_map_expr_kind does, but
# carry the per-Expr error counter forward. Mirrors the structural
# cases of dsg_map_expr_kind exactly so adding a new ExprKind variant
# breaks here at the same single match site.
type UseKindAcc = { kind: ExprKind, acc: UseRwAcc }

fn use_rewrite_recurse(k: ExprKind, table: [EffOps], opens: [String],
                         bound: [String], file: String,
                         acc: UseRwAcc) : UseKindAcc / Console + File {


  match k {
    EInt(_)        -> UseKindAcc { kind: k, acc: acc }
    EReal(_)       -> UseKindAcc { kind: k, acc: acc }
    EBool(_)       -> UseKindAcc { kind: k, acc: acc }
    EChar(_)       -> UseKindAcc { kind: k, acc: acc }
    EStr(_, _)     -> UseKindAcc { kind: k, acc: acc }
    EUnit          -> UseKindAcc { kind: k, acc: acc }
    EVar(_)        -> UseKindAcc { kind: k, acc: acc }
    EUnder         -> UseKindAcc { kind: k, acc: acc }
    EPlaceholder   -> UseKindAcc { kind: k, acc: acc }
    EHole(_)       -> UseKindAcc { kind: k, acc: acc }
    ETodo(_)       -> UseKindAcc { kind: k, acc: acc }
    EVariantsOf(_, _) -> UseKindAcc { kind: k, acc: acc }
    # m6.2 Phase 2.1: qualified module call has no sub-Exprs to
    # recurse into and binds no names — pass through unchanged.
    EModCall(_, _) -> UseKindAcc { kind: k, acc: acc }
    EIntrinsic(name, args_) -> {
      let ra = use_rewrite_exprs(args_, table, opens, bound, file, acc.errs, [])
      UseKindAcc { kind: EIntrinsic(name, ra.exprs), acc: UseRwAcc { errs: ra.errs } }
    }
    ECall(callee, args_) -> {
      let rc = use_rewrite_expr(callee, table, opens, bound, file, acc.errs)
      let ra = use_rewrite_exprs(args_, table, opens, bound, file, rc.errs, [])
      UseKindAcc { kind: ECall(rc.expr, ra.exprs), acc: UseRwAcc { errs: ra.errs } }
    }
    EField(base, name) -> {
      let rb = use_rewrite_expr(base, table, opens, bound, file, acc.errs)
      UseKindAcc { kind: EField(rb.expr, name), acc: UseRwAcc { errs: rb.errs } }
    }
    EIndex(a, b) -> {
      let ra = use_rewrite_expr(a, table, opens, bound, file, acc.errs)
      let rb = use_rewrite_expr(b, table, opens, bound, file, ra.errs)
      UseKindAcc { kind: EIndex(ra.expr, rb.expr), acc: UseRwAcc { errs: rb.errs } }
    }
    EBinop(op, a, b) -> {
      let ra = use_rewrite_expr(a, table, opens, bound, file, acc.errs)
      let rb = use_rewrite_expr(b, table, opens, bound, file, ra.errs)
      UseKindAcc { kind: EBinop(op, ra.expr, rb.expr), acc: UseRwAcc { errs: rb.errs } }
    }
    EUnop(op, x) -> {
      let r = use_rewrite_expr(x, table, opens, bound, file, acc.errs)
      UseKindAcc { kind: EUnop(op, r.expr), acc: UseRwAcc { errs: r.errs } }
    }
    EIf(c, t_, eo) -> {
      let rc = use_rewrite_expr(c, table, opens, bound, file, acc.errs)
      let rt = use_rewrite_expr(t_, table, opens, bound, file, rc.errs)
      let re = use_rewrite_opt(eo, table, opens, bound, file, rt.errs)
      UseKindAcc { kind: EIf(rc.expr, rt.expr, re.expr), acc: UseRwAcc { errs: re.errs } }
    }
    EList(els) -> {
      let r = use_rewrite_elems(els, table, opens, bound, file, acc.errs, [])
      UseKindAcc { kind: EList(r.elems), acc: UseRwAcc { errs: r.errs } }
    }
    ERecordLit(name, fis) -> {
      let r = use_rewrite_fields(fis, table, opens, bound, file, acc.errs, [])
      UseKindAcc { kind: ERecordLit(name, r.fields), acc: UseRwAcc { errs: r.errs } }
    }
    ERange(a, b, opt_step) -> {
      let ra = use_rewrite_expr(a, table, opens, bound, file, acc.errs)
      let rb = use_rewrite_expr(b, table, opens, bound, file, ra.errs)
      let rs = use_rewrite_opt(opt_step, table, opens, bound, file, rb.errs)
      UseKindAcc { kind: ERange(ra.expr, rb.expr, rs.expr), acc: UseRwAcc { errs: rs.errs } }
    }
    EPipe(a, b) -> {
      let ra = use_rewrite_expr(a, table, opens, bound, file, acc.errs)
      let rb = use_rewrite_expr(b, table, opens, bound, file, ra.errs)
      UseKindAcc { kind: EPipe(ra.expr, rb.expr), acc: UseRwAcc { errs: rb.errs } }
    }
    EMapPipe(a, b) -> {
      let ra = use_rewrite_expr(a, table, opens, bound, file, acc.errs)
      let rb = use_rewrite_expr(b, table, opens, bound, file, ra.errs)
      UseKindAcc { kind: EMapPipe(ra.expr, rb.expr), acc: UseRwAcc { errs: rb.errs } }
    }
    EFlatMapPipe(a, b) -> {
      let ra = use_rewrite_expr(a, table, opens, bound, file, acc.errs)
      let rb = use_rewrite_expr(b, table, opens, bound, file, ra.errs)
      UseKindAcc { kind: EFlatMapPipe(ra.expr, rb.expr), acc: UseRwAcc { errs: rb.errs } }
    }
    EFilterPipe(a, b) -> {
      let ra = use_rewrite_expr(a, table, opens, bound, file, acc.errs)
      let rb = use_rewrite_expr(b, table, opens, bound, file, ra.errs)
      UseKindAcc { kind: EFilterPipe(ra.expr, rb.expr), acc: UseRwAcc { errs: rb.errs } }
    }
    ELitUnit(inner, u) -> {
      let r = use_rewrite_expr(inner, table, opens, bound, file, acc.errs)
      UseKindAcc { kind: ELitUnit(r.expr, u), acc: UseRwAcc { errs: r.errs } }
    }
    EBang(inner) -> {
      let r = use_rewrite_expr(inner, table, opens, bound, file, acc.errs)
      UseKindAcc { kind: EBang(r.expr), acc: UseRwAcc { errs: r.errs } }
    }
    ELambda(_, _) -> UseKindAcc { kind: k, acc: acc }   # handled outer
    EBlock(_, _)  -> UseKindAcc { kind: k, acc: acc }   # handled outer
    EMatch(_, _)  -> UseKindAcc { kind: k, acc: acc }   # handled outer
    EHandle(_, _, _, _, _, _, _) -> UseKindAcc { kind: k, acc: acc }   # handled outer
  }
}

type UseRwOpt = { expr: Option[Expr], errs: Int }

fn use_rewrite_opt(o: Option[Expr], table: [EffOps], opens: [String],
                     bound: [String], file: String, errs: Int) : UseRwOpt / Console + File {


  match o {
    None -> UseRwOpt { expr: None, errs: errs }
    Some(e) -> {
      let r = use_rewrite_expr(e, table, opens, bound, file, errs)
      UseRwOpt { expr: Some(r.expr), errs: r.errs }
    }
  }
}

type UseRwExprs = { exprs: [Expr], errs: Int }

fn use_rewrite_exprs(es: [Expr], table: [EffOps], opens: [String],
                       bound: [String], file: String, errs: Int,
                       acc: [Expr]) : UseRwExprs / Console + File {


  match es {
    [] -> UseRwExprs { exprs: list_reverse(acc), errs: errs }
    [h, ...rest] -> {
      let r = use_rewrite_expr(h, table, opens, bound, file, errs)
      use_rewrite_exprs(rest, table, opens, bound, file, r.errs, [r.expr, ...acc])
    }
  }
}

type UseRwElems = { elems: [ListElem], errs: Int }

fn use_rewrite_elems(els: [ListElem], table: [EffOps], opens: [String],
                       bound: [String], file: String, errs: Int,
                       acc: [ListElem]) : UseRwElems / Console + File {


  match els {
    [] -> UseRwElems { elems: list_reverse(acc), errs: errs }
    [el, ...rest] -> {
      let r1 = match el {
        ElPlain(x)  -> {
          let r = use_rewrite_expr(x, table, opens, bound, file, errs)
          UseRwElems { elems: [ElPlain(r.expr)], errs: r.errs }
        }
        ElSpread(x) -> {
          let r = use_rewrite_expr(x, table, opens, bound, file, errs)
          UseRwElems { elems: [ElSpread(r.expr)], errs: r.errs }
        }
      }
      let head = match r1.elems { [h, ..._t] -> h _ -> ElPlain(mk_expr(EUnit, 0, 0)) }
      use_rewrite_elems(rest, table, opens, bound, file, r1.errs, [head, ...acc])
    }
  }
}

type UseRwFields = { fields: [FieldInit], errs: Int }

fn use_rewrite_fields(fs: [FieldInit], table: [EffOps], opens: [String],
                        bound: [String], file: String, errs: Int,
                        acc: [FieldInit]) : UseRwFields / Console + File {


  match fs {
    [] -> UseRwFields { fields: list_reverse(acc), errs: errs }
    [fi, ...rest] -> match fi {
      FI(n, v) -> {
        let r = use_rewrite_expr(v, table, opens, bound, file, errs)
        use_rewrite_fields(rest, table, opens, bound, file, r.errs, [FI(n, r.expr), ...acc])
      }
    }
  }
}

type UseRwArms = { arms: [Arm], errs: Int }

fn use_rewrite_arms(arms: [Arm], table: [EffOps], opens: [String],
                      bound: [String], file: String, errs: Int) : UseRwArms / Console + File {


  use_rewrite_arms_loop(arms, table, opens, bound, file, errs, [])
}

fn use_rewrite_arms_loop(arms: [Arm], table: [EffOps], opens: [String],
                           bound: [String], file: String, errs: Int,
                           acc: [Arm]) : UseRwArms / Console + File {


  match arms {
    [] -> UseRwArms { arms: list_reverse(acc), errs: errs }
    [a, ...rest] -> match a {
      Arm(p, g, b) -> {
        let arm_bound = list_append(bound, dsg_pat_bindings(p, []))
        let rg = use_rewrite_opt(g, table, opens, arm_bound, file, errs)
        let rb = use_rewrite_expr(b, table, opens, arm_bound, file, rg.errs)
        use_rewrite_arms_loop(rest, table, opens, bound, file, rb.errs,
                                [Arm(p, rg.expr, rb.expr), ...acc])
      }
    }
  }
}

type UseRwClauses = { clauses: [HClause], errs: Int }

fn use_rewrite_clauses(cs: [HClause], table: [EffOps], opens: [String],
                         bound: [String], file: String, errs: Int) : UseRwClauses / Console + File {


  use_rewrite_clauses_loop(cs, table, opens, bound, file, errs, [])
}

fn use_rewrite_clauses_loop(cs: [HClause], table: [EffOps], opens: [String],
                              bound: [String], file: String, errs: Int,
                              acc: [HClause]) : UseRwClauses / Console + File {


  match cs {
    [] -> UseRwClauses { clauses: list_reverse(acc), errs: errs }
    [c, ...rest] -> match c {
      HC(n, ps, b, l, co) -> {
        let body_bound = list_append(bound, use_param_names(ps, []))
        let r = use_rewrite_expr(b, table, opens, body_bound, file, errs)
        use_rewrite_clauses_loop(rest, table, opens, bound, file, r.errs,
                                   [HC(n, ps, r.expr, l, co), ...acc])
      }
    }
  }
}

type UseRwRet = { ret: Option[HReturn], errs: Int }

fn use_rewrite_opt_return(ret_opt: Option[HReturn], table: [EffOps],
                            opens: [String], bound: [String],
                            file: String, errs: Int) : UseRwRet / Console + File {


  match ret_opt {
    None -> UseRwRet { ret: None, errs: errs }
    Some(r) -> match r {
      HR(p, b, l, c) -> {
        let body_bound = [p, ...bound]
        let rb = use_rewrite_expr(b, table, opens, body_bound, file, errs)
        UseRwRet { ret: Some(HR(p, rb.expr, l, c)), errs: rb.errs }
      }
    }
  }
}

# Block-level: track SUse declarations as we walk; strip them from
# the output. `local_opens` is the original outer scope; each SUse
# extends it and the extension lives only for the rest of the block.
type UseRwBlock = { stmts: [Stmt], tail: Option[Expr], errs: Int }

fn use_rewrite_block(stmts: [Stmt], tail: Option[Expr], table: [EffOps],
                       outer_opens: [String], bound: [String],
                       file: String, errs: Int,
                       acc: [Stmt], opens: [String]) : UseRwBlock / Console + File {


  match stmts {
    [] -> {
      let rt = use_rewrite_opt(tail, table, opens, bound, file, errs)
      UseRwBlock { stmts: list_reverse(acc), tail: rt.expr, errs: rt.errs }
    }
    [s, ...rest] -> match s {
      SUse(name, _, _) -> {
        # Extend opens for the rest of the block. The SUse itself
        # is stripped from the output.
        use_rewrite_block(rest, tail, table, outer_opens, bound,
                            file, errs, acc, [name, ...opens])
      }
      SLet(p, ann, rhs) -> {
        let rr = use_rewrite_expr(rhs, table, opens, bound, file, errs)
        let bound1 = list_append(bound, dsg_pat_bindings(p, []))
        use_rewrite_block(rest, tail, table, outer_opens, bound1,
                            file, rr.errs,
                            [SLet(p, ann, rr.expr), ...acc], opens)
      }
      SVar(n, ty, rhs, l, c) -> {
        let rr = use_rewrite_expr(rhs, table, opens, bound, file, errs)
        let bound1 = [n, ...bound]
        use_rewrite_block(rest, tail, table, outer_opens, bound1,
                            file, rr.errs,
                            [SVar(n, ty, rr.expr, l, c), ...acc], opens)
      }
      SAssert(c, m) -> {
        let rc = use_rewrite_expr(c, table, opens, bound, file, errs)
        let rm = use_rewrite_opt(m, table, opens, bound, file, rc.errs)
        use_rewrite_block(rest, tail, table, outer_opens, bound,
                            file, rm.errs,
                            [SAssert(rc.expr, rm.expr), ...acc], opens)
      }
      SExprStmt(x) -> {
        let r = use_rewrite_expr(x, table, opens, bound, file, errs)
        use_rewrite_block(rest, tail, table, outer_opens, bound,
                            file, r.errs,
                            [SExprStmt(r.expr), ...acc], opens)
      }
      SIndexAssign(b, i, v, l, c) -> {
        let rb = use_rewrite_expr(b, table, opens, bound, file, errs)
        let ri = use_rewrite_expr(i, table, opens, bound, file, rb.errs)
        let rv = use_rewrite_expr(v, table, opens, bound, file, ri.errs)
        use_rewrite_block(rest, tail, table, outer_opens, bound,
                            file, rv.errs,
                            [SIndexAssign(rb.expr, ri.expr, rv.expr, l, c),
                             ...acc], opens)
      }
    }
  }
}

fn use_param_names(ps: [Param], acc: [String]) : [String] {
  match ps {
    [] -> list_reverse(acc)
    [p, ...rest] -> use_param_names(rest, [p.pname, ...acc])
  }
}

fn use_alias_bound(alias: Option[String], bound: [String]) : [String] {
  match alias {
    None    -> bound
    Some(a) -> [a, ...bound]
  }
}

# Top-level entry — runs after inject_builtin_effects so the builtin
# effect names are in the table.
#[doc("Result of the `use Effect` desugar: the rewritten decls plus an error count.")]
pub type UseRwProgram = { decls: [Decl], errs: Int }

#[doc("m7e §25: strip file-level `use Effect` decls and rewrite bare op references inside their scope to qualified `Eff.op` calls.")]
pub fn desugar_use_decls(decls: [Decl], file: String) : UseRwProgram / Console + File {


  let split = use_split_decls(decls, [], [])
  let table = use_collect_eff_ops(split.decls)
  # Validate file_opens reference declared effects.
  let errs0 = use_validate_opens(split.file_opens, table, file, 0)
  use_rewrite_program(split.decls, table, split.file_opens, file, errs0, [])
}

fn use_validate_opens(opens: [String], table: [EffOps], file: String,
                        errs: Int) : Int / Console + File {


  match opens {
    [] -> errs
    [name, ...rest] -> match use_eff_lookup(table, name) {
      Some(_) -> use_validate_opens(rest, table, file, errs)
      None    -> {
        diag_error(file, 0, 0, "`use #{name}`: no effect named `#{name}` is in scope")
        diag_help("declare the effect (`effect #{name} { ... }`) or import the module that declares it")
        use_validate_opens(rest, table, file, errs + 1)
      }
    }
  }
}

fn use_rewrite_program(decls: [Decl], table: [EffOps], file_opens: [String],
                         file: String, errs: Int, acc: [Decl]) : UseRwProgram / Console + File {


  match decls {
    [] -> UseRwProgram { decls: list_reverse(acc), errs: errs }
    [d, ...rest] -> {
      let r = use_rewrite_decl(d, table, file_opens, file, errs)
      use_rewrite_program(rest, table, file_opens, file, r.errs, [r.decl, ...acc])
    }
  }
}

type UseRwDecl = { decl: Decl, errs: Int }

fn use_rewrite_decl(d: Decl, table: [EffOps], file_opens: [String],
                      file: String, errs: Int) : UseRwDecl / Console + File {


  match d {
    DFn(p, n, tps, ps, ret, row, body, l, c, mo) -> {
      let bound = use_param_names(ps, [])
      let r = use_rewrite_expr(body, table, file_opens, bound, file, errs)
      UseRwDecl { decl: DFn(p, n, tps, ps, ret, row, r.expr, l, c, mo),
                  errs: r.errs }
    }
    DTest(desc, body, l, c) -> {
      let r = use_rewrite_expr(body, table, file_opens, [], file, errs)
      UseRwDecl { decl: DTest(desc, r.expr, l, c), errs: r.errs }
    }
    DBench(desc, body, l, c) -> {
      let r = use_rewrite_expr(body, table, file_opens, [], file, errs)
      UseRwDecl { decl: DBench(desc, r.expr, l, c), errs: r.errs }
    }
    DCheck(desc, ps, body, l, c) -> {
      let r = use_rewrite_expr(body, table, file_opens, [], file, errs)
      UseRwDecl { decl: DCheck(desc, ps, r.expr, l, c), errs: r.errs }
    }
    DImpl(pname, proto_args, target, ms, l, c) -> {
      let rms = use_rewrite_decls(ms, table, file_opens, file, errs, [])
      UseRwDecl { decl: DImpl(pname, proto_args, target, rms.decls, l, c),
                  errs: rms.errs }
    }
    DDerive(names, inner, l, c) -> {
      let r = use_rewrite_decl(inner, table, file_opens, file, errs)
      UseRwDecl { decl: DDerive(names, r.decl, l, c), errs: r.errs }
    }
    DUnstable(inner, l, c) -> {
      let r = use_rewrite_decl(inner, table, file_opens, file, errs)
      UseRwDecl { decl: DUnstable(r.decl, l, c), errs: r.errs }
    }
    _ -> UseRwDecl { decl: d, errs: errs }
  }
}

fn use_rewrite_decls(decls: [Decl], table: [EffOps], file_opens: [String],
                       file: String, errs: Int, acc: [Decl]) : UseRwProgram / Console + File {


  match decls {
    [] -> UseRwProgram { decls: list_reverse(acc), errs: errs }
    [d, ...rest] -> {
      let r = use_rewrite_decl(d, table, file_opens, file, errs)
      use_rewrite_decls(rest, table, file_opens, file, r.errs, [r.decl, ...acc])
    }
  }
}

# ====================================================================
# Cap-binding nursery rewrite (issue #71 option (b) prerequisite, m7b #4)
# ====================================================================
#
# `nursery { n -> ... n.spawn(task) ... n.await(f) ... }` is the
# canonical form pinned in `docs/structured-concurrency.md` §*Type
# system* and `docs/syntax-sugars.md` §1. The previous surface
# `nursery { ... spawn.spawn(task) ... }` had no cap binder, which
# meant a per-nursery brand had nowhere to attach (PR #74 deferred
# section). This pass turns the cap-binding form into the runtime-
# equivalent `nursery { ... Spawn.spawn(task) ... Spawn.await(f) ... }`
# the typer already accepts:
#
#   1. Each `ECall(EVar("nursery"), [..., ELambda([Param(n, ...)], body)])`
#      mints a fresh BrandId and rewrites the body so every
#      `EField(EVar(n), op)` whose op is a Spawn primitive becomes
#      `EField(EVar("Spawn"), op)`. The brand is recorded in a side
#      registry (`brand_registry` below) keyed by the lambda's
#      file:line:col so `--dump-brands` and the brand-mismatch
#      diagnostic can resolve allocation sites.
#   2. The lambda's `n` parameter is stripped, so the rewritten
#      lambda is a `() -> T / e` thunk matching the existing
#      `nursery[T, e](body: () -> T / e + Spawn + Cancel)` signature
#      in stdlib/spawn.kai. No signature change is needed.
#   3. Nested nurseries shadow per the innermost cap binder. The
#      walker tracks a stack of `(name, brand_id)` pairs; the
#      innermost match wins. Outer caps are still in scope via
#      capture if the lambda body refers to them by their original
#      name (which the user's source code reflects).
#   4. Bodies without a `n -> ` prefix (`nursery { spawn.spawn(...) }`)
#      pass through untouched — there is no cap binder to rewrite.
#
# Shadowing safety: a `let n = ...` inside the body that re-binds
# the cap name is respected by re-walking with the binder dropped
# from the stack, mirroring `rewrite_alias_*`'s shadow handling.

# A brand record carries everything `--dump-brands` and the brand-
# mismatch diagnostic need to surface. `bid` is the unique brand id;
# `cap_name` is the source-level name the user wrote (`n`, `outer`,
# etc.); `file/line/col` point at the lambda's `{` token (where the
# cap binder appears).
#[doc("A minted nursery brand (brand id, cap name, file, line, col) produced by the cap-binding rewrite.")]
pub type BrandRec = BR(Int, String, String, Int, Int)

# Per-call attribution: every `n.<op>(args)` rewritten by this pass
# records its (file, line, col, brand_id, op_name) so the post-rewrite
# brand-mismatch check (issue #71 option (b)) can tell which scope
# each call belongs to. The same registry feeds `--dump-brands`.
#[doc("A recorded nursery-cap consume site (file, line, col, brand id, op name) for brand-mismatch checking.")]
pub type BrandCall = BC(String, Int, Int, Int, String)

# Set of Spawn ops legal on a NurseryCap. Mirrors `builtin_spawn_decl`
# in this file. Update both lists in lockstep when a new Spawn op
# lands.
fn nursery_cap_op_names() : [String] =
  ["spawn", "await", "select", "cancel", "yield", "set_trap_exit", "cancel_all"]

fn is_nursery_cap_op(name: String) : Bool =
  list_has(nursery_cap_op_names(), name)

# Stack of active cap binders. Innermost first.
type NCapStack = NCS([NCapBinding])
type NCapBinding = NCB(String, Int)   # (cap_name, brand_id)

fn ncs_empty() : NCapStack = NCS([])

fn ncs_push(s: NCapStack, name: String, bid: Int) : NCapStack {
  match s { NCS(xs) -> NCS([NCB(name, bid), ...xs]) }
}

# A `let name = ...` (or other binder) that re-binds the cap name
# shadows the outer entry. Drop the head occurrence of `name`.
fn ncs_remove(s: NCapStack, name: String) : NCapStack {
  match s { NCS(xs) -> NCS(ncs_remove_loop(xs, name, [])) }
}

fn ncs_remove_loop(xs: [NCapBinding], name: String,
                     acc: [NCapBinding]) : [NCapBinding] {
  match xs {
    [] -> list_reverse(acc)
    [h, ...rest] -> match h {
      NCB(n, _) ->
        if n == name { ncs_remove_loop(rest, name, acc) }
        else        { ncs_remove_loop(rest, name, [h, ...acc]) }
    }
  }
}

fn ncs_remove_all(s: NCapStack, names: [String]) : NCapStack {
  match names {
    [] -> s
    [h, ...rest] -> ncs_remove_all(ncs_remove(s, h), rest)
  }
}

# Look up the innermost active brand id for `name`. None when no
# binding matches.
fn ncs_lookup(s: NCapStack, name: String) : Option[Int] {
  match s { NCS(xs) -> ncs_lookup_loop(xs, name) }
}

fn ncs_lookup_loop(xs: [NCapBinding], name: String) : Option[Int] {
  match xs {
    [] -> None
    [h, ...rest] -> match h {
      NCB(n, b) -> if n == name { Some(b) } else { ncs_lookup_loop(rest, name) }
    }
  }
}

# The walker threads a brand counter so each visit produces a fresh
# id. Side-effecting registry accumulation happens by returning the
# growing list alongside the rewritten expression. `calls` records
# per-call attributions so the post-rewrite brand-mismatch check can
# tell which scope each `Spawn.<op>` call originated in.
type BrandWalk = { bnext: Int, registry: [BrandRec], calls: [BrandCall] }

type BrandAlloc = { bw: BrandWalk, bid: Int }

fn bw_alloc(bw: BrandWalk, name: String, file: String,
             line: Int, col: Int) : BrandAlloc {
  let bid = bw.bnext
  BrandAlloc { bw: BrandWalk { bnext: bid + 1,
                    registry: [BR(bid, name, file, line, col),
                                ...bw.registry],
                    calls: bw.calls },
                bid: bid }
}

fn bw_record_call(bw: BrandWalk, file: String, line: Int, col: Int,
                   bid: Int, op_name: String) : BrandWalk {
  BrandWalk { bnext: bw.bnext,
              registry: bw.registry,
              calls: [BC(file, line, col, bid, op_name), ...bw.calls] }
}

# Top-level entry. Walks every Decl body and returns the rewritten
# program plus the brand registry collected during the walk.
#[doc("Result of the cap-binding nursery rewrite: the rewritten decls plus the brand registry and recorded call sites.")]
pub type NurseryRwProgram = { decls: [Decl], brands: [BrandRec], calls: [BrandCall] }

#[doc("m7b #4 / issue #71(b): expand `nursery { n -> body }` by stripping the cap param and rewriting `n.<op>` to `Spawn.<op>`, minting one BrandId per scope.")]
pub fn rewrite_nursery_caps_decls(decls: [Decl], file: String) : NurseryRwProgram {
  let bw0 = BrandWalk { bnext: 0, registry: [], calls: [] }
  let res = rewrite_nursery_caps_loop(decls, file, bw0, [])
  NurseryRwProgram { decls: res.decls,
                      brands: list_reverse(res.bw.registry),
                      calls: list_reverse(res.bw.calls) }
}

type NurseryRwLoop = { decls: [Decl], bw: BrandWalk }

fn rewrite_nursery_caps_loop(decls: [Decl], file: String, bw: BrandWalk,
                               acc: [Decl]) : NurseryRwLoop {
  match decls {
    [] -> NurseryRwLoop { decls: list_reverse(acc), bw: bw }
    [d, ...rest] -> {
      let r = rewrite_nursery_caps_decl(d, file, bw)
      rewrite_nursery_caps_loop(rest, file, r.bw, [r.decl, ...acc])
    }
  }
}

type NurseryRwDecl = { decl: Decl, bw: BrandWalk }

fn rewrite_nursery_caps_decl(d: Decl, file: String, bw: BrandWalk) : NurseryRwDecl {
  match d {
    DFn(p_, n, tps, ps, ret, row, body, l, c, mo) -> {
      let r = rewrite_nursery_caps_expr(body, ncs_empty(), file, bw)
      NurseryRwDecl { decl: DFn(p_, n, tps, ps, ret, row, r.expr, l, c, mo),
                       bw: r.bw }
    }
    DTest(desc, body, l, c) -> {
      let r = rewrite_nursery_caps_expr(body, ncs_empty(), file, bw)
      NurseryRwDecl { decl: DTest(desc, r.expr, l, c), bw: r.bw }
    }
    DBench(desc, body, l, c) -> {
      let r = rewrite_nursery_caps_expr(body, ncs_empty(), file, bw)
      NurseryRwDecl { decl: DBench(desc, r.expr, l, c), bw: r.bw }
    }
    DCheck(desc, ps, body, l, c) -> {
      let r = rewrite_nursery_caps_expr(body, ncs_empty(), file, bw)
      NurseryRwDecl { decl: DCheck(desc, ps, r.expr, l, c), bw: r.bw }
    }
    DImpl(pname, proto_args, target, ms, l, c) -> {
      let rms = rewrite_nursery_caps_loop(ms, file, bw, [])
      NurseryRwDecl { decl: DImpl(pname, proto_args, target, rms.decls, l, c),
                       bw: rms.bw }
    }
    DDerive(names, inner, l, c) -> {
      let r = rewrite_nursery_caps_decl(inner, file, bw)
      NurseryRwDecl { decl: DDerive(names, r.decl, l, c), bw: r.bw }
    }
    DUnstable(inner, l, c) -> {
      let r = rewrite_nursery_caps_decl(inner, file, bw)
      NurseryRwDecl { decl: DUnstable(r.decl, l, c), bw: r.bw }
    }
    _ -> NurseryRwDecl { decl: d, bw: bw }
  }
}

type NurseryRwExpr = { expr: Expr, bw: BrandWalk }

fn rewrite_nursery_caps_expr(e: Expr, s: NCapStack, file: String,
                               bw: BrandWalk) : NurseryRwExpr {
  let r = rewrite_nursery_caps_kind(e.kind, s, file, bw, e.line, e.col)
  NurseryRwExpr { expr: Expr { kind: r.kind, line: e.line, col: e.col,
                                ty: e.ty, mode: e.mode },
                   bw: r.bw }
}

type NurseryRwKind = { kind: ExprKind, bw: BrandWalk }

# Rewrite an expression kind. The cap rewrite proper handles three
# cases: (1) a `nursery` call with a 1-arg trailing lambda (mints a
# brand and recurses with cap pushed), (2) a `EField(EVar(n), op)`
# whose `n` matches an active cap and `op` is a Spawn primitive
# (rewrites to `EField(EVar("Spawn"), op)`), and (3) every other
# kind, which recurses structurally.
fn rewrite_nursery_caps_kind(k: ExprKind, s: NCapStack, file: String,
                               bw: BrandWalk, line: Int, col: Int) : NurseryRwKind {
  match k {
    ECall(callee, args_) -> {
      # Detect three shapes:
      #   (a) `nursery { n -> body }` — the cap-binding scope.
      #   (b) `n.<op>(args)` where `n` is an active cap binder —
      #       rewrite the callee + record the (line, col, brand) so
      #       the post-rewrite brand-mismatch check can attribute
      #       this call to its scope.
      #   (c) anything else — recurse structurally.
      match callee.kind {
        EVar(callee_name) ->
          if callee_name == "nursery" {
            rewrite_nursery_call(callee, args_, s, file, bw, line, col)
          } else {
            let cr = rewrite_nursery_caps_expr(callee, s, file, bw)
            let ar = rewrite_nursery_caps_exprs(args_, s, file, cr.bw, [])
            NurseryRwKind { kind: ECall(cr.expr, ar.exprs), bw: ar.bw }
          }
        EField(base, op_name) -> match base.kind {
          EVar(name) -> {
            if is_nursery_cap_op(op_name) {
              match ncs_lookup(s, name) {
                Some(bid) -> {
                  # Record this call site's brand attribution.
                  let bw1 = bw_record_call(bw, file, line, col, bid, op_name)
                  let ar = rewrite_nursery_caps_exprs(args_, s, file, bw1, [])
                  let new_callee = mk_expr(
                    EField(mk_expr(EVar("Spawn"), base.line, base.col), op_name),
                    callee.line, callee.col)
                  NurseryRwKind { kind: ECall(new_callee, ar.exprs), bw: ar.bw }
                }
                None -> {
                  let cr = rewrite_nursery_caps_expr(callee, s, file, bw)
                  let ar = rewrite_nursery_caps_exprs(args_, s, file, cr.bw, [])
                  NurseryRwKind { kind: ECall(cr.expr, ar.exprs), bw: ar.bw }
                }
              }
            } else {
              let cr = rewrite_nursery_caps_expr(callee, s, file, bw)
              let ar = rewrite_nursery_caps_exprs(args_, s, file, cr.bw, [])
              NurseryRwKind { kind: ECall(cr.expr, ar.exprs), bw: ar.bw }
            }
          }
          _ -> {
            let cr = rewrite_nursery_caps_expr(callee, s, file, bw)
            let ar = rewrite_nursery_caps_exprs(args_, s, file, cr.bw, [])
            NurseryRwKind { kind: ECall(cr.expr, ar.exprs), bw: ar.bw }
          }
        }
        _ -> {
          let cr = rewrite_nursery_caps_expr(callee, s, file, bw)
          let ar = rewrite_nursery_caps_exprs(args_, s, file, cr.bw, [])
          NurseryRwKind { kind: ECall(cr.expr, ar.exprs), bw: ar.bw }
        }
      }
    }
    EField(base, op_name) -> {
      # Bare `n.op` (without call): rewrite to `Spawn.op` if `n` is
      # an active cap. The typer rejects bare effect ops at use
      # sites, so this branch is mostly defensive; we still rewrite
      # so the diagnostic surface is consistent.
      match base.kind {
        EVar(name) -> {
          if is_nursery_cap_op(op_name) {
            match ncs_lookup(s, name) {
              Some(_) ->
                NurseryRwKind {
                  kind: EField(mk_expr(EVar("Spawn"), base.line, base.col), op_name),
                  bw: bw }
              None -> {
                let br = rewrite_nursery_caps_expr(base, s, file, bw)
                NurseryRwKind { kind: EField(br.expr, op_name), bw: br.bw }
              }
            }
          } else {
            let br = rewrite_nursery_caps_expr(base, s, file, bw)
            NurseryRwKind { kind: EField(br.expr, op_name), bw: br.bw }
          }
        }
        _ -> {
          let br = rewrite_nursery_caps_expr(base, s, file, bw)
          NurseryRwKind { kind: EField(br.expr, op_name), bw: br.bw }
        }
      }
    }
    ELambda(ps, body) -> {
      # Lambda params shadow outer caps with the same name.
      let pnames = map(ps, (p) => p.pname)
      let s1 = ncs_remove_all(s, pnames)
      let r = rewrite_nursery_caps_expr(body, s1, file, bw)
      NurseryRwKind { kind: ELambda(ps, r.expr), bw: r.bw }
    }
    EBlock(stmts, tail) -> {
      let sr = rewrite_nursery_caps_stmts(stmts, s, file, bw, [])
      let tr = rewrite_nursery_caps_opt(tail, sr.s, file, sr.bw)
      NurseryRwKind { kind: EBlock(sr.stmts, tr.expr), bw: tr.bw }
    }
    EMatch(scr, arms) -> {
      let sr = rewrite_nursery_caps_expr(scr, s, file, bw)
      let ar = rewrite_nursery_caps_arms(arms, s, file, sr.bw, [])
      NurseryRwKind { kind: EMatch(sr.expr, ar.arms), bw: ar.bw }
    }
    EHandle(body, eff_name, eff_tyargs, init_opt, alias_opt, clauses, ret_opt) -> {
      let br = rewrite_nursery_caps_expr(body, s, file, bw)
      let ir = rewrite_nursery_caps_opt(init_opt, s, file, br.bw)
      let cr = rewrite_nursery_caps_clauses(clauses, s, file, ir.bw, [])
      let rr = rewrite_nursery_caps_opt_return(ret_opt, s, file, cr.bw)
      NurseryRwKind { kind: EHandle(br.expr, eff_name, eff_tyargs,
                                      ir.expr, alias_opt, cr.clauses, rr.ret),
                       bw: rr.bw }
    }
    # All other composites: fold sub-expressions through dsg_map_expr_kind
    # by hand — but we need to thread `bw`. The simplest path is to
    # emulate dsg_map_expr_kind here for composites that may carry sub-
    # exprs. We handle them explicitly to keep the brand counter
    # threaded.
    EIf(c, t_, eo) -> {
      let cr = rewrite_nursery_caps_expr(c, s, file, bw)
      let tr = rewrite_nursery_caps_expr(t_, s, file, cr.bw)
      let er = rewrite_nursery_caps_opt(eo, s, file, tr.bw)
      NurseryRwKind { kind: EIf(cr.expr, tr.expr, er.expr), bw: er.bw }
    }
    EBinop(op, a, b) -> {
      let ar = rewrite_nursery_caps_expr(a, s, file, bw)
      let br = rewrite_nursery_caps_expr(b, s, file, ar.bw)
      NurseryRwKind { kind: EBinop(op, ar.expr, br.expr), bw: br.bw }
    }
    EUnop(op, x) -> {
      let r = rewrite_nursery_caps_expr(x, s, file, bw)
      NurseryRwKind { kind: EUnop(op, r.expr), bw: r.bw }
    }
    EIndex(a, b) -> {
      let ar = rewrite_nursery_caps_expr(a, s, file, bw)
      let br = rewrite_nursery_caps_expr(b, s, file, ar.bw)
      NurseryRwKind { kind: EIndex(ar.expr, br.expr), bw: br.bw }
    }
    EPipe(a, b) -> {
      let ar = rewrite_nursery_caps_expr(a, s, file, bw)
      let br = rewrite_nursery_caps_expr(b, s, file, ar.bw)
      NurseryRwKind { kind: EPipe(ar.expr, br.expr), bw: br.bw }
    }
    EMapPipe(a, b) -> {
      let ar = rewrite_nursery_caps_expr(a, s, file, bw)
      let br = rewrite_nursery_caps_expr(b, s, file, ar.bw)
      NurseryRwKind { kind: EMapPipe(ar.expr, br.expr), bw: br.bw }
    }
    EFlatMapPipe(a, b) -> {
      let ar = rewrite_nursery_caps_expr(a, s, file, bw)
      let br = rewrite_nursery_caps_expr(b, s, file, ar.bw)
      NurseryRwKind { kind: EFlatMapPipe(ar.expr, br.expr), bw: br.bw }
    }
    EFilterPipe(a, b) -> {
      let ar = rewrite_nursery_caps_expr(a, s, file, bw)
      let br = rewrite_nursery_caps_expr(b, s, file, ar.bw)
      NurseryRwKind { kind: EFilterPipe(ar.expr, br.expr), bw: br.bw }
    }
    ERecordLit(name, fs) -> {
      let r = rewrite_nursery_caps_fields(fs, s, file, bw, [])
      NurseryRwKind { kind: ERecordLit(name, r.fields), bw: r.bw }
    }
    EList(els) -> {
      let r = rewrite_nursery_caps_elems(els, s, file, bw, [])
      NurseryRwKind { kind: EList(r.elems), bw: r.bw }
    }
    ERange(a, b, opt_step) -> {
      let ar = rewrite_nursery_caps_expr(a, s, file, bw)
      let br = rewrite_nursery_caps_expr(b, s, file, ar.bw)
      let stepr = rewrite_nursery_caps_opt(opt_step, s, file, br.bw)
      NurseryRwKind { kind: ERange(ar.expr, br.expr, stepr.expr), bw: stepr.bw }
    }
    ELitUnit(inner, u) -> {
      let r = rewrite_nursery_caps_expr(inner, s, file, bw)
      NurseryRwKind { kind: ELitUnit(r.expr, u), bw: r.bw }
    }
    EBang(inner) -> {
      let r = rewrite_nursery_caps_expr(inner, s, file, bw)
      NurseryRwKind { kind: EBang(r.expr), bw: r.bw }
    }
    # Leaves and forms with no sub-Exprs.
    _ -> NurseryRwKind { kind: k, bw: bw }
  }
}

type NurseryRwExprs   = { exprs: [Expr], bw: BrandWalk }
type NurseryRwOpt     = { expr: Option[Expr], bw: BrandWalk }
type NurseryRwStmts   = { stmts: [Stmt], s: NCapStack, bw: BrandWalk }
type NurseryRwArms    = { arms: [Arm], bw: BrandWalk }
type NurseryRwClauses = { clauses: [HClause], bw: BrandWalk }
type NurseryRwRet     = { ret: Option[HReturn], bw: BrandWalk }
type NurseryRwFields  = { fields: [FieldInit], bw: BrandWalk }
type NurseryRwElems   = { elems: [ListElem], bw: BrandWalk }

fn rewrite_nursery_caps_exprs(es: [Expr], s: NCapStack, file: String,
                                bw: BrandWalk, acc: [Expr]) : NurseryRwExprs {
  match es {
    [] -> NurseryRwExprs { exprs: list_reverse(acc), bw: bw }
    [h, ...rest] -> {
      let r = rewrite_nursery_caps_expr(h, s, file, bw)
      rewrite_nursery_caps_exprs(rest, s, file, r.bw, [r.expr, ...acc])
    }
  }
}

fn rewrite_nursery_caps_opt(opt: Option[Expr], s: NCapStack, file: String,
                              bw: BrandWalk) : NurseryRwOpt {
  match opt {
    None -> NurseryRwOpt { expr: None, bw: bw }
    Some(e) -> {
      let r = rewrite_nursery_caps_expr(e, s, file, bw)
      NurseryRwOpt { expr: Some(r.expr), bw: r.bw }
    }
  }
}

# Statement-list walk. Tracks SLet / SVar bindings to drop them from
# the cap stack so a re-bind of `n` inside the body shadows.
fn rewrite_nursery_caps_stmts(ss: [Stmt], s: NCapStack, file: String,
                                bw: BrandWalk, acc: [Stmt]) : NurseryRwStmts {
  match ss {
    [] -> NurseryRwStmts { stmts: list_reverse(acc), s: s, bw: bw }
    [stmt, ...rest] -> match stmt {
      SLet(pat, ann, rhs) -> {
        let r = rewrite_nursery_caps_expr(rhs, s, file, bw)
        let s1 = ncs_remove_all(s, dsg_pat_bindings(pat, []))
        rewrite_nursery_caps_stmts(rest, s1, file, r.bw, [SLet(pat, ann, r.expr), ...acc])
      }
      SVar(n, ty, rhs, l, c) -> {
        let r = rewrite_nursery_caps_expr(rhs, s, file, bw)
        let s1 = ncs_remove(s, n)
        rewrite_nursery_caps_stmts(rest, s1, file, r.bw, [SVar(n, ty, r.expr, l, c), ...acc])
      }
      SAssert(c, m) -> {
        let cr = rewrite_nursery_caps_expr(c, s, file, bw)
        let mr = rewrite_nursery_caps_opt(m, s, file, cr.bw)
        rewrite_nursery_caps_stmts(rest, s, file, mr.bw, [SAssert(cr.expr, mr.expr), ...acc])
      }
      SExprStmt(x) -> {
        let r = rewrite_nursery_caps_expr(x, s, file, bw)
        rewrite_nursery_caps_stmts(rest, s, file, r.bw, [SExprStmt(r.expr), ...acc])
      }
      SIndexAssign(b, i, v, l, c) -> {
        let br = rewrite_nursery_caps_expr(b, s, file, bw)
        let ir = rewrite_nursery_caps_expr(i, s, file, br.bw)
        let vr = rewrite_nursery_caps_expr(v, s, file, ir.bw)
        rewrite_nursery_caps_stmts(rest, s, file, vr.bw,
          [SIndexAssign(br.expr, ir.expr, vr.expr, l, c), ...acc])
      }
      SUse(n, l, c) ->
        rewrite_nursery_caps_stmts(rest, s, file, bw, [SUse(n, l, c), ...acc])
    }
  }
}

fn rewrite_nursery_caps_arms(arms: [Arm], s: NCapStack, file: String,
                               bw: BrandWalk, acc: [Arm]) : NurseryRwArms {
  match arms {
    [] -> NurseryRwArms { arms: list_reverse(acc), bw: bw }
    [a, ...rest] -> match a {
      Arm(p, g, b) -> {
        let s1 = ncs_remove_all(s, dsg_pat_bindings(p, []))
        let gr = rewrite_nursery_caps_opt(g, s1, file, bw)
        let br = rewrite_nursery_caps_expr(b, s1, file, gr.bw)
        rewrite_nursery_caps_arms(rest, s, file, br.bw, [Arm(p, gr.expr, br.expr), ...acc])
      }
    }
  }
}

fn rewrite_nursery_caps_clauses(cs: [HClause], s: NCapStack, file: String,
                                  bw: BrandWalk, acc: [HClause]) : NurseryRwClauses {
  match cs {
    [] -> NurseryRwClauses { clauses: list_reverse(acc), bw: bw }
    [c, ...rest] -> match c {
      HC(n, ps, b, l, co) -> {
        let pnames = map(ps, (pm) => pm.pname)
        let s1 = ncs_remove_all(s, pnames)
        let r = rewrite_nursery_caps_expr(b, s1, file, bw)
        rewrite_nursery_caps_clauses(rest, s, file, r.bw, [HC(n, ps, r.expr, l, co), ...acc])
      }
    }
  }
}

fn rewrite_nursery_caps_opt_return(opt: Option[HReturn], s: NCapStack,
                                     file: String, bw: BrandWalk) : NurseryRwRet {
  match opt {
    None -> NurseryRwRet { ret: None, bw: bw }
    Some(r) -> match r {
      HR(p, b, l, c) -> {
        let s1 = ncs_remove(s, p)
        let br = rewrite_nursery_caps_expr(b, s1, file, bw)
        NurseryRwRet { ret: Some(HR(p, br.expr, l, c)), bw: br.bw }
      }
    }
  }
}

fn rewrite_nursery_caps_fields(fs: [FieldInit], s: NCapStack, file: String,
                                 bw: BrandWalk, acc: [FieldInit]) : NurseryRwFields {
  match fs {
    [] -> NurseryRwFields { fields: list_reverse(acc), bw: bw }
    [f, ...rest] -> match f {
      FI(n, v) -> {
        let r = rewrite_nursery_caps_expr(v, s, file, bw)
        rewrite_nursery_caps_fields(rest, s, file, r.bw, [FI(n, r.expr), ...acc])
      }
    }
  }
}

fn rewrite_nursery_caps_elems(els: [ListElem], s: NCapStack, file: String,
                                bw: BrandWalk, acc: [ListElem]) : NurseryRwElems {
  match els {
    [] -> NurseryRwElems { elems: list_reverse(acc), bw: bw }
    [el, ...rest] -> match el {
      ElPlain(x) -> {
        let r = rewrite_nursery_caps_expr(x, s, file, bw)
        rewrite_nursery_caps_elems(rest, s, file, r.bw, [ElPlain(r.expr), ...acc])
      }
      ElSpread(x) -> {
        let r = rewrite_nursery_caps_expr(x, s, file, bw)
        rewrite_nursery_caps_elems(rest, s, file, r.bw, [ElSpread(r.expr), ...acc])
      }
    }
  }
}

# `nursery { n -> body }` → mint a brand, push `(n, brand)`, walk
# body, strip `n` from the lambda. The trailing-lambda parser
# always leaves the lambda as the LAST argument (per
# parse_trailing_lambdas), and `nursery` takes only the body, so
# args is typically `[lam]` — we still loop over args so a future
# multi-arg `nursery(extra) { n -> body }` form would not silently
# misbehave.
fn rewrite_nursery_call(callee: Expr, args_: [Expr], s: NCapStack,
                          file: String, bw: BrandWalk,
                          line: Int, col: Int) : NurseryRwKind {
  let lr = split_last_arg(args_)
  match lr {
    NoLast -> {
      let ar = rewrite_nursery_caps_exprs(args_, s, file, bw, [])
      NurseryRwKind { kind: ECall(callee, ar.exprs), bw: ar.bw }
    }
    HasLast(prefix, last) -> match last.kind {
      ELambda(ps, body) -> match ps {
        [p0] -> {
          let p_name = p0.pname
          let alloc = bw_alloc(bw, p_name, file, last.line, last.col)
          let s1 = ncs_push(s, p_name, alloc.bid)
          let pr = rewrite_nursery_caps_exprs(prefix, s, file, alloc.bw, [])
          let br = rewrite_nursery_caps_expr(body, s1, file, pr.bw)
          let stripped_lam = mk_expr(ELambda([], br.expr), last.line, last.col)
          let new_args = list_append(pr.exprs, [stripped_lam])
          NurseryRwKind { kind: ECall(callee, new_args), bw: br.bw }
        }
        _ -> {
          let pr = rewrite_nursery_caps_exprs(prefix, s, file, bw, [])
          let lr2 = rewrite_nursery_caps_expr(last, s, file, pr.bw)
          NurseryRwKind { kind: ECall(callee, list_append(pr.exprs, [lr2.expr])),
                           bw: lr2.bw }
        }
      }
      _ -> {
        let pr = rewrite_nursery_caps_exprs(prefix, s, file, bw, [])
        let lr2 = rewrite_nursery_caps_expr(last, s, file, pr.bw)
        NurseryRwKind { kind: ECall(callee, list_append(pr.exprs, [lr2.expr])),
                         bw: lr2.bw }
      }
    }
  }
}

type SplitLast = NoLast | HasLast([Expr], Expr)

fn split_last_arg(args_: [Expr]) : SplitLast {
  match args_ {
    [] -> NoLast
    _  -> split_last_loop(args_, [])
  }
}

fn split_last_loop(args_: [Expr], acc: [Expr]) : SplitLast {
  match args_ {
    [] -> NoLast
    [h] -> HasLast(list_reverse(acc), h)
    [h, ...rest] -> split_last_loop(rest, [h, ...acc])
  }
}

# ====================================================================
# Brand-mismatch check (issue #71 option (b))
# ====================================================================
#
# The cap-binding rewrite above tags every `n.<op>(args)` it
# rewrites with a (file, line, col, brand_id, op_name) entry in
# `BrandWalk.calls`. This check walks the post-rewrite AST and
# tracks brand attribution of bindings:
#
#   - At each rewritten `Spawn.spawn(...)` call (registered with a
#     known brand), the result is "branded": when bound by
#     `let f = <call>`, the binding `f` inherits the brand.
#   - Brand attribution propagates through `let g = f` chains and
#     through `let g = some_let_chain_var`.
#   - At each rewritten `Spawn.await(arg)` / `Spawn.cancel(arg)` /
#     `Spawn.select(args)`, the arg's brand attribution is checked
#     against the call's own brand. A mismatch is a sibling-
#     nursery brand violation (issue #71 option (b)). The
#     diagnostic includes both brand IDs and where each was
#     allocated (`nursery { n -> ... }`'s file:line:col), so the
#     user can trace the breach.
#
# Limitations of this lane (documented in the PR body):
#   - Brand propagation through generic helper fns
#     (`fn id[T](x: T) : T = x`) is not yet wired through the
#     typer's TyVarT instantiation; the brief's full
#     TyBranded(Ty, BrandId) Ty extension would carry brands
#     through unification automatically. Today the check sees
#     direct let-chains (`let g = f`); a helper round-trip
#     strips the brand.
#   - Escape detection at the nursery boundary (returning a
#     branded fiber as the body's value) is still served by the
#     existing `check_no_fiber_escape` walker (PR #74's
#     option (a) that catches Fiber/Pid in return types and sum
#     payloads). The "brand outlives its scope" form requires the
#     same TyBranded threading deferred above.
#
# Both gaps are tracked in `docs/fibers-honesty-targets.md`
# §*Residual m8.x items* item 1.

# Lookup: did this call get rewritten by the cap-binding pass?
# Returns `Some((bid, op_name))` keyed on (file, line, col).
fn brand_call_lookup(calls: [BrandCall], file: String,
                       line: Int, col: Int) : Option[BrandCall] {
  match calls {
    [] -> None
    [c, ...rest] -> match c {
      BC(cf, cl, cc, _, _) ->
        if cf == file and cl == line and cc == col { Some(c) }
        else { brand_call_lookup(rest, file, line, col) }
    }
  }
}

fn brand_rec_lookup(brs: [BrandRec], bid: Int) : Option[BrandRec] {
  match brs {
    [] -> None
    [b, ...rest] -> match b {
      BR(b_id, _, _, _, _) ->
        if b_id == bid { Some(b) } else { brand_rec_lookup(rest, bid) }
    }
  }
}

# Brand environment: a list of (binding name, brand id) pairs.
# Innermost entries first so shadowing works naturally.
type BrandBinding = BB(String, Int)
type BrandEnv = BEnv([BrandBinding])

fn benv_empty() : BrandEnv = BEnv([])

fn benv_push(e: BrandEnv, name: String, bid: Int) : BrandEnv {
  match e { BEnv(xs) -> BEnv([BB(name, bid), ...xs]) }
}

fn benv_remove(e: BrandEnv, name: String) : BrandEnv {
  match e { BEnv(xs) -> BEnv(benv_remove_loop(xs, name, [])) }
}

fn benv_remove_loop(xs: [BrandBinding], name: String,
                      acc: [BrandBinding]) : [BrandBinding] {
  match xs {
    [] -> list_reverse(acc)
    [h, ...rest] -> match h {
      BB(n, _) ->
        if n == name { benv_remove_loop(rest, name, acc) }
        else        { benv_remove_loop(rest, name, [h, ...acc]) }
    }
  }
}

fn benv_remove_all(e: BrandEnv, names: [String]) : BrandEnv {
  match names {
    [] -> e
    [h, ...rest] -> benv_remove_all(benv_remove(e, h), rest)
  }
}

fn benv_lookup(e: BrandEnv, name: String) : Option[Int] {
  match e { BEnv(xs) -> benv_lookup_loop(xs, name) }
}

fn benv_lookup_loop(xs: [BrandBinding], name: String) : Option[Int] {
  match xs {
    [] -> None
    [h, ...rest] -> match h {
      BB(n, b) -> if n == name { Some(b) } else { benv_lookup_loop(rest, name) }
    }
  }
}

# Look up the brand attribution of an expression. Recognises:
#   - A rewritten `Spawn.spawn(args)` call (looks the call up in
#     the registry by line:col).
#   - A bare `EVar(name)` binding (looks `name` up in the env).
#   - Otherwise the expression has no brand attribution.
#
# Returns `Some(bid)` when the brand can be determined statically.
# The `None` case is intentionally permissive — a fiber that lost
# its brand through a non-let path (e.g., a list element retrieved
# by index, a record field) is treated as unbranded for the v1 of
# this check.
fn expr_brand(e: Expr, env: BrandEnv, calls: [BrandCall]) : Option[Int] {
  match e.kind {
    EVar(name) -> benv_lookup(env, name)
    ECall(callee, _) -> match callee.kind {
      EField(base, op_name) -> match base.kind {
        EVar(eff_name) ->
          if eff_name == "Spawn" and op_name == "spawn" {
            match brand_call_lookup(calls, "", e.line, e.col) {
              Some(c) -> match c {
                BC(_, _, _, bid, _) -> Some(bid)
              }
              # The registry stores file as recorded at rewrite. Try
              # without filtering on file (the brand check runs per
              # decl, all from the same source file).
              None -> brand_call_first_at(calls, e.line, e.col)
            }
          } else { None }
        _ -> None
      }
      _ -> None
    }
    _ -> None
  }
}

# Match a call by (line, col) regardless of file — every call in
# the registry comes from the file currently being checked.
fn brand_call_first_at(calls: [BrandCall], line: Int, col: Int) : Option[Int] {
  match calls {
    [] -> None
    [c, ...rest] -> match c {
      BC(_, cl, cc, bid, _) ->
        if cl == line and cc == col { Some(bid) }
        else { brand_call_first_at(rest, line, col) }
    }
  }
}

# Diagnostic emitter. The two sides of the mismatch carry
# `(brand_id, allocation_site)` so the user can see which two
# nurseries produced the conflicting brands.
fn emit_brand_mismatch(file: String, line: Int, col: Int,
                         expected_bid: Int, found_bid: Int,
                         brs: [BrandRec], op_name: String) : Unit / Console + File {


  diag_error(file, line, col,
    concat_all(["sibling-nursery brand mismatch on `", op_name,
                "`: fiber from a different nursery scope"]))
  match brand_rec_lookup(brs, expected_bid) {
    Some(b) -> match b {
      BR(_, name, bf, bl, bc) ->
        diag_note(concat_all(["expected brand from nursery `",
                               name, "` at ", bf, ":",
                               int_to_string(bl), ":",
                               int_to_string(bc)]))
    }
    None -> ()
  }
  match brand_rec_lookup(brs, found_bid) {
    Some(b) -> match b {
      BR(_, name, bf, bl, bc) ->
        diag_note(concat_all(["fiber argument carries brand from nursery `",
                               name, "` at ", bf, ":",
                               int_to_string(bl), ":",
                               int_to_string(bc)]))
    }
    None -> ()
  }
  diag_help("each `n.spawn(...)` returns a Fiber bound to that nursery; pass it only to the same nursery's await/select/cancel — or restructure so the consume site shares the spawn site's `n` cap")
}

# Top-level entry — one error count for the whole program.
#[doc("Issue #71(b): brand-mismatch validator over the post-rewrite AST; rejects sibling-nursery cap confusion at consume sites. Depends on the brand registry produced by rewrite_nursery_caps_decls.")]
pub fn check_nursery_brand_mismatch_decls(ds: [Decl], file: String,
                                        calls: [BrandCall],
                                        brs: [BrandRec]) : Int / Console + File {

  check_brand_decls_loop(ds, file, calls, brs, 0)
}

# `--dump-brands`: print the brand registry plus per-call
# attributions in a deterministic, grep-friendly form. Mirrors
# `--dump-intervals`'s shape (one record per line, fixed column
# order) so fixtures can pin the output as a golden file.
#[doc("Debug dump of the nursery brand registry and call sites (driven by a dump flag in the driver).")]
pub fn dump_brands(brs: [BrandRec], calls: [BrandCall]) : Unit / Console {
  print("# kaic2 --dump-brands")
  print("# brand allocations (one per `nursery { n -> ... }` site):")
  dump_brand_recs(brs)
  print("# call attributions (one per rewritten `n.<op>` site):")
  dump_brand_calls(calls)
}

fn dump_brand_recs(brs: [BrandRec]) : Unit / Console {
  match brs {
    [] -> ()
    [b, ...rest] -> match b {
      BR(bid, name, file, line, col) -> {
        print(concat_all(["brand ", int_to_string(bid),
                            " cap=", name,
                            " at=", file, ":",
                            int_to_string(line), ":",
                            int_to_string(col)]))
        dump_brand_recs(rest)
      }
    }
  }
}

fn dump_brand_calls(calls: [BrandCall]) : Unit / Console {
  match calls {
    [] -> ()
    [c, ...rest] -> match c {
      BC(file, line, col, bid, op_name) -> {
        print(concat_all(["call op=", op_name,
                            " brand=", int_to_string(bid),
                            " at=", file, ":",
                            int_to_string(line), ":",
                            int_to_string(col)]))
        dump_brand_calls(rest)
      }
    }
  }
}

fn check_brand_decls_loop(ds: [Decl], file: String, calls: [BrandCall],
                            brs: [BrandRec], errs: Int) : Int / Console + File {

  match ds {
    [] -> errs
    [d, ...rest] -> {
      let e1 = check_brand_decl(d, file, calls, brs, errs)
      check_brand_decls_loop(rest, file, calls, brs, e1)
    }
  }
}

fn check_brand_decl(d: Decl, file: String, calls: [BrandCall],
                      brs: [BrandRec], errs: Int) : Int / Console + File {

  match d {
    DFn(_, _, _, _, _, _, body, _, _, _) ->
      check_brand_expr(body, benv_empty(), file, calls, brs, errs)
    DTest(_, body, _, _) ->
      check_brand_expr(body, benv_empty(), file, calls, brs, errs)
    DBench(_, body, _, _) ->
      check_brand_expr(body, benv_empty(), file, calls, brs, errs)
    DCheck(_, _, body, _, _) ->
      check_brand_expr(body, benv_empty(), file, calls, brs, errs)
    DImpl(_, _, _, ms, _, _) ->
      check_brand_decls_loop(ms, file, calls, brs, errs)
    DDerive(_, inner, _, _) ->
      check_brand_decl(inner, file, calls, brs, errs)
    DUnstable(inner, _, _) ->
      check_brand_decl(inner, file, calls, brs, errs)
    _ -> errs
  }
}

fn check_brand_expr(e: Expr, env: BrandEnv, file: String,
                      calls: [BrandCall], brs: [BrandRec],
                      errs: Int) : Int / Console + File {

  check_brand_kind(e.kind, env, file, calls, brs, errs, e.line, e.col)
}

fn check_brand_opt(o: Option[Expr], env: BrandEnv, file: String,
                     calls: [BrandCall], brs: [BrandRec],
                     errs: Int) : Int / Console + File {

  match o {
    None -> errs
    Some(e) -> check_brand_expr(e, env, file, calls, brs, errs)
  }
}

fn check_brand_exprs(es: [Expr], env: BrandEnv, file: String,
                       calls: [BrandCall], brs: [BrandRec],
                       errs: Int) : Int / Console + File {

  match es {
    [] -> errs
    [h, ...rest] -> {
      let e1 = check_brand_expr(h, env, file, calls, brs, errs)
      check_brand_exprs(rest, env, file, calls, brs, e1)
    }
  }
}

fn check_brand_kind(k: ExprKind, env: BrandEnv, file: String,
                      calls: [BrandCall], brs: [BrandRec],
                      errs: Int, line: Int, col: Int) : Int / Console + File {

  match k {
    ECall(callee, args_) -> {
      # Recognise rewritten cap-binding op calls by their registry
      # entry. For consume ops, cross-check the arg's brand.
      match brand_call_first_at(calls, line, col) {
        Some(bid) -> {
          # Look up the actual op name to pick the right arg index.
          let op = call_op_name(calls, line, col)
          let e1 = check_brand_consume(op, args_, bid, env, file, calls, brs, errs)
          check_brand_exprs(args_, env, file, calls, brs, e1)
        }
        None -> {
          let e1 = check_brand_expr(callee, env, file, calls, brs, errs)
          check_brand_exprs(args_, env, file, calls, brs, e1)
        }
      }
    }
    EBlock(stmts, tail) -> {
      let r = check_brand_stmts(stmts, env, file, calls, brs, errs)
      check_brand_opt(tail, r.env, file, calls, brs, r.errs)
    }
    EMatch(scr, arms) -> {
      let e1 = check_brand_expr(scr, env, file, calls, brs, errs)
      check_brand_arms(arms, env, file, calls, brs, e1)
    }
    EIf(c, t_, eo) -> {
      let e1 = check_brand_expr(c, env, file, calls, brs, errs)
      let e2 = check_brand_expr(t_, env, file, calls, brs, e1)
      check_brand_opt(eo, env, file, calls, brs, e2)
    }
    EBinop(_, a, b) -> {
      let e1 = check_brand_expr(a, env, file, calls, brs, errs)
      check_brand_expr(b, env, file, calls, brs, e1)
    }
    EUnop(_, x) -> check_brand_expr(x, env, file, calls, brs, errs)
    EField(base, _) -> check_brand_expr(base, env, file, calls, brs, errs)
    EIndex(a, b) -> {
      let e1 = check_brand_expr(a, env, file, calls, brs, errs)
      check_brand_expr(b, env, file, calls, brs, e1)
    }
    EPipe(a, b) -> {
      let e1 = check_brand_expr(a, env, file, calls, brs, errs)
      check_brand_expr(b, env, file, calls, brs, e1)
    }
    EMapPipe(a, b) -> {
      let e1 = check_brand_expr(a, env, file, calls, brs, errs)
      check_brand_expr(b, env, file, calls, brs, e1)
    }
    EFlatMapPipe(a, b) -> {
      let e1 = check_brand_expr(a, env, file, calls, brs, errs)
      check_brand_expr(b, env, file, calls, brs, e1)
    }
    EFilterPipe(a, b) -> {
      let e1 = check_brand_expr(a, env, file, calls, brs, errs)
      check_brand_expr(b, env, file, calls, brs, e1)
    }
    ELambda(ps, body) -> {
      let pnames = map(ps, (p) => p.pname)
      check_brand_expr(body, benv_remove_all(env, pnames), file, calls, brs, errs)
    }
    ERecordLit(_, fs) -> check_brand_fields(fs, env, file, calls, brs, errs)
    EList(els) -> check_brand_elems(els, env, file, calls, brs, errs)
    ERange(a, b, opt_step) -> {
      let e1 = check_brand_expr(a, env, file, calls, brs, errs)
      let e2 = check_brand_expr(b, env, file, calls, brs, e1)
      check_brand_opt(opt_step, env, file, calls, brs, e2)
    }
    EHandle(body, _, _, init_opt, _, clauses, ret_opt) -> {
      let e1 = check_brand_expr(body, env, file, calls, brs, errs)
      let e2 = check_brand_opt(init_opt, env, file, calls, brs, e1)
      let e3 = check_brand_clauses(clauses, env, file, calls, brs, e2)
      check_brand_opt_return(ret_opt, env, file, calls, brs, e3)
    }
    ELitUnit(inner, _) -> check_brand_expr(inner, env, file, calls, brs, errs)
    EBang(inner) -> check_brand_expr(inner, env, file, calls, brs, errs)
    _ -> errs
  }
}

fn call_op_name(calls: [BrandCall], line: Int, col: Int) : String {
  match calls {
    [] -> ""
    [c, ...rest] -> match c {
      BC(_, cl, cc, _, op) ->
        if cl == line and cc == col { op } else { call_op_name(rest, line, col) }
    }
  }
}

# Consume-op brand check. For await/cancel/select the first arg
# carries the fiber(s); for the other ops there is nothing to
# check (spawn produces a brand, set_trap_exit/yield/cancel_all
# don't take a fiber).
fn check_brand_consume(op_name: String, args_: [Expr], expected_bid: Int,
                        env: BrandEnv, file: String, calls: [BrandCall],
                        brs: [BrandRec], errs: Int) : Int / Console + File {

  if op_name == "await" or op_name == "cancel" {
    match args_ {
      [arg, ..._other_args] -> match expr_brand(arg, env, calls) {
        Some(found) ->
          if found == expected_bid { errs }
          else {
            emit_brand_mismatch(file, arg.line, arg.col,
                                  expected_bid, found, brs, op_name)
            errs + 1
          }
        None -> errs
      }
      _ -> errs
    }
  } else if op_name == "select" {
    match args_ {
      [arg, ..._other_args] -> match arg.kind {
        EList(els) -> check_brand_select_elems(els, expected_bid, env, file, calls, brs, errs)
        _ -> match expr_brand(arg, env, calls) {
          Some(found) ->
            if found == expected_bid { errs }
            else {
              emit_brand_mismatch(file, arg.line, arg.col,
                                    expected_bid, found, brs, op_name)
              errs + 1
            }
          None -> errs
        }
      }
      _ -> errs
    }
  } else { errs }
}

fn check_brand_select_elems(els: [ListElem], expected_bid: Int,
                              env: BrandEnv, file: String,
                              calls: [BrandCall], brs: [BrandRec],
                              errs: Int) : Int / Console + File {

  match els {
    [] -> errs
    [el, ...rest] -> {
      let e1 = match el {
        ElPlain(x) -> match expr_brand(x, env, calls) {
          Some(found) ->
            if found == expected_bid { errs }
            else {
              emit_brand_mismatch(file, x.line, x.col,
                                    expected_bid, found, brs, "select")
              errs + 1
            }
          None -> errs
        }
        ElSpread(_) -> errs
      }
      check_brand_select_elems(rest, expected_bid, env, file, calls, brs, e1)
    }
  }
}

# Statement walk. SLet propagates brand attribution from RHS to
# the bound name when the RHS expression has a brand. Other
# binders (SVar, lambda params, match patterns) do not carry
# brands today.
type BrandStmtsRes = { env: BrandEnv, errs: Int }

fn check_brand_stmts(ss: [Stmt], env: BrandEnv, file: String,
                       calls: [BrandCall], brs: [BrandRec],
                       errs: Int) : BrandStmtsRes / Console + File {


  match ss {
    [] -> BrandStmtsRes { env: env, errs: errs }
    [stmt, ...rest] -> match stmt {
      SLet(pat, _, rhs) -> {
        let e1 = check_brand_expr(rhs, env, file, calls, brs, errs)
        let env1 = bind_brand_pat(pat, rhs, env, calls)
        check_brand_stmts(rest, env1, file, calls, brs, e1)
      }
      SVar(n, _, rhs, _, _) -> {
        let e1 = check_brand_expr(rhs, env, file, calls, brs, errs)
        let env1 = benv_remove(env, n)
        check_brand_stmts(rest, env1, file, calls, brs, e1)
      }
      SAssert(c, m) -> {
        let e1 = check_brand_expr(c, env, file, calls, brs, errs)
        let e2 = check_brand_opt(m, env, file, calls, brs, e1)
        check_brand_stmts(rest, env, file, calls, brs, e2)
      }
      SExprStmt(x) -> {
        let e1 = check_brand_expr(x, env, file, calls, brs, errs)
        check_brand_stmts(rest, env, file, calls, brs, e1)
      }
      SIndexAssign(b, i, v, _, _) -> {
        let e1 = check_brand_expr(b, env, file, calls, brs, errs)
        let e2 = check_brand_expr(i, env, file, calls, brs, e1)
        let e3 = check_brand_expr(v, env, file, calls, brs, e2)
        check_brand_stmts(rest, env, file, calls, brs, e3)
      }
      SUse(_, _, _) -> check_brand_stmts(rest, env, file, calls, brs, errs)
    }
  }
}

# Bind a pattern's name(s) with brand attribution lifted from the
# RHS. Today only PBind directly carries the brand; other patterns
# strip the brand (matches consumer behaviour).
fn bind_brand_pat(pat: Pattern, rhs: Expr, env: BrandEnv,
                    calls: [BrandCall]) : BrandEnv {
  let names = dsg_pat_bindings(pat, [])
  let env1 = benv_remove_all(env, names)
  match pat.pkind {
    PBind(n) -> match expr_brand(rhs, env, calls) {
      Some(bid) -> benv_push(env1, n, bid)
      None -> env1
    }
    _ -> env1
  }
}

fn check_brand_arms(arms: [Arm], env: BrandEnv, file: String,
                      calls: [BrandCall], brs: [BrandRec],
                      errs: Int) : Int / Console + File {

  match arms {
    [] -> errs
    [a, ...rest] -> match a {
      Arm(p, g, b) -> {
        let env1 = benv_remove_all(env, dsg_pat_bindings(p, []))
        let e1 = check_brand_opt(g, env1, file, calls, brs, errs)
        let e2 = check_brand_expr(b, env1, file, calls, brs, e1)
        check_brand_arms(rest, env, file, calls, brs, e2)
      }
    }
  }
}

fn check_brand_clauses(cs: [HClause], env: BrandEnv, file: String,
                        calls: [BrandCall], brs: [BrandRec],
                        errs: Int) : Int / Console + File {

  match cs {
    [] -> errs
    [c, ...rest] -> match c {
      HC(_, ps, b, _, _) -> {
        let pnames = map(ps, (pm) => pm.pname)
        let env1 = benv_remove_all(env, pnames)
        let e1 = check_brand_expr(b, env1, file, calls, brs, errs)
        check_brand_clauses(rest, env, file, calls, brs, e1)
      }
    }
  }
}

fn check_brand_opt_return(opt: Option[HReturn], env: BrandEnv, file: String,
                            calls: [BrandCall], brs: [BrandRec],
                            errs: Int) : Int / Console + File {

  match opt {
    None -> errs
    Some(r) -> match r {
      HR(p, b, _, _) -> {
        let env1 = benv_remove(env, p)
        check_brand_expr(b, env1, file, calls, brs, errs)
      }
    }
  }
}

fn check_brand_fields(fs: [FieldInit], env: BrandEnv, file: String,
                        calls: [BrandCall], brs: [BrandRec],
                        errs: Int) : Int / Console + File {

  match fs {
    [] -> errs
    [f, ...rest] -> match f {
      FI(_, v) -> {
        let e1 = check_brand_expr(v, env, file, calls, brs, errs)
        check_brand_fields(rest, env, file, calls, brs, e1)
      }
    }
  }
}

fn check_brand_elems(els: [ListElem], env: BrandEnv, file: String,
                       calls: [BrandCall], brs: [BrandRec],
                       errs: Int) : Int / Console + File {

  match els {
    [] -> errs
    [el, ...rest] -> {
      let e1 = match el {
        ElPlain(x) -> check_brand_expr(x, env, file, calls, brs, errs)
        ElSpread(x) -> check_brand_expr(x, env, file, calls, brs, errs)
      }
      check_brand_elems(rest, env, file, calls, brs, e1)
    }
  }
}


