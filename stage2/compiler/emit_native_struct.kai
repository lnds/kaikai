# compiler/emit_native_struct.kai — struct-by-value FFI marshalling for
# the native libLLVM backend (issue #1030).
#
# The classifier (emit_native_abi) decides HOW each aggregate crosses the
# boundary; this module turns that decision into IR, mirroring clang's
# lowering for the target the classifier picked:
#
#   PARAM  AbiCoerce  -> alloca the struct, store fields, load it back AS
#                        the coerce type (iN / float / [n x T]), pass the
#                        loaded value.
#          AbiIndirect-> alloca the struct, store fields, pass the pointer
#                        (stamped `byval` when the ABI wants a caller copy).
#   RETURN AbiCoerce  -> the extern returns the coerce type; store it into
#                        a struct-typed alloca, reload each field, re-box.
#          AbiSret    -> alloca the struct, pass its pointer as hidden arg 0
#                        with `sret`; the call returns void; reload + re-box.
#
# HAZARD (#923): an LLVM `Type*`/`Value*` must never enter the Perceus RC
# regime — a dropped handle deref's a raw LLVM pointer and corrupts. Every
# handle here is bound by a `let` whose RHS is a native-prim call (kaic1
# excludes those binders) or lives in a C `llvm_buf`; none rides a kaikai
# list/record/tuple. The struct LLVM types are recreated from the KFfiField
# list on demand (LLVM dedups identical struct types, so the recreated type
# IS the one the alloca used) — the kinds travel, never the handle.

import compiler.util
import compiler.kir
import compiler.native_prims
import compiler.emit_native_fn
import compiler.emit_native_ops
import compiler.emit_native_abi

# The LLVM struct type for a struct-by-value FFI type: a non-packed struct
# over each field's LLVM type (recursive for nested structs).
#[doc("The LLVM struct type mirroring a struct-by-value FFI type's C layout.")]
pub fn nstruct_llvm_type(ctx: Handle, fields: [KFfiField]) : Handle = {
  let elems = llvm_buf_new()
  nstruct_elem_types(ctx, fields, elems)
  let t = llvm_struct_type(native_ctx_m(ctx), elems)
  llvm_buf_free(elems)
  t
}

fn nstruct_elem_types(ctx: Handle, fields: [KFfiField], elems: Handle) : Unit = match fields {
  [] -> ()
  [KFF(_, k), ...rest] -> {
    # Capture the field type in a `let` before pushing (handle-binder
    # exclusion): a Type* passed inline as a call arg is RC-clobbered by
    # the type-blind kaic1. Same rule holds throughout this module.
    let ft = nstruct_field_llvm_type(ctx, k)
    llvm_buf_push(elems, ft)
    nstruct_elem_types(ctx, rest, elems)
  }
}

# The LLVM type of one struct FIELD at its exact C width — the same
# scalar-width map the shim uses, plus nested structs.
fn nstruct_field_llvm_type(ctx: Handle, k: KFfiKind) : Handle = match k {
  KFfiInt        -> native_ctx_i64t(ctx)
  KFfiReal       -> native_ctx_f64t(ctx)
  KFfiBool       -> native_ctx_i32t(ctx)
  KFfiChar       -> native_ctx_i32t(ctx)
  KFfiFixed(bits, _, isf) ->
    if isf { llvm_float_type(native_ctx_m(ctx)) }
    else { llvm_int_type(native_ctx_m(ctx), bits) }
  KFfiFixedVal(bits, _) -> llvm_int_type(native_ctx_m(ctx), bits)
  KFfiStruct(fs) -> nstruct_llvm_type(ctx, fs)
  _              -> native_ctx_i64t(ctx)
}

# The LLVM type of one ABI slot (an eightbyte / register slot).
fn nabi_slot_type(ctx: Handle, s: AbiSlot) : Handle = match s {
  ASInt(bits) -> llvm_int_type(native_ctx_m(ctx), bits)
  ASF32       -> llvm_float_type(native_ctx_m(ctx))
  ASF64       -> native_ctx_f64t(ctx)
}

# The LLVM arg/return type a coerced aggregate crosses as. One slot is the
# bare scalar; several become `[n x T]` (AAPCS64 HFA / GPR pair) or a
# literal struct `{ T0, T1 }` (SysV two-eightbyte mixed classes).
#[doc("The LLVM arg/return type a coerced aggregate crosses as (scalar, [n x T], or literal struct).")]
pub fn nabi_coerce_type(ctx: Handle, slots: [AbiSlot], as_array: Bool) : Handle = match slots {
  [s]         -> nabi_slot_type(ctx, s)
  _           -> if as_array {
                   let et = nabi_slot_type_first(ctx, slots)
                   llvm_array_type(et, list_length(slots))
                 } else { nabi_slot_struct_type(ctx, slots) }
}

fn nabi_slot_type_first(ctx: Handle, slots: [AbiSlot]) : Handle = match slots {
  [s, ..._] -> nabi_slot_type(ctx, s)
  []        -> native_ctx_i64t(ctx)
}

fn nabi_slot_struct_type(ctx: Handle, slots: [AbiSlot]) : Handle = {
  let elems = llvm_buf_new()
  nabi_push_slot_types(ctx, slots, elems)
  let t = llvm_struct_type(native_ctx_m(ctx), elems)
  llvm_buf_free(elems)
  t
}

fn nabi_push_slot_types(ctx: Handle, slots: [AbiSlot], elems: Handle) : Unit = match slots {
  [] -> ()
  [s, ...rest] -> {
    let st = nabi_slot_type(ctx, s)
    llvm_buf_push(elems, st)
    nabi_push_slot_types(ctx, rest, elems)
  }
}

# --- param marshalling ------------------------------------------------

# Materialise a boxed struct param into an alloca of the real struct type,
# storing each field (read from its box, narrowed to its C width) through a
# struct-GEP. Returns the struct pointer — the base every param pass reads.
#[doc("Alloca a struct arg and store each boxed field; returns the struct pointer.")]
pub fn nstruct_fill_arg(ctx: Handle, fields: [KFfiField], boxed: Handle) : Handle / Console = {
  let sty = nstruct_llvm_type(ctx, fields)
  let slot = llvm_build_alloca_entry(ctx, sty, "ffi.arg")
  nstruct_store_fields(ctx, fields, boxed, sty, slot, 0)
  slot
}

fn nstruct_store_fields(ctx: Handle, fields: [KFfiField], boxed: Handle,
                        sty: Handle, slot: Handle, idx: Int) : Unit / Console = match fields {
  [] -> ()
  [KFF(fname, fk), ...rest] -> {
    let nm = llvm_build_global_string(native_ctx_b(ctx), fname)
    let fbox = ncall_sig2(ctx, "kaix_field_borrow", native_ctx_ptrt(ctx),
                          native_ctx_ptrt(ctx), native_ctx_ptrt(ctx), boxed, nm)
    let dst = llvm_build_struct_gep(native_ctx_b(ctx), sty, slot, idx)
    nstruct_store_field(ctx, fk, fbox, dst)
    nstruct_store_fields(ctx, rest, boxed, sty, slot, idx + 1)
  }
}

# Write one boxed field into its struct-GEP address. A nested struct field
# is stored INLINE — GEP addresses the sub-struct within the parent's
# storage, and its own fields recurse into it (NOT a pointer store: the
# child struct is not a separate object at the C ABI).
fn nstruct_store_field(ctx: Handle, k: KFfiKind, fbox: Handle, dst: Handle) : Unit / Console = match k {
  KFfiStruct(nfs) -> {
    let nsty = nstruct_llvm_type(ctx, nfs)
    nstruct_store_fields(ctx, nfs, fbox, nsty, dst, 0)
  }
  _ -> {
    let raw = nstruct_unbox_field(ctx, k, fbox)
    llvm_build_store(native_ctx_b(ctx), raw, dst)
  }
}

# Box -> raw C-width scalar value for one non-struct struct field.
fn nstruct_unbox_field(ctx: Handle, k: KFfiKind, fbox: Handle) : Handle / Console = match k {
  KFfiInt  -> ncall_sig1(ctx, "kaix_int_field", native_ctx_i64t(ctx), native_ctx_ptrt(ctx), fbox)
  KFfiReal -> ncall_sig1(ctx, "kaix_real_field", native_ctx_f64t(ctx), native_ctx_ptrt(ctx), fbox)
  KFfiBool -> ncall_sig1(ctx, "kaix_bool_field", native_ctx_i32t(ctx), native_ctx_ptrt(ctx), fbox)
  KFfiChar -> ncall_sig1(ctx, "kaix_to_char", native_ctx_i32t(ctx), native_ctx_ptrt(ctx), fbox)
  KFfiFixed(bits, _, isf) ->
    if isf {
      let r = ncall_sig1(ctx, "kaix_real_field", native_ctx_f64t(ctx), native_ctx_ptrt(ctx), fbox)
      llvm_build_fpcast(native_ctx_b(ctx), r, llvm_float_type(native_ctx_m(ctx)))
    } else {
      let i = ncall_sig1(ctx, "kaix_int_field", native_ctx_i64t(ctx), native_ctx_ptrt(ctx), fbox)
      llvm_build_trunc(native_ctx_b(ctx), i, llvm_int_type(native_ctx_m(ctx), bits))
    }
  KFfiFixedVal(bits, _) -> {
    let i = ncall_sig1(ctx, "kaix_fixed_val_field", native_ctx_i64t(ctx), native_ctx_ptrt(ctx), fbox)
    llvm_build_trunc(native_ctx_b(ctx), i, llvm_int_type(native_ctx_m(ctx), bits))
  }
  _ -> nemit_null(ctx)
}

# Load the coerce-typed value of a filled struct arg: reinterpret the
# alloca as the coerce type (a plain typed load — the pointer is the same
# storage) and load. This is the register-class value the extern takes.
#[doc("Load a filled struct alloca back as its ABI coerce type, for a register-class param.")]
pub fn nstruct_load_coerced(ctx: Handle, slot: Handle, coerce_ty: Handle) : Handle / Console =
  llvm_build_load(native_ctx_b(ctx), coerce_ty, slot)

# --- return marshalling ----------------------------------------------

# Re-box a struct RETURN sitting in a struct-typed alloca into a fresh
# KAI_RECORD. Each field is loaded via struct-GEP, widened + boxed, then
# `nemit_record_call` builds the record (it frees the two buffers).
#[doc("Re-box a struct return (in a struct-typed alloca) into a fresh KAI_RECORD.")]
pub fn nstruct_rebox_from_slot(ctx: Handle, fields: [KFfiField], sty: Handle, slot: Handle) : Handle / Console = {
  let fieldbuf = llvm_buf_new()
  let namebuf  = llvm_buf_new()
  nstruct_rebox_fields(ctx, fields, sty, slot, fieldbuf, namebuf, 0)
  nemit_record_call(ctx, fieldbuf, namebuf)
}

fn nstruct_rebox_fields(ctx: Handle, fields: [KFfiField], sty: Handle, slot: Handle,
                        fieldbuf: Handle, namebuf: Handle, idx: Int) : Unit / Console = match fields {
  [] -> ()
  [KFF(fname, fk), ...rest] -> {
    let dst = llvm_build_struct_gep(native_ctx_b(ctx), sty, slot, idx)
    let boxed = nstruct_rebox_field(ctx, fk, dst)
    let nv = llvm_build_global_string(native_ctx_b(ctx), fname)
    llvm_buf_push(fieldbuf, boxed)
    llvm_buf_push(namebuf, nv)
    nstruct_rebox_fields(ctx, rest, sty, slot, fieldbuf, namebuf, idx + 1)
  }
}

# Load one field from its struct-GEP address at its C width, widen, and
# box. A nested struct field re-boxes recursively (its GEP address IS the
# nested struct's storage).
fn nstruct_rebox_field(ctx: Handle, k: KFfiKind, dst: Handle) : Handle / Console = match k {
  KFfiInt -> {
    let v = llvm_build_load(native_ctx_b(ctx), native_ctx_i64t(ctx), dst)
    ncall_sig1(ctx, "kaix_int", native_ctx_ptrt(ctx), native_ctx_i64t(ctx), v)
  }
  KFfiReal -> {
    let v = llvm_build_load(native_ctx_b(ctx), native_ctx_f64t(ctx), dst)
    ncall_sig1(ctx, "kaix_real", native_ctx_ptrt(ctx), native_ctx_f64t(ctx), v)
  }
  KFfiBool -> {
    let v = llvm_build_load(native_ctx_b(ctx), native_ctx_i32t(ctx), dst)
    ncall_sig1(ctx, "kaix_bool", native_ctx_ptrt(ctx), native_ctx_i32t(ctx), v)
  }
  KFfiChar -> {
    let v = llvm_build_load(native_ctx_b(ctx), native_ctx_i32t(ctx), dst)
    ncall_sig1(ctx, "kaix_char", native_ctx_ptrt(ctx), native_ctx_i32t(ctx), v)
  }
  KFfiFixed(bits, signed, isf) -> nstruct_rebox_fixed(ctx, bits, signed, isf, dst)
  KFfiFixedVal(bits, signed) -> nstruct_rebox_fixed_val(ctx, bits, signed, dst)
  KFfiStruct(nfs) -> {
    let nsty = nstruct_llvm_type(ctx, nfs)
    nstruct_rebox_from_slot(ctx, nfs, nsty, dst)
  }
  _ -> nemit_call0(ctx, "kaix_unit")
}

# Load a fixed-width field at its EXACT C width (an `iN` load — a wider
# load would read past the field into neighbouring struct bytes, the
# `0xFF404040`-for-a-u8 bug), then widen to the i64/f64 box payload.
fn nstruct_rebox_fixed(ctx: Handle, bits: Int, signed: Bool, isf: Bool, dst: Handle) : Handle / Console =
  if isf {
    let r = llvm_build_load(native_ctx_b(ctx), llvm_float_type(native_ctx_m(ctx)), dst)
    let w = llvm_build_fpcast(native_ctx_b(ctx), r, native_ctx_f64t(ctx))
    ncall_sig1(ctx, "kaix_real", native_ctx_ptrt(ctx), native_ctx_f64t(ctx), w)
  } else {
    let r = llvm_build_load(native_ctx_b(ctx), llvm_int_type(native_ctx_m(ctx), bits), dst)
    let w = if signed { llvm_build_sext(native_ctx_b(ctx), r, native_ctx_i64t(ctx)) }
            else { llvm_build_zext(native_ctx_b(ctx), r, native_ctx_i64t(ctx)) }
    ncall_sig1(ctx, "kaix_int", native_ctx_ptrt(ctx), native_ctx_i64t(ctx), w)
  }

# A KFfiFixed field always widens to the box's i64/f64 payload; the field
# storage already holds the exact C width, so the struct-GEP load reads iN
# and we sext/zext to i64. (The fixed-width scalar path in the shim does
# the same; here the load type must match the field's declared width.)
fn nstruct_rebox_fixed_val(ctx: Handle, bits: Int, signed: Bool, dst: Handle) : Handle / Console = {
  let r = llvm_build_load(native_ctx_b(ctx), llvm_int_type(native_ctx_m(ctx), bits), dst)
  let w = if signed { llvm_build_sext(native_ctx_b(ctx), r, native_ctx_i64t(ctx)) }
          else { llvm_build_zext(native_ctx_b(ctx), r, native_ctx_i64t(ctx)) }
  let ctor = if bits == 32 { if signed { "kaix_int32" } else { "kaix_uint32" } } else { "kaix_uint64" }
  ncall_sig1(ctx, ctor, native_ctx_ptrt(ctx), native_ctx_i64t(ctx), w)
}

# Store a coerce-typed return value into a struct-typed alloca (the reverse
# of the param load): the extern returned `coerce_ty`, we stash it in a
# struct slot so the per-field re-box reads real field offsets. Returns the
# struct alloca.
#[doc("Stash a coerce-typed struct return into a struct-typed alloca for per-field re-box.")]
pub fn nstruct_stash_coerced(ctx: Handle, sty: Handle, coerce_ty: Handle, raw: Handle) : Handle / Console = {
  let slot = llvm_build_alloca_entry(ctx, sty, "ffi.ret")
  llvm_build_store(native_ctx_b(ctx), raw, slot)
  slot
}
