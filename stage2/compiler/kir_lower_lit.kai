# compiler/kir_lower_lit.kai ŌĆö literal-pattern lowering for `match`.
#
# A `match` whose arms discriminate by LITERAL (`match n { 0 -> ..; 1 ->
# ..; _ -> .. }`, or `'c'` / `"s"` / `true` / `false`) cannot ride the
# variant tag-switch the rest of `lower_match` uses: a `PLit` is not a
# variant, so `arm_tag` returns -1 for every literal arm ŌĆö they all
# collapse into the single default block, and only the FIRST default body
# survives (the rest, plus the catch-all bind, vanish, leaving an empty
# `KSwitch` that segfaults the native backend). They need an EQUALITY
# DECISION TREE ŌĆö the same fail-chain the C-direct (`emit_pat_test`'s
# `kai_op_eq` arm) and list-match (`kir_lower_match.kai`) build.
#
# This module owns the PURE half of that lowering: emitting one literal
# arm's equality test + catch-all bind into the block under construction,
# returning the fail label the next arm reopens. Like `kir_lower_match`,
# it never recurses into `lower_expr` (the arm BODY is lowered by the
# walk's `lower_lit_match` driver in the Expr-SCC `kir_lower_walk`).

import compiler.ast
import compiler.kir
import compiler.kir_lower
import compiler.kir_lower_match

# A `match` is a LITERAL match iff any arm pattern is a `PLit`. The typer
# guarantees a homogeneous scrutinee, so literal arms never mix with
# variant/list arms; a trailing `_`/binder catch-all may still follow
# (handled as an unconditional arm terminating the fail chain). List
# patterns are dispatched FIRST in `lower_match`, so a `PList` never reaches
# here ŌĆö only `PLit` plus its catch-all.
pub fn match_is_literal(arms: [Arm]) : Bool = match arms {
  [] -> false
  [Arm(p, _, _), ...rest] -> match p.pkind {
    PLit(_) -> true
    _       -> match_is_literal(rest)
  }
}

# A non-literal arm in a literal match (a trailing `_`, a whole-value
# binder, a hole, or an as-pattern). It matches unconditionally, so it
# terminates the chain ŌĆö no test, just bind-the-whole-scrutinee where a
# name is present.
pub fn lit_arm_is_catchall(p: Pattern) : Bool = match p.pkind {
  PLit(_) -> false
  _       -> true
}

# Emit the equality test (or unconditional bind) for one arm against
# `scrv`, sealing the current block so a match flows to `body_lbl` and a
# mismatch to a fresh fail label. The returned state is reopened at
# `body_lbl` (ready for the body); the returned fail label is where the
# caller lowers the next arm. A catch-all arm emits no test (binds the
# whole scrutinee, branches straight to the body) and its "fail" label is
# unreachable. Mirror of `lm_emit_arm` for the literal shape.
pub fn lit_emit_arm(p: Pattern, scrv: KVal, body_lbl: String,
                    st: LowerSt) : LMArm / Console = match p.pkind {
  PLit(lit) -> match ls_fresh_label(st) { LSLabel(fail_lbl, st1) -> {
    let st2 = lit_emit_test(lit, scrv, body_lbl, fail_lbl, st1)
    LMArm(reopen(st2, body_lbl), fail_lbl)
  } }
  _ -> {
    let st1 = lit_bind_whole(p, scrv, st)
    let st2 = ls_seal(st1, KBr(body_lbl, KAt(p.line, p.col)), body_lbl)
    LMArm(reopen(st2, body_lbl), body_lbl)
  }
}

# `condbr (kai_eq_raw scr lit) ? body_lbl : fail_lbl`. The literal lowers to
# its KIR atom (`KIntV`/`KBoolV`/`KCharV`/`KStrV`), the equality through the
# non-consuming `kai_eq_raw` shim ŌĆö a boxed-Bool predicate that does NOT
# consume the scrutinee (the C-direct oracle uses the non-consuming
# `kai_op_eq`; `kaix_eq` / the `==` prim CONSUMES both operands and would
# decref the scrutinee shared across the remaining arms). The immortal Bool
# singleton needs no drop, exactly like the cons/nil predicates.
fn lit_emit_test(lit: Expr, scrv: KVal, body_lbl: String,
                 fail_lbl: String, st: LowerSt) : LowerSt / Console =
  match bind_op(st, KPrim("kai_eq_raw", [scrv, lit_atom(lit)]), KAt(lit.line, lit.col)) {
    LRes(cond, st1) -> ls_seal(st1, KCondBr(cond, body_lbl, fail_lbl, KAt(lit.line, lit.col)), fail_lbl)
  }

# The KIR atom for a literal pattern's expression. The typer guarantees a
# `PLit` wraps a literal-shaped expr (Int / Bool / Char / String / Real);
# a non-literal here is a typer invariant violation ŌĆö lower it to unit so
# the equality is well-formed but always false (loud divergence vs the
# oracle catches it, never a silent miscompile).
pub fn lit_atom(lit: Expr) : KVal = match lit.kind {
  EInt(n)       -> KIntV(n)
  EBool(b)      -> KBoolV(b)
  EChar(c)      -> KCharV(c)
  EStr(span, _) -> KStrV(span)
  EReal(r, _)   -> KRealV(r)
  EFixed(span, ty) -> KFixedV(span, ty)
  _             -> KUnitV
}

# Bind a catch-all arm's name (a whole-value binder or as-pattern) to the
# scrutinee. PWild / PHole bind nothing. The KIR `KLet` aliases the slot ŌĆö
# it never increfs (refcounting rides KRC nodes), matching `lm_bind_whole`.
fn lit_bind_whole(p: Pattern, scrv: KVal, st: LowerSt) : LowerSt = match p.pkind {
  PBind(name)  -> lit_bind_name(name, scrv, p, st)
  PAs(name, _) -> lit_bind_name(name, scrv, p, st)
  _            -> st
}

fn lit_bind_name(name: String, scrv: KVal, p: Pattern, st: LowerSt) : LowerSt =
  ls_emit(st, KLet(name, SBoxed, KLitOp(scrv), KAt(p.line, p.col)))
