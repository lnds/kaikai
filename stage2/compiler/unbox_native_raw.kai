# compiler/unbox_native_raw.kai — the NATIVE-backend strict raw-binder
# predicate (#1110).
#
# The unbox pass (`seed_variant_int_binders`) seeds a kind-1 Int arm binder
# `MUnboxed` so its reads lower to a raw `i64`. The C oracle's re-box border is
# TOTAL — it re-boxes a raw value at every tagged consumer — so it can seed a
# binder raw whenever it is not read via interp / a captured lambda. The NATIVE
# load-border is NOT total: it re-boxes a raw register only where a value flows
# through `nemit_load_reg_boxed`, not at every tagged consumer inline. So under
# the native backend the same binder is raw ONLY in the shapes the native
# lowers raw-safe, decided here.
#
# This is the ONE rawness verdict for a native arm binder: it governs the
# `unbox` mode, and `bind_slot_kslot` reads that mode for the register's KSlot,
# so mode and KSlot can never diverge — the classifier drift #1110 traced to
# two independent verdicts of the same binder's rawness.
#
# Split into its own module (not folded into the `unbox.kai` monolith) so the
# analysis carries its own grade and the import graph stays acyclic: it reads
# `compiler.ast` + the fn registry (`compiler.fnreg`), and `unbox` imports IT.

import compiler.ast
import compiler.fnreg

# True iff EVERY use of the kind-1 Int arm binder `nm` in `e` is a shape the
# native backend lowers raw-safe: an operand of a raw-arith / comparison
# `EBinop` whose SIBLING operand is itself a raw-Int form (an `EVar` or an Int
# literal), so the emitter lowers the WHOLE binop raw (`icmp`/`iadd` over two
# raw i64), never the tagged `kaix_eq` shim that would read `nm` as a
# `KaiValue *`. This is the READ-side use that drives the rb-tree descent win
# (`k < kx` → `nemit_proj_slot` reads the key `.i64` inline). The WRITE-side
# use is also raw-safe: `nm` as a direct argument of a variant constructor in
# a kind-1 Int slot position (the rebuild `RBNode(..,kx,..)`) — the ctor's
# reuse-in-place slot init lowers that `SIInt64` through `nemit_atom_raw`,
# which loads `nm` at its OWN register slot (raw i64 direct, boxed unbox-
# borrowed), so a raw binder lands in the raw slot with no deref hazard. `cis`
# resolves the constructed ctor's Int-slot flags for that check, and carries
# the same builtin-tag guard as `typed_inits` (`build_ctor_int_slots`), so a
# mixed-writer ctor is never marked raw here. A third modelled consumer:
# `nm` as a DIRECT arg of a direct call whose callee param at that position
# is RAW (the UFnSig mask the raw-signature classifier produced, the same
# verdict the KIR call lowering reads) — the call site materialises each
# arg at its param slot, so a raw register passes straight through. Any
# other use — a field read, an index, a pipe, a mixed-operand compare, a
# nested-match pattern — is boxed on the native's non-total border, so the
# binder stays boxed. Conservative by exclusion: an unmodelled form forces
# boxed. STRICTER than the C oracle's mode-slave seeding, which the
# native's non-total load-border cannot match.
pub fn native_arm_binder_raw_safe(nm: String, e: Expr, cis: [CtorIntSlots], fns: [EFn]) : Bool / Console = match e.kind {
  EUnit -> false
  _     -> nab_uses_ok(nm, e, cis, fns)
}

fn nab_uses_ok(nm: String, e: Expr, cis: [CtorIntSlots], fns: [EFn]) : Bool / Console = match e.kind {
  EVar(n)          -> n != nm
  EInt(_)          -> true
  EReal(_, _)      -> true
  EBinop(op, l, r) ->
    if nab_op_is_raw(op) and (nab_is_var(nm, l) or nab_is_var(nm, r)) {
      nab_operand(nm, l, cis, fns) and nab_operand(nm, r, cis, fns)
    } else { nab_uses_ok(nm, l, cis, fns) and nab_uses_ok(nm, r, cis, fns) }
  EUnop(_, x)      -> nab_uses_ok(nm, x, cis, fns)
  EIf(c, t, oe)    -> nab_uses_ok(nm, c, cis, fns) and nab_uses_ok(nm, t, cis, fns) and nab_opt(nm, oe, cis, fns)
  EBlock(ss, tl)   -> nab_stmts(nm, ss, cis, fns) and nab_opt(nm, tl, cis, fns)
  ECall(f, xs)     -> match nab_ctor_flags(f, cis) {
    Some(flags) -> nab_ctor_args_ok(nm, flags, xs, cis, fns)
    None        -> match nab_callee_raw_mask(nm, f, fns) {
      Some(mask) -> nab_call_args_ok(nm, mask, xs, cis, fns)
      None       -> not nab_mentions(nm, e)
    }
  }
  _                -> not nab_mentions(nm, e)
}

# `nm` in a variant-ctor call: safe as a DIRECT arg in a kind-1 Int slot
# (the `SIInt64` init stores the register raw); any other position recurses
# (and forces boxed on an unmodelled shape as usual). `flags` is consumed in
# lockstep with the args, so each arg sees its own slot's flag.
fn nab_ctor_args_ok(nm: String, flags: [Bool], xs: [Expr], cis: [CtorIntSlots], fns: [EFn]) : Bool / Console = match xs {
  []           -> true
  [x, ...rest] -> match flags {
    [f, ...fr] -> {
      let ok = if nab_is_var(nm, x) { f } else { nab_uses_ok(nm, x, cis, fns) }
      ok and nab_ctor_args_ok(nm, fr, rest, cis, fns)
    }
    # More args than declared slots: never raw here, but keep walking the
    # remaining args for other uses of `nm`.
    [] -> not nab_is_var(nm, x) and nab_uses_ok(nm, x, cis, fns) and nab_ctor_args_ok(nm, [], rest, cis, fns)
  }
}

# `nm` as a direct call arg: safe in a RAW param position (mask true — the
# call site passes the register at the param slot, no box mint); a boxed
# position or a non-var arg recurses. Mask and args walk in lockstep,
# mirroring `nab_ctor_args_ok`.
fn nab_call_args_ok(nm: String, mask: [Bool], xs: [Expr], cis: [CtorIntSlots], fns: [EFn]) : Bool / Console = match xs {
  []           -> true
  [x, ...rest] -> match mask {
    [m, ...mr] -> {
      let ok = if nab_is_var(nm, x) { m } else { nab_uses_ok(nm, x, cis, fns) }
      ok and nab_call_args_ok(nm, mr, rest, cis, fns)
    }
    [] -> not nab_is_var(nm, x) and nab_uses_ok(nm, x, cis, fns) and nab_call_args_ok(nm, [], rest, cis, fns)
  }
}

# The raw-param mask of a direct lowercase callee: an `EVar` head resolved
# through the SAME fn registry the raw-signature classifier filled, so the
# permit and the call lowering share one verdict. A shadowed or non-UFn
# head yields None (conservative). A raw binder feeding a call the KIR
# later takes indirect (locals-shadow) is still sound: the boxed-arg
# border re-boxes the raw register at the call, it just stops paying off.
fn nab_callee_raw_mask(nm: String, f: Expr, fns: [EFn]) : Option[[Bool]] = match f.kind {
  EVar(n) ->
    if n == nm { None }
    else { match efn_resolve(fns, n) {
      Some(EFn(_, _, _, Some(US(_, _, mask)))) -> Some(mask)
      _ -> None
    } }
  _ -> None
}

# The Int-slot flags of a constructor call head: an uppercase-initial `EVar`
# resolved through the same `CtorIntSlots` registry the seeding reads, so the
# permit and the ctor's write layout share one source. A ctor with no entry
# has no Int slots — `None` keeps the conservative path.
fn nab_ctor_flags(f: Expr, cis: [CtorIntSlots]) : Option[[Bool]] = match f.kind {
  EVar(n) -> match char_at(n, 0) {
    Some(c) -> if c >= 'A' and c <= 'Z' { nab_cis_lookup(cis, n) } else { None }
    None    -> None
  }
  _       -> None
}

fn nab_cis_lookup(m: [CtorIntSlots], target: String) : Option[[Bool]] = match m {
  []               -> None
  [CIS(n, fl), ...rest] -> if n == target { Some(fl) } else { nab_cis_lookup(rest, target) }
}

# The arith / comparison operators the native lowers to a raw `i`-family op
# over raw operands. Kept local (not imported from `unbox`) so the import graph
# stays acyclic — `unbox` imports this module, not the reverse.
fn nab_op_is_raw(op: String) : Bool =
  op == "+" or op == "-" or op == "*" or op == "/" or op == "%" or
  op == "<" or op == ">" or op == "<=" or op == ">=" or op == "==" or op == "!="

# A binop operand: `EVar(nm)` (the raw use) is safe iff its SIBLING is a
# raw-Int form; a non-`nm` operand must be a raw-Int form too (var / Int lit)
# for the whole binop to lower raw. Anything else keeps the binder boxed.
fn nab_operand(nm: String, e: Expr, cis: [CtorIntSlots], fns: [EFn]) : Bool / Console = match e.kind {
  EVar(_)    -> true
  EInt(_)    -> true
  EIntLit(_) -> true
  _          -> nab_uses_ok(nm, e, cis, fns)
}

fn nab_is_var(nm: String, e: Expr) : Bool = match e.kind { EVar(n) -> n == nm _ -> false }
fn nab_opt(nm: String, oe: Option[Expr], cis: [CtorIntSlots], fns: [EFn]) : Bool / Console = match oe { None -> true Some(e) -> nab_uses_ok(nm, e, cis, fns) }
fn nab_stmts(nm: String, ss: [Stmt], cis: [CtorIntSlots], fns: [EFn]) : Bool / Console = match ss {
  []           -> true
  [s, ...rest] -> nab_stmt(nm, s, cis, fns) and nab_stmts(nm, rest, cis, fns)
}
fn nab_stmt(nm: String, s: Stmt, cis: [CtorIntSlots], fns: [EFn]) : Bool / Console = match s {
  SExprStmt(e)    -> nab_uses_ok(nm, e, cis, fns)
  SLet(_, _, rhs) -> nab_uses_ok(nm, rhs, cis, fns)
  _               -> not nab_stmt_mentions(nm, s)
}

# Exhaustive mention walk (every sub-Expr AND nested match patterns) — the
# conservative catch-all for a form `nab_uses_ok` does not model. Unlike
# `scan_uses_expr` this descends into arm patterns, so a binder read in a
# nested match pattern still forces boxed.
fn nab_mentions(nm: String, e: Expr) : Bool / Console = match e.kind {
  EVar(n)              -> n == nm
  ECall(f, xs)         -> nab_mentions(nm, f) or nab_mentions_list(nm, xs)
  EIntrinsic(_, xs)    -> nab_mentions_list(nm, xs)
  EField(x, _)         -> nab_mentions(nm, x)
  EIndex(a, b)         -> nab_mentions(nm, a) or nab_mentions(nm, b)
  EBinop(_, a, b)      -> nab_mentions(nm, a) or nab_mentions(nm, b)
  EUnop(_, x)          -> nab_mentions(nm, x)
  EBang(x)             -> nab_mentions(nm, x)
  ELitUnit(x, _)       -> nab_mentions(nm, x)
  EIf(c, t, oe)        -> nab_mentions(nm, c) or nab_mentions(nm, t) or nab_mentions_opt(nm, oe)
  EMatch(s, arms)      -> nab_mentions(nm, s) or nab_mentions_arms(nm, arms)
  ELambda(_, b)        -> nab_mentions(nm, b)
  ERecordLit(_, fis)   -> nab_mentions_fields(nm, fis)
  EList(els)           -> nab_mentions_elems(nm, els)
  ERange(a, b, ob)     -> nab_mentions(nm, a) or nab_mentions(nm, b) or nab_mentions_opt(nm, ob)
  EBlock(ss, tl)       -> nab_mentions_stmts(nm, ss) or nab_mentions_opt(nm, tl)
  EPipe(a, b)          -> nab_mentions(nm, a) or nab_mentions(nm, b)
  EMapPipe(a, b)       -> nab_mentions(nm, a) or nab_mentions(nm, b)
  EFlatMapPipe(a, b)   -> nab_mentions(nm, a) or nab_mentions(nm, b)
  EFilterPipe(a, b)    -> nab_mentions(nm, a) or nab_mentions(nm, b)
  _                    -> false
}
fn nab_mentions_list(nm: String, es: [Expr]) : Bool / Console = match es {
  []        -> false
  [e, ...r] -> nab_mentions(nm, e) or nab_mentions_list(nm, r)
}
fn nab_mentions_opt(nm: String, oe: Option[Expr]) : Bool / Console = match oe {
  None    -> false
  Some(e) -> nab_mentions(nm, e)
}
fn nab_mentions_arms(nm: String, arms: [Arm]) : Bool / Console = match arms {
  []        -> false
  [a, ...r] -> (match a { Arm(p, g, b) -> nab_pat(nm, p) or nab_mentions_opt(nm, g) or nab_mentions(nm, b) }) or nab_mentions_arms(nm, r)
}
fn nab_mentions_fields(nm: String, fis: [FieldInit]) : Bool / Console = match fis {
  []        -> false
  [f, ...r] -> (match f { FI(_, e) -> nab_mentions(nm, e) }) or nab_mentions_fields(nm, r)
}
fn nab_mentions_elems(nm: String, els: [ListElem]) : Bool / Console = match els {
  []         -> false
  [el, ...r] -> (match el { ElPlain(e) -> nab_mentions(nm, e) ElSpread(e) -> nab_mentions(nm, e) }) or nab_mentions_elems(nm, r)
}
fn nab_mentions_stmts(nm: String, ss: [Stmt]) : Bool / Console = match ss {
  []        -> false
  [s, ...r] -> nab_stmt_mentions(nm, s) or nab_mentions_stmts(nm, r)
}
fn nab_stmt_mentions(nm: String, s: Stmt) : Bool / Console = match s {
  SExprStmt(e)                -> nab_mentions(nm, e)
  SLet(p, _, rhs)             -> nab_pat(nm, p) or nab_mentions(nm, rhs)
  SVar(_, _, rhs, _, _)       -> nab_mentions(nm, rhs)
  SAssert(e, oe)              -> nab_mentions(nm, e) or nab_mentions_opt(nm, oe)
  SIndexAssign(b, i, v, _, _) -> nab_mentions(nm, b) or nab_mentions(nm, i) or nab_mentions(nm, v)
  _                           -> false
}
fn nab_pat(nm: String, p: Pattern) : Bool / Console = match p.pkind {
  PBind(n)              -> n == nm
  PLit(e)               -> nab_mentions(nm, e)
  PList(subs, orest)    -> nab_pats(nm, subs) or (match orest { Some(n) -> n == nm None -> false })
  PVariant(_, subs)     -> nab_pats(nm, subs)
  PVariantRecord(_, fs) -> nab_pfields(nm, fs)
  PRecord(fs)           -> nab_pfields(nm, fs)
  PAs(n, inner)         -> n == nm or nab_pat(nm, inner)
  PNarrow(n, _)         -> n == nm
  _                     -> false
}
fn nab_pats(nm: String, ps: [Pattern]) : Bool / Console = match ps {
  []        -> false
  [p, ...r] -> nab_pat(nm, p) or nab_pats(nm, r)
}
fn nab_pfields(nm: String, fs: [PField]) : Bool / Console = match fs {
  []        -> false
  [f, ...r] -> (match f { PField(_, sub, _) -> nab_pat(nm, sub) }) or nab_pfields(nm, r)
}
