# compiler/parse.kai — the kaikai parser: LL(1)-with-bookkeeping
# recursive descent over the token stream, producing the syntactic
# AST (Expr / Stmt / Pattern / TypeExpr / Decl) defined in
# compiler/ast.kai.
#
# Extracted from main.kai under issue #677 Phase 1h (sub-lane H2),
# the last of the parse-extraction sequence. H0 shrank the public
# surface, H1a pulled the shared string/list utils into util.kai, and
# H1 pulled the refinement-discharge engine into refinements.kai so
# the residual range here is parser-only.
#
# What this module owns
#
# - Parser state (the immutable Parser record) + the PXxx workspace
#   progress types (PExpr / PStmt / PPat / PDecl / …).
# - Parser primitives (p_advance / p_peek / p_at / p_expect / …).
# - Literal decoders (decode_int / decode_real / decode_char).
# - The full recursive-descent grammar: expressions (precedence
#   climbing), statements, patterns, type expressions + effect rows,
#   and every declaration form (fn / let / type / effect / protocol /
#   impl / attribute / test / bench / check / import / extern "C").
# - Parse-time sugar desugaring: pipe-placeholder, multi-scrutinee
#   match, anonymous-record / positional-tuple field markers,
#   lambda-block params, regex-sigil literals.
# - Contract parsing (the Parser-coupled half): Contracts,
#   parse_contracts_loop, check_pred_not_false, maybe_wrap_pure. The
#   pure desugar half lives in compiler/refinements.kai.
# - extern "C" ABI validation (validate_extern_c_decl + helpers).
# - Type-param kind/bounds encoding (tp_make / tp_*_bounds).
# - Program entry: parse_program / parse_program_loop / PParser.
#
# Public surface (4 pub fns + 2 pub types)
#
# - parse_program — the driver entry point: file + src + tokens -> AST.
# - parse_interp_expr — re-parse a single `#{...}` interpolation body;
#   used by the emitter / typer / codegen (and the Perceus interp
#   rewriter, which re-tokenises separately for span mapping).
# - tp_bounds_of / tp_has_bounds / tp_strip_bounds — type-param bounds
#   decoders, read by the typer's bound renderer.
# - PParser — parse_program's result record. Parser is pub only
#   because PParser carries `p: Parser`; nothing else reaches for it.
#
# Cross-module dependencies
#
# - compiler.util — cat/concat_all, char_at_or_zero, list_is_empty,
#   has_interp.
# - compiler.chars — ch_is_digit / ch_is_alpha / ch_is_alnum.
# - compiler.diag — closest_name, diag_error_from_src.
# - compiler.lex — tokenize (for parse_interp_expr).
# - compiler.ast — the whole AST data model + mk_expr / mk_pat /
#   mk_ty, the field-marker sentinels, and tp_unit_suffix.
# - compiler.refinements — wrap_with_contracts (contract desugar) and
#   try_eval_pred (used by check_pred_not_false).
#
# What stays in main.kai
#
# - The AST dumper (`dump_*`, --ast): its display helpers
#   (type_expr_display / row_label_names / unit_expr_display) are
#   reused by typer/emitter diagnostics, so it waits until those
#   extract.
# - The resolver, typer, monomorphiser, Perceus pass, and both
#   emitters.
#
# Single-line `#[doc(...)]` only — kaic1 still consumes the
# concatenated bundle and does not accept triple-quoted strings
# inside attributes (#677 Phase 2 retires that constraint once
# separate compilation lands).

import compiler.util
import compiler.chars
import compiler.diag
import compiler.lex
import compiler.ast
import compiler.refinements

# ====================================================================
# parser state
# ====================================================================
#
# advanced and `had_error` possibly flipped. We don't carry a token
# index — `rest` is the unconsumed suffix of the token list, so
# p_advance is O(1) (takes tail). Peek-ahead uses list destructuring
# up to depth 3, which covers every lookahead stage 0 does.

pub type Parser = { file: String, src: String, rest: [Token], had_error: Bool,
                # m7b §1: trailing lambdas attach to Calls, but the
                # condition of `if` / `match` (and similar prefix
                # constructs that take an Expr followed by a `{`-block)
                # must not consume the `{` as a trailing lambda. This
                # flag is set to false while parsing such a cond and
                # restored when the cond parser finishes.
                allow_trailing_lambda: Bool }

# A result = a new parser plus an optional payload. `None` means the
# parser failed (had_error is set on `p`). This mirrors stage 0's
# error-then-stop style.

type PExpr   = { p: Parser, r: Option[Expr] }
type PStmt   = { p: Parser, r: Option[Stmt] }
type PPat    = { p: Parser, r: Option[Pattern] }
type PTy     = { p: Parser, r: Option[TypeExpr] }
type PDecl   = { p: Parser, r: Option[Decl] }
type PArm    = { p: Parser, r: Option[Arm] }
type PParam  = { p: Parser, r: Option[Param] }
type PFI     = { p: Parser, r: Option[FieldInit] }
type PVar    = { p: Parser, r: Option[Variant] }
type PFD     = { p: Parser, r: Option[FieldDecl] }
type PPF     = { p: Parser, r: Option[PField] }
type PEL     = { p: Parser, r: Option[ListElem] }

fn parser_new(file: String, src: String, toks: [Token]) : Parser =
  Parser { file: file, src: src, rest: toks, had_error: false, allow_trailing_lambda: true }

fn p_mark_err(p: Parser) : Parser =
  Parser { file: p.file, src: p.src, rest: p.rest, had_error: true,
           allow_trailing_lambda: p.allow_trailing_lambda }

fn p_advance(p: Parser) : Parser {
  match p.rest {
    [_, ...rest1] -> Parser { file: p.file, src: p.src, rest: rest1,
                              had_error: p.had_error,
                              allow_trailing_lambda: p.allow_trailing_lambda }
    [] -> p
  }
}

# A sentinel EOF token used when peeking past the list end. In practice
# the tokenizer always appends a TkEof, so we rarely hit this.
fn eof_tok() : Token = Token { kind: TkEof, line: 0, col: 0, start: 0, length: 0 }

fn p_peek(p: Parser) : Token {
  match p.rest {
    [t, ..._rs] -> t
    [] -> eof_tok()
  }
}

fn p_peek1(p: Parser) : Token {
  match p.rest {
    [_, t, ..._rs] -> t
    _ -> eof_tok()
  }
}

fn p_peek2(p: Parser) : Token {
  match p.rest {
    [_, _, t, ..._rs] -> t
    _ -> eof_tok()
  }
}

# Token-kind comparison by structural case (TkError is the only payload-
# carrying variant, and we never compare it for equality in the parser).
fn tk_is(a: TokKind, b: TokKind) : Bool {
  match a {
    TkEof        -> match b { TkEof -> true _ -> false }
    TkNewline    -> match b { TkNewline -> true _ -> false }
    TkAnd        -> match b { TkAnd -> true _ -> false }
    TkAs         -> match b { TkAs -> true _ -> false }
    TkAssert     -> match b { TkAssert -> true _ -> false }
    TkAxiom      -> match b { TkAxiom -> true _ -> false }
    TkBench      -> match b { TkBench -> true _ -> false }
    TkCase       -> match b { TkCase -> true _ -> false }
    TkCheck      -> match b { TkCheck -> true _ -> false }
    TkConst      -> match b { TkConst -> true _ -> false }
    TkEffect     -> match b { TkEffect -> true _ -> false }
    TkElse       -> match b { TkElse -> true _ -> false }
    TkEnsures    -> match b { TkEnsures -> true _ -> false }
    TkExtern     -> match b { TkExtern -> true _ -> false }
    TkFalse      -> match b { TkFalse -> true _ -> false }
    TkFn         -> match b { TkFn -> true _ -> false }
    TkFor        -> match b { TkFor -> true _ -> false }
    TkHandle     -> match b { TkHandle -> true _ -> false }
    TkIf         -> match b { TkIf -> true _ -> false }
    TkImpl       -> match b { TkImpl -> true _ -> false }
    TkImport     -> match b { TkImport -> true _ -> false }
    TkLet        -> match b { TkLet -> true _ -> false }
    TkMatch      -> match b { TkMatch -> true _ -> false }
    TkNot        -> match b { TkNot -> true _ -> false }
    TkOr         -> match b { TkOr -> true _ -> false }
    TkPriv       -> match b { TkPriv -> true _ -> false }
    TkProtocol   -> match b { TkProtocol -> true _ -> false }
    TkPub        -> match b { TkPub -> true _ -> false }
    TkRequires   -> match b { TkRequires -> true _ -> false }
    TkTest       -> match b { TkTest -> true _ -> false }
    TkTrue       -> match b { TkTrue -> true _ -> false }
    TkType       -> match b { TkType -> true _ -> false }
    TkUnitKw     -> match b { TkUnitKw -> true _ -> false }
    TkUse        -> match b { TkUse -> true _ -> false }
    TkVar        -> match b { TkVar -> true _ -> false }
    TkWhen       -> match b { TkWhen -> true _ -> false }
    TkWhere      -> match b { TkWhere -> true _ -> false }
    TkWith       -> match b { TkWith -> true _ -> false }
    TkInt        -> match b { TkInt -> true _ -> false }
    TkReal       -> match b { TkReal -> true _ -> false }
    TkComplex    -> match b { TkComplex -> true _ -> false }
    TkChar       -> match b { TkChar -> true _ -> false }
    TkString     -> match b { TkString -> true _ -> false }
    TkIdent      -> match b { TkIdent -> true _ -> false }
    TkUnderscore -> match b { TkUnderscore -> true _ -> false }
    TkLparen     -> match b { TkLparen -> true _ -> false }
    TkRparen     -> match b { TkRparen -> true _ -> false }
    TkLbracket   -> match b { TkLbracket -> true _ -> false }
    TkRbracket   -> match b { TkRbracket -> true _ -> false }
    TkLbrace     -> match b { TkLbrace -> true _ -> false }
    TkRbrace     -> match b { TkRbrace -> true _ -> false }
    TkComma      -> match b { TkComma -> true _ -> false }
    TkColon      -> match b { TkColon -> true _ -> false }
    TkColonEq    -> match b { TkColonEq -> true _ -> false }
    TkSemi       -> match b { TkSemi -> true _ -> false }
    TkDot        -> match b { TkDot -> true _ -> false }
    TkDotDot     -> match b { TkDotDot -> true _ -> false }
    TkEllipsis   -> match b { TkEllipsis -> true _ -> false }
    TkEq         -> match b { TkEq -> true _ -> false }
    TkArrow      -> match b { TkArrow -> true _ -> false }
    TkFatArrow   -> match b { TkFatArrow -> true _ -> false }
    TkPipe       -> match b { TkPipe -> true _ -> false }
    TkPipeApply  -> match b { TkPipeApply -> true _ -> false }
    TkBarBar     -> match b { TkBarBar -> true _ -> false }
    TkPipeQuestion -> match b { TkPipeQuestion -> true _ -> false }
    TkPlus       -> match b { TkPlus -> true _ -> false }
    TkMinus      -> match b { TkMinus -> true _ -> false }
    TkStar       -> match b { TkStar -> true _ -> false }
    TkSlash      -> match b { TkSlash -> true _ -> false }
    TkPercent    -> match b { TkPercent -> true _ -> false }
    TkEqEq       -> match b { TkEqEq -> true _ -> false }
    TkNeq        -> match b { TkNeq -> true _ -> false }
    TkLt         -> match b { TkLt -> true _ -> false }
    TkGt         -> match b { TkGt -> true _ -> false }
    TkLe         -> match b { TkLe -> true _ -> false }
    TkGe         -> match b { TkGe -> true _ -> false }
    TkBang       -> match b { TkBang -> true _ -> false }
    TkAt         -> match b { TkAt -> true _ -> false }
    TkDollar     -> match b { TkDollar -> true _ -> false }
    TkCaret      -> match b { TkCaret -> true _ -> false }
    TkHole       -> match b { TkHole -> true _ -> false }
    TkHoleName(_) -> match b { TkHoleName(_) -> true _ -> false }
    TkTodoBang   -> match b { TkTodoBang -> true _ -> false }
    TkPlusPlus   -> match b { TkPlusPlus -> true _ -> false }
    TkHashOpen   -> match b { TkHashOpen -> true _ -> false }
    TkRegex      -> match b { TkRegex -> true _ -> false }
    TkError(_)   -> false
  }
}

fn p_at(p: Parser, k: TokKind) : Bool = tk_is(p_peek(p).kind, k)

fn p_try_consume(p: Parser, k: TokKind) : Option[Parser] {
  if p_at(p, k) { Some(p_advance(p)) } else { None }
}

fn p_skip_newlines(p: Parser) : Parser {
  if p_at(p, TkNewline) { p_skip_newlines(p_advance(p)) } else { p }
}

# m7b §1: temporarily disable trailing-lambda attachment for the
# parser passed in (used by `if` / `match` cond parsing). Returns
# a parser identical except for the flag. The caller is expected
# to restore the original flag value after the cond parses by
# threading the flag back via `p_with_trailing_lambda(p, true)`.
fn p_with_trailing_lambda(p: Parser, allow: Bool) : Parser {
  Parser { file: p.file, src: p.src, rest: p.rest, had_error: p.had_error,
           allow_trailing_lambda: allow }
}

fn p_skip_newlines_and_semis(p: Parser) : Parser {
  if p_at(p, TkNewline) or p_at(p, TkSemi) { p_skip_newlines_and_semis(p_advance(p)) }
  else { p }
}

fn p_error(p: Parser, t: Token, msg: String) : Parser / Console {

  if p.had_error { p }
  else {
    diag_error_from_src(p.file, p.src, t.line, t.col, msg)
    p_mark_err(p)
  }
}

fn p_error_here(p: Parser, msg: String) : Parser / Console = p_error(p, p_peek(p), msg)

fn p_expect(p: Parser, k: TokKind, msg: String) : PExpr / Console {

  # PExpr is a misnomer — we just reuse the record structure. We return
  # an Expr-less PExpr; callers that need the consumed token use
  # p_expect_tok instead. This variant is a convenience for "advance
  # past a required delimiter".
  if p_at(p, k) { PExpr { p: p_advance(p), r: Some(mk_expr(EUnit, 0, 0)) } }
  else { PExpr { p: p_error_here(p, msg), r: None } }
}

# Same, but returns the consumed token in the Option payload slot (as an
# EStr carrying the raw span — caller decodes).
fn p_expect_tok(p: Parser, k: TokKind, msg: String) : Token {
  if p_at(p, k) { p_peek(p) }
  else { eof_tok() }
}

fn is_upper_ident(src: String, t: Token) : Bool {
  match char_at(src, t.start) {
    Some(c) -> c >= 'A' and c <= 'Z'
    None -> false
  }
}

fn tok_source(src: String, t: Token) : String = string_slice(src, t.start, t.length)

# ====================================================================
# literal decoders
# ====================================================================

fn decode_int_loop(s: String, i: Int, n: Int, acc: Int, neg: Bool) : Int {
  if i >= n { if neg { 0 - acc } else { acc } }
  else {
    match char_at(s, i) {
      None -> if neg { 0 - acc } else { acc }
      Some(c) -> {
        if c == '_' { decode_int_loop(s, i + 1, n, acc, neg) }
        else if ch_is_digit(c) {
          let d = char_to_int(c) - char_to_int('0')
          decode_int_loop(s, i + 1, n, acc * 10 + d, neg)
        } else {
          if neg { 0 - acc } else { acc }
        }
      }
    }
  }
}

fn decode_bin_loop(s: String, i: Int, n: Int, acc: Int) : Int {
  if i >= n { acc }
  else {
    match char_at(s, i) {
      None -> acc
      Some(c) -> {
        if c == '0' { decode_bin_loop(s, i + 1, n, acc * 2) }
        else if c == '1' { decode_bin_loop(s, i + 1, n, acc * 2 + 1) }
        else { acc }
      }
    }
  }
}

fn decode_int_after_sign(span: String, i: Int, n: Int, neg: Bool) : Int {
  # Detect 0x / 0b base prefixes; otherwise fall back to decimal.
  let has_prefix =
    if i + 1 < n {
      match char_at(span, i) {
        Some(c0) -> {
          if c0 == '0' {
            match char_at(span, i + 1) {
              Some(c1) -> c1 == 'x' or c1 == 'X' or c1 == 'b' or c1 == 'B'
              None -> false
            }
          } else { false }
        }
        None -> false
      }
    } else { false }
  if has_prefix {
    match char_at(span, i + 1) {
      Some(c1) -> {
        let is_hex = c1 == 'x' or c1 == 'X'
        let v = if is_hex { decode_hex_loop(span, i + 2, n, 0) }
                else { decode_bin_loop(span, i + 2, n, 0) }
        if neg { 0 - v } else { v }
      }
      None -> if neg { 0 } else { 0 }
    }
  } else {
    decode_int_loop(span, i, n, 0, neg)
  }
}

fn decode_int(span: String) : Int {
  let n = string_length(span)
  if n == 0 { 0 }
  else {
    match char_at(span, 0) {
      Some(c) -> if c == '-' { decode_int_after_sign(span, 1, n, true) }
                 else { decode_int_after_sign(span, 0, n, false) }
      None -> 0
    }
  }
}

fn strip_underscores_loop(s: String, i: Int, n: Int, acc: String) : String {
  if i >= n { acc }
  else {
    match char_at(s, i) {
      None -> acc
      Some(c) -> {
        if c == '_' { strip_underscores_loop(s, i + 1, n, acc) }
        else { strip_underscores_loop(s, i + 1, n, string_concat(acc, "#{c}")) }
      }
    }
  }
}

fn decode_real(span: String) : Real {
  let clean = strip_underscores_loop(span, 0, string_length(span), "")
  match string_to_real(clean) {
    Some(r) -> r
    None -> 0.0
  }
}

fn decode_char_escape(c: Char) : Char {
  match c {
    'n' -> '\n'
    't' -> '\t'
    'r' -> '\r'
    '\\' -> '\\'
    '\'' -> '\''
    '"' -> '"'
    '0' -> int_to_char(0)
    _ -> c
  }
}

fn decode_hex_loop(s: String, i: Int, n: Int, acc: Int) : Int {
  if i >= n { acc }
  else {
    match char_at(s, i) {
      None -> acc
      Some(c) -> {
        if c == '}' { acc }
        else {
          let v =
            if ch_is_digit(c) { char_to_int(c) - char_to_int('0') }
            else if c >= 'a' and c <= 'f' { char_to_int(c) - char_to_int('a') + 10 }
            else if c >= 'A' and c <= 'F' { char_to_int(c) - char_to_int('A') + 10 }
            else { 0 }
          decode_hex_loop(s, i + 1, n, acc * 16 + v)
        }
      }
    }
  }
}

# span is the raw char literal including surrounding quotes: 'a', '\n', '\u{2603}'
fn decode_char(span: String) : Char {
  let n = string_length(span)
  if n < 2 { int_to_char(0) }
  else {
    match char_at(span, 1) {
      None -> int_to_char(0)
      Some(c1) -> {
        if c1 == '\\' {
          match char_at(span, 2) {
            None -> int_to_char(0)
            Some(c2) -> {
              if c2 == 'u' {
                int_to_char(decode_hex_loop(span, 4, n - 1, 0))
              } else {
                decode_char_escape(c2)
              }
            }
          }
        } else {
          # Issue #744: a non-escape char literal body is a single
          # Unicode codepoint, possibly multi-byte UTF-8. `char_at`
          # returns only the first byte (`c1`); decode the full
          # codepoint that begins at byte offset 1 so `'á'`/`'▸'` lex
          # to their scalar value, not their UTF-8 lead byte. ASCII is
          # unchanged (a 1-byte sequence decodes to itself).
          int_to_char(string_cp_at(span, 1))
        }
      }
    }
  }
}

# ====================================================================
# precedence climbing: forward declarations
# ====================================================================
#
# These are implemented below. Listed here as a reading aid.
#  parse_expr   -> parse_pipe
#  parse_pipe   -> parse_or ("|>" parse_or)*
#  parse_or     -> parse_and ("or" parse_and)*
#  parse_and    -> parse_cmp ("and" parse_cmp)*
#  parse_cmp    -> parse_add (cmpop parse_add)?        (no chains)
#  parse_add    -> parse_mul ([+-] parse_mul)*
#  parse_mul    -> parse_unary ([*/%] parse_unary)*
#  parse_unary  -> ("-" | "not")? parse_postfix
#  parse_postfix-> parse_primary (call | field | index)*
#  parse_primary-> literal | ident | "(" expr ")" | if | match | block | record | list | lambda

fn op_of_tok(k: TokKind) : String {
  match k {
    TkPlus -> "+" TkMinus -> "-" TkStar -> "*" TkSlash -> "/"
    TkPercent -> "%" TkPlusPlus -> "++"
    TkEqEq -> "==" TkNeq -> "!=" TkLt -> "<" TkGt -> ">" TkLe -> "<=" TkGe -> ">="
    TkAnd -> "and" TkOr -> "or"
    _ -> "?"
  }
}

# ====================================================================
# expression parsing
# ====================================================================

fn ok_e(p: Parser, e: Expr) : PExpr = PExpr { p: p, r: Some(e) }
fn err_e(p: Parser) : PExpr = PExpr { p: p, r: None }
fn ok_s(p: Parser, s: Stmt) : PStmt = PStmt { p: p, r: Some(s) }
fn err_s(p: Parser) : PStmt = PStmt { p: p, r: None }
fn ok_p(p: Parser, x: Pattern) : PPat = PPat { p: p, r: Some(x) }
fn err_p(p: Parser) : PPat = PPat { p: p, r: None }
fn ok_t(p: Parser, x: TypeExpr) : PTy = PTy { p: p, r: Some(x) }
fn err_t(p: Parser) : PTy = PTy { p: p, r: None }
fn ok_d(p: Parser, x: Decl) : PDecl = PDecl { p: p, r: Some(x) }
fn err_d(p: Parser) : PDecl = PDecl { p: p, r: None }
fn ok_a(p: Parser, x: Arm) : PArm = PArm { p: p, r: Some(x) }
fn err_a(p: Parser) : PArm = PArm { p: p, r: None }
fn ok_pm(p: Parser, x: Param) : PParam = PParam { p: p, r: Some(x) }
fn err_pm(p: Parser) : PParam = PParam { p: p, r: None }
fn ok_fi(p: Parser, x: FieldInit) : PFI = PFI { p: p, r: Some(x) }
fn err_fi(p: Parser) : PFI = PFI { p: p, r: None }
fn ok_v(p: Parser, x: Variant) : PVar = PVar { p: p, r: Some(x) }
fn err_v(p: Parser) : PVar = PVar { p: p, r: None }
fn ok_fd(p: Parser, x: FieldDecl) : PFD = PFD { p: p, r: Some(x) }
fn err_fd(p: Parser) : PFD = PFD { p: p, r: None }
fn ok_pf(p: Parser, x: PField) : PPF = PPF { p: p, r: Some(x) }
fn err_pf(p: Parser) : PPF = PPF { p: p, r: None }
fn ok_el(p: Parser, x: ListElem) : PEL = PEL { p: p, r: Some(x) }
fn err_el(p: Parser) : PEL = PEL { p: p, r: None }

fn parse_expr(p: Parser) : PExpr / Console = parse_pipe(p)

# Parse a single expression from raw source — the shape every
# string-interpolation `#{...}` body takes. Tokenises, parses, and
# returns just the AST, hiding the PExpr workspace type from the
# emitter / typer / codegen callers (issue #677 phase 1h H0). This
# is the only parse entry point besides parse_program that downstream
# phases reach for; when parse.kai extracts it travels as `pub`.
pub fn parse_interp_expr(src: String) : Option[Expr] / Console {
  let toks = tokenize(src)
  let prs = parser_new("<interp>", src, toks)
  parse_expr(prs).r
}

fn parse_pipe(p: Parser) : PExpr / Console {

  let r = parse_or(p)
  match r.r {
    None -> r
    Some(lhs) -> parse_pipe_rest(r.p, lhs)
  }
}

# m7d §21 — outcome of a pipeline placeholder substitution attempt.
# `PPRPassthrough` keeps the legacy first-arg behaviour. The other
# two arms either return the substituted call expression (single `_`
# in the rhs args) or report a multiple-placeholder error.
type PPRResult
  = PPRPassthrough
  | PPRSubstituted(Expr, Parser)
  | PPRError(Parser)

fn try_pipe_placeholder(line: Int, col: Int, lhs: Expr, rhs: Expr, p: Parser) : PPRResult / Console {

  match rhs.kind {
    ECall(callee, args_) -> {
      let n = count_underscores(args_, 0)
      if n == 0 { PPRPassthrough }
      else if n > 1 {
        PPRError(p_error(p, p_peek(p),
          "multiple `_` in a `|>` call would evaluate the left-hand side more than once"))
      }
      else {
        # The substitution evaluates the lhs once via an immediate
        # lambda application: `((__pipe) => f(args[_ := __pipe]))(lhs)`.
        # Equivalent to a `let __pipe = lhs in f(...)` block but
        # composes through the existing lambda machinery (closure
        # capture, perceus, monomorphisation) without depending on
        # the SLet -> EBlock walker quirks for sub-expressions
        # synthesised mid-parse.
        let tmp_name = "__pipe"
        let tmp_var = mk_expr(EVar(tmp_name), lhs.line, lhs.col)
        let new_args = subst_underscores(args_, tmp_var)
        let new_call = mk_expr(ECall(callee, new_args), rhs.line, rhs.col)
        let param = Param { pname: tmp_name, ptype: None, pline: lhs.line, pcol: lhs.col }
        let lam = mk_expr(ELambda([param], new_call), line, col)
        let app = mk_expr(ECall(lam, [lhs]), line, col)
        PPRSubstituted(app, p)
      }
    }
    _ -> PPRPassthrough
  }
}

fn count_underscores(es: [Expr], acc: Int) : Int {
  match es {
    [] -> acc
    [h, ...rest] -> match h.kind {
      EUnder -> count_underscores(rest, acc + 1)
      _      -> count_underscores(rest, acc)
    }
  }
}

fn subst_underscores(es: [Expr], replacement: Expr) : [Expr] {
  match es {
    [] -> []
    [h, ...rest] -> match h.kind {
      EUnder -> [replacement, ...subst_underscores(rest, replacement)]
      _      -> [h, ...subst_underscores(rest, replacement)]
    }
  }
}

# Issue #385 — `.` placeholder desugar at call-argument position.
#
# `f(. < 3)` desugars to `f((__pl) => __pl < 3)` so the placeholder
# sugar documented in `docs/kaikai-minimal.md` §"Placeholder rules"
# works wherever a function value is expected. The walk stops at
# inner `ELambda` / `EHandle` boundaries: `.` inside a nested
# explicit-arrow lambda binds to that nested scope (and per the
# docs, multi-arg / nested-scope cases must use named arrows — a
# stray `.` that survives the desugar is rejected by the typer).
#
# Multiple `.` occurrences in the same argument all refer to the
# same `__pl` parameter (unary), per docs.

fn arg_has_placeholder(e: Expr) : Bool {
  match e.kind {
    EPlaceholder        -> true
    EInt(_)             -> false
    EReal(_)            -> false
    EBool(_)            -> false
    EChar(_)            -> false
    EStr(_, _)          -> false
    EUnit               -> false
    EVar(_)             -> false
    EUnder              -> false
    EHole(_)            -> false
    ETodo(_)            -> false
    EVariantsOf(_, _)   -> false
    EModCall(_, _)      -> false
    EIntrinsic(_, args_) -> any_arg_has_placeholder(args_)
    # `ELambda` introduces a fresh scope. Per docs, `.` does NOT
    # reach into a nested arrow lambda — that's the multi-arg /
    # nested case the spec rejects.
    ELambda(_, _)       -> false
    # `EHandle` clauses are themselves lambdas; treat the whole
    # node as a scope barrier. The handler body is a normal
    # expression but mixing `.` with effect handlers in argument
    # position is not in the documented sugar surface.
    EHandle(_, _, _, _, _, _, _) -> false
    ECall(callee, args_) ->
      arg_has_placeholder(callee) or any_arg_has_placeholder(args_)
    EField(base, _)     -> arg_has_placeholder(base)
    EIndex(a, b)        -> arg_has_placeholder(a) or arg_has_placeholder(b)
    EBinop(_, a, b)     -> arg_has_placeholder(a) or arg_has_placeholder(b)
    EUnop(_, x)         -> arg_has_placeholder(x)
    EIf(c, t_, eo)      ->
      arg_has_placeholder(c) or arg_has_placeholder(t_) or
      opt_arg_has_placeholder(eo)
    EMatch(scr, arms)   ->
      arg_has_placeholder(scr) or any_arm_has_placeholder(arms)
    ERecordLit(_, fs)   -> any_field_has_placeholder(fs)
    EList(els)          -> any_elem_has_placeholder(els)
    ERange(a, b, opt_step) ->
      arg_has_placeholder(a) or arg_has_placeholder(b) or
      opt_arg_has_placeholder(opt_step)
    EBlock(stmts, tail) ->
      any_stmt_has_placeholder(stmts) or opt_arg_has_placeholder(tail)
    EPipe(a, b)         -> arg_has_placeholder(a) or arg_has_placeholder(b)
    EMapPipe(a, b)      -> arg_has_placeholder(a) or arg_has_placeholder(b)
    EFlatMapPipe(a, b)  -> arg_has_placeholder(a) or arg_has_placeholder(b)
    EFilterPipe(a, b)   -> arg_has_placeholder(a) or arg_has_placeholder(b)
    ELitUnit(inner, _)  -> arg_has_placeholder(inner)
    EBang(inner)        -> arg_has_placeholder(inner)
  }
}

fn any_arg_has_placeholder(es: [Expr]) : Bool = match es {
  []           -> false
  [h, ...rest] -> if arg_has_placeholder(h) { true } else { any_arg_has_placeholder(rest) }
}

fn opt_arg_has_placeholder(o: Option[Expr]) : Bool = match o {
  None    -> false
  Some(e) -> arg_has_placeholder(e)
}

fn any_arm_has_placeholder(arms: [Arm]) : Bool = match arms {
  []           -> false
  [h, ...rest] -> match h {
    Arm(_, g, b) ->
      if opt_arg_has_placeholder(g) { true }
      else if arg_has_placeholder(b) { true }
      else { any_arm_has_placeholder(rest) }
  }
}

fn any_field_has_placeholder(fs: [FieldInit]) : Bool = match fs {
  []           -> false
  [h, ...rest] -> match h {
    FI(_, v) -> if arg_has_placeholder(v) { true } else { any_field_has_placeholder(rest) }
  }
}

fn any_elem_has_placeholder(els: [ListElem]) : Bool = match els {
  []           -> false
  [h, ...rest] -> match h {
    ElPlain(x)  -> if arg_has_placeholder(x) { true } else { any_elem_has_placeholder(rest) }
    ElSpread(x) -> if arg_has_placeholder(x) { true } else { any_elem_has_placeholder(rest) }
  }
}

fn any_stmt_has_placeholder(ss: [Stmt]) : Bool = match ss {
  []           -> false
  [h, ...rest] -> if stmt_has_placeholder(h) { true } else { any_stmt_has_placeholder(rest) }
}

fn stmt_has_placeholder(s: Stmt) : Bool = match s {
  SLet(_, _, rhs)             -> arg_has_placeholder(rhs)
  SAssert(c, m)               -> arg_has_placeholder(c) or opt_arg_has_placeholder(m)
  SExprStmt(x)                -> arg_has_placeholder(x)
  SIndexAssign(b, i, v, _, _) ->
    arg_has_placeholder(b) or arg_has_placeholder(i) or arg_has_placeholder(v)
  SVar(_, _, rhs, _, _)       -> arg_has_placeholder(rhs)
  SUse(_, _, _)               -> false
}

fn subst_placeholder_expr(e: Expr, repl: Expr) : Expr {
  match e.kind {
    EPlaceholder -> repl
    # ELambda / EHandle are scope barriers — leave them alone.
    ELambda(_, _) -> e
    EHandle(_, _, _, _, _, _, _) -> e
    _ -> {
      let new_kind = subst_placeholder_kind(e.kind, repl)
      Expr { kind: new_kind, line: e.line, col: e.col, ty: e.ty, mode: e.mode }
    }
  }
}

fn subst_placeholder_kind(k: ExprKind, repl: Expr) : ExprKind {
  match k {
    EInt(_)             -> k
    EReal(_)            -> k
    EBool(_)            -> k
    EChar(_)            -> k
    EStr(_, _)          -> k
    EUnit               -> k
    EVar(_)             -> k
    EUnder              -> k
    EHole(_)            -> k
    ETodo(_)            -> k
    EVariantsOf(_, _)   -> k
    EModCall(_, _)      -> k
    EIntrinsic(name, args_) ->
      EIntrinsic(name, map(args_, (a) => subst_placeholder_expr(a, repl)))
    EPlaceholder        -> k    # handled by subst_placeholder_expr
    ELambda(_, _)       -> k    # scope barrier
    EHandle(_, _, _, _, _, _, _) -> k    # scope barrier
    ECall(callee, args_) ->
      ECall(subst_placeholder_expr(callee, repl),
            map(args_, (a) => subst_placeholder_expr(a, repl)))
    EField(base, name)  -> EField(subst_placeholder_expr(base, repl), name)
    EIndex(a, b)        -> EIndex(subst_placeholder_expr(a, repl),
                                    subst_placeholder_expr(b, repl))
    EBinop(op, a, b)    -> EBinop(op, subst_placeholder_expr(a, repl),
                                       subst_placeholder_expr(b, repl))
    EUnop(op, x)        -> EUnop(op, subst_placeholder_expr(x, repl))
    EIf(c, t_, eo)      ->
      EIf(subst_placeholder_expr(c, repl),
          subst_placeholder_expr(t_, repl),
          subst_placeholder_opt(eo, repl))
    EMatch(scr, arms)   ->
      EMatch(subst_placeholder_expr(scr, repl),
              map(arms, (a) => subst_placeholder_arm(a, repl)))
    ERecordLit(name, fs) ->
      ERecordLit(name, map(fs, (fi) => subst_placeholder_field(fi, repl)))
    EList(els)          -> EList(map(els, (el) => subst_placeholder_elem(el, repl)))
    ERange(a, b, opt_step) ->
      ERange(subst_placeholder_expr(a, repl),
              subst_placeholder_expr(b, repl),
              subst_placeholder_opt(opt_step, repl))
    EBlock(stmts, tail) ->
      EBlock(map(stmts, (s) => subst_placeholder_stmt(s, repl)),
              subst_placeholder_opt(tail, repl))
    EPipe(a, b)         -> EPipe(subst_placeholder_expr(a, repl),
                                  subst_placeholder_expr(b, repl))
    EMapPipe(a, b)      -> EMapPipe(subst_placeholder_expr(a, repl),
                                      subst_placeholder_expr(b, repl))
    EFlatMapPipe(a, b)  -> EFlatMapPipe(subst_placeholder_expr(a, repl),
                                          subst_placeholder_expr(b, repl))
    EFilterPipe(a, b)   -> EFilterPipe(subst_placeholder_expr(a, repl),
                                        subst_placeholder_expr(b, repl))
    ELitUnit(inner, u)  -> ELitUnit(subst_placeholder_expr(inner, repl), u)
    EBang(inner)        -> EBang(subst_placeholder_expr(inner, repl))
  }
}

fn subst_placeholder_opt(o: Option[Expr], repl: Expr) : Option[Expr] = match o {
  None    -> None
  Some(e) -> Some(subst_placeholder_expr(e, repl))
}

fn subst_placeholder_arm(a: Arm, repl: Expr) : Arm = match a {
  Arm(p, g, b) ->
    Arm(p, subst_placeholder_opt(g, repl), subst_placeholder_expr(b, repl))
}

fn subst_placeholder_field(fi: FieldInit, repl: Expr) : FieldInit = match fi {
  FI(n, v) -> FI(n, subst_placeholder_expr(v, repl))
}

fn subst_placeholder_elem(el: ListElem, repl: Expr) : ListElem = match el {
  ElPlain(x)  -> ElPlain(subst_placeholder_expr(x, repl))
  ElSpread(x) -> ElSpread(subst_placeholder_expr(x, repl))
}

fn subst_placeholder_stmt(s: Stmt, repl: Expr) : Stmt = match s {
  SLet(p, ann, rhs)           -> SLet(p, ann, subst_placeholder_expr(rhs, repl))
  SAssert(c, m)               -> SAssert(subst_placeholder_expr(c, repl),
                                          subst_placeholder_opt(m, repl))
  SExprStmt(x)                -> SExprStmt(subst_placeholder_expr(x, repl))
  SIndexAssign(b, i, v, l, c) -> SIndexAssign(subst_placeholder_expr(b, repl),
                                                subst_placeholder_expr(i, repl),
                                                subst_placeholder_expr(v, repl),
                                                l, c)
  SVar(n, ty, rhs, l, c)      -> SVar(n, ty, subst_placeholder_expr(rhs, repl), l, c)
  SUse(n, l, c)               -> SUse(n, l, c)
}

# Wrap a single argument expression in a placeholder lambda when
# it carries a top-level `.`. Returns the argument unchanged when
# it has no placeholder, or when the top-level node is itself a
# lambda / handler (scope barriers), preserving the existing
# parser shape for those cases.
fn desugar_placeholder_arg(arg: Expr) : Expr {
  if arg_has_placeholder(arg) {
    let pl_name = "__pl"
    let pl_var = mk_expr(EVar(pl_name), arg.line, arg.col)
    let body = subst_placeholder_expr(arg, pl_var)
    let pl_param = Param { pname: pl_name, ptype: None,
                            pline: arg.line, pcol: arg.col }
    mk_expr(ELambda([pl_param], body), arg.line, arg.col)
  } else {
    arg
  }
}

fn desugar_placeholder_args(args_: [Expr]) : [Expr] =
  map(args_, desugar_placeholder_arg)

fn parse_pipe_rest(p: Parser, lhs: Expr) : PExpr / Console {

  # `|>` (apply), `|` (map), and `||` (flat-map) all sit at the lowest
  # binop level, left-associative. The `|` variant separator in
  # `type T = A | B` is parsed by `parse_sum_body`, not the expression
  # grammar, so there is no ambiguity here.
  #
  # Issue #130: pipe operators may also lead a continuation line. The
  # peeked parser skips leading newlines so `xs\n  |> f\n  |> g` parses
  # the same as `xs |>\n  f |>\n  g`. If the next non-newline token is
  # NOT a pipe we return the ORIGINAL `p` — those newlines belong to
  # the enclosing statement boundary, not the pipe chain.
  #
  # Issue #201: `|` and `||` are typed as `EMapPipe` / `EFlatMapPipe`
  # AST nodes. The typer dispatches them against the head type of the
  # LHS via the head-type-to-module map (see `head_type_module` and
  # `synth_map_pipe` / `synth_flat_map_pipe`) and rewrites the node
  # into a `<module>.map(xs, f)` / `<module>.flat_map(xs, f)` call.
  # Pre-#201, the parser desugared `|` straight into
  # `ECall(EVar("map"), [xs, f])` against a hardcoded prelude `map`
  # entry; the new shape lets `[T]` and any future container-shaped
  # head type share one surface without a hardcoded receiver.
  let p_look = p_skip_newlines(p)
  if p_at(p_look, TkPipeApply) {
    let t = p_peek(p_look)
    let p1 = p_skip_newlines(p_advance(p_look))
    let r = parse_or(p1)
    match r.r {
      None -> err_e(r.p)
      Some(rhs) -> {
        # m7d §21: pipeline placeholder. If the rhs is a call whose
        # arg list contains exactly one `_`, the apply pipe lands
        # the lhs at that position instead of as the first arg.
        # `let __pipe = lhs in f(args[_ := __pipe])` — the let
        # binding ensures the lhs is evaluated once, even if it has
        # side effects. The default-first-arg behaviour stays for
        # calls with no `_`. Multiple `_` in the same call would
        # silently duplicate side effects, so we reject them.
        match try_pipe_placeholder(t.line, t.col, lhs, rhs, r.p) {
          PPRError(p2)         -> err_e(p2)
          PPRSubstituted(e, p2) -> parse_pipe_rest(p2, e)
          PPRPassthrough       -> parse_pipe_rest(r.p, mk_expr(EPipe(lhs, rhs), t.line, t.col))
        }
      }
    }
  } else if p_at(p_look, TkPipe) {
    let t = p_peek(p_look)
    let p1 = p_skip_newlines(p_advance(p_look))
    let r = parse_or(p1)
    match r.r {
      None -> err_e(r.p)
      Some(rhs) -> parse_pipe_rest(r.p, mk_expr(EMapPipe(lhs, rhs), t.line, t.col))
    }
  } else if p_at(p_look, TkBarBar) {
    let t = p_peek(p_look)
    let p1 = p_skip_newlines(p_advance(p_look))
    let r = parse_or(p1)
    match r.r {
      None -> err_e(r.p)
      Some(rhs) -> parse_pipe_rest(r.p, mk_expr(EFlatMapPipe(lhs, rhs), t.line, t.col))
    }
  } else if p_at(p_look, TkPipeQuestion) {
    let t = p_peek(p_look)
    let p1 = p_skip_newlines(p_advance(p_look))
    let r = parse_or(p1)
    match r.r {
      None -> err_e(r.p)
      Some(rhs) -> parse_pipe_rest(r.p, mk_expr(EFilterPipe(lhs, rhs), t.line, t.col))
    }
  } else {
    ok_e(p, lhs)
  }
}

fn parse_or(p: Parser) : PExpr / Console {

  let r = parse_and(p)
  match r.r {
    None -> r
    Some(lhs) -> parse_or_rest(r.p, lhs)
  }
}

fn parse_or_rest(p: Parser, lhs: Expr) : PExpr / Console {

  if p_at(p, TkOr) {
    let t = p_peek(p)
    let r = parse_and(p_skip_newlines(p_advance(p)))
    match r.r {
      None -> err_e(r.p)
      Some(rhs) -> parse_or_rest(r.p, mk_expr(EBinop("or", lhs, rhs), t.line, t.col))
    }
  } else {
    ok_e(p, lhs)
  }
}

fn parse_and(p: Parser) : PExpr / Console {

  let r = parse_cmp(p)
  match r.r {
    None -> r
    Some(lhs) -> parse_and_rest(r.p, lhs)
  }
}

fn parse_and_rest(p: Parser, lhs: Expr) : PExpr / Console {

  if p_at(p, TkAnd) {
    let t = p_peek(p)
    let r = parse_cmp(p_skip_newlines(p_advance(p)))
    match r.r {
      None -> err_e(r.p)
      Some(rhs) -> parse_and_rest(r.p, mk_expr(EBinop("and", lhs, rhs), t.line, t.col))
    }
  } else {
    ok_e(p, lhs)
  }
}

fn is_cmp_tok(k: TokKind) : Bool {
  tk_is(k, TkEqEq) or tk_is(k, TkNeq) or tk_is(k, TkLt) or tk_is(k, TkGt) or tk_is(k, TkLe) or tk_is(k, TkGe)
}

# Comparison is deliberately non-associative (see `kaikai-minimal.md`
# → Operator precedence): `a < b < c` is a syntax error, not a chain.
# A plain fall-through would report "expected `fn`, `type`, ..." at
# the outer statement parser, which is useless. Instead, when we see
# a second comparison token right after `lhs OP rhs`, we emit a
# tailored diagnostic pointing at the offending `OP'` and suggesting
# the `and`-based rewrite.
fn parse_cmp(p: Parser) : PExpr / Console {

  let r = parse_concat(p)
  match r.r {
    None -> r
    Some(lhs) -> {
      let t = p_peek(r.p)
      if is_cmp_tok(t.kind) {
        let op = op_of_tok(t.kind)
        let r2 = parse_concat(p_skip_newlines(p_advance(r.p)))
        match r2.r {
          None -> err_e(r2.p)
          Some(rhs) -> {
            let after = p_peek(r2.p)
            if is_cmp_tok(after.kind) {
              let hint = "comparison is non-associative; write `... and ... #{op_of_tok(after.kind)} ...` instead"
              err_e(p_error(r2.p, after, hint))
            } else {
              ok_e(r2.p, mk_expr(EBinop(op, lhs, rhs), t.line, t.col))
            }
          }
        }
      } else { ok_e(r.p, lhs) }
    }
  }
}

# m7d §23 — `++` sits one slot below comparison, one above
# additive (`+`/`-`). Right-associative, so `a ++ b ++ c` parses
# as `a ++ (b ++ c)` — which matches both `string_concat` and
# `list_append` since both are the natural fold direction (no
# spine duplication on the head list / left string).
fn parse_concat(p: Parser) : PExpr / Console {

  let r = parse_add(p)
  match r.r {
    None -> r
    Some(lhs) -> {
      if p_at(r.p, TkPlusPlus) {
        let t = p_peek(r.p)
        let rr = parse_concat(p_skip_newlines(p_advance(r.p)))
        match rr.r {
          None -> err_e(rr.p)
          Some(rhs) -> ok_e(rr.p, mk_expr(EBinop("++", lhs, rhs), t.line, t.col))
        }
      } else { ok_e(r.p, lhs) }
    }
  }
}

fn parse_add(p: Parser) : PExpr / Console {

  let r = parse_mul(p)
  match r.r {
    None -> r
    Some(lhs) -> parse_add_rest(r.p, lhs)
  }
}

fn parse_add_rest(p: Parser, lhs: Expr) : PExpr / Console {

  let t = p_peek(p)
  if tk_is(t.kind, TkPlus) or tk_is(t.kind, TkMinus) {
    let op = op_of_tok(t.kind)
    let r = parse_mul(p_skip_newlines(p_advance(p)))
    match r.r {
      None -> err_e(r.p)
      Some(rhs) -> parse_add_rest(r.p, mk_expr(EBinop(op, lhs, rhs), t.line, t.col))
    }
  } else { ok_e(p, lhs) }
}

fn parse_mul(p: Parser) : PExpr / Console {

  let r = parse_unary(p)
  match r.r {
    None -> r
    Some(lhs) -> parse_mul_rest(r.p, lhs)
  }
}

fn parse_mul_rest(p: Parser, lhs: Expr) : PExpr / Console {

  let t = p_peek(p)
  if tk_is(t.kind, TkStar) or tk_is(t.kind, TkSlash) or tk_is(t.kind, TkPercent) {
    let op = op_of_tok(t.kind)
    let r = parse_unary(p_skip_newlines(p_advance(p)))
    match r.r {
      None -> err_e(r.p)
      Some(rhs) -> parse_mul_rest(r.p, mk_expr(EBinop(op, lhs, rhs), t.line, t.col))
    }
  } else { ok_e(p, lhs) }
}

fn parse_unary(p: Parser) : PExpr / Console {

  let t = p_peek(p)
  if tk_is(t.kind, TkMinus) {
    let r = parse_unary(p_advance(p))
    match r.r {
      None -> err_e(r.p)
      Some(e) -> ok_e(r.p, mk_expr(EUnop("-", e), t.line, t.col))
    }
  } else if tk_is(t.kind, TkNot) {
    let r = parse_unary(p_advance(p))
    match r.r {
      None -> err_e(r.p)
      Some(e) -> ok_e(r.p, mk_expr(EUnop("not", e), t.line, t.col))
    }
  } else if tk_is(t.kind, TkAt) {
    # m7b #4: `@cap` desugars to `cap.get()`. The alias rewrite later
    # remaps `Reader[T].get` to `Reader.ask`. Doc B §`Syntax note:
    # capability read/write sugar` rule 3: the identifier after `@`
    # must be a simple capability binding (no dotted paths).
    let p1 = p_advance(p)
    let id = p_peek(p1)
    if not tk_is(id.kind, TkIdent) {
      err_e(p_error(p1, id, "expected capability name after `@`"))
    } else {
      let name = tok_source(p1.src, id)
      let p2 = p_advance(p1)
      let cap = mk_expr(EVar(name), id.line, id.col)
      let getter = mk_expr(EField(cap, "get"), t.line, t.col)
      ok_e(p2, mk_expr(ECall(getter, []), t.line, t.col))
    }
  } else {
    parse_pow(p)
  }
}

# `^` — integer-exponent power. Higher precedence than `*`/`/` and
# right-associative (Haskell convention): `2 ^ 3 ^ 2` parses as
# `2 ^ (3 ^ 2)` = `2 ^ 9` = 512. The LHS is `parse_postfix` so calls
# and field accesses bind tighter than `^`; the RHS calls back into
# `parse_unary` so a leading sign on the exponent (`r ^ -2`) lexes
# as `EUnop("-", EInt(2))`. The typer treats `^` specially: when the
# base has a non-trivial unit, the exponent must be a literal Int
# (or `-Int`) so the result unit `u^n` resolves at compile time.
fn parse_pow(p: Parser) : PExpr / Console {

  let r = parse_postfix(p)
  match r.r {
    None -> r
    Some(lhs) -> {
      let t = p_peek(r.p)
      if tk_is(t.kind, TkCaret) {
        let rr = parse_unary(p_skip_newlines(p_advance(r.p)))
        match rr.r {
          None -> err_e(rr.p)
          Some(rhs) -> ok_e(rr.p, mk_expr(EBinop("^", lhs, rhs), t.line, t.col))
        }
      } else { ok_e(r.p, lhs) }
    }
  }
}

fn parse_postfix(p: Parser) : PExpr / Console {

  let r = parse_primary(p)
  match r.r {
    None -> r
    Some(e) -> parse_postfix_rest(r.p, e)
  }
}

fn parse_postfix_rest(p: Parser, lhs: Expr) : PExpr / Console {

  let t = p_peek(p)
  if tk_is(t.kind, TkLparen) {
    let args_r = parse_call_args(p_advance(p))
    match args_r.r {
      None -> err_e(args_r.p)
      Some(xs) -> {
        # m7b §1/§5: same-line `{` after `f(args)` attaches as a
        # trailing lambda. Up to two consecutive trailings (greedy,
        # both must be on the same line as the previous token).
        # Trailing-lambda attachment is disabled for cond positions
        # (see p_with_trailing_lambda).
        let lam_r = if args_r.p.allow_trailing_lambda {
          parse_trailing_lambdas(args_r.p, xs)
        } else {
          ok_args(args_r.p, xs)
        }
        match lam_r.r {
          None -> err_e(lam_r.p)
          Some(xs1) -> {
            # Issue #385: rewrite `f(. < 3)` to `f((__pl) => __pl < 3)`
            # so the documented placeholder sugar reaches the typer as
            # a function value. See `desugar_placeholder_arg` for the
            # scope rules.
            let xs2 = desugar_placeholder_args(xs1)
            parse_postfix_rest(lam_r.p, mk_expr(ECall(lhs, xs2), t.line, t.col))
          }
        }
      }
    }
  } else if tk_is(t.kind, TkDot) {
    let p1 = p_advance(p)
    let id = p_peek(p1)
    # m7b #5: `var` is a new statement keyword (§3 of syntax-sugars)
    # but also the name of a Doc B `Env` effect op (`Env.var(name)`).
    # Accept `var` here as a field-name token so the keyword does not
    # break existing Env-op call sites.
    # m13: `and` / `or` / `not` are keywords for the boolean
    # operators but also the natural names for `bit.and` / `bit.or`
    # / `bit.not` in the dotted intrinsic surface. `test` is a
    # keyword for the test-block declaration but also the natural
    # name for `bit.test`. After `.` there is no production that
    # consumes any of them, so accepting them here as field-name
    # tokens is unambiguous and lets the qualified bit ops parse
    # without renaming.
    if tk_is(id.kind, TkIdent) or tk_is(id.kind, TkVar) or
       tk_is(id.kind, TkAnd)   or tk_is(id.kind, TkOr)  or
       tk_is(id.kind, TkNot)   or tk_is(id.kind, TkTest) or
       tk_is(id.kind, TkBench) or tk_is(id.kind, TkCheck) {
      let name = tok_source(p.src, id)
      parse_postfix_rest(p_advance(p1), mk_expr(EField(lhs, name), t.line, t.col))
    } else {
      err_e(p_error_here(p1, "expected field name after `.`"))
    }
  } else if tk_is(t.kind, TkLbracket) {
    let p1 = p_advance(p)
    let r = parse_expr(p1)
    match r.r {
      None -> err_e(r.p)
      Some(idx) -> {
        let closed = p_expect(r.p, TkRbracket, "expected `]` after index")
        match closed.r {
          None -> err_e(closed.p)
          Some(_) -> parse_postfix_rest(closed.p, mk_expr(EIndex(lhs, idx), t.line, t.col))
        }
      }
    }
  } else if tk_is(t.kind, TkBang) {
    # m7e §13: `expr!` — postfix Option/Result propagation. Binds
    # tighter than calls and field access can chain through it
    # (`f()!.field`, `xs[0]!`), but binary operators sit lower.
    parse_postfix_rest(p_advance(p), mk_expr(EBang(lhs), t.line, t.col))
  } else if tk_is(t.kind, TkLbrace) and p.allow_trailing_lambda {
    # m7b §1: paren-free trailing lambda — `f { body }` desugars
    # to `f(() => body)`, optionally followed by a second trailing
    # lambda (§5). Same-line is implicit: parse_postfix_rest does
    # not skip newlines, so a `{` appearing here is on the same
    # source line as `lhs`. Disabled inside `if` / `match` conds.
    let lam_r = parse_trailing_lambdas(p, [])
    match lam_r.r {
      None -> err_e(lam_r.p)
      Some(xs1) -> parse_postfix_rest(lam_r.p, mk_expr(ECall(lhs, xs1), t.line, t.col))
    }
  } else {
    ok_e(p, lhs)
  }
}

# m7b §1 + §5 — parse zero, one, or two trailing lambdas after a
# call site. Each trailing lambda must be on the same line as the
# preceding token (parse_postfix_rest never skips newlines, so a
# `TkLbrace` at the head of `p` is by construction same-line).
# `acc` is the call's existing argument list; the parsed lambdas
# are appended in source order. Returns the call's full arg list.
fn parse_trailing_lambdas(p: Parser, acc: [Expr]) : PArgs / Console {

  if p_at(p, TkLbrace) {
    let lr = parse_trailing_lambda(p)
    match lr.r {
      None -> err_args(lr.p)
      Some(lam) -> {
        let acc1 = list_append(acc, [lam])
        if p_at(lr.p, TkLbrace) {
          let lr2 = parse_trailing_lambda(lr.p)
          match lr2.r {
            None -> err_args(lr2.p)
            Some(lam2) -> ok_args(lr2.p, list_append(acc1, [lam2]))
          }
        } else {
          ok_args(lr.p, acc1)
        }
      }
    }
  } else {
    ok_args(p, acc)
  }
}

# Parse a single trailing-lambda `{ (LambdaParams "->")? Block }`.
# Position is at the `{`. Returns an `ELambda(params, body)` where
# `body` is an EBlock (the lambda's body block). The block-form
# `{ x -> body }` desugars to `(x) => body` per syntax-sugars §1.
fn parse_trailing_lambda(p: Parser) : PExpr / Console {

  let t = p_peek(p)
  # Consume `{`.
  let p1 = p_advance(p)
  # Decide between `(LambdaParams "->")? Block`. Peek past optional
  # newlines after `{` to see whether we're staring at a parameter
  # list. The lookahead is bounded: `Ident ("," Ident)* "->"` or
  # just `->` for zero arity.
  let p1n = p_skip_newlines(p1)
  let pp_r = try_parse_lambda_block_params(p1n)
  match pp_r {
    Some(res) -> {
      # `res.p` is positioned right after `->`. Body is a brace-less
      # block of statements terminated by `}`.
      let body_r = parse_lambda_block_body(res.p, t)
      match body_r.r {
        None -> err_e(body_r.p)
        Some(body) -> ok_e(body_r.p, mk_expr(ELambda(res.params, body), t.line, t.col))
      }
    }
    None -> {
      # Zero-arity trailing lambda: no `params ->` prefix. The body
      # is the contents of the brace block. Treat as a lambda with
      # an empty parameter list whose body is the parsed block.
      let body_r = parse_lambda_block_body(p1, t)
      match body_r.r {
        None -> err_e(body_r.p)
        Some(body) -> ok_e(body_r.p, mk_expr(ELambda([], body), t.line, t.col))
      }
    }
  }
}

# Parse the contents of a lambda-block body up to the closing `}`.
# Position is after the optional `params ->` prefix. The body is
# the same shape as a regular block: zero or more statements
# followed by an optional final expression. We reuse the existing
# parse_block_body machinery for this.
fn parse_lambda_block_body(p: Parser, t: Token) : PExpr / Console {

  let p0 = p_skip_newlines_and_semis(p)
  parse_block_body(p0, [], t)
}

# Bounded-lookahead: tentatively scan for `LambdaParams "->"` or
# bare `"->"`. Returns Some(parser-after-arrow, params) on match,
# None otherwise. The scan never consumes tokens of the underlying
# parser on failure (it's a pure predicate over the token stream).
type LamBlockParams = { p: Parser, params: [Param] }

fn try_parse_lambda_block_params(p: Parser) : Option[LamBlockParams] {
  # Zero-arity: `{ -> body }`.
  if p_at(p, TkArrow) {
    Some(LamBlockParams { p: p_advance(p), params: [] })
  } else if p_at(p, TkIdent) {
    try_parse_lambda_block_params_loop(p, [])
  } else {
    None
  }
}

fn try_parse_lambda_block_params_loop(p: Parser, acc: [Param]) : Option[LamBlockParams] {
  let t = p_peek(p)
  if not tk_is(t.kind, TkIdent) { None }
  else {
    let name = tok_source(p.src, t)
    let p1 = p_advance(p)
    let pm = Param { pname: name, ptype: None, pline: t.line, pcol: t.col }
    let acc1 = [pm, ...acc]
    if p_at(p1, TkComma) {
      try_parse_lambda_block_params_loop(p_skip_newlines(p_advance(p1)), acc1)
    } else if p_at(p1, TkArrow) {
      Some(LamBlockParams { p: p_advance(p1), params: list_reverse(acc1) })
    } else {
      None
    }
  }
}

# Parse the argument list of a call. Position is AT the token after the
# opening `(`. Returns with `(` already consumed by caller, `)` to be
# consumed here. Newlines between args are allowed.
type PArgs = { p: Parser, r: Option[[Expr]] }

fn ok_args(p: Parser, xs: [Expr]) : PArgs = PArgs { p: p, r: Some(xs) }
fn err_args(p: Parser) : PArgs = PArgs { p: p, r: None }

fn parse_call_args(p: Parser) : PArgs / Console {

  let p0 = p_skip_newlines(p)
  if p_at(p0, TkRparen) { ok_args(p_advance(p0), []) }
  else { parse_call_args_loop(p0, []) }
}

fn parse_call_args_loop(p: Parser, acc: [Expr]) : PArgs / Console {

  let p_start = p_skip_newlines(p)
  if p_at(p_start, TkRparen) {
    # Trailing comma: `f(a, b,)` — `acc` already has all args.
    ok_args(p_advance(p_start), list_reverse(acc))
  } else {
    let r = parse_expr(p_start)
    match r.r {
      None -> err_args(r.p)
      Some(e) -> {
        let p1 = p_skip_newlines(r.p)
        if p_at(p1, TkComma) { parse_call_args_loop(p_skip_newlines(p_advance(p1)), [e, ...acc]) }
        else if p_at(p1, TkRparen) {
          ok_args(p_advance(p1), list_reverse([e, ...acc]))
        }
        else { err_args(p_error_here(p1, "expected `,` or `)` in call arguments")) }
      }
    }
  }
}

# ====================================================================
# primary expressions — placeholders for later implementations
# ====================================================================

# m12.5: after a numeric literal, peek for an *adjacent* `<` (no
# whitespace between the literal and the `<`). When found, parse the
# unit expression and wrap the literal in an ELitUnit. Adjacency is
# the only disambiguator from a comparison `1 < 2`; the spec explicitly
# requires no space between the number and `<`.
fn try_lit_unit_annotation(p: Parser, lit: Expr, lit_tok: Token) : PExpr / Console {

  let nxt = p_peek(p)
  let lit_end = lit_tok.start + lit_tok.length
  if tk_is(nxt.kind, TkLt) and nxt.start == lit_end {
    let p2 = p_skip_newlines(p_advance(p))
    let ru = parse_unit_expr(p2)
    match ru.r {
      None -> err_e(ru.p)
      Some(u) -> {
        let p3 = p_skip_newlines(ru.p)
        if not p_at(p3, TkGt) {
          err_e(p_error_here(p3, "expected `>` to close the unit annotation on a literal"))
        } else {
          ok_e(p_advance(p3), mk_expr(ELitUnit(lit, u), lit_tok.line, lit_tok.col))
        }
      }
    }
  } else {
    ok_e(p, lit)
  }
}

fn parse_primary(p: Parser) : PExpr / Console {

  let t = p_peek(p)
  match t.kind {
    TkInt -> {
      let span = tok_source(p.src, t)
      let lit = mk_expr(EInt(decode_int(span)), t.line, t.col)
      try_lit_unit_annotation(p_advance(p), lit, t)
    }
    TkReal -> {
      let span = tok_source(p.src, t)
      let lit = mk_expr(EReal(decode_real(span)), t.line, t.col)
      try_lit_unit_annotation(p_advance(p), lit, t)
    }
    # Phase 1 of #267 — `<digits>i` desugars at parse time to
    # `complex.mk(0.0, <digits>)`. Span covers digits + trailing `i`;
    # strip the `i` before decoding. Resolver rewrites the
    # `EField(EVar("complex"), "mk")` callee to an EModCall once the
    # `complex` module is bound (auto-imported via the prelude path).
    TkComplex -> {
      let span = tok_source(p.src, t)
      let im_span = string_slice(span, 0, string_length(span) - 1)
      let im = decode_real(im_span)
      let zero = mk_expr(EReal(0.0), t.line, t.col)
      let im_e = mk_expr(EReal(im), t.line, t.col)
      let mod_var = mk_expr(EVar("complex"), t.line, t.col)
      let callee = mk_expr(EField(mod_var, "mk"), t.line, t.col)
      ok_e(p_advance(p), mk_expr(ECall(callee, [zero, im_e]), t.line, t.col))
    }
    TkTrue  -> ok_e(p_advance(p), mk_expr(EBool(true),  t.line, t.col))
    TkFalse -> ok_e(p_advance(p), mk_expr(EBool(false), t.line, t.col))
    TkChar  -> {
      let span = tok_source(p.src, t)
      ok_e(p_advance(p), mk_expr(EChar(decode_char(span)), t.line, t.col))
    }
    TkString -> {
      let span = tok_source(p.src, t)
      let is_triple =
        string_length(span) >= 6 and
        match char_at(span, 0) { Some(c) -> c == '"' _ -> false } and
        match char_at(span, 1) { Some(c) -> c == '"' _ -> false } and
        match char_at(span, 2) { Some(c) -> c == '"' _ -> false }
      ok_e(p_advance(p), mk_expr(EStr(span, is_triple), t.line, t.col))
    }
    TkUnderscore -> ok_e(p_advance(p), mk_expr(EUnder, t.line, t.col))
    TkDot -> {
      # m7f §19 (v1): `.method` in expression position desugars to
      # the closure `(__pl) => __pl.method`. Covers the
      # `xs | .label` and `map(xs, .label)` patterns the spec
      # cites as the most common method-ref use case. The fully
      # general `obj.method` (receiver-bound ref) form requires
      # parser ambiguity resolution against record field access
      # plus brand machinery for receiver-Fiber refs — deferred
      # to v2.
      let p1 = p_advance(p)
      let nxt = p_peek(p1)
      if tk_is(nxt.kind, TkIdent) {
        let name = tok_source(p1.src, nxt)
        let p2 = p_advance(p1)
        # Synthesise `(__pl) => __pl.name`. The placeholder param
        # name is mangled to avoid colliding with user bindings.
        let pl_name = "__pl"
        let pl_param = Param { pname: pl_name, ptype: None,
                                 pline: t.line, pcol: t.col }
        let pl_var = mk_expr(EVar(pl_name), t.line, t.col)
        let body = mk_expr(EField(pl_var, name), t.line, t.col)
        ok_e(p2, mk_expr(ELambda([pl_param], body), t.line, t.col))
      } else {
        # Bare `.` — pipeline placeholder per syntax-sugars.md.
        ok_e(p1, mk_expr(EPlaceholder, t.line, t.col))
      }
    }
    TkHole -> ok_e(p_advance(p), mk_expr(EHole(None), t.line, t.col))
    TkHoleName(nm) -> ok_e(p_advance(p), mk_expr(EHole(Some(nm)), t.line, t.col))
    TkDollar -> parse_intrinsic(p, t)
    TkTodoBang -> parse_todo_bang(p, t)
    TkRegex -> parse_regex_sigil(p, t)
    TkIdent -> parse_ident_primary(p, t)
    TkLparen -> parse_paren_or_lambda(p, t)
    TkLbracket -> parse_list_or_range(p, t)
    TkLbrace -> parse_brace_primary(p, t)
    TkIf -> parse_if(p, t)
    TkMatch -> parse_match(p, t)
    TkHandle -> parse_handle(p_advance(p), t)
    _ -> err_e(p_error_here(p, "expected expression"))
  }
}

# m7d §1: `todo!(msg)` — `todo!` is a single token (lexer-fused).
# The message must be a plain (non-triple, no interpolation) string
# literal so the compile-time `--holes-json` report and the runtime
# panic message agree on a single static value. The token at `t` is
# the `todo!`, and `p` is positioned right after it.
fn parse_todo_bang(p: Parser, t: Token) : PExpr / Console {

  let p1 = p_advance(p)
  if not p_at(p1, TkLparen) {
    err_e(p_error_here(p1, "expected `(` after `todo!`"))
  } else {
    let p2 = p_skip_newlines(p_advance(p1))
    let st = p_peek(p2)
    if not tk_is(st.kind, TkString) {
      err_e(p_error(p2, st, "`todo!` requires a literal string message: `todo!(\"...\")`"))
    } else {
      let span = tok_source(p2.src, st)
      let n = string_length(span)
      let is_triple =
        n >= 6 and
        match char_at(span, 0) { Some(c) -> c == '"' _ -> false } and
        match char_at(span, 1) { Some(c) -> c == '"' _ -> false } and
        match char_at(span, 2) { Some(c) -> c == '"' _ -> false }
      if is_triple {
        err_e(p_error(p2, st, "`todo!` does not accept triple-quoted strings"))
      } else {
        let body_start = 1
        let body_end = n - 1
        if has_interp(span, body_start, body_end) {
          err_e(p_error(p2, st,
            "`todo!` message must be a plain string literal (no interpolation)"))
        } else {
          let msg = string_slice(span, body_start, body_end - body_start)
          let p3 = p_skip_newlines(p_advance(p2))
          if not p_at(p3, TkRparen) {
            err_e(p_error_here(p3, "expected `)` after `todo!` message"))
          } else {
            ok_e(p_advance(p3), mk_expr(ETodo(msg), t.line, t.col))
          }
        }
      }
    }
  }
}

# Issue #556: `$<ident>(args)` — a compiler intrinsic call.
# Caller has already peeked `TkDollar` at `t`; `p` is positioned on
# the `$` token itself. The parser:
#   1. consumes the `$`,
#   2. requires an immediately-following identifier (no whitespace
#      logic — the lexer already skipped newlines into `t`),
#   3. requires a `(arg, ...)` arglist,
#   4. produces `EIntrinsic(name, args)`.
# Per-intrinsic shape rules (arity, arg kind, context) are enforced
# later by the typer, not here — the parser's job is to deliver the
# call shape to the AST.
fn parse_intrinsic(p: Parser, t: Token) : PExpr / Console {

  let p1 = p_advance(p)
  let id = p_peek(p1)
  if not tk_is(id.kind, TkIdent) {
    err_e(p_error(p1, id, "expected an intrinsic name after `$` (e.g. `$extern_handler(\"sym\")`)"))
  } else {
    let name = tok_source(p1.src, id)
    let p2 = p_advance(p1)
    if not p_at(p2, TkLparen) {
      err_e(p_error_here(p2,
        "expected `(` to start the intrinsic argument list — write `$NAME(args)`"))
    } else {
      let p3 = p_advance(p2)
      let args_r = parse_call_args(p3)
      match args_r.r {
        None    -> err_e(args_r.p)
        Some(args_) -> ok_e(args_r.p, mk_expr(EIntrinsic(name, args_), t.line, t.col))
      }
    }
  }
}

# `handle { body } with Eff [as alias] { clauses }`. Pinned in
# Doc A §*Handling*. Both blocks are parsed by handle-specific
# rules; the body is an ordinary block expression, the clauses
# block contains `op_name(args, resume) -> body` plus an optional
# `return(x) -> body` at the end.
fn parse_handle(p: Parser, t: Token) : PExpr / Console {

  let bt = p_peek(p)
  if not p_at(p, TkLbrace) {
    err_e(p_error_here(p, "expected `{` to start handle body"))
  } else {
    let body_r = parse_block(p, bt)
    match body_r.r {
      None -> err_e(body_r.p)
      Some(body) -> {
        let p1 = p_skip_newlines(body_r.p)
        if not p_at(p1, TkWith) {
          err_e(p_error_here(p1, "expected `with` after handle body"))
        } else {
          let p2 = p_advance(p1)
          let eff_t = p_peek(p2)
          if not tk_is(eff_t.kind, TkIdent) {
            err_e(p_error(p2, eff_t, "expected effect name after `with`"))
          } else {
            let eff_name = tok_source(p2.src, eff_t)
            let p3 = p_advance(p2)
            # m7b #11: optional `[T1, T2]` after the effect name —
            # the type instantiation. e.g. `with Reader[Int]`.
            let tyargs_r =
              if p_at(p3, TkLbracket) {
                parse_row_label_args(p_skip_newlines(p_advance(p3)), [])
              } else {
                PRowArgs { p: p3, r: Some([]) }
              }
            match tyargs_r.r {
              None -> err_e(tyargs_r.p)
              Some(eff_tyargs) -> {
                # m7b #11: optional `(init)` after the type args —
                # the handler-state initial value, e.g. `with State[Int](0)`.
                let init_r =
                  if p_at(tyargs_r.p, TkLparen) {
                    let p_io = p_skip_newlines(p_advance(tyargs_r.p))
                    let ie = parse_expr(p_io)
                    match ie.r {
                      None -> PInit { p: ie.p, r: None, has_init: true }
                      Some(ix) -> {
                        let p_ic = p_skip_newlines(ie.p)
                        if not p_at(p_ic, TkRparen) {
                          PInit { p: p_error_here(p_ic, "expected `)` after handler-state initializer"),
                                  r: None, has_init: true }
                        } else {
                          PInit { p: p_advance(p_ic), r: Some(ix), has_init: true }
                        }
                      }
                    }
                  } else {
                    PInit { p: tyargs_r.p, r: None, has_init: false }
                  }
                let init_failed =
                  if init_r.has_init {
                    match init_r.r { None -> true Some(_) -> false }
                  } else { false }
                if init_failed {
                  err_e(init_r.p)
                } else {
                let alias_r = parse_handle_alias(init_r.p)
                let p4 = p_skip_newlines(alias_r.p)
                if not p_at(p4, TkLbrace) {
                  err_e(p_error_here(p4, "expected `{` to start handler clauses"))
                } else {
                  let p5 = p_skip_newlines(p_advance(p4))
                  let cr = parse_handle_clauses(p5, [], None, [])
                  match cr.r {
                    None -> err_e(cr.p)
                    Some(_) -> {
                      let handle_e = mk_expr(
                        EHandle(body, eff_name, eff_tyargs, init_r.r,
                                alias_r.r, cr.clauses, cr.return_clause),
                        t.line, t.col)
                      # m7b #5b extension (issue #148, Option A): a `var`
                      # or `let` decl at the top of the clause list lifts
                      # to a sibling block whose tail is the handler. The
                      # existing `desugar_var_block` pass then converts
                      # each `SVar` into a wrapping `with State[T] as
                      # name` handler. When the prelude is empty we emit
                      # the bare `EHandle` so handlers without `var` pay
                      # no wrapping overhead.
                      match cr.prelude {
                        [] -> ok_e(cr.p, handle_e)
                        _  -> ok_e(cr.p,
                                mk_expr(EBlock(cr.prelude, Some(handle_e)),
                                        t.line, t.col))
                      }
                    }
                  }
                }
                }
              }
            }
          }
        }
      }
    }
  }
}

type PInit = { p: Parser, r: Option[Expr], has_init: Bool }

# Handler-clause params: like fn params but the type annotation is
# optional. `print(s, resume) -> ...` is the common shape.
fn parse_clause_params(p: Parser, acc: [Param]) : PParams / Console {

  if p_at(p, TkRparen) { PParams { p: p_advance(p), r: Some(list_reverse(acc)) } }
  else {
    let t = p_peek(p)
    if not tk_is(t.kind, TkIdent) {
      PParams { p: p_error(p, t, "expected parameter name"), r: None }
    } else {
      let name = tok_source(p.src, t)
      let p1 = p_advance(p)
      let opt_ty_r =
        if p_at(p1, TkColon) {
          let rt = parse_type(p_advance(p1))
          match rt.r {
            None -> PTy { p: rt.p, r: None }
            Some(ty) -> PTy { p: rt.p, r: Some(ty) }
          }
        } else {
          PTy { p: p1, r: None }
        }
      let pm = Param { pname: name, ptype: opt_ty_r.r, pline: t.line, pcol: t.col }
      let p2 = p_skip_newlines(opt_ty_r.p)
      if p_at(p2, TkComma) {
        parse_clause_params(p_skip_newlines(p_advance(p2)), [pm, ...acc])
      } else if p_at(p2, TkRparen) {
        PParams { p: p_advance(p2), r: Some(list_reverse([pm, ...acc])) }
      } else {
        PParams { p: p_error_here(p2, "expected `,` or `)` in parameter list"), r: None }
      }
    }
  }
}

type PAlias = { p: Parser, r: Option[String] }

fn parse_handle_alias(p: Parser) : PAlias / Console {

  if not p_at(p, TkAs) { PAlias { p: p, r: None } }
  else {
    let p1 = p_advance(p)
    let nt = p_peek(p1)
    if not tk_is(nt.kind, TkIdent) {
      PAlias { p: p_error(p1, nt, "expected alias name after `as`"), r: None }
    } else {
      PAlias { p: p_advance(p1), r: Some(tok_source(p1.src, nt)) }
    }
  }
}

type PClauses = {
  p: Parser,
  clauses: [HClause],
  return_clause: Option[HReturn],
  prelude: [Stmt],
  r: Option[Bool]
}

# m7b #5b extension (issue #148, Option A): a `var` or `let` decl
# may appear at the top of the clause list, before all operation
# clauses. The parser collects them into a `prelude` and the
# caller wraps the `EHandle` in an `EBlock(prelude, Some(EHandle))`.
# The existing `desugar_var_block` pass then lifts each `SVar`
# into a sibling `with State[T](init) as name` that wraps the
# handler. Once an operation clause has been seen, any further
# `var` / `let` is a parse error — the rule is "var/let must
# precede all operation clauses inside one handler block."
fn parse_handle_clauses(p: Parser, acc: [HClause], rret: Option[HReturn], prelude: [Stmt]) : PClauses / Console {

  let p0 = p_skip_newlines(p)
  if p_at(p0, TkRbrace) {
    PClauses { p: p_advance(p0), clauses: list_reverse(acc),
               return_clause: rret, prelude: list_reverse(prelude), r: Some(true) }
  } else {
    let id_t = p_peek(p0)
    if tk_is(id_t.kind, TkVar) {
      match acc {
        [] -> {
          let sr = parse_var(p0, id_t)
          match sr.r {
            None -> PClauses { p: sr.p, clauses: [], return_clause: None,
                               prelude: [], r: None }
            Some(s) -> parse_handle_clauses(sr.p, acc, rret, [s, ...prelude])
          }
        }
        _ -> PClauses { p: p_error(p0, id_t,
               "`var` and `let` must precede all operation clauses inside a handler"),
               clauses: [], return_clause: None, prelude: [], r: None }
      }
    } else if tk_is(id_t.kind, TkLet) {
      match acc {
        [] -> {
          let sr = parse_let(p0, id_t)
          match sr.r {
            None -> PClauses { p: sr.p, clauses: [], return_clause: None,
                               prelude: [], r: None }
            Some(s) -> parse_handle_clauses(sr.p, acc, rret, [s, ...prelude])
          }
        }
        _ -> PClauses { p: p_error(p0, id_t,
               "`var` and `let` must precede all operation clauses inside a handler"),
               clauses: [], return_clause: None, prelude: [], r: None }
      }
    } else if not tk_is(id_t.kind, TkIdent) {
      PClauses { p: p_error(p0, id_t, "expected operation name in handler"),
                 clauses: [], return_clause: None, prelude: [], r: None }
    } else {
      let name = tok_source(p0.src, id_t)
      let p1 = p_advance(p0)
      if not p_at(p1, TkLparen) {
        PClauses { p: p_error_here(p1, "expected `(` after operation name"),
                   clauses: [], return_clause: None, prelude: [], r: None }
      } else {
        let p2 = p_skip_newlines(p_advance(p1))
        let params_r = parse_clause_params(p2, [])
        match params_r.r {
          None -> PClauses { p: params_r.p, clauses: [], return_clause: None,
                             prelude: [], r: None }
          Some(params) -> {
            let p3 = p_skip_newlines(params_r.p)
            if not p_at(p3, TkArrow) {
              PClauses { p: p_error_here(p3, "expected `->` after operation parameters"),
                         clauses: [], return_clause: None, prelude: [], r: None }
            } else {
              let p4 = p_skip_newlines(p_advance(p3))
              let rb = parse_expr(p4)
              match rb.r {
                None -> PClauses { p: rb.p, clauses: [], return_clause: None,
                                   prelude: [], r: None }
                Some(body) -> {
                  if name == "return" {
                    match params {
                      [pp] -> {
                        let hr = HR(pp.pname, body, id_t.line, id_t.col)
                        parse_handle_clauses(rb.p, acc, Some(hr), prelude)
                      }
                      _ -> PClauses { p: p_error(p3, id_t,
                             "return clause takes exactly one parameter"),
                             clauses: [], return_clause: None, prelude: [], r: None }
                    }
                  } else {
                    let hc = HC(name, params, body, id_t.line, id_t.col)
                    parse_handle_clauses(rb.p, [hc, ...acc], rret, prelude)
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}

fn parse_ident_primary(p: Parser, t: Token) : PExpr / Console {

  let name = tok_source(p.src, t)
  let p1 = p_advance(p)
  # m7e §11: `variants[T]()` — compile-time enumeration of a nullary
  # sum type's constructors. Special-cased before `[` would otherwise
  # pick up the postfix EIndex path. Active only when the source
  # ident is exactly "variants" and the next token is `[`. Any other
  # use of an identifier called `variants` followed by an expression
  # in `[...]` still parses as EIndex via parse_postfix_rest.
  if name == "variants" and p_at(p1, TkLbracket) {
    parse_variants_of(p1, t)
  }
  # issue #120: `region { ... }` — opt-in Perceus region block. A
  # contextual ident (not a lexer keyword), recognised only when the
  # source ident is exactly "region" and the next token is `{`. Any
  # other use of an identifier called `region` (a bare variable, a
  # call `region(x)`, a field `region.x`) falls through to the normal
  # EVar path, so user code that names something `region` is
  # unaffected. The block parses as a normal `EBlock`; the surface is
  # lowered to the marker `ECall(EVar("region"), [block])` so the
  # pre-typer region pass can recognise it by shape (mirroring how
  # nursery is recognised as `ECall(EVar("nursery"), ...)`), record the
  # region in a side table, run escape analysis, and unwrap the marker
  # back to the bare block. See docs/issue-120-regions-design.md.
  else if name == "region" and p_at(p1, TkLbrace) {
    parse_region(p1, t)
  }
  # m12.6.e: `ensure(value) where pred` primary — narrows `value`
  # into the refined type via a runtime check, returning
  # `Option[T]`. Recognised only when the call is followed by
  # `where`; without it, `ensure(x)` parses as an ordinary call so
  # user code that defines a function called `ensure` is unaffected.
  else if name == "ensure" and p_at(p1, TkLparen) {
    parse_ensure_primary(p1, t)
  }
  # Lambda: `name => body`. Body is parsed via `parse_or`, NOT
  # `parse_expr`, so a top-level pipe operator (`|`, `||`, `|?`,
  # `|>`) terminates the body and chains at the enclosing pipe
  # level. See issue #422 and `docs/syntax-sugars.md` §11.
  else if p_at(p1, TkFatArrow) {
    let p2 = p_advance(p1)
    let r = parse_or(p2)
    match r.r {
      None -> err_e(r.p)
      Some(body) -> {
        let param = Param { pname: name, ptype: None, pline: t.line, pcol: t.col }
        ok_e(r.p, mk_expr(ELambda([param], body), t.line, t.col))
      }
    }
  }
  # Record literal: `Name { ... }` — but only when the name is Uppercase.
  else if is_upper_ident(p.src, t) and p_at(p1, TkLbrace) {
    parse_record_lit(p1, name, t)
  }
  # Issue #456: qualified record literal `mod.Type { ... }`. Lowercase
  # head + `.UpperIdent` + `{` commits to a record literal whose type
  # name is folded into the dotted string `"mod.Type"`. The qualtype
  # rewriter pass validates against the module table and strips the
  # qualifier before resolve runs (mirrors the qualified-type-head
  # treatment in `parse_named_type`, issue #232).
  else if (not is_upper_ident(p.src, t)) and p_at(p1, TkDot) and
          tk_is(p_peek1(p1).kind, TkIdent) and
          is_upper_ident(p1.src, p_peek1(p1)) and
          tk_is(p_peek2(p1).kind, TkLbrace) {
    let nt = p_peek1(p1)
    let qname = concat_all([name, ".", tok_source(p1.src, nt)])
    # Advance past `.` and the UpperIdent so `p2` is at the `{`.
    let p2 = p_advance(p_advance(p1))
    parse_record_lit(p2, qname, t)
  }
  # Plain variable reference.
  else {
    ok_e(p1, mk_expr(EVar(name), t.line, t.col))
  }
}

# m7e §11: parse `variants[T]()`. `p` is positioned at the `[`; `t` is
# the original `variants` token (used for line/col). The closing `()`
# is mandatory and carries no payload — `variants[T](anything)` is a
# parse error. The TypeExpr inside the brackets is whatever
# `parse_type` accepts; resolver validates that it is a sum type with
# nullary-only variants.
fn parse_variants_of(p: Parser, t: Token) : PExpr / Console {

  let p1 = p_skip_newlines(p_advance(p))
  let r = parse_type(p1)
  match r.r {
    None -> err_e(r.p)
    Some(ty) -> {
      let p2 = p_skip_newlines(r.p)
      if not p_at(p2, TkRbracket) {
        err_e(p_error_here(p2, "expected `]` after type in `variants[T]`"))
      } else {
        let p3 = p_advance(p2)
        if not p_at(p3, TkLparen) {
          err_e(p_error_here(p3, "expected `()` after `variants[T]`"))
        } else {
          let p4 = p_advance(p3)
          if not p_at(p4, TkRparen) {
            err_e(p_error_here(p4,
              "`variants[T]()` does not accept arguments"))
          } else {
            ok_e(p_advance(p4),
                  mk_expr(EVariantsOf(ty, []), t.line, t.col))
          }
        }
      }
    }
  }
}

# issue #120: parse `region { ... }`. `p` is positioned at the `{`; `t`
# is the original `region` token (used for line/col so the pre-typer
# region pass can key the side table on the `region` keyword's
# position). The block is parsed as an ordinary `EBlock`, then wrapped
# in the marker `ECall(EVar("region"), [block])`. The block is the
# DIRECT single argument — NOT a thunk lambda — so it stays inline in
# the enclosing scope: no closure capture, no codegen perturbation. The
# pre-typer region pass (compiler.region) recognises this marker by
# shape, records the region, runs escape analysis, and unwraps it back
# to the bare block, so the typer and emitter see a normal block (P2a
# lowers to ordinary RC alloc; P1 consults the side table to bump-arena
# the region's constructors). `region` is NOT a fn and NOT an effect —
# the marker exists only between parse and the region pass.
fn parse_region(p: Parser, t: Token) : PExpr / Console {
  let r = parse_block(p, t)
  match r.r {
    None -> err_e(r.p)
    Some(block) -> {
      let callee = mk_expr(EVar("region"), t.line, t.col)
      ok_e(r.p, mk_expr(ECall(callee, [block]), t.line, t.col))
    }
  }
}

# m12.6.e: parse `ensure(value) where pred`. `p` is positioned at the
# `(` of `ensure(...)`; `t` is the original `ensure` token. The form
# desugars to:
#   { let self = value
#     if pred { Some(self) } else { None } }
# `self` is bound to the value so the predicate (which conventionally
# uses `self`, possibly elided in the leading-comparator form) sees it
# as a regular local. Without a `where` suffix, `ensure(...)` falls
# through to an ordinary call so user-defined `ensure` functions are
# preserved.
fn parse_ensure_primary(p: Parser, t: Token) : PExpr / Console {

  let p1 = p_skip_newlines(p_advance(p))
  let rv = parse_expr(p1)
  match rv.r {
    None -> err_e(rv.p)
    Some(value) -> {
      let p2 = p_skip_newlines(rv.p)
      if not p_at(p2, TkRparen) {
        err_e(p_error_here(p2, "expected `)` after value in `ensure(...)`"))
      } else {
        let p3 = p_advance(p2)
        if not p_at(p3, TkWhere) {
          # No `where` suffix — fall back to an ordinary call so the
          # name `ensure` remains usable as a regular function.
          let callee = mk_expr(EVar("ensure"), t.line, t.col)
          ok_e(p3, mk_expr(ECall(callee, [value]), t.line, t.col))
        } else {
          let p4 = p_skip_newlines(p_advance(p3))
          let pred_r = parse_refinement_predicate(p4, t.line, t.col)
          match pred_r.r {
            None -> err_e(pred_r.p)
            Some(pred) -> {
              # Build the desugared block:
              #   let self = value
              #   if pred { Some(self) } else { None }
              let self_let = SLet(mk_pat(PBind("self"), t.line, t.col),
                                  None, value)
              let self_var = mk_expr(EVar("self"), t.line, t.col)
              let some_call = mk_expr(ECall(
                mk_expr(EVar("Some"), t.line, t.col),
                [self_var]), t.line, t.col)
              let none_var = mk_expr(EVar("None"), t.line, t.col)
              let if_expr = mk_expr(EIf(pred, some_call, Some(none_var)),
                                    t.line, t.col)
              let block = mk_expr(EBlock([self_let], Some(if_expr)),
                                  t.line, t.col)
              ok_e(pred_r.p, block)
            }
          }
        }
      }
    }
  }
}

# m12.6.x #7: parse a `~r/pattern/` sigil token into an expression.
# The lexer has already validated the delimiter shape and stored the
# full sigil source span on the token. We desugar to a runtime call
# `regex_compile_or_panic("<pattern>")` whose result is a `Regex`
# value — meaning `~r/pat/` works as a first-class expression in any
# position, not just inside refinement predicates.
#
# The pattern body is wrapped as a kaikai string literal with two
# byte-level escapes (`\` -> `\\`, `"` -> `\"`) so the post-decode
# bytes match the regex source verbatim. v1 forbids `#` in the body
# because it would collide with kaikai's `#{...}` string
# interpolation; users wanting `#` in v1 can build the regex via
# `regex_compile` directly.
fn parse_regex_sigil(p: Parser, t: Token) : PExpr / Console {

  let span = tok_source(p.src, t)
  let n = string_length(span)
  # Span shape: `~r/pattern/`. Strip the 3-char prefix `~r/` and the
  # trailing `/`. The lexer guarantees both delimiters are present
  # (otherwise it emitted TkError, never TkRegex).
  let pattern = string_slice(span, 3, n - 4)
  if regex_pattern_has_hash(pattern, 0, string_length(pattern)) {
    err_e(p_error_here(p,
      "regex sigil contains `#`, which v1 forbids (would collide with kaikai string interpolation); use `regex_compile` directly for patterns containing `#`"))
  } else {
    let escaped = regex_pattern_to_kai_str_body(pattern, 0, string_length(pattern), "")
    let str_span = concat_all(["\"", escaped, "\""])
    let pat_str = mk_expr(EStr(str_span, false), t.line, t.col)
    let callee = mk_expr(EModCall("regexp", "compile_or_panic"), t.line, t.col)
    let call = mk_expr(ECall(callee, [pat_str]), t.line, t.col)
    ok_e(p_advance(p), call)
  }
}

# Walk the regex pattern body byte-by-byte, escaping the two
# characters that have a load-bearing meaning inside a kaikai
# string literal: `\` (escape introducer) and `"` (terminator).
# Every other byte passes through verbatim — including bytes that
# would be metacharacters at the regex level. The result is the
# *body* of a kaikai string literal; the caller wraps it in `"..."`.
fn regex_pattern_to_kai_str_body(s: String, i: Int, n: Int, acc: String) : String {
  if i >= n { acc }
  else {
    match char_at(s, i) {
      None -> acc
      Some(c) -> {
        let piece =
          if c == '\\' { "\\\\" }
          else if c == '"' { "\\\"" }
          else { "#{c}" }
        regex_pattern_to_kai_str_body(s, i + 1, n, string_concat(acc, piece))
      }
    }
  }
}

fn regex_pattern_has_hash(s: String, i: Int, n: Int) : Bool {
  if i >= n { false }
  else {
    match char_at(s, i) {
      None -> false
      Some(c) -> if c == '#' { true } else { regex_pattern_has_hash(s, i + 1, n) }
    }
  }
}

fn parse_record_lit(p: Parser, type_name: String, tname: Token) : PExpr / Console {

  # `{` is next. Consume it.
  let p1 = p_skip_newlines(p_advance(p))
  if p_at(p1, TkRbrace) {
    ok_e(p_advance(p1), mk_expr(ERecordLit(type_name, []), tname.line, tname.col))
  } else if p_at(p1, TkEllipsis) {
    # issue #326 — record-spread sugar: `T { ...src, x: 10, y: 20 }`.
    # The `...src` MUST be the first item; only named-field overrides
    # may follow. The source is captured as the first FieldInit with
    # the `__spread__` sentinel name and resolved by
    # `dpr_record_lit` against the record's declared field list.
    let _dotsTok = p_peek(p1)
    let p2 = p_skip_newlines(p_advance(p1))
    let r = parse_expr(p2)
    match r.r {
      None -> err_e(r.p)
      Some(src) -> {
        let acc0 = [FI(spread_field_marker(), src)]
        let p3 = p_skip_newlines(r.p)
        if p_at(p3, TkRbrace) {
          ok_e(p_advance(p3), mk_expr(ERecordLit(type_name, list_reverse(acc0)),
                                      tname.line, tname.col))
        } else if p_at(p3, TkComma) {
          parse_record_spread_loop(p_skip_newlines(p_advance(p3)), acc0, type_name, tname)
        } else {
          err_e(p_error_here(p3, "expected `,` or `}` after `...` source in record literal"))
        }
      }
    }
  } else {
    # issue #266 dispatch: peek the first item to choose between the
    # named-field path (existing) and the positional-sugar path. The
    # named path also covers `{ x, y }` punning, where the first item
    # is a bare ident followed by `,` or `}` — keeping legacy
    # behavior. Anything else (literal, call, expression, or an ident
    # followed by an expression-continuation token) routes to the
    # positional path. The positional fields are tagged with a
    # `__pos_<i>__` sentinel name; `desugar_pos_records_decls`
    # rewrites them into real field names using the record's
    # declared field order before any other pre-typer pass runs.
    let tk0 = p_peek(p1)
    let tk1 = p_peek1(p1)
    let tk1_named_follow = tk_is(tk1.kind, TkColon) or tk_is(tk1.kind, TkComma) or tk_is(tk1.kind, TkRbrace)
    let is_named_first = tk_is(tk0.kind, TkIdent) and tk1_named_follow
    if is_named_first {
      parse_record_fields_loop(p1, [], type_name, tname)
    } else {
      parse_record_pos_loop(p1, [], 0, type_name, tname)
    }
  }
}

# issue #326 — parse named-field overrides after `...src,`. The
# spread already lives at `acc[0]` with the `__spread__` sentinel.
# Pun and positional are rejected explicitly: pun would silently
# bind `x: x` from the local scope, which the proposal forbids;
# positional would conflict with #266. A second `...` is also
# rejected — v1 admits a single spread per literal.
fn parse_record_spread_loop(p: Parser, acc: [FieldInit], type_name: String, tname: Token) : PExpr / Console {

  let p0 = p_skip_newlines(p)
  if p_at(p0, TkRbrace) {
    ok_e(p_advance(p0), mk_expr(ERecordLit(type_name, list_reverse(acc)),
                                tname.line, tname.col))
  } else if p_at(p0, TkEllipsis) {
    err_e(p_error_here(p0,
      "record literal admits a single `...` spread; remove the second one"))
  } else {
    let tk = p_peek(p0)
    if not tk_is(tk.kind, TkIdent) {
      err_e(p_error(p0, tk,
        "expected named field override (`x: expr`) after `...` in record literal"))
    } else {
      let fname = tok_source(p0.src, tk)
      let p1 = p_advance(p0)
      if p_at(p1, TkColon) {
        let p2 = p_skip_newlines(p_advance(p1))
        let r = parse_expr(p2)
        match r.r {
          None -> err_e(r.p)
          Some(val) -> {
            let acc1 = [FI(fname, val), ...acc]
            let p3 = p_skip_newlines(r.p)
            if p_at(p3, TkComma) {
              parse_record_spread_loop(p_skip_newlines(p_advance(p3)), acc1, type_name, tname)
            } else if p_at(p3, TkRbrace) {
              ok_e(p_advance(p3), mk_expr(ERecordLit(type_name, list_reverse(acc1)),
                                          tname.line, tname.col))
            } else {
              err_e(p_error_here(p3, "expected `,` or `}` in record literal"))
            }
          }
        }
      } else {
        err_e(p_error(p1, p_peek(p1),
          "spread record overrides must use named field syntax `x: expr`; pun shorthand is not allowed after `...`"))
      }
    }
  }
}

# issue #266 — positional record sugar. Accumulates positional
# expressions tagged with `__pos_<i>__` field-name sentinels. Each
# item is a full Expr; intermixing `IDENT :` is a parse error.
fn parse_record_pos_loop(p: Parser, acc: [FieldInit], i: Int, type_name: String, tname: Token) : PExpr / Console {

  let p0 = p_skip_newlines(p)
  # Reject mixed forms: any subsequent item starting with `IDENT :`
  # signals named-field syntax inside a positional list.
  let tk0 = p_peek(p0)
  let tk1 = p_peek1(p0)
  if tk_is(tk0.kind, TkRbrace) {
    # Trailing comma: `R { 1, 2, }` — close the literal.
    ok_e(p_advance(p0), mk_expr(ERecordLit(type_name, list_reverse(acc)), tname.line, tname.col))
  } else if tk_is(tk0.kind, TkIdent) and tk_is(tk1.kind, TkColon) {
    err_e(p_error_here(p0, "expected positional or all-named record fields, found mixed forms"))
  } else {
    let r = parse_expr(p0)
    match r.r {
      None -> err_e(r.p)
      Some(val) -> {
        let acc1 = [FI(pos_field_marker(i), val), ...acc]
        let p1 = p_skip_newlines(r.p)
        if p_at(p1, TkComma) {
          parse_record_pos_loop(p_skip_newlines(p_advance(p1)), acc1, i + 1, type_name, tname)
        } else if p_at(p1, TkRbrace) {
          ok_e(p_advance(p1), mk_expr(ERecordLit(type_name, list_reverse(acc1)), tname.line, tname.col))
        } else {
          err_e(p_error_here(p1, "expected `,` or `}` in positional record literal"))
        }
      }
    }
  }
}

# pos_field_marker / spread_field_marker / is_pos_field_marker /
# is_spread_field_marker moved to compiler/ast.kai (issue #677 phase
# 1h H0): they are an AST-shape convention shared with codegen, not
# parser-internal.

fn parse_record_fields_loop(p: Parser, acc: [FieldInit], type_name: String, tname: Token) : PExpr / Console {

  let p0 = p_skip_newlines(p)
  let tk = p_peek(p0)
  if tk_is(tk.kind, TkEllipsis) {
    err_e(p_error(p0, tk,
      "`...` must be the first item in a record literal — found a field before the spread"))
  } else if tk_is(tk.kind, TkRbrace) {
    # Trailing comma: `R { a: 1, b: 2, }` — `acc` already contains the
    # parsed fields; close the literal here.
    ok_e(p_advance(p0), mk_expr(ERecordLit(type_name, list_reverse(acc)), tname.line, tname.col))
  } else if not tk_is(tk.kind, TkIdent) {
    err_e(p_error(p0, tk, "expected field name in record literal"))
  } else {
    let fname = tok_source(p0.src, tk)
    let p1 = p_advance(p0)
    if p_at(p1, TkColon) {
      let p2 = p_skip_newlines(p_advance(p1))
      let r = parse_expr(p2)
      match r.r {
        None -> err_e(r.p)
        Some(val) -> {
          let acc1 = [FI(fname, val), ...acc]
          let p3 = p_skip_newlines(r.p)
          if p_at(p3, TkComma) {
            parse_record_fields_loop(p_skip_newlines(p_advance(p3)), acc1, type_name, tname)
          } else if p_at(p3, TkRbrace) {
            ok_e(p_advance(p3), mk_expr(ERecordLit(type_name, list_reverse(acc1)), tname.line, tname.col))
          } else {
            err_e(p_error_here(p3, "expected `,` or `}` in record literal"))
          }
        }
      }
    }
    # m7d §10: record-literal punning. `{ x, y }` desugars to
    # `{ x: x, y: y }`. Symmetric with the pattern form already
    # parsed by `parse_record_pattern_fields` (PField is_shorthand).
    # Mixed forms (`{ x, y: other }`) compose because the punning
    # decision is per-field.
    else if p_at(p1, TkComma) or p_at(p1, TkRbrace) {
      let val = mk_expr(EVar(fname), tk.line, tk.col)
      let acc1 = [FI(fname, val), ...acc]
      if p_at(p1, TkComma) {
        parse_record_fields_loop(p_skip_newlines(p_advance(p1)), acc1, type_name, tname)
      } else {
        ok_e(p_advance(p1), mk_expr(ERecordLit(type_name, list_reverse(acc1)), tname.line, tname.col))
      }
    }
    else {
      err_e(p_error_here(p1, "expected `:`, `,`, or `}` after field name in record literal"))
    }
  }
}

fn parse_paren_or_lambda(p: Parser, t: Token) : PExpr / Console {

  # We need to distinguish:
  #   (expr)                  — grouping
  #   ()                       — unit
  #   () => expr               — zero-arg lambda
  #   (a, b, ...) => expr      — multi-arg lambda
  #   (a) => expr              — single-arg lambda (parenthesised)
  # Strategy: speculatively parse a lambda-param list. If followed by
  # `=>`, it's a lambda. Otherwise it was a parenthesised expression
  # and we re-parse from the original position.
  let p1 = p_skip_newlines(p_advance(p))
  # Empty parens: unit, or zero-arg lambda. Lambda body is parsed
  # via `parse_or` so a trailing pipe operator chains at the
  # enclosing level (issue #422).
  if p_at(p1, TkRparen) {
    let p2 = p_advance(p1)
    if p_at(p2, TkFatArrow) {
      let p3 = p_advance(p2)
      let r = parse_or(p3)
      match r.r {
        None -> err_e(r.p)
        Some(body) -> ok_e(r.p, mk_expr(ELambda([], body), t.line, t.col))
      }
    } else {
      ok_e(p2, mk_expr(EUnit, t.line, t.col))
    }
  } else {
    # Try lambda: tentatively scan for an ident list ending with `)` `=>`.
    # Body parsed via `parse_or` (issue #422).
    match try_parse_lambda_params(p1) {
      Some(res) -> {
        let r = parse_or(res.p)
        match r.r {
          None -> err_e(r.p)
          Some(body) -> ok_e(r.p, mk_expr(ELambda(res.params, body), t.line, t.col))
        }
      }
      None -> {
        # Fall back to `( expr )` or `( a, b, ... )` n-tuple sugar (#154).
        let r = parse_expr(p1)
        match r.r {
          None -> err_e(r.p)
          Some(e) -> {
            let p2 = p_skip_newlines(r.p)
            if p_at(p2, TkRparen) { ok_e(p_advance(p2), e) }
            else if p_at(p2, TkComma) {
              # n-tuple expression sugar: (a, b) => Pair { fst: a, snd: b },
              # (a, b, c) => Triple { ... }, (a, b, c, d) => Quad { ... }.
              # N capped at 4 — wider products should be a named record.
              parse_tuple_expr_rest(p_skip_newlines(p_advance(p2)), [e], t)
            }
            else { err_e(p_error_here(p2, "expected `)` after expression")) }
          }
        }
      }
    }
  }
}

# n-tuple expression sugar (#154). Called once the leading expr and a
# trailing `,` have been consumed. Accumulates further comma-separated
# exprs (in reverse) until `)`. On close, desugars to a record literal
# of the appropriate stdlib type (Pair / Triple / Quad). Arity > 4 is
# rejected with a diagnostic naming the cap.
fn parse_tuple_expr_rest(p: Parser, acc: [Expr], t: Token) : PExpr / Console {

  if p_at(p, TkRparen) {
    # Trailing comma: `(1, 2, 3,)` — `acc` already has all elements.
    let elems = list_reverse(acc)
    let p2 = p_advance(p)
    match tuple_type_for_arity(list_length(elems)) {
      None -> err_e(p_error_here(p, "n-tuple sugar supports arity 2..4 only — use a named record for wider products"))
      Some(name) -> ok_e(p2, mk_expr(ERecordLit(name, build_tuple_field_inits(elems, 0, [])), t.line, t.col))
    }
  } else {
  let r = parse_expr(p)
  match r.r {
    None -> err_e(r.p)
    Some(e) -> {
      let p1 = p_skip_newlines(r.p)
      if p_at(p1, TkComma) {
        parse_tuple_expr_rest(p_skip_newlines(p_advance(p1)), [e, ...acc], t)
      } else if p_at(p1, TkRparen) {
        let elems = list_reverse([e, ...acc])
        let p2 = p_advance(p1)
        match tuple_type_for_arity(list_length(elems)) {
          None -> err_e(p_error_here(p1, "n-tuple sugar supports arity 2..4 only — use a named record for wider products"))
          Some(name) -> ok_e(p2, mk_expr(ERecordLit(name, build_tuple_field_inits(elems, 0, [])), t.line, t.col))
        }
      } else {
        err_e(p_error_here(p1, "expected `,` or `)` in tuple expression"))
      }
    }
  }
  }
}

# Map arity → stdlib tuple type name. `None` for unsupported arities.
fn tuple_type_for_arity(n: Int) : Option[String] {
  match n {
    2 -> Some("Pair")
    3 -> Some("Triple")
    4 -> Some("Quad")
    _ -> None
  }
}

# Map positional index → tuple field name. Same convention across
# Pair / Triple / Quad: fst, snd, trd, frt.
fn tuple_field_name(i: Int) : String {
  match i {
    0 -> "fst"
    1 -> "snd"
    2 -> "trd"
    _ -> "frt"
  }
}

fn build_tuple_field_inits(elems: [Expr], i: Int, acc: [FieldInit]) : [FieldInit] {
  match elems {
    [] -> list_reverse(acc)
    [e, ...rest] -> build_tuple_field_inits(rest, i + 1, [FI(tuple_field_name(i), e), ...acc])
  }
}

# A lambda parameter list is a comma-separated sequence of identifiers
# (optionally with `: Type` annotations) followed by `)` then `=>`.
# This scan is non-destructive: it returns the parser advanced past the
# `=>` on success, None on failure.
type LamParams = { p: Parser, params: [Param] }

fn try_parse_lambda_params(p: Parser) : Option[LamParams] / Console {

  try_parse_lambda_params_loop(p, [])
}

fn try_parse_lambda_params_loop(p: Parser, acc: [Param]) : Option[LamParams] / Console {

  let t = p_peek(p)
  if not tk_is(t.kind, TkIdent) { None }
  else {
    let name = tok_source(p.src, t)
    let p1 = p_advance(p)
    # Optional `: Type`
    let p2_opt =
      if p_at(p1, TkColon) {
        let r = parse_type(p_advance(p1))
        match r.r {
          None -> None
          Some(_) -> Some(r.p)
        }
      } else {
        Some(p1)
      }
    match p2_opt {
      None -> None
      Some(p2) -> {
        let param = Param { pname: name, ptype: None, pline: t.line, pcol: t.col }
        let acc1 = [param, ...acc]
        if p_at(p2, TkComma) {
          try_parse_lambda_params_loop(p_skip_newlines(p_advance(p2)), acc1)
        } else if p_at(p2, TkRparen) {
          let p3 = p_advance(p2)
          if p_at(p3, TkFatArrow) {
            Some(LamParams { p: p_advance(p3), params: list_reverse(acc1) })
          } else { None }
        } else { None }
      }
    }
  }
}

# ====================================================================
# list / range
# ====================================================================

fn parse_list_or_range(p: Parser, t: Token) : PExpr / Console {

  let p1 = p_skip_newlines(p_advance(p))
  if p_at(p1, TkRbracket) {
    ok_e(p_advance(p1), mk_expr(EList([]), t.line, t.col))
  } else {
    # Parse first element (could start with `...`).
    parse_first_list_elem(p1, t)
  }
}

fn parse_first_list_elem(p: Parser, t: Token) : PExpr / Console {

  if p_at(p, TkEllipsis) {
    let r = parse_expr(p_advance(p))
    match r.r {
      None -> err_e(r.p)
      Some(e) -> parse_list_rest(r.p, [ElSpread(e)], t)
    }
  } else {
    let r = parse_expr(p)
    match r.r {
      None -> err_e(r.p)
      Some(first) -> {
        # Range: `[ a .. b ]` or `[ a .. b .. step ]`.
        let p1 = p_skip_newlines(r.p)
        if p_at(p1, TkDotDot) {
          let r2 = parse_expr(p_skip_newlines(p_advance(p1)))
          match r2.r {
            None -> err_e(r2.p)
            Some(to) -> {
              let p2 = p_skip_newlines(r2.p)
              if p_at(p2, TkDotDot) {
                let r3 = parse_expr(p_skip_newlines(p_advance(p2)))
                match r3.r {
                  None -> err_e(r3.p)
                  Some(step) -> {
                    let p3 = p_skip_newlines(r3.p)
                    if p_at(p3, TkRbracket) {
                      ok_e(p_advance(p3), mk_expr(ERange(first, to, Some(step)), t.line, t.col))
                    } else { err_e(p_error_here(p3, "expected `]` at end of range")) }
                  }
                }
              } else if p_at(p2, TkRbracket) {
                ok_e(p_advance(p2), mk_expr(ERange(first, to, None), t.line, t.col))
              } else { err_e(p_error_here(p2, "expected `]` at end of range")) }
            }
          }
        } else {
          parse_list_rest(p1, [ElPlain(first)], t)
        }
      }
    }
  }
}

fn parse_list_rest(p: Parser, acc: [ListElem], t: Token) : PExpr / Console {

  let p0 = p_skip_newlines(p)
  if p_at(p0, TkRbracket) {
    ok_e(p_advance(p0), mk_expr(EList(list_reverse(acc)), t.line, t.col))
  } else if p_at(p0, TkComma) {
    let p1 = p_skip_newlines(p_advance(p0))
    if p_at(p1, TkRbracket) {
      ok_e(p_advance(p1), mk_expr(EList(list_reverse(acc)), t.line, t.col))
    } else if p_at(p1, TkEllipsis) {
      let r = parse_expr(p_advance(p1))
      match r.r {
        None -> err_e(r.p)
        Some(e) -> parse_list_rest(r.p, [ElSpread(e), ...acc], t)
      }
    } else {
      let r = parse_expr(p1)
      match r.r {
        None -> err_e(r.p)
        Some(e) -> parse_list_rest(r.p, [ElPlain(e), ...acc], t)
      }
    }
  } else {
    err_e(p_error_here(p0, "expected `,` or `]` in list"))
  }
}

# ====================================================================
# block, if, match
# ====================================================================

fn parse_block(p: Parser, t: Token) : PExpr / Console {

  # `{` is at current position.
  let p1 = p_skip_newlines_and_semis(p_advance(p))
  parse_block_body(p1, [], t)
}

# m7b §1 *Lambda-block in non-trailing positions* — a `{` in
# expression position (i.e., reached via parse_primary, not via
# parse_handle's body) may start either a lambda-block or an
# ordinary block expression. Disambiguation is bounded lookahead:
#   {  ->  body    } -> zero-arity lambda-block
#   {  Ident ("," Ident)* "->"  body  } -> parameterised lambda-block
#   anything else -> ordinary block expression
# parse_handle still calls parse_block directly, so its body is
# always a block (a `{ x -> ... }` shape there is a syntax error,
# matching Doc A — handle clauses use a different production).
fn parse_brace_primary(p: Parser, t: Token) : PExpr / Console {

  # `{` is at p_peek(p). Peek past it (and any whitespace).
  let after_lbrace = p_skip_newlines(p_advance(p))
  let pp_r = try_parse_lambda_block_params(after_lbrace)
  match pp_r {
    Some(res) -> {
      let body_r = parse_lambda_block_body(res.p, t)
      match body_r.r {
        None -> err_e(body_r.p)
        Some(body) -> ok_e(body_r.p, mk_expr(ELambda(res.params, body), t.line, t.col))
      }
    }
    None -> parse_block(p, t)
  }
}

fn parse_block_body(p: Parser, stmts: [Stmt], t: Token) : PExpr / Console {

  let p0 = p_skip_newlines_and_semis(p)
  if p_at(p0, TkRbrace) {
    ok_e(p_advance(p0), mk_expr(EBlock(list_reverse(stmts), None), t.line, t.col))
  } else {
    let r = parse_stmt(p0)
    match r.r {
      None -> err_e(r.p)
      Some(s) -> {
        let p1 = p_skip_newlines_and_semis(r.p)
        if p_at(p1, TkRbrace) {
          # If the last stmt was an expression statement, it becomes the
          # block's final expression.
          match s {
            SExprStmt(e) -> ok_e(p_advance(p1), mk_expr(EBlock(list_reverse(stmts), Some(e)), t.line, t.col))
            _ -> ok_e(p_advance(p1), mk_expr(EBlock(list_reverse([s, ...stmts]), None), t.line, t.col))
          }
        } else {
          parse_block_body(p1, [s, ...stmts], t)
        }
      }
    }
  }
}

fn parse_stmt(p: Parser) : PStmt / Console {

  let t = p_peek(p)
  if tk_is(t.kind, TkLet) {
    parse_let(p, t)
  } else if tk_is(t.kind, TkVar) {
    parse_var(p, t)
  } else if tk_is(t.kind, TkCase) {
    # issue #415: `case` inside a stmt-block is the second half of a
    # mixed stmt + case body. The opening of the block was a stmt, so
    # the parser took the stmt-block path. Surface the pure-block
    # rule explicitly here instead of letting the user chase a stale
    # "expected expression" error.
    err_s(p_error(p, t, "case-block must contain only `case` arms; mix with stmt-block by extracting a helper or using `= match { ... }`"))
  } else if tk_is(t.kind, TkAssert) {
    parse_assert(p, t)
  } else if tk_is(t.kind, TkUse) {
    # m7e §25: `use Effect` at block scope. Same shape as the
    # file-level Decl form, but produces a Stmt so it can sit
    # mid-block. `desugar_use_decls` strips both before resolve.
    let p1 = p_advance(p)
    let id = p_peek(p1)
    if not tk_is(id.kind, TkIdent) {
      err_s(p_error(p1, id, "expected effect name after `use`"))
    } else if not is_upper_ident(p1.src, id) {
      err_s(p_error(p1, id, "effect name in `use` must start with an uppercase letter"))
    } else {
      let name = tok_source(p1.src, id)
      ok_s(p_advance(p1), SUse(name, t.line, t.col))
    }
  } else {
    let r = parse_expr(p)
    match r.r {
      None -> err_s(r.p)
      Some(e) -> {
        # m7b #6: indexed write `a[i] := v`. The LHS expression we just
        # parsed must be an `EIndex(base, idx)` whose `base` is a plain
        # identifier or a `.`-chain of fields rooted at an identifier
        # (the IndexLhs of `docs/syntax-sugars.md` §4). Anything else
        # (e.g. a call result) is rejected so the write hits a named
        # binding the caller can observe elsewhere.
        if p_at(r.p, TkColonEq) {
          parse_index_assign_rest(r.p, e, t)
        } else {
          ok_s(r.p, SExprStmt(e))
        }
      }
    }
  }
}

# m7b #6 + m7b #4: validate the LHS of `:=` and parse the RHS.
# Accepted shapes:
#   `Ident[i] := v`            (m7b #6 indexed write — SIndexAssign)
#   `Ident.field…[i] := v`     (m7b #6 indexed write through field path)
#   `Ident := v`               (m7b #4 capability write — desugared to
#                              `cap.set(v)`; the alias rewrite later
#                              maps it to `State.set(cap, v)`)
fn parse_index_assign_rest(p: Parser, lhs: Expr, t: Token) : PStmt / Console {

  match lhs.kind {
    EIndex(base, idx) -> {
      if not is_index_lhs_path(base) {
        err_s(p_error(p, t,
          string_concat(
            "left-hand side of `:=` must be `Ident` or `Ident.field…[i]`; ",
            "bind a temporary first if you need to write to a call result")))
      } else {
        let p1 = p_skip_newlines(p_advance(p))
        let rv = parse_expr(p1)
        match rv.r {
          None -> err_s(rv.p)
          Some(v) -> ok_s(rv.p, SIndexAssign(base, idx, v, lhs.line, lhs.col))
        }
      }
    }
    EVar(name) -> {
      # m7b #4: `cap := v` — desugar inline to `cap.set(v)` as a
      # statement. The alias rewrite remaps the resulting field
      # expression to `State.set(cap, v)`. Doc B §`Syntax note:
      # capability read/write sugar` rule 2: only `State[T].set(v)`
      # is the semantic target; if cap is a Reader binding the
      # desugar still produces `cap.set(v)`, the alias rewrite emits
      # `Reader.set(v)`, and the resolver rejects it ("Reader has
      # no operation `set`").
      let p1 = p_skip_newlines(p_advance(p))
      let rv = parse_expr(p1)
      match rv.r {
        None -> err_s(rv.p)
        Some(v) -> {
          let cap = mk_expr(EVar(name), lhs.line, lhs.col)
          let setter = mk_expr(EField(cap, "set"), lhs.line, lhs.col)
          let call = mk_expr(ECall(setter, [v]), lhs.line, lhs.col)
          ok_s(rv.p, SExprStmt(call))
        }
      }
    }
    _ -> err_s(p_error(p, t,
      "left-hand side of `:=` must be a capability binding `Ident`, an indexed `Ident[i]`, or `Ident.field…[i]`"))
  }
}

# IndexLhs ::= Ident ("." Ident)*  — used by m7b #6 to reject call-LHS
# index writes like `get_array()[0] := v`.
fn is_index_lhs_path(e: Expr) : Bool {
  match e.kind {
    EVar(_) -> true
    EField(base, _) -> is_index_lhs_path(base)
    _ -> false
  }
}

fn parse_let(p: Parser, t: Token) : PStmt / Console {

  let p1 = p_advance(p)
  let rp = parse_pattern(p1)
  match rp.r {
    None -> err_s(rp.p)
    Some(pat) -> {
      # Optional `: Type` annotation.
      let pa = p_skip_newlines(rp.p)
      let ty_opt_r =
        if p_at(pa, TkColon) {
          let rt = parse_type(p_advance(pa))
          match rt.r {
            None -> PTy { p: rt.p, r: None }
            Some(ty) -> PTy { p: rt.p, r: Some(ty) }
          }
        } else {
          PTy { p: pa, r: None }
        }
      if ty_opt_r.p.had_error and not pa.had_error { err_s(ty_opt_r.p) }
      else {
        let p_eq = p_skip_newlines(ty_opt_r.p)
        if not p_at(p_eq, TkEq) {
          err_s(p_error_here(p_eq, "expected `=` in let binding"))
        } else {
          let p_rhs = p_skip_newlines(p_advance(p_eq))
          let re = parse_expr(p_rhs)
          match re.r {
            None -> err_s(re.p)
            Some(rhs) -> ok_s(re.p, SLet(pat, ty_opt_r.r, rhs))
          }
        }
      }
    }
  }
}

# m7b #5: `var name (: T)? = init` — local mutable cell. The parser
# produces an `SVar` node; the pre-resolve `desugar_var_decls` pass
# rewrites every block containing an SVar into the canonical
# `handle { rest } with State[T](init) as name { ... }` form. No
# `var name` (without `= init`) form: rejected here with a syntax
# error so the desugared `with State[T](init)` always has a state
# value to thread.
fn parse_var(p: Parser, t: Token) : PStmt / Console {

  let p1 = p_advance(p)
  let nt = p_peek(p1)
  if not tk_is(nt.kind, TkIdent) {
    err_s(p_error(p1, nt, "expected identifier after `var`"))
  } else {
    let name = tok_source(p1.src, nt)
    let p2 = p_advance(p1)
    let ty_opt_r =
      if p_at(p2, TkColon) {
        let rt = parse_type(p_advance(p2))
        match rt.r {
          None -> PTy { p: rt.p, r: None }
          Some(ty) -> PTy { p: rt.p, r: Some(ty) }
        }
      } else {
        PTy { p: p2, r: None }
      }
    if ty_opt_r.p.had_error and not p2.had_error { err_s(ty_opt_r.p) }
    else {
      let p_eq = p_skip_newlines(ty_opt_r.p)
      if not p_at(p_eq, TkEq) {
        err_s(p_error_here(p_eq, "expected `=` in var binding (initialiser is required)"))
      } else {
        let p_rhs = p_skip_newlines(p_advance(p_eq))
        let re = parse_expr(p_rhs)
        match re.r {
          None -> err_s(re.p)
          Some(rhs) -> ok_s(re.p, SVar(name, ty_opt_r.r, rhs, t.line, t.col))
        }
      }
    }
  }
}

fn parse_assert(p: Parser, t: Token) : PStmt / Console {

  let p1 = p_advance(p)
  let re = parse_expr(p1)
  match re.r {
    None -> err_s(re.p)
    Some(cond) -> {
      if p_at(re.p, TkComma) {
        let p2 = p_skip_newlines(p_advance(re.p))
        let rm = parse_expr(p2)
        match rm.r {
          None -> err_s(rm.p)
          Some(msg) -> ok_s(rm.p, SAssert(cond, Some(msg)))
        }
      } else {
        ok_s(re.p, SAssert(cond, None))
      }
    }
  }
}

fn parse_if(p: Parser, t: Token) : PExpr / Console {

  let p1 = p_advance(p)
  # m7b §1: cond cannot consume a trailing `{` as a trailing lambda
  # — that `{` is the `if` body. Disable while parsing cond, then
  # restore the flag's prior value before consuming the body.
  let prev_atl = p1.allow_trailing_lambda
  let pc = p_with_trailing_lambda(p1, false)
  let rc = parse_expr(pc)
  match rc.r {
    None -> err_e(rc.p)
    Some(cond) -> {
      # Then-block
      let p2 = p_skip_newlines(p_with_trailing_lambda(rc.p, prev_atl))
      if not p_at(p2, TkLbrace) {
        err_e(p_error_here(p2, "expected `{` after `if` condition"))
      } else {
        let tb = p_peek(p2)
        let rt = parse_block(p2, tb)
        match rt.r {
          None -> err_e(rt.p)
          Some(then_e) -> {
            let p3 = p_skip_newlines(rt.p)
            if p_at(p3, TkElse) {
              let p4 = p_skip_newlines(p_advance(p3))
              if p_at(p4, TkIf) {
                let te = p_peek(p4)
                let re = parse_if(p4, te)
                match re.r {
                  None -> err_e(re.p)
                  Some(else_e) -> ok_e(re.p, mk_expr(EIf(cond, then_e, Some(else_e)), t.line, t.col))
                }
              } else if p_at(p4, TkLbrace) {
                let teb = p_peek(p4)
                let re = parse_block(p4, teb)
                match re.r {
                  None -> err_e(re.p)
                  Some(else_e) -> ok_e(re.p, mk_expr(EIf(cond, then_e, Some(else_e)), t.line, t.col))
                }
              } else {
                err_e(p_error_here(p4, "expected `if` or `{` after `else`"))
              }
            } else {
              ok_e(p3, mk_expr(EIf(cond, then_e, None), t.line, t.col))
            }
          }
        }
      }
    }
  }
}

fn parse_match(p: Parser, t: Token) : PExpr / Console {

  let p1 = p_advance(p)
  # m7b §1: same as `if` — scrutinees cannot eat the `{` that opens
  # the arms block as a trailing lambda.
  let prev_atl = p1.allow_trailing_lambda
  let ps = p_with_trailing_lambda(p1, false)
  let rs = parse_expr(ps)
  match rs.r {
    None -> err_e(rs.p)
    Some(scrut1) -> {
      # m7d §27: comma after the first scrutinee opens multi-scrutinee
      # match — `match e1, e2, ..., eN { p1, p2, ..., pN -> body | ... }`.
      # Parser-only sugar: desugars to nested EMatch over each column,
      # with fall-through to the remaining arms duplicated at the
      # column-1 wildcard branch. For N=1 (the original form), the
      # behaviour is unchanged.
      let r_more = parse_more_scruts(rs.p, [scrut1])
      let p2 = p_skip_newlines(p_with_trailing_lambda(r_more.p, prev_atl))
      if not p_at(p2, TkLbrace) {
        err_e(p_error_here(p2, "expected `{` after `match` expression"))
      } else {
        let scruts = list_reverse(r_more.r)
        let n = list_length(scruts)
        if n == 1 {
          parse_match_arms(p_skip_newlines(p_advance(p2)), [], scrut1, t)
        } else if n > 4 {
          # Issue #129: cap multi-arg `match` at 4 columns. Higher
          # arities exist (revisit if a use case wants 5+) but in
          # practice they push the desugared nesting past what stays
          # readable in diagnostics. Re-evaluate with concrete need.
          err_e(p_error_here(p2, "multi-arg `match` supports up to 4 scrutinees"))
        } else {
          parse_multi_match_arms(p_skip_newlines(p_advance(p2)), [], scruts, n, t)
        }
      }
    }
  }
}

# m7d §27: collect additional scrutinees after the first. `acc` is in
# reverse order; caller reverses. Returns the parser state pointing
# at the first non-`,` non-newline token.
type PScruts = { p: Parser, r: [Expr] }

fn parse_more_scruts(p: Parser, acc: [Expr]) : PScruts / Console {

  let p0 = p_skip_newlines(p)
  if not p_at(p0, TkComma) { PScruts { p: p0, r: acc } }
  else {
    let p1 = p_skip_newlines(p_advance(p0))
    let r = parse_expr(p1)
    match r.r {
      None    -> PScruts { p: r.p, r: acc }
      Some(e) -> parse_more_scruts(r.p, [e, ...acc])
    }
  }
}

# m7d §27: a multi-scrutinee arm carries N patterns (where N ==
# number of scrutinees). Mirrors `Arm` but with a list of patterns
# instead of a single one. Lives only in the parser; the desugar
# rewrites every MArm into nested standard `Arm`s before the AST
# leaves the parser.
type MArm = MArm([Pattern], Option[Expr], Expr)

# m7d §27: parse arms where each arm has N patterns separated by commas,
# optional guard, `->`, body. Stops at `}`.
fn parse_multi_match_arms(p: Parser, acc: [MArm], scruts: [Expr], n: Int, t: Token) : PExpr / Console {

  let p0 = p_skip_newlines_and_semis(p)
  if p_at(p0, TkRbrace) {
    let p1 = p_advance(p0)
    let arms_in_order = list_reverse(acc)
    let desugared = desugar_multi_match(scruts, arms_in_order, t.line, t.col)
    ok_e(p1, desugared)
  } else {
    let ra = parse_multi_arm(p0, n)
    match ra.r {
      None -> err_e(ra.p)
      Some(arm) -> parse_multi_match_arms(ra.p, [arm, ...acc], scruts, n, t)
    }
  }
}

# m7d §27: parse N comma-separated patterns followed by optional guard,
# `->`, body. The arity must match `n` (scrutinee count); mismatched
# arities are a parse error per the §27 spec.
type PMArm = { p: Parser, r: Option[MArm] }

fn err_marm(p: Parser) : PMArm = PMArm { p: p, r: None }
fn ok_marm(p: Parser, m: MArm) : PMArm = PMArm { p: p, r: Some(m) }

fn parse_multi_arm(p: Parser, n: Int) : PMArm / Console {

  let r_pats = parse_n_patterns(p, n, [])
  match r_pats.r {
    None -> err_marm(r_pats.p)
    Some(pats) -> {
      let p1 = p_skip_newlines(r_pats.p)
      let guard_opt_r =
        if p_at(p1, TkIf) {
          let prev_atl = p1.allow_trailing_lambda
          let pg = p_with_trailing_lambda(p_advance(p1), false)
          let rg = parse_expr(pg)
          let rg_p = p_with_trailing_lambda(rg.p, prev_atl)
          match rg.r {
            None -> PExpr { p: rg_p, r: None }
            Some(g) -> PExpr { p: rg_p, r: Some(g) }
          }
        } else {
          PExpr { p: p1, r: None }
        }
      let p2 = p_skip_newlines(guard_opt_r.p)
      if not p_at(p2, TkArrow) {
        err_marm(p_error_here(p2, "expected `->` in multi-arg match arm"))
      } else {
        let p3 = p_skip_newlines(p_advance(p2))
        let rb = parse_expr(p3)
        match rb.r {
          None -> err_marm(rb.p)
          Some(body) -> ok_marm(rb.p, MArm(pats, guard_opt_r.r, body))
        }
      }
    }
  }
}

# m7d §27: parse exactly `n` patterns, separated by commas. Returns
# None if any pattern fails to parse or if the comma count does not
# match (n-1 commas expected between n patterns).
type PPatN = { p: Parser, r: Option[[Pattern]] }

fn err_patn(p: Parser) : PPatN = PPatN { p: p, r: None }
fn ok_patn(p: Parser, ps: [Pattern]) : PPatN = PPatN { p: p, r: Some(ps) }

fn parse_n_patterns(p: Parser, n: Int, acc: [Pattern]) : PPatN / Console {

  if n == 0 {
    ok_patn(p, list_reverse(acc))
  } else {
    let rp = parse_pattern(p)
    match rp.r {
      None -> err_patn(rp.p)
      Some(pat) -> {
        let next = n - 1
        if next == 0 { ok_patn(rp.p, list_reverse([pat, ...acc])) }
        else {
          let p1 = p_skip_newlines(rp.p)
          if not p_at(p1, TkComma) {
            err_patn(p_error_here(p1, "expected `,` between multi-arg match patterns"))
          } else {
            parse_n_patterns(p_skip_newlines(p_advance(p1)), next, [pat, ...acc])
          }
        }
      }
    }
  }
}

# m7d §27: build the desugared AST. The shape is:
#
#   {
#     let __mm_s_0 = e0
#     let __mm_s_1 = e1
#     ...
#     match __mm_s_0 {
#       p0_arm0 -> match __mm_s_1 { p1_arm0 -> ... pN_arm0 -> body_arm0 | _ -> fall_arm1 }
#       _       -> fall_arm1
#     }
#   }
#
# where `fall_arm1` is the same shape recursively built over arm 1.
# The base case (no arms left) is a panic via `Fail.fail`. Bodies
# are duplicated only structurally — kaikai bodies are immutable
# Exprs, so the duplication does not cost runtime evaluation, only
# emitted-code size. For typical demo arities (N=2, K=3) the blow-up
# is bounded.
fn desugar_multi_match(scruts: [Expr], arms: [MArm], line: Int, col: Int) : Expr {
  let stmts = build_scrut_lets(scruts, 0, [])
  let scrut_vars = make_scrut_var_exprs(scruts, 0, line, col)
  let body = build_multi_match_chain(scrut_vars, arms, line, col)
  mk_expr(EBlock(list_reverse(stmts), Some(body)), line, col)
}

# m7d §27: emit `let __mm_s_i = scrut_i` statements, in the order
# they appear; returned reversed so the desugar wraps them with
# `list_reverse` to restore source order.
fn build_scrut_lets(scruts: [Expr], i: Int, acc: [Stmt]) : [Stmt] {
  match scruts {
    [] -> acc
    [e, ...rest] -> {
      let nm = scrut_var_name(i)
      let pat = mk_pat(PBind(nm), e.line, e.col)
      build_scrut_lets(rest, i + 1, [SLet(pat, None, e), ...acc])
    }
  }
}

fn make_scrut_var_exprs(scruts: [Expr], i: Int, line: Int, col: Int) : [Expr] {
  match scruts {
    [] -> []
    [_, ...rest] -> [
      mk_expr(EVar(scrut_var_name(i)), line, col),
      ...make_scrut_var_exprs(rest, i + 1, line, col)
    ]
  }
}

fn scrut_var_name(i: Int) : String =
  string_concat("__mm_s_", int_to_string(i))

# m7d §27: recursive builder for the arm chain. At each arm,
# constructs an EMatch over scrut_var_0 with two arms:
#   - column-1 pattern -> nested match on remaining columns
#   - wildcard         -> fall-through to next arm
# Both branches reference the same fall-through subtree, which is
# computed once but referenced twice (the AST is shared structurally
# since `Expr` values are immutable). When `arms` is empty, returns
# a panic via Fail-style trap.
fn build_multi_match_chain(scrut_vars: [Expr], arms: [MArm], line: Int, col: Int) : Expr {
  match arms {
    [] -> non_exhaustive_trap(line, col)
    [head, ...rest] -> {
      let fall = build_multi_match_chain(scrut_vars, rest, line, col)
      build_one_marm(scrut_vars, head, fall, line, col)
    }
  }
}

# m7d §27: lower one MArm into the nested-EMatch chain it stands for,
# wiring the failing-pattern branch to `fall`. The guard, when present,
# is attached to the innermost arm (last column).
fn build_one_marm(scrut_vars: [Expr], arm: MArm, fall: Expr, line: Int, col: Int) : Expr {
  match arm {
    MArm(pats, guard, body) -> build_marm_columns(scrut_vars, pats, guard, body, fall, line, col)
  }
}

fn build_marm_columns(scrut_vars: [Expr], pats: [Pattern], guard: Option[Expr],
                       body: Expr, fall: Expr, line: Int, col: Int) : Expr {
  match scrut_vars {
    [] -> body
    [sv, ...rest_svs] -> match pats {
      [] -> body
      [p, ...rest_ps] -> {
        # The guard, when present, only attaches to the innermost
        # column (last pattern); interior columns always carry None.
        let inner_guard = match rest_ps { [] -> guard  _ -> None }
        let inner = match rest_ps {
          [] -> Arm(p, guard, body)
          _  -> Arm(p, None, build_marm_columns(rest_svs, rest_ps, guard, body, fall, line, col))
        }
        # When this column's pattern is irrefutable (PWild / PBind /
        # nested PAs) AND the arm in this position carries no guard
        # that could fail, the `_ -> fall` sibling is unreachable.
        # Emitting it anyway produces two `default:` cases in the same
        # C `switch` (issue #129 follow-up). Drop the dead wildcard so
        # the match collapses to a single irrefutable arm; the fall
        # subtree stays reachable through the recursion's own `fall`.
        if pat_is_irrefutable(p) and guard_cannot_fail_here(inner_guard) {
          mk_expr(EMatch(sv, [inner]), line, col)
        } else {
          let wild = mk_pat(PWild, line, col)
          mk_expr(EMatch(sv, [inner, Arm(wild, None, fall)]), line, col)
        }
      }
    }
  }
}

# m7d §27 / issue #129 follow-up: a multi-arg-match column pattern is
# irrefutable when it always binds without testing the scrutinee — a
# wildcard, a name binding, or an `@`-alias whose inner pattern is also
# irrefutable. Such a column needs no fall-through sibling.
fn pat_is_irrefutable(p: Pattern) : Bool {
  match p.pkind {
    PWild        -> true
    PBind(_)     -> true
    PAs(_, inner) -> pat_is_irrefutable(inner)
    _            -> false
  }
}

# A column's arm can still fall through when it carries a guard, since a
# false guard re-routes control to the next arm. No guard means an
# irrefutable column always commits, so the wildcard sibling is dead.
fn guard_cannot_fail_here(g: Option[Expr]) : Bool {
  match g {
    None    -> true
    Some(_) -> false
  }
}

# m7d §27: trap for "no arm matched". Uses `todo!` (m7d §1) which
# behaves like a panic at runtime and matches any expected type in
# inference, without forcing the surrounding fn to declare a `/ Fail`
# row. v2 can refine to a static cross-column exhaustiveness check
# that elides the trap when arms statically cover the cartesian space.
fn non_exhaustive_trap(line: Int, col: Int) : Expr =
  mk_expr(ETodo("non-exhaustive multi-arg match"), line, col)

fn parse_match_arms(p: Parser, acc: [Arm], scrut: Expr, t: Token) : PExpr / Console {

  let p0 = p_skip_newlines_and_semis(p)
  if p_at(p0, TkRbrace) {
    ok_e(p_advance(p0), mk_expr(EMatch(scrut, list_reverse(acc)), t.line, t.col))
  } else {
    let ra = parse_arm(p0)
    match ra.r {
      None -> err_e(ra.p)
      Some(arm) -> parse_match_arms(ra.p, [arm, ...acc], scrut, t)
    }
  }
}

fn parse_arm(p: Parser) : PArm / Console {

  let rp = parse_pattern(p)
  match rp.r {
    None -> err_a(rp.p)
    Some(pat) -> {
      # m12.6.x #3: optional refinement-narrowing `: Type where ...`
      # after a binding pattern. Lowers to a guard that evaluates the
      # refinement's predicate with `self` bound to the name. Only
      # PBind patterns participate; other shapes ignore the suffix.
      let p_after_ty = p_skip_newlines(rp.p)
      let nr = parse_optional_arm_refine(p_after_ty, pat)
      # issue #187 phase 3: arm-refine may rewrite the pattern (PNarrow).
      let pat_eff = match nr.new_pat { Some(np) -> np  None -> pat }
      let p1 = p_skip_newlines(nr.p)
      # Optional guard: `if expr`. Same discipline as `parse_if` /
      # `parse_match`: the guard expression cannot eat the `->` (or
      # an arm body's `{`) by extending into a trailing lambda. Off
      # the flag for the guard, restore for the body.
      let guard_opt_r =
        if p_at(p1, TkIf) {
          let prev_atl = p1.allow_trailing_lambda
          let pg = p_with_trailing_lambda(p_advance(p1), false)
          let rg = parse_expr(pg)
          let rg_p = p_with_trailing_lambda(rg.p, prev_atl)
          match rg.r {
            None -> PExpr { p: rg_p, r: None }
            Some(g) -> PExpr { p: rg_p, r: Some(g) }
          }
        } else {
          PExpr { p: p1, r: None }
        }
      let combined_guard = combine_guards(nr.guard, guard_opt_r.r)
      match guard_opt_r.r {
        None -> if guard_opt_r.p.had_error { err_a(guard_opt_r.p) } else {
          parse_arm_body(guard_opt_r.p, pat_eff, combined_guard)
        }
        Some(_) -> parse_arm_body(guard_opt_r.p, pat_eff, combined_guard)
      }
    }
  }
}

# m12.6.x #3 result: parser state after consuming an optional `: Type`
# refinement-narrowing suffix on a match arm pattern. `guard` holds
# the synthesised predicate (or None when no suffix was present).
# issue #187 phase 3: `new_pat` overrides the original pattern when
# the suffix lowers to a `PNarrow` instead of a guard. `None` means
# leave the caller's pattern unchanged.
type ArmRefine = { p: Parser, guard: Option[Expr], new_pat: Option[Pattern] }

fn parse_optional_arm_refine(p: Parser, pat: Pattern) : ArmRefine / Console {

  if not p_at(p, TkColon) { ArmRefine { p: p, guard: None, new_pat: None } }
  else { match pat.pkind {
    PBind(name) -> {
      let p1 = p_skip_newlines(p_advance(p))
      let rt = parse_type(p1)
      match rt.r {
        None -> ArmRefine { p: rt.p, guard: None, new_pat: None }
        Some(ty) -> match ty.tkind {
          TyRefine(_, pred) -> {
            # Lower to `{ let self = <name>; pred }`. The let binding
            # makes the user-side `self` reference inside the predicate
            # resolve to the bound match variable. Same desugar as
            # `ensure(value) where pred` (m12.6.e).
            let var_e = mk_expr(EVar(name), pat.line, pat.col)
            let self_let = SLet(mk_pat(PBind("self"), pat.line, pat.col),
                                None, var_e)
            let block = mk_expr(EBlock([self_let], Some(pred)),
                                 pat.line, pat.col)
            ArmRefine { p: rt.p, guard: Some(block), new_pat: None }
          }
          # issue #187 phase 3 + m12.6.x #3 v2: `name : TyName(t, ...)`.
          # Parser cannot tell whether `t` is a refinement-type alias
          # (m12.6.x) or a union-component nominal type (#187), so it
          # emits a uniform `PNarrow(name, ty)` pattern with no guard.
          # `lower_pattern_narrow_decls` later splits the cases: for
          # every refinement alias declared in the program, the
          # narrowing is rewritten back into `PBind(name)` + a guard
          # call to `__ref_pred_t(name)` (preserving the m12.6.x
          # behaviour); narrowings whose target is not a refinement
          # alias survive as `PNarrow` for the typer, which checks
          # the scrutinee is a union containing the component.
          TyName(_, _) -> ArmRefine {
            p: rt.p,
            guard: None,
            new_pat: Some(mk_pat(PNarrow(name, ty), pat.line, pat.col))
          }
          _ -> ArmRefine {
            p: p_error(rt.p, p_peek(p),
                       "match-arm narrowing `: Type` requires either an inline `Int where ...` or a refinement-type alias name"),
            guard: None, new_pat: None
          }
        }
      }
    }
    _ -> ArmRefine {
      p: p_error(p, p_peek(p),
                 "match-arm narrowing `: Type` only applies to a binding pattern (a bare name)"),
      guard: None, new_pat: None
    }
  } }
}

# m12.6.x #3: combine two optional guards with `and`. When either
# side is None, return the other; when both are present, build
# `narrow_guard and user_guard` so a violated refinement
# short-circuits before the user predicate runs.
fn combine_guards(narrow: Option[Expr], user: Option[Expr]) : Option[Expr] {
  match narrow {
    None -> user
    Some(n) -> match user {
      None -> Some(n)
      Some(u) -> Some(mk_expr(EBinop("and", n, u), n.line, n.col))
    }
  }
}

fn parse_arm_body(p: Parser, pat: Pattern, guard: Option[Expr]) : PArm / Console {

  let p1 = p_skip_newlines(p)
  if not p_at(p1, TkArrow) {
    err_a(p_error_here(p1, "expected `->` in match arm"))
  } else {
    let p2 = p_skip_newlines(p_advance(p1))
    let rb = parse_expr(p2)
    match rb.r {
      None -> err_a(rb.p)
      Some(body) -> ok_a(rb.p, Arm(pat, guard, body))
    }
  }
}

# ====================================================================
# patterns
# ====================================================================

fn parse_pattern(p: Parser) : PPat / Console {

  let t = p_peek(p)
  match t.kind {
    TkHole          -> ok_p(p_advance(p), mk_pat(PHole(None), t.line, t.col))
    TkHoleName(nm)  -> ok_p(p_advance(p), mk_pat(PHole(Some(nm)), t.line, t.col))
    _ -> parse_pattern_rest(p, t)
  }
}

fn parse_pattern_rest(p: Parser, t: Token) : PPat / Console {

  if tk_is(t.kind, TkUnderscore) {
    ok_p(p_advance(p), mk_pat(PWild, t.line, t.col))
  } else if tk_is(t.kind, TkInt) {
    let span = tok_source(p.src, t)
    let lit = mk_expr(EInt(decode_int(span)), t.line, t.col)
    ok_p(p_advance(p), mk_pat(PLit(lit), t.line, t.col))
  } else if tk_is(t.kind, TkReal) {
    let span = tok_source(p.src, t)
    let lit = mk_expr(EReal(decode_real(span)), t.line, t.col)
    ok_p(p_advance(p), mk_pat(PLit(lit), t.line, t.col))
  } else if tk_is(t.kind, TkTrue) {
    ok_p(p_advance(p), mk_pat(PLit(mk_expr(EBool(true), t.line, t.col)), t.line, t.col))
  } else if tk_is(t.kind, TkFalse) {
    ok_p(p_advance(p), mk_pat(PLit(mk_expr(EBool(false), t.line, t.col)), t.line, t.col))
  } else if tk_is(t.kind, TkChar) {
    let span = tok_source(p.src, t)
    ok_p(p_advance(p), mk_pat(PLit(mk_expr(EChar(decode_char(span)), t.line, t.col)), t.line, t.col))
  } else if tk_is(t.kind, TkString) {
    let span = tok_source(p.src, t)
    ok_p(p_advance(p), mk_pat(PLit(mk_expr(EStr(span, false), t.line, t.col)), t.line, t.col))
  } else if tk_is(t.kind, TkMinus) {
    let nxt = p_peek1(p)
    if tk_is(nxt.kind, TkInt) {
      let span = tok_source(p.src, nxt)
      let v = 0 - decode_int(span)
      let p1 = p_advance(p_advance(p))
      ok_p(p1, mk_pat(PLit(mk_expr(EInt(v), t.line, t.col)), t.line, t.col))
    } else {
      err_p(p_error_here(p, "expected literal after `-` in pattern"))
    }
  } else if tk_is(t.kind, TkLbracket) {
    parse_list_pattern(p, t)
  } else if tk_is(t.kind, TkLparen) {
    # n-tuple pattern sugar (#154). `(a, b)` desugars to a record
    # pattern matching the corresponding stdlib type — `Pair` for
    # arity 2, `Triple` for 3, `Quad` for 4. Single-element parens
    # `(p)` are grouping (returns `p` unchanged); zero-element `()`
    # is reserved for the unit pattern (rejected here as a parse
    # error to keep the surface small until a use case appears).
    parse_tuple_pattern(p, t)
  } else if tk_is(t.kind, TkLbrace) {
    # m7d §28: anonymous record pattern. `{ fst, snd }` (with field
    # punning) or `{ fst: a, snd: b }`. The typer + bind_pat +
    # emitter machinery for PRecord is shared with the existing
    # match-arm record patterns, so this only needs the parser
    # entry point. Useful primarily on the LHS of `let` to
    # destructure multi-return shapes (Pair[a, b], etc.) without
    # the three-line `let p = ...; let a = p.fst; let b = p.snd`
    # ceremony.
    parse_record_pattern_fields(p_skip_newlines(p_advance(p)), [], None, t)
  } else if tk_is(t.kind, TkIdent) {
    parse_ident_pattern(p, t)
  } else {
    err_p(p_error_here(p, "expected pattern"))
  }
}

fn parse_list_pattern(p: Parser, t: Token) : PPat / Console {

  let p1 = p_skip_newlines(p_advance(p))
  if p_at(p1, TkRbracket) {
    ok_p(p_advance(p1), mk_pat(PList([], None), t.line, t.col))
  } else {
    parse_list_pattern_loop(p1, [], None, t)
  }
}

fn parse_list_pattern_loop(p: Parser, acc: [Pattern], rest: Option[String], t: Token) : PPat / Console {

  if p_at(p, TkEllipsis) {
    # Spread binder. Issue #328: `...` may stand alone (preferred form
    # `[h, ...]`) or be followed by `_` (uniform-with-`_` form
    # `[h, ..._]`); both discard the tail with no binding. The named
    # form `[h, ...rest]` keeps the existing semantics. Bare/`_` spread
    # uses a synthesized sentinel name (`__list_rest_<line>_<col>__`)
    # that round-trips as `Some(name)` through the rest of the pipeline,
    # preserving the spread-vs-no-spread distinction the typer needs
    # for exhaustiveness while leaving the binding unread.
    let p1 = p_advance(p)
    let id = p_peek(p1)
    if tk_is(id.kind, TkIdent) {
      let name = tok_source(p1.src, id)
      let p2 = p_skip_newlines(p_advance(p1))
      if p_at(p2, TkRbracket) {
        ok_p(p_advance(p2), mk_pat(PList(list_reverse(acc), Some(name)), t.line, t.col))
      } else {
        err_p(p_error_here(p2, "expected `]` after spread pattern"))
      }
    } else if tk_is(id.kind, TkUnderscore) {
      let sentinel = concat_all(["__list_rest_", int_to_string(id.line), "_",
                                  int_to_string(id.col), "__"])
      let p2 = p_skip_newlines(p_advance(p1))
      if p_at(p2, TkRbracket) {
        ok_p(p_advance(p2), mk_pat(PList(list_reverse(acc), Some(sentinel)), t.line, t.col))
      } else {
        err_p(p_error_here(p2, "expected `]` after spread pattern"))
      }
    } else if tk_is(id.kind, TkRbracket) {
      let sentinel = concat_all(["__list_rest_", int_to_string(id.line), "_",
                                  int_to_string(id.col), "__"])
      ok_p(p_advance(p1), mk_pat(PList(list_reverse(acc), Some(sentinel)), t.line, t.col))
    } else {
      err_p(p_error_here(p1, "expected identifier, `_`, or `]` after `...` in list pattern"))
    }
  } else {
    let r = parse_pattern(p)
    match r.r {
      None -> err_p(r.p)
      Some(pat) -> {
        let p1 = p_skip_newlines(r.p)
        if p_at(p1, TkComma) {
          parse_list_pattern_loop(p_skip_newlines(p_advance(p1)), [pat, ...acc], None, t)
        } else if p_at(p1, TkRbracket) {
          ok_p(p_advance(p1), mk_pat(PList(list_reverse([pat, ...acc]), None), t.line, t.col))
        } else {
          err_p(p_error_here(p1, "expected `,` or `]` in list pattern"))
        }
      }
    }
  }
}

# n-tuple pattern sugar (#154). Mirrors parse_tuple_expr_rest: starts
# with `(`, parses N≥2 comma-separated sub-patterns, closes with `)`,
# desugars to a `PVariantRecord` of the corresponding stdlib type
# (`Pair` / `Triple` / `Quad`). Single-paren `(p)` is grouping —
# returns the inner pattern unchanged. Empty `()` is rejected.
fn parse_tuple_pattern(p: Parser, t: Token) : PPat / Console {

  let p1 = p_skip_newlines(p_advance(p))
  if p_at(p1, TkRparen) {
    err_p(p_error_here(p1, "empty tuple pattern `()` not supported"))
  } else {
    let r = parse_pattern(p1)
    match r.r {
      None -> err_p(r.p)
      Some(first) -> {
        let p2 = p_skip_newlines(r.p)
        if p_at(p2, TkRparen) {
          # Single-pattern parens: grouping.
          ok_p(p_advance(p2), first)
        } else if p_at(p2, TkComma) {
          parse_tuple_pattern_rest(p_skip_newlines(p_advance(p2)), [first], t)
        } else {
          err_p(p_error_here(p2, "expected `,` or `)` in tuple pattern"))
        }
      }
    }
  }
}

fn parse_tuple_pattern_rest(p: Parser, acc: [Pattern], t: Token) : PPat / Console {

  let r = parse_pattern(p)
  match r.r {
    None -> err_p(r.p)
    Some(pat) -> {
      let p1 = p_skip_newlines(r.p)
      if p_at(p1, TkComma) {
        parse_tuple_pattern_rest(p_skip_newlines(p_advance(p1)), [pat, ...acc], t)
      } else if p_at(p1, TkRparen) {
        let pats = list_reverse([pat, ...acc])
        let p2 = p_advance(p1)
        match tuple_type_for_arity(list_length(pats)) {
          None -> err_p(p_error_here(p1, "n-tuple sugar supports arity 2..4 only — use a named record for wider products"))
          Some(name) -> ok_p(p2, mk_pat(PVariantRecord(name, build_tuple_pfields(pats, 0, [])), t.line, t.col))
        }
      } else {
        err_p(p_error_here(p1, "expected `,` or `)` in tuple pattern"))
      }
    }
  }
}

fn build_tuple_pfields(pats: [Pattern], i: Int, acc: [PField]) : [PField] {
  match pats {
    [] -> list_reverse(acc)
    [pat, ...rest] -> build_tuple_pfields(rest, i + 1, [PField(tuple_field_name(i), pat, false), ...acc])
  }
}

fn parse_ident_pattern(p: Parser, t: Token) : PPat / Console {

  let name = tok_source(p.src, t)
  let p1 = p_advance(p)
  # Issue #234: qualified variant pattern `mod.Ctor[(subs)|{fields}]`.
  # Lowercase head + `.UpperIdent` is a qualifier; drop it and let
  # the trailing UpperIdent flow through the existing variant
  # arms. Module-table validation happens at runtime in
  # rqc_kind for expressions; for patterns the qualifier is purely
  # disambiguation surface so dropping it is sound — the typer
  # narrows the variant's parent type from the scrutinee anyway.
  if (not is_upper_ident(p.src, t)) and p_at(p1, TkDot) and tk_is(p_peek1(p1).kind, TkIdent) and is_upper_ident(p1.src, p_peek1(p1)) {
    let nt = p_peek1(p1)
    parse_ident_pattern(p_advance(p1), nt)
  } else if is_upper_ident(p.src, t) and p_at(p1, TkLparen) {
    # Variant with positional sub-patterns.
    let p2 = p_skip_newlines(p_advance(p1))
    if p_at(p2, TkRparen) {
      ok_p(p_advance(p2), mk_pat(PVariant(name, []), t.line, t.col))
    } else {
      parse_variant_sub_patterns(p2, [], name, t)
    }
  } else if is_upper_ident(p.src, t) and p_at(p1, TkLbrace) {
    # Variant-record pattern: parse as record, wrap in PVariantRecord.
    let p2 = p_skip_newlines(p_advance(p1))
    parse_record_pattern_fields(p2, [], Some(name), t)
  } else if is_upper_ident(p.src, t) {
    # Bare uppercase ident: 0-arg variant.
    ok_p(p1, mk_pat(PVariant(name, []), t.line, t.col))
  } else if p_at(p1, TkAt) {
    # m7d §14: `name @ pattern` — as-pattern. Bind `name` to the
    # whole scrutinee and continue matching with the sub-pattern.
    # The lowercase ident already implies a fresh binding; the inner
    # pattern is parsed by the same `parse_pattern` entry, so list,
    # variant, record, hole, and even nested as-patterns compose.
    let p2 = p_skip_newlines(p_advance(p1))
    let r = parse_pattern(p2)
    match r.r {
      None -> err_p(r.p)
      Some(sub) -> ok_p(r.p, mk_pat(PAs(name, sub), t.line, t.col))
    }
  } else {
    ok_p(p1, mk_pat(PBind(name), t.line, t.col))
  }
}

fn parse_variant_sub_patterns(p: Parser, acc: [Pattern], name: String, t: Token) : PPat / Console {

  let r = parse_pattern(p)
  match r.r {
    None -> err_p(r.p)
    Some(sub) -> {
      let p1 = p_skip_newlines(r.p)
      if p_at(p1, TkComma) {
        parse_variant_sub_patterns(p_skip_newlines(p_advance(p1)), [sub, ...acc], name, t)
      } else if p_at(p1, TkRparen) {
        ok_p(p_advance(p1), mk_pat(PVariant(name, list_reverse([sub, ...acc])), t.line, t.col))
      } else {
        err_p(p_error_here(p1, "expected `,` or `)` in variant pattern"))
      }
    }
  }
}

fn parse_record_pattern_fields(p: Parser, acc: [PField], ctor: Option[String], t: Token) : PPat / Console {

  let p0 = p_skip_newlines(p)
  if p_at(p0, TkRbrace) {
    let p1 = p_advance(p0)
    match ctor {
      None -> ok_p(p1, mk_pat(PRecord(list_reverse(acc)), t.line, t.col))
      Some(name) -> ok_p(p1, mk_pat(PVariantRecord(name, list_reverse(acc)), t.line, t.col))
    }
  } else {
    let fn_t = p_peek(p0)
    if not tk_is(fn_t.kind, TkIdent) {
      err_p(p_error(p0, fn_t, "expected field name in record pattern"))
    } else {
      let fname = tok_source(p0.src, fn_t)
      let p1 = p_advance(p0)
      let sub_r =
        if p_at(p1, TkColon) {
          let r = parse_pattern(p_advance(p1))
          match r.r {
            None -> PPat { p: r.p, r: None }
            Some(sp) -> PPat { p: r.p, r: Some(sp) }
          }
        } else {
          PPat { p: p1, r: Some(mk_pat(PBind(fname), fn_t.line, fn_t.col)) }
        }
      match sub_r.r {
        None -> err_p(sub_r.p)
        Some(sub) -> {
          let is_short = not p_at(p1, TkColon)
          let pf = PField(fname, sub, is_short)
          let p2 = p_skip_newlines(sub_r.p)
          if p_at(p2, TkComma) {
            parse_record_pattern_fields(p_skip_newlines(p_advance(p2)), [pf, ...acc], ctor, t)
          } else if p_at(p2, TkRbrace) {
            parse_record_pattern_fields(p2, [pf, ...acc], ctor, t)
          } else {
            err_p(p_error_here(p2, "expected `,` or `}` in record pattern"))
          }
        }
      }
    }
  }
}

# ====================================================================
# type expressions
# ====================================================================

# After a return-type is parsed, an optional row suffix can follow:
#   T / Eff
#   T / Eff + Eff + ...
#   T / e                # row variable alone (m7b #12)
#   T / Eff + e          # closed labels followed by a row variable
# Capitalisation disambiguates: TitleCase identifiers are effect
# labels, lowercase identifiers in tail position are row variables.
# Two row variables (`/ e + r`) and a row variable not in tail
# (`/ e + Eff`) are syntax errors — kaikai picks the simpler
# tail-variable semantics. If `/` is absent, REmpty.
type PRow = { p: Parser, r: RowExpr }

fn parse_row_suffix(p: Parser) : PRow / Console {

  if not p_at(p, TkSlash) { PRow { p: p, r: REmpty } }
  else {
    let p1 = p_advance(p)
    parse_row_labels(p1, [])
  }
}

fn parse_row_labels(p: Parser, acc: [RowLabel]) : PRow / Console {

  let t = p_peek(p)
  # m7f §6: `?e` or `?` in row tail position. Treated as an
  # anonymous row variable with a prefix-marked name so the reporter
  # can identify it as a user-supplied hole vs an ordinary row var.
  # Must be the last item in the row — `?e + Stdout` is rejected
  # for the same reason `e + Stdout` is.
  if tk_is(t.kind, TkHole) {
    let p1 = p_advance(p)
    let placeholder = concat_all(["__rowhole__anon_",
                                    int_to_string(t.line), "_",
                                    int_to_string(t.col)])
    if p_at(p1, TkPlus) {
      let pe = p_error(p1, p_peek(p1),
        "row hole must be the last item in the row")
      PRow { p: pe, r: ROpen(placeholder, list_reverse(acc)) }
    } else {
      PRow { p: p1, r: ROpen(placeholder, list_reverse(acc)) }
    }
  } else if match t.kind { TkHoleName(_) -> true _ -> false } {
    let p1 = p_advance(p)
    let nm = match t.kind {
      TkHoleName(n) -> n
      _             -> "anon"
    }
    let placeholder = concat_all(["__rowhole_", nm, "_",
                                    int_to_string(t.line), "_",
                                    int_to_string(t.col)])
    if p_at(p1, TkPlus) {
      let pe = p_error(p1, p_peek(p1),
        "row hole must be the last item in the row")
      PRow { p: pe, r: ROpen(placeholder, list_reverse(acc)) }
    } else {
      PRow { p: p1, r: ROpen(placeholder, list_reverse(acc)) }
    }
  } else if not tk_is(t.kind, TkIdent) {
    PRow { p: p_error(p, t, "expected effect name in row"), r: REmpty }
  } else {
    let name = tok_source(p.src, t)
    let p1 = p_advance(p)
    if is_upper_ident(p.src, t) {
      # m7b #11: optional `[T1, T2]` after the label name. `Reader[Int]`
      # in row position parses the same way as a generic type
      # application — distinct labels for distinct instantiations.
      let args_r =
        if p_at(p1, TkLbracket) {
          parse_row_label_args(p_skip_newlines(p_advance(p1)), [])
        } else {
          PRowArgs { p: p1, r: Some([]) }
        }
      match args_r.r {
        None -> PRow { p: args_r.p, r: REmpty }
        Some(targs) -> {
          let acc1 = [RL(name, targs), ...acc]
          if p_at(args_r.p, TkPlus) {
            parse_row_labels(p_advance(args_r.p), acc1)
          } else {
            PRow { p: args_r.p, r: RClosed(list_reverse(acc1)) }
          }
        }
      }
    } else {
      # m7b #12: lowercase identifier — a row variable in tail
      # position. Row variables themselves carry no type args and
      # must be the last item in the row; anything after `+` here
      # is rejected.
      if p_at(p1, TkPlus) {
        let pe = p_error(p1, p_peek(p1),
          "row variable must be the last item in the row")
        PRow { p: pe, r: ROpen(name, list_reverse(acc)) }
      } else {
        PRow { p: p1, r: ROpen(name, list_reverse(acc)) }
      }
    }
  }
}

type PRowArgs = { p: Parser, r: Option[[TypeExpr]] }

fn parse_row_label_args(p: Parser, acc: [TypeExpr]) : PRowArgs / Console {

  let r = parse_type(p)
  match r.r {
    None -> PRowArgs { p: r.p, r: None }
    Some(arg) -> {
      let p1 = p_skip_newlines(r.p)
      if p_at(p1, TkComma) {
        parse_row_label_args(p_skip_newlines(p_advance(p1)), [arg, ...acc])
      } else if p_at(p1, TkRbracket) {
        PRowArgs { p: p_advance(p1), r: Some(list_reverse([arg, ...acc])) }
      } else {
        PRowArgs { p: p_error_here(p1, "expected `,` or `]` after row-label type arguments"), r: None }
      }
    }
  }
}

fn parse_type(p: Parser) : PTy / Console {

  let base = parse_type_base(p)
  match base.r {
    None -> base
    Some(_) -> parse_optional_refinement(base)
  }
}

# m12.6.a: after a base type parses, peek for `where` and consume the
# refinement predicate as a single Expr. The predicate parses with the
# normal expression grammar; m12.6.b/c restrict it to the decidable
# subset and wire it into typer + codegen. The unary form
# `where >= 0` (predicate begins with a comparator and elides `self`
# on the LHS) is desugared at parse time into `self >= 0`.
fn parse_optional_refinement(base: PTy) : PTy / Console {

  if not p_at(base.p, TkWhere) { base } else {
    match base.r {
      None -> base
      Some(bt) -> {
        let p1 = p_advance(base.p)
        let pe = parse_refinement_predicate(p1, bt.line, bt.col)
        match pe.r {
          None -> PTy { p: pe.p, r: None }
          Some(pred) ->
            PTy { p: pe.p, r: Some(mk_ty(TyRefine(bt, pred), bt.line, bt.col)) }
        }
      }
    }
  }
}

# m12.6.a: parse the body of a `where` clause. The grammar accepts any
# Expr; in addition, when the next token is a comparison operator
# (`<`, `<=`, `==`, `!=`, `>`, `>=`), `self` is implicitly inserted as
# the LHS so that `where >= 0` desugars to `self >= 0`. Validation that
# the resulting Expr lies in the decidable subset is the typer's job
# (m12.6.b).
#
# m12.6.x #7: a second receiver-elision sugar — `where matches <expr>`
# desugars to `matches(self, <expr>)`. This is the refinement-side
# counterpart to the regex sigil: typical use is `String where matches
# ~r/^[a-z]+$/`. The desugar applies whenever the predicate begins
# with the bare identifier `matches` and the next non-`(` token is an
# expression starter — that excludes `matches(s, p)` (an explicit
# call) and `matches.field` (a member access on a value bound to
# `matches`), so user code that already names a function `matches` is
# unaffected.
fn parse_refinement_predicate(p: Parser, line: Int, col: Int) : PExpr / Console {

  let t = p_peek(p)
  if is_cmp_token(t.kind) {
    let lhs = mk_expr(EVar("self"), line, col)
    parse_refinement_cmp_with(p, lhs, line, col)
  } else if is_matches_sugar_start(p, t) {
    parse_refinement_matches_with(p, t, line, col)
  } else {
    parse_expr(p)
  }
}

fn is_matches_sugar_start(p: Parser, t: Token) : Bool {
  if not tk_is(t.kind, TkIdent) { false }
  else if tok_source(p.src, t) != "matches" { false }
  else { refinement_matches_sugar_at(p_advance(p)) }
}

fn parse_refinement_matches_with(p: Parser, t: Token, line: Int, col: Int) : PExpr / Console {

  let p1 = p_advance(p)
  let rhs = parse_expr(p1)
  match rhs.r {
    None -> rhs
    Some(rv) -> {
      let self_e = mk_expr(EVar("self"), line, col)
      let callee = mk_expr(EVar("matches"), t.line, t.col)
      let call = mk_expr(ECall(callee, [self_e, rv]), t.line, t.col)
      PExpr { p: rhs.p, r: Some(call) }
    }
  }
}

# True when the token after `matches` looks like the start of an
# expression argument (rather than `(` — which signals an explicit
# call — or `.` — a member access on a value named `matches`). Used
# to gate the `where matches <expr>` receiver-elision sugar.
fn refinement_matches_sugar_at(p: Parser) : Bool {
  let t = p_peek(p)
  if tk_is(t.kind, TkLparen) { false }
  else if tk_is(t.kind, TkDot) { false }
  else if tk_is(t.kind, TkRegex) { true }
  else if tk_is(t.kind, TkIdent) { true }
  else if tk_is(t.kind, TkString) { true }
  else { false }
}

fn is_cmp_token(k: TokKind) : Bool {
  if tk_is(k, TkLt) { true }
  else if tk_is(k, TkLe) { true }
  else if tk_is(k, TkEqEq) { true }
  else if tk_is(k, TkNeq) { true }
  else if tk_is(k, TkGt) { true }
  else if tk_is(k, TkGe) { true }
  else { false }
}

# Build `self <op> rhs` when the where clause begins with a bare
# comparator. Emitted as an EBinop so the typer / codegen treat it
# identically to a written-out comparison. The spec's bounded-interval
# form `1 <= self <= 65535` is not chained here because parse_expr
# rejects non-associative comparison chaining; users who want both
# sides write `where 1 <= self and self <= 65535`.
fn parse_refinement_cmp_with(p: Parser, lhs: Expr, line: Int, col: Int) : PExpr / Console {

  let op_tok = p_peek(p)
  let op_name = cmp_op_name(op_tok.kind)
  let p1 = p_advance(p)
  let rhs = parse_expr(p1)
  match rhs.r {
    None -> rhs
    Some(rv) -> {
      let cmp = mk_expr(EBinop(op_name, lhs, rv), line, col)
      PExpr { p: rhs.p, r: Some(cmp) }
    }
  }
}

fn cmp_op_name(k: TokKind) : String {
  if tk_is(k, TkLt) { "<" }
  else if tk_is(k, TkLe) { "<=" }
  else if tk_is(k, TkEqEq) { "==" }
  else if tk_is(k, TkNeq) { "!=" }
  else if tk_is(k, TkGt) { ">" }
  else if tk_is(k, TkGe) { ">=" }
  else { "==" }
}

fn parse_type_base(p: Parser) : PTy / Console {

  let t = p_peek(p)
  if tk_is(t.kind, TkLbracket) {
    let p1 = p_advance(p)
    let r = parse_type(p1)
    match r.r {
      None -> err_t(r.p)
      Some(inner) -> {
        if p_at(r.p, TkRbracket) {
          ok_t(p_advance(r.p), mk_ty(TyList(inner), t.line, t.col))
        } else {
          err_t(p_error_here(r.p, "expected `]` in list type"))
        }
      }
    }
  } else if tk_is(t.kind, TkLparen) {
    parse_fn_type(p, t)
  } else if tk_is(t.kind, TkIdent) {
    parse_named_type(p, t)
  } else {
    err_t(p_error_here(p, "expected type"))
  }
}

fn parse_named_type(p: Parser, t: Token) : PTy / Console {

  let name = tok_source(p.src, t)
  let p1 = p_advance(p)
  # Issue #232: qualified type head `mod.Type[args?]`. When the
  # leading ident is lowercase and followed by `.UpperIdent`, fold
  # the qualifier into the TyName payload as a dotted string. The
  # qualtype rewriter pass validates against the module table and
  # strips the qualifier before resolve_ty runs.
  if (not is_upper_ident(p.src, t)) and p_at(p1, TkDot) and tk_is(p_peek1(p1).kind, TkIdent) and is_upper_ident(p1.src, p_peek1(p1)) {
    let nt = p_peek1(p1)
    let qname = concat_all([name, ".", tok_source(p1.src, nt)])
    let p2 = p_advance(p_advance(p1))
    if p_at(p2, TkLbracket) and not tk_is(p_peek1(p2).kind, TkLt) {
      let p3 = p_skip_newlines(p_advance(p2))
      parse_type_args_loop(p3, [], qname, t)
    } else {
      ok_t(p2, mk_ty(TyName(qname, []), t.line, t.col))
    }
  }
  # m12.6.x #5 inline: peek-2 disambiguation. `Foo[<...>]` is the
  # `[<refinement_pure>]` attribute (handled by the caller, e.g.
  # parse_fn_decl), NOT a generic-type opener. So when `[` is
  # followed by `<`, leave both tokens for the outer parser.
  else if p_at(p1, TkLbracket) and not tk_is(p_peek1(p1).kind, TkLt) {
    # Generic type: Name[T1, T2, ...]
    let p2 = p_skip_newlines(p_advance(p1))
    parse_type_args_loop(p2, [], name, t)
  } else if (name == "Real" or name == "Int" or name == "Decimal") and p_at(p1, TkLt) {
    # m12.5: dimensioned numeric — `Real<unit-expr>` / `Int<unit-expr>` /
    # `Decimal<unit-expr>`. `Decimal` is the stdlib alias that ledger /
    # finance demos reach for; the parser accepts the annotation here so
    # record fields (`balance: Decimal<USD>`) and top-level positions
    # share one route. The typer collapses TyDim to the head TyName at
    # protocol-dispatch time (see `proto_type_name`).
    let p2 = p_skip_newlines(p_advance(p1))
    let ru = parse_unit_expr(p2)
    match ru.r {
      None -> err_t(ru.p)
      Some(u) -> {
        let p3 = p_skip_newlines(ru.p)
        if not p_at(p3, TkGt) {
          err_t(p_error_here(p3, "expected `>` to close the unit annotation"))
        } else {
          let base = mk_ty(TyName(name, []), t.line, t.col)
          ok_t(p_advance(p3), mk_ty(TyDim(base, u), t.line, t.col))
        }
      }
    }
  } else {
    ok_t(p1, mk_ty(TyName(name, []), t.line, t.col))
  }
}

fn parse_type_args_loop(p: Parser, acc: [TypeExpr], name: String, t: Token) : PTy / Console {

  let r = parse_type(p)
  match r.r {
    None -> err_t(r.p)
    Some(arg) -> {
      let p1 = p_skip_newlines(r.p)
      if p_at(p1, TkComma) {
        parse_type_args_loop(p_skip_newlines(p_advance(p1)), [arg, ...acc], name, t)
      } else if p_at(p1, TkRbracket) {
        ok_t(p_advance(p1), mk_ty(TyName(name, list_reverse([arg, ...acc])), t.line, t.col))
      } else {
        err_t(p_error_here(p1, "expected `,` or `]` after type arguments"))
      }
    }
  }
}

fn parse_fn_type(p: Parser, t: Token) : PTy / Console {

  let p1 = p_skip_newlines(p_advance(p))
  if p_at(p1, TkRparen) {
    let p2 = p_advance(p1)
    if not p_at(p2, TkArrow) {
      err_t(p_error_here(p2, "expected `->` in function type"))
    } else {
      let r = parse_type(p_advance(p2))
      match r.r {
        None -> err_t(r.p)
        Some(ret) -> {
          let row_r = parse_row_suffix(r.p)
          ok_t(row_r.p, mk_ty(TyFn([], ret, row_r.r), t.line, t.col))
        }
      }
    }
  } else {
    parse_fn_type_args(p1, [], t)
  }
}

# Function-type args OR n-tuple type sugar (#154). The disambiguation
# is local: parse a comma-separated list of types until `)`. If `->`
# follows, it's a function type. Otherwise it's a tuple type and we
# desugar to `Pair[A, B]` / `Triple[A, B, C]` / `Quad[A, B, C, D]`.
# A single type in parens (`(A)`) followed by no `->` is grouping —
# returns the inner type unchanged. Zero-arg `()` keeps the existing
# function-type contract (handled in parse_fn_type, must be `() -> T`).
fn parse_fn_type_args(p: Parser, acc: [TypeExpr], t: Token) : PTy / Console {

  let r = parse_type(p)
  match r.r {
    None -> err_t(r.p)
    Some(arg) -> {
      let p1 = p_skip_newlines(r.p)
      if p_at(p1, TkComma) {
        parse_fn_type_args(p_skip_newlines(p_advance(p1)), [arg, ...acc], t)
      } else if p_at(p1, TkRparen) {
        let p2 = p_advance(p1)
        if p_at(p2, TkArrow) {
          let rr = parse_type(p_advance(p2))
          match rr.r {
            None -> err_t(rr.p)
            Some(ret) -> {
              let row_r = parse_row_suffix(rr.p)
              ok_t(row_r.p, mk_ty(TyFn(list_reverse([arg, ...acc]), ret, row_r.r), t.line, t.col))
            }
          }
        } else {
          # Not a function type: re-interpret as tuple-type sugar or grouping.
          let args = list_reverse([arg, ...acc])
          let n = list_length(args)
          if n == 1 {
            # Single type in parens: grouping. `(A)` ≡ `A`.
            ok_t(p2, arg)
          } else {
            match tuple_type_for_arity(n) {
              None -> err_t(p_error_here(p1, "n-tuple type sugar supports arity 2..4 only — use a named record for wider products"))
              Some(name) -> ok_t(p2, mk_ty(TyName(name, args), t.line, t.col))
            }
          }
        }
      } else {
        err_t(p_error_here(p1, "expected `,` or `)` in type"))
      }
    }
  }
}

# ====================================================================
# declarations
# ====================================================================

fn parse_decl(p: Parser) : PDecl / Console {

  let p_pre = p_skip_newlines(p)
  # Issue #260: the legacy `[<extern_c>]` attribute prefix is
  # rejected before any other parsing happens — the spec syntax is
  # now `extern "C" fn ...` (and the override variant from issue
  # #261). We surface a migration error pointing at the new form.
  if parse_at_legacy_extern_c_attribute(p_pre) {
    let line_msg = "`[<extern_c>] axiom` is removed (issue #260) — use `extern \"C\" fn name(...) : T / Ffi` instead"
    err_d(p_error_here(p_pre, line_msg))
  } else {
  let p0 = p_pre
  let t = p_peek(p0)
  # Issue #260: `extern` is a top-level keyword introducing an FFI
  # declaration. It binds tighter than `pub`, so the surface form
  # is `extern "C" pub fn ...`. The optional name override (issue
  # #261) sits between the ABI literal and the `pub`/`fn`.
  if tk_is(t.kind, TkExtern) {
    parse_extern_decl(p_advance(p0), t)
  } else {
  let is_pub_r =
    if tk_is(t.kind, TkPub) { PTy { p: p_advance(p0), r: Some(mk_ty(TyName("", []), 0, 0)) } }
    else { PTy { p: p0, r: None } }
  let is_pub =
    match is_pub_r.r { Some(_) -> true None -> false }
  let p1 = is_pub_r.p
  let hd = p_peek(p1)
  if tk_is(hd.kind, TkFn) {
    parse_fn_decl(p_advance(p1), is_pub, hd)
  } else if tk_is(hd.kind, TkType) {
    parse_type_decl(p_advance(p1), is_pub, hd)
  } else if tk_is(hd.kind, TkEffect) {
    parse_effect_decl(p_advance(p1), is_pub, hd)
  } else if tk_is(hd.kind, TkProtocol) {
    parse_protocol_decl(p_advance(p1), is_pub, hd)
  } else if tk_is(hd.kind, TkImpl) {
    if is_pub { err_d(p_error(p1, hd, "`pub` is not allowed on an impl")) }
    else { parse_impl_decl(p_advance(p1), hd) }
  } else if tk_is(hd.kind, TkHashOpen) {
    if is_pub { err_d(p_error(p1, hd, "`pub` must come AFTER the `#[...]` attribute, not before — write `#[unstable] pub fn ...`")) }
    else { parse_attribute_decl(p_advance(p1), hd) }
  } else if tk_is(hd.kind, TkTest) {
    if is_pub { err_d(p_error(p1, hd, "`pub` is not allowed on a test")) }
    else { parse_test_decl(p_advance(p1), hd) }
  } else if tk_is(hd.kind, TkBench) {
    if is_pub { err_d(p_error(p1, hd, "`pub` is not allowed on a bench")) }
    else { parse_bench_decl(p_advance(p1), hd) }
  } else if tk_is(hd.kind, TkCheck) {
    if is_pub { err_d(p_error(p1, hd, "`pub` is not allowed on a check")) }
    else { parse_check_decl(p_advance(p1), hd) }
  } else if tk_is(hd.kind, TkImport) {
    if is_pub { err_d(p_error(p1, hd, "`pub` is not allowed on an import")) }
    else { parse_import_decl(p_advance(p1), hd) }
  } else if tk_is(hd.kind, TkUnitKw) {
    parse_unit_decl(p_advance(p1), is_pub, hd)
  } else if tk_is(hd.kind, TkUse) {
    if is_pub { err_d(p_error(p1, hd, "`pub` is not allowed on a `use` declaration")) }
    else { parse_use_decl(p_advance(p1), hd) }
  } else if tk_is(hd.kind, TkAxiom) {
    parse_axiom_decl(p_advance(p1), is_pub, false, "", hd)
  } else if tk_is(hd.kind, TkConst) {
    parse_const_decl(p_advance(p1), is_pub, hd)
  } else {
    let base = "expected `fn`, `type`, `effect`, `protocol`, `impl`, `test`, `unit`, `use`, `axiom`, `const`, or `import`"
    let msg = if tk_is(hd.kind, TkIdent) {
      let text = tok_source(p1.src, hd)
      match closest_name(text, ["fn", "type", "effect", "protocol", "impl", "test", "unit", "use", "axiom", "const", "import", "pub"]) {
        Some(sug) -> concat_all([base, " (did you mean `", sug, "`?)"])
        None      -> base
      }
    } else { base }
    err_d(p_error(p1, hd, msg))
  }
  }
  }
}

# §29 const NAME : T = expr — top-level named constant. Parses to
# the dedicated `DConst` variant (issue #269). The `lower_consts`
# pass converts it to `DAttribPure(DFn arity-0)` early in the
# pipeline so downstream walkers (typer, monomorphiser, emitters)
# keep seeing the legacy shape until the structural typer/emitter
# integration lands. Const reads still go through the `desugar_const_refs_decls`
# pass that rewrites `EVar(NAME)` to `ECall(EVar(NAME), [])`; that
# pass is now scope-aware so a fn parameter named `NAME` shadows
# the const correctly (the bug filed in #269).
fn parse_const_decl(p: Parser, is_pub: Bool, t: Token) : PDecl / Console {

  let id = p_peek(p)
  if not tk_is(id.kind, TkIdent) {
    err_d(p_error(p, id, "expected constant name after `const`"))
  } else {
    let name = tok_source(p.src, id)
    let p1 = p_advance(p)
    let p2 = p_skip_newlines(p1)
    if not p_at(p2, TkColon) {
      err_d(p_error_here(p2, "expected `:` after constant name (`const NAME : T = expr`)"))
    } else {
      let p3 = p_skip_newlines(p_advance(p2))
      let rt = parse_type(p3)
      match rt.r {
        None -> err_d(rt.p)
        Some(ty) -> {
          let p4 = p_skip_newlines(rt.p)
          if not p_at(p4, TkEq) {
            err_d(p_error_here(p4, "expected `=` in constant declaration"))
          } else {
            let p5 = p_skip_newlines(p_advance(p4))
            let re = parse_expr(p5)
            match re.r {
              None -> err_d(re.p)
              Some(body) -> {
                ok_d(re.p, DConst(is_pub, name, ty, body, t.line, t.col))
              }
            }
          }
        }
      }
    }
  }
}

# Issue #260: detect the legacy `[<extern_c>]` attribute prefix
# without consuming any tokens. We peek for the exact 3-token shape
# `[`, `<`, `extern_c` so the much-more-common `[` (a list literal
# at the top of a const) does not trigger. Returns true only when
# the migration error should fire. The parser then surfaces a
# diagnostic without trying to recover.
fn parse_at_legacy_extern_c_attribute(p: Parser) : Bool {
  if not p_at(p, TkLbracket) { false }
  else if not tk_is(p_peek1(p).kind, TkLt) { false }
  else {
    # Peek the third token (the attribute name). `p_peek1` is +1, so
    # we advance once into the `<` and peek1 from there to get the
    # ident slot. `extern_c` is the only attribute that lived inside
    # `[<...>]` to date; other names are likely typos and still get
    # the same migration message (cheaper than enumerating valid
    # alternatives, none of which exist).
    let p1 = p_advance(p)
    let id = p_peek1(p1)
    if not tk_is(id.kind, TkIdent) { false }
    else { tok_source(p1.src, id) == "extern_c" }
  }
}

# Issue #260: parse the new spec form
#   extern STRING_LIT [ "(" STRING_LIT ")" ] [ "pub" ] "fn" name(...) : T [ / row ]
# Routes into `parse_axiom_decl` so the rest of the pipeline keeps
# seeing a uniform `DAxiom(extern_c=true, c_sym_over=...)` shape.
# `t` is the `extern` token, used for line/col on the resulting
# decl.
#
# Issue #261 hooks in here too: the optional `("symbol")` after the
# ABI literal becomes the `c_sym_over` argument. The override must
# be a valid C identifier (`[A-Za-z_][A-Za-z0-9_]*`); anything else
# is rejected so a typo'd quote does not silently link a symbol the
# user did not intend.
fn parse_extern_decl(p: Parser, t: Token) : PDecl / Console {

  let p_abi = p_skip_newlines(p)
  let abi_tok = p_peek(p_abi)
  if not tk_is(abi_tok.kind, TkString) {
    err_d(p_error(p_abi, abi_tok, "expected an ABI string literal after `extern` (only `\"C\"` is supported)"))
  } else {
    let abi_span = tok_source(p_abi.src, abi_tok)
    if not (abi_span == "\"C\"") {
      err_d(p_error(p_abi, abi_tok,
        concat_all(["unsupported FFI ABI ", abi_span, " — only \"C\" is supported"])))
    } else {
      let p1 = p_advance(p_abi)
      # Optional `("real_symbol")` name override (issue #261). Sits
      # immediately after the ABI literal with no intervening
      # newline so the parser cannot mistake a list literal that
      # follows on the next line for the override.
      let over_r = parse_optional_extern_c_override(p1)
      match over_r.r {
        None -> err_d(over_r.p)
        Some(c_sym_over) -> {
          let p2 = p_skip_newlines(over_r.p)
          let is_pub_tok = p_peek(p2)
          let is_pub = tk_is(is_pub_tok.kind, TkPub)
          let p3 = if is_pub { p_skip_newlines(p_advance(p2)) } else { p2 }
          let fn_tok = p_peek(p3)
          if not tk_is(fn_tok.kind, TkFn) {
            err_d(p_error(p3, fn_tok, "expected `fn` after `extern \"C\"` (FFI declarations look like `extern \"C\" fn name(...) : T / Ffi`)"))
          } else {
            let decl_r = parse_axiom_decl(p_advance(p3), is_pub, true, c_sym_over, t)
            validate_extern_c_decl(decl_r, t)
          }
        }
      }
    }
  }
}

type PStr = { p: Parser, r: Option[String] }

# Issue #261: parse the optional `("real_symbol")` override after
# the ABI literal. Returns:
#   - `None` parser-error on a malformed override (unmatched paren,
#     non-string token inside, or a non-C-identifier symbol);
#   - `Some("")` when there is no override (caller will use the
#     kaikai identifier as the C symbol);
#   - `Some(s)` when the override is `s`.
fn parse_optional_extern_c_override(p: Parser) : PStr / Console {

  if not p_at(p, TkLparen) { PStr { p: p, r: Some("") } }
  else {
    let p1 = p_advance(p)
    let sym_tok = p_peek(p1)
    if not tk_is(sym_tok.kind, TkString) {
      PStr { p: p_error(p1, sym_tok, "expected a C-symbol string literal inside `extern \"C\"(...)`"), r: None }
    } else {
      let sym_span = tok_source(p1.src, sym_tok)
      let n = string_length(sym_span)
      # The span includes the surrounding quotes — strip them.
      let sym_clean = if n >= 2 { string_slice(sym_span, 1, n - 2) } else { "" }
      if not is_valid_c_identifier(sym_clean) {
        PStr {
          p: p_error(p1, sym_tok,
            concat_all(["invalid C symbol override ", sym_span,
                        " — must match `[A-Za-z_][A-Za-z0-9_]*`"])),
          r: None
        }
      } else {
        let p2 = p_advance(p1)
        if not p_at(p2, TkRparen) {
          PStr { p: p_error_here(p2, "expected `)` to close `extern \"C\"(\"<symbol>\")` override"), r: None }
        } else {
          PStr { p: p_advance(p2), r: Some(sym_clean) }
        }
      }
    }
  }
}

# Issue #536: an `extern "C" fn` declaration MUST advertise `Ffi` in
# its effect row. The capability discipline pinned in CLAUDE.md
# baseline architecture says FFI crosses to C *via* the `Ffi`
# capability; an extern without that label silently bypasses the
# contract and downstream Tier-1 invariants about effect rows lose
# their teeth. Returns true iff the row syntactically contains a
# label named `Ffi` (label args are irrelevant — `Ffi` is nullary).
fn extern_row_has_ffi(row: RowExpr) : Bool {
  match row {
    REmpty         -> false
    RClosed(lbs)   -> row_label_names_has(lbs, "Ffi")
    ROpen(_, lbs)  -> row_label_names_has(lbs, "Ffi")
  }
}

fn row_label_names_has(labels: [RowLabel], target: String) : Bool {
  match labels {
    [] -> false
    [l, ...rest] -> match l {
      RL(name, _) -> if name == target { true } else { row_label_names_has(rest, target) }
    }
  }
}

# Issue #536 shape 2: a type appearing in the parameter list or
# return slot of an `extern "C" fn` MUST be C-ABI compatible. The
# kaikai layout for `[T]` (singly-linked list), `Option[T]` (tagged
# sum), records, and user-declared sum types is implementation-
# defined and unsafe to expose across the C boundary. The allowlist
# is intentionally small — Int, Real, Bool, String, Unit (return
# only). Future extensions (Int32, opaque pointer types) get added
# here explicitly, not via heuristics.
#
# `is_return_slot` widens the allowlist to include `Unit` (a `void`
# return is fine in C; a `void` parameter is not the same shape as
# kaikai's nullary `Unit` and is excluded).
fn is_c_abi_safe_type(t: TypeExpr, is_return_slot: Bool) : Bool {
  match t.tkind {
    TyName(name, targs) ->
      if list_length(targs) > 0 { false }
      else if name == "Int" { true }
      else if name == "Real" { true }
      else if name == "Bool" { true }
      else if name == "String" { true }
      else if name == "Unit" { is_return_slot }
      else { false }
    _ -> false
  }
}

# Issue #536: walk an `extern "C" fn` parameter list and return the
# first param whose type is NOT C-ABI safe, or `None` if every
# parameter is safe. Untyped parameters (`ptype: None`) cannot occur
# in an extern signature — `parse_fn_params` rejects missing
# annotations on axiom-shape decls — but we guard for it anyway.
fn first_non_c_abi_param(params: [Param]) : Option[Param] {
  match params {
    [] -> None
    [p, ...rest] -> match p.ptype {
      None -> Some(p)
      Some(ty) ->
        if is_c_abi_safe_type(ty, false) { first_non_c_abi_param(rest) }
        else { Some(p) }
    }
  }
}

# Issue #536: render a TypeExpr surface form for diagnostics. We
# only need the cases the validator might reject; the fallthrough
# emits a placeholder that still anchors the diagnostic to the
# offending site.
fn type_surface(t: TypeExpr) : String {
  match t.tkind {
    TyName(name, targs) ->
      if list_length(targs) == 0 { name }
      else { concat_all([name, "[", type_args_surface(targs), "]"]) }
    TyList(inner) -> concat_all(["[", type_surface(inner), "]"])
    TyFn(_, _, _) -> "fn(...)"
    TyDim(base, _) -> concat_all([type_surface(base), "<...>"])
    TyRefine(base, _) -> concat_all([type_surface(base), " where ..."])
  }
}

fn type_args_surface(ts: [TypeExpr]) : String {
  match ts {
    [] -> ""
    [t]  -> type_surface(t)
    [t, ...rest] -> concat_all([type_surface(t), ", ", type_args_surface(rest)])
  }
}

# Issue #536: post-process a successfully parsed `extern "C" fn`
# declaration. Three independent checks, each surfacing a parse-
# time diagnostic anchored to the `extern` keyword token:
#   (a) the effect row must contain `Ffi`;
#   (b) every parameter type must be C-ABI compatible;
#   (c) the return type must be C-ABI compatible.
# A failure in any check converts the PDecl into an error result;
# on success, the original PDecl flows through unchanged so the
# rest of the pipeline keeps seeing the uniform DAxiom shape.
fn validate_extern_c_decl(decl_r: PDecl, t: Token) : PDecl / Console {
  match decl_r.r {
    None -> decl_r
    Some(d) -> match d {
      DAxiom(_, _, name, _, _, params, ret_ty, row, _, _) -> {
        if not extern_row_has_ffi(row) {
          let msg = concat_all([
            "`extern \"C\" fn ", name,
            "` must declare `/ Ffi` in its row — FFI declarations always cross the Ffi capability boundary"
          ])
          err_d(p_error(decl_r.p, t, msg))
        } else {
          match first_non_c_abi_param(params) {
            Some(p) -> {
              let ty_s = match p.ptype {
                Some(ty) -> type_surface(ty)
                None     -> "<missing>"
              }
              let msg = concat_all([
                "`extern \"C\" fn ", name,
                "` parameter `", p.pname,
                "` has type `", ty_s,
                "` which is not C-ABI compatible — allowed: Int, Real, Bool, String"
              ])
              err_d(p_error(decl_r.p, t, msg))
            }
            None ->
              if not is_c_abi_safe_type(ret_ty, true) {
                let msg = concat_all([
                  "`extern \"C\" fn ", name,
                  "` return type `", type_surface(ret_ty),
                  "` is not C-ABI compatible — allowed: Int, Real, Bool, String, Unit"
                ])
                err_d(p_error(decl_r.p, t, msg))
              } else { decl_r }
          }
        }
      }
      # parse_axiom_decl always produces a DAxiom on success; any
      # other shape would be a structural surprise and should fall
      # through unchanged so the user sees the original parser
      # error rather than a misleading FFI message.
      _ -> decl_r
    }
  }
}

# Issue #261: the override must be a syntactically valid C
# identifier so the emitted call site survives the C compiler. We
# do not try to validate that the symbol actually links — that is
# a build-time concern, not a parse-time one.
fn is_valid_c_identifier(s: String) : Bool {
  let n = string_length(s)
  if n == 0 { false }
  else {
    let c0 = char_at_or_zero(s, 0)
    if not (ch_is_alpha(c0) or c0 == '_') { false }
    else { is_valid_c_identifier_rest(s, 1, n) }
  }
}

fn is_valid_c_identifier_rest(s: String, i: Int, n: Int) : Bool {
  if i >= n { true }
  else {
    let c = char_at_or_zero(s, i)
    if ch_is_alnum(c) or c == '_' { is_valid_c_identifier_rest(s, i + 1, n) }
    else { false }
  }
}

# m12.7: parse `axiom name[tparams](params) : T / row`. Mirrors
# `parse_fn_decl`'s prologue (name + tparams + params) but the
# return type is REQUIRED (no default `Unit`) and there is no body
# clause — `=` or `{` after the row annotation is rejected. The
# Decl carries everything `lower_axioms` needs to synthesise a
# `todo!` body in the desugar pass.
#
# m12.7.x FFI v1: `extern_c` was historically set by the legacy
# `[<extern_c>]` attribute prefix (removed in issue #260). After
# the migration, `extern_c` is only set via `parse_extern_decl`
# routing through `parse_axiom_decl_inner`; bare `axiom` decls
# always pass `extern_c=false, c_sym_over=""`.
#
# Issue #261: `c_sym_over` carries the optional C-symbol override
# (empty string when absent). Only meaningful when `extern_c` is true.
fn parse_axiom_decl(p: Parser, is_pub: Bool, extern_c: Bool, c_sym_over: String, t: Token) : PDecl / Console {

  let id = p_peek(p)
  if not tk_is(id.kind, TkIdent) {
    err_d(p_error(p, id, "expected axiom name"))
  } else {
    let name = tok_source(p.src, id)
    let p1 = p_advance(p)
    let tparams_r =
      if p_at(p1, TkLbracket) {
        parse_type_params_loop(p_skip_newlines(p_advance(p1)), [])
      } else {
        PTParams { p: p1, r: Some([]) }
      }
    match tparams_r.r {
      None -> err_d(tparams_r.p)
      Some(tparams) -> {
        let pp = tparams_r.p
        if not p_at(pp, TkLparen) {
          err_d(p_error_here(pp, "expected `(` after axiom name"))
        } else {
          let p2 = p_skip_newlines(p_advance(pp))
          let params_r = parse_fn_params(p2, [])
          match params_r.r {
            None -> err_d(params_r.p)
            Some(params) -> {
              let p3 = p_skip_newlines(params_r.p)
              if not p_at(p3, TkColon) {
                err_d(p_error_here(p3, "axiom requires a return type — write `axiom name(...) : T`"))
              } else {
                let rt = parse_type(p_advance(p3))
                match rt.r {
                  None -> err_d(rt.p)
                  Some(ty) -> {
                    let row_r = parse_row_suffix(rt.p)
                    let p4 = p_skip_newlines(row_r.p)
                    if p_at(p4, TkEq) or p_at(p4, TkLbrace) {
                      err_d(p_error_here(p4, "axiom must not have a body — drop the `=` / `{` and trailing block"))
                    } else {
                      ok_d(row_r.p, DAxiom(is_pub, extern_c, name, c_sym_over, tparams, params, ty, row_r.r, t.line, t.col))
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}

# m7e §25: parse `use Effect` as a Decl. The token at `t` is the
# `use` keyword; `p` is positioned right after it. Effect names are
# uppercase idents (matches the existing convention enforced by
# `parse_effect_decl`). Aliases (`use Console as C`) are not part
# of the v1.
fn parse_use_decl(p: Parser, t: Token) : PDecl / Console {

  let id = p_peek(p)
  if not tk_is(id.kind, TkIdent) {
    err_d(p_error(p, id, "expected effect name after `use`"))
  } else if not is_upper_ident(p.src, id) {
    err_d(p_error(p, id, "effect name in `use` must start with an uppercase letter"))
  } else {
    let name = tok_source(p.src, id)
    ok_d(p_advance(p), DUse(name, t.line, t.col))
  }
}

# m12.5: parse a unit declaration. Two shapes:
#   `unit USD`                                    — atomic
#   `unit Newton = kg * m / sec^2`                — alias
fn parse_unit_decl(p: Parser, is_pub: Bool, t: Token) : PDecl / Console {

  let id = p_peek(p)
  if not tk_is(id.kind, TkIdent) {
    err_d(p_error(p, id, "expected unit name after `unit`"))
  } else {
    let name = tok_source(p.src, id)
    let p1 = p_advance(p)
    if p_at(p1, TkEq) {
      let p2 = p_skip_newlines(p_advance(p1))
      let rb = parse_unit_expr(p2)
      match rb.r {
        None -> err_d(rb.p)
        Some(u) -> ok_d(rb.p, DUnit(is_pub, name, Some(u), t.line, t.col))
      }
    } else {
      ok_d(p1, DUnit(is_pub, name, None, t.line, t.col))
    }
  }
}

# m12.5: unit-expression grammar.
#   unit_expr := unit_term ( ('*' | '/') unit_term )*
#   unit_term := unit_factor ('^' integer)?
#   unit_factor := IDENT | INT('1') | '(' unit_expr ')'
type PUnit = { p: Parser, r: Option[UnitExprT] }

fn ok_u(p: Parser, u: UnitExprT) : PUnit = PUnit { p: p, r: Some(u) }
fn err_u(p: Parser) : PUnit = PUnit { p: p, r: None }

fn parse_unit_expr(p: Parser) : PUnit / Console {

  let r = parse_unit_term(p)
  match r.r {
    None -> err_u(r.p)
    Some(lhs) -> parse_unit_expr_rest(r.p, lhs)
  }
}

fn parse_unit_expr_rest(p: Parser, lhs: UnitExprT) : PUnit / Console {

  if p_at(p, TkStar) {
    let r = parse_unit_term(p_advance(p))
    match r.r {
      None -> err_u(r.p)
      Some(rhs) -> parse_unit_expr_rest(r.p, UMul(lhs, rhs))
    }
  } else if p_at(p, TkSlash) {
    let r = parse_unit_term(p_advance(p))
    match r.r {
      None -> err_u(r.p)
      Some(rhs) -> parse_unit_expr_rest(r.p, UMul(lhs, UInv(rhs)))
    }
  } else {
    ok_u(p, lhs)
  }
}

fn parse_unit_term(p: Parser) : PUnit / Console {

  let r = parse_unit_factor(p)
  match r.r {
    None -> err_u(r.p)
    Some(base) -> {
      if p_at(r.p, TkCaret) {
        let p1 = p_advance(r.p)
        let rn = parse_unit_signed_int(p1)
        match rn.r {
          None -> err_u(rn.p)
          Some(n) -> ok_u(rn.p, UPow(base, n))
        }
      } else {
        ok_u(r.p, base)
      }
    }
  }
}

type PUInt = { p: Parser, r: Option[Int] }

fn parse_unit_signed_int(p: Parser) : PUInt / Console {

  let neg = p_at(p, TkMinus)
  let p1 = if neg { p_advance(p) } else { p }
  let t = p_peek(p1)
  if not tk_is(t.kind, TkInt) {
    PUInt { p: p_error_here(p1, "expected integer after `^` in unit expression"), r: None }
  } else {
    let n = decode_int(tok_source(p1.src, t))
    let v = if neg { 0 - n } else { n }
    PUInt { p: p_advance(p1), r: Some(v) }
  }
}

fn parse_unit_factor(p: Parser) : PUnit / Console {

  let t = p_peek(p)
  if tk_is(t.kind, TkIdent) {
    ok_u(p_advance(p), USym(tok_source(p.src, t)))
  } else if tk_is(t.kind, TkInt) {
    # Per spec §6 `<1>` is the dimensionless unit. Reject other ints.
    let span = tok_source(p.src, t)
    if decode_int(span) == 1 { ok_u(p_advance(p), UOne) }
    else { err_u(p_error(p, t, "only `1` is allowed as a unit literal (use a unit symbol or a parenthesised expression instead)")) }
  } else if tk_is(t.kind, TkLparen) {
    let r = parse_unit_expr(p_advance(p))
    match r.r {
      None -> err_u(r.p)
      Some(u) -> {
        if not p_at(r.p, TkRparen) {
          err_u(p_error_here(r.p, "expected `)` in unit expression"))
        } else {
          ok_u(p_advance(r.p), u)
        }
      }
    }
  } else {
    err_u(p_error(p, t, "expected unit symbol, `1`, or parenthesised unit expression"))
  }
}

fn parse_fn_decl(p: Parser, is_pub: Bool, t: Token) : PDecl / Console {

  let id = p_peek(p)
  if not tk_is(id.kind, TkIdent) {
    err_d(p_error(p, id, "expected function name"))
  } else {
    let name = tok_source(p.src, id)
    let p1 = p_advance(p)
    # m7b #13: optional `[T1, T2, ...]` type parameter list before `(`.
    # Same shape as effect tparams (m7b #11) — uppercase or lowercase
    # identifiers, comma-separated. Empty when omitted.
    let tparams_r =
      if p_at(p1, TkLbracket) {
        parse_type_params_loop(p_skip_newlines(p_advance(p1)), [])
      } else {
        PTParams { p: p1, r: Some([]) }
      }
    match tparams_r.r {
      None -> err_d(tparams_r.p)
      Some(tparams) -> {
        let pp = tparams_r.p
        if not p_at(pp, TkLparen) {
          err_d(p_error_here(pp, "expected `(` after function name"))
        } else {
      let p2 = p_skip_newlines(p_advance(pp))
      let params_r = parse_fn_params(p2, [])
      match params_r.r {
        None -> err_d(params_r.p)
        Some(params) -> {
          let p3 = p_skip_newlines(params_r.p)
          # Optional `: ReturnType`
          let ret_r =
            if p_at(p3, TkColon) {
              let rt = parse_type(p_advance(p3))
              match rt.r {
                None -> PTy { p: rt.p, r: None }
                Some(ty) -> PTy { p: rt.p, r: Some(ty) }
              }
            } else {
              PTy { p: p3, r: None }
            }
          if ret_r.p.had_error and not p3.had_error { err_d(ret_r.p) }
          else {
            # Optional effect-row suffix: `T / Io + Fail`. m7a #3b.
            let row_r = parse_row_suffix(ret_r.p)
            # m12.6.x #5(a): optional `[<refinement_pure>]` attribute
            # between the signature/row and the contract clauses. The
            # parser uses peek-2 lookahead so a bare `[` (e.g. the
            # rare list-type follow-up) doesn't trigger.
            let attr = parse_optional_pure_attribute(p_skip_newlines(row_r.p))
            # m12.6.b: optional `requires` / `ensures` clauses between
            # the signature and the body. They desugar to asserts in
            # the body — see wrap_with_contracts.
            let cc = parse_contracts_loop(p_skip_newlines(attr.p), [], [])
            let p4 = p_skip_newlines(cc.p)
            # Body: `= expr` or `{ block }`.
            if p_at(p4, TkEq) {
              let p5 = p_skip_newlines(p_advance(p4))
              let rb = parse_expr(p5)
              match rb.r {
                None -> err_d(rb.p)
                Some(body) -> {
                  let body2 = wrap_with_contracts(body, cc.reqs, cc.enss, params, name, t.line, t.col)
                  let dfn = DFn(is_pub, name, tparams, params, ret_r.r, row_r.r, body2, t.line, t.col, None)
                  ok_d(rb.p, maybe_wrap_pure(attr.is_pure, dfn, t.line, t.col))
                }
              }
            } else if p_at(p4, TkLbrace) {
              let tb = p_peek(p4)
              # issue #415: peek past `{` and any newlines/semis. If
              # the first significant token is `case`, parse a
              # multi-clause body that desugars to a `match` over the
              # implicit tuple of args. Otherwise, fall through to the
              # existing statement-block form.
              let after_lbrace = p_skip_newlines_and_semis(p_advance(p4))
              if p_at(after_lbrace, TkCase) {
                let rb = parse_clause_block(after_lbrace, params, tb)
                match rb.r {
                  None -> err_d(rb.p)
                  Some(body) -> {
                    let body2 = wrap_with_contracts(body, cc.reqs, cc.enss, params, name, t.line, t.col)
                    let dfn = DFn(is_pub, name, tparams, params, ret_r.r, row_r.r, body2, t.line, t.col, None)
                    ok_d(rb.p, maybe_wrap_pure(attr.is_pure, dfn, t.line, t.col))
                  }
                }
              } else {
                let rb = parse_block(p4, tb)
                match rb.r {
                  None -> err_d(rb.p)
                  Some(body) -> {
                    let body2 = wrap_with_contracts(body, cc.reqs, cc.enss, params, name, t.line, t.col)
                    let dfn = DFn(is_pub, name, tparams, params, ret_r.r, row_r.r, body2, t.line, t.col, None)
                    ok_d(rb.p, maybe_wrap_pure(attr.is_pure, dfn, t.line, t.col))
                  }
                }
              }
            } else {
              err_d(p_error_here(p4, "expected `=` or `{` to start function body"))
            }
          }
        }
      }
        }
      }
    }
  }
}

# issue #415: parse a multi-clause function body. The opening `{`
# has already been consumed; `p` points at the first `case` keyword
# (or whatever follows `{` and any newlines/semis — caller verified
# `p_at(p, TkCase)`). Each arm is `case <pat> (when <guard>)? -> <body>`.
# For a 1-arg fn the scrutinee is `EVar(arg_name)` and arms carry a
# single pattern (reuses `parse_match_arms`). For an N-arg fn (N>=2)
# the scrutinee tuple is `(arg1, ..., argN)` represented as N parallel
# scrutinees and arms carry N comma-separated patterns (reuses
# `parse_multi_match_arms`). After collection the result is an
# `EMatch` indistinguishable from a hand-written `match` body, so the
# typer / codegen / perceus see no new shape.
#
# Pure-block rule: if any non-`case` token appears between arms, the
# arm-collection loop fails with "expected `case` or `}`" and the
# whole fn body is rejected — stmt-block mixed with case-arms is a
# hard parse error, never a warning.
fn parse_clause_block(p: Parser, params: [Param], t: Token) : PExpr / Console {

  let n = list_length(params)
  if n == 0 {
    # Zero-arg fn with case-arms: there's nothing to discriminate
    # on. Reject explicitly so the diagnostic points at the keyword.
    err_e(p_error_here(p, "case-block requires at least one parameter to discriminate on"))
  } else if n == 1 {
    let scrut = make_param_scrut(list_head(params))
    parse_case_arms(p, [], scrut, t)
  } else if n > 4 {
    # Issue #129 cap on multi-arg match also bounds the desugared
    # tuple here; raising it requires re-evaluating the nested-match
    # blowup as in `parse_match`.
    err_e(p_error_here(p, "case-block supports up to 4 parameters"))
  } else {
    let scruts = make_param_scruts(params, [])
    parse_case_multi_arms(p, [], scruts, n, t)
  }
}

fn list_head(xs: [Param]) : Param {
  match xs {
    [] -> Param { pname: "_", ptype: None, pline: 0, pcol: 0 }
    [h, ..._] -> h
  }
}

fn make_param_scrut(pm: Param) : Expr =
  mk_expr(EVar(pm.pname), pm.pline, pm.pcol)

fn make_param_scruts(params: [Param], acc: [Expr]) : [Expr] {
  match params {
    [] -> list_reverse(acc)
    [pm, ...rest] -> make_param_scruts(rest, [make_param_scrut(pm), ...acc])
  }
}

# issue #415: arm collector for the 1-arg case-block. Mirrors
# `parse_match_arms` but expects each arm to be led by `case`. Stops
# at `}`. Errors point at the offending token when neither `case`
# nor `}` appears next.
fn parse_case_arms(p: Parser, acc: [Arm], scrut: Expr, t: Token) : PExpr / Console {

  let p0 = p_skip_newlines_and_semis(p)
  if p_at(p0, TkRbrace) {
    if list_is_empty(acc) {
      err_e(p_error_here(p0, "case-block must have at least one `case` arm"))
    } else {
      ok_e(p_advance(p0), mk_expr(EMatch(scrut, list_reverse(acc)), t.line, t.col))
    }
  } else if not p_at(p0, TkCase) {
    err_e(p_error_here(p0, "case-block must contain only `case` arms; mix with stmt-block by extracting a helper or using `= match { ... }`"))
  } else {
    let p1 = p_skip_newlines(p_advance(p0))
    let ra = parse_case_arm_tail(p1)
    match ra.r {
      None -> err_e(ra.p)
      Some(arm) -> parse_case_arms(ra.p, [arm, ...acc], scrut, t)
    }
  }
}

# issue #415: parse the tail of a `case` arm — pattern, optional
# `when` guard, `->`, body. The leading `case` keyword has already
# been consumed by the caller.
fn parse_case_arm_tail(p: Parser) : PArm / Console {

  let rp = parse_pattern(p)
  match rp.r {
    None -> err_a(rp.p)
    Some(pat) -> {
      let p1 = p_skip_newlines(rp.p)
      let guard_opt_r =
        if p_at(p1, TkWhen) {
          let prev_atl = p1.allow_trailing_lambda
          let pg = p_with_trailing_lambda(p_advance(p1), false)
          let rg = parse_expr(pg)
          let rg_p = p_with_trailing_lambda(rg.p, prev_atl)
          match rg.r {
            None -> PExpr { p: rg_p, r: None }
            Some(g) -> PExpr { p: rg_p, r: Some(g) }
          }
        } else {
          PExpr { p: p1, r: None }
        }
      match guard_opt_r.r {
        None -> if guard_opt_r.p.had_error { err_a(guard_opt_r.p) } else {
          parse_arm_body(guard_opt_r.p, pat, None)
        }
        Some(_) -> parse_arm_body(guard_opt_r.p, pat, guard_opt_r.r)
      }
    }
  }
}

# issue #415: arm collector for N-arg case-block. Mirrors
# `parse_multi_match_arms`. Each arm is `case p1, ..., pN (when g)? -> body`.
fn parse_case_multi_arms(p: Parser, acc: [MArm], scruts: [Expr], n: Int, t: Token) : PExpr / Console {

  let p0 = p_skip_newlines_and_semis(p)
  if p_at(p0, TkRbrace) {
    if list_is_empty(acc) {
      err_e(p_error_here(p0, "case-block must have at least one `case` arm"))
    } else {
      let p1 = p_advance(p0)
      let arms_in_order = list_reverse(acc)
      let desugared = desugar_multi_match(scruts, arms_in_order, t.line, t.col)
      ok_e(p1, desugared)
    }
  } else if not p_at(p0, TkCase) {
    err_e(p_error_here(p0, "case-block must contain only `case` arms; mix with stmt-block by extracting a helper or using `= match { ... }`"))
  } else {
    let p1 = p_skip_newlines(p_advance(p0))
    let ra = parse_case_multi_arm(p1, n)
    match ra.r {
      None -> err_e(ra.p)
      Some(arm) -> parse_case_multi_arms(ra.p, [arm, ...acc], scruts, n, t)
    }
  }
}

# issue #415: parse `pat1, ..., patN (when guard)? -> body` after the
# leading `case` has been consumed. Mirrors `parse_multi_arm` but
# uses `when` instead of `if` for the guard.
fn parse_case_multi_arm(p: Parser, n: Int) : PMArm / Console {

  let r_pats = parse_n_patterns(p, n, [])
  match r_pats.r {
    None -> err_marm(r_pats.p)
    Some(pats) -> {
      let p1 = p_skip_newlines(r_pats.p)
      let guard_opt_r =
        if p_at(p1, TkWhen) {
          let prev_atl = p1.allow_trailing_lambda
          let pg = p_with_trailing_lambda(p_advance(p1), false)
          let rg = parse_expr(pg)
          let rg_p = p_with_trailing_lambda(rg.p, prev_atl)
          match rg.r {
            None -> PExpr { p: rg_p, r: None }
            Some(g) -> PExpr { p: rg_p, r: Some(g) }
          }
        } else {
          PExpr { p: p1, r: None }
        }
      let p2 = p_skip_newlines(guard_opt_r.p)
      if not p_at(p2, TkArrow) {
        err_marm(p_error_here(p2, "expected `->` in case-arm"))
      } else {
        let p3 = p_skip_newlines(p_advance(p2))
        let rb = parse_expr(p3)
        match rb.r {
          None -> err_marm(rb.p)
          Some(body) -> ok_marm(rb.p, MArm(pats, guard_opt_r.r, body))
        }
      }
    }
  }
}

# m12.6.x #5(a): result of attempting to parse the optional
# `[<refinement_pure>]` attribute after a fn signature / row. When
# the bracket is absent (or doesn't open with `<`), `is_pure` stays
# false and the parser is returned unchanged (peek-2 lookahead so a
# bare `[` doesn't trigger).
type PureAttr = { p: Parser, is_pure: Bool }

fn parse_optional_pure_attribute(p: Parser) : PureAttr / Console {

  if not p_at(p, TkLbracket) { PureAttr { p: p, is_pure: false } }
  else if not tk_is(p_peek1(p).kind, TkLt) {
    PureAttr { p: p, is_pure: false }
  } else {
    let p1 = p_skip_newlines(p_advance(p))
    let p2 = p_skip_newlines(p_advance(p1))
    let id = p_peek(p2)
    if not tk_is(id.kind, TkIdent) {
      PureAttr {
        p: p_error(p2, id, "expected attribute name after `[<`"),
        is_pure: false
      }
    } else {
      let attr_name = tok_source(p2.src, id)
      let p3 = p_skip_newlines(p_advance(p2))
      if not p_at(p3, TkGt) {
        PureAttr {
          p: p_error_here(p3, "expected `>` to close fn attribute"),
          is_pure: false
        }
      } else {
        let p4 = p_skip_newlines(p_advance(p3))
        if not p_at(p4, TkRbracket) {
          PureAttr {
            p: p_error_here(p4, "expected `]` to close fn attribute"),
            is_pure: false
          }
        } else {
          let p5 = p_advance(p4)
          if attr_name == "refinement_pure" {
            PureAttr { p: p5, is_pure: true }
          } else {
            PureAttr {
              p: p_error(p5, id, concat_all([
                "unknown fn attribute `", attr_name,
                "` — only `refinement_pure` is recognised in m12.6.x v1"
              ])),
              is_pure: false
            }
          }
        }
      }
    }
  }
}

fn maybe_wrap_pure(is_pure: Bool, dfn: Decl, line: Int, col: Int) : Decl =
  if is_pure { DAttribPure(dfn, line, col) } else { dfn }

# m12.6.b: contract-clause result. Carries the parser advanced past
# all `requires` / `ensures` clauses plus the accumulated predicates.
# Both lists are stored in source order (parse_contracts_loop reverses
# the accumulators before returning).
type Contracts = { p: Parser, reqs: [Expr], enss: [Expr] }

# m12.6.b: parse zero-or-more `requires <expr>` / `ensures <expr>`
# clauses, in any interleaving, until the next token is `=` or `{`
# (the start of the body) or anything else. Each clause's predicate
# is parsed as a single Expr; parse_expr stops at TkRequires /
# TkEnsures / TkEq / TkLbrace because none are operators.
fn parse_contracts_loop(p: Parser, reqs: [Expr], enss: [Expr]) : Contracts / Console {

  let p0 = p_skip_newlines(p)
  if p_at(p0, TkRequires) {
    let kw = p_peek(p0)
    let pe = parse_expr(p_skip_newlines(p_advance(p0)))
    match pe.r {
      None -> Contracts { p: pe.p, reqs: list_reverse(reqs), enss: list_reverse(enss) }
      Some(pred) -> {
        let p1 = check_pred_not_false(pe.p, pred, "requires", kw)
        # m12.6.x #5(a) v2: pure-call check moved to a post-parse pass
        # so it can consult the program-wide list of fns marked with
        # `[<refinement_pure>]`. See validate_contract_predicates_decls.
        parse_contracts_loop(p1, [pred, ...reqs], enss)
      }
    }
  } else if p_at(p0, TkEnsures) {
    let kw = p_peek(p0)
    let pe = parse_expr(p_skip_newlines(p_advance(p0)))
    match pe.r {
      None -> Contracts { p: pe.p, reqs: list_reverse(reqs), enss: list_reverse(enss) }
      Some(pred) -> {
        let p1 = check_pred_not_false(pe.p, pred, "ensures", kw)
        parse_contracts_loop(p1, reqs, [pred, ...enss])
      }
    }
  } else {
    Contracts { p: p0, reqs: list_reverse(reqs), enss: list_reverse(enss) }
  }
}


# m12.6.x #6: if a contract predicate folds to `false` at parse time,
# emit a compile-time error pointing at the clause keyword. The
# contract list still accumulates the predicate so downstream stmts
# parse cleanly; the parser's `had_error` flag aborts code emission
# at the end of the file, the same path as any other parse error.
fn check_pred_not_false(p: Parser, pred: Expr, kind: String, kw: Token) : Parser / Console {

  match try_eval_pred(pred) {
    Some(false) -> p_error(p, kw, concat_all([
      "`", kind, "` predicate is statically `false` — the contract ",
      "would always panic. Remove the clause or fix the predicate."
    ]))
    _ -> p
  }
}


# `effect Eff[T1, T2] { op_decl ... }` — m7a #3a + m7b #11.
# No name resolution and no evidence-type emission live here; those are
# #3c and #3d. Each op_decl is `name(params) : ReturnType`, body-less;
# per docs/effects-impl.md §*Evidence types*. Per-op type generics are
# m7b #2 (separate sub-task). m7b #11 adds the optional `[T1, T2]`
# tparam list after the effect name; tparams are in scope inside every
# op signature's parameter and return types.
fn parse_effect_decl(p: Parser, is_pub: Bool, t: Token) : PDecl / Console {

  let id = p_peek(p)
  if not tk_is(id.kind, TkIdent) {
    err_d(p_error(p, id, "expected effect name"))
  } else {
    let name = tok_source(p.src, id)
    let p1 = p_advance(p)
    let p1n = p_skip_newlines(p1)
    let tparams_r =
      if p_at(p1n, TkLbracket) {
        parse_type_params_loop(p_skip_newlines(p_advance(p1n)), [])
      } else {
        PTParams { p: p1n, r: Some([]) }
      }
    match tparams_r.r {
      None -> err_d(tparams_r.p)
      Some(tparams) -> {
        let p2 = p_skip_newlines(tparams_r.p)
        if not p_at(p2, TkLbrace) {
          err_d(p_error_here(p2, "expected `{` to start effect body"))
        } else {
          let p3 = p_skip_newlines(p_advance(p2))
          let ops_r = parse_effect_ops(p3, [])
          match ops_r.r {
            None -> err_d(ops_r.p)
            Some(ops) -> {
              # Issue #533: when parse_effect_ops stops at `default {`
              # (sentinel return, no `}` consumed), parse the default
              # block and then consume the effect-body closing `}`.
              let after_ops = p_skip_newlines(ops_r.p)
              let id_t = p_peek(after_ops)
              let is_default_kw =
                tk_is(id_t.kind, TkIdent) and tok_source(after_ops.src, id_t) == "default"
              if is_default_kw {
                let p_after_default = p_skip_newlines(p_advance(after_ops))
                if not p_at(p_after_default, TkLbrace) {
                  err_d(p_error_here(p_after_default, "expected `{` after `default`"))
                } else {
                  let p_block_open = p_skip_newlines(p_advance(p_after_default))
                  let cr = parse_handle_clauses(p_block_open, [], None, [])
                  match cr.r {
                    None -> err_d(cr.p)
                    Some(_) -> {
                      # parse_handle_clauses already consumed the
                      # inner `}`. Now consume the outer effect-body
                      # closing `}`.
                      let p_after_block = p_skip_newlines(cr.p)
                      if not p_at(p_after_block, TkRbrace) {
                        err_d(p_error_here(p_after_block,
                          "expected `}` to close effect body after `default` block"))
                      } else {
                        let p_close = p_advance(p_after_block)
                        let defblk = DBlk(cr.clauses, cr.return_clause,
                                          id_t.line, id_t.col)
                        ok_d(p_close, DEffect(is_pub, name, tparams, ops,
                                              Some(defblk), t.line, t.col))
                      }
                    }
                  }
                }
              } else {
                ok_d(ops_r.p, DEffect(is_pub, name, tparams, ops, None, t.line, t.col))
              }
            }
          }
        }
      }
    }
  }
}

type PEffectOps = { p: Parser, r: Option[[EffectOp]] }

fn parse_effect_ops(p: Parser, acc: [EffectOp]) : PEffectOps / Console {

  let p0 = p_skip_newlines(p)
  if p_at(p0, TkRbrace) {
    # Note: do NOT advance past the `}` here. The caller drives the
    # closing-brace consumption so it can first check for an optional
    # `default { clauses }` block — but issue #533 v1 places `default`
    # *before* the closing brace of the effect body, so this branch
    # always closes the effect decl. Keep the existing advance.
    PEffectOps { p: p_advance(p0), r: Some(list_reverse(acc)) }
  } else {
    let id = p_peek(p0)
    if not tk_is(id.kind, TkIdent) {
      PEffectOps { p: p_error(p0, id, "expected operation name"), r: None }
    } else {
      let opname = tok_source(p0.src, id)
      # Issue #533: when the ident is `default` and the next token is
      # `{`, stop accumulating ops. The caller (parse_effect_decl)
      # consumes the `default { clauses }` block before the effect
      # body's closing brace. We do NOT advance past `default` here;
      # the caller re-peeks it.
      let p_after_id = p_skip_newlines(p_advance(p0))
      if opname == "default" and p_at(p_after_id, TkLbrace) {
        PEffectOps { p: p0, r: Some(list_reverse(acc)) }
      } else {
      let p1 = p_advance(p0)
      # m7b #2: optional `[T1, T2]` op-level tparams before `(args)`.
      # Reuses parse_type_params_loop (m7b #11 / m7a effects). Empty
      # when omitted; the op signature is then monomorphic.
      let op_tparams_r =
        if p_at(p1, TkLbracket) {
          parse_type_params_loop(p_skip_newlines(p_advance(p1)), [])
        } else {
          PTParams { p: p1, r: Some([]) }
        }
      match op_tparams_r.r {
        None -> PEffectOps { p: op_tparams_r.p, r: None }
        Some(op_tparams) -> {
          let pp = op_tparams_r.p
          if not p_at(pp, TkLparen) {
            PEffectOps { p: p_error_here(pp, "expected `(` after operation name"), r: None }
          } else {
        let p2 = p_skip_newlines(p_advance(pp))
        let params_r = parse_fn_params(p2, [])
        match params_r.r {
          None -> PEffectOps { p: params_r.p, r: None }
          Some(params) -> {
            let p3 = p_skip_newlines(params_r.p)
            if not p_at(p3, TkColon) {
              PEffectOps { p: p_error_here(p3, "expected `:` before operation return type"), r: None }
            } else {
              let rt = parse_type(p_advance(p3))
              match rt.r {
                None -> PEffectOps { p: rt.p, r: None }
                Some(ty) -> {
                  let op = EOp(opname, op_tparams, params, ty, id.line, id.col)
                  parse_effect_ops(rt.p, [op, ...acc])
                }
              }
            }
          }
        }
          }
        }
      }
      }
    }
  }
}

type PParams = { p: Parser, r: Option[[Param]] }

fn parse_fn_params(p: Parser, acc: [Param]) : PParams / Console {

  if p_at(p, TkRparen) { PParams { p: p_advance(p), r: Some(list_reverse(acc)) } }
  else {
    let t = p_peek(p)
    if not tk_is(t.kind, TkIdent) {
      PParams { p: p_error(p, t, "expected parameter name"), r: None }
    } else {
      let name = tok_source(p.src, t)
      let p1 = p_advance(p)
      if not p_at(p1, TkColon) {
        PParams { p: p_error_here(p1, "expected `:` after parameter name"), r: None }
      } else {
        let rt = parse_type(p_advance(p1))
        match rt.r {
          None -> PParams { p: rt.p, r: None }
          Some(ty) -> {
            let param = Param { pname: name, ptype: Some(ty), pline: t.line, pcol: t.col }
            let p2 = p_skip_newlines(rt.p)
            if p_at(p2, TkComma) {
              parse_fn_params(p_skip_newlines(p_advance(p2)), [param, ...acc])
            } else if p_at(p2, TkRparen) {
              PParams { p: p_advance(p2), r: Some(list_reverse([param, ...acc])) }
            } else {
              PParams { p: p_error_here(p2, "expected `,` or `)` in parameter list"), r: None }
            }
          }
        }
      }
    }
  }
}

# m12.8: `protocol P { op_decls }`. Each op_decl is `name(params) :
# ReturnType`, body-less, mirroring effect-op shape. The first param
# may use `Self` as its type to indicate the dispatch site; the
# resolver / typer treats `Self` as a fresh type variable.
fn parse_protocol_decl(p: Parser, is_pub: Bool, t: Token) : PDecl / Console {

  let id = p_peek(p)
  if not tk_is(id.kind, TkIdent) or not is_upper_ident(p.src, id) {
    err_d(p_error(p, id, "expected an uppercase protocol name"))
  } else {
    let name = tok_source(p.src, id)
    let p1 = p_advance(p)
    # Issue #180: optional `[A1, A2, ...]` type-parameter list bound at
    # protocol declaration scope. Reuses the standard tparam parser
    # (same shape as `effect Reader[T]` and `fn[T]`).
    let proto_tps_r =
      if p_at(p1, TkLbracket) {
        parse_type_params_loop(p_skip_newlines(p_advance(p1)), [])
      } else {
        PTParams { p: p1, r: Some([]) }
      }
    match proto_tps_r.r {
      None -> err_d(proto_tps_r.p)
      Some(proto_tparams) -> {
        let p1n = p_skip_newlines(proto_tps_r.p)
        if not p_at(p1n, TkLbrace) {
          err_d(p_error_here(p1n, "expected `{` to start protocol body"))
        } else {
          let p2 = p_skip_newlines(p_advance(p1n))
          let ops_r = parse_protocol_ops(p2, [])
          match ops_r.r {
            None -> err_d(ops_r.p)
            Some(ops) -> ok_d(ops_r.p, DProtocol(is_pub, name, proto_tparams, ops, t.line, t.col))
          }
        }
      }
    }
  }
}

type PProtoOps = { p: Parser, r: Option[[ProtoOp]] }

fn parse_protocol_ops(p: Parser, acc: [ProtoOp]) : PProtoOps / Console {

  let p0 = p_skip_newlines(p)
  if p_at(p0, TkRbrace) {
    PProtoOps { p: p_advance(p0), r: Some(list_reverse(acc)) }
  } else {
    let id = p_peek(p0)
    if not tk_is(id.kind, TkIdent) {
      PProtoOps { p: p_error(p0, id, "expected operation name"), r: None }
    } else {
      let opname = tok_source(p0.src, id)
      let p1 = p_advance(p0)
      let op_tparams_r =
        if p_at(p1, TkLbracket) {
          parse_type_params_loop(p_skip_newlines(p_advance(p1)), [])
        } else {
          PTParams { p: p1, r: Some([]) }
        }
      match op_tparams_r.r {
        None -> PProtoOps { p: op_tparams_r.p, r: None }
        Some(op_tparams) -> {
          let pp = op_tparams_r.p
          if not p_at(pp, TkLparen) {
            PProtoOps { p: p_error_here(pp, "expected `(` after operation name"), r: None }
          } else {
            let p2 = p_skip_newlines(p_advance(pp))
            let params_r = parse_fn_params(p2, [])
            match params_r.r {
              None -> PProtoOps { p: params_r.p, r: None }
              Some(params) -> {
                let p3 = p_skip_newlines(params_r.p)
                if not p_at(p3, TkColon) {
                  PProtoOps { p: p_error_here(p3, "expected `:` before operation return type"), r: None }
                } else {
                  let rt = parse_type(p_advance(p3))
                  match rt.r {
                    None -> PProtoOps { p: rt.p, r: None }
                    Some(ty) -> {
                      let op = POp(opname, op_tparams, params, ty, id.line, id.col)
                      parse_protocol_ops(rt.p, [op, ...acc])
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}

# m12.8: `impl P for T { fn op(args) = body ... }`. Each method is a
# regular DFn whose name matches a protocol op name. The body
# inherits the parser's full feature set (any expression form).
#
# m12.8 phase 2: an optional impl-level tparam list `[u: Measure, ...]`
# may follow `impl` (mirrors the `fn[T1, T2]` shape). The bound names
# are prepended to each method's own tparams so the typer sees them
# as ordinary fn tparams in scope inside parameter and body types
# (e.g. `impl[u: Measure] Show for Real<u> { fn show(x: Real<u>) ... }`).
fn parse_impl_decl(p: Parser, t: Token) : PDecl / Console {

  let imp_tps_r =
    if p_at(p, TkLbracket) {
      # Issue #174: impl-site tparams accept protocol bounds
      # (`[T : Show + Eq, U]`) in addition to the legacy `Measure`
      # kind annotation. Bounds are encoded as `T#b:Show,Eq` in the
      # stored tparam string; see `tp_bounds_of` / `tp_strip_bounds`.
      parse_impl_type_params_loop(p_skip_newlines(p_advance(p)), [])
    } else {
      PTParams { p: p, r: Some([]) }
    }
  match imp_tps_r.r {
    None -> err_d(imp_tps_r.p)
    Some(impl_tparams) -> {
      let p_after_tps = p_skip_newlines(imp_tps_r.p)
      let id = p_peek(p_after_tps)
      if not tk_is(id.kind, TkIdent) or not is_upper_ident(p_after_tps.src, id) {
        err_d(p_error(p_after_tps, id, "expected an uppercase protocol name after `impl`"))
      } else {
        let pname = tok_source(p_after_tps.src, id)
        let p1 = p_advance(p_after_tps)
        # Issue #180: optional `[T1, T2, ...]` after the protocol name
        # binds the protocol's type-parameters at this impl-site
        # (`impl Add[Real] for Complex`). Each Ti is a concrete
        # TypeExpr — polymorphism in `Ai` is out of scope (see #174).
        let pa_args_r =
          if p_at(p1, TkLbracket) {
            parse_impl_proto_args(p_skip_newlines(p_advance(p1)), [])
          } else {
            PImplArgs { p: p1, r: Some([]) }
          }
        match pa_args_r.r {
          None -> err_d(pa_args_r.p)
          Some(proto_args) -> {
            let p1b = pa_args_r.p
            let p1n = p_skip_newlines(p1b)
            if not p_at(p1n, TkFor) {
              err_d(p_error_here(p1n, "expected `for` after protocol name in `impl`"))
            } else {
              let p2 = p_skip_newlines(p_advance(p1n))
              let target_r = parse_type(p2)
              match target_r.r {
                None -> err_d(target_r.p)
                Some(target_ty) -> {
                  let p3 = p_skip_newlines(target_r.p)
                  if not p_at(p3, TkLbrace) {
                    err_d(p_error_here(p3, "expected `{` to start impl body"))
                  } else {
                    let p4 = p_skip_newlines(p_advance(p3))
                    let methods_r = parse_impl_methods(p4, [])
                    match methods_r.r {
                      None -> err_d(methods_r.p)
                      Some(ms) -> {
                        let ms2 = prepend_impl_tparams_to_methods(impl_tparams, ms)
                        ok_d(methods_r.p, DImpl(pname, proto_args, target_ty, ms2, t.line, t.col))
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}

# m12.8 phase 2: prepend the impl-level tparams to each method's own
# tparams. Caller has already validated method shape (parse_impl_methods
# only emits DFn nodes).
fn prepend_impl_tparams_to_methods(impl_tps: [String], ms: [Decl]) : [Decl] {
  match impl_tps {
    [] -> ms
    _  -> {
      # Issue #174: tparams may carry bound suffixes (`T#b:Show`).
      # Strip them before injecting into the method's tparam list so
      # the rest of the pipeline (which uses these strings as plain
      # ident keys) sees only `T`. Bounds inform compile-time
      # diagnostics through a separate mechanism — they do not
      # change the method's typing.
      let stripped = map(impl_tps, tp_strip_bounds)
      map(ms, (d) => prepend_impl_tparams_to_method(stripped, d))
    }
  }
}

fn prepend_impl_tparams_to_method(impl_tps: [String], d: Decl) : Decl {
  match d {
    DFn(pub_, n, tps, ps, ret, row, body, l, c, mo) ->
      DFn(pub_, n, list_append(impl_tps, tps), ps, ret, row, body, l, c, mo)
    _ -> d
  }
}

type PImplArgs = { p: Parser, r: Option[[TypeExpr]] }

# Issue #180: parse comma-separated TypeExpr list inside `[...]` after
# the protocol name in `impl P[T1, T2, ...] for U`. Each Ti is a
# fully-elaborated TypeExpr (including `Money[USD]`, `Real<m>`, etc.).
fn parse_impl_proto_args(p: Parser, acc: [TypeExpr]) : PImplArgs / Console {

  let p0 = p_skip_newlines(p)
  if p_at(p0, TkRbracket) {
    PImplArgs { p: p_advance(p0), r: Some(list_reverse(acc)) }
  } else {
    let ty_r = parse_type(p0)
    match ty_r.r {
      None -> PImplArgs { p: ty_r.p, r: None }
      Some(ty) -> {
        let p1 = p_skip_newlines(ty_r.p)
        if p_at(p1, TkComma) {
          parse_impl_proto_args(p_advance(p1), [ty, ...acc])
        } else if p_at(p1, TkRbracket) {
          PImplArgs { p: p_advance(p1), r: Some(list_reverse([ty, ...acc])) }
        } else {
          PImplArgs { p: p_error_here(p1, "expected `,` or `]` in impl protocol arguments"), r: None }
        }
      }
    }
  }
}

type PImplMethods = { p: Parser, r: Option[[Decl]] }

fn parse_impl_methods(p: Parser, acc: [Decl]) : PImplMethods / Console {

  let p0 = p_skip_newlines(p)
  if p_at(p0, TkRbrace) {
    PImplMethods { p: p_advance(p0), r: Some(list_reverse(acc)) }
  } else {
    if not p_at(p0, TkFn) {
      PImplMethods { p: p_error_here(p0, "expected `fn` to start an impl method"), r: None }
    } else {
      let fn_tok = p_peek(p0)
      let p1 = p_advance(p0)
      let dr = parse_fn_decl(p1, false, fn_tok)
      match dr.r {
        None -> PImplMethods { p: dr.p, r: None }
        Some(d) -> parse_impl_methods(dr.p, [d, ...acc])
      }
    }
  }
}

# Issue #608: `#[ident (args)?]` attribute, dispatched after the lexer
# emits `TkHashOpen` and the caller has advanced past it. Reads the
# identifier inside the brackets, expects the matching `]`, and routes
# to the appropriate inner-decl parser. Known attributes today: `derive`
# (with parenthesised protocol list) and `unstable` (flag form). Unknown
# attributes parse cleanly (forward-compat for future `#[doc(...)]`,
# `#[deprecated]`, custom user attributes) and are dropped from the AST.
fn parse_attribute_decl(p: Parser, hash_tok: Token) : PDecl / Console {

  let p0 = p_skip_newlines(p)
  let id = p_peek(p0)
  if not tk_is(id.kind, TkIdent) {
    err_d(p_error(p0, id, "expected attribute name after `#[`"))
  } else {
    let name = tok_source(p0.src, id)
    let p1 = p_advance(p0)
    if name == "derive" {
      parse_attr_derive_body(p1, hash_tok)
    } else if name == "unstable" {
      parse_attr_unstable_body(p1, hash_tok)
    } else {
      parse_attr_unknown_body(p1, name, hash_tok)
    }
  }
}

# `#[derive(P1, P2, ...)] type T = ...`. The ident and TkHashOpen have
# already been consumed; `p` points at the `(`.
fn parse_attr_derive_body(p: Parser, hash_tok: Token) : PDecl / Console {

  if not p_at(p, TkLparen) {
    err_d(p_error_here(p, "expected `(` after `#[derive`"))
  } else {
    let p1 = p_skip_newlines(p_advance(p))
    let names_r = parse_derive_names(p1, [])
    match names_r.r {
      None -> err_d(names_r.p)
      Some(names) -> {
        let p_close = p_skip_newlines(names_r.p)
        if not p_at(p_close, TkRbracket) {
          err_d(p_error_here(p_close, "expected `]` to close `#[derive(...)]`"))
        } else {
          let p2 = p_skip_newlines(p_advance(p_close))
          let p2_pub_r =
            if tk_is(p_peek(p2).kind, TkPub) { PTy { p: p_advance(p2), r: Some(mk_ty(TyName("", []), 0, 0)) } }
            else { PTy { p: p2, r: None } }
          let inner_pub = match p2_pub_r.r { Some(_) -> true None -> false }
          let p3 = p2_pub_r.p
          let hd = p_peek(p3)
          if not tk_is(hd.kind, TkType) {
            err_d(p_error(p3, hd, "`#[derive(...)]` must precede a `type` declaration"))
          } else {
            let inner = parse_type_decl(p_advance(p3), inner_pub, hd)
            match inner.r {
              None -> err_d(inner.p)
              Some(d) -> ok_d(inner.p, DDerive(names, d, hash_tok.line, hash_tok.col))
            }
          }
        }
      }
    }
  }
}

# `#[unstable] pub fn / pub type / pub const / pub effect / pub protocol`.
# The ident and TkHashOpen have already been consumed; `p` points at the
# closing `]`.
fn parse_attr_unstable_body(p: Parser, hash_tok: Token) : PDecl / Console {

  if not p_at(p, TkRbracket) {
    err_d(p_error_here(p, "expected `]` to close `#[unstable]` (the unstable attribute takes no arguments)"))
  } else {
    let p_after = p_advance(p)
    parse_unstable_decl(p_after, hash_tok)
  }
}

# Forward-compat: unknown attributes (`#[doc("...")]`, `#[deprecated]`,
# `#[cfg(...)]`, custom user attributes). Consume the optional argument
# list and the closing `]`, then return whatever decl follows untouched.
# The attribute itself is dropped — only `derive` and `unstable` have
# downstream semantics in this lane.
fn parse_attr_unknown_body(p: Parser, name: String, hash_tok: Token) : PDecl / Console {

  let p_args = if p_at(p, TkLparen) {
    skip_balanced_parens(p_advance(p), 1)
  } else { p }
  if not p_at(p_args, TkRbracket) {
    err_d(p_error_here(p_args, string_concat_all(["expected `]` to close `#[", name, "(...)]`"])))
  } else {
    let p2 = p_skip_newlines(p_advance(p_args))
    parse_decl(p2)
  }
}

# Skip tokens until the matching `)` (the caller has already consumed the
# opening `(` and `depth` starts at 1). Used by unknown-attribute parsing
# to ignore arbitrary argument shapes. Bails on EOF.
fn skip_balanced_parens(p: Parser, depth: Int) : Parser {
  if depth <= 0 { p }
  else {
    let t = p_peek(p)
    if tk_is(t.kind, TkEof) { p }
    else if tk_is(t.kind, TkLparen) { skip_balanced_parens(p_advance(p), depth + 1) }
    else if tk_is(t.kind, TkRparen) { skip_balanced_parens(p_advance(p), depth - 1) }
    else { skip_balanced_parens(p_advance(p), depth) }
  }
}

type PDeriveNames = { p: Parser, r: Option[[String]] }

fn parse_derive_names(p: Parser, acc: [String]) : PDeriveNames / Console {

  let id = p_peek(p)
  if not tk_is(id.kind, TkIdent) or not is_upper_ident(p.src, id) {
    PDeriveNames { p: p_error(p, id, "expected a protocol name in `#[derive(...)]`"), r: None }
  } else {
    let name = tok_source(p.src, id)
    let p1 = p_skip_newlines(p_advance(p))
    if p_at(p1, TkComma) {
      parse_derive_names(p_skip_newlines(p_advance(p1)), [name, ...acc])
    } else if p_at(p1, TkRparen) {
      PDeriveNames { p: p_advance(p1), r: Some(list_reverse([name, ...acc])) }
    } else {
      PDeriveNames { p: p_error_here(p1, "expected `,` or `)` in `#[derive(...)]`"), r: None }
    }
  }
}

# Issue #602: `#unstable` immediately followed by `pub fn`, `pub type`,
# or `pub const`. Newlines between the annotation and the `pub` keyword
# are allowed so authors can place `#unstable` on its own line above
# the declaration (matching the surface shown in `docs/editions.md`).
# Wraps the parsed Decl in `DUnstable` so downstream walkers see the
# inner shape unchanged but the export-collection pass can mark the
# pub name as unstable for import-site enforcement.
fn parse_unstable_decl(p: Parser, t: Token) : PDecl / Console {
  let p0 = p_skip_newlines(p)
  let pub_tok = p_peek(p0)
  if not tk_is(pub_tok.kind, TkPub) {
    err_d(p_error(p0, pub_tok, "`#[unstable]` must precede a `pub fn`, `pub type`, or `pub const` declaration"))
  } else {
    let p1 = p_skip_newlines(p_advance(p0))
    let hd = p_peek(p1)
    if tk_is(hd.kind, TkFn) {
      let inner = parse_fn_decl(p_advance(p1), true, hd)
      match inner.r {
        None    -> err_d(inner.p)
        Some(d) -> ok_d(inner.p, DUnstable(d, t.line, t.col))
      }
    } else if tk_is(hd.kind, TkType) {
      let inner = parse_type_decl(p_advance(p1), true, hd)
      match inner.r {
        None    -> err_d(inner.p)
        Some(d) -> ok_d(inner.p, DUnstable(d, t.line, t.col))
      }
    } else if tk_is(hd.kind, TkConst) {
      let inner = parse_const_decl(p_advance(p1), true, hd)
      match inner.r {
        None    -> err_d(inner.p)
        Some(d) -> ok_d(inner.p, DUnstable(d, t.line, t.col))
      }
    } else if tk_is(hd.kind, TkEffect) {
      let inner = parse_effect_decl(p_advance(p1), true, hd)
      match inner.r {
        None    -> err_d(inner.p)
        Some(d) -> ok_d(inner.p, DUnstable(d, t.line, t.col))
      }
    } else if tk_is(hd.kind, TkProtocol) {
      let inner = parse_protocol_decl(p_advance(p1), true, hd)
      match inner.r {
        None    -> err_d(inner.p)
        Some(d) -> ok_d(inner.p, DUnstable(d, t.line, t.col))
      }
    } else {
      err_d(p_error(p1, hd, "`#[unstable] pub` must be followed by `fn`, `type`, `const`, `effect`, or `protocol`"))
    }
  }
}

fn parse_type_decl(p: Parser, is_pub: Bool, t: Token) : PDecl / Console {

  let id = p_peek(p)
  if not tk_is(id.kind, TkIdent) or not is_upper_ident(p.src, id) {
    err_d(p_error(p, id, "expected an uppercase type name after `type`"))
  } else {
    let name = tok_source(p.src, id)
    let p1 = p_advance(p)
    let p1n = p_skip_newlines(p1)
    # Optional type params `[a, b, c]`.
    let tparams_r =
      if p_at(p1n, TkLbracket) {
        parse_type_params_loop(p_skip_newlines(p_advance(p1n)), [])
      } else {
        PTParams { p: p1n, r: Some([]) }
      }
    match tparams_r.r {
      None -> err_d(tparams_r.p)
      Some(tparams) -> {
        let p2 = p_skip_newlines(tparams_r.p)
        if not p_at(p2, TkEq) {
          err_d(p_error_here(p2, "expected `=` in type declaration"))
        } else {
          let p3 = p_skip_newlines(p_advance(p2))
          parse_type_body(p3, is_pub, name, tparams, t)
        }
      }
    }
  }
}

type PTParams = { p: Parser, r: Option[[String]] }

fn parse_type_params_loop(p: Parser, acc: [String]) : PTParams / Console {

  let t = p_peek(p)
  if not tk_is(t.kind, TkIdent) {
    PTParams { p: p_error(p, t, "expected type parameter name"), r: None }
  } else {
    let raw_name = tok_source(p.src, t)
    let p1 = p_skip_newlines(p_advance(p))
    # m12.5: optional `: Measure` (or `: Type`) kind annotation.
    # Stored by suffixing the param name with "#Unit" for unit-kind
    # params (legacy internal name; surface keyword renamed in #253).
    let kr = parse_optional_kind_annotation(p1)
    let stored = tp_make(raw_name, kr.kind)
    let p2 = p_skip_newlines(kr.p)
    if p_at(p2, TkComma) {
      parse_type_params_loop(p_skip_newlines(p_advance(p2)), [stored, ...acc])
    } else if p_at(p2, TkRbracket) {
      PTParams { p: p_advance(p2), r: Some(list_reverse([stored, ...acc])) }
    } else {
      PTParams { p: p_error_here(p2, "expected `,` or `]` after type parameter"), r: None }
    }
  }
}

# Issue #174: impl-site variant of parse_type_params_loop. Accepts the
# same `Measure` kind annotation as before AND, additionally, a list
# of uppercase protocol-name bounds: `T : Show`, `T : Show + Eq`. The
# bound list is encoded as a `#b:Name1,Name2` suffix in the stored
# tparam string. The `#` is collision-free against kaikai identifiers
# (lexer rejects `#` inside ident).
fn parse_impl_type_params_loop(p: Parser, acc: [String]) : PTParams / Console {

  let t = p_peek(p)
  if not tk_is(t.kind, TkIdent) {
    PTParams { p: p_error(p, t, "expected type parameter name"), r: None }
  } else {
    let raw_name = tok_source(p.src, t)
    let p1 = p_skip_newlines(p_advance(p))
    let kbr = parse_optional_kind_or_bounds(p1)
    let stored = tp_make_with_bounds(raw_name, kbr.kind, kbr.bounds)
    let p2 = p_skip_newlines(kbr.p)
    if p_at(p2, TkComma) {
      parse_impl_type_params_loop(p_skip_newlines(p_advance(p2)), [stored, ...acc])
    } else if p_at(p2, TkRbracket) {
      PTParams { p: p_advance(p2), r: Some(list_reverse([stored, ...acc])) }
    } else {
      PTParams { p: p_error_here(p2, "expected `,` or `]` after type parameter"), r: None }
    }
  }
}

# Issue #174: impl-site colon-suffix parser. Distinguishes:
#   `: Measure`              → kind annotation (legacy)
#   `: Type`                 → kind annotation (legacy, no-op default)
#   `: Show`                 → bound list `[Show]`
#   `: Show + Eq + Ord`      → multi-bound list
# Mixing kinds and bounds is rejected: `: Measure + Show` makes no
# sense since `Measure` is a kind, not a protocol.
type PKindBounds = { p: Parser, kind: Kind, bounds: [String] }

fn parse_optional_kind_or_bounds(p: Parser) : PKindBounds / Console {

  if p_at(p, TkColon) {
    let p1 = p_skip_newlines(p_advance(p))
    let t = p_peek(p1)
    if not tk_is(t.kind, TkIdent) {
      PKindBounds { p: p_error_here(p1, "expected protocol name, `Type`, or `Measure` after `:` in type parameter"),
                    kind: KType, bounds: [] }
    } else {
      let kw = tok_source(p1.src, t)
      let p2 = p_advance(p1)
      if kw == "Measure" { PKindBounds { p: p2, kind: KUnit, bounds: [] } }
      else if kw == "Type" { PKindBounds { p: p2, kind: KType, bounds: [] } }
      else if kw == "Unit" {
        PKindBounds { p: p_error(p1, t, "expected kind `Measure`; `Unit` is the void return type, not a kind (renamed in #253)"),
                      kind: KType, bounds: [] }
      } else if is_upper_ident(p1.src, t) {
        # First bound — accumulate further `+ Bound` entries.
        parse_more_bounds_loop(p2, [kw])
      } else {
        PKindBounds { p: p_error(p1, t, "type-parameter annotation must be `Type`, `Measure`, or an uppercase protocol name"),
                      kind: KType, bounds: [] }
      }
    }
  } else {
    PKindBounds { p: p, kind: KType, bounds: [] }
  }
}

fn parse_more_bounds_loop(p: Parser, acc: [String]) : PKindBounds / Console {

  let p_n = p_skip_newlines(p)
  if p_at(p_n, TkPlus) {
    let p1 = p_skip_newlines(p_advance(p_n))
    let t = p_peek(p1)
    if not tk_is(t.kind, TkIdent) or not is_upper_ident(p1.src, t) {
      PKindBounds { p: p_error_here(p1, "expected uppercase protocol name after `+` in bound list"),
                    kind: KType, bounds: list_reverse(acc) }
    } else {
      let nm = tok_source(p1.src, t)
      parse_more_bounds_loop(p_advance(p1), [nm, ...acc])
    }
  } else {
    PKindBounds { p: p, kind: KType, bounds: list_reverse(acc) }
  }
}

# Issue #174: encode a tparam name plus optional protocol bound list
# into the legacy `String` slot. Format:
#   "T"               (no kind, no bounds)
#   "T#Unit"          (kind = Measure, no bounds)
#   "T#b:Show"        (no kind, single bound)
#   "T#b:Show,Eq"     (no kind, multi-bound)
# Kind and bounds never coexist (parser rejects the combo), so a
# tparam string contains at most one of `#Unit` or `#b:...`.
fn tp_make_with_bounds(name: String, k: Kind, bounds: [String]) : String {
  let with_kind = tp_make(name, k)
  match bounds {
    [] -> with_kind
    _  -> concat_all([with_kind, "#b:", tp_bounds_join(bounds)])
  }
}

fn tp_bounds_join(bs: [String]) : String = match bs {
  [] -> ""
  [b] -> b
  [b, ...rest] -> concat_all([b, ",", tp_bounds_join(rest)])
}

# Decoder helpers — used by lower_protocols / monomorpher to walk an
# impl's tparam list and extract bounds.
fn tp_bounds_marker_index(s: String) : Int =
  tp_bounds_marker_loop(s, 0, string_length(s))

fn tp_bounds_marker_loop(s: String, i: Int, n: Int) : Int {
  if i + 3 > n { -1 }
  else {
    match char_at(s, i) {
      Some(c0) -> if c0 == '#' {
        match char_at(s, i + 1) {
          Some(c1) -> if c1 == 'b' {
            match char_at(s, i + 2) {
              Some(c2) -> if c2 == ':' { i }
                          else { tp_bounds_marker_loop(s, i + 1, n) }
              None -> -1
            }
          } else { tp_bounds_marker_loop(s, i + 1, n) }
          None -> -1
        }
      } else { tp_bounds_marker_loop(s, i + 1, n) }
      None -> -1
    }
  }
}

pub fn tp_has_bounds(stored: String) : Bool = tp_bounds_marker_index(stored) >= 0

pub fn tp_strip_bounds(stored: String) : String {
  let i = tp_bounds_marker_index(stored)
  if i < 0 { stored } else { string_slice(stored, 0, i) }
}

pub fn tp_bounds_of(stored: String) : [String] {
  let i = tp_bounds_marker_index(stored)
  if i < 0 { [] }
  else {
    let start = i + 3
    let suf = string_slice(stored, start, string_length(stored) - start)
    split_csv(suf, [])
  }
}

fn split_csv_index(s: String, i: Int, n: Int) : Int {
  if i >= n { -1 }
  else {
    match char_at(s, i) {
      Some(c) -> if c == ',' { i } else { split_csv_index(s, i + 1, n) }
      None -> -1
    }
  }
}

fn split_csv(s: String, acc: [String]) : [String] {
  let n = string_length(s)
  if n == 0 { list_reverse(acc) }
  else {
    let i = split_csv_index(s, 0, n)
    if i < 0 { list_reverse([s, ...acc]) }
    else {
      let head = string_slice(s, 0, i)
      let rest = string_slice(s, i + 1, n - i - 1)
      split_csv(rest, [head, ...acc])
    }
  }
}

# m12.5: helper — consume an optional `: Type` / `: Measure` kind
# suffix. Defaults to KType when absent, preserving existing
# behaviour. Issue #253: the surface keyword is `Measure` (was
# `Unit` in m12.5–m12.8); the legacy `Unit` produces a targeted
# diagnostic distinguishing it from `Unit` the void-return type.
type PKind = { p: Parser, kind: Kind }

fn parse_optional_kind_annotation(p: Parser) : PKind / Console {

  if p_at(p, TkColon) {
    let p1 = p_skip_newlines(p_advance(p))
    let t = p_peek(p1)
    if not tk_is(t.kind, TkIdent) {
      PKind { p: p_error_here(p1, "expected `Type` or `Measure` after `:` in type parameter"), kind: KType }
    } else {
      let kw = tok_source(p1.src, t)
      let p2 = p_advance(p1)
      if kw == "Measure" { PKind { p: p2, kind: KUnit } }
      else if kw == "Type" { PKind { p: p2, kind: KType } }
      else if kw == "Unit" { PKind { p: p_error(p1, t, "expected kind `Measure`; `Unit` is the void return type, not a kind (renamed in #253)"), kind: KType } }
      else { PKind { p: p_error(p1, t, "type-parameter kind must be `Type` or `Measure`"), kind: KType } }
    }
  } else {
    PKind { p: p, kind: KType }
  }
}

fn parse_type_body(p: Parser, is_pub: Bool, name: String, tparams: [String], t: Token) : PDecl / Console {

  if p_at(p, TkLbrace) {
    let p1 = p_skip_newlines(p_advance(p))
    parse_record_body(p1, [], is_pub, name, tparams, t)
  } else {
    # Sum or alias: check for an uppercase ident followed by `(` OR
    # followed eventually by `|` to decide. Simpler approach: try to
    # parse as sum; if the first variant is followed by `|`, continue
    # as sum; otherwise, fall back to alias. But stage 1 mirrors stage
    # 0: use the same heuristic — if the first token is Uppercase and
    # the next is `(` OR further along we see `|`, treat as sum.
    let hd = p_peek(p)
    if tk_is(hd.kind, TkIdent) and is_upper_ident(p.src, hd) {
      # Effect alias body has the form `Eff1 + Eff2 + ...`. The `+`
      # immediately after the first uppercase ident is the unambiguous
      # signal: type aliases never use `+`, sums use `|`. Single-effect
      # aliases (`type Foo = Console`) parse as TBAlias and are
      # recognised at resolve time. (m7b #1a)
      let nxt = p_peek1(p)
      if tk_is(nxt.kind, TkPlus) {
        let nm = tok_source(p.src, hd)
        parse_effect_alias_body(p_advance(p_advance(p)), [nm], is_pub, name, tparams, t)
      } else {
        let is_sum = looks_like_sum(p)
        if is_sum {
          parse_sum_body(p, [], is_pub, name, tparams, t)
        } else {
          let rt = parse_type(p)
          match rt.r {
            None -> err_d(rt.p)
            Some(aliased) -> ok_d(rt.p, DType(is_pub, name, tparams, TBAlias(aliased), t.line, t.col, None))
          }
        }
      }
    } else {
      let rt = parse_type(p)
      match rt.r {
        None -> err_d(rt.p)
        Some(aliased) -> ok_d(rt.p, DType(is_pub, name, tparams, TBAlias(aliased), t.line, t.col, None))
      }
    }
  }
}

# Mirror of stage 0's looks_like_sum heuristic: scan ahead for `|` or
# for `Uppercase(` indicating a variant with payload.
fn looks_like_sum(p: Parser) : Bool {
  let hd = p_peek(p)
  let nxt = p_peek1(p)
  if is_upper_ident(p.src, hd) and tk_is(nxt.kind, TkLparen) { true }
  else { looks_like_sum_scan(p.rest, 0) }
}

fn looks_like_sum_scan(toks: [Token], depth: Int) : Bool {
  match toks {
    [] -> false
    [t, ...rs] -> {
      match t.kind {
        TkEof -> false
        TkLparen -> looks_like_sum_scan(rs, depth + 1)
        TkLbracket -> looks_like_sum_scan(rs, depth + 1)
        TkLbrace -> looks_like_sum_scan(rs, depth + 1)
        TkRparen -> looks_like_sum_scan(rs, depth - 1)
        TkRbracket -> looks_like_sum_scan(rs, depth - 1)
        TkRbrace -> looks_like_sum_scan(rs, depth - 1)
        TkPipe -> if depth == 0 { true } else { looks_like_sum_scan(rs, depth) }
        TkNewline -> if depth == 0 { looks_like_sum_after_nl(rs) }
                     else { looks_like_sum_scan(rs, depth) }
        _ -> looks_like_sum_scan(rs, depth)
      }
    }
  }
}

fn looks_like_sum_after_nl(toks: [Token]) : Bool {
  match toks {
    [] -> false
    [t, ...rs] -> {
      match t.kind {
        TkNewline -> looks_like_sum_after_nl(rs)
        TkPipe -> true
        _ -> false
      }
    }
  }
}

fn parse_record_body(p: Parser, acc: [FieldDecl], is_pub: Bool, name: String, tparams: [String], t: Token) : PDecl / Console {

  let p0 = p_skip_newlines(p)
  if p_at(p0, TkRbrace) {
    ok_d(p_advance(p0), DType(is_pub, name, tparams, TBRecord(list_reverse(acc)), t.line, t.col, None))
  } else {
    # Optional `priv` qualifier marks the field private to the
    # declaring module. Default visibility for record fields is
    # public (record fields are the value's representation, not
    # its API — the module is the unit of encapsulation in kaikai;
    # the record is the unit of representation). Marking `priv`
    # is the opt-out used when a field carries an invariant the
    # module wants to enforce — e.g. `Map.root: Tree` where `Tree`
    # is private to the `map` module.
    let field_is_pub = not tk_is(p_peek(p0).kind, TkPriv)
    let p_after_priv = if field_is_pub { p0 } else { p_advance(p0) }
    let ft = p_peek(p_after_priv)
    if not tk_is(ft.kind, TkIdent) {
      err_d(p_error(p_after_priv, ft, "expected field name in record type"))
    } else {
      let fname = tok_source(p_after_priv.src, ft)
      let p1 = p_advance(p_after_priv)
      if not p_at(p1, TkColon) {
        err_d(p_error_here(p1, "expected `:` after field name"))
      } else {
        let rt = parse_type(p_advance(p1))
        match rt.r {
          None -> err_d(rt.p)
          Some(ty) -> {
            let fd = FD(field_is_pub, fname, ty)
            let p2 = p_skip_newlines(rt.p)
            if p_at(p2, TkComma) {
              parse_record_body(p_skip_newlines(p_advance(p2)), [fd, ...acc], is_pub, name, tparams, t)
            } else if p_at(p2, TkRbrace) {
              ok_d(p_advance(p2), DType(is_pub, name, tparams, TBRecord(list_reverse([fd, ...acc])), t.line, t.col, None))
            } else {
              err_d(p_error_here(p2, "expected `,` or `}` in record type"))
            }
          }
        }
      }
    }
  }
}

# m7b #1a — closed effect-alias body. Caller has consumed the first
# label and the `+` separator; `acc` holds the labels parsed so far in
# reverse order. Subsequent labels must be uppercase idents separated
# by `+`. Validation that each label refers to a declared effect, plus
# cycle detection, is m7b #1c at resolve time.
fn parse_effect_alias_body(p: Parser, acc: [String], is_pub: Bool, name: String, tparams: [String], t: Token) : PDecl / Console {

  let hd = p_peek(p)
  if not tk_is(hd.kind, TkIdent) or not is_upper_ident(p.src, hd) {
    err_d(p_error(p, hd, "expected uppercase effect name in effect alias"))
  } else {
    let nm = tok_source(p.src, hd)
    let p1 = p_advance(p)
    let acc1 = [nm, ...acc]
    if p_at(p1, TkPlus) {
      parse_effect_alias_body(p_advance(p1), acc1, is_pub, name, tparams, t)
    } else {
      ok_d(p1, DType(is_pub, name, tparams, TBEffectAlias(list_reverse(acc1)), t.line, t.col, None))
    }
  }
}

fn parse_sum_body(p: Parser, acc: [Variant], is_pub: Bool, name: String, tparams: [String], t: Token) : PDecl / Console {

  let p0 = p_skip_newlines(p)
  let vt = p_peek(p0)
  if not tk_is(vt.kind, TkIdent) or not is_upper_ident(p0.src, vt) {
    err_d(p_error(p0, vt, "expected variant constructor name"))
  } else {
    let vname = tok_source(p0.src, vt)
    let p1 = p_advance(p0)
    let args_r =
      if p_at(p1, TkLparen) {
        parse_variant_args(p_skip_newlines(p_advance(p1)), [])
      } else {
        PVariantArgs { p: p1, r: Some([]) }
      }
    match args_r.r {
      None -> err_d(args_r.p)
      Some(vargs) -> {
        let vnode = Var(vname, vargs)
        let p2 = p_skip_newlines(args_r.p)
        if p_at(p2, TkPipe) {
          parse_sum_body(p_skip_newlines(p_advance(p2)), [vnode, ...acc], is_pub, name, tparams, t)
        } else {
          ok_d(p2, DType(is_pub, name, tparams, TBSum(list_reverse([vnode, ...acc])), t.line, t.col, None))
        }
      }
    }
  }
}

type PVariantArgs = { p: Parser, r: Option[[TypeExpr]] }

fn parse_variant_args(p: Parser, acc: [TypeExpr]) : PVariantArgs / Console {

  if p_at(p, TkRparen) { PVariantArgs { p: p_advance(p), r: Some(list_reverse(acc)) } }
  else {
    let r = parse_type(p)
    match r.r {
      None -> PVariantArgs { p: r.p, r: None }
      Some(ty) -> {
        let p1 = p_skip_newlines(r.p)
        if p_at(p1, TkComma) {
          parse_variant_args(p_skip_newlines(p_advance(p1)), [ty, ...acc])
        } else if p_at(p1, TkRparen) {
          PVariantArgs { p: p_advance(p1), r: Some(list_reverse([ty, ...acc])) }
        } else {
          PVariantArgs { p: p_error_here(p1, "expected `,` or `)` in variant payload"), r: None }
        }
      }
    }
  }
}

fn parse_test_decl(p: Parser, t: Token) : PDecl / Console {

  let desc_t = p_peek(p)
  if not tk_is(desc_t.kind, TkString) {
    err_d(p_error(p, desc_t, "expected string description after `test`"))
  } else {
    let desc_span = tok_source(p.src, desc_t)
    let p1 = p_skip_newlines(p_advance(p))
    if not p_at(p1, TkLbrace) {
      err_d(p_error_here(p1, "expected `{` for test body"))
    } else {
      let tb = p_peek(p1)
      let rb = parse_block(p1, tb)
      match rb.r {
        None -> err_d(rb.p)
        Some(body) -> ok_d(rb.p, DTest(desc_span, body, t.line, t.col))
      }
    }
  }
}

# bench v1 (issue #40): structural mirror of parse_test_decl. The
# runner times the body N=1000 times and reports mean ns/iter.
fn parse_bench_decl(p: Parser, t: Token) : PDecl / Console {

  let desc_t = p_peek(p)
  if not tk_is(desc_t.kind, TkString) {
    err_d(p_error(p, desc_t, "expected string description after `bench`"))
  } else {
    let desc_span = tok_source(p.src, desc_t)
    let p1 = p_skip_newlines(p_advance(p))
    if not p_at(p1, TkLbrace) {
      err_d(p_error_here(p1, "expected `{` for bench body"))
    } else {
      let tb = p_peek(p1)
      let rb = parse_block(p1, tb)
      match rb.r {
        None -> err_d(rb.p)
        Some(body) -> ok_d(rb.p, DBench(desc_span, body, t.line, t.col))
      }
    }
  }
}

# check v1 (issue #44): property-based test block.
# Syntax:
#   check "<description>" [with name: T, name: T, ...] { body }
# The body is evaluated KAI_CHECK_ITERS times (default 100). Each
# iteration generates random values for the `with`-clause params via
# arbitrary[T]() runtime helpers and runs the body. The body must
# produce a Bool — true means the property holds for that input,
# false records a counterexample and exits the check early. v1 only
# reports the counterexample that triggered the failure (no
# shrinking).
fn parse_check_with_params(p: Parser, acc: [Param]) : PParams / Console {

  let t = p_peek(p)
  if not tk_is(t.kind, TkIdent) {
    PParams { p: p_error(p, t, "expected parameter name in `with` clause"), r: None }
  } else {
    let name = tok_source(p.src, t)
    let p1 = p_advance(p)
    if not p_at(p1, TkColon) {
      PParams { p: p_error_here(p1, "expected `:` after `with` parameter name"), r: None }
    } else {
      let rt = parse_type(p_advance(p1))
      match rt.r {
        None -> PParams { p: rt.p, r: None }
        Some(ty) -> {
          let param = Param { pname: name, ptype: Some(ty), pline: t.line, pcol: t.col }
          let p2 = p_skip_newlines(rt.p)
          if p_at(p2, TkComma) {
            parse_check_with_params(p_skip_newlines(p_advance(p2)), [param, ...acc])
          } else {
            PParams { p: p2, r: Some(list_reverse([param, ...acc])) }
          }
        }
      }
    }
  }
}

fn parse_check_decl(p: Parser, t: Token) : PDecl / Console {

  let desc_t = p_peek(p)
  if not tk_is(desc_t.kind, TkString) {
    err_d(p_error(p, desc_t, "expected string description after `check`"))
  } else {
    let desc_span = tok_source(p.src, desc_t)
    let p1 = p_skip_newlines(p_advance(p))
    let pwith = if p_at(p1, TkWith) {
      parse_check_with_params(p_skip_newlines(p_advance(p1)), [])
    } else {
      PParams { p: p1, r: Some([]) }
    }
    match pwith.r {
      None -> err_d(pwith.p)
      Some(params) -> {
        let p2 = p_skip_newlines(pwith.p)
        if not p_at(p2, TkLbrace) {
          err_d(p_error_here(p2, "expected `{` for check body"))
        } else {
          let tb = p_peek(p2)
          let rb = parse_block(p2, tb)
          match rb.r {
            None -> err_d(rb.p)
            Some(body) -> ok_d(rb.p, DCheck(desc_span, params, body, t.line, t.col))
          }
        }
      }
    }
  }
}

fn parse_import_decl(p: Parser, t: Token) : PDecl / Console {

  # For stage 1 MVP, imports are structurally parsed but not resolved.
  # Accept: `import a.b.c`, `import a.b.c as X`, `import a.b.c.{f, g}`.
  # m7f §7: `import ?name` — dependency hole. Symbol-index resolver
  # runs after normal imports and reports candidates.
  let first = p_peek(p)
  if match first.kind { TkHoleName(_) -> true _ -> false } {
    let nm = match first.kind { TkHoleName(n) -> n _ -> "" }
    ok_d(p_advance(p), DImport(IkHole(nm), t.line, t.col))
  } else if tk_is(first.kind, TkHole) {
    err_d(p_error(p, first, "`import ?` requires a name; write `import ?some_symbol`"))
  } else if not tk_is(first.kind, TkIdent) {
    err_d(p_error(p, first, "expected module name after `import`"))
  } else {
    parse_import_path(p_advance(p), tok_source(p.src, first), t)
  }
}

fn parse_import_path(p: Parser, acc_path: String, t: Token) : PDecl / Console {

  if p_at(p, TkDot) {
    let p1 = p_advance(p)
    let nxt = p_peek(p1)
    if tk_is(nxt.kind, TkIdent) {
      let seg = tok_source(p1.src, nxt)
      parse_import_path(p_advance(p1), string_concat(string_concat(acc_path, "."), seg), t)
    } else if tk_is(nxt.kind, TkLbrace) {
      # Selective: `.{a, b}`
      parse_import_selectives(p_skip_newlines(p_advance(p1)), [], acc_path, t)
    } else {
      err_d(p_error_here(p1, "expected identifier or `{` after `.`"))
    }
  } else if p_at(p, TkAs) {
    let p1 = p_advance(p)
    let nxt = p_peek(p1)
    if not tk_is(nxt.kind, TkIdent) {
      err_d(p_error(p1, nxt, "expected alias name after `as`"))
    } else {
      let alias = tok_source(p1.src, nxt)
      ok_d(p_advance(p1), DImport(IkAlias(acc_path, alias), t.line, t.col))
    }
  } else {
    ok_d(p, DImport(IkPath(acc_path), t.line, t.col))
  }
}

fn parse_import_selectives(p: Parser, acc: [String], path: String, t: Token) : PDecl / Console {

  let p0 = p_skip_newlines(p)
  let nxt = p_peek(p0)
  if not tk_is(nxt.kind, TkIdent) {
    err_d(p_error(p0, nxt, "expected identifier in selective import"))
  } else {
    let name = tok_source(p0.src, nxt)
    let p1 = p_skip_newlines(p_advance(p0))
    if p_at(p1, TkComma) {
      parse_import_selectives(p_skip_newlines(p_advance(p1)), [name, ...acc], path, t)
    } else if p_at(p1, TkRbrace) {
      ok_d(p_advance(p1), DImport(IkSelective(path, list_reverse([name, ...acc])), t.line, t.col))
    } else {
      err_d(p_error_here(p1, "expected `,` or `}` in selective import"))
    }
  }
}

# ====================================================================
# program
# ====================================================================

fn parse_program_loop(p: Parser, acc: [Decl]) : PParser / Console {

  let p0 = p_skip_newlines(p)
  if p_at(p0, TkEof) {
    # m12.6.x #6: a parser that accumulated errors (e.g. via
    # check_pred_not_false in parse_contracts_loop) must not let
    # the driver claim success. Surface had_error as `decls: None`
    # so the entry point exits non-zero, even when every decl
    # parsed in shape.
    if p0.had_error { PParser { p: p0, decls: None } }
    else { PParser { p: p0, decls: Some(list_reverse(acc)) } }
  }
  else {
    let r = parse_decl(p0)
    match r.r {
      None -> PParser { p: r.p, decls: None }
      Some(d) -> parse_program_loop(r.p, [d, ...acc])
    }
  }
}

pub type PParser = { p: Parser, decls: Option[[Decl]] }

pub fn parse_program(file: String, src: String, toks: [Token]) : PParser / Console {

  parse_program_loop(parser_new(file, src, toks), [])
}

# tp_make: encode a type-param name with its kind. Moved here from
# main.kai with the parser (issue #677 phase 1h H2) — the parser is
# its only caller; the decoders (tp_kind_of / tp_strip_kind) stay in
# main.kai and read tp_unit_suffix from compiler/ast.kai.
fn tp_make(name: String, k: Kind) : String {
  match k {
    KType -> name
    KUnit -> string_concat(name, tp_unit_suffix())
  }
}
