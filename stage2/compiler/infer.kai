# compiler/infer.kai — kaikai's static-typing core: the HM type-scheme
# engine, substitution + unification (with unit-of-measure ops),
# bidirectional inference (`synth`/`check`), the per-module infer driver
# (`infer_program`, `typecheck_module`), the post-typing effect-coverage
# and field-privacy walkers, and the typed-AST diagnostic dumps
# (`--infer`, `--check`, `--holes`, `--holes-json`, `--effects-json`,
# `--dump-typed`, `--dump-intervals`, `--dump-last-use`, `--strict-holes`).
#
# The HM engine (`apply_ty`, `unify`, `instantiate`, `synth`,
# `InferState`, `Subst`, `TyEnv`, `HoleKind`) is PRIVATE to this module.

import compiler.util
import compiler.chars
import compiler.diag
import compiler.ast
import compiler.kinds
import compiler.kind_theory
import compiler.kind_semilattice
import compiler.kind_resolve
import compiler.intervals
import compiler.refinements
import compiler.parse
import compiler.resolve
import compiler.modules
import compiler.loop_lower
import compiler.desugar
import compiler.doc_attr
import compiler.native_prims
import compiler.infer_index
import compiler.lit_mint
import compiler.unit_walk
import compiler.pipe_fusion
import compiler.vec_surface
import compiler.fixed_vec_match

# ====================================================================
# Local mirrors of main.kai helpers (downward-glue rule, `inf_` prefix)
# ====================================================================
#
# Each mirrors a main.kai helper the typer body calls downward. The
# `inf_` prefix keeps the flat kaic1 bundle from minting duplicate C
# symbols against main's own copies. They depend only on already-
# imported symbols (AST types from compiler.ast, core string/list
# ops), so the mirrors are exact and carry no further coupling.

fn inf_alias_set_status(entries: [AEntry], name: String, status: AStatus) : [AEntry] {
  match entries {
    [] -> [AEnt(name, status)]
    [e, ...rest] -> match e {
      AEnt(en, es) ->
        if en == name { [AEnt(en, status), ...rest] }
        else { [AEnt(en, es), ...inf_alias_set_status(rest, name, status)] }
    }
  }
}


fn inf_alias_status(entries: [AEntry], name: String) : AStatus {
  match entries {
    [] -> AsTodo
    [e, ...rest] -> match e {
      AEnt(en, es) -> if en == name { es } else { inf_alias_status(rest, name) }
    }
  }
}


fn inf_all_clauses_extern_handler(cs: [HClause]) : Bool = match cs {
  []           -> true
  [c, ...rest] -> match c {
    HC(_, _, body, _, _) -> match inf_extern_handler_c_symbol(body) {
      None    -> false
      Some(_) -> inf_all_clauses_extern_handler(rest)
    }
  }
}

fn inf_cand_names_of(cands: [AliasCand]) : [String] {
  match cands {
    [] -> []
    [c, ...rest] -> match c {
      AC(n, _, _, _, _) -> [n, ...inf_cand_names_of(rest)]
    }
  }
}


fn inf_cand_pos(cands: [AliasCand], name: String) : AliasPos {
  match inf_find_alias_cand(cands, name) {
    None -> AliasPos { line: 0, col: 0 }
    Some(c) -> match c {
      AC(_, _, _, ln, co) -> AliasPos { line: ln, col: co }
    }
  }
}


fn inf_collect_alias_cands(decls: [Decl]) : [AliasCand] {
  match decls {
    [] -> []
    [d, ...rest] -> {
      let here = match d {
        DType(_, name, _, body, line, col, _, _) -> match body {
          TBEffectAlias(labels) -> [AC(name, labels, true, line, col)]
          TBAlias(ty) -> match ty.tkind {
            TyName(n, targs) ->
              if targs == [] { [AC(name, [n], false, line, col)] }
              else { [] }
            _ -> []
          }
          _ -> []
        }
        _ -> []
      }
      list_append(here, inf_collect_alias_cands(rest))
    }
  }
}


fn inf_collect_op_to_eff(decls: [Decl]) : [OpToEff] {
  match decls {
    [] -> []
    [d, ...rest] -> match d {
      DEffect(_, eff_name, _, ops, _, _, _, _) ->
        list_append(inf_ops_to_eff_pairs(eff_name, ops),
                    inf_collect_op_to_eff(rest))
      _ -> inf_collect_op_to_eff(rest)
    }
  }
}


fn inf_dedup_strs(xs: [String]) : [String] = inf_dedup_strs_loop(xs, [])

fn inf_dedup_strs_loop(xs: [String], acc: [String]) : [String] {
  match xs {
    [] -> list_reverse(acc)
    [x, ...rest] ->
      if list_has(acc, x) { inf_dedup_strs_loop(rest, acc) }
      else { inf_dedup_strs_loop(rest, [x, ...acc]) }
  }
}


fn inf_eff_has_op(eff_name: String, op_name: String, op_to_eff: [OpToEff]) : Bool {
  match op_to_eff {
    [] -> false
    [oe, ...rest] -> match oe {
      OEFP(o, e) ->
        if o == op_name and e == eff_name { true }
        else { inf_eff_has_op(eff_name, op_name, rest) }
    }
  }
}

# alias-aware op-call resolution lives inside
# `try_op_call` (typer) and `desugar_op_calls_callee` (emit) instead
# of as a standalone walker — a separate pre-pass blew the selfhost
# stack when traversing compiler.kai's deep AST. The helpers
# `inf_find_alias` / `inf_find_eff_for_alias_op` / `inf_eff_has_op` (defined
# above) are consulted at each call site.


fn inf_effect_default_block_all_extern(eff_name: String, decls: [Decl]) : Bool =
  match inf_find_effect_default_block(eff_name, decls) {
    None         -> false
    Some(defblk) -> match defblk {
      DBlk(clauses, _, _, _) -> inf_all_clauses_extern_handler(clauses)
    }
  }


fn inf_indent_of(depth: Int) : String {
  if depth == 0 { "" } else { string_concat("  ", inf_indent_of(depth - 1)) }
}

fn inf_emit_line(depth: Int, s: String) : Unit / Console = print("#{inf_indent_of(depth)}#{s}")


fn inf_extern_handler_c_symbol(body: Expr) : Option[String] =
  match body.kind {
    EIntrinsic(name, args_) ->
      if name == "extern_handler" {
        match args_ {
          [a] -> match a.kind {
            EStr(span, is_triple) ->
              if is_triple { None }
              else { Some(inf_strip_string_quotes(span)) }
            _ -> None
          }
          _ -> None
        }
      } else { None }
    _ -> None
  }

# Strip leading `"` and trailing `"` from a string-literal span and
# resolve the minimal escape set the C-identifier surface uses: `\"`
# survives only as a defensive case (no C identifier contains `"`),
# and no other escape is meaningful here. Returns "" if the span has
# no outer quotes (defensive against malformed AST).

fn inf_find_alias(aliases: [AliasResult], name: String) : Option[AliasResult] {
  match aliases {
    [] -> None
    [a, ...rest] -> match a {
      AR(n, _) -> if n == name { Some(a) } else { inf_find_alias(rest, name) }
    }
  }
}

# Substitute every alias name in `labels` with its expanded form.
# Effect names pass through unchanged. Duplicates introduced by
# expansion are removed by the caller.

fn inf_find_alias_cand(cands: [AliasCand], name: String) : Option[AliasCand] {
  match cands {
    [] -> None
    [c, ...rest] -> match c {
      AC(n, _, _, _, _) -> if n == name { Some(c) } else { inf_find_alias_cand(rest, name) }
    }
  }
}


fn inf_find_eff_for_alias_op(components: [String], op_to_eff: [OpToEff], op_name: String) : Option[String] {
  match components {
    [] -> None
    [c, ...rest] ->
      if inf_eff_has_op(c, op_name, op_to_eff) { Some(c) }
      else { inf_find_eff_for_alias_op(rest, op_to_eff, op_name) }
  }
}


fn inf_find_effect_default_block(eff_name: String, decls: [Decl]) : Option[DefaultBlock] {
  match decls {
    [] -> None
    [d, ...rest] -> match d {
      DEffect(_, n, _, _, defblk, _, _, _) ->
        if n == eff_name { defblk } else { inf_find_effect_default_block(eff_name, rest) }
      _ -> inf_find_effect_default_block(eff_name, rest)
    }
  }
}

# Op-level coverage walker.
#
# The typer's row-level checks (`check_body_row`, `check_main_row_handlable`)
# enforce that every effect label reached from a body is named by an
# enclosing `handle` or absorbed by `main`. They are blind to which
# specific op of an effect was performed, so a `handle ... with Log
# { info }` whose body invokes `Log.warn` compiles cleanly and
# segfaults at runtime (dispatch hits an unwired evidence slot).
#
# This walker closes the gap. For every directly-performed `Eff.op`
# call inside a `DFn` body it walks the lexical stack of enclosing
# handles. Discharge order:
#
#   1. Enclosing `handle ... with Eff { clauses }` lists `op` in its
#      clauses  → discharged.
#   2. Enclosing `handle ... with Eff` exists, `op` not in clauses,
#      but `Eff`'s `default { }` block declares `op` → discharged
#      (clause-merge from the spec).
#   3. No enclosing `handle ... with Eff`, the function is `main`,
#      and `Eff`'s `default { }` block declares `op` → discharged
#      (auto-installed at the program root).
#   4. Otherwise → "effect not handled: Eff.op" with notes naming
#      the default-block status so the user can decide between
#      adding a clause to the handle, growing the default block, or
#      wrapping the call site.
#
# Scope: only direct `Eff.op(...)` invocations are checked (the
# `ECall(EVar("Eff.op"), _)` shape produced by `synth_op_call_with_scheme`).
# Cross-function reachability is out of scope for Stage B; the row-
# level check still propagates labels through helper signatures and
# bites where they bubble up.

fn inf_finish_iscan_rev(span: String, end: Int, st: IScan) : [IPart] {
  if st.lit_start < end {
    let piece = string_slice(span, st.lit_start, end - st.lit_start)
    [IpLit(piece, inf_raw_lit_for_c(piece)), ...st.parts]
  } else {
    st.parts
  }
}


# Emit an LLVM global string constant and return both the textual
# declaration and the total byte count (including null terminator),
# so callers can size their `getelementptr` with the same N the
# declaration uses.

fn inf_iscan_collect(span: String, end: Int, st: IScan) : [IPart] =
  list_reverse(inf_iscan_collect_rev(span, end, st))


fn inf_iscan_collect_rev(span: String, end: Int, st: IScan) : [IPart] {
  if st.i >= end { inf_finish_iscan_rev(span, end, st) }
  else {
    match char_at(span, st.i) {
      None -> inf_finish_iscan_rev(span, end, st)
      Some(c) -> {
        let nxt = match char_at(span, st.i + 1) { Some(c2) -> c2 None -> ' ' }
        if c == '#' and nxt == '{' and st.i + 1 < end {
          let with_lit =
            if st.i > st.lit_start {
              let piece = string_slice(span, st.lit_start, st.i - st.lit_start)
              [IpLit(piece, inf_raw_lit_for_c(piece)), ...st.parts]
            } else { st.parts }
          let expr_start = st.i + 2
          let expr_end = inf_iscan_expr_end(span, expr_start, end, 1)
          let expr_src = string_slice(span, expr_start, expr_end - expr_start)
          let new_parts = [IpExp(expr_src), ...with_lit]
          let next_i = if expr_end < end { expr_end + 1 } else { expr_end }
          inf_iscan_collect_rev(span, end, IScan { parts: new_parts, lit_start: next_i, i: next_i })
        } else {
          inf_iscan_collect_rev(span, end, IScan { parts: st.parts, lit_start: st.lit_start, i: st.i + 1 })
        }
      }
    }
  }
}


fn inf_iscan_expr_end(span: String, i: Int, end: Int, depth: Int) : Int {
  if depth == 0 or i >= end { i }
  else {
    match char_at(span, i) {
      None -> i
      Some(c) -> {
        match c {
          '{' -> inf_iscan_expr_end(span, i + 1, end, depth + 1)
          '}' -> {
            if depth == 1 { i }
            else { inf_iscan_expr_end(span, i + 1, end, depth - 1) }
          }
          _ -> inf_iscan_expr_end(span, i + 1, end, depth)
        }
      }
    }
  }
}


fn inf_join_with(xs: [String], sep: String) : String = string_join(xs, sep)

# ---- tables: user function arities, variant arities ----
#
# Stage 0 emit keeps parallel tables of user-defined function names and
# variant constructors; the ident dispatcher looks into both before
# falling back to a local. Stage 1 does the same; both tables are
# lists of sum-variant pairs.

# EFn now carries the decl's module of origin. None for
# decls authored in the root file; Some(m) for decls imported from
# module `m` (or pulled in via --core, see expand_imports +
# load_core). Codegen reads the field to mint `kai_<m>__<name>`
# vs `kai_<name>`, and to disambiguate two-modules-export-same-name
# at bare-name call sites.
#
# Unboxing: the fourth slot is the unboxed-
# signature classification. `None` means the classical
# `static KaiValue *kai_<name>(KaiValue *...)` calling convention.
# `Some(US([Ty], Ty))` means the fn was classified by `unbox_classify`
# as taking + returning raw C scalars (`int64_t` / `double` /
# `int` / `uint32_t`); the emitter mints a raw signature, EVar reads
# of the fn's parameters resolve to `kair_<name>`, and call sites
# emit raw arguments via `emit_expr_raw`. The classifier requires
# every param ty + return ty to be in {Int, Bool, Char, Real}
# (concretely; not parametric T), no FFI shim, no protocol-impl
# child, no effect row, no closure parameters. See
# `unbox_classify_decl`.

fn inf_last_use_for(nm: String, uses: [Use]) : LU =
  inf_last_use_for_loop(nm, uses, false, -1, -1)


fn inf_last_use_for_loop(nm: String, uses: [Use], blocked: Bool,
                     mx_line: Int, mx_col: Int) : LU {
  match uses {
    [] -> {
      if blocked { LUBlocked(nm) }
      else if mx_line < 0 { LUUnused(nm) }
      else { LUAt(nm, mx_line, mx_col) }
    }
    [h, ...rest] -> match h {
      U(uname, ln, cl, in_lam) -> {
        if uname == nm {
          if in_lam {
            inf_last_use_for_loop(nm, rest, true, mx_line, mx_col)
          } else if ln > mx_line or (ln == mx_line and cl > mx_col) {
            inf_last_use_for_loop(nm, rest, blocked, ln, cl)
          } else {
            inf_last_use_for_loop(nm, rest, blocked, mx_line, mx_col)
          }
        } else {
          inf_last_use_for_loop(nm, rest, blocked, mx_line, mx_col)
        }
      }
    }
  }
}

# ---- TCO — self-tail-call detection --------------------------------
#
# the Perceus exit-drop wrap places `kai_internal_drop(...)`
# calls *after* the body's tail expression, so neither gcc nor clang
# can fold a self-recursive call into `jmp` at the C level. The
# compiler-side fix rewrites self-tail-calls into a `goto`-loop with
# parameter rebinding; this walker is the recognition half.
#
# `tcrec_has_tail_self_call(body, nm, arity)` returns true if `body`
# contains at least one self-recursive call to a fn named `nm` with
# `arity` arguments in *tail position*. Tail position propagates
# through:
#   - EBlock(_, Some(tail))      — `tail` is tail
#   - EIf(_, then, opt_else)     — both branches are tail
#   - EMatch(_, arms)            — each arm body is tail
# It does NOT propagate through:
#   - ECall args / EBinop / EUnop / ERange / records / lists
#   - EBlock stmts (only the trailing expression is tail)
#   - EMatch scrutinee / EIf condition / match guards
#   - ELambda body (different fn — never tail of the enclosing fn)
#   - EPipe / EHandle (conservative; could be relaxed later)
#
# A locally-bound `let`/`var` shadowing `nm` disables the match
# inside its scope.

fn inf_mangle_ty(t: Ty) : String {
  match t {
    TyInt    -> "Int"
    TyReal   -> "Real"
    TyBool   -> "Bool"
    TyString -> "String"
    TyChar   -> "Char"
    TyUnit   -> "Unit"
    TyByte     -> "Byte"
    TyInt32    -> "Int32"
    TyUInt32   -> "UInt32"
    TyUInt64   -> "UInt64"
    TyInt128   -> "Int128"
    TyHandle   -> "Handle"
    TyListT(inner) -> concat_all(["L_", inf_mangle_ty(inner), "_E"])
    TyFnT(ps, ret, _) -> concat_all([
      "F_", inf_join_with(map(ps, inf_mangle_ty), "_"),
      "_R_", inf_mangle_ty(ret), "_E"
    ])
    TyCon(_, cname, tas) -> {
      match tas {
        [] -> cname
        [_h, ..._rest] -> concat_all([cname, "_O_",
                                    inf_join_with(map(tas, inf_mangle_ty), "_"),
                                    "_C"])
      }
    }
    TyVarT(_) -> "TVAR"
    # a resolved shape app is erased to its constructor before mangling;
    # an unresolved one signals a bug, flagged like `TVAR`.
    TyShapeApp(_, arg) -> concat_all(["SVAR_", inf_mangle_ty(arg)])
    TyAny     -> "Any"
    # units are erased at codegen time. The mangled name for a
    # dimensioned type is the same as its base type's mangle — so a
    # call like `f(1.0<USD>)` and a call `f(1.0)` mangle into the same
    # specialisation. This is the codegen-erasure invariant manifest
    # at the mangler level.
    TyDimT(base, _) -> inf_mangle_ty(base)
    # refinements erase like units. `Int where >= 0` and
    # `Int` mangle the same — they share monomorphisations and
    # protocol-impl dispatch entries.
    TyRefineT(base, _) -> inf_mangle_ty(base)
    # mangle a union as `U_<part1>_<part2>_..._E`
    # using the canonical component order. The leading `U_` and
    # trailing `_E` bracket the spec the same way `L_..._E` brackets
    # a list, so distinct unions never collide with each other or
    # with primitive mangles even when their component manglings
    # rearrange. The arm keeps the walker exhaustive without `_`
    # fallbacks that would mask future bugs.
    TyUnion(parts) -> concat_all(["U_",
                                  inf_join_with(map(parts, inf_mangle_ty), "_"),
                                  "_E"])
  }
}


fn inf_map_arm_exprs(a: Arm, f: (Expr) -> Expr) : Arm {
  match a {
    Arm(p, g, b) -> Arm(p, inf_map_opt_expr(g, f), f(b))
  }
}


fn inf_map_clause_exprs(c: HClause, f: (Expr) -> Expr) : HClause {
  match c {
    HC(n, ps, b, l, co) -> HC(n, ps, f(b), l, co)
  }
}


fn inf_map_elem_exprs(el: ListElem, f: (Expr) -> Expr) : ListElem {
  match el {
    ElPlain(x)  -> ElPlain(f(x))
    ElSpread(x) -> ElSpread(f(x))
  }
}


fn inf_map_expr_kind(k: ExprKind, f: (Expr) -> Expr) : ExprKind {
  match k {
    # Leaves: no sub-Expr to recurse into.
    EInt(_)        -> k
    EReal(_, _)       -> k
    EIntLit(_)        -> k
    EDecimalLit(_)    -> k
    EFixed(_, _)      -> k
    EBool(_)       -> k
    EChar(_)       -> k
    EStr(_, _)     -> k
    EUnit          -> k
    EVar(_)        -> k
    EUnder         -> k
    EPlaceholder   -> k
    EHole(_)       -> k
    ETodo(_)       -> k
    EExternBody(_) -> k
    # `EVariantsOf(TypeExpr, [String])` carries no sub-Expr (only a
    # TypeExpr and a resolved-names list, neither of which the
    # visitor traverses). Same shape as EHole/ETodo for the
    # purposes of the structural recursion.
    EVariantsOf(_, _) -> k
    # qualified module call carries no sub-Exprs
    # (both fields are plain Strings), so `f` has nothing to apply.
    EModCall(_, _) -> k
    # intrinsic args ARE sub-Exprs, so the visitor recurs.
    EIntrinsic(name, args_) -> EIntrinsic(name, map(args_, f))
    # Composites: apply f to every direct sub-Expr.
    ECall(callee, args_) -> ECall(f(callee), map(args_, f))
    EField(base, name)   -> EField(f(base), name)
    EIndex(a, b)         -> EIndex(f(a), f(b))
    EBinop(op, a, b)     -> EBinop(op, f(a), f(b))
    EUnop(op, x)         -> EUnop(op, f(x))
    EIf(c, t_, eo)       -> EIf(f(c), f(t_), inf_map_opt_expr(eo, f))
    EMatch(scr, arms)    -> EMatch(f(scr), map(arms, (a) => inf_map_arm_exprs(a, f)))
    ELambda(ps, b)       -> ELambda(ps, f(b))
    ERecordLit(name, fs) -> ERecordLit(name, map(fs, (fi) => inf_map_field_exprs(fi, f)))
    EList(els)           -> EList(map(els, (el) => inf_map_elem_exprs(el, f)))
    ERange(a, b, opt_step) -> ERange(f(a), f(b), inf_map_opt_expr(opt_step, f))
    EBlock(stmts, tail)  -> EBlock(map(stmts, (s) => inf_map_stmt_exprs(s, f)),
                                    inf_map_opt_expr(tail, f))
    EPipe(a, b)          -> EPipe(f(a), f(b))
    EMapPipe(a, b)       -> EMapPipe(f(a), f(b))
    EFlatMapPipe(a, b)   -> EFlatMapPipe(f(a), f(b))
    EFilterPipe(a, b)    -> EFilterPipe(f(a), f(b))
    EHandle(body, eff_name, eff_tyargs, init_opt, alias_opt, clauses, ret_opt) ->
      EHandle(f(body), eff_name, eff_tyargs,
              inf_map_opt_expr(init_opt, f), alias_opt,
              map(clauses, (c) => inf_map_clause_exprs(c, f)),
              inf_map_opt_return_exprs(ret_opt, f))
    ELitUnit(inner, u)   -> ELitUnit(f(inner), u)
    EBang(inner)         -> EBang(f(inner))
  }
}


fn inf_map_field_exprs(fi: FieldInit, f: (Expr) -> Expr) : FieldInit {
  match fi {
    FI(n, v) -> FI(n, f(v))
  }
}


fn inf_map_opt_expr(opt: Option[Expr], f: (Expr) -> Expr) : Option[Expr] {
  match opt {
    Some(e) -> Some(f(e))
    None    -> None
  }
}


fn inf_map_opt_return_exprs(opt: Option[HReturn], f: (Expr) -> Expr) : Option[HReturn] {
  match opt {
    Some(r) -> Some(inf_map_return_exprs(r, f))
    None    -> None
  }
}


fn inf_map_return_exprs(r: HReturn, f: (Expr) -> Expr) : HReturn {
  match r {
    HR(p, b, l, c) -> HR(p, f(b), l, c)
  }
}


fn inf_map_stmt_exprs(s: Stmt, f: (Expr) -> Expr) : Stmt {
  match s {
    SLet(p, ann, rhs)           -> SLet(p, ann, f(rhs))
    SAssert(c, m)               -> SAssert(f(c), inf_map_opt_expr(m, f))
    SExprStmt(x)                -> SExprStmt(f(x))
    SIndexAssign(b, i, v, l, c) -> SIndexAssign(f(b), f(i), f(v), l, c)
    SVar(n, ty, rhs, l, c)      -> SVar(n, ty, f(rhs), l, c)
    # SUse has no sub-expression — pass through unchanged.
    SUse(n, l, c)               -> SUse(n, l, c)
  }
}


fn inf_mo_eq(a: Option[String], b: Option[String]) : Bool {
  match a {
    None -> match b { None -> true _ -> false }
    Some(x) -> match b {
      Some(y) -> x == y
      None    -> false
    }
  }
}


fn inf_ops_to_eff_pairs(eff_name: String, ops: [EffectOp]) : [OpToEff] {
  match ops {
    [] -> []
    [op, ...rest] -> match op {
      EOp(op_name, _, _, _, _, _) ->
        [OEFP(op_name, eff_name), ...inf_ops_to_eff_pairs(eff_name, rest)]
    }
  }
}

# Returns Some(eff_name) if some component of the alias provides op_name.
# When multiple components share an op_name (currently impossible in
# the catalog — Stdout.print, Stderr.eprint, Stdin.read_line, etc., are
# disjoint), the leftmost component wins. The check is case-sensitive.

#[doc("The module name a root file contributes: its basename with any `.kai` suffix removed.")]
pub fn inf_core_module_name(path: String) : String {
  let total = string_length(path)
  let i = last_slash(path, total - 1)
  let after_slash = if i < 0 { path } else { string_slice(path, i + 1, total - i - 1) }
  let n = string_length(after_slash)
  if n > 4 and string_slice(after_slash, n - 4, 4) == ".kai" {
    string_slice(after_slash, 0, n - 4)
  } else { after_slash }
}

# Parse a core file and return its decl list paired with a
# ModuleEntry. On any error report to stderr and return None.
#
# every `DTest` / `DBench` / `DCheck` block authored in a
# core module file is dropped at load time (see `load_core` in
# driver.kai). Without that filter `kai test <user.kai>` would also run
# every stdlib test block — testing one file must never run another
# module's tests. The kaikai project's own intrinsic-test gate is
# unaffected: it passes the stdlib file as the *target* (which keeps
# its own test blocks intact through `compile_source`).

fn inf_prepend_rev_strs(xs: [String], acc: [String]) : [String] {
  match xs {
    [] -> acc
    [x, ...rest] -> inf_prepend_rev_strs(rest, [x, ...acc])
  }
}


fn inf_proto_dispatch_tag_prefix() : String = "__kai_proto_dispatch__:"


fn inf_proto_dispatcher_name(op: String) : String = concat_all(["__proto_", op])

# Register every DProtocol decl the program declares. The op list
# becomes the universe of "names that look like ordinary fn calls but
# really need protocol dispatch".
#
# Boundary tagging: thread `cur_mod` through the walk so
# each registered DProtocol records its home module. DProtocol carries
# no `module_origin` field of its own (only `DFn` does), so we recover
# the home by streaming through the same
# `decl_home_hint_reset` algorithm `validate_pub_access` uses. The
# result `proto_origins` table feeds `make_dispatcher_fn` so each
# synthesised dispatcher inherits the originating module's tag.

fn inf_raw_lit_for_c(piece: String) : String =
  cat3("\"", escape_str_body_for_c(piece), "\"")

# `st.parts` accumulates in REVERSE here for O(1) prepend; the public
# inf_iscan_collect entry point reverses once at the end.

fn inf_resolve_alias(name: String, cands: [AliasCand], cand_ns: [String],
                 eff_names: [String], file: String, st: AliasResolveState) : AliasResolveOne / Console + File {


  match inf_alias_status(st.entries, name) {
    AsDone(labels) -> AliasResolveOne { st: st, r: Some(labels) }
    AsFail -> AliasResolveOne { st: st, r: None }
    AsActive -> {
      let pos = inf_cand_pos(cands, name)
      diag_error(file, pos.line, pos.col,
        string_concat("cyclic effect alias: ", name))
      diag_note("an alias can only expand to declared effects, not back to itself")
      diag_help("break the cycle: list each effect explicitly in the body of `type #{name} = ...`")
      let st2 = AliasResolveState {
        entries: inf_alias_set_status(st.entries, name, AsFail),
        errs:    st.errs + 1
      }
      AliasResolveOne { st: st2, r: None }
    }
    AsTodo -> {
      match inf_find_alias_cand(cands, name) {
        None -> AliasResolveOne { st: st, r: None }
        Some(c) -> match c {
          AC(_, raw, explicit, line, col) -> {
            let entries1 = inf_alias_set_status(st.entries, name, AsActive)
            let st1 = AliasResolveState { entries: entries1, errs: st.errs }
            let r = inf_resolve_alias_labels(raw, cands, cand_ns, eff_names, file,
                                         name, explicit, line, col, st1, [])
            match r.r {
              None -> {
                let entries2 = inf_alias_set_status(r.st.entries, name, AsFail)
                AliasResolveOne { st: AliasResolveState { entries: entries2, errs: r.st.errs }, r: None }
              }
              Some(labels) -> {
                let unique = inf_dedup_strs(labels)
                let entries2 = inf_alias_set_status(r.st.entries, name, AsDone(unique))
                AliasResolveOne { st: AliasResolveState { entries: entries2, errs: r.st.errs }, r: Some(unique) }
              }
            }
          }
        }
      }
    }
  }
}


fn inf_resolve_alias_cands(cands: [AliasCand], eff_names: [String], file: String) : AliasResolution / Console + File {


  let cand_ns = inf_cand_names_of(cands)
  inf_resolve_alias_cands_loop(cands, cand_ns, eff_names, file,
                           AliasResolveState { entries: [], errs: 0 }, cands, [])
}


fn inf_resolve_alias_cands_loop(all_cands: [AliasCand], cand_ns: [String],
                            eff_names: [String], file: String,
                            st: AliasResolveState, todo: [AliasCand],
                            acc: [AliasResult]) : AliasResolution / Console + File {


  match todo {
    [] -> AliasResolution { aliases: list_reverse(acc), errs: st.errs }
    [c, ...rest] -> match c {
      # A name declared as a first-class `effect` is an effect, not an
      # alias: skip registering an alias entry for it so a row label
      # resolves to the effect.
      AC(name, _, _, _, _) ->
        if list_has(eff_names, name) {
          inf_resolve_alias_cands_loop(all_cands, cand_ns, eff_names, file, st, rest, acc)
        } else {
          let r = inf_resolve_alias(name, all_cands, cand_ns, eff_names, file, st)
          let acc1 = match r.r {
            Some(labels) -> [AR(name, labels), ...acc]
            None -> acc
          }
          inf_resolve_alias_cands_loop(all_cands, cand_ns, eff_names, file, r.st, rest, acc1)
        }
    }
  }
}


fn inf_resolve_alias_labels(raw: [String], cands: [AliasCand], cand_ns: [String],
                        eff_names: [String], file: String,
                        parent: String, explicit: Bool, pline: Int, pcol: Int,
                        st: AliasResolveState, acc: [String]) : AliasResolveOne / Console + File {


  match raw {
    [] -> AliasResolveOne { st: st, r: Some(list_reverse(acc)) }
    [label, ...rest] -> {
      if list_has(eff_names, label) {
        inf_resolve_alias_labels(rest, cands, cand_ns, eff_names, file, parent,
                             explicit, pline, pcol, st, [label, ...acc])
      } else if list_has(cand_ns, label) {
        let r = inf_resolve_alias(label, cands, cand_ns, eff_names, file, st)
        match r.r {
          None -> AliasResolveOne { st: r.st, r: None }
          Some(sub) ->
            inf_resolve_alias_labels(rest, cands, cand_ns, eff_names, file, parent,
                                 explicit, pline, pcol, r.st,
                                 inf_prepend_rev_strs(sub, acc))
        }
      } else {
        if explicit {
          diag_error(file, pline, pcol,
            concat_all(["unknown effect in alias body: ", label,
                        " (declared as part of `", parent, "`)"]))
          let st1 = AliasResolveState { entries: st.entries, errs: st.errs + 1 }
          AliasResolveOne { st: st1, r: None }
        } else {
          AliasResolveOne { st: st, r: None }
        }
      }
    }
  }
}


# True when `name` is a fixed-width boundary annotation. On the kaikai
# side such a value is a plain `Int` (or
# `Real` for the float `F32`) — the exact C width lives only at the
# boundary (the classifier reads the surface name; the shim casts at
# the call). Mapping here, not in the FFI classifier, is what lets
# `make_gray(64)` and `Color { r: 255 }` type-check.
fn is_ffi_fixed_name(name: String) : Bool =
  name == "U8" or name == "U16" or name == "U32" or name == "U64" or
  name == "I8" or name == "I16" or name == "I32" or name == "I64" or name == "F32"

# The honest 1.0 fixed-width value types (`Int32`/`UInt32`/`UInt64`/
# `Int128`), distinct from the legacy FFI annotations (`I32`/`U32`/...)
# which still map to Int. Centralised so every type-name resolver shares
# one source of truth. `fixed_width_ty_of_name` assumes the predicate
# held (mirrors `is_ffi_fixed_name` / `ffi_fixed_ty_of_name`).
#[doc("True when `name` is a fixed-width integer type name (Int32/UInt32/UInt64/Int128).")]
pub fn is_fixed_width_name(name: String) : Bool =
  name == "Int32" or name == "UInt32" or name == "UInt64" or name == "Int128"

#[doc("The fixed-width Ty for `name`; call only when `is_fixed_width_name` holds.")]
pub fn fixed_width_ty_of_name(name: String) : Ty =
  if name == "Int32" { TyInt32 }
  else if name == "UInt32" { TyUInt32 }
  else if name == "UInt64" { TyUInt64 }
  else { TyInt128 }

# The kaikai-side `Ty` of a fixed-width annotation: `Real` for `F32`,
# `Int` for every integer width. Only call when `is_ffi_fixed_name`.
fn ffi_fixed_ty_of_name(name: String) : Ty =
  if name == "F32" { TyReal } else { TyInt }

fn inf_resolve_ty(t: TypeExpr) : Ty {
  match t.tkind {
    TyName(name, targs) -> {
      if name == "Int" { TyInt }
      else if name == "Real" { TyReal }
      else if name == "Bool" { TyBool }
      else if name == "String" { TyString }
      else if name == "Char" { TyChar }
      else if name == "Unit" { TyUnit }
      else if name == "Byte" { TyByte }
      else if is_fixed_width_name(name) { fixed_width_ty_of_name(name) }
      # A fixed-width boundary annotation is an `Int` (or `Real` for
      # `F32`) on the kaikai side — it only carries its
      # exact C width at the FFI boundary (the classifier reads the
      # surface name). So literals and arithmetic unify normally; the
      # shim casts at the call. Mapping here, not in the FFI classifier,
      # is what lets `make_gray(64)` type-check. These legacy FFI
      # annotations keep their `Int`/`Real` kaikai-side mapping; the
      # new honest path is to write `Int32`/`UInt32`/`UInt64` directly.
      else if is_ffi_fixed_name(name) { ffi_fixed_ty_of_name(name) }
      # `Handle` is the surface name for the opaque LLVM
      # C-API scalar (`TyHandle`). Only the native backend writes it.
      else if name == "Handle" { TyHandle }
      # `Nothing` is the uninhabited type used by `Fail.fail`
      # (Doc B §`Fail`). The typer can't witness uninhabitedness, so
      # we treat it as TyAny — a call producing Nothing unifies with
      # any expected type, which is sound only because the default
      # handler aborts before any consumer of that "value" runs.
      else if name == "Nothing" { TyAny }
      else { TyCon(None, name, inf_resolve_ty_list(targs)) }
    }
    TyList(inner) -> TyListT(inf_resolve_ty(inner))
    TyFn(fps, fret, rexpr) -> TyFnT(inf_resolve_ty_list(fps), inf_resolve_ty(fret), inf_row_of_expr(rexpr))
    # dimensioned base type. The unit goes through unit_canon
    # (with empty alias and tparam contexts here) so two textually
    # different but algebraically equal forms compare equal under unify.
    TyDim(base, u) -> TyDimT(inf_resolve_ty(base), unit_canon(u))
    # preserve the refinement on the semantic side.
    # `TyRefineT(b, p)` ⊑ `b` in the unifier (upcast); narrowing
    # requires explicit `ensure(...)` or a match-arm `: RefinedT`.
    TyRefine(base, p) -> TyRefineT(inf_resolve_ty(base), p)
    # a compound row reaching *type* position (not dissolved
    # by alias substitution) — resolve to an undeclared name so the
    # natural "unknown type" cascade reports it.
    TyRow(_) -> TyCon(None, "__row_in_type_position__", [])
  }
}

# Convert a parsed RowExpr into its semantic Row. Label validation
# (each label refers to a declared effect) happens elsewhere; this
# routine focuses on the type-arg projection. Type args declared in
# row position are resolved against the *current* declaration's tparam
# list when one is supplied (`row_of_expr_with_tparams`); calls without
# tparam context (display, alias rewriting) drop the args.
#
# ROpen carries a row-variable name in tail position. This
# helper has no per-decl row-var binding context, so it returns a
# Row with a *placeholder* tail id (-1). Callers that need a proper
# row-var binding (fn_scheme_of_decl, infer_decl) use
# `inf_row_of_expr_with_rbinds` instead and pass a context built by
# `mk_rvbinds`. Diagnostics-only paths are fine with the placeholder.

fn inf_resolve_ty_list(ts: [TypeExpr]) : [Ty] = map(ts, inf_resolve_ty)

# Annotation resolution that honours the per-type row-kind table: a
# `T[..., e]` slot the type declares row-kind resolves to a row carrier
# so `let s : Stream[String, File + ReadFault]` unifies with the
# inferred carrier. Without the table this path can't tell `Console`
# (an effect) from a type in argument position, so it falls back to
# `inf_resolve_ty` for non-row-kind slots and types with no table entry.
fn inf_resolve_ty_rk(t: TypeExpr, table: [RowKindEntry]) : Ty {
  match t.tkind {
    TyName(name, targs) ->
      match row_kind_slots_of(table, name) {
        [] -> inf_resolve_ty(t)
        idxs -> TyCon(None, name, inf_resolve_args_rk(targs, idxs, 0, table))
      }
    TyList(inner) -> TyListT(inf_resolve_ty_rk(inner, table))
    _ -> inf_resolve_ty(t)
  }
}

fn inf_resolve_args_rk(targs: [TypeExpr], idxs: [Int], i: Int, table: [RowKindEntry]) : [Ty] {
  match targs {
    [] -> []
    [a, ...rest] -> {
      let resolved = if list_has_int(idxs, i) { inf_resolve_row_arg(a) }
                     else { inf_resolve_ty_rk(a, table) }
      [resolved, ...inf_resolve_args_rk(rest, idxs, i + 1, table)]
    }
  }
}

# A row-kind argument slot in an annotation: `Console`, `File + Fail`,
# or a bare row var. Resolves to a row carrier matching the inferred one.
fn inf_resolve_row_arg(a: TypeExpr) : Ty = match a.tkind {
  TyRow(rexpr) -> row_arg_carrier(inf_row_of_expr(rexpr))
  TyName(eff, []) -> row_arg_carrier(Row { labels: [Label { eff: eff, ty_args: [] }], tail: None, display_alias: None })
  _ -> inf_resolve_ty(a)
}


fn inf_row_empty() : Row = Row {
  labels:        [],
  tail:          None,
  display_alias: None
}


fn inf_row_labels_of_rls(ls: [RowLabel]) : [Label] {
  match ls {
    [] -> []
    [rl, ...rest] -> match rl {
      RL(name, ts) -> [
        Label { eff: name, ty_args: inf_resolve_ty_list(ts) },
        ...inf_row_labels_of_rls(rest)
      ]
    }
  }
}

# resolve a row label list under a tparam binding. Used at
# decl boundaries where the `Reader[T]` type arg refers to one of the
# function's own tparams. Falls back to the unparameterised
# `inf_row_labels_of_rls` for callers that lack a binding context.

fn inf_row_of_expr(re: RowExpr) : Row {
  inf_row_of_expr_with_rbinds(re, [])
}



fn inf_row_of_expr_with_rbinds(re: RowExpr, rbinds: [RVBind]) : Row {
  match re {
    REmpty -> inf_row_empty()
    RClosed(labels) -> Row {
      labels: inf_row_labels_of_rls(labels),
      tail: None,
      display_alias: None
    }
    ROpen(rv, labels) -> Row {
      labels: inf_row_labels_of_rls(labels),
      tail: match inf_rvbind_lookup(rbinds, rv) {
        Some(id) -> Some(id)
        None     -> Some(-1)
      },
      display_alias: None
    }
  }
}


fn inf_row_to_string_suffix(r: Row) : String {
  # a row with no labels is treated as "pure" in display
  # form, whether its tail is None (truly closed empty) or Some(_)
  # (a free row var with no demand on it — the phantom that
  # `fn_scheme_of_decl` inserts for REmpty signatures, or any fresh
  # row var introduced by instantiation and never constrained). The
  # tail variable is internal bookkeeping; showing `?eN` to users
  # mis-suggests they need to annotate the function. Diagnostics for
  # actual row mismatches still print the `expected` and `found`
  # rows in full (those rows carry labels by the time the mismatch
  # is reported).
  let body =
    if labels_empty(r.labels) {
      ""
    } else {
      let lbs = inf_join_with(map(r.labels, label_to_string), " + ")
      let tail_s = match r.tail {
        None -> ""
        Some(v) -> {
          let pre = if string_length(lbs) > 0 { " + " } else { "" }
          concat_all([pre, "?e", int_to_string(v)])
        }
      }
      concat_all([" / ", lbs, tail_s])
    }
  body
}

# Dump the declared signature (or shape) of every top-level decl. Used
# by `--types`; does not attempt to infer bodies, just surfaces what
# the user wrote.

fn inf_rvbind_lookup(binds: [RVBind], name: String) : Option[Int] {
  match binds {
    [] -> None
    [b, ...rest] -> match b {
      RVB(n, i) -> if n == name { Some(i) } else { inf_rvbind_lookup(rest, name) }
    }
  }
}


# Public entry: collect every `Use` in `e`, in source pre-order.
#
# The `_acc` workers below thread a reverse-order accumulator: each
# `EVar` is consed to the front (O(1)), children are visited left to
# right, and a single `list_reverse` at this entry point restores the
# observable pre-order. This replaces the former
# `list_append(left, list_append(...))` chaining, which copied the
# left list at every node — O(n^2) in AST size. The consumer
# `inf_last_use_for` is
# order-independent (max line/col wins, any in-lam ref blocks), so
# the reverse only preserves the diagnostic's stable output ordering.

fn inf_scan_uses_expr(e: Expr, in_lam: Bool) : [Use] / Console =

  list_reverse(inf_scan_uses_expr_acc(e, in_lam, []))


fn inf_scan_uses_expr_acc(e: Expr, in_lam: Bool, acc: [Use]) : [Use] / Console =

  inf_scan_uses_kind(e.kind, e.line, e.col, in_lam, acc)


fn inf_scan_uses_in_arms(arms: [Arm], in_lam: Bool, acc: [Use]) : [Use] / Console {

  match arms {
    [] -> acc
    [h, ...rest] -> match h {
      Arm(_, guard_opt, body) -> {
        let a1 = match guard_opt {
          None -> acc
          Some(g) -> inf_scan_uses_expr_acc(g, in_lam, acc)
        }
        let a2 = inf_scan_uses_expr_acc(body, in_lam, a1)
        inf_scan_uses_in_arms(rest, in_lam, a2)
      }
    }
  }
}


fn inf_scan_uses_in_clauses(cs: [HClause], in_lam: Bool, acc: [Use]) : [Use] / Console {

  match cs {
    [] -> acc
    [h, ...rest] -> match h {
      HC(_, _, body, _, _) ->
        inf_scan_uses_in_clauses(rest, in_lam,
                                 inf_scan_uses_expr_acc(body, in_lam, acc))
    }
  }
}

# Re-parse an `EStr` span to surface `#{expr}` interpolations and
# scan each parsed sub-expression for EVar refs. Mirrors `fv_interp`.

fn inf_scan_uses_in_exprs(es: [Expr], in_lam: Bool, acc: [Use]) : [Use] / Console {

  match es {
    [] -> acc
    [h, ...rest] ->
      inf_scan_uses_in_exprs(rest, in_lam,
                             inf_scan_uses_expr_acc(h, in_lam, acc))
  }
}


fn inf_scan_uses_in_field_inits(fis: [FieldInit], in_lam: Bool, acc: [Use]) : [Use] / Console {

  match fis {
    [] -> acc
    [h, ...rest] -> match h {
      FI(_, e) ->
        inf_scan_uses_in_field_inits(rest, in_lam,
                                     inf_scan_uses_expr_acc(e, in_lam, acc))
    }
  }
}


fn inf_scan_uses_in_interp(span: String, is_triple: Bool, in_lam: Bool, acc: [Use]) : [Use] / Console {

  let n = string_length(span)
  let body_start = if is_triple { 3 } else { 1 }
  let body_end = if is_triple { n - 3 } else { n - 1 }
  let parts = inf_iscan_collect(span, body_end,
                            IScan { parts: [], lit_start: body_start, i: body_start })
  inf_scan_uses_interp_parts(parts, in_lam, acc)
}


fn inf_scan_uses_in_list_elems(es: [ListElem], in_lam: Bool, acc: [Use]) : [Use] / Console {

  match es {
    [] -> acc
    [h, ...rest] -> {
      let inner = match h {
        ElPlain(e) -> e
        ElSpread(e) -> e
      }
      inf_scan_uses_in_list_elems(rest, in_lam,
                                  inf_scan_uses_expr_acc(inner, in_lam, acc))
    }
  }
}


fn inf_scan_uses_in_stmts(stmts: [Stmt], in_lam: Bool, acc: [Use]) : [Use] / Console {

  match stmts {
    [] -> acc
    [h, ...rest] -> {
      let a1 = match h {
        SLet(_, _, rhs) -> inf_scan_uses_expr_acc(rhs, in_lam, acc)
        SAssert(c, opt_msg) -> {
          let a = inf_scan_uses_expr_acc(c, in_lam, acc)
          match opt_msg {
            None -> a
            Some(e2) -> inf_scan_uses_expr_acc(e2, in_lam, a)
          }
        }
        SExprStmt(e) -> inf_scan_uses_expr_acc(e, in_lam, acc)
        SIndexAssign(arr, idx, val, _, _) -> {
          let a = inf_scan_uses_expr_acc(arr, in_lam, acc)
          let a2 = inf_scan_uses_expr_acc(idx, in_lam, a)
          inf_scan_uses_expr_acc(val, in_lam, a2)
        }
        SVar(_, _, init, _, _) -> inf_scan_uses_expr_acc(init, in_lam, acc)
        # SUse has no expression — no uses to scan.
        SUse(_, _, _) -> acc
      }
      inf_scan_uses_in_stmts(rest, in_lam, a1)
    }
  }
}


fn inf_scan_uses_interp_parts(parts: [IPart], in_lam: Bool, acc: [Use]) : [Use] / Console {

  match parts {
    [] -> acc
    [p, ...rest] -> match p {
      IpLit(_, _) -> inf_scan_uses_interp_parts(rest, in_lam, acc)
      IpExp(esrc) -> {
        let a1 = match parse_interp_expr(esrc) {
          Some(e) -> inf_scan_uses_expr_acc(e, in_lam, acc)
          None -> acc
        }
        inf_scan_uses_interp_parts(rest, in_lam, a1)
      }
    }
  }
}

# Find the last-use record for `nm` among `uses`. A single in-lambda
# reference forces `LUBlocked`; otherwise the max (line, col) wins.

fn inf_scan_uses_kind(k: ExprKind, line: Int, col: Int, in_lam: Bool, acc: [Use]) : [Use] / Console {

  match k {
    EVar(nm) -> [U(nm, line, col, in_lam), ...acc]
    # Interpolated strings hide EVar refs inside `#{...}` segments —
    # the lexer keeps the raw source span and emit re-parses at code
    # gen. Mirror `fv_interp` (5700-5725) so a binding read only via
    # interpolation never gets mis-classified as `LUUnused`.
    EStr(span, is_triple) -> inf_scan_uses_in_interp(span, is_triple, in_lam, acc)
    ECall(f, xs) -> inf_scan_uses_in_exprs(xs, in_lam,
                                           inf_scan_uses_expr_acc(f, in_lam, acc))
    EField(x, _) -> inf_scan_uses_expr_acc(x, in_lam, acc)
    EIndex(x, i) -> inf_scan_uses_expr_acc(i, in_lam,
                                           inf_scan_uses_expr_acc(x, in_lam, acc))
    EBinop(_, l, r) -> inf_scan_uses_expr_acc(r, in_lam,
                                              inf_scan_uses_expr_acc(l, in_lam, acc))
    EUnop(_, x) -> inf_scan_uses_expr_acc(x, in_lam, acc)
    EIf(c, t, opt_e) -> {
      let a1 = inf_scan_uses_expr_acc(t, in_lam, inf_scan_uses_expr_acc(c, in_lam, acc))
      match opt_e {
        None -> a1
        Some(e2) -> inf_scan_uses_expr_acc(e2, in_lam, a1)
      }
    }
    EMatch(s, arms) -> inf_scan_uses_in_arms(arms, in_lam,
                                             inf_scan_uses_expr_acc(s, in_lam, acc))
    ELambda(_, body) -> inf_scan_uses_expr_acc(body, true, acc)
    ERecordLit(_, fis) -> inf_scan_uses_in_field_inits(fis, in_lam, acc)
    EList(elems) -> inf_scan_uses_in_list_elems(elems, in_lam, acc)
    ERange(lo, hi, opt_by) -> {
      let a1 = inf_scan_uses_expr_acc(hi, in_lam, inf_scan_uses_expr_acc(lo, in_lam, acc))
      match opt_by {
        None -> a1
        Some(e2) -> inf_scan_uses_expr_acc(e2, in_lam, a1)
      }
    }
    EBlock(stmts, opt_tail) -> {
      let a1 = inf_scan_uses_in_stmts(stmts, in_lam, acc)
      match opt_tail {
        None -> a1
        Some(e2) -> inf_scan_uses_expr_acc(e2, in_lam, a1)
      }
    }
    EPipe(l, r) -> inf_scan_uses_expr_acc(r, in_lam,
                                          inf_scan_uses_expr_acc(l, in_lam, acc))
    EMapPipe(l, r) -> inf_scan_uses_expr_acc(r, in_lam,
                                             inf_scan_uses_expr_acc(l, in_lam, acc))
    EFlatMapPipe(l, r) -> inf_scan_uses_expr_acc(r, in_lam,
                                                 inf_scan_uses_expr_acc(l, in_lam, acc))
    EFilterPipe(l, r) -> inf_scan_uses_expr_acc(r, in_lam,
                                                inf_scan_uses_expr_acc(l, in_lam, acc))
    EHandle(body, _, _, init_opt, _, clauses, ret_opt) -> {
      let a1 = inf_scan_uses_expr_acc(body, in_lam, acc)
      let a2 = match init_opt {
        None -> a1
        Some(e2) -> inf_scan_uses_expr_acc(e2, in_lam, a1)
      }
      let a3 = inf_scan_uses_in_clauses(clauses, in_lam, a2)
      match ret_opt {
        None -> a3
        Some(hr) -> match hr {
          HR(_, body2, _, _) -> inf_scan_uses_expr_acc(body2, in_lam, a3)
        }
      }
    }
    _ -> acc
  }
}


fn inf_starts_with_loop(s: String, prefix: String, i: Int) : Bool {
  let pn = string_length(prefix)
  if i >= pn { true }
  else { match char_at(s, i) {
    None -> false
    Some(sc) -> match char_at(prefix, i) {
      None -> true
      Some(pc) -> if sc == pc { inf_starts_with_loop(s, prefix, i + 1) } else { false }
    }
  } }
}


# ====================================================================
# lift `"...#{x}..."` interpolation parts
# into the pre-inference AST so the typer + protocol-call rewrite see
# them. Without this the interp body is parsed at emit time and
# routed through the universal `kai_to_string` runtime, which
# bypasses any user-defined `impl Show for T`.
# ====================================================================
#
# Run only when the program declares `protocol Show` (the
# `op_names` list contains "show"); otherwise leave EStr nodes alone
# so files that just use `#{int_to_string(x)}` and never load the
# stdlib protocols continue to work via the legacy emit-time path.
#
# Lowering shape: a string `"prefix #{e1} mid #{e2} suffix"` becomes
#
#   string_concat_all(["prefix ", show(e1), " mid ", show(e2), " suffix"])
#
# Each interp body `e_i` is parsed using `parse_expr` (same parser
# the emitter used to call lazily) and then recursively desugared so
# nested interpolations also lift.


fn inf_string_starts_with_q(s: String, prefix: String) : Bool =
  inf_starts_with_loop(s, prefix, 0)


fn inf_strip_string_quotes(span: String) : String {
  let n = string_length(span)
  if n < 2 { "" }
  else {
    let first_q = match char_at(span, 0) { Some(c) -> c == '"' _ -> false }
    let last_q  = match char_at(span, n - 1) { Some(c) -> c == '"' _ -> false }
    if first_q and last_q { string_slice(span, 1, n - 2) }
    else { span }
  }
}


# assemble the full
# setup block for the builtins listed in `main`'s row. Push order
# Stdout → Stderr → Fail → Stdin → Env → File → Mutable → Cancel →
# Spawn matches Doc B §*Installation order*: Spawn innermost (last
# pushed, first looked up); Cancel the layer below it (root nursery
# flags fibers, Cancel handler unwinds); Mutable below Cancel (I/O
# cluster). `Console` acts as the alias `Stdout + Stderr`,
# so a row containing it triggers both setups.

fn inf_ty_eq(a: Ty, b: Ty) : Bool {
  match a {
    TyInt -> match b { TyInt -> true _ -> false }
    TyReal -> match b { TyReal -> true _ -> false }
    TyBool -> match b { TyBool -> true _ -> false }
    TyChar -> match b { TyChar -> true _ -> false }
    TyString -> match b { TyString -> true _ -> false }
    TyUnit -> match b { TyUnit -> true _ -> false }
    TyByte -> match b { TyByte -> true _ -> false }
    TyInt32 -> match b { TyInt32 -> true _ -> false }
    TyUInt32 -> match b { TyUInt32 -> true _ -> false }
    TyUInt64 -> match b { TyUInt64 -> true _ -> false }
    TyInt128 -> match b { TyInt128 -> true _ -> false }
    TyHandle -> match b { TyHandle -> true _ -> false }
    TyAny -> match b { TyAny -> true _ -> false }
    TyVarT(ai) -> match b { TyVarT(bi) -> ai == bi _ -> false }
    TyListT(ai) -> match b { TyListT(bi) -> inf_ty_eq(ai, bi) _ -> false }
    TyFnT(aps, ar, _) -> match b {
      TyFnT(bps, br, _) -> inf_ty_list_eq(aps, bps) and inf_ty_eq(ar, br)
      _ -> false
    }
    # Hanga Roa: structural equality respects module_origin too.
    # Used by the monomorphiser to key specialisations; without
    # this check, `tuple.Pair` and a user-defined `Pair` would
    # collapse to one mangled symbol.
    TyCon(am, an, atas) -> match b {
      TyCon(bm, bn, btas) -> module_slot_compat(am, bm) and an == bn and inf_ty_list_eq(atas, btas)
      _ -> false
    }
    TyDimT(ab, _) -> match b { TyDimT(bb, _) -> inf_ty_eq(ab, bb) _ -> false }
    TyRefineT(ab, _) -> match b { TyRefineT(bb, _) -> inf_ty_eq(ab, bb) _ -> false }
    TyShapeApp(asv, aa) -> match b {
      TyShapeApp(bsv, ba) -> asv == bsv and inf_ty_eq(aa, ba)
      _ -> false
    }
    # two unions are equal iff their canonical
    # component lists are point-wise equal. Callers that hand us a
    # `TyUnion` constructed via `normalize_union` get this for free;
    # any caller that bypasses normalisation falls through and is
    # rejected — that's the bug, not the equality check.
    TyUnion(aps) -> match b { TyUnion(bps) -> inf_ty_list_eq(aps, bps) _ -> false }
  }
}


# The element type a `|` / `||` / `|?` combinator feeds its function:
# the `A` of a list `[A]` or a head `T[A, ...]`. Used to thread the
# receiver type into a point-free section's lambda up front.
fn pipe_elem_ty(t: Ty) : Option[Ty] {
  match t {
    TyListT(e)       -> Some(e)
    TyCon(_, _, [a, ...]) -> Some(a)
    _                -> None
  }
}

# A point-free section the parser synthesised has a single
# `__pl`-named placeholder parameter. Recognise it so only those
# lambdas get the up-front receiver-threading — user-written lambdas
# keep the unchanged synth path.
fn is_point_free_lambda(rhs: Expr) : Bool =
  match rhs.kind {
    ELambda([p], _) -> p.pname == "__pl"
    _               -> false
  }

# Infer a pipe / combinator function argument. A point-free section
# gets its `__pl` receiver pinned to `lhs_ty`'s element type up front
# (so `.length()` resolves its UFCS dispatch); everything else takes
# the plain synth path unchanged.
fn synth_pipe_rhs(st: InferState, rhs: Expr, lhs_ty: Ty) : Inferred / Console + File + Mutable =
  if is_point_free_lambda(rhs) {
    match pipe_elem_ty(apply_ty(st.sub, lhs_ty)) {
      Some(et) -> match rhs.kind {
        ELambda(ps, body) ->
          synth_lambda_threaded(st, ps, body, Some(et), rhs.line, rhs.col)
        _ -> synth(st, rhs)
      }
      None -> synth(st, rhs)
    }
  } else { synth(st, rhs) }

fn inf_ty_head_name(t: Ty) : Option[String] {
  match t {
    TyInt          -> Some("Int")
    TyReal         -> Some("Real")
    TyBool         -> Some("Bool")
    TyChar         -> Some("Char")
    TyString       -> Some("String")
    TyUnit         -> Some("Unit")
    TyByte           -> Some("Byte")
    TyInt32          -> Some("Int32")
    TyUInt32         -> Some("UInt32")
    TyUInt64         -> Some("UInt64")
    TyInt128         -> Some("Int128")
    TyHandle         -> Some("Handle")
    TyListT(_)     -> Some("List")
    TyCon(_, name, _) -> Some(name)
    # a dimensioned value dispatches on the underlying base
    # type's head — `Decimal<USD>` → `Decimal`, mirroring the
    # `proto_type_name` collapse on the syntactic side.
    TyDimT(base, _) -> inf_ty_head_name(base)
    # refinements are transparent for protocol dispatch
    # — `Int where >= 0` and `Int` resolve to the same `impl`.
    TyRefineT(base, _) -> inf_ty_head_name(base)
    TyVarT(_)      -> None
    # an unresolved shape app has no concrete head — dispatch is post-mono.
    TyShapeApp(_, _) -> None
    TyFnT(_, _, _) -> None
    TyAny          -> None
    # a union has no single head type, so
    # protocol dispatch declines — the resolver forbids
    # `impl P for Union` declarations; here we just signal
    # "no canonical head" the same way TyVarT does so callers fall
    # back to the diagnostic path.
    TyUnion(_)     -> None
  }
}

# Walks the registry's impl table for a (protocol-op, type-name)
# match. The op-name search visits each impl entry's protocol's
# ops to find which protocol the op belongs to; we look
# the op up first to know `pname`, then iterate impls for a matching
# (pname, tname).

fn inf_ty_list_eq(a: [Ty], b: [Ty]) : Bool =
  match a {
    [] -> match b { [] -> true _ -> false }
    [ah, ...arest] -> match b {
      [] -> false
      [bh, ...brest] -> if inf_ty_eq(ah, bh) { inf_ty_list_eq(arest, brest) } else { false }
    }
  }


fn inf_ty_string_list(ts: [Ty]) : [String] = map(ts, inf_ty_to_string)


# Recognise the row-arg carrier (`TyFnT([], TyUnit, row)`) a `TyCon`
# slot uses to thread an effect row, so diagnostics show the slot as the
# row itself (`Stream[String, File + ReadFault]`) rather than the carrier
# function (`Stream[String, () -> Unit / File + ReadFault]`).
fn inf_row_carrier_of(t: Ty) : Option[Row] = match t {
  TyFnT(ps, ret, row) -> match ps {
    [] -> match ret { TyUnit -> Some(row) _ -> None }
    _  -> None
  }
  _ -> None
}

fn inf_tycon_arg_to_string(t: Ty) : String = match inf_row_carrier_of(t) {
  Some(row) -> if labels_empty(row.labels) { "_" } else { inf_join_with(map(row.labels, label_to_string), " + ") }
  None      -> inf_ty_to_string(t)
}

#[doc("Render a resolved Ty as its surface display string (with a non-empty effect row suffix). Shared by the typed-AST dumps and consumers like kai lint.")]
pub fn inf_ty_to_string(t: Ty) : String {
  match t {
    TyInt    -> "Int"
    TyReal   -> "Real"
    TyBool   -> "Bool"
    TyString -> "String"
    TyChar   -> "Char"
    TyUnit   -> "Unit"
    TyByte     -> "Byte"
    TyInt32    -> "Int32"
    TyUInt32   -> "UInt32"
    TyUInt64   -> "UInt64"
    TyInt128   -> "Int128"
    TyHandle   -> "Handle"
    TyListT(inner) -> cat3("[", inf_ty_to_string(inner), "]")
    # render the function type's effect row alongside the
    # arrow when non-empty, with each label printed as `Eff` or
    # `Eff[T1, T2]` so parametric-effect mismatches (Reader[Int] vs
    # Reader[String]) are visible in `expected/found` notes.
    TyFnT(ps, ret, row) -> concat_all([
      "(", inf_join_with(inf_ty_string_list(ps), ", "), ") -> ",
      inf_ty_to_string(ret),
      inf_row_to_string_suffix(row)
    ])
    TyCon(_, cname, tas) -> {
      match tas {
        [] -> cname
        _ -> concat_all([cname, "[", inf_join_with(map(tas, inf_tycon_arg_to_string), ", "), "]"])
      }
    }
    TyVarT(n) -> cat2("?t", int_to_string(n))
    # a still-unresolved shape application prints as `?sN[Arg]`.
    TyShapeApp(sv, arg) -> concat_all(["?s", int_to_string(sv), "[", inf_ty_to_string(arg), "]"])
    TyAny -> "?"
    # render dimensioned base types as `Real<u>` / `Int<u>`.
    # The unit goes through unit_canon so the printed form matches
    # what the unifier compares against — same shape on every side.
    TyDimT(base, u) -> concat_all([inf_ty_to_string(base), "<", inf_unit_canon_display(u), ">"])
    # render `T where ...` for diagnostics. The predicate
    # is left as `<pred>` to keep the line short.
    TyRefineT(base, _) -> concat_all([inf_ty_to_string(base), " where <pred>"])
    # render unions inline as `A | B | C` to match
    # surface syntax. Components are already in canonical order when
    # the walker receives them via `normalize_union`.
    TyUnion(parts) -> inf_join_with(map(parts, inf_ty_to_string), " | ")
  }
}

# render a UnitExprT in canonical form for diagnostics. Sorts
# symbols alphabetically and groups powers, so `kg * m` and `m * kg`
# render identically.

fn inf_type_expr_display(t: TypeExpr) : String {
  match t.tkind {
    TyName(name, []) -> name
    TyName(name, ts) -> concat_all([name, "[", inf_join_with(map(ts, inf_type_expr_display), ", "), "]"])
    TyList(inner) -> concat_all(["[", inf_type_expr_display(inner), "]"])
    TyFn(ps, ret, _) -> concat_all([
      "(", inf_join_with(map(ps, inf_type_expr_display), ", "), ") -> ", inf_type_expr_display(ret)
    ])
    TyDim(base, u) -> concat_all([inf_type_expr_display(base), "<", inf_unit_expr_display(u), ">"])
    TyRefine(base, _) -> concat_all([inf_type_expr_display(base), " where <pred>"])
    # compound row as a type argument — render bare labels.
    TyRow(row) -> inf_row_expr_display(row)
  }
}

# render a row's labels/tail as a bare `A + B + tail`
# string — the shape a compound row takes inside a `[...]` type
# argument list.
fn inf_row_expr_display(r: RowExpr) : String {
  match r {
    REmpty -> ""
    RClosed(labels) -> inf_row_labels_display(labels)
    ROpen(tail, labels) ->
      if labels == [] { tail }
      else { concat_all([inf_row_labels_display(labels), " + ", tail]) }
  }
}

fn inf_row_labels_display(ls: [RowLabel]) : String {
  match ls {
    [] -> ""
    [RL(n, _)] -> n
    [RL(n, _), ...rest] -> concat_all([n, " + ", inf_row_labels_display(rest)])
  }
}

# render a UnitExprT as user-readable text. The display is *not*
# the canonical form (which lives as Map[Sym,Int]); it's the tree shape
# the parser produced, with light cleanup. Use inf_unit_canon_display for
# canonical output.
#
# Style: scientific notation. Multiplication renders as a single space
# (`kg m`), division renders with `/` and no surrounding spaces
# (`m/s`, `kg m/s^2`). Powers use `^` with the integer literal
# (`m^2`, `s^-1`). `UOne` factors are dropped.

fn inf_unit_canon_display(u: UnitExprT) : String = inf_unit_expr_display(unit_canon(u))

# extract the canonical unit symbol
# of a dimensioned type for the `unit_name` compile-time intrinsic.
# Bare types and unresolved unit-vars yield the empty string so the
# emitter never produces an LLVM/C error from a missing dimension.

fn inf_unit_eq(a: UnitExprT, b: UnitExprT) : Bool {
  let ca = unit_canon(a)
  let cb = unit_canon(b)
  inf_unit_expr_display(ca) == inf_unit_expr_display(cb)
}

# `inf_ty_eq` is a structural equality on resolved types. Conservative:
# `TyVarT` only matches itself by id; refinements / units erase at
# the type level (units distinguished separately in MonoTuple's
# `[UnitExprT]` field, refinements stay erased per Tier 1's
# value-only refinement semantics).

fn inf_unit_expr_display(u: UnitExprT) : String {
  match u {
    UOne -> "1"
    USym(s) -> kind_sym_bare(s)
    UMul(a, b) -> match b {
      UInv(b_inner) -> match a {
        UOne -> concat_all(["1/", inf_unit_expr_display(b_inner)])
        _    -> concat_all([inf_unit_expr_display(a), "/", inf_unit_expr_display(b_inner)])
      }
      UOne -> inf_unit_expr_display(a)
      _ -> match a {
        UOne -> inf_unit_expr_display(b)
        UInv(a_inner) -> concat_all([inf_unit_expr_display(b), "/", inf_unit_expr_display(a_inner)])
        _ -> concat_all([inf_unit_expr_display(a), " ", inf_unit_expr_display(b)])
      }
    }
    UInv(a) -> concat_all(["1/", inf_unit_expr_display(a)])
    UPow(a, n) -> concat_all([inf_unit_expr_display(a), "^", int_to_string(n)])
    UJoin(a, b) -> concat_all([inf_unit_expr_display(a), " + ", inf_unit_expr_display(b)])
    UVar(n) -> cat2("?u", int_to_string(n))
    UDims(us) -> inf_unit_display_list(us)
  }
}

fn inf_unit_display_list(us: [UnitExprT]) : String = match us {
  [] -> ""
  [u] -> inf_unit_expr_display(u)
  [u, ...rest] -> concat_all([inf_unit_expr_display(u), ", ", inf_unit_display_list(rest)])
}

# Extract just the eff names from a row's labels — useful for the
# many string-based passes in the resolver that don't need the type
# args. Parametric effects are projected to their bare name (so
# `Reader[Int]` and `Reader[String]` both yield `Reader`); callers
# that need to distinguish instantiations work on the full label list.

# ====================================================================
# Shared typer/effect types (AliasCand, AliasResolution, HandleFrame,
# Use, IPart, IScan, OpToEff, FieldDeclWithHome, ...). Both main and
# infer use them, so they live here (pub) and main imports them
# downward — no lateral arrow, no upward reference.
# ====================================================================

#[doc("infer: `IPart` — typer/effect support type.")]
pub type IPart = IpLit(String, String) | IpExp(String)   # lit: body_slice, raw_literal; exp: body_slice


#[doc("infer: `IScan` — typer/effect support type.")]
pub type IScan = { parts: [IPart], lit_start: Int, i: Int }

# triple-quote bodies may carry literal newlines / tabs /
# unescaped `"`; emitting the raw slice produces invalid C. The lit
# pieces between `#{...}` boundaries are routed through the same
# `escape_str_body_for_c` helper as the non-interp fast path. For a
# regular string the helper is identity, so behavior is unchanged.

#[doc("infer: `OpToEff` — typer/effect support type.")]
pub type OpToEff = OEFP(String, String)


#[doc("infer: `label_to_rl_zero` — typer/effect support type.")]
pub fn label_to_rl_zero(lab: Label) : RowLabel = RL(lab.eff, [])

# walk a typed Expr collecting effect labels from
# every call site's callee type. Used only on `main`'s body to fix
# the footgun where every `Stdout.print` reached only via helpers
# left `inferred_main_row` empty, the wrapper installed no default
# handlers, and the program SIGSEGV'd. Caller-side effect tracking
# during typing is intentionally direct-only (the body-row
# enforcement lives there); this walk is a separate, post-typing pass that
# reads the *callee's* declared row out of its resolved Expr.ty so
# nothing changes for non-main inference. ELambda is *not* recursed
# into — a lambda's body effects only run when the lambda is
# invoked, and that invocation appears as its own ECall whose
# callee row already carries those effects (the row var was
# unified with the lambda's row at the call site).

#[doc("infer: `HandleFrame` — typer/effect support type.")]
pub type HandleFrame = HF(String, [String], [String], Int, Int)

# Two-list signature so the per-module body walk (first arg) can still
# iterate this pass's DFns while effect-existence lookups (second arg)
# consult the whole program. Hanga Roa's module partition can place
# `effect MyLog { ... }` and the `fn main()` that performs `MyLog.warn`
# in different per-module passes — even when both live in the same
# source file — so a single-list lookup misses the DEffect and the
# walker exits silently on every cross-pass op call.

#[doc("infer: `FieldDeclWithHome` — typer/effect support type.")]
pub type FieldDeclWithHome = FDH(FieldDecl, Option[String])


#[doc("infer: `AliasCand` — typer/effect support type.")]
pub type AliasCand = AC(String, [String], Bool, Int, Int)

# AliasResult: a candidate that resolved to a flat label list.

#[doc("infer: `AliasResult` — typer/effect support type.")]
pub type AliasResult = AR(String, [String])

# DFS expansion status for an alias name.

#[doc("infer: `AStatus` — typer/effect support type.")]
pub type AStatus = AsTodo | AsActive | AsDone([String]) | AsFail


#[doc("infer: `AEntry` — typer/effect support type.")]
pub type AEntry = AEnt(String, AStatus)


#[doc("infer: `AliasResolveState` — typer/effect support type.")]
pub type AliasResolveState = { entries: [AEntry], errs: Int }

#[doc("infer: `AliasResolveOne` — typer/effect support type.")]
pub type AliasResolveOne   = { st: AliasResolveState, r: Option[[String]] }

#[doc("infer: `AliasPos` — typer/effect support type.")]
pub type AliasPos     = { line: Int, col: Int }


#[doc("infer: `AliasResolution` — typer/effect support type.")]
pub type AliasResolution = { aliases: [AliasResult], errs: Int }


#[doc("infer: `Use` — typer/effect support type.")]
pub type Use = U(String, Int, Int, Bool)   # name, line, col, in_lambda


#[doc("infer: `LU` — typer/effect support type.")]
pub type LU
  = LUAt(String, Int, Int)             # last-use position
  | LUBlocked(String)                  # closure capture blocks last
  | LUUnused(String)                   # never referenced

# Walker entry: collect every EVar in `e`. The flag is true while we
# are inside any enclosing ELambda body; closure capture detection
# is conservative — a single in-lambda ref to a name blocks last for
# that name regardless of how far up the lambda is nested.


# ====================================================================
# Moved-in effect-coverage / field-privacy / call-label / edition
# helper families (sole external caller is the infer driver below)
# ====================================================================

fn inferred_main_row(performed: [Label]) : RowExpr {
  match performed {
    [] -> REmpty
    _  -> RClosed(map(performed, label_to_rl_zero))
  }
}


fn collect_call_labels(e: Expr, acc: [Label]) : [Label] = match e.kind {
  EInt(_)             -> acc
  EReal(_, _)            -> acc
  EIntLit(_)            -> acc
  EDecimalLit(_)        -> acc
  EFixed(_, _)          -> acc
  EBool(_)            -> acc
  EChar(_)            -> acc
  EStr(_, _)          -> acc
  EUnit               -> acc
  EVar(_)             -> acc
  EUnder              -> acc
  EPlaceholder        -> acc
  EHole(_)            -> acc
  ETodo(_)            -> acc
  EExternBody(_)      -> acc
  EVariantsOf(_, _)   -> acc
  EModCall(_, _)      -> acc
  EIntrinsic(_, args_) -> collect_call_labels_list(args_, acc)
  ECall(callee, args_) -> {
    let acc1 = match callee.ty {
      Some(t) -> match t {
        TyFnT(_, _, row) -> append_labels(row.labels, acc)
        _                -> acc
      }
      None    -> acc
    }
    collect_call_labels_list(args_, collect_call_labels(callee, acc1))
  }
  EField(base, _)     -> collect_call_labels(base, acc)
  EIndex(a, b)        -> collect_call_labels(b, collect_call_labels(a, acc))
  EBinop(_, a, b)     -> collect_call_labels(b, collect_call_labels(a, acc))
  EUnop(_, x)         -> collect_call_labels(x, acc)
  EIf(c, t, eo)       -> {
    let a1 = collect_call_labels(t, collect_call_labels(c, acc))
    match eo { Some(b) -> collect_call_labels(b, a1) None -> a1 }
  }
  EMatch(scr, arms)   -> collect_call_labels_arms(arms, collect_call_labels(scr, acc))
  ELambda(_, _)       -> acc
  ERecordLit(_, fs)   -> collect_call_labels_fields(fs, acc)
  EList(els)          -> collect_call_labels_elems(els, acc)
  ERange(a, b, opt)   -> {
    let a1 = collect_call_labels(b, collect_call_labels(a, acc))
    match opt { Some(s) -> collect_call_labels(s, a1) None -> a1 }
  }
  EBlock(stmts, tail) -> {
    let a1 = collect_call_labels_stmts(stmts, acc)
    match tail { Some(t) -> collect_call_labels(t, a1) None -> a1 }
  }
  EPipe(a, b)         -> collect_pipe_labels(b, collect_call_labels(b, collect_call_labels(a, acc)))
  EMapPipe(a, b)      -> collect_call_labels(b, collect_call_labels(a, acc))
  EFlatMapPipe(a, b)  -> collect_call_labels(b, collect_call_labels(a, acc))
  EFilterPipe(a, b)   -> collect_call_labels(b, collect_call_labels(a, acc))
  EBang(inner)        -> collect_call_labels(inner, acc)
  ELitUnit(inner, _)  -> collect_call_labels(inner, acc)
  EHandle(body, _, _, init_opt, _, clauses, ret_opt) -> {
    let a1 = collect_call_labels(body, acc)
    let a2 = match init_opt { Some(i) -> collect_call_labels(i, a1) None -> a1 }
    let a3 = collect_call_labels_clauses(clauses, a2)
    match ret_opt {
      Some(r) -> match r { HR(_, b, _, _) -> collect_call_labels(b, a3) }
      None    -> a3
    }
  }
}

# The pipe `x |> f` APPLIES `f`, so its effect is `f`'s row. When the
# rhs is a bare function reference (`|> run`), the operand node carries
# `TyFnT(_, _, row)` and the plain `collect_call_labels` EVar arm sees no
# call to read — the applied row would be lost from `main`'s inferred row.
# Read it here. A rhs that is itself a call (`|> f(y)`) carries its return
# type (not `TyFnT`), so this is inert and the inner ECall arm supplies the
# row instead.
fn collect_pipe_labels(b: Expr, acc: [Label]) : [Label] = match b.ty {
  Some(t) -> match t {
    TyFnT(_, _, row) -> append_labels(row.labels, acc)
    _                -> acc
  }
  None    -> acc
}


fn collect_call_labels_list(es: [Expr], acc: [Label]) : [Label] = match es {
  []           -> acc
  [h, ...rest] -> collect_call_labels_list(rest, collect_call_labels(h, acc))
}


fn collect_call_labels_arms(arms: [Arm], acc: [Label]) : [Label] = match arms {
  []           -> acc
  [a, ...rest] -> match a {
    Arm(_, opt_guard, body) -> {
      let a1 = match opt_guard { Some(g) -> collect_call_labels(g, acc) None -> acc }
      collect_call_labels_arms(rest, collect_call_labels(body, a1))
    }
  }
}


fn collect_call_labels_fields(fs: [FieldInit], acc: [Label]) : [Label] = match fs {
  []           -> acc
  [f, ...rest] -> match f {
    FI(_, e) -> collect_call_labels_fields(rest, collect_call_labels(e, acc))
  }
}


fn collect_call_labels_elems(els: [ListElem], acc: [Label]) : [Label] = match els {
  []           -> acc
  [el, ...rest] -> match el {
    ElPlain(e)  -> collect_call_labels_elems(rest, collect_call_labels(e, acc))
    ElSpread(e) -> collect_call_labels_elems(rest, collect_call_labels(e, acc))
  }
}


fn collect_call_labels_stmts(ss: [Stmt], acc: [Label]) : [Label] = match ss {
  []           -> acc
  [s, ...rest] -> match s {
    SLet(_, _, e)        -> collect_call_labels_stmts(rest, collect_call_labels(e, acc))
    SVar(_, _, e, _, _)  -> collect_call_labels_stmts(rest, collect_call_labels(e, acc))
    SAssert(e, og)       -> {
      let a1 = collect_call_labels(e, acc)
      let a2 = match og { Some(g) -> collect_call_labels(g, a1) None -> a1 }
      collect_call_labels_stmts(rest, a2)
    }
    SExprStmt(e)         -> collect_call_labels_stmts(rest, collect_call_labels(e, acc))
    SIndexAssign(a, b, c, _, _) -> {
      let a1 = collect_call_labels(c, collect_call_labels(b, collect_call_labels(a, acc)))
      collect_call_labels_stmts(rest, a1)
    }
    SUse(_, _, _)        -> collect_call_labels_stmts(rest, acc)
  }
}


fn collect_call_labels_clauses(cs: [HClause], acc: [Label]) : [Label] = match cs {
  []           -> acc
  [c, ...rest] -> match c {
    HC(_, _, body, _, _) -> collect_call_labels_clauses(rest, collect_call_labels(body, acc))
  }
}

# Append `xs` onto `acc`, skipping labels already present by `eff`
# name (caller's own dedup via `st_add_label` is structural; we use
# the simpler eff-name dedup here because all builtin handlers are
# non-parametric — `inferred_main_row` would drop the ty_args anyway).

fn append_labels(xs: [Label], acc: [Label]) : [Label] = match xs {
  []           -> acc
  [h, ...rest] -> if eff_already_in(acc, h.eff) {
    append_labels(rest, acc)
  } else {
    append_labels(rest, [h, ...acc])
  }
}


fn eff_already_in(acc: [Label], eff: String) : Bool = match acc {
  []           -> false
  [l, ...rest] -> if l.eff == eff { true } else { eff_already_in(rest, eff) }
}

# extract the row labels declared on `fn main`. A row of
# `REmpty` returns []; `RClosed([Console, Fail])` returns those
# labels. The wrapper installs default handlers only for the
# subset of these that match a builtin effect. When
# `main` has no declared row, the typer's
# `inferred_main_row` already populated this with the body's
# builtins, so this function reads back the same labels it would
# have read from an explicit annotation.

fn check_default_coverage(file: String, mod_decls: [Decl], all_decls: [Decl]) : Int / Console + File {
  # Precompute the `eff_name -> default ops` table once over `all_decls`,
  # then thread it through every per-DFn body walk so each `EHandle`
  # resolves its effect's default ops by assoc-list lookup instead of
  # re-scanning all declarations.
  let eff_map = build_effect_default_op_map(all_decls)
  check_default_coverage_loop(file, all_decls, eff_map, mod_decls, 0)
}


fn check_default_coverage_loop(file: String, all_decls: [Decl],
                                eff_map: [EffDefaultOps], ds: [Decl],
                                acc: Int) : Int / Console + File {
  match ds {
    [] -> acc
    [d, ...rest] -> match d {
      DFn(_, fname, _, _, _, _, body, _, _, _) -> {
        let n = walk_coverage_expr(file, all_decls, eff_map, fname, body, [], 0)
        check_default_coverage_loop(file, all_decls, eff_map, rest, acc + n)
      }
      _ -> check_default_coverage_loop(file, all_decls, eff_map, rest, acc)
    }
  }
}

# Field-privacy walker (priv-fields lane). For every `EField(obj, fname)`
# and every `ERecordLit { fname: val, ... }` in this module's typed
# bodies, when `obj.ty` is `TyCon(Some(decl_mod), rec_name, _)` and
# `decl_mod` is some other module, look up the field in `all_decls`
# and reject the read/write when the field is `priv`. Records declared
# in the same module pass freely (their internal fns are the
# expected consumers).
#
# Runs post-typing so `Expr.ty` is the resolved record type, not a
# free type variable. Mirrors `check_default_coverage`'s pre-conditions
# (post-typing, has `tp.decls` for iteration, has `all_decls_for_typer`
# for lookup of the declaring module's record shape).

fn check_field_privacy(file: String, home: Option[String],
                        mod_decls: [Decl], all_decls: [Decl])
                        : Int / Console + File {
  check_field_privacy_loop(file, home, all_decls, mod_decls, 0)
}


fn check_field_privacy_loop(file: String, home: Option[String],
                              all_decls: [Decl], ds: [Decl],
                              acc: Int) : Int / Console + File {
  match ds {
    [] -> acc
    [d, ...rest] -> match d {
      DFn(_, _, _, _, _, _, body, _, _, _) -> {
        let n = walk_field_priv_expr(file, home, all_decls, body, 0)
        check_field_privacy_loop(file, home, all_decls, rest, acc + n)
      }
      _ -> check_field_privacy_loop(file, home, all_decls, rest, acc)
    }
  }
}

# Look up a `(FieldDecl, declaring_module)` pair by record name across
# `all_decls`. Returns the FieldDecl paired with the DType's own
# module_origin so callers can compare against the access-site home —
# the TyCon's `module_origin` is not always populated for user types
# at this point, so the DType is the authoritative source.
#
# When two DTypes carry the same record name across modules (shadowing),
# the first match wins — by Hanga Roa convention the root file's type
# shadows imports, but at this point in the pipeline `all_decls` order
# reflects that already (root file's decls come last after import
# expansion's reverse-flatten, so the first match here is typically
# the deepest dependency). Same-name collisions across modules are
# rare enough that the caller will accept the first hit's verdict.

fn lookup_record_field(all_decls: [Decl], rec_name: String, fname: String)
                         : Option[FieldDeclWithHome] = match all_decls {
  []           -> None
  [d, ...rest] -> match d {
    DType(_, tn, _, TBRecord(fields), _, _, decl_mo, _) ->
      if tn == rec_name {
        match find_field_in_decls(fields, fname) {
          Some(fd) -> Some(FDH(fd, decl_mo))
          None     -> lookup_record_field(rest, rec_name, fname)
        }
      } else {
        lookup_record_field(rest, rec_name, fname)
      }
    _ -> lookup_record_field(rest, rec_name, fname)
  }
}


fn find_field_in_decls(fields: [FieldDecl], target: String) : Option[FieldDecl] =
  match fields {
    []           -> None
    [f, ...rest] -> match f {
      FD(_, n, _) -> if n == target { Some(f) } else { find_field_in_decls(rest, target) }
    }
  }

# Returns the (module, record_name) pair of the record type carried
# by `obj.ty`. Records whose carrier is anything other than a
# record-shaped TyCon (free variable, primitive, list, fn) cannot
# be classified at this point — return None and skip the check.

fn record_carrier_of(ty: Option[Ty]) : Option[Pair[Option[String], String]] =
  match ty {
    None     -> None
    Some(t)  -> record_carrier_t(t)
  }


fn record_carrier_t(t: Ty) : Option[Pair[Option[String], String]] = match t {
  TyCon(mo, name, _) -> Some(Pair { fst: mo, snd: name })
  TyRefineT(inner, _) -> record_carrier_t(inner)
  TyDimT(inner, _)    -> record_carrier_t(inner)
  _ -> None
}


fn walk_field_priv_expr(file: String, home: Option[String],
                          all_decls: [Decl], e: Expr,
                          acc: Int) : Int / Console + File {
  let head_errs = match e.kind {
    # Cross-module read of a `priv` field. The record's declared
    # home is in `obj.ty`'s TyCon module_origin; the access site's
    # home is the walker-level `home` parameter (None = root file).
    EField(obj, fname) -> match record_carrier_of(obj.ty) {
      None         -> 0
      Some(carrier) -> {
        let rec_name = carrier.snd
        match lookup_record_field(all_decls, rec_name, fname) {
          None -> 0
          Some(fdh) -> match fdh { FDH(fd, decl_mo) ->
            if inf_mo_eq(decl_mo, home) { 0 }
            else { match fd {
              FD(true, _, _)  -> 0
              FD(false, _, _) -> {
                let owner = match decl_mo {
                  Some(m) -> m
                  None    -> "<root>"
                }
                diag_error(file, e.line, e.col,
                  concat_all(["field `", fname,
                              "` of `", rec_name,
                              "` is private to module `", owner, "`"]))
                diag_help(concat_all(["the field is declared `priv` in module `",
                                      owner, "`; only fns inside that module can read it"]))
                1
              }
            } }
          }
        }
      }
    }
    # Cross-module construction touching a `priv` field. RecordLit
    # carries the carrier in its ty (set by `synth_record_lit`).
    # Any field init mentioning a priv field of another module is
    # an error — the constructor escapes the encapsulation boundary.
    ERecordLit(_, fis) -> match record_carrier_of(e.ty) {
      None         -> 0
      Some(carrier) -> {
        let rec_name = carrier.snd
        walk_priv_field_inits(file, home, all_decls, rec_name,
                                fis, e.line, e.col, 0)
      }
    }
    _ -> 0
  }
  acc + head_errs + walk_field_priv_children(file, home, all_decls, e.kind, 0)
}


fn walk_priv_field_inits(file: String, home: Option[String],
                           all_decls: [Decl], rec_name: String,
                           fis: [FieldInit], line: Int, col: Int,
                           acc: Int) : Int / Console + File {
  match fis {
    []           -> acc
    [fi, ...rest] -> match fi {
      FI(fname, _) -> {
        let n = match lookup_record_field(all_decls, rec_name, fname) {
          None -> 0
          Some(fdh) -> match fdh { FDH(fd, decl_mo) ->
            if inf_mo_eq(decl_mo, home) { 0 }
            else { match fd {
              FD(true, _, _)  -> 0
              FD(false, _, _) -> {
                let owner = match decl_mo {
                  Some(m) -> m
                  None    -> "<root>"
                }
                diag_error(file, line, col,
                  concat_all(["cannot construct `", rec_name,
                              "` from outside module `", owner,
                              "`: field `", fname, "` is private"]))
                diag_help(concat_all(["the field is declared `priv` in module `",
                                      owner, "`; ask that module for a constructor fn"]))
                1
              }
            } }
          }
        }
        walk_priv_field_inits(file, home, all_decls, rec_name, rest,
                               line, col, acc + n)
      }
    }
  }
}


fn walk_field_priv_children(file: String, home: Option[String],
                              all_decls: [Decl], k: ExprKind,
                              acc: Int) : Int / Console + File = match k {
  EInt(_)           -> acc
  EReal(_, _)          -> acc
  EIntLit(_)           -> acc
  EDecimalLit(_)       -> acc
  EFixed(_, _)         -> acc
  EBool(_)          -> acc
  EChar(_)          -> acc
  EStr(_, _)        -> acc
  EUnit             -> acc
  EVar(_)           -> acc
  EUnder            -> acc
  EPlaceholder      -> acc
  EHole(_)          -> acc
  ETodo(_)          -> acc
  EExternBody(_)    -> acc
  EVariantsOf(_, _) -> acc
  EModCall(_, _)    -> acc
  EIntrinsic(_, args_) -> walk_field_priv_list(file, home, all_decls, args_, acc)
  ECall(callee, args_) -> {
    let a1 = walk_field_priv_expr(file, home, all_decls, callee, acc)
    walk_field_priv_list(file, home, all_decls, args_, a1)
  }
  EField(base, _)   -> walk_field_priv_expr(file, home, all_decls, base, acc)
  EIndex(a, b)      -> {
    let a1 = walk_field_priv_expr(file, home, all_decls, a, acc)
    walk_field_priv_expr(file, home, all_decls, b, a1)
  }
  EBinop(_, a, b)   -> {
    let a1 = walk_field_priv_expr(file, home, all_decls, a, acc)
    walk_field_priv_expr(file, home, all_decls, b, a1)
  }
  EUnop(_, x)       -> walk_field_priv_expr(file, home, all_decls, x, acc)
  EIf(c, t, eo)     -> {
    let a1 = walk_field_priv_expr(file, home, all_decls, c, acc)
    let a2 = walk_field_priv_expr(file, home, all_decls, t, a1)
    match eo {
      Some(b) -> walk_field_priv_expr(file, home, all_decls, b, a2)
      None    -> a2
    }
  }
  EMatch(scr, arms) -> {
    let a1 = walk_field_priv_expr(file, home, all_decls, scr, acc)
    walk_field_priv_arms(file, home, all_decls, arms, a1)
  }
  ELambda(_, _) -> acc
  ERecordLit(_, fs) -> walk_field_priv_field_inits(file, home, all_decls, fs, acc)
  EList(els) -> walk_field_priv_elems(file, home, all_decls, els, acc)
  ERange(a, b, opt) -> {
    let a1 = walk_field_priv_expr(file, home, all_decls, a, acc)
    let a2 = walk_field_priv_expr(file, home, all_decls, b, a1)
    match opt {
      Some(s) -> walk_field_priv_expr(file, home, all_decls, s, a2)
      None    -> a2
    }
  }
  EBlock(stmts, tail) -> {
    let a1 = walk_field_priv_stmts(file, home, all_decls, stmts, acc)
    match tail {
      Some(t) -> walk_field_priv_expr(file, home, all_decls, t, a1)
      None    -> a1
    }
  }
  EPipe(a, b)        -> {
    let a1 = walk_field_priv_expr(file, home, all_decls, a, acc)
    walk_field_priv_expr(file, home, all_decls, b, a1)
  }
  EMapPipe(a, b)     -> {
    let a1 = walk_field_priv_expr(file, home, all_decls, a, acc)
    walk_field_priv_expr(file, home, all_decls, b, a1)
  }
  EFlatMapPipe(a, b) -> {
    let a1 = walk_field_priv_expr(file, home, all_decls, a, acc)
    walk_field_priv_expr(file, home, all_decls, b, a1)
  }
  EFilterPipe(a, b)  -> {
    let a1 = walk_field_priv_expr(file, home, all_decls, a, acc)
    walk_field_priv_expr(file, home, all_decls, b, a1)
  }
  EBang(inner)       -> walk_field_priv_expr(file, home, all_decls, inner, acc)
  ELitUnit(inner, _) -> walk_field_priv_expr(file, home, all_decls, inner, acc)
  EHandle(body, _, _, init_opt, _, clauses, ret_opt) -> {
    let a0 = match init_opt {
      Some(i) -> walk_field_priv_expr(file, home, all_decls, i, acc)
      None    -> acc
    }
    let a1 = walk_field_priv_clauses(file, home, all_decls, clauses, a0)
    let a2 = match ret_opt {
      Some(r) -> match r { HR(_, b, _, _) -> walk_field_priv_expr(file, home, all_decls, b, a1) }
      None    -> a1
    }
    walk_field_priv_expr(file, home, all_decls, body, a2)
  }
}


fn walk_field_priv_list(file: String, home: Option[String],
                          all_decls: [Decl], es: [Expr],
                          acc: Int) : Int / Console + File = match es {
  [] -> acc
  [h, ...rest] -> {
    let a1 = walk_field_priv_expr(file, home, all_decls, h, acc)
    walk_field_priv_list(file, home, all_decls, rest, a1)
  }
}


fn walk_field_priv_arms(file: String, home: Option[String],
                         all_decls: [Decl], arms: [Arm],
                         acc: Int) : Int / Console + File = match arms {
  [] -> acc
  [a, ...rest] -> match a {
    Arm(_, og, body) -> {
      let a1 = match og {
        Some(g) -> walk_field_priv_expr(file, home, all_decls, g, acc)
        None    -> acc
      }
      let a2 = walk_field_priv_expr(file, home, all_decls, body, a1)
      walk_field_priv_arms(file, home, all_decls, rest, a2)
    }
  }
}


fn walk_field_priv_field_inits(file: String, home: Option[String],
                                 all_decls: [Decl], fis: [FieldInit],
                                 acc: Int) : Int / Console + File = match fis {
  [] -> acc
  [fi, ...rest] -> match fi {
    FI(_, e) -> {
      let a1 = walk_field_priv_expr(file, home, all_decls, e, acc)
      walk_field_priv_field_inits(file, home, all_decls, rest, a1)
    }
  }
}


fn walk_field_priv_elems(file: String, home: Option[String],
                          all_decls: [Decl], els: [ListElem],
                          acc: Int) : Int / Console + File = match els {
  [] -> acc
  [el, ...rest] -> match el {
    ElPlain(e)  -> {
      let a1 = walk_field_priv_expr(file, home, all_decls, e, acc)
      walk_field_priv_elems(file, home, all_decls, rest, a1)
    }
    ElSpread(e) -> {
      let a1 = walk_field_priv_expr(file, home, all_decls, e, acc)
      walk_field_priv_elems(file, home, all_decls, rest, a1)
    }
  }
}


fn walk_field_priv_stmts(file: String, home: Option[String],
                          all_decls: [Decl], ss: [Stmt],
                          acc: Int) : Int / Console + File = match ss {
  [] -> acc
  [s, ...rest] -> match s {
    SLet(_, _, e) -> {
      let a1 = walk_field_priv_expr(file, home, all_decls, e, acc)
      walk_field_priv_stmts(file, home, all_decls, rest, a1)
    }
    SVar(_, _, e, _, _) -> {
      let a1 = walk_field_priv_expr(file, home, all_decls, e, acc)
      walk_field_priv_stmts(file, home, all_decls, rest, a1)
    }
    SAssert(e, og) -> {
      let a1 = walk_field_priv_expr(file, home, all_decls, e, acc)
      let a2 = match og {
        Some(g) -> walk_field_priv_expr(file, home, all_decls, g, a1)
        None    -> a1
      }
      walk_field_priv_stmts(file, home, all_decls, rest, a2)
    }
    SExprStmt(e) -> {
      let a1 = walk_field_priv_expr(file, home, all_decls, e, acc)
      walk_field_priv_stmts(file, home, all_decls, rest, a1)
    }
    SIndexAssign(a, b, c, _, _) -> {
      let a1 = walk_field_priv_expr(file, home, all_decls, a, acc)
      let a2 = walk_field_priv_expr(file, home, all_decls, b, a1)
      let a3 = walk_field_priv_expr(file, home, all_decls, c, a2)
      walk_field_priv_stmts(file, home, all_decls, rest, a3)
    }
    SUse(_, _, _) -> walk_field_priv_stmts(file, home, all_decls, rest, acc)
  }
}


fn walk_field_priv_clauses(file: String, home: Option[String],
                             all_decls: [Decl], cs: [HClause],
                             acc: Int) : Int / Console + File = match cs {
  [] -> acc
  [c, ...rest] -> match c {
    HC(_, _, body, _, _) -> {
      let a1 = walk_field_priv_expr(file, home, all_decls, body, acc)
      walk_field_priv_clauses(file, home, all_decls, rest, a1)
    }
  }
}

# Names of ops the user wrote in a handle's clause list.

fn handle_clause_op_names(cs: [HClause]) : [String] = match cs {
  []           -> []
  [c, ...rest] -> match c {
    HC(name, _, _, _, _) -> [name, ...handle_clause_op_names(rest)]
  }
}

# Names of ops declared inside an effect's `default { }` block whose
# clause body is an `$extern_handler("c_sym")` intrinsic — the only
# shape Stage A codegen knows how to lower into a runtime shim.
# kaikai-bodied default clauses are recognised by the parser but their
# emit path is Stage C scope; including them here would let the typer
# discharge ops that the binary cannot service at runtime.
# Returns the empty list for "no default block" — the walker treats
# that case identically to "default block exists but covers no extern
# handlerable ops".

fn default_block_extern_ops(defblk: Option[DefaultBlock]) : [String] =
  match defblk {
    None      -> []
    Some(blk) -> match blk {
      DBlk(clauses, _, _, _) -> extern_handler_op_names(clauses)
    }
  }


# precomputed `eff_name -> extern-handlerable default ops`
# table. The coverage walk used to call `effect_default_op_names`, an
# O(n_decls) scan over every declaration, at every `EHandle` node and at
# every main-level uncovered op-call — O(N_EHandle x n_decls) overall.
# This table walks `decls` ONCE, recording per effect exactly the op
# names the old scan would have returned, so each use site is a single
# assoc-list lookup. Mirrors the `EffOps`/`use_eff_lookup` idiom from
# desugar.kai (kept local here because this lane touches only infer.kai).
# Effects absent from the table (lookup `None`) resolve to `[]` at the use
# site, matching the old scan on an effect with no `default { }` block.
type EffDefaultOps = EDOps(String, [String])


fn build_effect_default_op_map(decls: [Decl]) : [EffDefaultOps] {
  match decls {
    [] -> []
    [d, ...rest] -> match d {
      DEffect(_, name, _, _, defblk, _, _, _) ->
        [EDOps(name, default_block_extern_ops(defblk)),
         ...build_effect_default_op_map(rest)]
      _ -> build_effect_default_op_map(rest)
    }
  }
}


# Lookup matching `effect_default_op_names`'s contract: an undeclared
# effect (no table entry) returns `[]`, exactly as the original scan does
# when `inf_find_effect_default_block` finds no DEffect.
fn effect_default_op_map_get(table: [EffDefaultOps], eff_name: String) : [String] {
  match table {
    [] -> []
    [h, ...rest] -> match h {
      EDOps(n, ops) ->
        if n == eff_name { ops } else { effect_default_op_map_get(rest, eff_name) }
    }
  }
}


fn extern_handler_op_names(cs: [HClause]) : [String] = match cs {
  []           -> []
  [c, ...rest] -> match c {
    HC(name, _, body, _, _) -> match inf_extern_handler_c_symbol(body) {
      None    -> extern_handler_op_names(rest)
      Some(_) -> [name, ...extern_handler_op_names(rest)]
    }
  }
}


fn find_top_eff_frame(stack: [HandleFrame], eff_name: String) : Option[HandleFrame] {
  match stack {
    []           -> None
    [f, ...rest] -> match f {
      HF(n, _, _, _, _) ->
        if n == eff_name { Some(f) } else { find_top_eff_frame(rest, eff_name) }
    }
  }
}

# walker over a typed (or pre-typed) Expr. `fname` is the
# enclosing `DFn` name, used for the main-discharge step (step 4) and
# for diagnostic context.

fn walk_coverage_expr(file: String, decls: [Decl], eff_map: [EffDefaultOps],
                       fname: String,
                       e: Expr, stack: [HandleFrame], acc: Int) : Int / Console + File {
  match e.kind {
    EInt(_)           -> acc
    EReal(_, _)          -> acc
    EIntLit(_)           -> acc
    EDecimalLit(_)       -> acc
    EFixed(_, _)         -> acc
    EBool(_)          -> acc
    EChar(_)          -> acc
    EStr(_, _)        -> acc
    EUnit             -> acc
    EVar(_)           -> acc
    EUnder            -> acc
    EPlaceholder      -> acc
    EHole(_)          -> acc
    ETodo(_)          -> acc
    EExternBody(_)    -> acc
    EVariantsOf(_, _) -> acc
    EModCall(_, _)    -> acc
    EIntrinsic(_, args_) ->
      walk_coverage_list(file, decls, eff_map, fname, args_, stack, acc)
    ECall(callee, args_) -> {
      # Detect `Eff.op(...)` shape produced by synth_op_call_with_scheme.
      # The callee is `EVar("Eff.op")` (possibly with an `@alias` suffix on
      # the dispatch key — strip that before splitting).
      let head_errs = match callee.kind {
        EVar(key) -> check_op_call_coverage(file, decls, eff_map, fname, key,
                                              stack, e.line, e.col)
        _ -> 0
      }
      let acc1 = acc + head_errs
      let acc2 = walk_coverage_expr(file, decls, eff_map, fname, callee, stack, acc1)
      walk_coverage_list(file, decls, eff_map, fname, args_, stack, acc2)
    }
    EField(base, _) -> walk_coverage_expr(file, decls, eff_map, fname, base, stack, acc)
    EIndex(a, b)    -> {
      let a1 = walk_coverage_expr(file, decls, eff_map, fname, a, stack, acc)
      walk_coverage_expr(file, decls, eff_map, fname, b, stack, a1)
    }
    EBinop(_, a, b) -> {
      let a1 = walk_coverage_expr(file, decls, eff_map, fname, a, stack, acc)
      walk_coverage_expr(file, decls, eff_map, fname, b, stack, a1)
    }
    EUnop(_, x)     -> walk_coverage_expr(file, decls, eff_map, fname, x, stack, acc)
    EIf(c, t, eo)   -> {
      let a1 = walk_coverage_expr(file, decls, eff_map, fname, c, stack, acc)
      let a2 = walk_coverage_expr(file, decls, eff_map, fname, t, stack, a1)
      match eo {
        Some(b) -> walk_coverage_expr(file, decls, eff_map, fname, b, stack, a2)
        None    -> a2
      }
    }
    EMatch(scr, arms) -> {
      let a1 = walk_coverage_expr(file, decls, eff_map, fname, scr, stack, acc)
      walk_coverage_arms(file, decls, eff_map, fname, arms, stack, a1)
    }
    ELambda(_, _) -> acc           # lambda bodies have their own row
    ERecordLit(_, fs) -> walk_coverage_fields(file, decls, eff_map, fname, fs, stack, acc)
    EList(els)        -> walk_coverage_elems(file, decls, eff_map, fname, els, stack, acc)
    ERange(a, b, opt) -> {
      let a1 = walk_coverage_expr(file, decls, eff_map, fname, a, stack, acc)
      let a2 = walk_coverage_expr(file, decls, eff_map, fname, b, stack, a1)
      match opt {
        Some(s) -> walk_coverage_expr(file, decls, eff_map, fname, s, stack, a2)
        None    -> a2
      }
    }
    EBlock(stmts, tail) -> {
      let a1 = walk_coverage_stmts(file, decls, eff_map, fname, stmts, stack, acc)
      match tail {
        Some(t) -> walk_coverage_expr(file, decls, eff_map, fname, t, stack, a1)
        None    -> a1
      }
    }
    EPipe(a, b)        -> {
      let a1 = walk_coverage_expr(file, decls, eff_map, fname, a, stack, acc)
      walk_coverage_expr(file, decls, eff_map, fname, b, stack, a1)
    }
    EMapPipe(a, b)     -> {
      let a1 = walk_coverage_expr(file, decls, eff_map, fname, a, stack, acc)
      walk_coverage_expr(file, decls, eff_map, fname, b, stack, a1)
    }
    EFlatMapPipe(a, b) -> {
      let a1 = walk_coverage_expr(file, decls, eff_map, fname, a, stack, acc)
      walk_coverage_expr(file, decls, eff_map, fname, b, stack, a1)
    }
    EFilterPipe(a, b)  -> {
      let a1 = walk_coverage_expr(file, decls, eff_map, fname, a, stack, acc)
      walk_coverage_expr(file, decls, eff_map, fname, b, stack, a1)
    }
    EBang(inner)       -> walk_coverage_expr(file, decls, eff_map, fname, inner, stack, acc)
    ELitUnit(inner, _) -> walk_coverage_expr(file, decls, eff_map, fname, inner, stack, acc)
    EHandle(body, eff_name, _, init_opt, _, clauses, ret_opt) -> {
      let frame = HF(eff_name,
                     handle_clause_op_names(clauses),
                     effect_default_op_map_get(eff_map, eff_name),
                     e.line, e.col)
      let a1 = match init_opt {
        Some(i) -> walk_coverage_expr(file, decls, eff_map, fname, i, stack, acc)
        None    -> acc
      }
      # Clause bodies execute outside `with eff_name` (the typer enforces
      # this; clauses are separate functions). Walk them under the outer
      # stack so a Eff.op clause body that itself calls Eff.op is not
      # silently treated as discharged by this frame.
      let a2 = walk_coverage_clauses(file, decls, eff_map, fname, clauses, stack, a1)
      let a3 = match ret_opt {
        Some(r) -> match r {
          HR(_, b, _, _) -> walk_coverage_expr(file, decls, eff_map, fname, b, stack, a2)
        }
        None -> a2
      }
      walk_coverage_expr(file, decls, eff_map, fname, body, [frame, ...stack], a3)
    }
  }
}


fn walk_coverage_list(file: String, decls: [Decl], eff_map: [EffDefaultOps],
                       fname: String,
                       es: [Expr], stack: [HandleFrame], acc: Int) : Int / Console + File {
  match es {
    []           -> acc
    [h, ...rest] -> {
      let a1 = walk_coverage_expr(file, decls, eff_map, fname, h, stack, acc)
      walk_coverage_list(file, decls, eff_map, fname, rest, stack, a1)
    }
  }
}


fn walk_coverage_arms(file: String, decls: [Decl], eff_map: [EffDefaultOps],
                       fname: String,
                       arms: [Arm], stack: [HandleFrame], acc: Int) : Int / Console + File {
  match arms {
    []           -> acc
    [a, ...rest] -> match a {
      Arm(_, og, body) -> {
        let a1 = match og {
          Some(g) -> walk_coverage_expr(file, decls, eff_map, fname, g, stack, acc)
          None    -> acc
        }
        let a2 = walk_coverage_expr(file, decls, eff_map, fname, body, stack, a1)
        walk_coverage_arms(file, decls, eff_map, fname, rest, stack, a2)
      }
    }
  }
}


fn walk_coverage_fields(file: String, decls: [Decl], eff_map: [EffDefaultOps],
                         fname: String,
                         fs: [FieldInit], stack: [HandleFrame], acc: Int) : Int / Console + File {
  match fs {
    []           -> acc
    [f, ...rest] -> match f {
      FI(_, e) -> {
        let a1 = walk_coverage_expr(file, decls, eff_map, fname, e, stack, acc)
        walk_coverage_fields(file, decls, eff_map, fname, rest, stack, a1)
      }
    }
  }
}


fn walk_coverage_elems(file: String, decls: [Decl], eff_map: [EffDefaultOps],
                        fname: String,
                        els: [ListElem], stack: [HandleFrame], acc: Int) : Int / Console + File {
  match els {
    []            -> acc
    [el, ...rest] -> match el {
      ElPlain(e)  -> {
        let a1 = walk_coverage_expr(file, decls, eff_map, fname, e, stack, acc)
        walk_coverage_elems(file, decls, eff_map, fname, rest, stack, a1)
      }
      ElSpread(e) -> {
        let a1 = walk_coverage_expr(file, decls, eff_map, fname, e, stack, acc)
        walk_coverage_elems(file, decls, eff_map, fname, rest, stack, a1)
      }
    }
  }
}


fn walk_coverage_stmts(file: String, decls: [Decl], eff_map: [EffDefaultOps],
                        fname: String,
                        ss: [Stmt], stack: [HandleFrame], acc: Int) : Int / Console + File {
  match ss {
    []           -> acc
    [s, ...rest] -> match s {
      SLet(_, _, e) -> {
        let a1 = walk_coverage_expr(file, decls, eff_map, fname, e, stack, acc)
        walk_coverage_stmts(file, decls, eff_map, fname, rest, stack, a1)
      }
      SVar(_, _, e, _, _) -> {
        let a1 = walk_coverage_expr(file, decls, eff_map, fname, e, stack, acc)
        walk_coverage_stmts(file, decls, eff_map, fname, rest, stack, a1)
      }
      SAssert(e, og) -> {
        let a1 = walk_coverage_expr(file, decls, eff_map, fname, e, stack, acc)
        let a2 = match og {
          Some(g) -> walk_coverage_expr(file, decls, eff_map, fname, g, stack, a1)
          None    -> a1
        }
        walk_coverage_stmts(file, decls, eff_map, fname, rest, stack, a2)
      }
      SExprStmt(e) -> {
        let a1 = walk_coverage_expr(file, decls, eff_map, fname, e, stack, acc)
        walk_coverage_stmts(file, decls, eff_map, fname, rest, stack, a1)
      }
      SIndexAssign(a, b, c, _, _) -> {
        let a1 = walk_coverage_expr(file, decls, eff_map, fname, a, stack, acc)
        let a2 = walk_coverage_expr(file, decls, eff_map, fname, b, stack, a1)
        let a3 = walk_coverage_expr(file, decls, eff_map, fname, c, stack, a2)
        walk_coverage_stmts(file, decls, eff_map, fname, rest, stack, a3)
      }
      SUse(_, _, _) -> walk_coverage_stmts(file, decls, eff_map, fname, rest, stack, acc)
    }
  }
}


fn walk_coverage_clauses(file: String, decls: [Decl], eff_map: [EffDefaultOps],
                          fname: String,
                          cs: [HClause], stack: [HandleFrame], acc: Int) : Int / Console + File {
  match cs {
    []           -> acc
    [c, ...rest] -> match c {
      HC(_, _, body, _, _) -> {
        let a1 = walk_coverage_expr(file, decls, eff_map, fname, body, stack, acc)
        walk_coverage_clauses(file, decls, eff_map, fname, rest, stack, a1)
      }
    }
  }
}

# Op-call discharge: returns the number of new diagnostics emitted (0
# or 1). `key` is the callee `EVar` payload — `Eff.op` for a regular
# op call, possibly `Eff.op@alias` if the alias-tagged dispatch path
# fired. Returns 0 when the callee is not in `Eff.op` form (regular
# function call, FFI shim, etc.).

fn check_op_call_coverage(file: String, decls: [Decl],
                           eff_map: [EffDefaultOps], fname: String,
                           key: String, stack: [HandleFrame],
                           line: Int, col: Int) : Int / Console + File {
  let bare = strip_alias_suffix(key)
  if not string_contains_dot(bare) { 0 }
  else {
    let eff_name = dotted_prefix(bare)
    let op_name  = dotted_suffix(bare)
    # Skip the row-level absorbed labels (Ffi etc.) — they have no per-op
    # discharge surface. The walker only fires for declared effects that
    # come through `effect E { ops }`. Builtins are injected as DEffect
    # by `inject_builtin_effects` before this check runs, so they all
    # show up via `is_effect_declared`.
    if not is_effect_declared(eff_name, decls) { 0 }
    else {
      match find_top_eff_frame(stack, eff_name) {
        Some(frame) -> match frame {
          HF(_, clause_ops, _default_ops, _, _) ->
            if list_has_string(clause_ops, op_name) { 0 }
            else {
              # Spec step 3 ("enclosing handle exists, op not in
              # clauses, default block covers op → clause-merge from
              # default fires") is DISABLED in Stage B: codegen Stage
              # A's `emit_clause_assignments` only wires `_ev.<op>` for
              # ops the user typed in the handle. The inner handle's
              # evidence node masks any enclosing default, so the
              # dispatch hits a NULL function pointer at runtime
              # regardless of what `default { }` declares. Stage C
              # extends the handle emitter to consult the effect's
              # default block and synthesize the missing clauses; at
              # that point this branch flips to check `_default_ops`
              # and discharges.
              report_uncovered_op(file, fname, eff_name, op_name, decls,
                                   line, col, false)
              1
            }
        }
        None ->
          # No enclosing handle for `eff_name`. The op either fires from
          # main (step 4) or escapes to the caller's row.
          if fname == "main" {
            # every effect (builtin or user) with a
            # source-level `default { }` block bridging via
            # `$extern_handler` gets auto-installed at main. The
            # check is now uniform — no special builtin list.
            let default_ops = effect_default_op_map_get(eff_map, eff_name)
            if list_has_string(default_ops, op_name) { 0 }
            else {
              report_uncovered_op(file, fname, eff_name, op_name, decls,
                                   line, col, true)
              1
            }
          }
          else { 0 }
      }
    }
  }
}

# Some op-call callees carry an `@alias` suffix on the dispatch key
# (e.g. `Stdout.print@io`). Strip it so the `Eff.op` split is honest.

fn strip_alias_suffix(key: String) : String =
  strip_alias_suffix_loop(key, 0, string_length(key))


fn strip_alias_suffix_loop(key: String, i: Int, n: Int) : String {
  if i >= n { key }
  else {
    match char_at(key, i) {
      # `@` is the legacy by-id alias tag; `#` is the §6 capability dispatch tag.
      # Both are codegen-only suffixes the coverage/display path strips.
      Some(c) -> if c == '@' or c == '#' { string_slice(key, 0, i) }
                 else { strip_alias_suffix_loop(key, i + 1, n) }
      None    -> key
    }
  }
}


fn is_effect_declared(eff_name: String, decls: [Decl]) : Bool {
  match decls {
    [] -> false
    [d, ...rest] -> match d {
      DEffect(_, n, _, _, _, _, _, _) ->
        if n == eff_name { true } else { is_effect_declared(eff_name, rest) }
      _ -> is_effect_declared(eff_name, rest)
    }
  }
}

# Emit the structured diagnostic for an unhandled op. The `at_main` flag
# distinguishes "no handle, fname is main, default block does not cover
# the op" from "enclosing handle exists, clauses omit the op, default
# does not fill the gap" — the help lines differ.

fn report_uncovered_op(file: String, fname: String, eff_name: String,
                        op_name: String, decls: [Decl],
                        line: Int, col: Int, at_main: Bool) : Unit / Console + File {
  let qualified = concat_all([eff_name, ".", op_name])
  let header = concat_all(["effect not handled: ", qualified])
  diag_error(file, line, col, header)
  let default_status = describe_default_status(eff_name, op_name, decls)
  diag_note(default_status)
  if at_main {
    diag_help(concat_all(["wrap the call in `handle { ... } with ",
                          eff_name, " { ", op_name,
                          "(args, resume) -> ... }`, or add `",
                          op_name, "(args, resume) -> ...` to `effect ",
                          eff_name, "`'s `default { }` block"]))
  } else {
    diag_help(concat_all(["add a `", op_name,
                          "(args, resume) -> ...` clause to the enclosing `handle ... with ",
                          eff_name, "`, or add `", op_name,
                          "(args, resume) -> ...` to `effect ", eff_name,
                          "`'s `default { }` block"]))
  }
}


fn describe_default_status(eff_name: String, op_name: String,
                            decls: [Decl]) : String {
  match inf_find_effect_default_block(eff_name, decls) {
    None ->
      concat_all(["effect `", eff_name,
                  "` declares no `default { }` block, so no fallback handler exists"])
    Some(defblk) -> match defblk {
      DBlk(clauses, _, _, _) -> {
        let all_names = handle_clause_op_names(clauses)
        let extern_names = extern_handler_op_names(clauses)
        if list_has_string(extern_names, op_name) {
          # The default block does declare the op AND its body is an
          # `$extern_handler(...)` bridge — codegen Stage A can lower it
          # at `main` level. The reason discharge failed is that we are
          # inside a partial `handle ... with E`: Stage A's
          # `emit_clause_assignments` only wires the user-declared
          # clauses, so an inner handle's evidence node masks the
          # main-level default. Stage C lifts the masking by emitting
          # the default's clauses inside every enclosing handle's `_ev`.
          concat_all(["effect `", eff_name,
                      "`'s `default { }` block does declare `", op_name,
                      "` via `$extern_handler`, but the enclosing `handle ... with ",
                      eff_name, "` masks the main-level default — Stage C will let the handle inherit unmissed default clauses; until then the partial handle must add `",
                      op_name, "`"])
        } else if list_has_string(all_names, op_name) {
          # The user wrote the clause but its body is a kaikai expression.
          # Stage A lowers only `$extern_handler(...)` bridges; Stage C
          # will close this gap.
          concat_all(["effect `", eff_name,
                      "`'s `default { }` block declares `", op_name,
                      "` but its body is not an `$extern_handler(...)` bridge — Stage C will lower kaikai-bodied default clauses; for now the clause must use the intrinsic"])
        } else {
          concat_all(["effect `", eff_name,
                      "`'s `default { }` block does not declare `",
                      op_name, "`"])
        }
      }
    }
  }
}

# Build a single shim declaration from a clause whose body bridges to
# a C symbol via `$extern_handler("c_sym")`. Returns "" if the body is
# not an extern_handler intrinsic — Stage A does not emit kaikai-bodied
# default clauses.
# NOTE: do NOT name a local binding `c_sym` here — `c_sym` is also a
# pre-existing fn in compiler.kai (FFI C-symbol minter), and
# the resolver picks the global fn over the let-binding, emitting the
# expression as a closure reference instead of a string read. Use
# `csym_name` or similar to dodge the collision.

fn edition_rank(n: String) : Int =
  if n == "orongo" { 2 }
  else if n == "hanga-roa" { 1 }
  else if n == "tongariki" { 0 }
  else { 0 }


fn edition_at_least(have: String, target: String) : Bool =
  edition_rank(have) >= edition_rank(target)

# register a `[unstable] <pkg> = true` opt-in from
# kai.toml. Repeated flags accumulate.

# ====================================================================
# HM type schemes, substitution/unification, bidirectional inference,
# and the infer driver
# ====================================================================

# type schemes + environment
# ====================================================================
#
# A TyScheme is `Scheme(bound_vars, bound_rvars, Ty)`: the type-var
# ids in `bound_vars` appear as TyVarT(n) inside `Ty`; the row-var
# ids in `bound_rvars` appear as `Row { tail: Some(n) }` inside any
# TyFnT in `Ty`. Both kinds are instantiated to fresh ids at each
# use site. The bound ids
# are scheme-local — bound-id 0 in scheme A and bound-id 0 in scheme
# B refer to different vars; the instantiation step rewrites them
# through a temporary substitution before they reach the inferencer's
# main subst slots.
#
# A TyEnv is a flat association list of (name, scheme) entries plus a
# fresh-variable counter used later. Lookups are linear — fine at this
# stage (a few dozen entries).

#[doc("infer: a quantified type scheme (bound ty/row/unit vars + unit-var kinds + the Ty).")]
pub type TyScheme = Scheme([Int], [Int], [Int], [String], Ty)
# third parameter `bound_uvars` lists unit-var ids quantified
# by the scheme. Instantiation allocates a fresh UVar per bound id
# (parallel to bound_vars / bound_rvars). Empty for non-unit-poly
# schemes. The fourth parameter is parallel to `bound_uvars`: the
# kind each unit tparam ranges over (`Measure`, `Currency`, ...);
# `""` leaves the var unconstrained (kind-agnostic builtins).

#[doc("infer: a (name, scheme) entry in the typing environment.")]
pub type TyEntry = { name: String, scheme: TyScheme }

# a per-decl summary of `type T = A | B` declarations.
# The summary lives on `TyEnv.unions`
# and acts as the canonical "components of T" map for the typer:
# `variants_of_type` falls back to it (the shadow case where
# the component is a pre-declared top-level type) and
# `union_upcast_ok` consults it to validate D3 upcasts.
# Components are stored in their post-`normalize_union` canonical
# form; `parent` is the declared type name; `line`/`col` point at
# the declaration's token for diagnostic anchoring.
#[doc("infer: `UnionInfo` — driver-facing type.")]
pub type UnionInfo = UI(String, [Ty], Int, Int)

# `unions` carries the per-decl union summary harvested
# at env-build time. It coexists with the variant-table dual rep:
# the table drives runtime ctor lookup, while `unions` is the
# typer-side authority for "which types compose this union?".
# per-compile cache `head_owners` records the (head_type
# → declaring_module) mapping the typer consults when lowering a
# convention-based pipe (`|`, `||`, `|?`). Each `HeadOwnerEntry` carries
# the modules that declare a `pub type T` so a second-pass dispatch
# lookup can answer "module that owns `T`'s `map`/`flat_map`/`filter`"
# in O(1) per pipe call site without re-scanning the decl stream.
# When `head_owners` lists more than one module for the same `T` the
# typer reports an unambiguous diagnostic at the use site instead of
# silently picking a winner. The list is built once per compile by
# `build_head_owner_map` and stays empty for typer entry points that
# do not run inside `compile_source` (test helpers, `dump_typed`, etc.)
# — those paths have no module table to consult, so the only head a
# pipe could resolve against is the core-loaded `List`, which their
# fixtures already exercise via the standard core path.
# `#[constructor]` registry entry: the constructed type's bare name,
# its home module, and the marked fn's name. `try_constructor_call`
# reads it to rewrite `Type(args)` into `EModCall(home, fn)(args)`.
#[doc("infer: one `#[constructor]` binding — `(type_name, home_module, fn_name)`.")]
pub type CtorEntry = CtorE(String, String, String)

#[doc("infer: `TyEnv` — driver-facing type.")]
pub type TyEnv = { entries: [TyEntry], fresh: Int, unions: [UnionInfo],
               # `#[constructor]` bindings: `type_name -> (home, fn)`.
               constructors: [CtorEntry],
               head_owners: [HeadOwnerEntry],
               # bare names of functions declared in the ROOT
               # (user) file. A root `fn foo` unconditionally shadows any
               # stdlib `pub fn foo` of the same name — even when their
               # signatures match exactly and receiver-type narrowing
               # would otherwise route a bare `foo(x)` to a
               # same-signature stdlib export (e.g. user `length(String)`
               # vs `string.length(String)`). `try_bare_call_narrow`
               # consults this set and skips narrowing when `nm` is a root
               # shadow, so the bare lookup (which resolves to the user's
               # newest-registered decl) wins. Seeded via
               # `collect_root_fn_names` ONLY in the target bucket (the
               # file being compiled); empty for any imported module, so a
               # user root fn never shifts an imported module's typed AST.
               root_fns: [String],
               # per-type effect-row-kind slot table (`compute_row_kind_slots`).
               # Lets annotation resolution (`inf_resolve_ty_rk`) wrap a
               # `T[..., e]` row slot in a carrier so a concrete-row
               # `let s : Stream[String, File + ReadFault]` annotation
               # unifies with the inferred carrier.
               row_kind: [RowKindEntry],
               # name index over `entries`, keyed by each entry's bucket
               # key (last `::`-segment). Mirrors `entries` exactly: every
               # prepend to `entries` prepends to this index too, so
               # `ty_env_lookup` / `ty_env_collect_candidates` answer
               # per-name queries without walking the full assoc list.
               index: NameIndex[TyEntry] }

# head-owner cache entry. `head` is the bare type name
# (`List`, `MyBox`, ...); `mods` is the list of modules whose
# `pub type` declarations introduce this name. Single-element `mods`
# is the dispatchable case; multi-element is ambiguous and the typer
# diagnostic asks the user to qualify the LHS.
#[doc("infer: `HeadOwnerEntry` — driver-facing type.")]
pub type HeadOwnerEntry = HOE(String, [String])

#[doc("infer: the empty typing environment.")]
pub fn ty_env_empty() : TyEnv = TyEnv { entries: [], fresh: 0, unions: [], constructors: [], head_owners: [], root_fns: [], row_kind: [], index: idx_empty() }

fn ty_env_add(env: TyEnv, name: String, sc: TyScheme) : TyEnv {
  let k = ty_bucket_key(name)
  let e = TyEntry { name: name, scheme: sc }
  TyEnv { entries: [e, ...env.entries],
          fresh: env.fresh, unions: env.unions, constructors: env.constructors, head_owners: env.head_owners, root_fns: env.root_fns, row_kind: env.row_kind,
          index: idx_prepend(env.index, k, e) }
}

# composite key for module-qualified scheme entries.
# When the same bare `fname` is exported from two core modules
# (e.g. `repeat` from `list.kai` and `string.kai`), the bare-name
# entries shadow each other in `entries`. Modules also register
# under this `<mod>::<fname>` key so the EModCall branch can pick
# the correct scheme by qualifier instead of guessing from arg
# types after a wrong scheme was instantiated. Mirrors the
# codegen-side `c_sym(name, Some(mod))` discipline.
fn ty_mod_key(mod: String, fname: String) : String =
  string_concat(mod, string_concat("::", fname))

fn ty_env_add_qualified(env: TyEnv, mod: String, name: String, sc: TyScheme) : TyEnv =
  ty_env_add(env, ty_mod_key(mod, name), sc)

# Bucket key for the name index: the segment after the FINAL `::`, or
# the whole name when it has none. Applied identically on insert and on
# query so an entry registered under `<mod>::<fname>` and a bare-name
# query for `<fname>` land in the same bucket. Soundness rests on the
# scan re-applying the exact byte predicate of each lookup, so a hash or
# bucket collision is filtered out, never returned.
fn ty_bucket_key(name: String) : String {
  let i = ty_last_sep(name, string_length(name) - 1)
  if i < 0 { name } else { string_slice(name, i + 2, string_length(name) - (i + 2)) }
}

# Index of the `:` that opens the final `::` in `name`, scanning down
# from `from`; -1 when no `::` is present.
fn ty_last_sep(name: String, from: Int) : Int {
  if from < 1 { -1 }
  else {
    match char_at(name, from - 1) {
      Some(a) -> match char_at(name, from) {
        Some(b) -> if a == ':' and b == ':' { from - 1 } else { ty_last_sep(name, from - 1) }
        None    -> ty_last_sep(name, from - 1)
      }
      None -> ty_last_sep(name, from - 1)
    }
  }
}

# Prepend a fresh batch of new entries onto BOTH the entries list and the
# index, returning the pair. Each `TyEntry` is shared into `entries`
# (cons) and `index` (idx_prepend) exactly as `ty_env_add` shares a
# single entry. `batch` must be a fresh local (not an already-stored
# list): it is reversed so a tail-recursive prepend lands the original
# head (newest) at the front of both structures, matching `ty_env_add`'s
# newest-first order.
type TyEnvParts = TEP([TyEntry], NameIndex[TyEntry])

fn ty_env_prepend_batch(batch: [TyEntry], entries: [TyEntry], ix: NameIndex[TyEntry]) : TyEnvParts =
  ty_env_prepend_batch_loop(list_reverse(batch), entries, ix)

fn ty_env_prepend_batch_loop(batch: [TyEntry], entries: [TyEntry], ix: NameIndex[TyEntry]) : TyEnvParts = match batch {
  [] -> TEP(entries, ix)
  [e, ...rest] -> {
    let k = ty_bucket_key(e.name)
    ty_env_prepend_batch_loop(rest, [e, ...entries], idx_prepend(ix, k, e))
  }
}

fn ty_env_lookup_loop(es: [TyEntry], target: String) : Option[TyScheme] {
  match es {
    [] -> None
    [e, ...rest] -> if e.name == target { Some(e.scheme) } else { ty_env_lookup_loop(rest, target) }
  }
}

# The index bucket for `target` is the entries-order subsequence of
# all entries sharing `target`'s bucket key, newest-first; scanning it
# with the same `e.name == target` predicate returns the identical
# first match the full-`entries` walk produced.
fn ty_env_lookup(env: TyEnv, target: String) : Option[TyScheme] =
  ty_env_lookup_loop(idx_chain(env.index, ty_bucket_key(target)), target)

# qualifier-aware lookup. Returns the scheme registered
# under `<mod>::<fname>` if present; the EModCall branch consults
# this BEFORE falling back to a bare lookup so two modules exporting
# the same bare name resolve unambiguously to their declaring module.
fn ty_env_lookup_qualified(env: TyEnv, mod: String, fname: String) : Option[TyScheme] =
  ty_env_lookup(env, ty_mod_key(mod, fname))

# walk the env collecting modules that export `fname`.
# Used to suggest "did you mean `<other_mod>.<fname>`?" when the
# user qualifies a name with the wrong module.
fn ty_env_modules_exporting(env: TyEnv, fname: String) : [String] =
  modules_exporting_loop(env.entries, fname, [])

fn modules_exporting_loop(es: [TyEntry], fname: String, acc: [String]) : [String] {
  match es {
    [] -> list_reverse(acc)
    [e, ...rest] -> {
      let mod_opt = ty_entry_split_mod(e.name, fname)
      match mod_opt {
        Some(m) -> if list_has(acc, m) { modules_exporting_loop(rest, fname, acc) }
                   else { modules_exporting_loop(rest, fname, [m, ...acc]) }
        None    -> modules_exporting_loop(rest, fname, acc)
      }
    }
  }
}

# returns `Some(bare)` when `key` has the form
# `<target>::<bare>` (i.e. the qualified key whose left side is
# `target`). Used by `variants_of_type_loop_arity` to surface user
# variants registered only under the qualified key (because a core
# builtin already occupies the bare slot) as variants of `target`,
# yielding the bare ctor name pattern arms / exhaustiveness reports
# expect.
fn ty_env_strip_qualified_prefix(key: String, target: String) : Option[String] {
  let prefix = string_concat(target, "::")
  let pn = string_length(prefix)
  let kn = string_length(key)
  if kn <= pn { None }
  else {
    let head = string_slice(key, 0, pn)
    if head == prefix { Some(string_slice(key, pn, kn - pn)) } else { None }
  }
}

# Returns Some(<mod>) if `key` is `<mod>::<fname>`, else None. Used
# only by `ty_env_modules_exporting` for diagnostic suggestions.
fn ty_entry_split_mod(key: String, fname: String) : Option[String] {
  let suffix = string_concat("::", fname)
  let kn = string_length(key)
  let sn = string_length(suffix)
  if kn <= sn { None }
  else {
    let tail = string_slice(key, kn - sn, sn)
    if tail == suffix { Some(string_slice(key, 0, kn - sn)) } else { None }
  }
}

# a candidate from `ty_env_collect_candidates`. Carries
# the registered scheme plus its declaring module name. Only entries
# registered under the qualified `<mod>::<fname>` key contribute
# candidates; bare core entries (the hardcoded list-typed
# `map` / `filter` / `each` etc. from `add_core_sigs`) are
# excluded so the receiver-type narrowing does not have to compete
# against schemes that share a name but were never module-tagged.
# When narrowing fires, callers rewrite `EVar(fname)` to
# `EModCall(mod, fname)` so codegen mints `kai_<mod>__<fname>`
# directly, bypassing `efn_resolve`'s load-order tie-break.
type TyCandidate = { scheme: TyScheme, mod: String }

# collect every qualified scheme registered for
# `target`, newest-first so picks honour the same tie-break the legacy
# `ty_env_lookup` used. `target` always arrives bare, so its bucket key
# is `target`; the bucket is the entries-order subsequence of every
# entry whose last `::`-segment is `target` (a superset of the
# `<mod>::target` keys), and the unchanged `ty_entry_extract_mod` filter
# drops the bare `target` entry: identical to walking full `entries`.
fn ty_env_collect_candidates(env: TyEnv, target: String) : [TyCandidate] =
  ty_env_collect_candidates_loop(idx_chain(env.index, ty_bucket_key(target)),
                                 string_concat("::", target), [])

fn ty_env_collect_candidates_loop(es: [TyEntry],
                                   suffix: String,
                                   acc: [TyCandidate]) : [TyCandidate] {
  match es {
    [] -> list_reverse(acc)
    [e, ...rest] -> match ty_entry_extract_mod(e.name, suffix) {
      None -> ty_env_collect_candidates_loop(rest, suffix, acc)
      Some(m) -> {
        let cand = TyCandidate { scheme: e.scheme, mod: m }
        ty_env_collect_candidates_loop(rest, suffix, [cand, ...acc])
      }
    }
  }
}

# Returns `Some(<mod>)` if `key` ends with `suffix` (which is
# `::<target>`) AND there is at least one byte before the `::`.
# Avoids a string scan by reusing the slice computation that
# `ty_entry_split_mod` already does for diagnostics.
fn ty_entry_extract_mod(key: String, suffix: String) : Option[String] {
  let kn = string_length(key)
  let sn = string_length(suffix)
  if kn <= sn { None }
  else {
    let tail = string_slice(key, kn - sn, sn)
    if tail == suffix { Some(string_slice(key, 0, kn - sn)) } else { None }
  }
}

# True when `key` ends with `suffix` AND the suffix is preceded by at
# least one character (so `::name` itself doesn't match — the bare
# `target` arm above handles bare keys). Mirrors `ty_entry_split_mod`'s
# length check.
fn ty_entry_key_has_suffix(key: String, suffix: String) : Bool {
  let kn = string_length(key)
  let sn = string_length(suffix)
  if kn <= sn { false }
  else { string_slice(key, kn - sn, sn) == suffix }
}

# Names of entries whose first byte is uppercase ASCII. Used to
# filter down to variant constructors (`Some`, `Ok`, `Err`, user
# variants) when suggesting alternatives for unknown variants.
fn ty_env_uppercase_names(env: TyEnv) : [String] =
  uppercase_names_loop(env.entries, [])

fn uppercase_names_loop(es: [TyEntry], acc: [String]) : [String] {
  match es {
    [] -> list_reverse(acc)
    [e, ...rest] -> {
      let first_upper = match char_at(e.name, 0) {
        Some(c) -> c >= 'A' and c <= 'Z'
        None    -> false
      }
      if first_upper {
        uppercase_names_loop(rest, [e.name, ...acc])
      } else {
        uppercase_names_loop(rest, acc)
      }
    }
  }
}

# ---- small constructors ----

fn mono(ty: Ty) : TyScheme = Scheme([], [], [], [], ty)

fn scheme(vars: [Int], ty: Ty) : TyScheme = Scheme(vars, [], [], [], ty)

fn scheme_full(vars: [Int], rvars: [Int], ty: Ty) : TyScheme = Scheme(vars, rvars, [], [], ty)

# scheme generalising over type-, row-, and unit-vars all at once.
# Used by fn_scheme_of_decl when the signature has [u: Measure] tparams.
# `ukinds` is parallel to `uvars`: the kind each unit tparam ranges
# over ("" = unconstrained).
fn scheme_uvars(vars: [Int], rvars: [Int], uvars: [Int], ukinds: [String], ty: Ty) : TyScheme =
  Scheme(vars, rvars, uvars, ukinds, ty)

fn tv(n: Int) : Ty = TyVarT(n)

fn fn_ty(ps: [Ty], ret: Ty) : Ty = TyFnT(ps, ret, inf_row_empty())

# Like `fn_ty` but stamps a closed effect row onto the function type, so a
# core builtin carries its own effect in its scheme instead of having it
# attributed by a name-keyed side table at the call site. The labels are
# non-parametric builtin effects (Stdout, File, Mutable, …) — no ty_args, no
# tail — so the standard call-inference path (`collect_call_labels` /
# `st_propagate_capability_labels`) propagates them into the caller's row,
# exactly as for a stdlib fn written `: T / Stdout`. Empty `effs` degrades to
# `fn_ty`.
fn fn_ty_eff(ps: [Ty], ret: Ty, effs: [String]) : Ty =
  TyFnT(ps, ret, labels_to_closed_row(map(effs, (e) => Label { eff: e, ty_args: [] })))

# open-tail Row for row-polymorphic
# core signatures (each/map/filter/reduce). The row var id
# `rid` matches the scheme's bound rvar; at instantiation time the
# inferencer mints a fresh rvar so labels propagate from callee
# into caller.
fn row_with_tail(rid: Int) : Row = Row {
  labels:        [],
  tail:          Some(rid),
  display_alias: None
}

fn list_ty(t: Ty) : Ty = TyListT(t)

# ---- core signatures ----
#
# Kept in sync with stage 0's runtime and with stdlib/core/*.kai's
# assumptions. Type variables inside a scheme are private to it.

#[doc("infer: `add_core_sigs` — typer entry point invoked by the driver.")]
pub fn add_core_sigs(env: TyEnv) : TyEnv {
  let es = [
    # IO
    TyEntry { name: "print",          scheme: mono(fn_ty_eff([TyString], TyUnit, ["Stdout"])) },
    TyEntry { name: "eprint",         scheme: mono(fn_ty_eff([TyString], TyUnit, ["Stderr"])) },
    # (LSP framing): write_stdout writes a String to stdout
    # verbatim with no trailing newline and flushes. Required by the
    # LSP JSON-RPC framer where the body is exactly Content-Length bytes.
    TyEntry { name: "write_stdout",   scheme: mono(fn_ty_eff([TyString], TyUnit, ["Stdout"])) },
    # bare `args()` reads the process command-line snapshot;
    # per docs/effects-stdlib.md §`Env` the op lives on `Env`. (program_name
    # below is deliberately effect-free — argv[0] is routed through
    # the kai_g_argv snapshot as a pure read of process-wide constant state.)
    TyEntry { name: "args",           scheme: mono(fn_ty_eff([], list_ty(TyString), ["Env"])) },
    # argv[0] as a flat core. Total — empty string
    # when the runtime hasn't seen `kai_set_args` yet.
    TyEntry { name: "program_name",   scheme: mono(fn_ty([], TyString)) },
    TyEntry { name: "stdlib_path",    scheme: mono(fn_ty([], TyString)) },
    TyEntry { name: "abspath",        scheme: mono(fn_ty([TyString], TyString)) },
    TyEntry { name: "read_file",      scheme: mono(fn_ty_eff([TyString], TyCon(None, "Result", [TyString, TyString]), ["File"])) },
    TyEntry { name: "write_file",     scheme: mono(fn_ty_eff([TyString, TyString], TyCon(None, "Result", [TyUnit, TyString]), ["File"])) },
    # fs/file expansion. `file_exists` returns Bool;
    # `file_delete` / `file_rename` return Result[Unit, String] (Ok
    # first). All three carry the `File` effect in their scheme row.
    TyEntry { name: "file_exists",    scheme: mono(fn_ty_eff([TyString], TyBool, ["File"])) },
    TyEntry { name: "file_delete",    scheme: mono(fn_ty_eff([TyString], TyCon(None, "Result", [TyUnit, TyString]), ["File"])) },
    TyEntry { name: "file_rename",    scheme: mono(fn_ty_eff([TyString, TyString], TyCon(None, "Result", [TyUnit, TyString]), ["File"])) },
    # Binary file IO. Both ride the `File` effect in their scheme row.
    # `file_read_bytes` returns Result[Array[Byte], String] so the
    # buffer surface lines up with BinSerialize — cache
    # layers and crypto consumers round-trip bytes (including 0x00)
    # without paying a list-to-array conversion at the boundary.
    # `file_write_bytes` is the symmetric write.
    TyEntry { name: "file_read_bytes",  scheme: mono(fn_ty_eff([TyString], TyCon(None, "Result", [TyCon(None, "Array", [TyByte]), TyString]), ["File"])) },
    TyEntry { name: "file_write_bytes", scheme: mono(fn_ty_eff([TyString, TyCon(None, "Array", [TyByte])], TyCon(None, "Result", [TyUnit, TyString]), ["File"])) },
    # fs/dir surface. list_dir / walk return [String]
    # (cons-list); create_dir / remove_dir return Result[Unit, String]
    # (Ok first). All four carry the `File` effect in their scheme row.
    TyEntry { name: "dir_list_dir",   scheme: mono(fn_ty_eff([TyString], list_ty(TyString), ["File"])) },
    TyEntry { name: "dir_create_dir", scheme: mono(fn_ty_eff([TyString], TyCon(None, "Result", [TyUnit, TyString]), ["File"])) },
    TyEntry { name: "dir_remove_dir", scheme: mono(fn_ty_eff([TyString], TyCon(None, "Result", [TyUnit, TyString]), ["File"])) },
    TyEntry { name: "dir_walk",       scheme: mono(fn_ty_eff([TyString], list_ty(TyString), ["File"])) },
    TyEntry { name: "read_line",      scheme: mono(fn_ty_eff([], TyCon(None, "Result", [TyString, TyString]), ["Stdin"])) },
    # byte-oriented stdin read. Returns a String of at
    # most `n` bytes; on EOF the result is shorter (possibly empty).
    # No Result wrapper — the LSP framing use case treats a short
    # read as end-of-stream.
    TyEntry { name: "read_bytes",     scheme: mono(fn_ty_eff([TyInt], TyString, ["Stdin"])) },
    # `exit` and `panic` never return — give them a polymorphic result so
    # they unify with any context. `exit` rides `Process`;
    # `panic` is an audited runtime escape, not a Process op, so it stays
    # effect-free in its scheme.
    TyEntry { name: "exit",           scheme: scheme([0], fn_ty_eff([TyInt], tv(0), ["Process"])) },
    TyEntry { name: "panic",          scheme: scheme([0], fn_ty([TyString], tv(0))) },

    # Conversions
    TyEntry { name: "int_to_string",  scheme: mono(fn_ty([TyInt],    TyString)) },
    TyEntry { name: "real_to_string", scheme: mono(fn_ty([TyReal],   TyString)) },
    TyEntry { name: "string_to_int",  scheme: mono(fn_ty([TyString], TyCon(None, "Option", [TyInt]))) },
    TyEntry { name: "string_to_real", scheme: mono(fn_ty([TyString], TyCon(None, "Option", [TyReal]))) },
    TyEntry { name: "char_to_int",    scheme: mono(fn_ty([TyChar],   TyInt)) },
    TyEntry { name: "int_to_char",    scheme: mono(fn_ty([TyInt],    TyChar)) },
    # 1-byte raw String constructor (cache codec primitive).
    TyEntry { name: "int_to_byte_string", scheme: mono(fn_ty([TyInt], TyString)) },
    # byte read from String (Int 0..255, -1 on OOB).
    TyEntry { name: "string_byte_at_int", scheme: mono(fn_ty([TyString, TyInt], TyInt)) },
    # UTF-8 codepoint decode. `string_cp_at(s, off)` is the
    # codepoint at byte offset `off` (-1 on OOB); `string_cp_len(s, off)`
    # is its byte width 1..4 (0 on OOB). `string.chars()` walks over them.
    TyEntry { name: "string_cp_at",   scheme: mono(fn_ty([TyString, TyInt], TyInt)) },
    TyEntry { name: "string_cp_len",  scheme: mono(fn_ty([TyString, TyInt], TyInt)) },
    # Codepoint-wise reverse: one pass, one allocation, byte-exact for
    # multibyte UTF-8. Backs `string.reverse`.
    TyEntry { name: "string_reverse", scheme: mono(fn_ty([TyString], TyString)) },
    # Hash protocol backends. `string_hash` is the full-width
    # 64-bit FNV-1a over the bytes; `real_bits` reinterprets a double's
    # IEEE-754 bits as an Int. Both may wrap negative — HashMap
    # normalises to a bucket.
    TyEntry { name: "string_hash", scheme: mono(fn_ty([TyString], TyInt)) },
    TyEntry { name: "real_bits",   scheme: mono(fn_ty([TyReal],   TyInt)) },
    # int_to_real: lossless cast (Int → Real). Used by stdlib/math/real.kai
    # for floor/ceil/round/trunc, which need to round-trip through Int.
    TyEntry { name: "int_to_real",    scheme: mono(fn_ty([TyInt],    TyReal)) },
    # real_to_int: truncating cast toward zero (matches C `(int64_t) r`).
    # NaN, Inf, and out-of-Int64-range values collapse to 0 — see
    # `kai_core_real_to_int` in stage0/runtime.h for the guards.
    TyEntry { name: "real_to_int",    scheme: mono(fn_ty([TyReal],   TyInt)) },

    # Byte nominal primitive. `int_to_u8` range-checks
    # 0..255 and returns `Result[u8, String]` (Ok first).
    # `u8_to_int` is lossless widening. Arithmetic
    # (`u8_add`, `u8_sub`) wraps mod 256 per the C `uint8_t` semantics
    # — overflow is defined, not UB. Comparison ops mirror Int.
    TyEntry { name: "int_to_byte",      scheme: mono(fn_ty([TyInt],            TyCon(None, "Result", [TyByte, TyString]))) },
    TyEntry { name: "byte_to_int",      scheme: mono(fn_ty([TyByte],             TyInt)) },
    TyEntry { name: "byte_add",         scheme: mono(fn_ty([TyByte, TyByte],       TyByte)) },
    TyEntry { name: "byte_sub",         scheme: mono(fn_ty([TyByte, TyByte],       TyByte)) },
    TyEntry { name: "byte_eq",          scheme: mono(fn_ty([TyByte, TyByte],       TyBool)) },
    TyEntry { name: "byte_lt",          scheme: mono(fn_ty([TyByte, TyByte],       TyBool)) },
    TyEntry { name: "byte_to_string",   scheme: mono(fn_ty([TyByte],             TyString)) },

    # Fixed-width integer prims (numeric lane A). `*_to_string` backs the
    # Show impls; `int_to_*` / `*_to_int` are the explicit conversions
    # (truncating into the width, widening back to Int). Arithmetic and
    # comparison ride the `+`/`-`/`*`/`<`/`==` operators directly (the
    # typer keeps fixed-width operands on the raw fast path), so no
    # `*_add`/`*_eq` prims are needed.
    TyEntry { name: "int32_to_string",  scheme: mono(fn_ty([TyInt32],  TyString)) },
    TyEntry { name: "uint32_to_string", scheme: mono(fn_ty([TyUInt32], TyString)) },
    TyEntry { name: "uint64_to_string", scheme: mono(fn_ty([TyUInt64], TyString)) },
    TyEntry { name: "int128_to_string", scheme: mono(fn_ty([TyInt128], TyString)) },
    TyEntry { name: "int_to_int32",     scheme: mono(fn_ty([TyInt], TyInt32)) },
    TyEntry { name: "int_to_uint32",    scheme: mono(fn_ty([TyInt], TyUInt32)) },
    TyEntry { name: "int_to_uint64",    scheme: mono(fn_ty([TyInt], TyUInt64)) },
    TyEntry { name: "int_to_int128",    scheme: mono(fn_ty([TyInt], TyInt128)) },
    TyEntry { name: "int32_to_int",     scheme: mono(fn_ty([TyInt32],  TyInt)) },
    TyEntry { name: "uint32_to_int",    scheme: mono(fn_ty([TyUInt32], TyInt)) },
    TyEntry { name: "uint64_to_int",    scheme: mono(fn_ty([TyUInt64], TyInt)) },
    TyEntry { name: "int128_to_int",    scheme: mono(fn_ty([TyInt128], TyInt)) },

    # libm bindings. IEEE-754 pass-through; inspect with
    # `real_is_nan` / `real_is_inf`. See stage0/runtime.h for the
    # `kai_core_real_*` family.
    TyEntry { name: "real_sqrt",      scheme: mono(fn_ty([TyReal],   TyReal)) },
    TyEntry { name: "real_cbrt",      scheme: mono(fn_ty([TyReal],   TyReal)) },
    TyEntry { name: "real_exp",       scheme: mono(fn_ty([TyReal],   TyReal)) },
    TyEntry { name: "real_log",       scheme: mono(fn_ty([TyReal],   TyReal)) },
    TyEntry { name: "real_log2",      scheme: mono(fn_ty([TyReal],   TyReal)) },
    TyEntry { name: "real_log10",     scheme: mono(fn_ty([TyReal],   TyReal)) },
    TyEntry { name: "real_sin",       scheme: mono(fn_ty([TyReal],   TyReal)) },
    TyEntry { name: "real_cos",       scheme: mono(fn_ty([TyReal],   TyReal)) },
    TyEntry { name: "real_tan",       scheme: mono(fn_ty([TyReal],   TyReal)) },
    TyEntry { name: "real_asin",      scheme: mono(fn_ty([TyReal],   TyReal)) },
    TyEntry { name: "real_acos",      scheme: mono(fn_ty([TyReal],   TyReal)) },
    TyEntry { name: "real_atan",      scheme: mono(fn_ty([TyReal],   TyReal)) },
    TyEntry { name: "real_sinh",      scheme: mono(fn_ty([TyReal],   TyReal)) },
    TyEntry { name: "real_cosh",      scheme: mono(fn_ty([TyReal],   TyReal)) },
    TyEntry { name: "real_tanh",      scheme: mono(fn_ty([TyReal],   TyReal)) },
    TyEntry { name: "real_signum",    scheme: mono(fn_ty([TyReal],   TyReal)) },
    TyEntry { name: "real_is_nan",    scheme: mono(fn_ty([TyReal],   TyBool)) },
    TyEntry { name: "real_is_inf",    scheme: mono(fn_ty([TyReal],   TyBool)) },
    TyEntry { name: "real_pow",       scheme: mono(fn_ty([TyReal, TyReal], TyReal)) },
    TyEntry { name: "real_atan2",     scheme: mono(fn_ty([TyReal, TyReal], TyReal)) },
    TyEntry { name: "real_rem",       scheme: mono(fn_ty([TyReal, TyReal], TyReal)) },

    # Strings
    TyEntry { name: "string_length",  scheme: mono(fn_ty([TyString],                TyInt)) },
    TyEntry { name: "string_concat",  scheme: mono(fn_ty([TyString, TyString],      TyString)) },
    TyEntry { name: "string_concat_all", scheme: mono(fn_ty([list_ty(TyString)],    TyString)) },
    TyEntry { name: "string_join",    scheme: mono(fn_ty([list_ty(TyString), TyString], TyString)) },
    TyEntry { name: "string_slice",   scheme: mono(fn_ty([TyString, TyInt, TyInt],  TyString)) },
    TyEntry { name: "string_split",   scheme: mono(fn_ty([TyString, TyString],      list_ty(TyString))) },
    TyEntry { name: "string_contains",scheme: mono(fn_ty([TyString, TyString],      TyBool)) },
    TyEntry { name: "char_at",        scheme: mono(fn_ty([TyString, TyInt],         TyCon(None, "Option", [TyChar]))) },

    # Lists (monomorphic over element type `0`).
    TyEntry { name: "list_length",    scheme: scheme([0], fn_ty([list_ty(tv(0))],                    TyInt)) },
    TyEntry { name: "list_append",    scheme: scheme([0], fn_ty([list_ty(tv(0)), list_ty(tv(0))],    list_ty(tv(0)))) },
    TyEntry { name: "list_reverse",   scheme: scheme([0], fn_ty([list_ty(tv(0))],                    list_ty(tv(0)))) },

    # Higher-order (element `0`, result `1`).
    # higher-order combinators are row-
    # polymorphic in the callback. The callback's row tail equals
    # the combinator's outer row tail, so a `each(xs, dump_fn)` where
    # `dump_fn : Decl -> Unit / Console` propagates Console back to
    # the calling fn through `each`'s outer row. Without this,
    # row-bearing dump helpers can't be passed to each/map/filter
    # at all.
    TyEntry { name: "map",    scheme: scheme_full([0, 1], [0], TyFnT([list_ty(tv(0)), TyFnT([tv(0)], tv(1), row_with_tail(0))], list_ty(tv(1)), row_with_tail(0))) },
    # `flat_map` pairs with the `||` flat-map-pipe operator.
    # Canonical signature is `([a], (a) -> [b]) -> [b]`; the row-poly
    # callback lets effects in the per-element function flow out
    # through the outer row, mirroring `map`. The `synth_flat_map_pipe`
    # dispatch validates this exact shape before rewriting the pipe.
    TyEntry { name: "flat_map", scheme: scheme_full([0, 1], [0], TyFnT([list_ty(tv(0)), TyFnT([tv(0)], list_ty(tv(1)), row_with_tail(0))], list_ty(tv(1)), row_with_tail(0))) },
    TyEntry { name: "filter", scheme: scheme_full([0],    [0], TyFnT([list_ty(tv(0)), TyFnT([tv(0)], TyBool, row_with_tail(0))], list_ty(tv(0)), row_with_tail(0))) },
    TyEntry { name: "reduce", scheme: scheme_full([0, 1], [0], TyFnT([list_ty(tv(0)), tv(1), TyFnT([tv(1), tv(0)], tv(1), row_with_tail(0))], tv(1), row_with_tail(0))) },
    TyEntry { name: "each",   scheme: scheme_full([0],    [0], TyFnT([list_ty(tv(0)), TyFnT([tv(0)], TyUnit, row_with_tail(0))], TyUnit, row_with_tail(0))) },

    # Opaque mutable arrays.
    TyEntry { name: "array_make",   scheme: scheme([0], fn_ty([TyInt, tv(0)],                                TyCon(None, "Array", [tv(0)]))) },
    # Length-0 array of any element type — the polymorphic empty no
    # `array_make` can build, since `array_make` needs a reified `init`
    # even for n=0. Effect-free (no slot is observably written).
    TyEntry { name: "array_empty",  scheme: scheme([0], fn_ty([],                                            TyCon(None, "Array", [tv(0)]))) },
    TyEntry { name: "array_length", scheme: scheme([0], fn_ty([TyCon(None, "Array", [tv(0)])],                      TyInt)) },
    TyEntry { name: "array_get",    scheme: scheme([0], fn_ty([TyCon(None, "Array", [tv(0)]), TyInt],               tv(0))) },
    # bare `array_set` / `array_grow` (the desugar of `a[i] := v`)
    # raise the `Mutable` demand on the caller's row via their scheme. The
    # provenance-masking pass (`mask_local_mutable_demand`) still drops
    # `Mutable` again when every demand targets a locally-constructed Array —
    # it gates on the label being present and walks the AST by name, so it is
    # agnostic to how the label entered the row. `array_make` / `array_length`
    # / `array_get` stay effect-free (constructor and reads).
    TyEntry { name: "array_set",    scheme: scheme([0], fn_ty_eff([TyCon(None, "Array", [tv(0)]), TyInt, tv(0)], TyCon(None, "Array", [tv(0)]), ["Mutable"])) },
    TyEntry { name: "array_grow",   scheme: scheme([0], fn_ty_eff([TyCon(None, "Array", [tv(0)]), TyInt, tv(0)], TyCon(None, "Array", [tv(0)]), ["Mutable"])) },
    # Vec[T] — the pure value vector. Every op is EFFECT-FREE: `vec_set` /
    # `vec_push` return the result vector instead of mutating a reference,
    # so no `Mutable` demand ever enters the row. The runtime mutates in
    # place only behind the rc==1 uniqueness check, which no witness can
    # observe; a shared vector copies on write.
    TyEntry { name: "vec_make",   scheme: scheme([0], fn_ty([TyInt, tv(0)],                                  TyCon(None, "Vec", [tv(0)]))) },
    TyEntry { name: "vec_empty",  scheme: scheme([0], fn_ty([],                                              TyCon(None, "Vec", [tv(0)]))) },
    TyEntry { name: "vec_length", scheme: scheme([0], fn_ty([TyCon(None, "Vec", [tv(0)])],                          TyInt)) },
    TyEntry { name: "vec_get",    scheme: scheme([0], fn_ty([TyCon(None, "Vec", [tv(0)]), TyInt],                   tv(0))) },
    TyEntry { name: "vec_set",    scheme: scheme([0], fn_ty([TyCon(None, "Vec", [tv(0)]), TyInt, tv(0)],     TyCon(None, "Vec", [tv(0)]))) },
    TyEntry { name: "vec_push",   scheme: scheme([0], fn_ty([TyCon(None, "Vec", [tv(0)]), tv(0)],            TyCon(None, "Vec", [tv(0)]))) },
    TyEntry { name: "vec_slice",  scheme: scheme([0], fn_ty([TyCon(None, "Vec", [tv(0)]), TyInt, TyInt],     TyCon(None, "Vec", [tv(0)]))) },
    TyEntry { name: "vec_tail_from", scheme: scheme([0], fn_ty([TyCon(None, "Vec", [tv(0)]), TyInt],         TyCon(None, "Vec", [tv(0)]))) },
    TyEntry { name: "vec_reserve", scheme: scheme([0], fn_ty([TyInt],                                        TyCon(None, "Vec", [tv(0)]))) },
    TyEntry { name: "vec_from_list", scheme: scheme([0], fn_ty([TyListT(tv(0))],                             TyCon(None, "Vec", [tv(0)]))) },
    # mailbox runtime — type-erased entries (Msg flows
    # through TyAny). The polymorphic surface is in stdlib/actor.kai
    # where `with_mailbox[Msg]` and `Actor[Msg]`'s clauses re-attach
    # the right Msg to send/receive. mailbox_alloc returns a Pid
    # whose Msg type is fresh at the call site (TyAny unifies with
    # whatever the surrounding context expects).
    TyEntry { name: "mailbox_alloc",         scheme: scheme([0], fn_ty([],                                       TyCon(None, "Pid", [tv(0)]))) },
    TyEntry { name: "mailbox_alloc_bounded", scheme: scheme([0], fn_ty([TyInt, TyInt],                            TyCon(None, "Pid", [tv(0)]))) },
    TyEntry { name: "mailbox_send",          scheme: scheme([0], fn_ty([TyCon(None, "Pid", [tv(0)]), tv(0)],           TyUnit)) },
    TyEntry { name: "mailbox_recv",          scheme: scheme([0], fn_ty([TyCon(None, "Pid", [tv(0)])],                  tv(0))) },
    TyEntry { name: "mailbox_recv_timeout",  scheme: scheme([0], fn_ty([TyCon(None, "Pid", [tv(0)]), TyInt],          TyCon(None, "Option", [tv(0)]))) },
    TyEntry { name: "mailbox_free",          scheme: scheme([0], fn_ty([TyCon(None, "Pid", [tv(0)])],                  TyUnit)) },
    # Tier 2 spawn_actor — alloc-without-stamp + reassign owner.
    # Used by stdlib/actor.kai's `spawn_actor` / `spawn_actor_policy`.
    TyEntry { name: "mailbox_alloc_unowned", scheme: scheme([0],    fn_ty([],                                       TyCon(None, "Pid", [tv(0)]))) },
    TyEntry { name: "mailbox_alloc_bounded_unowned", scheme: scheme([0], fn_ty([TyInt, TyInt],                      TyCon(None, "Pid", [tv(0)]))) },
    TyEntry { name: "mailbox_assign_owner",  scheme: scheme([0, 1], fn_ty([TyCon(None, "Pid", [tv(0)]), TyCon(None, "Fiber", [tv(1)])], TyUnit)) },
    TyEntry { name: "spawn_actor_fiber",      scheme: scheme([0, 1], fn_ty([TyCon(None, "Pid", [tv(0)]), tv(1)], TyCon(None, "Fiber", [TyUnit]))) },
    # No `unitless` TyEntry: that escape leaked typer-internal erasure
    # as a callable. The idiomatic equivalents are `print("#{x}")` for
    # output and multiplication by a unit-bearing factor for conversions.
    # `unit_name[u: Measure](x: Real<u>) : String`
    # — compile-time reflection that returns the canonical unit
    # symbol of the dimensioned argument as a String literal. The
    # call lowers to a constant string at the C / LLVM emit step,
    # extracted from the arg's `.ty`. Lets user code build
    # "<value> <unit>" strings without per-unit-specialised protocol
    # impls (which would require a structural change to the impl
    # machinery). When the arg's unit is still a UVar
    # (the protocol-impl-generic case), the empty string is emitted.
    TyEntry { name: "unit_name",
              scheme: scheme_uvars([], [], [0], [""],
                fn_ty([TyDimT(TyReal, UVar(0))], TyString)) },
    # typer-internal erasure of the unit annotation on
    # a dimensioned Real. Polymorphic in the unit-var so the call site
    # can pass `Real<USD>`, `Real<EUR>`, etc. and recover bare `Real`
    # for use with `real_to_string`. Not part of the user-facing
    # surface (the `__` prefix is the convention for compiler-internal
    # names).
    TyEntry { name: "__strip_unit",
              scheme: scheme_uvars([], [], [0], [""],
                fn_ty([TyDimT(TyReal, UVar(0))], TyReal)) },
    # typer-internal unit tag/untag over any carrier, identity at
    # runtime. The mint/erase door for non-literal dimensioned values
    # (`money.of` / `money.amount` route a runtime Decimal in and out
    # of `Decimal<c>`). Kind-agnostic: the unit var takes its kind
    # from the context that binds it.
    TyEntry { name: "__attach_unit",
              scheme: scheme_uvars([0], [], [0], [""],
                fn_ty([tv(0)], TyDimT(tv(0), UVar(0)))) },
    TyEntry { name: "__detach_unit",
              scheme: scheme_uvars([0], [], [0], [""],
                fn_ty([TyDimT(tv(0), UVar(0))], tv(0))) },
    # bit operations on Int as compiler intrinsics. The typer
    # records the signatures here; `emit_call_value` lowers each call
    # to the matching C operator (`<<`, `>>`, `&`, `|`, `^`, `~`)
    # inline — there is no runtime helper. Schemes are monomorphic.
    # `bit_shr` is arithmetic (sign-preserving) to match C's `>>` on
    # signed types; `bit_ushr` casts through `uint64_t` for logical
    # zero-fill. `bit_count` uses `__builtin_popcountll`. `bit_test`
    # is the only op that returns Bool; the rest stay in Int.
    TyEntry { name: "bit_and",    scheme: mono(fn_ty([TyInt, TyInt], TyInt)) },
    TyEntry { name: "bit_or",     scheme: mono(fn_ty([TyInt, TyInt], TyInt)) },
    TyEntry { name: "bit_xor",    scheme: mono(fn_ty([TyInt, TyInt], TyInt)) },
    TyEntry { name: "bit_not",    scheme: mono(fn_ty([TyInt],        TyInt)) },
    TyEntry { name: "bit_shl",    scheme: mono(fn_ty([TyInt, TyInt], TyInt)) },
    TyEntry { name: "bit_shr",    scheme: mono(fn_ty([TyInt, TyInt], TyInt)) },
    TyEntry { name: "bit_ushr",   scheme: mono(fn_ty([TyInt, TyInt], TyInt)) },
    TyEntry { name: "bit_count",  scheme: mono(fn_ty([TyInt],        TyInt)) },
    TyEntry { name: "bit_test",   scheme: mono(fn_ty([TyInt, TyInt], TyBool)) },
    TyEntry { name: "bit_set",    scheme: mono(fn_ty([TyInt, TyInt], TyInt)) },
    TyEntry { name: "bit_clear",  scheme: mono(fn_ty([TyInt, TyInt], TyInt)) },
    TyEntry { name: "bit_toggle", scheme: mono(fn_ty([TyInt, TyInt], TyInt)) }
  ]
  # the in-process libLLVM C-API prims (TyHandle-bearing,
  # native-backend only). Generated from `rcore_table` so the typer
  # scheme cannot drift from the C forwarder + emit dispatch. Dead on
  # any program that does not use the native backend.
  let native_es = native_prim_ty_entries(rcore_table())
  let batch = list_append(es, native_es)
  match ty_env_prepend_batch(batch, env.entries, env.index) {
    TEP(all_entries, idx) ->
      TyEnv { entries: all_entries, fresh: env.fresh, unions: env.unions, constructors: env.constructors, head_owners: env.head_owners, root_fns: env.root_fns, row_kind: env.row_kind,
              index: idx }
  }
}

# Map each raw core prim to its typer entry: a monomorphic function
# scheme over the prim's raw param/return types. The native backend's
# C-API surface is thus typed straight from `rcore_table`.
fn native_prim_ty_entries(table: [RCore]) : [TyEntry] = match table {
  [] -> []
  [RP(name, _, ptys, rty), ...rest] ->
    [TyEntry { name: name, scheme: mono(fn_ty(ptys, rty)) }, ...native_prim_ty_entries(rest)]
}

# ---- built-in variant constructors ----

fn add_builtin_variant_sigs(env: TyEnv) : TyEnv {
  # also register the qualified `Option::Some`,
  # `Option::None`, `Result::Ok`, `Result::Err` keys so that
  # annotation-driven ctor disambiguation in user code can pin a
  # core variant by qualifier when a user type collides with the
  # bare ctor name. Core code itself does not consult these (it
  # uses bare names exclusively); the qualified entries exist only
  # so `ctor_needs_qualification` and `check_expr_against`'s ECall
  # path can route `Result.Ok(x)` and `Response.Ok(x)` to distinct
  # schemes without flipping the bare slot's protection.
  let some_sc = scheme([0],    fn_ty([tv(0)], TyCon(None, "Option", [tv(0)])))
  let none_sc = scheme([0],    TyCon(None, "Option", [tv(0)]))
  let ok_sc   = scheme([0, 1], fn_ty([tv(0)], TyCon(None, "Result", [tv(0), tv(1)])))
  let err_sc  = scheme([0, 1], fn_ty([tv(1)], TyCon(None, "Result", [tv(0), tv(1)])))
  let es = [
    # Bare entries — the load-bearing keys that bare core code uses.
    TyEntry { name: "Some", scheme: some_sc },
    TyEntry { name: "None", scheme: none_sc },
    TyEntry { name: "Ok",   scheme: ok_sc   },
    TyEntry { name: "Err",  scheme: err_sc  },
    # Qualified entries — only the ctor-overloading disambiguation paths read these.
    TyEntry { name: ty_mod_key("Option", "Some"), scheme: some_sc },
    TyEntry { name: ty_mod_key("Option", "None"), scheme: none_sc },
    TyEntry { name: ty_mod_key("Result", "Ok"),   scheme: ok_sc   },
    TyEntry { name: ty_mod_key("Result", "Err"),  scheme: err_sc  }
  ]
  match ty_env_prepend_batch(es, env.entries, env.index) {
    TEP(all_entries, idx) ->
      TyEnv { entries: all_entries, fresh: env.fresh, unions: env.unions, constructors: env.constructors, head_owners: env.head_owners, root_fns: env.root_fns, row_kind: env.row_kind,
              index: idx }
  }
}

# ---- user-defined signatures ----
#
# For each DFn decl add its signature; for each DType of sum-shape add a
# scheme per variant that produces TyCon(_, type_name, [tparams]).

fn tparam_ids_loop(tparams: [String], i: Int, acc: [Int]) : [Int] {
  match tparams {
    [] -> list_reverse(acc)
    [_, ...rest] -> tparam_ids_loop(rest, i + 1, [i, ...acc])
  }
}

fn tparam_ids(tparams: [String]) : [Int] = tparam_ids_loop(tparams, 0, [])

# same as tparam_ids but starts numbering from `start` so a
# nested set of tparams (op-level on top of effect-level) gets a
# disjoint id range.
fn tparam_ids_from(tparams: [String], start: Int) : [Int] = tparam_ids_loop(tparams, start, [])

# split the tparam list into separate type-var and unit-var ID
# lists. Mirrors the kind-aware allocation in mk_tpbinds — bound_vars
# (type pool) get IDs 0..nT-1; bound_uvars (unit pool) get IDs 0..nU-1.
#[doc("infer: `TParamSplit` — driver-facing type.")]
pub type TParamSplit = { tvars: [Int], uvars: [Int] }

#[doc("infer: `tparam_id_split` — typer entry point invoked by the driver.")]
pub fn tparam_id_split(tparams: [String]) : TParamSplit =
  tparam_id_split_loop(tparams, 0, 0, [], [])

# Count how many tparams in `tparams` are unit-kind. Used by
# `infer_decl` to advance the inferencer's unit_fresh counter past
# the impl-level bound uvar ids so freshly minted uvars during body
# type-checking do not alias them.
fn tparam_unit_count(tparams: [String]) : Int =
  tparam_unit_count_loop(tparams, 0)

fn tparam_unit_count_loop(tparams: [String], acc: Int) : Int {
  match tparams {
    [] -> acc
    [n, ...rest] -> {
      let next = if tp_kind_is_unit(n) { acc + 1 } else { acc }
      tparam_unit_count_loop(rest, next)
    }
  }
}

# The kind each unit tparam ranges over, in tparam order — parallel
# to `tparam_id_split`'s uvars, so uvar id i has kind element i.
fn tparam_unit_kinds(tparams: [String]) : [String] =
  tparam_unit_kinds_loop(tparams, [])

fn tparam_unit_kinds_loop(tparams: [String], acc: [String]) : [String] {
  match tparams {
    [] -> list_reverse(acc)
    [n, ...rest] ->
      if tp_kind_is_unit(n) { tparam_unit_kinds_loop(rest, [tp_kind_name(n), ...acc]) }
      else { tparam_unit_kinds_loop(rest, acc) }
  }
}

# build a `[(endpoint_id, bound_id)]` redirect map for
# uvar canonicalisation. For each bound uvar id, chase the
# substitution to find the chain endpoint. If the endpoint is a
# different UVar id, record `(endpoint -> bound)` so subsequent
# walkers can rewrite the body's `Expr.ty` to use the bound id (the
# id the body subst map keys on). If the endpoint resolves to a
# concrete unit (USym / UMul / ...), no redirect is needed — the
# body's `Expr.ty` already pinpoints a non-generic call site.
type IntPair = IPair(Int, Int)

fn build_uvar_canon_map(bound: [Int], sub: Subst, acc: [IntPair]) : [IntPair] {
  match bound {
    [] -> list_reverse(acc)
    [b, ...rest] -> {
      let resolved = apply_unit(sub, UVar(b))
      let acc1 = match resolved {
        UVar(f) -> if f != b { [IPair(f, b), ...acc] } else { acc }
        _ -> acc
      }
      build_uvar_canon_map(rest, sub, acc1)
    }
  }
}

fn build_tvar_canon_map(bound: [Int], sub: Subst, acc: [IntPair]) : [IntPair] {
  match bound {
    [] -> list_reverse(acc)
    [b, ...rest] -> {
      let resolved = apply_ty(sub, TyVarT(b))
      let acc1 = match resolved {
        TyVarT(f) -> if f != b { [IPair(f, b), ...acc] } else { acc }
        _ -> acc
      }
      build_tvar_canon_map(rest, sub, acc1)
    }
  }
}

fn intpair_lookup(ps: [IntPair], k: Int) : Option[Int] {
  match ps {
    [] -> None
    [h, ...rest] -> match h {
      IPair(a, b) -> if a == k { Some(b) } else { intpair_lookup(rest, k) }
    }
  }
}

# Walkers `canon_uvars_*` / `canon_tvars_*` rewrite `Expr.ty` in
# place by replacing `UVar(endpoint)` / `TyVarT(endpoint)` with the
# bound id per the redirect map. Recurse via subst_expr-style
# structural traversal. The map is small (≤ #bound-tparams) so
# linear lookups are cheap.
fn canon_uvars_expr(e: Expr, m: [IntPair]) : Expr {
  let ty1 = match e.ty {
    Some(t) -> Some(canon_uvars_ty(t, m))
    None    -> None
  }
  Expr { kind: canon_uvars_kind(e.kind, m), line: e.line, col: e.col,
         ty: ty1, mode: e.mode }
}

fn canon_uvars_kind(k: ExprKind, m: [IntPair]) : ExprKind {
  inf_map_expr_kind(k, (sub) => canon_uvars_expr(sub, m))
}

fn canon_uvars_ty(t: Ty, m: [IntPair]) : Ty {
  match t {
    TyInt    -> t
    TyReal   -> t
    TyBool   -> t
    TyChar   -> t
    TyString -> t
    TyUnit   -> t
    TyByte     -> t
    TyInt32    -> t
    TyUInt32   -> t
    TyUInt64   -> t
    TyInt128   -> t
    TyHandle   -> t
    TyAny    -> t
    TyVarT(_) -> t
    TyListT(inner) -> TyListT(canon_uvars_ty(inner, m))
    TyFnT(ps, ret, row) -> TyFnT(map(ps, (p) => canon_uvars_ty(p, m)),
                                  canon_uvars_ty(ret, m), canon_uvars_row(row, m))
    TyCon(mo_, name, tas) -> TyCon(mo_, name, map(tas, (a) => canon_uvars_ty(a, m)))
    # the shape var id is a tvar, not a unit var — leave it, recurse arg.
    TyShapeApp(sv, arg) -> TyShapeApp(sv, canon_uvars_ty(arg, m))
    TyDimT(base, u) -> TyDimT(canon_uvars_ty(base, m), canon_uvars_unit(u, m))
    TyRefineT(base, p) -> TyRefineT(canon_uvars_ty(base, m), p)
    # a union's components are unit-vars-free
    # at the top level by construction (the resolver only
    # composes nominal types) but their inner Tys may carry unit
    # vars; recurse and re-normalise so the canonical form survives.
    TyUnion(parts) -> normalize_union(map(parts, (a) => canon_uvars_ty(a, m)))
  }
}

fn canon_uvars_row(r: Row, m: [IntPair]) : Row {
  let new_labels = map(r.labels, (l) => canon_uvars_label(l, m))
  Row { labels: new_labels, tail: r.tail, display_alias: r.display_alias }
}

fn canon_uvars_label(l: Label, m: [IntPair]) : Label =
  Label { eff: l.eff, ty_args: map(l.ty_args, (a) => canon_uvars_ty(a, m)) }

fn canon_uvars_unit(u: UnitExprT, m: [IntPair]) : UnitExprT {
  match u {
    UOne        -> u
    USym(_)     -> u
    UVar(n)     -> match intpair_lookup(m, n) {
      Some(b) -> UVar(b)
      None    -> u
    }
    UMul(a, b)  -> UMul(canon_uvars_unit(a, m), canon_uvars_unit(b, m))
    UInv(a)     -> UInv(canon_uvars_unit(a, m))
    UPow(a, n)  -> UPow(canon_uvars_unit(a, m), n)
    UJoin(a, b) -> UJoin(canon_uvars_unit(a, m), canon_uvars_unit(b, m))
    UDims(us)   -> UDims(canon_uvars_units(us, m))
  }
}

fn canon_uvars_units(us: [UnitExprT], m: [IntPair]) : [UnitExprT] = match us {
  [] -> []
  [u, ...rest] -> [canon_uvars_unit(u, m), ...canon_uvars_units(rest, m)]
}

fn canon_tvars_expr(e: Expr, m: [IntPair]) : Expr {
  let ty1 = match e.ty {
    Some(t) -> Some(canon_tvars_ty(t, m))
    None    -> None
  }
  Expr { kind: canon_tvars_kind(e.kind, m), line: e.line, col: e.col,
         ty: ty1, mode: e.mode }
}

fn canon_tvars_kind(k: ExprKind, m: [IntPair]) : ExprKind {
  inf_map_expr_kind(k, (sub) => canon_tvars_expr(sub, m))
}

fn canon_tvars_ty(t: Ty, m: [IntPair]) : Ty {
  match t {
    TyInt    -> t
    TyReal   -> t
    TyBool   -> t
    TyChar   -> t
    TyString -> t
    TyUnit   -> t
    TyByte     -> t
    TyInt32    -> t
    TyUInt32   -> t
    TyUInt64   -> t
    TyInt128   -> t
    TyHandle   -> t
    TyAny    -> t
    TyVarT(n) -> match intpair_lookup(m, n) {
      Some(b) -> TyVarT(b)
      None    -> t
    }
    TyListT(inner) -> TyListT(canon_tvars_ty(inner, m))
    TyFnT(ps, ret, row) -> TyFnT(map(ps, (p) => canon_tvars_ty(p, m)),
                                  canon_tvars_ty(ret, m), canon_tvars_row(row, m))
    TyCon(mo_, name, tas) -> TyCon(mo_, name, map(tas, (a) => canon_tvars_ty(a, m)))
    TyShapeApp(sv, arg) -> match intpair_lookup(m, sv) {
      Some(b) -> TyShapeApp(b, canon_tvars_ty(arg, m))
      None    -> TyShapeApp(sv, canon_tvars_ty(arg, m))
    }
    TyDimT(base, u) -> TyDimT(canon_tvars_ty(base, m), u)
    TyRefineT(base, p) -> TyRefineT(canon_tvars_ty(base, m), p)
    # see `canon_uvars_ty`. Renumbering tvars
    # inside components can change their `inf_mangle_ty` strings, so
    # we re-normalise to keep the canonical sort order.
    TyUnion(parts) -> normalize_union(map(parts, (a) => canon_tvars_ty(a, m)))
  }
}

fn canon_tvars_row(r: Row, m: [IntPair]) : Row {
  let new_labels = map(r.labels, (l) => canon_tvars_label(l, m))
  Row { labels: new_labels, tail: r.tail, display_alias: r.display_alias }
}

fn canon_tvars_label(l: Label, m: [IntPair]) : Label =
  Label { eff: l.eff, ty_args: map(l.ty_args, (a) => canon_tvars_ty(a, m)) }

# Canonicalise a list of ResolvedCS records by applying the bound-id
# redirect maps to each CS's tys / units. Mirrors the canon_*_expr
# walkers but operates on the per-decl call-site list.
fn canon_resolved_css(css: [ResolvedCS], tv_map: [IntPair],
                       uv_map: [IntPair]) : [ResolvedCS] {
  match css {
    [] -> []
    [cs, ...rest] -> match cs {
      RCS(nm, line, col, tys, units, mo) ->
        [RCS(nm, line, col,
             map(tys, (t) => canon_uvars_ty(canon_tvars_ty(t, tv_map), uv_map)),
             map(units, (u) => canon_uvars_unit(u, uv_map)), mo),
         ...canon_resolved_css(rest, tv_map, uv_map)]
    }
  }
}

fn tparam_id_split_loop(tparams: [String], ti: Int, ui: Int,
                        tacc: [Int], uacc: [Int]) : TParamSplit {
  match tparams {
    [] -> TParamSplit { tvars: list_reverse(tacc), uvars: list_reverse(uacc) }
    [n, ...rest] -> {
      if tp_kind_is_unit(n) {
        tparam_id_split_loop(rest, ti, ui + 1, tacc, [ui, ...uacc])
      } else {
        tparam_id_split_loop(rest, ti + 1, ui, [ti, ...tacc], uacc)
      }
    }
  }
}

# The type-var ids assigned (by `tparam_id_split`'s numbering) to the
# tparams named in `targets`. Used to drop row-kind tparams from the
# generalised type-var set.
fn tparam_type_ids_of(tparams: [String], targets: [String]) : [Int] =
  tparam_type_ids_of_loop(tparams, targets, 0, [])

fn tparam_type_ids_of_loop(tparams: [String], targets: [String], ti: Int, acc: [Int]) : [Int] {
  match tparams {
    [] -> list_reverse(acc)
    [n, ...rest] ->
      if tp_kind_is_unit(n) { tparam_type_ids_of_loop(rest, targets, ti, acc) }
      else {
        let acc1 = if list_has(targets, n) { [ti, ...acc] } else { acc }
        tparam_type_ids_of_loop(rest, targets, ti + 1, acc1)
      }
  }
}

# Remove every id in `drop` from `xs` (order-preserving).
fn remove_ints(xs: [Int], drop: [Int]) : [Int] = match xs {
  [] -> []
  [x, ...rest] ->
    if list_has_int(drop, x) { remove_ints(rest, drop) }
    else { [x, ...remove_ints(rest, drop)] }
}

# Resolve a TypeExpr under a mapping from tparam name to its TyVarT id.
# The mapping is itself an association list for now.
#[doc("infer: a type-parameter binding (name -> fresh id).")]
pub type TPBind = TPB(String, Int)

fn tpbind_lookup(binds: [TPBind], name: String) : Option[Int] {
  match binds {
    [] -> None
    [b, ...rest] -> match b {
      TPB(n, i) -> if n == name { Some(i) } else { tpbind_lookup(rest, name) }
    }
  }
}

#[doc("infer: `resolve_ty_with_tparams` — typer entry point invoked by the driver.")]
pub fn resolve_ty_with_tparams(t: TypeExpr, binds: [TPBind]) : Ty {
  match t.tkind {
    TyName(name, tas) -> {
      match shape_tparam_lookup(binds, name) {
        Some(sid) -> match tas {
          [arg] -> TyShapeApp(sid, resolve_ty_with_tparams(arg, binds))
          _ -> tv(sid)
        }
        None -> match tpbind_lookup(binds, name) {
        Some(i) -> tv(i)
        None -> {
          if name == "Int"    { TyInt }
          else if name == "Real"   { TyReal }
          else if name == "Bool"   { TyBool }
          else if name == "String" { TyString }
          else if name == "Char"   { TyChar }
          else if name == "Unit"   { TyUnit }
          else if name == "Byte"     { TyByte }
          else if is_fixed_width_name(name) { fixed_width_ty_of_name(name) }
          else if is_ffi_fixed_name(name) { ffi_fixed_ty_of_name(name) }
          else if name == "Handle"   { TyHandle }
          # Nothing is the bottom type (used by
          # Fail.fail and Spawn's type-erased ops); the typer treats
          # it as TyAny because it can't witness uninhabitedness.
          # Without this case, Spawn.spawn(thunk: Nothing) refuses
          # any non-Nothing thunk argument. inf_resolve_ty and
          # resolve_ty_with_binds both have this case; it was
          # missing here.
          else if name == "Nothing" { TyAny }
          else { TyCon(None, name, resolve_tas_with(tas, binds)) }
        }
      }
      }
    }
    TyList(inner) -> list_ty(resolve_ty_with_tparams(inner, binds))
    TyFn(ps, ret, _) -> fn_ty(map(ps, (p) => resolve_ty_with_tparams(p, binds)),
                           resolve_ty_with_tparams(ret, binds))
    # dimensioned types in this lighter resolver — without unit
    # tparam bindings — leave UVar references as USym holdovers. Real
    # generic-unit resolution lives in resolve_ty_with_binds below.
    TyDim(base, u) -> dim_collapse(resolve_ty_with_tparams(base, binds), unit_canon(u))
    # preserve refinement on the semantic side.
    TyRefine(base, p) -> TyRefineT(resolve_ty_with_tparams(base, binds), p)
    # a compound row reaching *type* position (not dissolved
    # by alias substitution) — resolve to an undeclared name so the
    # natural "unknown type" cascade reports it.
    TyRow(_) -> TyCon(None, "__row_in_type_position__", [])
  }
}

fn resolve_tas_with(tas: [TypeExpr], binds: [TPBind]) : [Ty] =
  map(tas, (t) => resolve_ty_with_tparams(t, binds))

# Build the TPBind list for a decl's generic type parameters.
# type-kind and unit-kind params allocate IDs from *separate*
# pools (type-var pool for KType, unit-var pool for KUnit). Without
# this split a `[u: Unit, T]` decl would conflate type-var 1 with
# unit-var 1 across instantiation passes.
fn mk_tpbinds_loop(tparams: [String], ti: Int, ui: Int, acc: [TPBind]) : [TPBind] {
  match tparams {
    [] -> list_reverse(acc)
    [n, ...rest] -> {
      if tp_kind_is_unit(n) {
        mk_tpbinds_loop(rest, ti, ui + 1, [TPB(n, ui), ...acc])
      } else {
        mk_tpbinds_loop(rest, ti + 1, ui, [TPB(n, ti), ...acc])
      }
    }
  }
}

fn mk_tpbinds(tparams: [String]) : [TPBind] = mk_tpbinds_loop(tparams, 0, 0, [])

# same as mk_tpbinds but starts ids at `start`. Used to
# combine effect-level and op-level tparams into a single binding
# context with disjoint ids.
fn mk_tpbinds_from(tparams: [String], start: Int) : [TPBind] = mk_tpbinds_loop(tparams, start, 0, [])

fn append_tpbinds(a: [TPBind], b: [TPBind]) : [TPBind] {
  match a {
    [] -> b
    [h, ...rest] -> [h, ...append_tpbinds(rest, b)]
  }
}

fn append_ints(a: [Int], b: [Int]) : [Int] {
  match a {
    [] -> b
    [h, ...rest] -> [h, ...append_ints(rest, b)]
  }
}

# An effect row occupying a `TyCon` argument slot. The row has no
# runtime witness — it is a `TyFnT([], TyUnit, row)` carrier so every
# existing `Ty` walker handles it (mangling erases the row, so two
# `Stream[t, e]` differing only in `e` share one monomorphisation),
# and unifying two carriers routes the row to `unify_row` via the
# `TyFnT` arm. Keyed on a row-var id shared with the ctor field's row.
fn row_arg_carrier(r: Row) : Ty = TyFnT([], TyUnit, r)

# The head `TyCon`'s slot for declared-tparam id `i`: a row carrier
# when `i` is a row-kind tparam, an ordinary type-var slot otherwise.
fn head_slot_for(i: Int, rvar_ids: [Int]) : Ty =
  if list_has_int(rvar_ids, i) { row_arg_carrier(row_with_tail(i)) } else { tv(i) }

# Which slots of a nominal type are effect-row-kind. `RKE(name, [idx])`
# lists the zero-based tparam positions a `pub type` declares in row
# position (a tparam that appears after `/` inside some ctor field).
# A use-site `T[..., e, ...]` consults this so the `e` slot resolves to
# a row carrier even when the surrounding fn never mentions `e` after a
# `/` — the `from_list[t,e](xs:[t]) : Stream[t,e]` case, where the row
# var is sourced, not threaded from an argument.
pub type RowKindEntry = RKE(String, [Int])

# Build the per-type row-kind-slot table from the whole decl stream.
fn compute_row_kind_slots(decls: [Decl]) : [RowKindEntry] {
  match decls {
    [] -> []
    [d, ...rest] -> match row_kind_entry_of(d) {
      Some(e) -> [e, ...compute_row_kind_slots(rest)]
      None    -> compute_row_kind_slots(rest)
    }
  }
}

fn row_kind_entry_of(d: Decl) : Option[RowKindEntry] = match d {
  DType(_, name, tparams, body, _, _, _, _) -> {
    let row_names = row_names_of_typebody(body)
    match row_names {
      [] -> None
      _  -> Some(RKE(name, row_kind_indices(tparams, row_names, 0)))
    }
  }
  _ -> None
}

# Names a type body uses in row position across all its ctor fields.
fn row_names_of_typebody(b: TypeBody) : [String] = match b {
  TBSum(vs)    -> row_names_of_variants(vs, [])
  TBRecord(fs) -> row_names_of_fields(fs, [])
  _            -> []
}

fn row_names_of_variants(vs: [Variant], acc: [String]) : [String] = match vs {
  [] -> acc
  [v, ...rest] -> match v {
    Var(_, vargs) -> row_names_of_variants(rest, collect_rvars_in_typeexprs(vargs, acc))
  }
}

fn row_names_of_fields(fs: [FieldDecl], acc: [String]) : [String] = match fs {
  [] -> acc
  [f, ...rest] -> match f {
    FD(_, _, te) -> row_names_of_fields(rest, collect_rvars_in_typeexpr(te, acc))
  }
}

# The zero-based positions in `tparams` whose name appears in `row_names`.
fn row_kind_indices(tparams: [String], row_names: [String], i: Int) : [Int] = match tparams {
  [] -> []
  [n, ...rest] ->
    if list_has(row_names, n) { [i, ...row_kind_indices(rest, row_names, i + 1)] }
    else { row_kind_indices(rest, row_names, i + 1) }
}

# Row-kind slot indices declared for `name`, or [] if the type declares none.
fn row_kind_slots_of(table: [RowKindEntry], name: String) : [Int] = match table {
  [] -> []
  [e, ...rest] -> match e {
    RKE(n, idxs) -> if n == name { idxs } else { row_kind_slots_of(rest, name) }
  }
}

# Reject a nominal type whose ctor field uses an effect-row variable
# the type never declares as a tparam (`type Q[t] = Qq((t) -> Unit / e)`
# with `e` absent from `[t]`). Without this the scheme builder panics in
# `tpbind_id_of` — an unbound row var has no slot to thread through. The
# fix the user wants is to declare the row var: `type Q[t, e] = ...`.
#[doc("infer: `validate_nominal_row_vars_decls` — typer entry point invoked by the driver.")]
pub fn validate_nominal_row_vars_decls(decls: [Decl], file: String) : Int / Console + File =
  validate_nominal_row_vars_loop(decls, file, 0)

fn validate_nominal_row_vars_loop(decls: [Decl], file: String, errs: Int) : Int / Console + File {
  match decls {
    [] -> errs
    [d, ...rest] -> validate_nominal_row_vars_loop(rest, file, errs + validate_nominal_row_vars_decl(d, file))
  }
}

fn validate_nominal_row_vars_decl(d: Decl, file: String) : Int / Console + File = match d {
  DType(_, _, tparams, body, line, col, _, _) -> {
    let free = names_excluding(row_names_of_typebody(body), tparams)
    match free {
      [] -> 0
      [name, ...__] -> {
        diag_error(file, line, col,
          concat_all(["unbound effect-row variable `", name,
            "` in type declaration — declare it as a type parameter ",
            "(`[..., ", name, "]`) so the carrier can thread the row"]))
        1
      }
    }
  }
  _ -> 0
}

fn scheme_of_variant(type_name: String, tparams: [String], v: Variant) : TyScheme {
  match v {
    Var(_ctor_name, vargs) -> {
      # A tparam that appears in *row* position inside a ctor field
      # (e.g. `Stream[t, e] = Stream(((t) -> Bool / e) -> Unit / e)`)
      # must be resolved as a row variable, not a type variable —
      # otherwise the field's effect row is dropped and any effectful
      # producer fails to unify (the bug behind the nominal Stream
      # carrier). We split the declared tparams: those used in row
      # position become `rbinds` (resolved via `resolve_ty_with_binds`,
      # which preserves `TyFn` rows); the rest stay type-level `binds`.
      let rvar_names = collect_rvars_in_typeexprs(vargs, [])
      let tvar_names = names_excluding(tparams, rvar_names)
      let binds = mk_tpbinds(tparams)
      # The row-var binds REUSE the ids `mk_tpbinds` already assigned to
      # each name (rather than re-numbering from zero with `mk_rvbinds`):
      # if `e` is the second tparam it has tpbind id 1, and the rbind for
      # `e` must carry that same 1. Otherwise a stray `e` in *type*
      # position would resolve via `binds` to `tv(1)` — an id that is in
      # neither `vars` nor `rvars`, leaving an ungeneralised free type-var
      # in the scheme. Type-var ids (for `tvar_names`) and row-var ids
      # (for `rvar_names`) are disjoint by construction, so the
      # type-pool / row-pool substitutions never collide.
      let rbinds = map(rvar_names, (n) => RVB(n, tpbind_id_of(binds, n)))
      let arg_tys = map(vargs, (a) => resolve_ty_with_binds(a, binds, rbinds))
      # The result `TyCon` carries one type-arg slot per declared tparam,
      # in declaration order, so use-site unification lines up positionally.
      # A row-kind tparam's slot carries its effect row as a degenerate
      # `TyFnT([], TyUnit, row)` keyed on the SAME row-var id the ctor
      # field's `/ e` uses, so unifying the head slot threads the row (the
      # bug behind the nominal Stream carrier was that the slot was a `tv`
      # disjoint from that row id — the effect leaked uncheck).
      let ids = tparam_ids(tparams)
      let tvar_ids = map(tvar_names, (n) => tpbind_id_of(binds, n))
      let rvar_ids = map(rvar_names, (n) => tpbind_id_of(binds, n))
      let result = TyCon(None, type_name, map(ids, (i) => head_slot_for(i, rvar_ids)))
      match vargs {
        [] -> scheme(ids, result)
        _  -> scheme_full(tvar_ids, rvar_ids, fn_ty(arg_tys, result))
      }
    }
  }
}

# Look up the type-var id assigned to a tparam name in its TPBind list.
# A miss is a compiler bug: every name passed here comes from `tparams`,
# which `mk_tpbinds` binds in full — so panic rather than fabricate a
# bogus id that would leak an ungeneralised type-var into the scheme.
fn tpbind_id_of(binds: [TPBind], name: String) : Int =
  match tpbind_lookup(binds, name) {
    Some(i) -> i
    None    -> panic("tpbind_id_of: tparam not in binds: #{name}")
  }

# Return the names in `xs` that are not present in `drop` (order-preserving).
# Used to separate a ctor's type-kind tparams from its row-kind ones.
fn names_excluding(xs: [String], drop: [String]) : [String] {
  match xs {
    [] -> []
    [h, ...rest] ->
      if list_has(drop, h) { names_excluding(rest, drop) }
      else { [h, ...names_excluding(rest, drop)] }
  }
}

fn add_variants_of_decl(env: TyEnv, d: Decl, top_names: [String]) : TyEnv {
  match d {
    DType(_, tname, tparams, body, _, _, _, _) -> match body {
      TBSum(vs) -> add_variants_loop(env, tname, tparams, vs, top_names)
      _ -> env
    }
    _ -> env
  }
}

# when a variant name `cname` shadows an already-declared
# top-level type, skip the zero-arg constructor registration. The
# pre-declared decl is the canonical handle; re-registering it as a
# variant of `tname` would create a constructor scheme returning
# `tname` — confusing for value-position lookups (a user typing
# `Color` as an expression in a `Mixed`-expecting hole would resolve
# to the ctor instead of failing cleanly). The component relationship
# is still recorded in `env.unions` so `variants_of_type` and the D3
# upcast keep working through `union_components_of`.
# The skip only kicks in when the variant carries no payload; a
# payload-bearing variant `Foo(Int)` still needs its constructor
# scheme even if `Foo` is also a type, since pattern matching there
# goes through the variant-as-callable path.
fn add_variants_loop(env: TyEnv, tname: String, tparams: [String],
                       vs: [Variant], top_names: [String]) : TyEnv {
  match vs {
    [] -> env
    [v, ...rest] -> match v {
      Var(cname, vargs) -> {
        let shadows = match vargs {
          [] -> list_has(top_names, cname)
          _  -> false
        }
        if shadows {
          add_variants_loop(env, tname, tparams, rest, top_names)
        } else {
          let sc = scheme_of_variant(tname, tparams, v)
          # Ctor overloading at use sites: always
          # register the qualified `<tname>::<cname>` key so disambiguation
          # at match / annotated construction sites can pick this variant
          # explicitly. The bare `cname` key is ALSO added unless a core
          # builtin already occupies it (Ok/Err/Some/None) — in that case
          # the bare slot is left protecting the core, and resolution
          # of `cname` in user code must come through the qualified key
          # (driven by scrutinee or annotation context) or via the
          # explicit `<tname>.<cname>` syntax. Same-arity user-vs-user
          # bare collisions still prepend (legacy behavior); the
          # cross-module case is handled by the qualified key.
          let env_q = ty_env_add(env, ty_mod_key(tname, cname), sc)
          let env2 = if bare_is_core_builtin_variant(env_q, cname) {
            env_q
          } else {
            ty_env_add(env_q, cname, sc)
          }
          add_variants_loop(env2, tname, tparams, rest, top_names)
        }
      }
    }
  }
}

# is the bare `cname` slot currently occupied by a
# core builtin variant constructor (Ok/Err/Some/None from
# `add_builtin_variant_sigs`)? Used by `add_variants_loop` to decide
# whether registering a user variant under bare `cname` would clobber a
# core entry — in which case we keep the core bare entry and rely
# on qualified-key resolution for the user variant. The check looks at
# the scheme's return tycon name: only Result / Option builtin schemes
# are protected.
fn bare_is_core_builtin_variant(env: TyEnv, cname: String) : Bool {
  match ty_env_lookup(env, cname) {
    None -> false
    Some(sc) -> match extract_return_tycon(sc) {
      Some(t) -> t == "Result" or t == "Option"
      None -> false
    }
  }
}

# === TyUnion construction + D2 collision check ===
#
# Walk every `type T = A | B | ...` declaration and construct the
# corresponding `TyUnion(components)`. The TyCon + variant-table
# representation drives pattern matching, codegen, and protocol
# dispatch; the union view is a parallel structure plus a user-visible
# D2 collision diagnostic.
#
# Components resolve as `TyCon(_, component_name, [])` — opaque nominal
# types. `resolve_ty_with_tparams` accepts any uppercase name as a
# TyCon, so a downstream `: ColorRed` annotation works through the same
# path as `: Color`. The resolver does not synthesise new `DType`
# decls; the variant constructor entry registered by `add_variants_loop`
# is the runtime value, and the `TyCon(_, name, [])` form is the
# type-level handle.

# `UnionInfo` is declared near `TyEnv`. The helpers below populate and
# consume it.

fn collect_unions(ds: [Decl]) : [UnionInfo] = collect_unions_loop(ds, [])

fn collect_unions_loop(ds: [Decl], acc: [UnionInfo]) : [UnionInfo] {
  match ds {
    [] -> list_reverse(acc)
    [d, ...rest] -> match d {
      DType(_, name, _, body, line, col, _, _) -> match body {
        TBSum(vs) -> {
          let comps = variants_to_component_tys(vs)
          collect_unions_loop(rest, [UI(name, comps, line, col), ...acc])
        }
        _ -> collect_unions_loop(rest, acc)
      }
      _ -> collect_unions_loop(rest, acc)
    }
  }
}

# Each `Var(cname, _)` becomes the type `TyCon(_, cname, [])` — a
# nominal handle for the component. The variant payload is erased at
# the type level: the parent's TyCon-result is what makes
# payload-bearing variants type-check. Singleton unions collapse to the
# bare component (per `normalize_union`).
fn variants_to_component_tys(vs: [Variant]) : [Ty] {
  match vs {
    [] -> []
    [v, ...rest] -> match v {
      Var(cname, _) -> [TyCon(None, cname, []), ...variants_to_component_tys(rest)]
    }
  }
}

# Lift a `UnionInfo` into the canonical `Ty` shape.
# `normalize_union` flattens, sorts, and dedups, so two source
# declarations with reordered or duplicated components yield equal
# `Ty` values — D6 algebraic laws.
fn union_info_to_ty(u: UnionInfo) : Ty {
  match u { UI(_, comps, _, _) -> normalize_union(comps) }
}

# Component names listed in declaration order, dropping payload.
# Returned as plain strings so callers can `list_has` directly.
fn union_info_component_names(u: UnionInfo) : [String] {
  match u { UI(_, comps, _, _) -> ty_names(comps) }
}

fn ty_names(ts: [Ty]) : [String] {
  match ts {
    [] -> []
    [t, ...rest] -> match t {
      TyCon(_, n, _) -> [n, ...ty_names(rest)]
      _           -> ty_names(rest)
    }
  }
}

# Look up the components of a union by parent name.
fn union_components_of(unions: [UnionInfo], parent: String) : [String] {
  match unions {
    [] -> []
    [u, ...rest] -> match u {
      UI(name, _, _, _) -> if name == parent {
        union_info_component_names(u)
      } else {
        union_components_of(rest, parent)
      }
    }
  }
}

# Reverse lookup: which parent unions list `child` as a component?
# Identifies a found type's component-of-origin.
fn union_parents_of(unions: [UnionInfo], child: String) : [String] =
  union_parents_of_loop(unions, child, [])

fn union_parents_of_loop(unions: [UnionInfo], child: String, acc: [String]) : [String] {
  match unions {
    [] -> list_reverse(acc)
    [u, ...rest] -> match u {
      UI(name, _, _, _) -> if list_has(union_info_component_names(u), child) {
        union_parents_of_loop(rest, child, [name, ...acc])
      } else {
        union_parents_of_loop(rest, child, acc)
      }
    }
  }
}

# === D2: name-collision error semantics ===
#
# `type A = Foo | Bar` and `type B = Foo | Baz` are both attempting
# to *implicitly declare* a nominal type `Foo`. D2 says: refuse, and
# instruct the user to pre-declare `type Foo = ...` once and
# reference it from both unions.
#
# Detection rule:
#   - Walk every `TBSum` decl in source order.
#   - For each variant name `v`:
#       - If `v` is the name of *some* `DType` in the program (any
#         shape — record, sum, alias, effect-alias), it is
#         pre-declared. The TBSum *references* it. No error.
#       - Else if `v` was already claimed by an EARLIER `TBSum` decl
#         with a *different* parent name, that's D2 — emit an error
#         pointing at the current decl, with a note pointing at the
#         earlier one and a hint to pre-declare.
#       - Else record the claim and continue.
#   - `A | A` (same parent claiming `A` twice) is D6 idempotence,
#     not D2 — `normalize_union` collapses the duplicate, no error.

type VariantClaim = VC(String, String, Int, Int)
#                       ^vname  ^parent ^line ^col   (line/col of the
#                                                     claiming TBSum)

# Names of every top-level `DType` in the program. Record /
# alias / effect-alias names count: pre-declaring `type Foo = { ... }`
# and then writing `type A = Foo | Bar` is an explicit reference,
# not an implicit declaration.
fn collect_top_type_names(ds: [Decl]) : [String] = collect_top_type_names_loop(ds, [])

fn collect_top_type_names_loop(ds: [Decl], acc: [String]) : [String] {
  match ds {
    [] -> list_reverse(acc)
    [d, ...rest] -> match d {
      DType(_, name, _, _, _, _, _, _) -> collect_top_type_names_loop(rest, [name, ...acc])
      _ -> collect_top_type_names_loop(rest, acc)
    }
  }
}

# Find the first claim of `vname` whose parent differs from `parent`.
# Same-parent claims are not collisions (D6 idempotence; the union
# normalises to a singleton).
fn find_other_claim(claims: [VariantClaim], vname: String, parent: String) : Option[VariantClaim] {
  match claims {
    [] -> None
    [c, ...rest] -> match c {
      VC(n, p, _, _) -> {
        if n == vname and p != parent { Some(c) }
        else { find_other_claim(rest, vname, parent) }
      }
    }
  }
}

# Public entry: validate every TBSum's variants against earlier
# claims. Returns the count of D2 errors (0 means clean). Plumbed
# into `compile_source` next to `pred_errs` and `var_use_errs`.
#[doc("infer: `validate_union_collisions_decls` — typer entry point invoked by the driver.")]
pub fn validate_union_collisions_decls(ds: [Decl], file: String,
                                     module_table: [ModuleEntry]) : Int / Console + File {

  let top_names = collect_top_type_names(ds)
  # D2 only governs root-file unions. `target_mod` is the root file's
  # stamped module_origin (`tag_target_decls_module_origin`); a DType
  # whose origin differs belongs to a core/imported module and must
  # not participate — a user union reusing a core type's variant name
  # is ctor overloading resolved at use sites, not a collision.
  let target_mod = inf_core_module_name(file)
  # pre-seed the claim table with the builtin variant
  # constructors registered by `add_builtin_variant_sigs` (Result.Ok,
  # Result.Err, Option.Some, Option.None). A user `pub type T = Ok(...)`
  # would otherwise overwrite the bare `Ok` entry in the TyEnv —
  # because `add_variants_loop` prepends the user scheme — and silently
  # break every core site that constructs `Result.Ok`. Catching the
  # collision here gives a precise diagnostic at the user's DType
  # instead of a cascade of unrelated type-mismatch errors pointing at
  # nonexistent line numbers in the user file.
  validate_union_collisions_loop(ds, top_names, file, module_table, target_mod, 0,
                                   builtin_variant_claims())
}

# A decl's `module_origin` marks it as belonging to the root file when
# it is unstamped (`None`) or stamped with the root module's own name.
fn is_root_decl_origin(origin: Option[String], target_mod: String) : Bool =
  match origin {
    None    -> true
    Some(m) -> m == target_mod
  }

# locate the source file that exports `type_name`. Walks
# the module table built by `expand_imports`; the entry's `origin`
# field is the absolute path on disk. Falls back to the root file when
# no module exports the type (top-level user decl in the entry file
# itself). Returns the resolved path so diagnostics for a colliding
# DType point at the file that declared it, not at the root file
# whose line numbers don't match.
fn resolve_decl_file(type_name: String, root_file: String,
                       mt: [ModuleEntry]) : String {
  match mt {
    [] -> root_file
    [me, ...rest] -> match me {
      ME(_, exports, origin, _) ->
        if list_has(exports, type_name) { origin }
        else { resolve_decl_file(type_name, root_file, rest) }
    }
  }
}

# builtin variant constructors that share a top-level
# namespace with user-declared variants. Mirrors the entries injected
# by `add_builtin_variant_sigs`. Kept in sync manually — both lists
# are short and stable.
fn builtin_variant_claims() : [VariantClaim] {
  [
    VC("Some", "Option", 0, 0),
    VC("None", "Option", 0, 0),
    VC("Ok",   "Result", 0, 0),
    VC("Err",  "Result", 0, 0)
  ]
}

fn validate_union_collisions_loop(remaining: [Decl], top_names: [String],
                                    file: String, mt: [ModuleEntry],
                                    target_mod: String, errs: Int,
                                    claims: [VariantClaim]) : Int / Console + File {

  match remaining {
    [] -> errs
    [d, ...rest] -> match d {
      # Only root-file unions seed and test claims. A `type` from the
      # core/imported modules sharing a variant name with a user union
      # is ctor overloading resolved at use sites, not a D2 collision —
      # registering its variants would reject a valid program (e.g.
      # user `type Status = Exited(Int) | Signaled(Int)` vs core
      # `os.Exit = Exited(Int) | Signaled(Int)`).
      DType(_, parent, _, body, line, col, origin, _) ->
        if is_root_decl_origin(origin, target_mod) {
          match body {
            TBSum(vs) -> {
              let decl_file = resolve_decl_file(parent, file, mt)
              let r = check_variants_for_collision(vs, parent, line, col,
                                                      top_names, claims, decl_file, errs)
              validate_union_collisions_loop(rest, top_names, file, mt, target_mod, r.errs, r.claims)
            }
            _ -> validate_union_collisions_loop(rest, top_names, file, mt, target_mod, errs, claims)
          }
        } else {
          validate_union_collisions_loop(rest, top_names, file, mt, target_mod, errs, claims)
        }
      _ -> validate_union_collisions_loop(rest, top_names, file, mt, target_mod, errs, claims)
    }
  }
}

type CollisionResult = { errs: Int, claims: [VariantClaim] }

fn check_variants_for_collision(vs: [Variant], parent: String, line: Int, col: Int,
                                  top_names: [String], claims: [VariantClaim],
                                  decl_file: String, errs: Int) : CollisionResult / Console + File {

  match vs {
    [] -> CollisionResult { errs: errs, claims: claims }
    [v, ...rest] -> match v {
      Var(vname, _) -> {
        if list_has(top_names, vname) {
          # `vname` is pre-declared as a top-level type. The TBSum
          # references it; no implicit declaration, no D2.
          check_variants_for_collision(rest, parent, line, col,
                                          top_names, claims, decl_file, errs)
        } else {
          match find_other_claim(claims, vname, parent) {
            Some(prev) -> {
              # claims pre-seeded by
              # `builtin_variant_claims` carry sentinel line/col 0;
              # render them with a builtin-specific message instead of
              # the generic "declared by both ..." that points at the
              # nonexistent file:0:0.
              #
              # Ctor overloading at use sites: 
              # the builtin-collision case is now ALLOWED. A user
              # `pub type Response = Ok(String) | ...` no longer trips
              # an upfront rejection; ambiguity surfaces at use sites
              # only (via scrutinee-driven and annotation-driven
              # resolution, and a dedicated diagnostic for the
              # genuinely bare unannotated use). The D2 same-file
              # user-vs-user collision still fires.
              match prev {
                VC(_, _, 0, 0) ->
                  # Builtin collision — registration is safe because
                  # `add_variants_loop` keeps the core bare entry
                  # and only adds the user variant under its qualified
                  # key. Continue without bumping err count.
                  check_variants_for_collision(rest, parent, line, col,
                                                  top_names, claims, decl_file, errs)
                _ -> {
                  report_d2_collision(decl_file, vname, parent, line, col, prev)
                  check_variants_for_collision(rest, parent, line, col,
                                                  top_names, claims, decl_file, errs + 1)
                }
              }
            }
            None -> {
              let nc = VC(vname, parent, line, col)
              check_variants_for_collision(rest, parent, line, col,
                                              top_names, [nc, ...claims], decl_file, errs)
            }
          }
        }
      }
    }
  }
}

# collision between a user-declared variant and a builtin
# constructor of `Result` / `Option`. Distinct from D2 because the
# earlier claim has no source location — the builtin's "definition"
# lives inside `add_builtin_variant_sigs`, not in any .kai file. The
# message names both unions and tells the user to rename.
fn report_builtin_collision(file: String, vname: String, parent: String,
                              line: Int, col: Int, builtin_parent: String) : Unit / Console + File {

  let msg = concat_all(["constructor '", vname,
                        "' in 'type ", parent,
                        " = ...' collides with the built-in constructor '",
                        vname, "' of '", builtin_parent, "'"])
  diag_error(file, line, col, msg)
  diag_help(concat_all(["rename the variant (e.g. '", vname, "Value') so it does not shadow '",
                         builtin_parent, ".", vname, "'"]))
}

# Render the D2 diagnostic. The first line names the offending
# component and points at the *current* decl (the second site to
# claim the name); the note points at the *earlier* decl; the hint
# tells the user how to fix it. The wording matches the spec in the
# lane brief verbatim modulo file paths.
fn report_d2_collision(file: String, vname: String, parent: String,
                        line: Int, col: Int, prev: VariantClaim) : Unit / Console + File {
  match prev {
    VC(_, prev_parent, prev_line, prev_col) -> {
      let msg = concat_all(["type '", vname,
                            "' is declared by both 'type ",
                            prev_parent,
                            " = ...' (",
                            file, ":",
                            int_to_string(prev_line), ":",
                            int_to_string(prev_col),
                            ") and 'type ",
                            parent,
                            " = ...' (",
                            file, ":",
                            int_to_string(line), ":",
                            int_to_string(col),
                            ")"])
      diag_error(file, line, col, msg)
      diag_help(concat_all(["pre-declare 'type ", vname,
                             " = ...' once and reference it from both unions"]))
    }
  }
}

# type-name collisions across module boundaries.
#
# Two related contracts. Both rejected up front instead of letting
# resolution pick one definition non-deterministically and emit
# downstream errors that name constructors the user never wrote.
#
#   (a) A user `type T = ...` whose name `T` is already exported by
#       a core or imported module. Without this check the typer's
#       variant lookup walks both definitions and reports `match` arms
#       as non-exhaustive against the *other* file's constructors.
#       This validator closes the type-name path for `pub type`
#       exported by any module in the table — auto-loaded cores
#       and explicit `import` lines alike.
#
#   (b) Two `type T = ...` declarations in the SAME root file.
#       Stage 2 silently accepts; the typer picks one nondeterm-
#       inistically. Rejecting at the second occurrence keeps the
#       diagnostic local.
#
# Diagnostic always points at the *user's* DType (the second site
# to claim the name): `path` is the root file, line/col come from
# the offending DType. The first claimant is named in the message
# either by its module name (case a) or by its earlier line/col
# (case b).
#
# Approach mirrors `validate_union_collisions_decls`: a small walker
# over `root_only_decls`, two helper lookups against `module_table`
# (case a) and an in-flight claim list (case b). No interaction with
# the typer or pattern-exhaustiveness — that machinery keeps working
# under the assumption that one type name resolves to one definition,
# which is exactly what this validator enforces.

type TypeNameClaim = TNC(String, Int, Int)

#[doc("infer: `validate_type_name_collisions_decls` — typer entry point invoked by the driver.")]
pub fn validate_type_name_collisions_decls(root_decls: [Decl], file: String) : Int / Console + File {

  validate_type_name_collisions_loop(root_decls, file, [], 0)
}

fn validate_type_name_collisions_loop(remaining: [Decl], file: String,
                                         claims: [TypeNameClaim],
                                         errs: Int) : Int / Console + File {

  match remaining {
    [] -> errs
    [d, ...rest] -> match d {
      DType(_, name, _, _, line, col, _, _) ->
        validate_one_type_decl(rest, file, claims, errs, name, line, col)
      DDerive(_, inner, _, _) -> match inner {
        DType(_, name, _, _, line, col, _, _) ->
          validate_one_type_decl(rest, file, claims, errs, name, line, col)
        _ -> validate_type_name_collisions_loop(rest, file, claims, errs)
      }
      DUnstable(inner, _, _) -> match inner {
        DType(_, name, _, _, line, col, _, _) ->
          validate_one_type_decl(rest, file, claims, errs, name, line, col)
        _ -> validate_type_name_collisions_loop(rest, file, claims, errs)
      }
      DProtoLaws(_, inner, _, _) -> validate_type_name_collisions_loop(rest, file, claims, errs)
      DImplAxiom(_, inner, _, _) -> validate_type_name_collisions_loop(rest, file, claims, errs)
      DConstructor(inner, _, _) -> validate_type_name_collisions_loop(rest, file, claims, errs)
      _ -> validate_type_name_collisions_loop(rest, file, claims, errs)
    }
  }
}

fn validate_one_type_decl(rest: [Decl], file: String,
                             claims: [TypeNameClaim], errs: Int,
                             name: String, line: Int, col: Int) : Int / Console + File {

  if list_has(reserved_builtin_type_names(), name) {
    diag_error(file, line, col,
      concat_all(["type '", name,
                  "' is a reserved builtin type name and cannot be redeclared"]))
    diag_help(concat_all(["rename the local type (e.g. '", name,
                          "2'); '", name, "' is reserved by the language"]))
    validate_type_name_collisions_loop(rest, file,
                                          [TNC(name, line, col), ...claims],
                                          errs + 1)
  } else {
  match find_type_name_claim(claims, name) {
    Some(prev) -> {
      report_dup_type_decl(file, name, line, col, prev)
      validate_type_name_collisions_loop(rest, file, claims, errs + 1)
    }
    # Hanga Roa: cross-module type-name "collision" with a core /
    # core / imported module is NOT an error — it is shadowing,
    # which every serious language with scoped identifiers permits.
    # A user `type Pair = { fst: Int, snd: Int }` in their root file
    # is welcome to coexist with `core.tuple.Pair[a, b]`: inside the
    # user's archivo the local definition wins; the imported one
    # stays reachable via qualified access (`tuple.Pair`). The cb4bd6b
    # invariant ("one type name resolves to one definition") was an
    # over-strict shortcut that traded language ergonomics for a
    # simpler variant-table lookup — the correct fix lives in the
    # typer's dispatch (key variants by (module, name) and resolve
    # contextually by the scrutinee's type) and is tracked as a
    # separate bug. Local duplicates inside the same file (the case
    # `Some(prev)` above) remain an error — that ambiguity has no
    # disambiguator.
    None -> validate_type_name_collisions_loop(rest, file,
                                                  [TNC(name, line, col), ...claims],
                                                  errs)
  }
  }
}

# types that the language reserves for its own use; user
# code cannot redeclare them via `type X = ...`. `Cont` is the
# one-shot continuation type that appears in `extern "handler" fn`
# signatures inside `default { }` blocks; the typer/codegen treat it
# as an opaque builtin (TyCon(None, "Cont", [t])) and lower it to KaiCont*
# at emit time.
fn reserved_builtin_type_names() : [String] = ["Cont"]

fn me_list_has_name(mes: [ModuleEntry], name: String) : Bool {
  match mes {
    [] -> false
    [me, ...rest] -> match me {
      ME(mn, _, _, _) -> if mn == name { true } else { me_list_has_name(rest, name) }
    }
  }
}

fn find_type_name_claim(claims: [TypeNameClaim], name: String) : Option[TypeNameClaim] {
  match claims {
    [] -> None
    [c, ...rest] -> match c {
      TNC(n, _, _) -> if n == name { Some(c) } else { find_type_name_claim(rest, name) }
    }
  }
}


fn report_dup_type_decl(file: String, name: String, line: Int, col: Int,
                          prev: TypeNameClaim) : Unit / Console + File {

  match prev {
    TNC(_, prev_line, prev_col) -> {
      let msg = concat_all(["type '", name,
                            "' is already declared in this module (earlier at ",
                            file, ":", int_to_string(prev_line), ":",
                            int_to_string(prev_col), ")"])
      diag_error(file, line, col, msg)
      diag_help(concat_all(["remove or rename the second 'type ", name,
                              " = ...' declaration"]))
    }
  }
}

#[doc("infer: `validate_constructor_uniqueness_decls` — reject a second `#[constructor]` for the same type.")]
pub fn validate_constructor_uniqueness_decls(decls: [Decl], file: String) : Int / Console + File {

  validate_constructor_uniqueness_loop(decls, file, [], 0)
}

fn validate_constructor_uniqueness_loop(remaining: [Decl], file: String,
                                        claims: [TypeNameClaim],
                                        errs: Int) : Int / Console + File {
  match remaining {
    [] -> errs
    [d, ...rest] -> match constructor_decl_type(d) {
      Some(TNC(tname, line, col)) -> match find_type_name_claim(claims, tname) {
        Some(prev) -> {
          report_dup_constructor(file, tname, line, col, prev)
          validate_constructor_uniqueness_loop(rest, file, claims, errs + 1)
        }
        None -> validate_constructor_uniqueness_loop(rest, file,
                                                     [TNC(tname, line, col), ...claims], errs)
      }
      None -> validate_constructor_uniqueness_loop(rest, file, claims, errs)
    }
  }
}

# `Some(TNC(type_name, line, col))` for a `#[constructor]` wrapper whose
# inner fn returns a named type; None for any other decl.
fn constructor_decl_type(d: Decl) : Option[TypeNameClaim] = match d {
  DConstructor(DFn(_, _, _, _, Some(ret_te), _, _, _, _, _), l, c) ->
    match constructor_type_name(ret_te) {
      Some(tname) -> Some(TNC(tname, l, c))
      None        -> None
    }
  _ -> None
}

fn report_dup_constructor(file: String, tname: String, line: Int, col: Int,
                          prev: TypeNameClaim) : Unit / Console + File {
  match prev {
    TNC(_, prev_line, prev_col) -> {
      diag_error(file, line, col,
        concat_all(["type '", tname, "' already has a `#[constructor]` (earlier at ",
                    file, ":", int_to_string(prev_line), ":", int_to_string(prev_col), ")"]))
      diag_help(concat_all(["a type has at most one `#[constructor]`; keep one and make the other a named `pub fn` (overloading is out — Tier 1 #3)"]))
    }
  }
}

# Reject two declarations sharing a
# name in the same module across the `fn`, `effect`, `const`, `axiom`
# kinds. The resolver historically prepended decls into the env blindly
# (see `register_one`), so a second `fn foo` (or `effect E`, `const N`,
# `axiom A`) silently shadowed the first. Companion to
# `validate_type_name_collisions_decls` for `type`; these walkers only
# check same-module same-name pairs in `root_only_decls`. Cross-module
# shadowing (`pub fn foo` in one module, `fn foo` private in another) is
# gated by `pub` + `use` and remains permitted.
#
# Diagnostic shape mirrors the type case: anchor at the second site,
# cite the earlier file:line:col in the message body, and add a help
# line nudging the user to rename or remove the redeclaration.
#
# The four kinds differ only in (a) which Decl variant carries the
# name/line/col, and (b) three words of diagnostic text. A single
# parametric walker (`validate_name_collisions_walk`) carries the shared
# linear scan; each public entry point supplies a pure extractor naming
# its Decl variant plus an `EntitySpec` for the three varying words. The
# `type` and union validators stay bespoke — `type` layers cross-module
# / reserved-name / DDerive-DUnstable cases and a distinct message, and
# union collision accumulates per-variant claims with builtin seeding;
# forcing either into this mould would drag their special logic into the
# generic path.

# A name claimed by a decl at a source position. `NS(name, line, col)`.
type NameSite = NS(String, Int, Int)

# The three words of diagnostic text that vary per entity kind:
#   word   — noun in the error line ("function" / "effect" / ...)
#   kw     — keyword fragment opening the help suggestion ("fn" / ...)
#   syntax — the rest of the help's declaration shape ("(...)" / ...)
type EntitySpec = ES(String, String, String)

# Parametric same-module duplicate-name walker. `extract` returns
# `Some(NS(name, line, col))` for the decls this entity owns and `None`
# for every other decl kind; `spec` supplies the varying diagnostic
# words. Linear scan accumulating seen claims (prepend; order does not
# affect the count) and an error tally.
fn validate_name_collisions_walk(remaining: [Decl], file: String,
                                    extract: (Decl) -> Option[NameSite],
                                    spec: EntitySpec,
                                    seen: [NameSite],
                                    errs: Int) : Int / Console + File {

  match remaining {
    [] -> errs
    [d, ...rest] -> match extract(d) {
      Some(site) -> match site {
        NS(name, line, col) -> match find_name_site(seen, name) {
          Some(prev) -> {
            report_dup_name_decl(file, name, line, col, prev, spec)
            validate_name_collisions_walk(rest, file, extract, spec, seen, errs + 1)
          }
          None ->
            validate_name_collisions_walk(rest, file, extract, spec,
                                             [NS(name, line, col), ...seen], errs)
        }
      }
      None -> validate_name_collisions_walk(rest, file, extract, spec, seen, errs)
    }
  }
}

fn find_name_site(seen: [NameSite], name: String) : Option[NameSite] {
  match seen {
    [] -> None
    [c, ...rest] -> match c {
      NS(n, _, _) -> if n == name { Some(c) } else { find_name_site(rest, name) }
    }
  }
}

fn report_dup_name_decl(file: String, name: String, line: Int, col: Int,
                          prev: NameSite, spec: EntitySpec) : Unit / Console + File {

  match prev {
    NS(_, prev_line, prev_col) -> match spec {
      ES(word, kw, syntax) -> {
        let msg = concat_all([word, " '", name,
                              "' is already declared in this module (earlier at ",
                              file, ":", int_to_string(prev_line), ":",
                              int_to_string(prev_col), ")"])
        diag_error(file, line, col, msg)
        diag_help(concat_all(["remove or rename the second '", kw, " ", name,
                                syntax, "' declaration"]))
      }
    }
  }
}

fn extract_fn_site(d: Decl) : Option[NameSite] = match d {
  DFn(_, name, _, _, _, _, _, line, col, _) -> Some(NS(name, line, col))
  _ -> None
}

#[doc("infer: `validate_fn_name_collisions_decls` — typer entry point invoked by the driver.")]
pub fn validate_fn_name_collisions_decls(root_decls: [Decl],
                                        file: String) : Int / Console + File {

  validate_name_collisions_walk(root_decls, file, extract_fn_site,
                                   ES("function", "fn", "(...)"), [], 0)
}

# reject two `effect Foo` declarations in the same module.
# The resolver's `register_one` prepends DEffect names into the env
# blindly so the second silently shadows the first. Companion to the
# DFn / DType walkers above; shares `validate_name_collisions_walk`.

fn extract_effect_site(d: Decl) : Option[NameSite] = match d {
  DEffect(_, name, _, _, _, line, col, _) -> Some(NS(name, line, col))
  _ -> None
}

#[doc("infer: `validate_effect_name_collisions_decls` — typer entry point invoked by the driver.")]
pub fn validate_effect_name_collisions_decls(root_decls: [Decl],
                                            file: String) : Int / Console + File {

  validate_name_collisions_walk(root_decls, file, extract_effect_site,
                                   ES("effect", "effect", " { ... }"), [], 0)
}

# reject two `const N = ...` declarations in the same
# module. DConst flows through `register_one` with the same blind
# prepend pattern; shares `validate_name_collisions_walk`.

fn extract_const_site(d: Decl) : Option[NameSite] = match d {
  DConst(_, name, _, _, _, line, col) -> Some(NS(name, line, col))
  _ -> None
}

#[doc("infer: `validate_const_name_collisions_decls` — typer entry point invoked by the driver.")]
pub fn validate_const_name_collisions_decls(root_decls: [Decl],
                                           file: String) : Int / Console + File {

  validate_name_collisions_walk(root_decls, file, extract_const_site,
                                   ES("const", "const", " = ..."), [], 0)
}

# reject two axiom declarations sharing a name in the
# same module. DAxiom is rewritten to DFn by `lower_axioms`, but the
# walk must run on the raw decl list (before the lowering) so the
# diagnostic anchors at the original axiom site. Shares
# `validate_name_collisions_walk`; the caller feeds it the pre-lowering
# decls so DAxiom still appears.

fn extract_axiom_site(d: Decl) : Option[NameSite] = match d {
  DAxiom(_, _, name, _, _, _, _, _, line, col) -> Some(NS(name, line, col))
  _ -> None
}

#[doc("infer: `validate_axiom_name_collisions_decls` — typer entry point invoked by the driver.")]
pub fn validate_axiom_name_collisions_decls(root_decls: [Decl],
                                           file: String) : Int / Console + File {

  validate_name_collisions_walk(root_decls, file, extract_axiom_site,
                                   ES("axiom", "axiom", "(...)"), [], 0)
}

# Run every same-module duplicate-decl validator over a single module's
# decls. Stdlib modules (core auto-load + `import`-resolved files) bypass
# `validate_*_collisions_decls` because those walkers only see the
# root file's `root_only_decls`. The consequence (json_hex_digit case):
# a duplicate `fn foo` inside a stdlib module silently overwrites the
# first definition, the second wins at name resolution, and the codegen
# emits two C-level definitions of `kai_<mod>__foo` that cc rejects at
# link time — far from the kaikai source where the duplicate lives.
#
# This wrapper closes the gap. `load_core` (core auto-load) and
# `resolve_module` (import) call it on every freshly-parsed module's
# decls before tagging or appending to the global stream. Each
# validator counts its own diagnostic emissions; the caller sums the
# total and aborts the load when non-zero so downstream passes never
# see the broken module.
#
# Pre-conditions:
#   - decls are the just-parsed AST of one source file, NOT the global
#     concat. Cross-module shadowing is NOT a concern here — by design,
#     a stdlib `type Pair` and a user `type Pair` coexist (Hanga Roa
#     decision; see `validate_one_type_decl` comments). This walker
#     only catches same-file same-name pairs.
#[doc("infer: `validate_module_same_module_collisions` — typer entry point invoked by the driver.")]
pub fn validate_module_same_module_collisions(decls: [Decl], file: String)
    : Int / Console + File {
  let e_fn     = validate_fn_name_collisions_decls(decls, file)
  let e_type   = validate_type_name_collisions_decls(decls, file)
  let e_effect = validate_effect_name_collisions_decls(decls, file)
  let e_const  = validate_const_name_collisions_decls(decls, file)
  let e_axiom  = validate_axiom_name_collisions_decls(decls, file)
  e_fn + e_type + e_effect + e_const + e_axiom
}

# collect all distinct row-variable names appearing in the
# row positions of a function declaration's signature: the outer
# return-row plus every nested `TyFn` row inside parameter types and
# the return type. Order of first occurrence is preserved so each
# decl gets a stable assignment of bound row-var ids.
fn collect_decl_rvars(d: Decl) : [String] {
  match d {
    DFn(_, _, _, params, opt_ret, rexpr, _, _, _, _) -> {
      let acc0 = collect_rvars_in_row(rexpr, [])
      let acc1 = collect_rvars_in_params(params, acc0)
      match opt_ret {
        Some(rty) -> collect_rvars_in_typeexpr(rty, acc1)
        None      -> acc1
      }
    }
    _ -> []
  }
}

fn collect_rvars_in_row(re: RowExpr, acc: [String]) : [String] {
  match re {
    REmpty -> acc
    RClosed(_) -> acc
    ROpen(rv, _) -> if list_has(acc, rv) { acc } else { list_append(acc, [rv]) }
  }
}

fn collect_rvars_in_params(ps: [Param], acc: [String]) : [String] {
  match ps {
    [] -> acc
    [p, ...rest] -> {
      let acc1 = match p.ptype {
        Some(te) -> collect_rvars_in_typeexpr(te, acc)
        None     -> acc
      }
      collect_rvars_in_params(rest, acc1)
    }
  }
}

# Collect names a fn signature places in a row-kind slot of a nominal
# type (`e` in `from_list(...) : Stream[t, e]`), consulting the
# per-type row-kind table. These join `collect_decl_rvars` so the row
# var is bound + generalised even when it never appears after a `/`.
fn collect_rowkind_args_decl(d: Decl, table: [RowKindEntry]) : [String] = match d {
  DFn(_, _, _, params, opt_ret, _, _, _, _, _) -> {
    let a0 = collect_rowkind_args_params(params, table, [])
    match opt_ret {
      Some(rty) -> collect_rowkind_args_te(rty, table, a0)
      None      -> a0
    }
  }
  _ -> []
}

fn collect_rowkind_args_params(ps: [Param], table: [RowKindEntry], acc: [String]) : [String] = match ps {
  [] -> acc
  [p, ...rest] -> {
    let a1 = match p.ptype {
      Some(te) -> collect_rowkind_args_te(te, table, acc)
      None     -> acc
    }
    collect_rowkind_args_params(rest, table, a1)
  }
}

fn collect_rowkind_args_te(t: TypeExpr, table: [RowKindEntry], acc: [String]) : [String] = match t.tkind {
  TyName(name, tas) -> {
    let here = collect_rowkind_args_at(tas, row_kind_slots_of(table, name), 0, acc)
    collect_rowkind_args_tes(tas, table, here)
  }
  TyList(inner) -> collect_rowkind_args_te(inner, table, acc)
  TyFn(ps, ret, _) -> collect_rowkind_args_te(ret, table, collect_rowkind_args_tes(ps, table, acc))
  TyDim(base, _) -> collect_rowkind_args_te(base, table, acc)
  TyRefine(base, _) -> collect_rowkind_args_te(base, table, acc)
  TyRow(_) -> acc
}

fn collect_rowkind_args_tes(ts: [TypeExpr], table: [RowKindEntry], acc: [String]) : [String] = match ts {
  [] -> acc
  [t, ...rest] -> collect_rowkind_args_tes(rest, table, collect_rowkind_args_te(t, table, acc))
}

# For each slot index in `idxs`, if that slot is a bare `TyName(n, [])`,
# collect `n`. The slot is declared row-kind, so `n` names a row var.
fn collect_rowkind_args_at(tas: [TypeExpr], idxs: [Int], i: Int, acc: [String]) : [String] = match tas {
  [] -> acc
  [a, ...rest] -> {
    let a1 = if list_has_int(idxs, i) {
      match a.tkind {
        TyName(n, []) -> if list_has(acc, n) { acc } else { list_append(acc, [n]) }
        _ -> acc
      }
    } else { acc }
    collect_rowkind_args_at(rest, idxs, i + 1, a1)
  }
}

fn collect_rvars_in_typeexpr(t: TypeExpr, acc: [String]) : [String] {
  match t.tkind {
    TyName(_, tas) -> collect_rvars_in_typeexprs(tas, acc)
    TyList(inner)  -> collect_rvars_in_typeexpr(inner, acc)
    TyFn(ps, ret, rexpr) -> {
      let acc1 = collect_rvars_in_typeexprs(ps, acc)
      let acc2 = collect_rvars_in_typeexpr(ret, acc1)
      collect_rvars_in_row(rexpr, acc2)
    }
    # dimensioned base — recurse into the inner ty; the unit
    # itself never carries row variables.
    TyDim(base, _) -> collect_rvars_in_typeexpr(base, acc)
    # refinement predicates are pure (no effects, no rows);
    # only the base type can contribute row variables.
    TyRefine(base, _) -> collect_rvars_in_typeexpr(base, acc)
    # a compound row as a type argument can carry an open
    # tail (`Stream[Int, Stdout + f]`); collect `f` as a row variable
    # so the scheme binds it before alias substitution folds the row in.
    TyRow(row) -> collect_rvars_in_row(row, acc)
  }
}

fn collect_rvars_in_typeexprs(ts: [TypeExpr], acc: [String]) : [String] {
  match ts {
    [] -> acc
    [t, ...rest] -> collect_rvars_in_typeexprs(rest, collect_rvars_in_typeexpr(t, acc))
  }
}

fn mk_rvbinds_loop(names: [String], i: Int, acc: [RVBind]) : [RVBind] {
  match names {
    [] -> list_reverse(acc)
    [n, ...rest] -> mk_rvbinds_loop(rest, i + 1, [RVB(n, i), ...acc])
  }
}

fn mk_rvbinds(names: [String]) : [RVBind] = mk_rvbinds_loop(names, 0, [])

fn rvbind_ids_loop(binds: [RVBind], acc: [Int]) : [Int] {
  match binds {
    [] -> list_reverse(acc)
    [b, ...rest] -> match b {
      RVB(_, i) -> rvbind_ids_loop(rest, [i, ...acc])
    }
  }
}

fn rvbind_ids(binds: [RVBind]) : [Int] = rvbind_ids_loop(binds, [])

# Resolve a TypeExpr under both the type-parameter and row-variable
# binding contexts. A `TyName(name, [])` is first looked up as a
# tparam; if not found, the builtin / user-type fallback applies.
fn resolve_ty_with_binds(t: TypeExpr, tpbinds: [TPBind], rbinds: [RVBind]) : Ty =
  resolve_ty_with_binds_rk(t, tpbinds, rbinds, [])

# As `resolve_ty_with_binds` but consulting the per-type row-kind table
# so a `T[..., e]` slot the type declares row-kind resolves to a row
# carrier — covering a row var, a single concrete effect, or a compound
# row equally. Callers with no table pass `[]`: then only ctor-field row
# vars (in `rbinds`) and literal compound rows resolve to carriers; a
# single concrete effect stays a type.
fn resolve_ty_with_binds_rk(t: TypeExpr, tpbinds: [TPBind], rbinds: [RVBind], rk: [RowKindEntry]) : Ty {
  match t.tkind {
    TyName(name, tas) -> {
      match shape_tparam_lookup(tpbinds, name) {
        # A shape tparam applied to its single type argument forms `s[A]`.
        # A bare `s` (no args) is the unapplied shape variable. More than
        # one arg is an arity violation caught by the formation validator.
        Some(sid) -> match tas {
          [arg] -> TyShapeApp(sid, resolve_ty_with_binds_rk(arg, tpbinds, rbinds, rk))
          _ -> tv(sid)
        }
        None -> match tpbind_lookup(tpbinds, name) {
        Some(i) -> tv(i)
        None -> {
          if name == "Int" { TyInt }
          else if name == "Real"   { TyReal }
          else if name == "Bool"   { TyBool }
          else if name == "String" { TyString }
          else if name == "Char"   { TyChar }
          else if name == "Unit"   { TyUnit }
          else if name == "Byte"     { TyByte }
          else if is_fixed_width_name(name) { fixed_width_ty_of_name(name) }
          else if is_ffi_fixed_name(name) { ffi_fixed_ty_of_name(name) }
          else if name == "Handle"   { TyHandle }
          else if name == "Nothing" { TyAny }
          # Hanga Roa: the module_origin slot stays `None` here.
          # `resolve_ty_with_binds` runs at scheme-build time when
          # `recs` / `sums` (the only sources of module_origin) are
          # not yet in scope. A post-typing pass (`tag_tycon_modules`)
          # walks the inferred body and rewrites `TyCon(None, name, _)`
          # to `TyCon(Some(m), name, _)` using the home-module-aware
          # record / sum tables. That keeps `resolve_ty_with_binds`'s
          # 15 call sites untouched and concentrates the populate
          # logic in one place.
          else { TyCon(None, name, resolve_tycon_args(tas, row_kind_slots_of(rk, name), 0, tpbinds, rbinds, rk)) }
        }
      }
      }
    }
    TyList(inner) -> TyListT(resolve_ty_with_binds_rk(inner, tpbinds, rbinds, rk))
    TyFn(fps, fret, rexpr) ->
      TyFnT(map(fps, (p) => resolve_ty_with_binds_rk(p, tpbinds, rbinds, rk)),
            resolve_ty_with_binds_rk(fret, tpbinds, rbinds, rk),
            row_of_expr_with_binds(rexpr, tpbinds, rbinds))
    # dimensioned base — resolve the inner Ty against tpbinds,
    # then walk the unit and rewrite any symbol that names a unit
    # tparam (`[u: Measure]` → name "u#Unit") to UVar(id).
    TyDim(base, u) ->
      dim_collapse(resolve_ty_with_binds_rk(base, tpbinds, rbinds, rk),
                   unit_canon(unit_resolve_tparams(u, tpbinds)))
    # preserve refinement on the semantic side.
    TyRefine(base, p) -> TyRefineT(resolve_ty_with_binds_rk(base, tpbinds, rbinds, rk), p)
    # a compound row reaching *type* position (not dissolved
    # by alias substitution). Resolve to an undeclared name so the
    # natural "unknown type" cascade reports it.
    TyRow(_) -> TyCon(None, "__row_in_type_position__", [])
  }
}

# Resolve a `TyCon`'s argument list, threading the parent type's
# row-kind slot indices: a slot whose index is in `idxs` resolves to a
# row carrier.
fn resolve_tycon_args(tas: [TypeExpr], idxs: [Int], i: Int,
                      tpbinds: [TPBind], rbinds: [RVBind], rk: [RowKindEntry]) : [Ty] {
  match tas {
    [] -> []
    [a, ...rest] -> {
      let resolved = resolve_tycon_arg(a, list_has_int(idxs, i), tpbinds, rbinds, rk)
      [resolved, ...resolve_tycon_args(rest, idxs, i + 1, tpbinds, rbinds, rk)]
    }
  }
}

# Resolve a single `TyCon` argument slot. When `is_row` (the parent
# declares this slot row-kind) a row var, a single concrete effect, or
# a compound row all resolve to a carrier so the slot threads the
# effect row. A ctor-field row var also resolves to a carrier off
# `rbinds`, table-independent. The carrier shares its row-var id with
# the ctor field's `/ e`, so the head slot and the function row are the
# same generalised row var.
fn resolve_tycon_arg(t: TypeExpr, is_row: Bool, tpbinds: [TPBind], rbinds: [RVBind], rk: [RowKindEntry]) : Ty {
  match t.tkind {
    TyName(name, tas) ->
      match tas {
        [] -> match inf_rvbind_lookup(rbinds, name) {
          Some(id) -> row_arg_carrier(row_with_tail(id))
          None     -> if is_row { inf_resolve_row_arg(t) }
                      else { resolve_ty_with_binds_rk(t, tpbinds, rbinds, rk) }
        }
        _ -> resolve_ty_with_binds_rk(t, tpbinds, rbinds, rk)
      }
    TyRow(rexpr) -> row_arg_carrier(row_of_expr_with_binds(rexpr, tpbinds, rbinds))
    _ -> resolve_ty_with_binds_rk(t, tpbinds, rbinds, rk)
  }
}

# walk a UnitExprT and replace USym("u") with UVar(id) when "u"
# matches a unit-kind tparam. Type-kind tparams are left alone — they
# would be a category error in unit position; we surface that as a
# unification failure later if necessary, not as a parser/resolve error.
fn unit_resolve_tparams(u: UnitExprT, tpbinds: [TPBind]) : UnitExprT {
  match u {
    UOne -> u
    UVar(_) -> u
    USym(s) -> match unit_tparam_lookup(tpbinds, s) {
      Some(id) -> UVar(id)
      None     -> u
    }
    UMul(a, b) -> UMul(unit_resolve_tparams(a, tpbinds), unit_resolve_tparams(b, tpbinds))
    UInv(a) -> UInv(unit_resolve_tparams(a, tpbinds))
    UPow(a, n) -> UPow(unit_resolve_tparams(a, tpbinds), n)
    UJoin(a, b) -> UJoin(unit_resolve_tparams(a, tpbinds), unit_resolve_tparams(b, tpbinds))
    UDims(us) -> UDims(units_resolve_tparams(us, tpbinds))
  }
}

fn units_resolve_tparams(us: [UnitExprT], tpbinds: [TPBind]) : [UnitExprT] = match us {
  [] -> []
  [u, ...rest] -> [unit_resolve_tparams(u, tpbinds), ...units_resolve_tparams(rest, tpbinds)]
}

# Look up a unit-kind tparam by its surface name. The tparam list
# stores names with the "#Unit" suffix for unit-kind params; the
# resolver compares the bare surface name against the suffix-stripped
# stored name.
fn unit_tparam_lookup(binds: [TPBind], surface: String) : Option[Int] {
  match binds {
    [] -> None
    [b, ...rest] -> match b {
      TPB(stored, id) -> {
        if tp_kind_is_unit(stored) and tp_strip_kind(stored) == surface { Some(id) }
        else { unit_tparam_lookup(rest, surface) }
      }
    }
  }
}

# Look up a shape-kind tparam by its surface name. Shape params store a
# `#Shape` suffix, so the surface name in constructor position (`s` in
# `s[A]`) is matched against the stripped stored name.
fn shape_tparam_lookup(binds: [TPBind], surface: String) : Option[Int] {
  match binds {
    [] -> None
    [b, ...rest] -> match b {
      TPB(stored, id) -> {
        if tp_kind_is_shape(stored) and tp_strip_kind(stored) == surface { Some(id) }
        else { shape_tparam_lookup(rest, surface) }
      }
    }
  }
}

# tp_unit_suffix lives in compiler/ast.kai; tp_make lives in
# compiler/parse.kai; the kind decoders (tp_kind_is_unit / tp_kind_of /
# tp_strip_kind / tp_kind_name) live in compiler/kinds.kai.

fn string_ends_with(s: String, suffix: String) : Bool {
  let sl = string_length(s)
  let xl = string_length(suffix)
  if xl > sl { false }
  else { string_slice(s, sl - xl, xl) == suffix }
}

# Earlier callers that only carry rbinds (no fn-level tparams).
fn resolve_ty_with_rvbinds(t: TypeExpr, rbinds: [RVBind]) : Ty =
  resolve_ty_with_binds(t, [], rbinds)

fn param_ty_with_binds(pm: Param, tpbinds: [TPBind], rbinds: [RVBind]) : Ty =
  param_ty_with_binds_rk(pm, tpbinds, rbinds, [])

fn param_ty_with_binds_rk(pm: Param, tpbinds: [TPBind], rbinds: [RVBind], rk: [RowKindEntry]) : Ty {
  match pm.ptype {
    Some(te) -> resolve_ty_with_binds_rk(te, tpbinds, rbinds, rk)
    None     -> TyAny
  }
}

fn param_ty_with_rvbinds(pm: Param, rbinds: [RVBind]) : Ty =
  param_ty_with_binds(pm, [], rbinds)

# Variant of inf_row_of_expr_with_rbinds that also resolves per-label
# ty_args under tpbinds — labels like `Reader[T]` where `T` is a
# fn-level type parameter.
fn row_of_expr_with_binds(re: RowExpr, tpbinds: [TPBind], rbinds: [RVBind]) : Row {
  match re {
    REmpty -> inf_row_empty()
    RClosed(labels) -> Row {
      labels: row_labels_of_rls_with_binds(labels, tpbinds, rbinds),
      tail: None,
      display_alias: None
    }
    ROpen(rv, labels) -> Row {
      labels: row_labels_of_rls_with_binds(labels, tpbinds, rbinds),
      tail: match inf_rvbind_lookup(rbinds, rv) {
        Some(id) -> Some(id)
        None     -> Some(-1)
      },
      display_alias: None
    }
  }
}

fn row_labels_of_rls_with_binds(ls: [RowLabel], tpbinds: [TPBind], rbinds: [RVBind]) : [Label] {
  match ls {
    [] -> []
    [rl, ...rest] -> match rl {
      RL(name, ts) -> [
        Label { eff: name, ty_args: map(ts, (te) => resolve_ty_with_binds(te, tpbinds, rbinds)) },
        ...row_labels_of_rls_with_binds(rest, tpbinds, rbinds)
      ]
    }
  }
}

#[doc("infer: project a function declaration to its quantified type scheme.")]
pub fn fn_scheme_of_decl(d: Decl) : Option[TyScheme] = fn_scheme_of_decl_rk(d, [])

# As `fn_scheme_of_decl` but with the per-type row-kind-slot table so a
# row var sourced only in a `T[..., e, ...]` return position (e.g.
# `from_list(...) : Stream[t, e]`) is bound + generalised as a row var.
pub fn fn_scheme_of_decl_rk(d: Decl, row_kind_table: [RowKindEntry]) : Option[TyScheme] {
  match d {
    DFn(_, fname, tparams, params, opt_ret, rexpr, _, _, _, _) -> {
      # collect row-variable names per decl, allocate small
      # bound ids (0, 1, ...) in order of appearance, build the body
      # type with those ids in tail positions. The scheme generalises
      # over them so each call site fresh-instantiates.
      # same idea for declared type parameters (`fn id[T]...`).
      # tparam ids are 0..len(tparams)-1; row-var ids live in their
      # own dimension, so the two namespaces don't collide.
      # also auto-collect lowercase TyName
      # identifiers that appear in the signature but were not
      # declared in `[T1, T2]`. Treat them as *implicit* tparams.
      # Without this, `pub fn list_contains(xs: [a], x: a) : Bool`
      # ends up with `a` as a nominal `TyCon(None, "a", [])` and the
      # call site fails to unify with `[Int], Int`. The implicit
      # set is appended to the declared one so explicit `[a]` still
      # wins on collisions; their ids form a contiguous block.
      let rk_names = collect_rowkind_args_decl(d, row_kind_table)
      let names = list_append(collect_decl_rvars(d), rk_names)
      let rbinds = mk_rvbinds(names)
      let implicit = collect_implicit_tparams_in_decl(d, tparams)
      let effective_tparams = list_append(tparams, implicit)
      let tpbinds = mk_tpbinds(effective_tparams)
      let pts = map(params, (p) => param_ty_with_binds_rk(p, tpbinds, rbinds, row_kind_table))
      let ret = match opt_ret {
        Some(rty) -> resolve_ty_with_binds_rk(rty, tpbinds, rbinds, row_kind_table)
        None      -> TyUnit
      }
      # elaboration for pure named callbacks. When a fn
      # decl omits the row clause (`fn foo(...) : T` without `/`), the
      # scheme gains a fresh phantom row variable in the outermost
      # TyFnT tail. Effect: each call site instantiates the row to a
      # fresh free variable instead of empty-closed, so passing a pure
      # named callback to a slot expecting `(args) -> ret / e` no
      # longer pins `e := ε`. `check_body_row` (line ~36939) still
      # enforces empty-closed for the *body*, so soundness is
      # preserved: pure → effectful lifts, effectful → pure stays
      # rejected. The asymmetry holds because RClosed/ROpen signatures
      # carry their declared row verbatim — only REmpty triggers
      # elaboration. Excludes `main` (which absorbs builtin effects
      # under its REmpty branch in check_body_row).
      let phantom_id = list_length(rbinds)
      let row = if elaborate_phantom_row(rexpr, fname) {
        Row { labels: [], tail: Some(phantom_id), display_alias: None }
      } else {
        row_of_expr_with_binds(rexpr, tpbinds, rbinds)
      }
      let body = TyFnT(pts, ret, row)
      # split tparam IDs by kind so unit-vars live in their own
      # pool and get fresh-instantiated by st_instantiate_report. A
      # row-kind tparam (sourced in a `T[..., e]` slot) is generalised
      # as a row var, not a type var, so drop its type-var id from the
      # split — its `tv(id)` never appears in the body (the slot is a
      # carrier), and leaving it would generalise a dead type var.
      let split = tparam_id_split(effective_tparams)
      let rk_tvar_ids = tparam_type_ids_of(effective_tparams, rk_names)
      let tvars = remove_ints(split.tvars, rk_tvar_ids)
      let rvars = if elaborate_phantom_row(rexpr, fname) {
        list_append(rvbind_ids(rbinds), [phantom_id])
      } else {
        rvbind_ids(rbinds)
      }
      Some(scheme_uvars(tvars, rvars, split.uvars,
                        tparam_unit_kinds(effective_tparams), body))
    }
    _ -> None
  }
}

# predicate gating the elaboration of a phantom row
# variable on a fn signature lacking a `/` row clause. `main` is
# excluded because `check_body_row`'s REmpty branch absorbs builtin
# effects there; adding a phantom row var would interfere with that
# special-case.
fn elaborate_phantom_row(rexpr: RowExpr, fname: String) : Bool {
  match rexpr {
    REmpty -> fname != "main"
    _      -> false
  }
}

# walk a decl's signature for lowercase identifiers in type
# position, appending them in first-seen order. Skip names already
# declared in the explicit `[…]` tparam list, builtin primitive
# names (which start uppercase anyway, but defensive), and the empty
# string. Used by `fn_scheme_of_decl` and `infer_decl` to make
# implicit polymorphism work the way earlier code (and the stdlib)
# already assumed.
#[doc("infer: `collect_implicit_tparams_in_decl` — typer entry point invoked by the driver.")]
pub fn collect_implicit_tparams_in_decl(d: Decl, declared: [String]) : [String] {
  match d {
    DFn(_, _, _, params, opt_ret, rexpr, _, _, _, _) -> {
      let acc0 = collect_implicit_in_params(params, declared, [])
      let acc1 = match opt_ret {
        Some(rty) -> collect_implicit_in_typeexpr(rty, declared, acc0)
        None      -> acc0
      }
      collect_implicit_in_row(rexpr, declared, acc1)
    }
    _ -> []
  }
}

fn collect_implicit_in_params(ps: [Param], declared: [String], acc: [String]) : [String] {
  match ps {
    [] -> acc
    [p, ...rest] -> {
      let acc1 = match p.ptype {
        Some(te) -> collect_implicit_in_typeexpr(te, declared, acc)
        None     -> acc
      }
      collect_implicit_in_params(rest, declared, acc1)
    }
  }
}

fn collect_implicit_in_typeexpr(t: TypeExpr, declared: [String], acc: [String]) : [String] {
  match t.tkind {
    TyName(name, tas) -> {
      let acc1 = collect_implicit_in_typeexprs(tas, declared, acc)
      if is_implicit_tparam_candidate(name) and not list_has(declared, name) and not list_has(acc1, name) { list_append(acc1, [name]) } else { acc1 }
    }
    TyList(inner) -> collect_implicit_in_typeexpr(inner, declared, acc)
    TyFn(ps, ret, rexpr) -> {
      let acc1 = collect_implicit_in_typeexprs(ps, declared, acc)
      let acc2 = collect_implicit_in_typeexpr(ret, declared, acc1)
      collect_implicit_in_row(rexpr, declared, acc2)
    }
    # implicit-tparam collection for dimensioned types — recurse
    # into the base ty; unit-vars are NOT implicitly generalised, the
    # user must declare them via `[u: Measure]`.
    TyDim(base, _) -> collect_implicit_in_typeexpr(base, declared, acc)
    # refinements stay transparent; only the base type
    # contributes implicit type parameters.
    TyRefine(base, _) -> collect_implicit_in_typeexpr(base, declared, acc)
    # a compound row as a type argument — recurse into any
    # parameterised labels it carries (`Reader[t]`) for implicit tparams.
    TyRow(row) -> collect_implicit_in_row(row, declared, acc)
  }
}

fn collect_implicit_in_typeexprs(ts: [TypeExpr], declared: [String], acc: [String]) : [String] {
  match ts {
    [] -> acc
    [t, ...rest] -> collect_implicit_in_typeexprs(rest, declared, collect_implicit_in_typeexpr(t, declared, acc))
  }
}

fn collect_implicit_in_row(re: RowExpr, declared: [String], acc: [String]) : [String] {
  match re {
    REmpty -> acc
    RClosed(labels) -> collect_implicit_in_row_labels(labels, declared, acc)
    ROpen(_, labels) -> collect_implicit_in_row_labels(labels, declared, acc)
  }
}

fn collect_implicit_in_row_labels(labels: [RowLabel], declared: [String], acc: [String]) : [String] {
  match labels {
    [] -> acc
    [l, ...rest] -> match l {
      RL(_, tas) -> collect_implicit_in_row_labels(rest, declared,
                       collect_implicit_in_typeexprs(tas, declared, acc))
    }
  }
}

# A name is an implicit-tparam candidate if it begins with a
# lowercase letter. Builtin primitives (Int, Real, Bool, …) all
# start uppercase, so this naturally excludes them.
fn is_implicit_tparam_candidate(name: String) : Bool {
  if string_length(name) == 0 { false }
  else { match char_at(name, 0) {
    Some(c) -> ch_is_lower(c)
    None -> false
  } }
}

fn add_decls_loop(env: TyEnv, ar_acc: [OpEffArity], ds: [Decl],
                    top_names: [String]) : EnvWithArities =
  add_decls_loop_rk(env, ar_acc, ds, top_names, compute_row_kind_slots(ds))

fn add_decls_loop_rk(env: TyEnv, ar_acc: [OpEffArity], ds: [Decl],
                    top_names: [String], rk_table: [RowKindEntry]) : EnvWithArities {
  match ds {
    [] -> EnvWithArities { env: env, arities: ar_acc }
    [d, ...rest] -> {
      let r = match d {
        # register the scheme under the bare `fname`
        # (today's behaviour — newest registration shadows earlier
        # ones in `ty_env_lookup`) AND, when the decl carries a
        # module origin, under the composite `<mod>::<fname>` so
        # the EModCall branch can pick the correct scheme by
        # qualifier instead of guessing from arg types after a
        # wrong scheme was instantiated. Bare lookups are
        # unaffected — the EModCall branch consults the qualified
        # key first and falls back to bare only for core-only
        # schemes registered by `add_core_sigs`.
        DFn(_, fname, _, _, _, _, _, _, _, mo) -> match fn_scheme_of_decl_rk(d, rk_table) {
          Some(sc) -> {
            let env1 = ty_env_add(env, fname, sc)
            let env2 = match mo {
              Some(m) -> ty_env_add_qualified(env1, m, fname, sc)
              None    -> env1
            }
            EnvWithArities { env: env2, arities: ar_acc }
          }
          None     -> EnvWithArities { env: env, arities: ar_acc }
        }
        # prepend a boundary sentinel
        # `<tname>::__type_decl_arity_<N>__` BEFORE registering
        # the variants. Since `ty_env_add` cons-prepends, the
        # sentinel ends up after this DType's variants in head-
        # first order: walking newest-first, the typer's
        # `variants_of_type_loop_arity` accepts variants until
        # it hits the sentinel (the boundary between this
        # DType's variants and any earlier declaration's). The
        # arity filter alone discriminates `Tree[k, v]` (arity
        # 2) from `Tree` (arity 0); the sentinel closes the
        # same-arity case (e.g. private `type SplitN = SplitOk
        # | SplitShort` in `stdlib/crypto/hash.kai` vs. a user
        # redeclaration of `type SplitN = ...`).
        DType(_, dt_name, dt_tparams, _, _, _, _, _) -> {
          let env1 = ty_env_add_decl_marker(env, dt_name, list_length(dt_tparams))
          let env2 = add_variants_of_decl(env1, d, top_names)
          EnvWithArities { env: env2, arities: ar_acc }
        }
        DEffect(_, eff_name, tparams, ops, _, _, _, _) -> {
          let r2 = add_effect_op_sigs(env, eff_name, tparams, ops)
          # merge per-effect arities into the running accumulator.
          EnvWithArities { env: r2.env, arities: append_op_arities(r2.arities, ar_acc) }
        }
        # A const binds its NAME to its declared type T monomorphically
        # — `name : T`, NOT `() -> T`. So `EVar(name)` reads as a value
        # of type T (no call, no instantiation). Registered bare and,
        # when it carries a home module, under the qualified key too —
        # the same dual registration `DFn` uses, so cross-module const
        # reads (`real.real_pi`) resolve through the qualified env.
        DConst(_, cname, cte, _, mo, _, _) -> {
          let csc = mono(resolve_ty_with_binds(cte, [], []))
          let env1 = ty_env_add(env, cname, csc)
          let env2 = match mo {
            Some(m) -> ty_env_add_qualified(env1, m, cname, csc)
            None    -> env1
          }
          EnvWithArities { env: env2, arities: ar_acc }
        }
        # `#[constructor]` wrapper: register the inner `pub fn` exactly
        # as a bare `DFn` would be, then record its `type -> (home, fn)`
        # binding so `try_constructor_call` can desugar `Type(args)`.
        DProtoLaws(_, inner, cl, cc) -> {
          let r = add_decls_loop_rk(env, ar_acc, [inner], top_names, rk_table)
          EnvWithArities { env: register_constructor(r.env, inner, cl, cc), arities: r.arities }
        }
        DImplAxiom(_, inner, cl, cc) -> {
          let r = add_decls_loop_rk(env, ar_acc, [inner], top_names, rk_table)
          EnvWithArities { env: register_constructor(r.env, inner, cl, cc), arities: r.arities }
        }
        DConstructor(inner, cl, cc) -> {
          let r = add_decls_loop_rk(env, ar_acc, [inner], top_names, rk_table)
          EnvWithArities { env: register_constructor(r.env, inner, cl, cc), arities: r.arities }
        }
        _ -> EnvWithArities { env: env, arities: ar_acc }
      }
      add_decls_loop_rk(r.env, r.arities, rest, top_names, rk_table)
    }
  }
}

# Record a `#[constructor]` binding on the env. The inner `DFn`'s
# return type names the constructed type; its home module and fn name
# complete the `EModCall` target. Entries accumulate (a duplicate is
# a second entry for the same type name); `check_constructor_uniqueness`
# reports the second as an error later, where diagnostics are available.
fn register_constructor(env: TyEnv, inner: Decl, l: Int, c: Int) : TyEnv {
  match inner {
    DFn(_, fname, _, _, ret_opt, _, _, _, _, mo) -> match ret_opt {
      Some(ret_te) -> match constructor_type_name(ret_te) {
        Some(tname) -> {
          let home = match mo { Some(m) -> m  None -> "" }
          ctor_add(env, CtorE(tname, home, fname), l, c)
        }
        None -> env
      }
      None -> env
    }
    _ -> env
  }
}

# Bare name of a return type: the final `::`/`.` segment of a
# `TyName`, so `bigint.BigInt` and `BigInt` both key on `BigInt`.
fn constructor_type_name(te: TypeExpr) : Option[String] = match te.tkind {
  TyName(nm, _) -> Some(ctor_last_segment(nm))
  _             -> None
}

fn ctor_last_segment(nm: String) : String {
  let i = ctor_last_dot(nm, string_length(nm) - 1)
  if i < 0 { nm } else { string_slice(nm, i + 1, string_length(nm) - (i + 1)) }
}

fn ctor_last_dot(nm: String, from: Int) : Int {
  if from < 0 { -1 }
  else {
    match char_at(nm, from) {
      Some(ch) -> if ch == '.' { from } else { ctor_last_dot(nm, from - 1) }
      None     -> ctor_last_dot(nm, from - 1)
    }
  }
}

fn ctor_add(env: TyEnv, entry: CtorEntry, l: Int, c: Int) : TyEnv =
  TyEnv { entries: env.entries, fresh: env.fresh, unions: env.unions,
          constructors: [entry, ...env.constructors],
          head_owners: env.head_owners, root_fns: env.root_fns,
          row_kind: env.row_kind, index: env.index }

# Collect every `#[constructor]` binding in a decl stream. Used to
# seed a module's `ModuleEnvDelta` so downstream modules inherit the
# registry — the sugar resolves cross-module `Type(args)` calls.
fn collect_constructors(ds: [Decl], acc: [CtorEntry]) : [CtorEntry] {
  match ds {
    [] -> list_reverse(acc)
    [d, ...rest] -> match d {
      DConstructor(DFn(_, fname, _, _, Some(ret_te), _, _, _, _, mo), _, _) ->
        match constructor_type_name(ret_te) {
          Some(tname) -> {
            let home = match mo { Some(m) -> m  None -> "" }
            collect_constructors(rest, [CtorE(tname, home, fname), ...acc])
          }
          None -> collect_constructors(rest, acc)
        }
      _ -> collect_constructors(rest, acc)
    }
  }
}

# Look up the constructor binding for a bare type name; newest-first,
# so the reported duplicate never masks the first-registered target.
fn constructor_lookup(cs: [CtorEntry], tname: String) : Option[CtorEntry] {
  match cs {
    [] -> None
    [CtorE(t, h, f), ...rest] ->
      if t == tname { Some(CtorE(t, h, f)) } else { constructor_lookup(rest, tname) }
  }
}

fn append_op_arities(a: [OpEffArity], b: [OpEffArity]) : [OpEffArity] {
  match a {
    [] -> b
    [h, ...rest] -> [h, ...append_op_arities(rest, b)]
  }
}

# register each effect op under the dotted key "Eff.op"
# in the type env. When synth_call sees `ECall(EField(EVar(Eff),
# op), args)`, it looks up that key and treats the call as an op
# invocation. Per-op type generics will replace the monomorphic
# scheme with one that carries the op's own quantifiers.
type EnvWithArities = { env: TyEnv, arities: [OpEffArity] }

fn add_effect_op_sigs(env: TyEnv, eff_name: String, tparams: [String],
                       ops: [EffectOp]) : EnvWithArities {
  let binds = mk_tpbinds(tparams)
  let ids = tparam_ids(tparams)
  add_effect_op_sigs_loop(env, eff_name, binds, ids, ops, [])
}

# register each op of `Eff[T1, T2]` under the
# dotted key `Eff.op` with a polymorphic scheme that quantifies
# over BOTH the effect's type parameters AND the op's own
# per-op tparams (`op[U](...)`). Op tparam ids are
# allocated from `next_id` so they never collide with effect
# tparams. Stateless effects with monomorphic ops yield the same
# monomorphic scheme as before.
#
# Per-op ROW generics: collect any row-variable name
# appearing in an `ROpen(rv, _)` tail of the op's parameter or
# return types (the analog of `collect_decl_rvars` for fns).
# `Spawn.spawn[T](thunk: () -> T / e) : Fiber[T]` therefore picks
# up `e` as a per-op row variable. The scheme generalises over it
# so each call site fresh-instantiates a row var that unifies with
# the lambda argument's row tail. Effect-level row generics are
# not (yet) a thing; the offset for `mk_rvbinds_from` stays 0.
fn add_effect_op_sigs_loop(env: TyEnv, eff_name: String, binds: [TPBind],
                            ids: [Int], ops: [EffectOp],
                            ar_acc: [OpEffArity]) : EnvWithArities {
  match ops {
    [] -> EnvWithArities { env: env, arities: ar_acc }
    [op, ...rest] -> match op {
      EOp(op_name, op_tparams, params, ret, _, _) -> {
        let next_id = list_length(binds)
        let op_binds = mk_tpbinds_from(op_tparams, next_id)
        let op_ids   = tparam_ids_from(op_tparams, next_id)
        let all_binds = append_tpbinds(binds, op_binds)
        let all_ids   = append_ints(ids, op_ids)
        let op_rv_names = collect_op_rvars(params, ret)
        let op_rvbinds  = mk_rvbinds_from(op_rv_names, 0)
        let op_rv_ids   = rvbind_ids(op_rvbinds)
        let pts = param_tys_with_op_binds(params, all_binds, op_rvbinds)
        let ret_ty = resolve_ty_with_binds(ret, all_binds, op_rvbinds)
        let body_ty = TyFnT(pts, ret_ty, inf_row_empty())
        let sc = match op_rv_ids {
          [] -> match all_ids {
            [] -> mono(body_ty)
            _  -> scheme(all_ids, body_ty)
          }
          _ -> scheme_full(all_ids, op_rv_ids, body_ty)
        }
        let key = string_concat(eff_name, string_concat(".", op_name))
        let env1 = ty_env_add(env, key, sc)
        # Record only the effect-level arity per dotted key. The
        # synth_op_call_with_scheme caller uses this to take the
        # first N entries of `inst.fresh` as the row label's ty_args.
        let ar1 = [OEA(key, list_length(ids)), ...ar_acc]
        add_effect_op_sigs_loop(env1, eff_name, binds, ids, rest, ar1)
      }
    }
  }
}

# collect row-variable names appearing in `ROpen` tails
# inside an op's parameter types and return type. Mirrors
# `collect_decl_rvars` for fns but reads an EffectOp's pieces
# directly. The op's outer row is always empty (ops run inside a
# handler context), so only nested TyFn rows in param / ret types
# can introduce row variables.
fn collect_op_rvars(params: [Param], ret: TypeExpr) : [String] {
  let acc0 = collect_rvars_in_params(params, [])
  collect_rvars_in_typeexpr(ret, acc0)
}

# same as `mk_rvbinds` but starts ids at `start`.
# Effects do not currently declare row params at the effect level,
# so the offset is 0 today; the parameter exists for symmetry with
# `mk_tpbinds_from` and to avoid silent breakage if effect-level
# row generics ever land.
fn mk_rvbinds_from(names: [String], start: Int) : [RVBind] =
  mk_rvbinds_loop(names, start, [])

# variant of `param_tys_with_binds` that resolves
# parameter types under both type-param and row-variable binding
# contexts. Used by the op-signature builder so a thunk parameter
# `f: () -> T / e` records `e` as a bound row id rather than
# losing it to `Some(-1)` (the unbound-rv sentinel).
fn param_tys_with_op_binds(params: [Param], tpbinds: [TPBind],
                            rbinds: [RVBind]) : [Ty] {
  match params {
    [] -> []
    [pm, ...rest] -> {
      let here = match pm.ptype {
        Some(te) -> resolve_ty_with_binds(te, tpbinds, rbinds)
        None     -> TyAny
      }
      [here, ...param_tys_with_op_binds(rest, tpbinds, rbinds)]
    }
  }
}

# parameter typing under tparam binds. Pattern-binding
# inside a `map`-lambda body confuses stage 1's capture analyser
# (CLAUDE.md note in dump_typed_subexprs); we use an explicit
# recursive helper instead of an inline lambda.
fn param_tys_with_binds(params: [Param], binds: [TPBind]) : [Ty] {
  match params {
    [] -> []
    [pm, ...rest] -> {
      let here = match pm.ptype {
        Some(te) -> resolve_ty_with_tparams(te, binds)
        None     -> TyAny
      }
      [here, ...param_tys_with_binds(rest, binds)]
    }
  }
}

#[doc("infer: `BuiltEnv` — driver-facing type.")]
pub type BuiltEnv = { env: TyEnv, core_len: Int, op_eff_arities: [OpEffArity] }

# per-module env composition.
#
# `build_ty_env_seed` builds the built-in baseline (`add_core_sigs`
# + `add_builtin_variant_sigs`) that every module inherits.
# `core_len = list_length(seed.entries)` is the boundary the
# `--holes` user-scope filter consults; it is the length of the
# *built-in* seed, NOT of any user core module.
#
# `build_ty_env_module` adds a single module's contributions to an
# inherited seed: registers every DFn / DType / DEffect against the
# entries already present, returning the updated env plus this
# module's op-effect arities. The fold composition is the call
# `build_ty_env_module(seed, all_decls)`, which is byte-identical
# to the monolithic builder.
#
# `unions` and `top_names` are global properties of the entire
# decl stream — collected once over the union of all modules and
# threaded around the per-module fold rather than recomputed per
# module. They are not part of `ModuleEnvDelta` under scope A.
fn build_ty_env_seed() : BuiltEnv {
  let e0 = ty_env_empty()
  let e1 = add_core_sigs(e0)
  let e2 = add_builtin_variant_sigs(e1)
  BuiltEnv { env: e2, core_len: list_length(e2.entries),
             op_eff_arities: [] }
}

fn build_ty_env_module(seed: BuiltEnv, decls: [Decl],
                        unions: [UnionInfo], top_names: [String]) : BuiltEnv {
  let env_with_unions = TyEnv {
    entries: seed.env.entries, fresh: seed.env.fresh, unions: unions, constructors: seed.env.constructors,
    head_owners: seed.env.head_owners, root_fns: seed.env.root_fns,
    row_kind: compute_row_kind_slots(decls), index: seed.env.index
  }
  let r = add_decls_loop(env_with_unions, seed.op_eff_arities, decls, top_names)
  BuiltEnv { env: r.env, core_len: seed.core_len,
             op_eff_arities: r.arities }
}

# `build_ty_env_module` variant that seeds the working
# env from a `ModuleEnvDelta` previously contributed by an upstream
# module (typically the core). The seed entries (built-in
# core + built-in variants) precede `inherited.ty_entries`, then
# `add_decls_loop` registers this module's decls on top. The
# resulting `BuiltEnv` carries `core_len` for the built-in
# boundary unchanged — `core_len` is the built-in seed length, an
# invariant of the compiler binary, NOT a per-module quantity.
#
# When `inherited == module_env_delta_empty()` the result is exactly
# `build_ty_env_module(seed, decls, unions, top_names)`, so callers
# that have no upstream delta keep the earlier byte-identical path.
fn build_ty_env_inherited(seed: BuiltEnv, inherited: ModuleEnvDelta,
                            decls: [Decl], unions: [UnionInfo],
                            top_names: [String]) : BuiltEnv =
  build_ty_env_inherited_rk(seed, inherited, decls, unions, top_names,
                            compute_row_kind_slots(decls))

# As `build_ty_env_inherited` but with an explicit row-kind table. The
# per-module typer fold passes the table computed over the FULL program
# decl stream, so a `T[..., e]` annotation in one module resolves the
# row slot of a type declared in another (e.g. a root `fn : Stream[t, e]`
# against stdlib's `Stream`).
fn build_ty_env_inherited_rk(seed: BuiltEnv, inherited: ModuleEnvDelta,
                            decls: [Decl], unions: [UnionInfo],
                            top_names: [String], rk_table: [RowKindEntry]) : BuiltEnv {
  # `inherited.ty_entries` are newer than the seed (prepended at head).
  # Prepend them onto BOTH the seed entries and the seed index in one
  # pass, sharing each entry exactly as `ty_env_add` does -- never
  # re-walking an already-stored list, which double-consumes its
  # backbone under Perceus.
  let env_in = match ty_env_prepend_batch(inherited.ty_entries, seed.env.entries, seed.env.index) {
    TEP(seeded_entries, seeded_index) -> TyEnv {
      entries: seeded_entries, fresh: seed.env.fresh, unions: unions,
      constructors: list_append(inherited.constructors, seed.env.constructors),
      head_owners: seed.env.head_owners, root_fns: seed.env.root_fns,
      row_kind: rk_table, index: seeded_index
    }
  }
  let ar_in = list_append(inherited.op_eff_arities, seed.op_eff_arities)
  let r = add_decls_loop_rk(env_in, ar_in, decls, top_names, rk_table)
  BuiltEnv { env: r.env, core_len: seed.core_len,
             op_eff_arities: r.arities }
}

#[doc("infer: build the initial typing environment (core + user sigs) for a decl list.")]
pub fn build_ty_env(decls: [Decl]) : BuiltEnv {
  let seed = build_ty_env_seed()
  # harvest the union summary once and stash it on the
  # env so every downstream typer query (`variants_of_type`,
  # `union_upcast_ok`, the collision diagnostic) sees the same data.
  let unions = collect_unions(decls)
  # pre-compute top-level type names so variant
  # registration can skip ctor entries whose name shadows.
  let top_names = collect_top_type_names(decls)
  build_ty_env_module(seed, decls, unions, top_names)
}

# ---- env dump (debugging) ----

fn scheme_to_string(sc: TyScheme) : String {
  match sc {
    Scheme(vars, rvars, uvars, _, ty) -> {
      let tv_part = map(vars, (n) => cat2("?t", int_to_string(n)))
      let rv_part = map(rvars, (n) => cat2("?r", int_to_string(n)))
      let uv_part = map(uvars, (n) => cat2("?u", int_to_string(n)))
      let all = list_append(tv_part, list_append(rv_part, uv_part))
      match all {
        [] -> inf_ty_to_string(ty)
        _  -> concat_all(["forall ", inf_join_with(all, " "), ". ", inf_ty_to_string(ty)])
      }
    }
  }
}

fn dump_env_entry(e: TyEntry) : Unit / Console =
  print("#{e.name} : #{scheme_to_string(e.scheme)}")

#[doc("infer: --dump-env dump of the typing environment.")]
pub fn dump_env(env: TyEnv) : Unit / Console = dump_env_loop(list_reverse(env.entries))

fn dump_env_loop(es: [TyEntry]) : Unit / Console {
  match es {
    [] -> ()
    [e, ...rest] -> { dump_env_entry(e) dump_env_loop(rest) }
  }
}

# ====================================================================
# substitution + unification
# ====================================================================
#
# A Subst maps type-variable ids to types. It is applied to a type by
# walking structurally and replacing each TyVarT(n) whose n has a
# binding in the substitution. Unification takes two types and either
# extends a substitution so the two become equal or reports failure.
#
# The occurs check prevents infinite types: unifying `?t0` with
# `[?t0]` would otherwise loop, so we refuse.
#
# Instantiation turns a TyScheme into a Ty by replacing each bound id
# with a fresh TyVarT drawn from the environment's counter. Each call
# site of a polymorphic function gets its own fresh vars.

# The substitution is indexed directly by TyVar id, so apply_ty and
# occurs do O(1) lookups instead of walking an association list.
#
# ⚠️  Aliasing hazard. `Array[T]` is a provisional audited escape
# (see CLAUDE.md Tier 1 and docs/design.md "Memory model"): the
# mutation is not visible in the type. Every kaikai value otherwise
# pretends to be immutable, so the usual mental model —
# "Subst { slots: ... } builds a new record, the old subst is still
# valid" — is WRONG here. subst_extend mutates `s.slots` in place
# and returns a new Subst record that **aliases the same array**.
#
# The contract callers must obey:
#
#   1. Thread the substitution linearly. unify, st_set_sub,
#      mk_fresh_subst all do this already: extend it, pass it
#      forward, never look at the old value.
#   2. **Never fork** a Subst between two alternative trials and
#      compare results. Both trials will see each other's mutations
#      and the inference will silently corrupt. If you ever need
#      speculative unification (e.g. for typeclass resolution or
#      intersection types), this representation must change first.
#   3. Do not publish a Subst outside the inferencer's control flow
#      (no storing in long-lived records, no returning via Option,
#      no capturing in a closure that outlives the caller).
#
# When the `Mutable` effect lands, `array_set` should require it,
# and these informal rules become a type-level obligation.
type Subst = {
  slots:     Array[Option[Ty]],
  row_slots: Array[Option[Row]],
  row_fresh: Int,
  # parallel slot table for unit unification variables (UVar).
  # Same opaque-mutable Array discipline as `slots`; never publish
  # outside the inferencer.
  unit_slots: Array[Option[UnitExprT]],
  unit_fresh: Int,
  # the atomic (kind, theory) pairs: unit formation and unify_dim
  # dispatch on the theory of each habitant's kind. Program-wide,
  # read-only after seeding.
  kind_theories: [KindTheory],
  # the kind each constrained unit var ranges over: seeded from the
  # decl's unit tparams and copied to fresh vars at instantiation.
  # A var absent here is unconstrained. The abelian pivot consults
  # this before binding, so a habitant of one kind cannot bind a
  # tparam declared over another.
  unit_var_kinds: [UVKind]
}

#[doc("infer: a (unit-var id, kind name) constraint entry.")]
pub type UVKind = UVK(Int, String)

fn subst_empty() : Subst = Subst {
  slots:     array_make(64, None),
  row_slots: array_make(16, None),
  row_fresh: 0,
  unit_slots: array_make(16, None),
  unit_fresh: 0,
  kind_theories: [],
  unit_var_kinds: []
}

fn subst_seed_kind_theories(s: Subst, kts: [KindTheory]) : Subst = Subst {
  slots: s.slots, row_slots: s.row_slots, row_fresh: s.row_fresh,
  unit_slots: s.unit_slots, unit_fresh: s.unit_fresh, kind_theories: kts,
  unit_var_kinds: s.unit_var_kinds
}

fn subst_unit_kind_lookup(s: Subst, v: Int) : Option[String] =
  uvk_lookup(s.unit_var_kinds, v)

fn uvk_lookup(xs: [UVKind], v: Int) : Option[String] = match xs {
  [] -> None
  [h, ...rest] -> match h {
    UVK(id, k) -> if id == v { Some(k) } else { uvk_lookup(rest, v) }
  }
}

# Constrain unit var `v` to kind `k`. `""` (kind-agnostic) adds nothing.
fn subst_add_unit_kind(s: Subst, v: Int, k: String) : Subst =
  if k == "" { s }
  else { Subst { slots: s.slots, row_slots: s.row_slots, row_fresh: s.row_fresh,
                 unit_slots: s.unit_slots, unit_fresh: s.unit_fresh,
                 kind_theories: s.kind_theories,
                 unit_var_kinds: [UVK(v, k), ...s.unit_var_kinds] } }

fn subst_add_unit_kinds(s: Subst, ids: [Int], kinds: [String]) : Subst {
  match ids {
    [] -> s
    [i, ...irest] -> match kinds {
      [] -> s
      [k, ...krest] -> subst_add_unit_kinds(subst_add_unit_kind(s, i, k), irest, krest)
    }
  }
}

fn subst_lookup(s: Subst, v: Int) : Option[Ty] {
  if v >= array_length(s.slots) { None }
  else { array_get(s.slots, v) }
}

fn subst_extend(s: Subst, v: Int, ty: Ty) : Subst / Mutable {
  let len = array_length(s.slots)
  let slots1 = if v >= len {
    let grown = if v + 1 > len * 2 { v + 1 } else { len * 2 }
    array_grow(s.slots, grown, None)
  } else { s.slots }
  let slots2 = array_set(slots1, v, Some(ty))
  Subst { slots: slots2, row_slots: s.row_slots, row_fresh: s.row_fresh,
          unit_slots: s.unit_slots, unit_fresh: s.unit_fresh,
          kind_theories: s.kind_theories, unit_var_kinds: s.unit_var_kinds }
}

# Row-var substitution (parallel to subst_lookup / subst_extend, but
# indexed into row_slots). Row vars are only created during unify_row,
# never elsewhere.

fn subst_row_lookup(s: Subst, v: Int) : Option[Row] {
  # tolerate sentinel negative ids that `row_of_expr_with_binds`
  # emits when a row variable name was not resolved (e.g. an alias body
  # whose row tparam remained after alias expansion). Treat as unbound
  # instead of paniccing in `array_get`.
  if v < 0 { None }
  else if v >= array_length(s.row_slots) { None }
  else { array_get(s.row_slots, v) }
}

fn subst_row_extend(s: Subst, v: Int, r: Row) : Subst / Mutable {
  let len = array_length(s.row_slots)
  let rs1 = if v >= len {
    let grown = if v + 1 > len * 2 { v + 1 } else { len * 2 }
    array_grow(s.row_slots, grown, None)
  } else { s.row_slots }
  let rs2 = array_set(rs1, v, Some(r))
  Subst { slots: s.slots, row_slots: rs2, row_fresh: s.row_fresh,
          unit_slots: s.unit_slots, unit_fresh: s.unit_fresh,
          kind_theories: s.kind_theories, unit_var_kinds: s.unit_var_kinds }
}

# Allocate a fresh row variable id and bump the counter. Returned in
# a record because kaikai stage 2 has no tuples.
type FreshRow = { id: Int, subst: Subst }

fn subst_fresh_row(s: Subst) : FreshRow {
  let id = s.row_fresh
  let s1 = Subst { slots: s.slots, row_slots: s.row_slots, row_fresh: id + 1,
                   unit_slots: s.unit_slots, unit_fresh: s.unit_fresh,
                   kind_theories: s.kind_theories, unit_var_kinds: s.unit_var_kinds }
  FreshRow { id: id, subst: s1 }
}

# unit-var substitution. UVar(n) into the parallel `unit_slots`
# array. Same growth/lookup discipline as the type-var slots.
fn subst_unit_lookup(s: Subst, v: Int) : Option[UnitExprT] {
  if v >= array_length(s.unit_slots) { None }
  else { array_get(s.unit_slots, v) }
}

fn subst_unit_extend(s: Subst, v: Int, u: UnitExprT) : Subst / Mutable {
  let len = array_length(s.unit_slots)
  let us1 = if v >= len {
    let grown = if v + 1 > len * 2 { v + 1 } else { len * 2 }
    array_grow(s.unit_slots, grown, None)
  } else { s.unit_slots }
  let us2 = array_set(us1, v, Some(u))
  Subst { slots: s.slots, row_slots: s.row_slots, row_fresh: s.row_fresh,
          unit_slots: us2, unit_fresh: s.unit_fresh,
          kind_theories: s.kind_theories, unit_var_kinds: s.unit_var_kinds }
}

type FreshUnit = { id: Int, subst: Subst }

fn subst_fresh_unit(s: Subst) : FreshUnit {
  let id = s.unit_fresh
  let s1 = Subst { slots: s.slots, row_slots: s.row_slots, row_fresh: s.row_fresh,
                   unit_slots: s.unit_slots, unit_fresh: id + 1,
                   kind_theories: s.kind_theories, unit_var_kinds: s.unit_var_kinds }
  FreshUnit { id: id, subst: s1 }
}

# ====================================================================
# unit-of-measure operations
# ====================================================================
#
# Three layers of operations on UnitExprT:
#   1. unit_to_table / unit_from_table — convert between the AST tree
#      shape and a canonical (sym, exponent) / (uvar, exponent) table.
#   2. unit_canon — normal form: alphabetically-sorted symbols, grouped
#      exponents, no factor-of-1 noise.
#   3. unify_abelian — abelian-group unification (Stuckey/Kennedy): solve
#      `u1 = u2` by reducing `u1 * u2^-1 = 1` to a substitution.
#
# Aliases (`unit Newton = kg * m / sec^2`) are expanded by the *resolver*
# before they reach unification; canonicalisation never sees them.

# Sym and unit-var entries of the canonical table. Both use a sorted
# (key, exponent) representation; zero exponents are dropped.
type USymEntry = USE(String, Int)
type UVarEntry = UVE(Int, Int)

type UTable = { syms: [USymEntry], vars: [UVarEntry] }

fn utable_empty() : UTable = UTable { syms: [], vars: [] }

# True iff the table represents the dimensionless unit "1".
fn utable_is_one(t: UTable) : Bool {
  match t.syms { [] -> match t.vars { [] -> true _ -> false } _ -> false }
}

# Insert a `(sym, exp)` contribution; merges with an existing entry by
# adding exponents; drops entries that reach 0; keeps the list sorted
# alphabetically.
fn usym_insert(xs: [USymEntry], k: String, n: Int) : [USymEntry] {
  match xs {
    [] -> if n == 0 { [] } else { [USE(k, n)] }
    [h, ...rest] -> match h {
      USE(hk, hn) ->
        if hk == k {
          let m = hn + n
          if m == 0 { rest } else { [USE(hk, m), ...rest] }
        } else if string_lt(k, hk) {
          if n == 0 { [h, ...rest] } else { [USE(k, n), h, ...rest] }
        } else {
          [h, ...usym_insert(rest, k, n)]
        }
    }
  }
}

fn uvar_insert(xs: [UVarEntry], k: Int, n: Int) : [UVarEntry] {
  match xs {
    [] -> if n == 0 { [] } else { [UVE(k, n)] }
    [h, ...rest] -> match h {
      UVE(hk, hn) ->
        if hk == k {
          let m = hn + n
          if m == 0 { rest } else { [UVE(hk, m), ...rest] }
        } else if k < hk {
          if n == 0 { [h, ...rest] } else { [UVE(k, n), h, ...rest] }
        } else {
          [h, ...uvar_insert(rest, k, n)]
        }
    }
  }
}

# Walk a UnitExprT, accumulating contributions into the table. The
# `mul` parameter scales every leaf's exponent; flips sign for UInv
# and multiplies by n for UPow.
fn unit_to_table_at(u: UnitExprT, scale: Int, t: UTable) : UTable {
  match u {
    UOne -> t
    USym(s) -> UTable { syms: usym_insert(t.syms, s, scale), vars: t.vars }
    UVar(v) -> UTable { syms: t.syms, vars: uvar_insert(t.vars, v, scale) }
    UMul(a, b) -> unit_to_table_at(b, scale, unit_to_table_at(a, scale, t))
    UInv(a) -> unit_to_table_at(a, 0 - scale, t)
    UPow(a, n) -> unit_to_table_at(a, scale * n, t)
    # a join contributes each side at the same scale; the semilattice
    # engine reads any positive multiplicity as membership.
    UJoin(a, b) -> unit_to_table_at(b, scale, unit_to_table_at(a, scale, t))
    # Positional lists are intercepted before any equality decision
    # reaches a table (unify_dim, unit_canon, apply_unit). Merging the
    # components here keeps the walk total for the two consumers that
    # only read the table's sym/var SETS: the kind gate and the occurs
    # check, for both of which the merged set is exactly right.
    UDims(us) -> units_to_table_at(us, scale, t)
  }
}

fn units_to_table_at(us: [UnitExprT], scale: Int, t: UTable) : UTable = match us {
  [] -> t
  [u, ...rest] -> units_to_table_at(rest, scale, unit_to_table_at(u, scale, t))
}

fn unit_to_table(u: UnitExprT) : UTable = unit_to_table_at(u, 1, utable_empty())

# parallel walker that *also* chases UVar bindings through the
# substitution. `seen` keeps the recursion linear by short-circuiting
# any cycle (occurs check is the real guard; this is just defence).
fn unit_resolve_to_at(u: UnitExprT, scale: Int, t: UTable, s: Subst, seen: [Int]) : UTable {
  match u {
    UOne -> t
    USym(sm) -> UTable { syms: usym_insert(t.syms, sm, scale), vars: t.vars }
    UVar(v) -> {
      if list_has_int(seen, v) {
        UTable { syms: t.syms, vars: uvar_insert(t.vars, v, scale) }
      } else {
        match subst_unit_lookup(s, v) {
          Some(u_sub) -> unit_resolve_to_at(u_sub, scale, t, s, [v, ...seen])
          None -> UTable { syms: t.syms, vars: uvar_insert(t.vars, v, scale) }
        }
      }
    }
    UMul(a, b) -> unit_resolve_to_at(b, scale, unit_resolve_to_at(a, scale, t, s, seen), s, seen)
    UInv(a) -> unit_resolve_to_at(a, 0 - scale, t, s, seen)
    UPow(a, n) -> unit_resolve_to_at(a, scale * n, t, s, seen)
    UJoin(a, b) -> unit_resolve_to_at(b, scale, unit_resolve_to_at(a, scale, t, s, seen), s, seen)
    UDims(us) -> units_resolve_to_at(us, scale, t, s, seen)
  }
}

fn units_resolve_to_at(us: [UnitExprT], scale: Int, t: UTable, s: Subst, seen: [Int]) : UTable = match us {
  [] -> t
  [u, ...rest] -> units_resolve_to_at(rest, scale, unit_resolve_to_at(u, scale, t, s, seen), s, seen)
}

# Rebuild a UnitExprT from a canonical table. The table is already
# sorted, so we walk left-to-right and chain UMul; positive exponents
# render as USym/UVar (or UPow when |n|>1), negative as UInv-of-pow.
fn utable_to_tree(t: UTable) : UnitExprT {
  let factors_syms = sym_entries_to_factors(t.syms)
  let factors_vars = var_entries_to_factors(t.vars)
  let all_factors = list_append(factors_syms, factors_vars)
  match all_factors {
    [] -> UOne
    [h, ...rest] -> tree_chain(h, rest)
  }
}

# helpers to convert table entries into UnitExprT factors.
# Standalone (rather than inline lambdas) because stage 1's lambda
# free-var analysis would over-capture the pattern binders here.
fn sym_entries_to_factors(xs: [USymEntry]) : [UnitExprT] {
  match xs {
    [] -> []
    [h, ...rest] -> match h {
      USE(k, n) -> [sym_factor(k, n), ...sym_entries_to_factors(rest)]
    }
  }
}

fn var_entries_to_factors(xs: [UVarEntry]) : [UnitExprT] {
  match xs {
    [] -> []
    [h, ...rest] -> match h {
      UVE(k, n) -> [var_factor(k, n), ...var_entries_to_factors(rest)]
    }
  }
}

fn sym_factor(k: String, n: Int) : UnitExprT {
  if n == 1 { USym(k) }
  else if n == 0 - 1 { UInv(USym(k)) }
  else if n > 0 { UPow(USym(k), n) }
  else { UInv(UPow(USym(k), 0 - n)) }
}

fn var_factor(k: Int, n: Int) : UnitExprT {
  if n == 1 { UVar(k) }
  else if n == 0 - 1 { UInv(UVar(k)) }
  else if n > 0 { UPow(UVar(k), n) }
  else { UInv(UPow(UVar(k), 0 - n)) }
}

fn tree_chain(acc: UnitExprT, rest: [UnitExprT]) : UnitExprT {
  match rest {
    [] -> acc
    [h, ...tl] -> tree_chain(UMul(acc, h), tl)
  }
}

# Public canonicaliser. Aliases are *not* expanded here; that's the
# resolver's job (resolve_ty_with_units below). A positional list
# canonicalises point to point — its components never merge into one
# abelian table.
#[doc("infer: `unit_canon` — typer entry point invoked by the driver.")]
pub fn unit_canon(u: UnitExprT) : UnitExprT = match u {
  UDims(us) -> UDims(units_canon(us))
  _ -> utable_to_tree(unit_to_table(u))
}

fn units_canon(us: [UnitExprT]) : [UnitExprT] = match us {
  [] -> []
  [u, ...rest] -> [unit_canon(u), ...units_canon(rest)]
}

fn unit_is_one(u: UnitExprT) : Bool = match u {
  UDims(_) -> false
  _ -> utable_is_one(unit_to_table(u))
}

# Apply the unit substitution to a UnitExprT: each UVar(n) is chased
# through unit_slots to its current binding (if any), and the resolved
# tree is canonicalised. This is the unit-side analogue of apply_ty
# and must be called before any structural decision about a unit.
# The head is chased without table conversion first, so a variable
# bound to a positional list surfaces intact.
fn apply_unit(s: Subst, u: UnitExprT) : UnitExprT {
  match unit_resolve_hab_head(s, u, []) {
    UDims(us) -> UDims(apply_units(s, us))
    r -> utable_to_tree(unit_to_table_resolved(r, s))
  }
}

fn apply_units(s: Subst, us: [UnitExprT]) : [UnitExprT] = match us {
  [] -> []
  [u, ...rest] -> [apply_unit(s, u), ...apply_units(s, rest)]
}

# Chase a top-level UVar chain to its binding without converting to a
# table, so a positional-list binding is seen as such. `seen` guards
# against cycles (the occurs check is the real guard).
fn unit_resolve_hab_head(s: Subst, u: UnitExprT, seen: [Int]) : UnitExprT = match u {
  UVar(v) ->
    if list_has_int(seen, v) { u }
    else { match subst_unit_lookup(s, v) {
      Some(b) -> unit_resolve_hab_head(s, b, [v, ...seen])
      None -> u
    } }
  _ -> u
}

# Walk the unit, chasing UVar bindings through `s.unit_slots`. The
# Bool guard prevents cycles by remembering which uvars we've already
# expanded on the current path; a cycle indicates a bug elsewhere
# (occurs check should have caught it) and we treat it as identity.
fn unit_to_table_resolved(u: UnitExprT, s: Subst) : UTable =
  unit_resolve_to_at(u, 1, utable_empty(), s, [])

# Subtract `b` from `a` (i.e. compute `a / b` as exponent vector). The
# result is `a * b^-1` in canonical form.
fn utable_diff(a: UTable, b: UTable) : UTable {
  let s1 = utable_diff_syms(a.syms, b.syms)
  let v1 = utable_diff_vars(a.vars, b.vars)
  UTable { syms: s1, vars: v1 }
}

fn utable_diff_syms(a: [USymEntry], b: [USymEntry]) : [USymEntry] {
  match b {
    [] -> a
    [h, ...rest] -> match h {
      USE(k, n) -> utable_diff_syms(usym_insert(a, k, 0 - n), rest)
    }
  }
}

fn utable_diff_vars(a: [UVarEntry], b: [UVarEntry]) : [UVarEntry] {
  match b {
    [] -> a
    [h, ...rest] -> match h {
      UVE(k, n) -> utable_diff_vars(uvar_insert(a, k, 0 - n), rest)
    }
  }
}

# Pick the unit-var with the smallest |exponent| in the table; returns
# (index_in_vars, var_id, exponent). None if `vars` is empty.
type UPickVar = { id: Int, exp: Int }

fn utable_pick_min_var(t: UTable) : Option[UPickVar] {
  match t.vars {
    [] -> None
    [h, ...rest] -> match h {
      UVE(id, e) -> Some(utable_pick_min_var_pick(rest, UPickVar { id: id, exp: e }))
    }
  }
}

fn utable_pick_min_var_pick(rest: [UVarEntry], best: UPickVar) : UPickVar {
  match rest {
    [] -> best
    [h, ...tl] -> match h {
      UVE(id, e) -> {
        let abs_e = abs_int(e)
        let abs_b = abs_int(best.exp)
        if abs_e < abs_b { utable_pick_min_var_pick(tl, UPickVar { id: id, exp: e }) }
        else { utable_pick_min_var_pick(tl, best) }
      }
    }
  }
}

# Remove a single (var, exp) entry by its id from the table, returning
# the table without that var.
fn utable_drop_var(t: UTable, target: Int) : UTable {
  UTable { syms: t.syms, vars: utable_drop_var_loop(t.vars, target) }
}

fn utable_drop_var_loop(xs: [UVarEntry], target: Int) : [UVarEntry] {
  match xs {
    [] -> []
    [h, ...rest] -> match h {
      UVE(k, _) -> if k == target { rest } else { [h, ...utable_drop_var_loop(rest, target)] }
    }
  }
}

# True iff every entry's exponent is a multiple of `k`. Used by the
# unit unifier to decide whether the chosen pivot var divides cleanly.
fn utable_all_divisible(t: UTable, k: Int) : Bool =
  syms_divisible(t.syms, k) and vars_divisible(t.vars, k)

fn syms_divisible(xs: [USymEntry], k: Int) : Bool {
  match xs {
    [] -> true
    [h, ...rest] -> match h {
      USE(_, n) -> if (n - (n / k) * k) == 0 { syms_divisible(rest, k) } else { false }
    }
  }
}

fn vars_divisible(xs: [UVarEntry], k: Int) : Bool {
  match xs {
    [] -> true
    [h, ...rest] -> match h {
      UVE(_, n) -> if (n - (n / k) * k) == 0 { vars_divisible(rest, k) } else { false }
    }
  }
}

# Negate every exponent and divide by k (caller guarantees k | every
# entry). Used to construct the substitution `var := -(rest)/k`.
fn utable_negdiv(t: UTable, k: Int) : UTable {
  UTable {
    syms: usym_negdiv(t.syms, k),
    vars: uvar_negdiv(t.vars, k)
  }
}

fn usym_negdiv(xs: [USymEntry], k: Int) : [USymEntry] {
  match xs {
    [] -> []
    [h, ...rest] -> match h {
      USE(s, n) -> [USE(s, (0 - n) / k), ...usym_negdiv(rest, k)]
    }
  }
}

fn uvar_negdiv(xs: [UVarEntry], k: Int) : [UVarEntry] {
  match xs {
    [] -> []
    [h, ...rest] -> match h {
      UVE(v, n) -> [UVE(v, (0 - n) / k), ...uvar_negdiv(rest, k)]
    }
  }
}

# Occurs check: does unit-var `v` appear (after substitution chase) in
# `u`? Refuses self-binding to keep apply_unit terminating.
fn occurs_unit(v: Int, u: UnitExprT, s: Subst) : Bool {
  let tab = unit_to_table_resolved(u, s)
  occurs_unit_in_vars(v, tab.vars)
}

fn occurs_unit_in_vars(v: Int, xs: [UVarEntry]) : Bool {
  match xs {
    [] -> false
    [h, ...rest] -> match h {
      UVE(k, _) -> if k == v { true } else { occurs_unit_in_vars(v, rest) }
    }
  }
}

# Dimension-unification dispatch seam. Positional lists (`<m, n>`)
# unify point to point before any table forms; after that the kind's
# theory selects the engine: Semilattice kinds ride the subsumption
# join (`unify_semilattice`), nominal-slot kinds (Module and Composition
# atoms, Dim's value indices) identity-plus-binding (`unify_nominal`),
# everything else the abelian solver. Composition's order and summed
# measure are formation invariants of the composed type, not this seam.
fn unify_dim(u1: UnitExprT, u2: UnitExprT, s: Subst) : Option[Subst] / Mutable {
  let h1 = unit_resolve_hab_head(s, u1, [])
  let h2 = unit_resolve_hab_head(s, u2, [])
  match h1 {
    UDims(xs) -> match h2 {
      UDims(ys) -> unify_dims(xs, ys, s)
      UVar(v) -> bind_unit_dims(v, xs, s)
      _ -> None
    }
    _ -> match h2 {
      UDims(ys) -> match h1 {
        UVar(v) -> bind_unit_dims(v, ys, s)
        _ -> None
      }
      _ -> {
        let t1 = unit_to_table_resolved(h1, s)
        let t2 = unit_to_table_resolved(h2, s)
        if utable_semilattice_theory(t1, s) or utable_semilattice_theory(t2, s) {
          unify_semilattice(t1, t2, s)
        } else if utable_first_order(t1, s) or utable_first_order(t2, s) {
          unify_nominal(t1, t2, s)
        } else {
          unify_abelian_diff(utable_diff(t1, t2), s)
        }
      }
    }
  }
}

fn unify_dims(xs: [UnitExprT], ys: [UnitExprT], s: Subst) : Option[Subst] / Mutable = match xs {
  [] -> match ys { [] -> Some(s) _ -> None }
  [x, ...xr] -> match ys {
    [] -> None
    [y, ...yr] -> match unify_dim(x, y, s) {
      None -> None
      Some(s1) -> unify_dims(xr, yr, s1)
    }
  }
}

# Bind a unit variable to a whole positional list. The occurs check
# and the kind gate both read the merged component table, which
# carries exactly the sym/var sets each needs.
fn bind_unit_dims(v: Int, us: [UnitExprT], s: Subst) : Option[Subst] / Mutable {
  let bound = UDims(us)
  if occurs_unit(v, bound, s) { None }
  else {
    match unit_kind_gate(s, v, bound) {
      None -> None
      Some(s1) -> Some(subst_unit_extend(s1, v, bound))
    }
  }
}

# A table rides the nominal slot verdict when any habitant's kind — or
# any variable's kind constraint — is declared over a first-order theory
# (Module, Composition, or the HM core behind `Dim`).
fn utable_first_order(t: UTable, s: Subst) : Bool =
  usyms_any_first_order(t.syms, s.kind_theories) or uvars_any_first_order(t.vars, s)

fn usyms_any_first_order(xs: [USymEntry], kts: [KindTheory]) : Bool = match xs {
  [] -> false
  [h, ...rest] -> match h {
    USE(k, _) ->
      kind_is_first_order(kts, kind_sym_kind(k)) or usyms_any_first_order(rest, kts)
  }
}

fn uvars_any_first_order(xs: [UVarEntry], s: Subst) : Bool = match xs {
  [] -> false
  [h, ...rest] -> match h {
    UVE(v, _) -> match subst_unit_kind_lookup(s, v) {
      Some(k) -> kind_is_first_order(s.kind_theories, k) or uvars_any_first_order(rest, s)
      None -> uvars_any_first_order(rest, s)
    }
  }
}

# A table rides the Semilattice engine when any habitant's kind — or
# any variable's kind constraint — is declared over the Semilattice
# theory.
fn utable_semilattice_theory(t: UTable, s: Subst) : Bool =
  usyms_any_semilattice(t.syms, s.kind_theories) or uvars_any_semilattice(t.vars, s)

fn usyms_any_semilattice(xs: [USymEntry], kts: [KindTheory]) : Bool = match xs {
  [] -> false
  [h, ...rest] -> match h {
    USE(k, _) ->
      kind_is_semilattice(kts, kind_sym_kind(k)) or usyms_any_semilattice(rest, kts)
  }
}

fn uvars_any_semilattice(xs: [UVarEntry], s: Subst) : Bool = match xs {
  [] -> false
  [h, ...rest] -> match h {
    UVE(v, _) -> match subst_unit_kind_lookup(s, v) {
      Some(k) -> kind_is_semilattice(s.kind_theories, k) or uvars_any_semilattice(rest, s)
      None -> uvars_any_semilattice(rest, s)
    }
  }
}

# The Semilattice engine: classify each side (ground habitant set,
# lone variable) and unify by subsumption — the required (expected)
# side must be a subset of the provided side. A variable bind still
# passes the kind gate, so a habitant of another kind cannot bind a
# Semilattice tparam.
fn unify_semilattice(t1: UTable, t2: UTable, s: Subst) : Option[Subst] / Mutable {
  let v1 = sl_side(utable_symexps(t1), utable_varexps(t1))
  let v2 = sl_side(utable_symexps(t2), utable_varexps(t2))
  match sl_unify_verdict(v1, v2) {
    SlOk -> Some(s)
    SlFail -> None
    SlBind(v, bound) -> match unit_kind_gate(s, v, bound) {
      None -> None
      Some(s1) -> Some(subst_unit_extend(s1, v, bound))
    }
  }
}

# The nominal slot engine shared by Module and Composition: classify
# each side (dimensionless, lone atom, lone variable) and unify by atom
# identity. A variable bind still passes the kind gate, so a habitant of
# another kind cannot bind the tparam — and Composition's order/measure
# invariants ride the composed type's formation, not this slot verdict.
fn unify_nominal(t1: UTable, t2: UTable, s: Subst) : Option[Subst] / Mutable {
  let v1 = nominal_side(utable_symexps(t1), utable_varexps(t1))
  let v2 = nominal_side(utable_symexps(t2), utable_varexps(t2))
  match nominal_unify_verdict(v1, v2) {
    MEq -> Some(s)
    MFail -> None
    MBind(v, bound) -> match unit_kind_gate(s, v, bound) {
      None -> None
      Some(s1) -> Some(subst_unit_extend(s1, v, bound))
    }
  }
}

fn utable_symexps(t: UTable) : [SymExp] = use_to_symexps(t.syms)

fn use_to_symexps(xs: [USymEntry]) : [SymExp] = match xs {
  [] -> []
  [h, ...rest] -> match h { USE(k, n) -> [SEx(k, n), ...use_to_symexps(rest)] }
}

fn utable_varexps(t: UTable) : [VarExp] = uve_to_varexps(t.vars)

fn uve_to_varexps(xs: [UVarEntry]) : [VarExp] = match xs {
  [] -> []
  [h, ...rest] -> match h { UVE(v, n) -> [VEx(v, n), ...uve_to_varexps(rest)] }
}

# Unify two unit expressions under `s`. The classic equational view:
# `u1 ≡ u2` iff `u1 * u2^-1 ≡ 1`. We solve the homogeneous form by
# repeatedly picking the unit-var with the smallest |exponent| and
# isolating it. Polynomial in the size of the input — Kennedy 1996.
#
# Stop guard: this function only ever recurses through utable bookkeeping
# and a single substitution + retry. If the lane ever needs to introduce
# a real Smith-normal-form pass, that is a sign the design is being
# pushed past the docs/units-of-measure.md "polynomial" promise — call
# it out before extending.
fn unify_abelian(u1: UnitExprT, u2: UnitExprT, s: Subst) : Option[Subst] / Mutable {
  let t1 = unit_to_table_resolved(u1, s)
  let t2 = unit_to_table_resolved(u2, s)
  let diff = utable_diff(t1, t2)
  unify_abelian_diff(diff, s)
}

fn unify_abelian_diff(t: UTable, s: Subst) : Option[Subst] / Mutable {
  if utable_is_one(t) { Some(s) }
  else {
    match utable_pick_min_var(t) {
      None -> None                                 # only syms left, but non-zero — fail
      Some(pick) -> {
        let rest = utable_drop_var(t, pick.id)
        let k = pick.exp
        if utable_all_divisible(rest, k) {
          # Bind `pick.id := (-rest) / k`. occurs check guards against
          # self-cycle (would be unusual since we removed the var).
          let bound = utable_to_tree(utable_negdiv(rest, k))
          if occurs_unit(pick.id, bound, s) { None }
          else {
            match unit_kind_gate(s, pick.id, bound) {
              None -> None
              Some(s1) -> Some(subst_unit_extend(s1, pick.id, bound))
            }
          }
        } else {
          # Pivot does not cleanly divide the remainder. The classical
          # Kennedy/Stuckey fix introduces a fresh unit-var w and
          # rewrites `pick := w * (low/k)` so the residual equation
          # uses smaller exponents. The lane fixtures don't exercise
          # this path (every case the lane ships pivots with |k|=1).
          # Refuse here so the failure is loud rather than silent —
          # see docs/units-of-measure.md §Risks "polynomial" guarantee.
          None
        }
      }
    }
  }
}

# The kind a habitant symbol inhabits: its qualifier when present,
# Measure for a bare symbol (default-kind habitants stay bare by
# construction — see kind_qualify_nondefault).
fn unit_sym_kind_name(sym: String) : String =
  if kind_sym_is_qualified(sym) { kind_sym_kind(sym) } else { measure_kind_name() }

# Kind gate on a pivot bind `?v := bound`: when `v` is constrained to
# kind K, every habitant symbol in `bound` must inhabit K, and every
# unit var in `bound` inherits the constraint. A cross-kind habitant
# or a conflicting var constraint refuses the bind (None), surfacing
# as the ordinary unification mismatch at the source position.
fn unit_kind_gate(s: Subst, v: Int, bound: UnitExprT) : Option[Subst] {
  match subst_unit_kind_lookup(s, v) {
    None -> Some(s)
    Some(k) -> {
      let t = unit_to_table(bound)
      if uk_syms_ok(t.syms, k) { uk_constrain_vars(t.vars, k, s) } else { None }
    }
  }
}

fn uk_syms_ok(xs: [USymEntry], k: String) : Bool = match xs {
  [] -> true
  [h, ...rest] -> match h {
    USE(sym, _) -> if unit_sym_kind_name(sym) == k { uk_syms_ok(rest, k) } else { false }
  }
}

fn uk_constrain_vars(xs: [UVarEntry], k: String, s: Subst) : Option[Subst] = match xs {
  [] -> Some(s)
  [h, ...rest] -> match h {
    UVE(v, _) -> match subst_unit_kind_lookup(s, v) {
      None -> uk_constrain_vars(rest, k, subst_add_unit_kind(s, v, k))
      Some(k2) -> if k2 == k { uk_constrain_vars(rest, k, s) } else { None }
    }
  }
}

# Formation check on a canonical table, dispatched by each habitant
# kind's theory (atom_form_violation in kind_theory).
fn utable_atom_violation(t: UTable, kts: [KindTheory]) : Option[String] =
  atom_form_violation(utable_symexps(t), list_length(t.vars), kts)

# Apply the substitution to a type. Recurses structurally; resolves
# `TyVarT(n)` via subst_lookup, then recurses on the replacement so a
# chained binding `?t0 -> ?t1 -> Int` collapses to `Int`.
fn apply_ty(s: Subst, t: Ty) : Ty {
  match t {
    TyInt    -> t
    TyReal   -> t
    TyBool   -> t
    TyString -> t
    TyChar   -> t
    TyUnit   -> t
    TyByte     -> t
    TyInt32    -> t
    TyUInt32   -> t
    TyUInt64   -> t
    TyInt128   -> t
    TyHandle   -> t
    TyAny    -> t
    TyVarT(n) -> match subst_lookup(s, n) {
      Some(t2) -> apply_ty(s, t2)
      None     -> t
    }
    TyListT(inner) -> TyListT(apply_ty(s, inner))
    TyFnT(params, ret, row) -> TyFnT(apply_tys(s, params), apply_ty(s, ret), apply_row(s, row))
    TyCon(mo_, name, atys) -> TyCon(mo_, name, apply_tys(s, atys))
    # Once the shape var binds to a constructor witness, reconstruct the
    # concrete applied type (`s := List, A := Int` → `TyListT(Int)`), so
    # a resolved `TyShapeApp` never survives past substitution. Unbound,
    # only the argument is walked.
    TyShapeApp(sv, arg) -> match subst_lookup(s, sv) {
      Some(wit) -> shape_reapply(apply_ty(s, wit), apply_ty(s, arg))
      None      -> TyShapeApp(sv, apply_ty(s, arg))
    }
    # applying a substitution to a dimensioned type recurses into
    # both the base type and the unit expression. Unit-vars chase
    # through unit_slots; everything else passes through unchanged.
    TyDimT(base, u) -> dim_collapse(apply_ty(s, base), apply_unit(s, u))
    # substitutions don't touch the predicate Expr (it
    # references value-level identifiers, not Ty vars); just recurse
    # through the base.
    TyRefineT(base, p) -> TyRefineT(apply_ty(s, base), p)
    # substitute through each component then
    # re-normalise. A substitution can change a component's mangled
    # form (e.g. `?t0` → `Int`), which can re-order the canonical
    # list and uncover new duplicates that idempotence collapses.
    TyUnion(parts) -> normalize_union(map(parts, (p) => apply_ty(s, p)))
  }
}


# collapse `TyDimT(TyDimT(b, u1), u2)` to `TyDimT(b, u1*u2)` and
# strip a `TyDimT(_, UOne)` down to its base. Both shapes can arise
# transiently when chasing unit-vars through nested dimensioned types.
# also lift refinements outside of unit wrappers — the
# canonical form is `TyRefineT(TyDimT(b, u), p)`. The predicate
# describes the value of the dimensioned quantity; the unit
# describes the dimension. Putting refinements outside lets the
# pred-lookup walkers find them at the top of the type tree.
#[doc("infer: `dim_collapse` — typer entry point invoked by the driver.")]
pub fn dim_collapse(base: Ty, u: UnitExprT) : Ty {
  match base {
    # A positional list never merges into an abelian product: the
    # nesting stays as written and unification decides its fate.
    TyDimT(inner, u_inner) ->
      if unit_is_dims(u_inner) or unit_is_dims(u) { TyDimT(base, unit_canon(u)) }
      else { dim_collapse(inner, unit_canon(UMul(u_inner, u))) }
    TyRefineT(inner, p)    -> TyRefineT(dim_collapse(inner, u), p)
    _ -> {
      let uc = unit_canon(u)
      # A `Vec[e]<1>` keeps its brand: a fixed-width-1 vec has a distinct
      # inline layout, so it must NOT collapse into the dynamic `Vec[e]`
      # the way a dimensionless `Real<1>` collapses into `Real`.
      if unit_is_one(uc) {
        if ty_vec_headed(base) { TyDimT(base, uc) } else { base }
      } else { TyDimT(base, uc) }
    }
  }
}

fn unit_is_dims(u: UnitExprT) : Bool = match u { UDims(_) -> true  _ -> false }

fn apply_tys(s: Subst, ts: [Ty]) : [Ty] {
  match ts {
    [] -> []
    [t, ...rest] -> [apply_ty(s, t), ...apply_tys(s, rest)]
  }
}

# canonicalise a list of union components.
# Applies the three algebraic laws of `|` (D6 in `docs/unions-design.md`):
#
#   - associative: nested `TyUnion` flattens (`(A | B) | C` → `A | B | C`).
#   - idempotent:  duplicates collapse (`A | A` → `A`).
#   - commutative: the result is sorted by `inf_mangle_ty` so component
#                  order does not affect type identity (`A | B ≡ B | A`).
#
# The sort key is `inf_mangle_ty(t)` — already deterministic, already used
# for monomorphisation, and stable across compilations because it is
# a pure function of the resolved Ty. Using the existing mangler also
# means two semantically equal types (e.g. `Decimal<USD>` and
# `Decimal` post-unit-erasure under codegen monomorphisation) sort
# adjacently, but unification still distinguishes them at the type
# level via `unify` / `inf_ty_eq` — normalisation is purely about
# canonical ordering for equality, not about merging distinct types.
#
# Returns the bare component when the normalised list collapses to a
# singleton (`TyUnion([T])` ≡ `T`). The `TyUnion([])` case is
# unreachable (no constructor produces it) and rejected by the
# resolver; if it nevertheless arises here we return `TyAny` as a
# safe placeholder rather than crash, matching the "I don't know yet"
# semantics elsewhere in this file.
#[doc("infer: `normalize_union` — typer entry point invoked by the driver.")]
pub fn normalize_union(components: [Ty]) : Ty {
  let flat = union_flatten(components)
  let sorted = union_sort_by_mangle(flat)
  let deduped = union_dedup_sorted(sorted)
  match deduped {
    [] -> TyAny
    [only] -> only
    _ -> TyUnion(deduped)
  }
}

# Flatten any `TyUnion` directly inside the input — single level is
# enough because the invariant is that every constructed `TyUnion`
# was itself built via `normalize_union`, so its components are never
# unions. We still recurse to absorb a `TyUnion` from a caller that
# bypassed the helper.
fn union_flatten(ts: [Ty]) : [Ty] {
  match ts {
    [] -> []
    [h, ...rest] -> match h {
      TyUnion(inner) -> append_ty_lists(union_flatten(inner), union_flatten(rest))
      _ -> [h, ...union_flatten(rest)]
    }
  }
}

fn append_ty_lists(a: [Ty], b: [Ty]) : [Ty] {
  match a {
    [] -> b
    [h, ...rest] -> [h, ...append_ty_lists(rest, b)]
  }
}

# Insertion sort keyed by `inf_mangle_ty`. The expected union arity is
# small (a handful of bounded-context errors in the DDD use case)
# so insertion sort beats merge sort here in both code size and
# constant factor.
fn union_sort_by_mangle(ts: [Ty]) : [Ty] {
  match ts {
    [] -> []
    [h, ...rest] -> union_sort_insert(h, union_sort_by_mangle(rest))
  }
}

fn union_sort_insert(t: Ty, sorted: [Ty]) : [Ty] {
  match sorted {
    [] -> [t]
    [h, ...rest] -> {
      if string_lt(inf_mangle_ty(t), inf_mangle_ty(h)) { [t, h, ...rest] }
      else { [h, ...union_sort_insert(t, rest)] }
    }
  }
}

# Dedup adjacent equal entries. Input must already be sorted by
# `inf_mangle_ty` so `inf_ty_eq` only fires on neighbours. `inf_ty_eq` is the
# semantic equality from later in this file; forward references work
# because top-level fn definitions are not order-dependent.
fn union_dedup_sorted(ts: [Ty]) : [Ty] {
  match ts {
    [] -> []
    [h, ...rest] -> match rest {
      [] -> [h]
      [n, ..._trail] -> {
        if inf_ty_eq(h, n) { union_dedup_sorted(rest) }
        else { [h, ...union_dedup_sorted(rest)] }
      }
    }
  }
}

# ---- row substitution + unification --------------------------------
#
# Rémy-style row unification.
#
# Canonicality (sorted/dedup labels) is the caller's responsibility;
# it is not enforced here.

# row-level cell identity for parametric effects.
#
# Two `var` cells (`var i`, `var go`) each desugar to `with State[T](init)
# as <name>`; semantically they are two independent State handlers, but
# their row labels were both `State[?T]` — structurally indistinguishable
# once the cell `<name>` was dropped. When the two cells reach a
# row-unification partition with their `T`s still unresolved (the
# `while`-in-lambda shape), the partition fused them and cross-bound their
# `T`s (`Int := Bool`), corrupting downstream types. The alias `<name>`
# already exists at the op-call site (`lookup_alias`) and at the handler
# (`alias_opt`); we thread it into the LABEL's `eff` string as a
# `"State@i"` suffix so distinct cells are distinct labels and never fuse.
# The suffix is confined to the typer: every cell label is discharged by
# its own `with State as <name>` handler (the discharge is made symmetric
# in `filter_labels_matching_res`), so a `"State@i"` label never escapes
# to a function signature, `main`'s row, or the emitters — which keep
# seeing bare effect names. `label_to_string` strips it for diagnostics.
#
# Unlike the codegen `@<alias>` dispatch tag, this suffix is stamped
# whenever the alias resolves, independent of taggability: the dispatch
# tag is disabled across a lambda boundary (the C local is out of scope),
# but row identity must hold inside lambdas too — that is exactly where
# the `while` thunks live.
fn label_eff_with_alias(eff: String, alias_opt: Option[String]) : String {
  match alias_opt {
    None    -> eff
    Some(a) -> string_concat(eff, string_concat("@", a))
  }
}

# Strip a `@<alias>` cell-identity suffix from a label eff for display.
# `"State@i"` → `"State"`; `"Stdout"` → `"Stdout"`. Diagnostics and any
# user-facing rendering must show the effect, not the internal cell tag.
fn strip_label_alias(eff: String) : String =
  strip_label_alias_loop(eff, 0, string_length(eff))

fn strip_label_alias_loop(eff: String, i: Int, n: Int) : String {
  if i >= n { eff }
  else {
    match char_at(eff, i) {
      Some(c) -> if c == '@' { string_slice(eff, 0, i) } else { strip_label_alias_loop(eff, i + 1, n) }
      None    -> eff
    }
  }
}

fn label_concat(a: [Label], b: [Label]) : [Label] {
  match a {
    [] -> b
    [h, ...rest] -> [h, ...label_concat(rest, b)]
  }
}

fn apply_label_args(s: Subst, l: Label) : Label =
  Label { eff: l.eff, ty_args: apply_tys(s, l.ty_args) }

fn apply_labels(s: Subst, ls: [Label]) : [Label] {
  match ls {
    [] -> []
    [h, ...rest] -> [apply_label_args(s, h), ...apply_labels(s, rest)]
  }
}

# Resolve a row under the current substitution: apply_ty to each
# label payload, and chase the tail var if it's bound.
fn apply_row(s: Subst, r: Row) : Row {
  let labels1 = apply_labels(s, r.labels)
  match r.tail {
    None -> Row { labels: labels1, tail: None, display_alias: r.display_alias }
    Some(v) -> match subst_row_lookup(s, v) {
      None -> Row { labels: labels1, tail: Some(v), display_alias: r.display_alias }
      Some(r2) -> {
        let r2r = apply_row(s, r2)
        Row {
          labels: label_concat(labels1, r2r.labels),
          tail: r2r.tail,
          display_alias: r.display_alias
        }
      }
    }
  }
}

# Does row variable `v` appear in row `r` after applying the current
# substitution? Standard occurs check, restricted to the tail (row
# vars cannot appear inside a label's ty_args).
fn occurs_row(v: Int, r: Row, s: Subst) : Bool {
  let r1 = apply_row(s, r)
  match r1.tail {
    None -> false
    Some(w) -> v == w
  }
}

# Partition two label lists into (both-pairs, only-left, only-right).
# O(n*m); fine for rows of expected size <10.

type LabelPair = LPair(Label, Label)

type LabelPartition = {
  both_pairs: [LabelPair],
  only_left:  [Label],
  only_right: [Label]
}

# A label-removal result: the matched `Label` plus the candidate list
# with that label removed (relative order of the rest preserved).
type FindRemove = { found: Label, remain: [Label] }

# best-match label lookup for nested parametric effects.
#
# When two `with_mailbox` blocks are nested and the body's row carries
# both `Actor[Request]` and `Actor[Reply]`, the partition step has to
# decide which one absorbs into the handler's `Actor[Msg]`. Naïve
# eff-name-only matching picks by row position, which depends on
# insertion order — that order varies with how the stdlib loads
# (`--core` vs `--path`) and is not what the user wrote.
#
# Preference order (each tier falls through to the next when no match
# survives):
#
#   1. Concrete-args match.  Both sides have concrete ty_args that
#      `ty_eq_shape` agrees on. Picks the "right" Actor[T] when the
#      handler's instantiation has already been concretised by an
#      enclosing context. No effect on the nested-handler bug because
#      the handler's `Msg` is still a fresh TyVar at this point.
#
#   2. Raw-TyVar-args match. The candidate's ty_args list contains an
#      unsubstituted `TyVarT` after `apply_label_args`. A surviving
#      TyVar at this stage means the candidate was added by an
#      `Actor.self()` call inside the body whose `T` is the natural
#      mate for the handler's `Msg`. Concrete-arg candidates (like the
#      `Actor[Request]` propagated transitively from `dual_send`) get
#      deprioritised, leaving them to flow up to the enclosing handler.
#
#   3. Eff-name match with unifiable args. The fallback for labels
#      tiers 1–2 did not claim — bare effects (`Stdout`, `Console`, …)
#      whose empty arg list trivially unifies, and parametric labels
#      where one side is still a flex `?t` (`State[?t]` vs `State[Int]`
#      → pair, then `unify_label_pairs` binds `?t := Int`). Matching on
#      eff-name ALONE, ignoring ty_args, is wrong: two *distinct*
#      instantiations of one parametric effect (`State[Bool]` from a
#      condition thunk vs `State[Int]` from a body thunk) would be
#      paired and then forced through `unify_label_pairs`, which fails
#      on `Bool` ≢ `Int`. A row is a
#      multiset keyed by (eff, ty_args): `State[Bool]` and `State[Int]`
#      are different labels and must coexist (only_left / only_right),
#      not collapse. Requiring `labels_args_unify` keeps the legitimate
#      flex-vs-concrete pairing while rejecting the concrete-vs-concrete
#      non-unifiable collision — the args check is pure (`ty_eq_shape`
#      for concrete-concrete, flex for any TyVar side), so no spurious
#      bindings escape the partition decision.
fn find_remove_label_best(target: Label, ls: [Label], s: Subst) : Option[FindRemove] {
  match find_remove_label_concrete(target, ls, s, []) {
    Some(fr) -> Some(fr)
    None -> match find_remove_label_tyvar_args(target, ls, s, []) {
      Some(fr) -> Some(fr)
      None     -> find_remove_label_unifiable(target, ls, s, [])
    }
  }
}

# tier-3 of `find_remove_label_best`. Pair `target` with a
# same-eff candidate ONLY when their ty_args are unifiable under `s`
# (`labels_args_unify`: concrete-concrete via `ty_eq_shape`, flexible
# whenever either side is a TyVar). Bare effects with empty arg lists
# unify trivially, so `Stdout`/`Console` keep their single-candidate
# semantics. Two concrete-but-disjoint instantiations of one parametric
# effect (`State[Bool]` vs `State[Int]`) no longer pair, so the row
# partition leaves them as distinct only_left / only_right labels
# instead of forcing `Bool ≡ Int`.
fn find_remove_label_unifiable(target: Label, ls: [Label], s: Subst,
                               seen: [Label]) : Option[FindRemove] {
  match ls {
    [] -> None
    [h, ...rest] -> {
      if h.eff == target.eff and labels_args_unify(h.ty_args, target.ty_args, s) {
        Some(FindRemove { found: h, remain: label_concat(seen, rest) })
      } else {
        find_remove_label_unifiable(target, rest, s, label_concat(seen, [h]))
      }
    }
  }
}

fn find_remove_label_concrete(target: Label, ls: [Label], s: Subst,
                                seen: [Label]) : Option[FindRemove] {
  match ls {
    [] -> None
    [h, ...rest] -> {
      if h.eff == target.eff and labels_args_unify_concrete(h.ty_args, target.ty_args, s) {
        Some(FindRemove { found: h, remain: label_concat(seen, rest) })
      } else {
        find_remove_label_concrete(target, rest, s, label_concat(seen, [h]))
      }
    }
  }
}

# prefer candidates whose ty_args still contain a raw
# TyVarT under the current substitution. Such a TyVar is the "fresh-
# from-`Actor.self()`" mate the handler's instantiation is reaching
# for. See `find_remove_label_best`'s doc-comment for the ordering
# rationale.
#
# the raw-TyVar test alone over-matches. A `var b = true`
# / `var i = 0` pair desugars to two `State[?t]` labels whose row args
# stay raw `TyVarT`s even after `?t` is bound (the labels carry literal
# tyvars per the `apply_ty_keep_row_labels` discipline). Both look like
# tyvar-args candidates, so a condition thunk's `State[?t→Bool]` and a
# body thunk's `State[?u→Int]` would pair here and then fail in
# `unify_label_pairs` on `Bool ≢ Int`. Gate the match on
# `labels_args_unify` as well: a genuinely-free tyvar (the `Actor.self`
# case) stays flexibly unifiable against the target, but a tyvar already
# resolved to a conflicting concrete is rejected, leaving the two
# `State[_]` labels to coexist as distinct row entries.
fn find_remove_label_tyvar_args(target: Label, ls: [Label], s: Subst,
                                  seen: [Label]) : Option[FindRemove] {
  match ls {
    [] -> None
    [h, ...rest] -> {
      let tyvar_mate = h.eff == target.eff and label_args_have_tyvar(h.ty_args, s) and labels_args_unify(h.ty_args, target.ty_args, s)
      if tyvar_mate {
        Some(FindRemove { found: h, remain: label_concat(seen, rest) })
      } else {
        find_remove_label_tyvar_args(target, rest, s, label_concat(seen, [h]))
      }
    }
  }
}

# check the RAW shape of the ty_args (before applying
# the substitution). A label literally written as `Actor[TyVarT(n)]`
# was added by an `Actor.self()` call inside the body — the TyVar
# may have been bound transitively (e.g. through a downstream call's
# parameter unification), but the label itself was created with a
# fresh TyVar that the handler's `Msg` is the natural mate for. A
# label literally written as `Actor[Request]` came from a callee's
# declared row (e.g. `dual_send`) and is not a candidate for the
# enclosing handler's instantiation.
fn label_args_have_tyvar(args: [Ty], s: Subst) : Bool {
  match args {
    [] -> false
    [h, ...rest] -> match h {
      TyVarT(_) -> true
      _         -> label_args_have_tyvar(rest, s)
    }
  }
}

# Strict variant of `labels_args_unify`: requires every position to be
# CONCRETE-CONCRETE structurally equal under the current substitution.
# A position where either side is still a TyVar/TyAny is rejected so
# the best-match preference does not collapse back to "any eff-name
# match". Empty arg lists count as concrete-match (bare effects like
# `Stdout` keep their single-candidate semantics).
fn labels_args_unify_concrete(a: [Ty], b: [Ty], s: Subst) : Bool {
  match a {
    [] -> match b { [] -> true _ -> false }
    [ah, ...arest] -> match b {
      [] -> false
      [bh, ...brest] -> {
        let aa = apply_ty(s, ah)
        let bb = apply_ty(s, bh)
        if ty_eq_shape_concrete(aa, bb) { labels_args_unify_concrete(arest, brest, s) }
        else { false }
      }
    }
  }
}

# Stricter shape check than `ty_unifiable_shallow`: rejects matches
# involving TyVar or TyAny on either side. Used only by the best-match
# label lookup so it never collapses two `Actor[?T]` candidates into a
# single match.
fn ty_eq_shape_concrete(a: Ty, b: Ty) : Bool {
  match a {
    TyVarT(_) -> false
    TyAny     -> false
    _ -> match b {
      TyVarT(_) -> false
      TyAny     -> false
      _ -> ty_eq_shape(a, b)
    }
  }
}

fn partition_labels(a: [Label], b: [Label]) : LabelPartition =
  partition_walk(a, b, [], [], subst_empty())

fn partition_labels_sub(a: [Label], b: [Label], s: Subst) : LabelPartition =
  partition_walk(a, b, [], [], s)

fn partition_walk(a: [Label], b_remain: [Label],
                  bp: [LabelPair], ol: [Label], s: Subst) : LabelPartition {
  match a {
    [] -> LabelPartition { both_pairs: bp, only_left: ol, only_right: b_remain }
    [ah, ...arest] -> match find_remove_label_best(ah, b_remain, s) {
      None -> partition_walk(arest, b_remain, bp, [ah, ...ol], s)
      Some(fr) -> partition_walk(arest, fr.remain, [LPair(ah, fr.found), ...bp], ol, s)
    }
  }
}

# Unify the ty_args of every (left, right) pair where the labels share
# an effect symbol.
fn unify_label_pairs(pairs: [LabelPair], s: Subst) : Option[Subst] / Mutable {
  # Effect label ty_args do not participate in D3 union upcast: empty
  # env is fine and avoids reshaping the row-unification API.
  match pairs {
    [] -> Some(s)
    [LPair(la, lb), ...rest] -> match unify_list(ty_env_empty(), la.ty_args, lb.ty_args, s) {
      None -> None
      Some(s1) -> unify_label_pairs(rest, s1)
    }
  }
}

# True iff the label list is empty.
#[doc("infer: `labels_empty` — typer entry point invoked by the driver.")]
pub fn labels_empty(ls: [Label]) : Bool {
  match ls { [] -> true _ -> false }
}

# Bind the two row tails per Doc A §*Row unification* steps 2–3.
# - Both rigid: the only-left and only-right lists must be empty.
# - One rigid, one flex: bind the flex tail to a row containing the
#   other side's "only" labels and a None tail (since the rigid side
#   admitted nothing extra). The "only" list of the rigid side must
#   be empty.
# - Both flex: introduce a fresh tail variable τ and bind each side
#   to a row carrying the *other* side's "only" labels plus τ.
fn bind_row_tails(at: Option[Int], bt: Option[Int],
                  oleft: [Label], oright: [Label],
                  s: Subst) : Option[Subst] / Mutable {
  match at {
    None -> match bt {
      None -> if labels_empty(oleft) and labels_empty(oright) { Some(s) } else { None }
      Some(b_id) -> {
        if not labels_empty(oright) { None }
        else {
          let r = Row { labels: oleft, tail: None, display_alias: None }
          if occurs_row(b_id, r, s) { None }
          else { Some(subst_row_extend(s, b_id, r)) }
        }
      }
    }
    Some(a_id) -> match bt {
      None -> {
        if not labels_empty(oleft) { None }
        else {
          let r = Row { labels: oright, tail: None, display_alias: None }
          if occurs_row(a_id, r, s) { None }
          else { Some(subst_row_extend(s, a_id, r)) }
        }
      }
      Some(b_id) -> {
        if a_id == b_id and labels_empty(oleft) and labels_empty(oright) { Some(s) }
        else {
          let fr = subst_fresh_row(s)
          let s1 = fr.subst
          let r_for_a = Row { labels: oright, tail: Some(fr.id), display_alias: None }
          let r_for_b = Row { labels: oleft,  tail: Some(fr.id), display_alias: None }
          if occurs_row(a_id, r_for_a, s1) { None }
          else {
            let s2 = subst_row_extend(s1, a_id, r_for_a)
            if occurs_row(b_id, r_for_b, s2) { None }
            else { Some(subst_row_extend(s2, b_id, r_for_b)) }
          }
        }
      }
    }
  }
}

# Unify two effect rows. Returns the extended substitution or None.
#
# keep label ty_args literal during partition so
# `find_remove_label_best` can distinguish TyVar payloads from
# concrete ones. `apply_row_tail_only` resolves the tail var for
# proper rigid/flex bookkeeping but leaves the labels' ty_args
# untouched. `unify_label_pairs` still applies the substitution
# inside `unify_list`, so soundness is preserved.
fn unify_row(r1: Row, r2: Row, s: Subst) : Option[Subst] / Mutable {
  let a = apply_row_tail_only(s, r1)
  let b = apply_row_tail_only(s, r2)
  let p = partition_labels_sub(a.labels, b.labels, s)
  match unify_label_pairs(p.both_pairs, s) {
    None -> None
    Some(s1) -> bind_row_tails(a.tail, b.tail, p.only_left, p.only_right, s1)
  }
}

fn apply_row_tail_only(s: Subst, r: Row) : Row {
  match r.tail {
    None -> r
    Some(v) -> match subst_row_lookup(s, v) {
      None -> r
      Some(r2) -> {
        let r2r = apply_row_tail_only(s, r2)
        Row {
          labels: label_concat(r.labels, r2r.labels),
          tail: r2r.tail,
          display_alias: r.display_alias
        }
      }
    }
  }
}

# variant of `apply_ty` whose only difference from the
# plain one is that effect-row LABELS are NOT substituted (the row
# tail still is). Used by `unify_env` so a downstream `unify_row`
# partition can see raw TyVar payloads. Everywhere else continues to
# use `apply_ty`.
fn apply_ty_keep_row_labels(s: Subst, t: Ty) : Ty {
  match t {
    TyVarT(n) -> match subst_lookup(s, n) {
      Some(t2) -> apply_ty_keep_row_labels(s, t2)
      None     -> t
    }
    TyListT(inner) -> TyListT(apply_ty_keep_row_labels(s, inner))
    TyFnT(params, ret, row) ->
      TyFnT(apply_ty_keep_row_labels_list(s, params),
            apply_ty_keep_row_labels(s, ret),
            apply_row_tail_only(s, row))
    TyCon(mo_, name, atys) -> TyCon(mo_, name, apply_ty_keep_row_labels_list(s, atys))
    TyShapeApp(sv, arg) -> match subst_lookup(s, sv) {
      Some(wit) -> shape_reapply(apply_ty_keep_row_labels(s, wit), apply_ty_keep_row_labels(s, arg))
      None      -> TyShapeApp(sv, apply_ty_keep_row_labels(s, arg))
    }
    TyDimT(base, u) -> dim_collapse(apply_ty_keep_row_labels(s, base), apply_unit(s, u))
    TyRefineT(base, p) -> TyRefineT(apply_ty_keep_row_labels(s, base), p)
    TyUnion(parts) -> normalize_union(apply_ty_keep_row_labels_list(s, parts))
    _ -> t
  }
}

fn apply_ty_keep_row_labels_list(s: Subst, ts: [Ty]) : [Ty] {
  match ts {
    [] -> []
    [h, ...rest] -> [apply_ty_keep_row_labels(s, h), ...apply_ty_keep_row_labels_list(s, rest)]
  }
}

# Does TyVarT(v) appear inside `ty` after applying the substitution?
# Used as the occurs check in unify.
fn occurs_any(v: Int, ts: [Ty], s: Subst) : Bool {
  match ts {
    [] -> false
    [t, ...rest] -> if occurs(v, t, s) { true } else { occurs_any(v, rest, s) }
  }
}

fn occurs(v: Int, t: Ty, s: Subst) : Bool {
  let t1 = apply_ty(s, t)
  match t1 {
    TyVarT(n) -> n == v
    TyListT(inner) -> occurs(v, inner, s)
    TyFnT(params, ret, _) -> occurs_any(v, [ret, ...params], s)
    TyCon(_, _, atys) -> occurs_any(v, atys, s)
    # the shape var id shares the tvar pool, so `v` may be the head; it
    # also occurs inside the argument.
    TyShapeApp(sv, arg) -> v == sv or occurs(v, arg, s)
    # TyDimT carries a base Ty to recurse into; the unit side
    # has its own occurs_unit guard inside unify_abelian.
    TyDimT(base, _) -> occurs(v, base, s)
    # predicates carry value-level identifiers, not Ty
    # vars; only the base contributes to occurs.
    TyRefineT(base, _) -> occurs(v, base, s)
    # a tvar `v` occurs in a union iff it occurs
    # in any component. Required so unify's occurs check stays sound
    # for a union containing `?t0`.
    TyUnion(parts) -> occurs_any(v, parts, s)
    _ -> false
  }
}

# Unify two types under substitution `s`. Returns Some(s') with the
# extended substitution, or None on failure. The caller is responsible
# for reporting the mismatch at the right source position.
#
# TyAny is the "unresolved" placeholder the walker emits when it cannot
# determine a type (unknown record field, opaque lookup). It must match
# *anything* without entering the substitution: if TyAny leaked into
# `sub`, it would pollute unrelated TyVars through later lookups and
# turn clean `[?t1]` inferences into `[?]` noise. So short-circuit it
# at the top of unify, before the var-binding branches.
fn unify(t1: Ty, t2: Ty, s: Subst) : Option[Subst] / Mutable = unify_env(ty_env_empty(), t1, t2, s)

# env-threaded unify. The env carries the type
# environment so `unify_heads` can consult `variants_of_type` for
# the Decision-3 implicit upcast (`docs/unions-design.md`): a value
# of a component type is usable wherever its parent union is
# expected. Calls without env access (e.g. hole-synthesis) pass
# `ty_env_empty()` and lose only the upcast-acceptance behaviour.
fn unify_env(env: TyEnv, t1: Ty, t2: Ty, s: Subst) : Option[Subst] / Mutable {
  # refinements are transparent for unify — peel
  # them off both sides before head-unification so neither direction
  # gets blocked. The predicate stays attached at the declaration
  # site; downstream passes that need to reason about it look it up
  # from the source signature.
  # `apply_ty_keep_row_labels` preserves the raw TyVar
  # payloads inside effect-row labels (only the row TAIL is chased)
  # so the downstream `unify_row` partition can pick by
  # raw-tyvar-vs-concrete in `find_remove_label_best`. A plain
  # `apply_ty` would substitute bound TyVars away — every label
  # whose ty_args reference a TyVar that has been unified to a
  # concrete type would become structurally identical to a
  # source-literal concrete label, and the absorption order for two
  # `Actor[T]` instantiations would collapse back to row position.
  let a = unwrap_refines(apply_ty_keep_row_labels(s, t1))
  let b = unwrap_refines(apply_ty_keep_row_labels(s, t2))
  match a {
    TyAny -> Some(s)
    _ -> match b {
      TyAny -> Some(s)
      _ -> match a {
        TyVarT(n) -> match b {
          TyVarT(m) -> if n == m { Some(s) } else { Some(subst_extend(s, n, b)) }
          _ -> if occurs(n, b, s) { None } else { Some(subst_extend(s, n, b)) }
        }
        _ -> match b {
          TyVarT(m) -> if occurs(m, a, s) { None } else { Some(subst_extend(s, m, a)) }
          # a shape application on the right is normalised to the left so
          # the single `TyShapeApp` arm in `unify_heads` handles both
          # directions symmetrically.
          TyShapeApp(_, _) -> match a { TyShapeApp(_, _) -> unify_heads(env, a, b, s)
                                        _ -> unify_heads(env, b, a, s) }
          _ -> unify_heads(env, a, b, s)
        }
      }
    }
  }
}

# peel a stack of TyRefineT wrappers down to the base type.
fn unwrap_refines(t: Ty) : Ty {
  match t {
    TyRefineT(base, _) -> unwrap_refines(base)
    _ -> t
  }
}

# Neither side is a var: must match head-symbol + structure.
fn unify_list(env: TyEnv, xs: [Ty], ys: [Ty], s: Subst) : Option[Subst] / Mutable {
  match xs {
    [] -> match ys { [] -> Some(s) _ -> None }
    [x, ...xr] -> match ys {
      [] -> None
      [y, ...yr] -> match unify_env(env, x, y, s) {
        None -> None
        Some(s1) -> unify_list(env, xr, yr, s1)
      }
    }
  }
}

fn unify_heads(env: TyEnv, a: Ty, b: Ty, s: Subst) : Option[Subst] / Mutable {
  match a {
    # bare numerics on the LHS treat the RHS dim case specially
    # — `Real` ≡ `Real<1>`. Any other unit is a mismatch (`Real` vs
    # `Real<USD>` is rejected).
    TyInt    -> match b {
      TyInt    -> Some(s)
      TyDimT(bb, bu) -> match bb { TyInt -> unify_dim(UOne, bu, s) _ -> None }
      _ -> None
    }
    TyReal   -> match b {
      TyReal   -> Some(s)
      TyDimT(bb, bu) -> match bb { TyReal -> unify_dim(UOne, bu, s) _ -> None }
      _ -> None
    }
    TyBool   -> match b { TyBool   -> Some(s) _ -> None }
    TyString -> match b { TyString -> Some(s) _ -> None }
    TyChar   -> match b { TyChar   -> Some(s) _ -> None }
    TyUnit   -> match b { TyUnit   -> Some(s) _ -> None }
    # Byte is nominal — distinct from Int. Only unifies
    # with itself. Conversions use `int_to_u8` / `u8_to_int`.
    TyByte     -> match b { TyByte     -> Some(s) _ -> None }
    TyInt32    -> match b { TyInt32    -> Some(s) _ -> None }
    TyUInt32   -> match b { TyUInt32   -> Some(s) _ -> None }
    TyUInt64   -> match b { TyUInt64   -> Some(s) _ -> None }
    TyInt128   -> match b { TyInt128   -> Some(s) _ -> None }
    TyHandle   -> match b { TyHandle   -> Some(s) _ -> None }
    # TyAny unifies with anything until typed holes and error reporting
    # land; it's the "I don't know yet" placeholder.
    TyAny    -> Some(s)
    TyListT(a1) -> match b {
      TyListT(b1) -> unify_env(env, a1, b1, s)
      _ -> None
    }
    TyFnT(ap, ar, arow) -> match b {
      TyFnT(bp, br, brow) -> match unify_list(env, ap, bp, s) {
        None -> None
        Some(s1) -> match unify_env(env, ar, br, s1) {
          None -> None
          Some(s2) -> unify_row(arow, brow, s2)
        }
      }
      _ -> None
    }
    # Hanga Roa: TyCon identity is (module_origin, name, args). Two
    # TyCons unify only when BOTH the module origin and the bare
    # name coincide. Same-name types from different modules are
    # distinct (the load-bearing rule for shadowing). Both `None`
    # — language-level builtins / root-file types — also coincide.
    TyCon(am, an, aa) -> match b {
      TyCon(bm, bn, ba) -> {
        if module_slot_compat(am, bm) and an == bn { unify_list(env, aa, ba, s) }
        # implicit upcast inside structural
        # unification. When the two TyCons disagree, accept the
        # mismatch if `b` is a component of the union `a` per the env
        # (`type a = ... | b | ...`). Direction matters: only the
        # found-side type may be a component of the expected-side
        # union (`unify` is called with the *expected* side first
        # via st_unify; here we mirror that contract). Empty arg
        # lists ensure we are looking at bare nominal types, not
        # generic instances. No chains: only the immediate parent
        # accepts.
        # Union upcast: module must match too (a union accepts variants
        # declared in the same module, not same-name types from elsewhere).
        else if option_str_eq(am, bm) and list_length(aa) == 0 and list_length(ba) == 0 and list_has(variants_of_type(env, an), bn) { Some(s) }
        else { None }
      }
      # a bare named record on the LHS unifies with the
      # same record on the RHS decorated by a unit, when the unit
      # collapses to UOne. Mirrors the `Real ≡ Real<1>` / `Int ≡ Int<1>`
      # rules above. Only `Decimal` has a UoM-decorated form; the other
      # named records do not.
      TyDimT(bb, bu) -> match bb {
        TyCon(_, bn, ba) ->
          # A fixed-width `Vec[t]<n>` has a distinct inline layout, so it
          # never collapses into a bare `Vec[t]` — even at `<1>`. The
          # numeric `Real ≡ Real<1>` collapse below is untouched.
          if bn == "Vec" { None }
          else if an == bn { match unify_list(env, aa, ba, s) {
            None -> None
            Some(s1) -> unify_dim(UOne, bu, s1)
          } } else { None }
        _ -> None
      }
      _ -> None
    }
    TyVarT(_) -> None                                  # handled in unify
    # TyDimT vs TyDimT — unify base then unit. TyDimT vs bare
    # primitive uses the `Real ≡ Real<1>` rule above (the bare-side
    # arms catch this via the dim-aware match arms).
    TyDimT(ab, au) -> match b {
      TyDimT(bb, bu) -> match unify_env(env, ab, bb, s) {
        None -> None
        Some(s1) -> unify_dim(au, bu, s1)
      }
      TyInt    -> match ab { TyInt -> unify_dim(au, UOne, s) _ -> None }
      TyReal   -> match ab { TyReal -> unify_dim(au, UOne, s) _ -> None }
      # `Decimal<u>` ≡ bare `Decimal` when u collapses to 1,
      # mirroring the bare-numeric arms. Lets a `Decimal<USD>` value
      # flow into a fn expecting bare `Decimal` only when the units
      # cancel — anything else is a unit mismatch.
      TyCon(_, bn, ba) -> match ab {
        TyCon(_, an, aa) ->
          # A fixed-width `Vec[t]<n>` never collapses into a bare `Vec[t]`
          # (distinct inline layout); the numeric collapse above stays.
          if an == "Vec" { None }
          else if an == bn { match unify_list(env, aa, ba, s) {
            None -> None
            Some(s1) -> unify_dim(au, UOne, s1)
          } } else { None }
        _ -> None
      }
      TyRefineT(bbase, _) -> unify_env(env, a, bbase, s)
      _ -> None
    }
    # refinements are transparent to unify — both
    # `TyRefineT(b, p) ⊑ b` (upcast) and `b ⊑ TyRefineT(b, p)` go
    # through. The predicate stays attached on the source-side fn
    # signature; downstream passes (interval propagation, match-arm
    # narrowing, ensure() desugar) consume it from there. A future
    # refinement-aware unify could distinguish argument-flow direction
    # to reject downcasts, but it requires reshape of unify's API.
    TyRefineT(abase, _) -> unify_env(env, abase, b, s)
    # two unions unify only when their canonical
    # component lists agree component-wise. Subsumption between a
    # union and one of its components — the implicit upcast — is the
    # resolver's job; unify stays symmetric here.
    TyUnion(aps) -> match b {
      TyUnion(bps) -> unify_list(env, aps, bps, s)
      _ -> None
    }
    # First-order shape application: `s[A] ~ D[B]` binds `s := D`
    # (a nullary constructor witness) and unifies `A ~ B`. The witness
    # carries the constructor head only; `apply_ty` reconstructs `D[A]`.
    # A `List` head witnesses as `TyCon(None,"List",[])` and rebuilds to
    # `TyListT`. No witness (`Int`, arity-2 `Map`) fails cleanly — the
    # strict-arity-1, no-higher-order rule.
    TyShapeApp(sv, a1) -> match shape_witness_of(b) {
      Some(wit) -> match shape_bind(sv, wit, a1, s) {
        None -> None
        Some(s1) -> unify_env(env, a1, shape_arg_of(b), s1)
      }
      None -> None
    }
  }
}

# The unapplied-constructor witness of a saturated arity-1 type, or None
# when it is not a single-arg constructor a `Shape` variable may bind to
# (`Int`, arity-2 `Map`, functions). `List` witnesses as a nullary
# `TyCon(None,"List",[])`; `reapply` maps that head back to `TyListT`.
#[doc("The nullary constructor witness a `Shape` variable binds to when applied against a saturated arity-1 type.")]
pub fn shape_witness_of(t: Ty) : Option[Ty] = match t {
  TyListT(_) -> Some(TyCon(None, "List", []))
  TyCon(m, n, args) -> match args { [_one] -> Some(TyCon(m, n, [])) _ -> None }
  _ -> None
}

# The single type argument of a saturated arity-1 type.
#[doc("The single type argument of a saturated arity-1 type (for shape-app decomposition).")]
pub fn shape_arg_of(t: Ty) : Ty = match t {
  TyListT(inner) -> inner
  TyCon(_, _, [a]) -> a
  _ -> TyAny
}

# Reapply a resolved constructor witness to an argument, reversing
# `shape_witness_of`. INVARIANT: the `List` witness always rebuilds to
# the dedicated `TyListT` node, never `TyCon(_,"List",[a])` — those two
# are distinct in the unifier and must not diverge. A witness that is
# not a nullary constructor (a stray binding) passes the argument
# through unchanged.
#[doc("Reconstruct a concrete applied type from a resolved shape witness and its argument.")]
pub fn shape_reapply(wit: Ty, arg: Ty) : Ty = match wit {
  TyCon(_, "List", []) -> TyListT(arg)
  TyCon(m, n, []) -> TyCon(m, n, [arg])
  _ -> wit
}

# Bind a shape variable to its constructor witness with an occurs-check
# over the pending argument, then record `sv := witness` in the subst.
fn shape_bind(sv: Int, wit: Ty, arg: Ty, s: Subst) : Option[Subst] / Mutable =
  if occurs(sv, arg, s) { None } else { Some(subst_extend(s, sv, wit)) }

# ---- instantiation ----
#
# Turn a TyScheme into (fresh Ty, updated env). Each bound var in the
# scheme is replaced by a freshly-generated TyVarT; everywhere the
# bound id appears inside the scheme body, we substitute the fresh
# id. The env's `fresh` counter advances by one per bound var.

fn fresh_var(env: TyEnv) : TyEnv =
  TyEnv { entries: env.entries, fresh: env.fresh + 1, unions: env.unions, constructors: env.constructors, head_owners: env.head_owners, root_fns: env.root_fns, row_kind: env.row_kind, index: env.index }

fn advance_fresh(env: TyEnv, n: Int) : TyEnv =
  if n <= 0 { env } else { advance_fresh(fresh_var(env), n - 1) }

fn mk_fresh_subst_loop(vars: [Int], start: Int, s: Subst) : Subst / Mutable {
  match vars {
    [] -> s
    [v, ...rest] -> mk_fresh_subst_loop(rest, start + 1, subst_extend(s, v, TyVarT(start)))
  }
}

fn mk_fresh_subst(vars: [Int], start: Int) : Subst / Mutable =
  mk_fresh_subst_loop(vars, start, subst_empty())

# Turn a TyScheme into a pair `(env-with-advanced-counter, ty)` where
# every bound var in the scheme has been replaced by a fresh TyVarT
# drawn from the counter.
type Instantiated = { env: TyEnv, ty: Ty }

fn max_id_loop(vs: [Int], acc: Int) : Int {
  match vs {
    [] -> acc
    [v, ...rest] -> max_id_loop(rest, if v > acc { v } else { acc })
  }
}

# `start` must exceed every bound-var id in `vars`, otherwise the
# substitution would map a bound id to itself (e.g. `SB(0, TyVarT(0))`
# when env.fresh=0 and vars=[0]) and apply_ty would loop forever. By
# clamping up to `max(vars) + 1`, fresh vars never alias any bound id.
fn instantiate(env: TyEnv, sc: TyScheme) : Instantiated {
  match sc {
    Scheme(vars, _, _, _, body) -> {
      let n = list_length(vars)
      let need = if n == 0 { 0 } else { max_id_loop(vars, 0) + 1 }
      let start = if env.fresh >= need { env.fresh } else { need }
      let env1 = TyEnv { entries: env.entries, fresh: start + n, unions: env.unions, constructors: env.constructors, head_owners: env.head_owners, root_fns: env.root_fns, row_kind: env.row_kind, index: env.index }
      let sub = mk_fresh_subst(vars, start)
      Instantiated { env: env1, ty: apply_ty(sub, body) }
    }
  }
}

# Build a temporary substitution that maps each bound row-var id in
# `rvars` to a fresh row-variable id allocated from `s.row_fresh`.
# Returns the temp substitution (only used to rewrite the scheme body)
# and the updated subst with the fresh counter advanced.
type FreshRowSubst = { temp: Subst, sub: Subst }

fn mk_fresh_row_subst_loop(rvars: [Int], temp: Subst, s: Subst) : FreshRowSubst / Mutable {
  match rvars {
    [] -> FreshRowSubst { temp: temp, sub: s }
    [v, ...rest] -> {
      let fr = subst_fresh_row(s)
      let r = Row { labels: [], tail: Some(fr.id), display_alias: None }
      let temp1 = subst_row_extend(temp, v, r)
      mk_fresh_row_subst_loop(rest, temp1, fr.subst)
    }
  }
}

fn mk_fresh_row_subst(rvars: [Int], s: Subst) : FreshRowSubst / Mutable {
  # Fresh ids must be drawn from a counter strictly greater than any
  # bound id in `rvars`; otherwise the temp substitution might map a
  # bound id `v` to a Row whose tail is `v` (when v == row_fresh) and
  # apply_row would loop forever.
  let need = if rvars == [] { 0 } else { max_id_loop(rvars, 0) + 1 }
  let s_seed = if s.row_fresh >= need { s }
               else { Subst { slots: s.slots, row_slots: s.row_slots,
                              row_fresh: need,
                              unit_slots: s.unit_slots, unit_fresh: s.unit_fresh,
                              kind_theories: s.kind_theories, unit_var_kinds: s.unit_var_kinds } }
  mk_fresh_row_subst_loop(rvars, subst_empty(), s_seed)
}

# parallel to mk_fresh_row_subst — but for unit-vars. Allocates a
# fresh UVar per bound unit-var id and binds it via subst_unit_extend.
# also returns the fresh uvar ids in `fresh_ids` so the
# caller (st_instantiate_report) can record them in the call-site for
# per-unit specialisation later.
type FreshUnitSubst = { temp: Subst, sub: Subst, fresh_ids: [Int] }

fn mk_fresh_unit_subst_loop(uvars: [Int], temp: Subst, s: Subst,
                             fids_acc: [Int]) : FreshUnitSubst / Mutable {
  match uvars {
    [] -> FreshUnitSubst { temp: temp, sub: s, fresh_ids: list_reverse(fids_acc) }
    [v, ...rest] -> {
      let fr = subst_fresh_unit(s)
      let temp1 = subst_unit_extend(temp, v, UVar(fr.id))
      mk_fresh_unit_subst_loop(rest, temp1, fr.subst, [fr.id, ...fids_acc])
    }
  }
}

fn mk_fresh_unit_subst(uvars: [Int], s: Subst) : FreshUnitSubst / Mutable {
  let need = if uvars == [] { 0 } else { max_id_loop(uvars, 0) + 1 }
  let s_seed = if s.unit_fresh >= need { s }
               else { Subst { slots: s.slots, row_slots: s.row_slots,
                              row_fresh: s.row_fresh,
                              unit_slots: s.unit_slots, unit_fresh: need,
                              kind_theories: s.kind_theories, unit_var_kinds: s.unit_var_kinds } }
  mk_fresh_unit_subst_loop(uvars, subst_empty(), s_seed, [])
}

# bump the row-var fresh counter past `n` reserved ids so a
# subsequent `subst_fresh_row` returns ids that don't alias them.
# Used by `infer_decl` to keep its row-poly bound ids out of the
# inferencer's fresh-row pool.
fn advance_row_fresh(st: InferState, n: Int) : InferState {
  if n <= 0 { st }
  else {
    let s1 = Subst { slots: st.sub.slots, row_slots: st.sub.row_slots,
                     row_fresh: st.sub.row_fresh + n,
                     unit_slots: st.sub.unit_slots, unit_fresh: st.sub.unit_fresh,
                     kind_theories: st.sub.kind_theories, unit_var_kinds: st.sub.unit_var_kinds }
    st_set_sub(st, s1)
  }
}

# parallel to advance_row_fresh, for unit-vars. Used by
# infer_decl when reserving bound unit-var ids ahead of synth.
fn advance_unit_fresh(st: InferState, n: Int) : InferState {
  if n <= 0 { st }
  else {
    let s1 = Subst { slots: st.sub.slots, row_slots: st.sub.row_slots,
                     row_fresh: st.sub.row_fresh,
                     unit_slots: st.sub.unit_slots, unit_fresh: st.sub.unit_fresh + n,
                     kind_theories: st.sub.kind_theories, unit_var_kinds: st.sub.unit_var_kinds }
    st_set_sub(st, s1)
  }
}

# ====================================================================
# bidirectional inference
# ====================================================================
#
# `synth` traverses an expression, returning the inferred `Ty` plus an
# updated InferState (environment, substitution, error counter, record
# registry). Type mismatches print a diagnostic at the offending source
# position and bump the error counter; the walker keeps going with the
# old substitution so a single failure doesn't cascade into a wall of
# noise.
#
# Local `let` bindings are treated monomorphically (no generalisation);
# user-level polymorphism continues to live in core and variant
# schemes. TyAny acts as the unknown-fallback for AST shapes we cannot
# yet resolve (unknown record names, records referenced without a
# registry entry) and unifies with anything, so it never blocks
# inference from making progress elsewhere.
#
# Output surfaced via the `--infer` flag: one line per `DFn` decl
# giving its inferred function type. Unresolved type variables survive
# as `?tN` (see `inf_ty_to_string`).

# ---- record registry (typer-side helpers) ----
#
# `RecInfo` + the bare/field-aware lookups (`rec_find`,
# `rec_find_with_field`, `collect_records`) live in compiler.ast,
# since the positional-record desugar also consumes them. These
# remaining helpers are typer-only: the
# arity-discriminating wrapper and the per-module rerank that
# `rec_find` consults to disambiguate same-name records — see
# `rec_find_in_scope`.
fn rec_find_arity(rs: [RecInfo], target: String, arity: Int) : Option[RecInfo] =
  rec_find_arity_loop(rs, target, arity, None)

# Hanga Roa: reorder a `[RecInfo]` so the records visible to a decl
# from module `home_mod` resolve correctly under `rec_find`.
#
# Semantics: library code from module M sees its own records first,
# then records from OTHER library modules, but NEVER records from
# the consumer's root file. Root code sees everything in its
# natural newest-first order (its own redecls win for the root's
# own scope). `root_mod` is the basename of the root file, used
# to identify and drop root-tagged records when home != root.
fn rerank_recs_for(rs: [RecInfo], home_mod: Option[String], root_mod: String) : [RecInfo] = {
  let is_root_home = match home_mod {
    None     -> true
    Some(hm) -> hm == root_mod
  }
  if is_root_home {
    rs
  } else {
    rerank_recs_loop(rs, home_mod, root_mod, [], [], [])
  }
}

fn rerank_recs_loop(rs: [RecInfo], hm: Option[String], root_mod: String,
                       home: [RecInfo], other_mods: [RecInfo],
                       root: [RecInfo]) : [RecInfo] =
  match rs {
    [] -> list_append(list_reverse(home),
            list_append(list_reverse(other_mods), list_reverse(root)))
    [r, ...rs2] -> match r {
      RI(_, _, _, mo) -> {
        let is_root_rec = match mo {
          None     -> false
          Some(rm) -> rm == root_mod
        }
        if is_root_rec {
          # Drop: library code never sees consumer-root records.
          rerank_recs_loop(rs2, hm, root_mod, home, other_mods, root)
        } else if option_str_eq(mo, hm) {
          rerank_recs_loop(rs2, hm, root_mod, [r, ...home], other_mods, root)
        } else { match mo {
          None    -> rerank_recs_loop(rs2, hm, root_mod, home, other_mods, [r, ...root])
          Some(_) -> rerank_recs_loop(rs2, hm, root_mod, home, [r, ...other_mods], root)
        } }
      }
    }
  }

fn option_str_eq(a: Option[String], b: Option[String]) : Bool = match a {
  None    -> match b { None -> true Some(_) -> false }
  Some(x) -> match b { None -> false Some(y) -> x == y }
}

# Hanga Roa: module-slot compatibility for TyCon unification.
# Two TyCons unify when their module slots are equal OR at least
# one slot is `None`. `None` is the placeholder produced by
# `resolve_ty_with_binds` when it walks a signature TypeExpr
# without access to the recs/sums tables; the modular typecheck
# partition (`partition_decls_by_home`) already prevents a user
# `type Pair = ...` and `tuple.Pair[a, b]` from sharing the same
# bucket's typer state, so a `None` slot in a signature is no
# longer destructive — it cannot accidentally pair-up a user-side
# `Pair` against the stdlib's `Pair`.
#
# Returning to strict slot equality fails inside `tuple.kai`'s own
# bodies: `pub fn swap(p: Pair[a, b])` resolves `p`'s type via
# `resolve_ty_with_binds` to `TyCon(None, "Pair", [a, b])`, but
# the `Pair { ... }` literal in the body goes through
# `rec_instantiate` which stamps `Some("tuple")`. The permissive
# rule lets those unify; the partition keeps it safe.
#[doc("infer: `module_slot_compat` — typer entry point invoked by the driver.")]
pub fn module_slot_compat(am: Option[String], bm: Option[String]) : Bool = match am {
  None    -> true
  Some(_) -> match bm {
    None    -> true
    Some(_) -> option_str_eq(am, bm)
  }
}

fn field_init_list_has(fs: [FieldInit], target: String) : Bool {
  match fs {
    [] -> false
    [f, ...rest] -> match f {
      FI(nm, _) -> if nm == target { true } else { field_init_list_has(rest, target) }
    }
  }
}

# keep the accumulator newest-first (no `list_reverse`)
# so a user record declared later in the decl stream shadows an
# earlier same-name core record under `rec_find` (legacy bare-name
# lookup). The newest-first ordering is harmless for the field-aware
# walker — `rec_find_with_field` picks by declared-field set rather
# than position — and is correct for the arity-aware walker, which
# is unaffected by ordering when at most one record matches the
# arity. Earlier the list was `list_reverse`d back to declaration
# order (oldest-first), which made bare `rec_find` return the
# core's record over a same-name user redeclaration.
pub type SumInfo = SI(String, [String], [Variant], Option[String])
              # name, tparams, variants, module_origin (None = root file)

fn sum_find_loop(ss: [SumInfo], target: String) : Option[SumInfo] {
  match ss {
    [] -> None
    [s, ...rest] -> match s {
      SI(nm, _, _, _) -> if nm == target { Some(s) } else { sum_find_loop(rest, target) }
    }
  }
}

fn sum_find(ss: [SumInfo], target: String) : Option[SumInfo] = sum_find_loop(ss, target)

# SumInfo analog of `rerank_recs_for`. Same semantics: library
# code never sees the consumer's root sums.
fn rerank_sums_for(ss: [SumInfo], home_mod: Option[String], root_mod: String) : [SumInfo] = {
  let is_root_home = match home_mod {
    None     -> true
    Some(hm) -> hm == root_mod
  }
  if is_root_home {
    ss
  } else {
    rerank_sums_loop(ss, home_mod, root_mod, [], [], [])
  }
}

fn rerank_sums_loop(ss: [SumInfo], hm: Option[String], root_mod: String,
                       home: [SumInfo], other_mods: [SumInfo],
                       root: [SumInfo]) : [SumInfo] =
  match ss {
    [] -> list_append(list_reverse(home),
            list_append(list_reverse(other_mods), list_reverse(root)))
    [s, ...ss2] -> match s {
      SI(_, _, _, mo) -> {
        let is_root_sum = match mo {
          None     -> false
          Some(rm) -> rm == root_mod
        }
        if is_root_sum {
          rerank_sums_loop(ss2, hm, root_mod, home, other_mods, root)
        } else if option_str_eq(mo, hm) {
          rerank_sums_loop(ss2, hm, root_mod, [s, ...home], other_mods, root)
        } else { match mo {
          None    -> rerank_sums_loop(ss2, hm, root_mod, home, other_mods, [s, ...root])
          Some(_) -> rerank_sums_loop(ss2, hm, root_mod, home, [s, ...other_mods], root)
        } }
      }
    }
  }

fn collect_sums_loop(ds: [Decl], acc: [SumInfo]) : [SumInfo] {
  match ds {
    [] -> list_reverse(acc)
    [d, ...rest] -> match d {
      DType(_, nm, tps, body, _, _, mo, _) -> match body {
        TBSum(vs) -> collect_sums_loop(rest, [SI(nm, tps, vs, mo), ...acc])
        _ -> collect_sums_loop(rest, acc)
      }
      _ -> collect_sums_loop(rest, acc)
    }
  }
}

fn collect_sums(ds: [Decl]) : [SumInfo] = collect_sums_loop(ds, [])

# ---- inference state ----

# A single call-site that instantiated a polymorphic scheme. `fresh`
# lists the TyVarT ids minted for that instantiation; running each
# through the final sub recovers the concrete type arguments. The
# parallel `unit_fresh` list carries the UVar ids minted for the
# scheme's unit-kind tparams: without these the impl
# `Show for Real<u>` cannot be specialised per concrete unit, since
# the scheme has zero type-vars and the parametric body's
# `unit_name(x)` reads the impl-level uvar baked into `Expr.ty`.
# `mo` is the module_origin of the enclosing DFn (None = root file,
# Some(mod) = imported or auto-loaded module). Hanga Roa: with core
# auto-loaded into every program, downstream consumers of CallSite
# (notably `--dump-mono` and the test runner) need to distinguish
# call-sites authored in the user's root file from those that come
# through core or other modules.
type CallSite = CS(String, Int, Int, [Int], [Int], Option[String])  # name, line, col, fresh ty ids, fresh unit ids, module_origin

# A typed hole site: the kind discriminator (splits `?` /
# `?name` from `todo!(msg)`), source position, the fresh TyVarT id
# that stands in for it during inference, and the env entries
# visible at that point (snapshot of the locals stack). After
# inference the fresh id runs through the final sub to recover the
# expected type.
type HoleSite = HS(HoleKind, Int, Int, Int, [TyEntry], Int)
#                   kind     line col fresh scope      env_fresh

# hole kinds.
# - `HKHole(None)`     — anonymous `?`.
# - `HKHole(Some(n))`  — named `?n`. Same `n` shares one TyVarT.
# - `HKTodo(msg)`      — `todo!(msg)`. Each occurrence is independent
#   (no name-based sharing), and reporting flags it under
#   `"kind": "todo"` in `--holes-json`.
#[doc("infer: `HoleKind` — driver-facing type.")]
pub type HoleKind = HKHole(Option[String]) | HKTodo(String)

type InferState = { file: String, env: TyEnv, core_len: Int, sub: Subst, recs: [RecInfo], errs: Int,
                    insts: [CallSite], holes: [HoleSite],
                    # row accumulator carries full Labels (eff
                    # name + ty_args). Op calls add the parametric label
                    # built from the op's instantiation (`inst.fresh`);
                    # `synth_handle` filters by name + ty_args unification
                    # so distinct instantiations of the same effect stay
                    # separate when their ty_args do not unify.
                    row: [Label],
                    eff_uses: [EffUse],   # per-label first-use site for diagnostics
                    aliases: [AliasBinding],   # `Eff as log` bindings active in scope
                    # when type-checking a stateful handler's
                    # clause body, a ResumeBind tracks the effect's
                    # answer type and the handler-state type so
                    # `resume(v)` and `resume(v, ns)` calls validate
                    # against the right shape. None outside clauses or
                    # in stateless clauses (in which case the standard
                    # env binding is the source of truth).
                    clause_resume: Option[ResumeBind],
                    # per-op generic schemes quantify over both
                    # effect-level and op-level tparams; the row label
                    # only carries the effect-level ones. This table
                    # records, per dotted "Eff.op" key, the effect's
                    # arity so synth_op_call_with_scheme can split
                    # `inst.fresh` correctly. Builds during build_ty_env.
                    op_eff_arities: [OpEffArity],
                    # declared return type of the immediately-
                    # enclosing function. Set by `infer_decl` before it
                    # walks the body; cleared (None) inside lambda
                    # bodies — `e!` propagates from the enclosing
                    # function, not from a closure, so `!` inside a
                    # lambda is rejected with a clear diagnostic.
                    ret_ty: Option[Ty],
                    # type aliases (`type Console =
                    # Stdout + Stderr + Stdin`, `type Io = Console +
                    # Env + File`, ...) carried into the typer so
                    # `try_op_call` can resolve `Aliasname.opname` by
                    # finding which component effect provides the op.
                    # Populated from `alias_res.aliases` at the start
                    # of `infer_program` (or empty).
                    type_aliases: [AliasResult],
                    # per-effect op→eff catalog
                    # consulted alongside `type_aliases` so
                    # `try_op_call` can answer "which component of
                    # this alias declares this op?" in O(n*m).
                    op_to_eff: [OpToEff],
                    # snapshot of the protocol impl table
                    # at lower-protocols time. `synth_binop` consults
                    # it to decide whether a (prim, nonprim) /
                    # (nonprim, prim) / (nonprim, nonprim cross) pair
                    # has a matching `impl P[A] for T` registered.
                    # Empty when no protocols are loaded.
                    proto_impls: [ProtoImplReg],
                    # `==` / `!=` / `<` / `>` / `<=` / `>=` as sugar for
                    # Eq.eq / Ord.cmp: `synth_binop` consults the sum-type
                    # registry to decide whether a compound type is
                    # structurally comparable (descend field types, no
                    # custom impl anywhere) or must dispatch to a user
                    # `impl Eq`/`impl Ord`. Records live in `recs`; sum
                    # variants live here. Populated in `infer_program`.
                    sums: [SumInfo],
                    # structured diagnostic collection. T1,
                    # T2, T4, T5 emit-sites push a `Diagnostic` here in
                    # parallel with their existing stderr `diag_*` calls.
                    # Stored in reverse order (most recent first); the
                    # entry point flips it back to source order when
                    # exposing via `TypedProgram.diags`.
                    diags: [Diagnostic],
                    # field accesses on a not-yet-resolved
                    # receiver, drained by `infer_decl` after the body's
                    # tyvars settle (post `check_body_row`). See
                    # `DeferredField`.
                    deferred_fields: [DeferredField],
                    # for every parametric effect op call, the
                    # effect name plus the LIVE tyvar ids of its row
                    # ty_args (`eff_fresh`), captured at the op-call. NOT
                    # the resolved `Ty`s — a frozen `Ty` snapshot taken at
                    # op-call time predates the `match` binder that unifies
                    # the receiver with the op's return payload, so it
                    # would carry a dead representative. Keeping the ids
                    # lets the deferred-field drain resolve them under the
                    # FINAL substitution: a receiver still free after the
                    # body settled is pinned by finding the op whose
                    # payload id shares the receiver's final representative
                    # (the body genuinely connected them) and unifying that
                    # op's label against the enclosing DECLARED row — the
                    # authoritative source of `User`. Read-only after the
                    # body walk; never feeds row-subset checking, so it
                    # cannot perturb the m7b_11 row-mismatch diagnostic.
                    op_payload_labels: [OpPayloadVars],
                    # per effect-op call, the resolution the typer made:
                    # the op name, the effects that declare that op (the
                    # ambiguity set), which effect won, and the call's
                    # alias tag. Recorded at the resolution site
                    # (`try_op_call`) where all three coexist; after that
                    # they fuse into one label or vanish (an interp-buried
                    # `@cap` read leaves no structural op-call). Read-only
                    # — it never changes a resolution decision, only
                    # observes it — so the #820 evidence-obligation
                    # analysis sees the op-name collision where it is
                    # actually decided.
                    op_res: [OpResolution],
                    # true while type-checking a handler op-clause body.
                    # `resume` is only legal in call position (`resume(v)`);
                    # any value-position use (`let k = resume`, `f(resume)`)
                    # escapes the clause and is rejected. Set on clause entry,
                    # cleared inside lambdas (where `resume` is an ordinary
                    # identifier), restored by `st_restore_entries`.
                    in_clause: Bool }

#[doc("infer: `OpEffArity` — driver-facing type.")]
pub type OpEffArity = OEA(String, Int)

# a deferred field-access constraint. When `synth_field`
# meets a receiver whose type is still an unbound tyvar (e.g. the
# payload of a generic effect op, `Some(b) -> b.id` where `b : ?a`
# and `?a` is only pinned to `Box` later by `check_body_row` against
# the declared row), it cannot decide field-vs-UFCS yet. Instead of
# the wrong eager UFCS fallback, it records a `DF(recv_id, field,
# result_id, line, col)` and stamps `b.id` with a fresh result tyvar.
# `infer_decl` drains the worklist AFTER `check_body_row` — by then
# `?a` is resolved — looking the field up on the now-concrete receiver
# type and unifying the result. A receiver still unbound at drain time
# is an "annotation needed" error (OCaml warning-18 shape). This keeps
# the field-vs-UFCS decision out of the effect-row inference entirely;
# the bug was a timing problem, not an effect-propagation one.
#[doc("infer: `DeferredField` — a field access on a not-yet-resolved receiver.")]
pub type DeferredField = DF(Int, String, Int, Int, Int)  # recv tyvar id, field name, result tyvar id, line, col

# a parametric effect op call's row identity: the effect
# name (with the `@cell` suffix if any) and the LIVE tyvar ids of its
# row ty_args, in declaration order. Stashed at the op-call before
# `st_add_label` dedup can drop the label; resolved under the final sub
# at drain time so the receiver-to-payload link the `match` binder made
# is visible.
#[doc("infer: `OpPayloadVars` — a parametric op call's effect name + live row-arg tyvar ids.")]
pub type OpPayloadVars = OPV(String, [Int])  # eff name, row ty_arg tyvar ids

# a single effect-op call's resolution, captured at `try_op_call`.
# `fn_name` is the enclosing function (stamped by `infer_decl` once the
# body is walked — empty at the raw capture); `op` is the op name;
# `cands` are every effect declaring that op (the by-name ambiguity set);
# `chosen` is the effect the typer bound; `alias` is the `@cell` tag when
# the call resolved through a named instance, `None` for a bare/by-name
# call; `tagged` is whether the dispatch keeps that tag at runtime —
# false when the call crossed a clause/lambda boundary, where the tag is
# suppressed and the call falls back to the by-name walk (the #789
# value-corruption shape: an aliased `@cap` read that loses its instance
# identity inside an unrelated handler clause). The #820 evidence
# analysis reads this to classify each call's supplier and to surface the
# op-name collision where it is decided — before the op call fuses into a
# label or vanishes in an interpolation span. `fn_name` attributes the
# resolution to its function without relying on source lines, which an
# interpolation re-parse rewrites.
#[doc("infer: `OpResolution` — one op call's resolution: enclosing fn, op name, candidate effects, chosen effect, alias tag, runtime-tagged, site.")]
pub type OpResolution = OPR(String, String, [String], String, Option[String], Bool, Int, Int)

# answer type + handler-state type for the currently-walked
# clause body of a stateful handler.
type ResumeBind = RB(Ty, Ty)

# first-use record per effect label in the current body.
# `check_body_row` reads this when it needs to point a diagnostic
# at the op call that caused the row to widen, instead of pinning
# the whole error to the function's declaration site.
type EffUse = EU(String, Int, Int)

# Stack entry for `Eff as log`. The stack is pushed on entering
# the body of a `handle ... with Eff as log { ... }` and popped
# on exit. try_op_call consults it when the dotted lookup fails:
# `log.print` walks the stack, finds `log → Io`, and retries as
# `Io.print`.
#
# (compiler integration, scope-limited): the Bool field
# records whether the binding is "taggable" — when true, an op
# call through this alias gets the `@<alias>` suffix that the
# codegen turns into a `kai_evidence_lookup_node_by_id(...)`
# dispatch. When false (after we descended into a lambda body),
# the alias still resolves for substitution but the codegen
# falls back to the legacy name-keyed lookup. The handle
# prologue's `kai_alias_<a>_id` C local is not in scope across
# the lambda boundary, so tagged dispatch would emit invalid C.
#[doc("infer: an effect-alias binding (alias name, effect name, taggable).")]
pub type AliasBinding = AB(String, String, Bool)   # alias_name, eff_name, taggable

# `TyRes` is the narrow result returned by pure type operations that
# don't consume or produce an expression (fresh var, instantiate a
# scheme, compute a param type). `Inferred` adds the re-built Expr
# tree with every sub-node carrying its inferred `Ty`, which M4+
# passes consume without re-running inference.
type TyRes = { st: InferState, ty: Ty }

type Inferred = { st: InferState, ty: Ty, expr: Expr }

type InferredList = { st: InferState, tys: [Ty], exprs: [Expr] }

type InferredStmts = { st: InferState, stmts: [Stmt] }
type InferredArms  = { st: InferState, arms: [Arm] }
type InferredElems = { st: InferState, elems: [ListElem] }
type InferredFInits = { st: InferState, fis: [FieldInit] }

fn infer_state_new(file: String, env: TyEnv, core_len: Int, recs: [RecInfo]) : InferState =
  infer_state_new_full(file, env, core_len, recs, [])

fn infer_state_new_full(file: String, env: TyEnv, core_len: Int,
                        recs: [RecInfo], op_eff_arities: [OpEffArity]) : InferState =
  infer_state_new_full_aliases(file, env, core_len, recs, op_eff_arities, [], [], [])

# variant carrying type aliases + op-to-eff catalog
# so `try_op_call` can resolve `Aliasname.opname` against alias
# components. Older callers (no alias context) use the empty form.
fn infer_state_new_full_aliases(file: String, env: TyEnv, core_len: Int,
                                  recs: [RecInfo], op_eff_arities: [OpEffArity],
                                  type_aliases: [AliasResult],
                                  op_to_eff: [OpToEff],
                                  kind_theories: [KindTheory]) : InferState =
  InferState { file: file, env: env, core_len: core_len,
               sub: subst_seed_kind_theories(subst_empty(), kind_theories),
               recs: recs, errs: 0, insts: [], holes: [], row: [],
               eff_uses: [], aliases: [], clause_resume: None,
               op_eff_arities: op_eff_arities, ret_ty: None,
               type_aliases: type_aliases, op_to_eff: op_to_eff, proto_impls: [], sums: [], diags: [], deferred_fields: [], op_payload_labels: [], op_res: [], in_clause: false }

fn st_set_proto_impls(st: InferState, pis: [ProtoImplReg]) : InferState =
  InferState { file: st.file, env: st.env, core_len: st.core_len, sub: st.sub,
               recs: st.recs, errs: st.errs, insts: st.insts, holes: st.holes,
               row: st.row, eff_uses: st.eff_uses, aliases: st.aliases,
               clause_resume: st.clause_resume, op_eff_arities: st.op_eff_arities,
               ret_ty: st.ret_ty, type_aliases: st.type_aliases, op_to_eff: st.op_to_eff,
               proto_impls: pis, sums: st.sums, diags: st.diags, deferred_fields: st.deferred_fields, op_payload_labels: st.op_payload_labels, op_res: st.op_res, in_clause: st.in_clause }

fn st_set_sums(st: InferState, ss: [SumInfo]) : InferState =
  InferState { file: st.file, env: st.env, core_len: st.core_len, sub: st.sub,
               recs: st.recs, errs: st.errs, insts: st.insts, holes: st.holes,
               row: st.row, eff_uses: st.eff_uses, aliases: st.aliases,
               clause_resume: st.clause_resume, op_eff_arities: st.op_eff_arities,
               ret_ty: st.ret_ty, type_aliases: st.type_aliases, op_to_eff: st.op_to_eff,
               proto_impls: st.proto_impls, sums: ss, diags: st.diags, deferred_fields: st.deferred_fields, op_payload_labels: st.op_payload_labels, op_res: st.op_res, in_clause: st.in_clause }

fn st_set_env(st: InferState, new_env: TyEnv) : InferState =
  InferState { file: st.file, env: new_env, core_len: st.core_len, sub: st.sub,
               recs: st.recs, errs: st.errs, insts: st.insts, holes: st.holes,
               row: st.row, eff_uses: st.eff_uses, aliases: st.aliases,
               clause_resume: st.clause_resume, op_eff_arities: st.op_eff_arities,
               ret_ty: st.ret_ty, type_aliases: st.type_aliases, op_to_eff: st.op_to_eff, proto_impls: st.proto_impls, sums: st.sums, diags: st.diags, deferred_fields: st.deferred_fields, op_payload_labels: st.op_payload_labels, op_res: st.op_res, in_clause: st.in_clause }

fn st_set_sub(st: InferState, new_sub: Subst) : InferState =
  InferState { file: st.file, env: st.env, core_len: st.core_len, sub: new_sub,
               recs: st.recs, errs: st.errs, insts: st.insts, holes: st.holes,
               row: st.row, eff_uses: st.eff_uses, aliases: st.aliases,
               clause_resume: st.clause_resume, op_eff_arities: st.op_eff_arities,
               ret_ty: st.ret_ty, type_aliases: st.type_aliases, op_to_eff: st.op_to_eff, proto_impls: st.proto_impls, sums: st.sums, diags: st.diags, deferred_fields: st.deferred_fields, op_payload_labels: st.op_payload_labels, op_res: st.op_res, in_clause: st.in_clause }

fn st_bump_err(st: InferState) : InferState =
  InferState { file: st.file, env: st.env, core_len: st.core_len, sub: st.sub,
               recs: st.recs, errs: st.errs + 1, insts: st.insts, holes: st.holes,
               row: st.row, eff_uses: st.eff_uses, aliases: st.aliases,
               clause_resume: st.clause_resume, op_eff_arities: st.op_eff_arities,
               ret_ty: st.ret_ty, type_aliases: st.type_aliases, op_to_eff: st.op_to_eff, proto_impls: st.proto_impls, sums: st.sums, diags: st.diags, deferred_fields: st.deferred_fields, op_payload_labels: st.op_payload_labels, op_res: st.op_res, in_clause: st.in_clause }

# push a Diagnostic onto the InferState accumulator.
# Used by the T1, T2, T4, T5 emit sites in parallel with their stderr
# `diag_error` calls — stderr output is unchanged.
fn st_push_diag(st: InferState, d: Diagnostic) : InferState =
  InferState { file: st.file, env: st.env, core_len: st.core_len, sub: st.sub,
               recs: st.recs, errs: st.errs, insts: st.insts, holes: st.holes,
               row: st.row, eff_uses: st.eff_uses, aliases: st.aliases,
               clause_resume: st.clause_resume, op_eff_arities: st.op_eff_arities,
               ret_ty: st.ret_ty, type_aliases: st.type_aliases, op_to_eff: st.op_to_eff, proto_impls: st.proto_impls, sums: st.sums, diags: [d, ...st.diags], deferred_fields: st.deferred_fields, op_payload_labels: st.op_payload_labels, op_res: st.op_res, in_clause: st.in_clause }

# record one op-call resolution. Read-only side data for the #820
# evidence analysis: the effect the typer chose, every effect that
# declares this op (the by-name ambiguity set), and the alias tag.
# Never read by inference itself, so it cannot perturb a decision.
fn st_record_op_res(st: InferState, op: String, chosen: String,
                    alias_opt: Option[String], tagged: Bool, line: Int, col: Int) : InferState {
  let cands = effs_declaring_op(st.op_to_eff, op)
  # fn_name filled in by `infer_decl` once the enclosing function is known.
  let opr = OPR("", op, cands, chosen, alias_opt, tagged, line, col)
  InferState { file: st.file, env: st.env, core_len: st.core_len, sub: st.sub,
               recs: st.recs, errs: st.errs, insts: st.insts, holes: st.holes,
               row: st.row, eff_uses: st.eff_uses, aliases: st.aliases,
               clause_resume: st.clause_resume, op_eff_arities: st.op_eff_arities,
               ret_ty: st.ret_ty, type_aliases: st.type_aliases, op_to_eff: st.op_to_eff, proto_impls: st.proto_impls, sums: st.sums, diags: st.diags, deferred_fields: st.deferred_fields, op_payload_labels: st.op_payload_labels, op_res: [opr, ...st.op_res], in_clause: st.in_clause }
}

# every effect declaring `op`, deduped — the by-name ambiguity set.
fn effs_declaring_op(oe: [OpToEff], op: String) : [String] = match oe {
  []           -> []
  [p, ...rest] -> match p {
    OEFP(o, eff) ->
      if o == op and not list_has_string(effs_declaring_op(rest, op), eff) {
        [eff, ...effs_declaring_op(rest, op)]
      } else { effs_declaring_op(rest, op) }
  }
}

# stamp the op-call resolution onto a just-inferred op call. `r` is the
# result of a `synth_op_call_*`; the record rides its `st` so it is not
# lost. Keyed by the chosen effect + the op name split from `key`.
fn record_op_res(r: Inferred, key: String, alias_opt: Option[String],
                 tagged: Bool, line: Int, col: Int) : Inferred =
  Inferred { st: st_record_op_res(r.st, dotted_suffix(key), dotted_prefix(key), alias_opt, tagged, line, col),
             ty: r.ty, expr: r.expr }

# mark that the current body has performed an op
# of `eff` with the given type-arg instantiation. Labels with the same
# `eff` but unifiable ty_args dedup; labels with the same `eff` but
# non-unifiable ty_args are kept distinct so a body can perform e.g.
# `Reader[Int]` and `Reader[String]` and have both flow through.
fn st_add_label(st: InferState, lab: Label, line: Int, col: Int) : InferState {
  if label_present_unifiable(st.row, lab, st.sub) { st }
  else {
    InferState { file: st.file, env: st.env, core_len: st.core_len, sub: st.sub,
                 recs: st.recs, errs: st.errs, insts: st.insts, holes: st.holes,
                 row: [lab, ...st.row],
                 eff_uses: [EU(lab.eff, line, col), ...st.eff_uses],
                 aliases: st.aliases,
                 clause_resume: st.clause_resume, op_eff_arities: st.op_eff_arities,
                 ret_ty: st.ret_ty, type_aliases: st.type_aliases, op_to_eff: st.op_to_eff, proto_impls: st.proto_impls, sums: st.sums, diags: st.diags, deferred_fields: st.deferred_fields, op_payload_labels: st.op_payload_labels, op_res: st.op_res, in_clause: st.in_clause }
  }
}

# Unify a cell op's label ty_args against an existing same-cell label
# before `st_add_label`'s pure dedup drops one of them. The dedup treats a
# fresh tyvar as unifiable but never propagates the binding, so a fresh
# payload tyvar (a `State.get` return) would stay free unless the concrete
# arg an earlier op pinned (`State.set`'s value) is threaded here.
#
# Gated on the `@alias` cell tag: a cell's ops all share one state type by
# construction of its handler, so forcing the unification is sound. Effects
# WITHOUT an alias may carry two independent instances in the row
# (`Actor[Request]` + `Actor[Reply]`); those key by concrete `name[args]`
# and must NOT have their args cross-bound — the shallow-unifiable check is
# too lax a precondition for them (a free arg "unifies" with any concrete
# one). So only same-cell (`eff@alias`) labels are threaded.
fn st_unify_dedup_label(st: InferState, lab: Label, line: Int, col: Int) : InferState / Console + File + Mutable =
  if not label_is_aliased_cell(lab.eff) { st }
  else {
    match find_unifiable_label_args(st.row, lab, st.sub) {
      Some(existing_args) -> st_unify_ty_args(st, existing_args, lab.ty_args, line, col)
      None                -> st
    }
  }

# A cell label carries an `@<alias>` identity suffix (see
# `label_eff_with_alias`); a bare effect name does not.
fn label_is_aliased_cell(eff: String) : Bool = label_has_at(eff, 0, string_length(eff))

fn label_has_at(eff: String, i: Int, n: Int) : Bool {
  if i >= n { false }
  else { match char_at(eff, i) {
    Some(c) -> if c == '@' { true } else { label_has_at(eff, i + 1, n) }
    None    -> false
  } }
}

fn find_unifiable_label_args(row: [Label], target: Label, s: Subst) : Option[[Ty]] {
  match row {
    [] -> None
    [h, ...rest] ->
      if h.eff == target.eff and labels_args_unify(h.ty_args, target.ty_args, s) {
        Some(h.ty_args)
      } else { find_unifiable_label_args(rest, target, s) }
  }
}

fn st_unify_ty_args(st: InferState, a: [Ty], b: [Ty], line: Int, col: Int) : InferState / Console + File + Mutable =
  match a {
    [] -> st
    [ah, ...arest] -> match b {
      [] -> st
      [bh, ...brest] ->
        st_unify_ty_args(st_unify(st, ah, bh, "shared effect label", line, col), arest, brest, line, col)
    }
  }

# Compatibility wrapper for stateless / non-parametric op calls. The
# pattern carries no type args.
fn st_add_effect(st: InferState, eff: String, line: Int, col: Int) : InferState =
  st_add_label(st, Label { eff: eff, ty_args: [] }, line, col)

# Fold `st_add_label` over a list of labels. Used by `synth_call` to
# propagate every label the callee declared into the caller's row, so
# `inferred_main_row` sees effects reached transitively via helpers.
fn st_add_labels(st: InferState, labels: [Label], line: Int, col: Int) : InferState = match labels {
  []           -> st
  [h, ...rest] -> st_add_labels(st_add_label(st, h, line, col), rest, line, col)
}

# propagate capability-only labels from a callee's
# declared row into the caller's row. Today this is exactly `Ffi`:
# it carries zero ops, has no default handler installed by
# `emit_main_wrapper`, and per `docs/design.md` §Baseline
# architecture must be declared everywhere it crosses to C. Without
# this propagation, `main : Unit { let _ = puts("hi") }` (where
# `puts : Int / Ffi` is an `extern "C" fn`) compiles silently —
# the silent contract documented in
# `examples/negative/silent_contract/ffi_call_no_capability.kai`.
#
# General transitive propagation (every callee label flows up) is the
# principled answer, but applying it bluntly would force annotating the
# many internal compiler helpers (diag_*, dump_*, check_*, synth_*)
# whose `/ Console` rows are currently absorbed by the caller's open
# tail var.
fn st_propagate_capability_labels(st: InferState, callee_ty: Ty,
                                   line: Int, col: Int) : InferState {
  match callee_ty {
    TyFnT(_, _, row) -> st_add_labels(st, capability_labels_only(row.labels), line, col)
    _ -> st
  }
}

# full transitive propagation of every callee effect
# label to the caller's row. No `Ffi`-only filter — honest
# signatures, no hardcoded filters.
fn capability_labels_only(labels: [Label]) : [Label] = labels

# True iff `target.eff` matches some label in `row` AND the existing
# label's ty_args unify with target.ty_args under the current sub.
# Used as a syntactic-dedup guard; non-unifying same-name labels do not
# match here (so the row keeps both, and the resolver / handler-filter
# pass decides their fate).
fn label_present_unifiable(row: [Label], target: Label, s: Subst) : Bool {
  match row {
    [] -> false
    [h, ...rest] ->
      if h.eff == target.eff and labels_args_unify(h.ty_args, target.ty_args, s) {
        true
      } else {
        label_present_unifiable(rest, target, s)
      }
  }
}

# Speculative arity + unification check on two ty_arg lists. Wrong
# arity → no match. Used by st_add_label and the handler-filter pass.
# Pure under apply_ty (does not extend the substitution) — the actual
# unification later in synth_op_call_with_scheme is what mutates the
# sub.
fn labels_args_unify(a: [Ty], b: [Ty], s: Subst) : Bool {
  match a {
    [] -> match b { [] -> true _ -> false }
    [ah, ...arest] -> match b {
      [] -> false
      [bh, ...brest] -> {
        let aa = apply_ty(s, ah)
        let bb = apply_ty(s, bh)
        if ty_unifiable_shallow(aa, bb) { labels_args_unify(arest, brest, s) }
        else { false }
      }
    }
  }
}

# Conservative shape-check on already-substituted types. Two TyVars
# never block a match; concrete-vs-concrete must agree structurally.
# Stricter than full unify (no substitution side effect) but enough
# for the dedup / filter decisions in this layer.
fn ty_unifiable_shallow(a: Ty, b: Ty) : Bool {
  match a {
    TyVarT(_) -> true
    TyAny     -> true
    _ -> match b {
      TyVarT(_) -> true
      TyAny     -> true
      _ -> ty_eq_shape(a, b)
    }
  }
}

# Structural equality on resolved Tys — used only as a fallback in
# `ty_unifiable_shallow`. Excludes TyVarT/TyAny which short-circuit
# above. Approximates HM-equality for concrete types.
fn ty_eq_shape(a: Ty, b: Ty) : Bool {
  # ty_eq_shape is a shape-only check (no predicate
  # equality), so refinements are peeled before comparing.
  let ax = unwrap_refines(a)
  let bx = unwrap_refines(b)
  match ax {
    TyInt    -> match bx { TyInt -> true _ -> false }
    TyReal   -> match bx { TyReal -> true _ -> false }
    TyBool   -> match bx { TyBool -> true _ -> false }
    TyString -> match bx { TyString -> true _ -> false }
    TyChar   -> match bx { TyChar -> true _ -> false }
    TyUnit   -> match bx { TyUnit -> true _ -> false }
    TyByte     -> match bx { TyByte -> true _ -> false }
    TyInt32    -> match bx { TyInt32 -> true _ -> false }
    TyUInt32   -> match bx { TyUInt32 -> true _ -> false }
    TyUInt64   -> match bx { TyUInt64 -> true _ -> false }
    TyInt128   -> match bx { TyInt128 -> true _ -> false }
    TyHandle   -> match bx { TyHandle -> true _ -> false }
    TyListT(ai) -> match bx { TyListT(bi) -> ty_eq_shape(ai, bi) _ -> false }
    TyFnT(ap, ar, _) -> match bx {
      TyFnT(bp, br, _) -> ty_list_eq_shape(ap, bp) and ty_eq_shape(ar, br)
      _ -> false
    }
    # Hanga Roa: shape equality respects module_origin too.
    TyCon(am, an, atas) -> match bx {
      TyCon(bm, bn, btas) -> module_slot_compat(am, bm) and an == bn and ty_list_eq_shape(atas, btas)
      _ -> false
    }
    # shape-equality on unions is point-wise on
    # the canonical component list — same rule as `inf_ty_eq` minus the
    # refinement-stripping the caller already did at the top of this
    # function. Different union arities never compare equal.
    TyUnion(aps) -> match bx {
      TyUnion(bps) -> ty_list_eq_shape(aps, bps)
      _ -> false
    }
    _ -> false
  }
}

fn ty_list_eq_shape(a: [Ty], b: [Ty]) : Bool {
  match a {
    [] -> match b { [] -> true _ -> false }
    [h, ...rest] -> match b {
      [] -> false
      [h2, ...rest2] -> ty_eq_shape(h, h2) and ty_list_eq_shape(rest, rest2)
    }
  }
}

# replace the row accumulator wholesale. Used by
# synth_handle to switch into an empty inner row before walking
# the body, then to merge the filtered body-row back with the
# outer row.
fn st_set_row(st: InferState, new_row: [Label]) : InferState =
  InferState { file: st.file, env: st.env, core_len: st.core_len, sub: st.sub,
               recs: st.recs, errs: st.errs, insts: st.insts, holes: st.holes,
               row: new_row, eff_uses: st.eff_uses, aliases: st.aliases,
               clause_resume: st.clause_resume, op_eff_arities: st.op_eff_arities,
               ret_ty: st.ret_ty, type_aliases: st.type_aliases, op_to_eff: st.op_to_eff, proto_impls: st.proto_impls, sums: st.sums, diags: st.diags, deferred_fields: st.deferred_fields, op_payload_labels: st.op_payload_labels, op_res: st.op_res, in_clause: st.in_clause }

# push/pop the alias stack as we enter/leave a handle's body.
# a freshly-pushed alias starts taggable; descending into a
# lambda body marks every alias visible at that point as
# non-taggable so try_op_call's alias-fallback emits a bare
# dispatch key (no `@<alias>` suffix) and codegen falls back to
# the legacy name-keyed lookup.
fn st_push_alias(st: InferState, alias: String, eff: String) : InferState =
  InferState { file: st.file, env: st.env, core_len: st.core_len, sub: st.sub,
               recs: st.recs, errs: st.errs, insts: st.insts, holes: st.holes,
               row: st.row, eff_uses: st.eff_uses,
               aliases: [AB(alias, eff, true), ...st.aliases],
               clause_resume: st.clause_resume, op_eff_arities: st.op_eff_arities,
               ret_ty: st.ret_ty, type_aliases: st.type_aliases, op_to_eff: st.op_to_eff, proto_impls: st.proto_impls, sums: st.sums, diags: st.diags, deferred_fields: st.deferred_fields, op_payload_labels: st.op_payload_labels, op_res: st.op_res, in_clause: st.in_clause }

fn st_pop_alias(st: InferState) : InferState {
  match st.aliases {
    [] -> st
    [_, ...rest] ->
      InferState { file: st.file, env: st.env, core_len: st.core_len, sub: st.sub,
                   recs: st.recs, errs: st.errs, insts: st.insts, holes: st.holes,
                   row: st.row, eff_uses: st.eff_uses, aliases: rest,
                   clause_resume: st.clause_resume, op_eff_arities: st.op_eff_arities,
                   ret_ty: st.ret_ty, type_aliases: st.type_aliases, op_to_eff: st.op_to_eff, proto_impls: st.proto_impls, sums: st.sums, diags: st.diags, deferred_fields: st.deferred_fields, op_payload_labels: st.op_payload_labels, op_res: st.op_res, in_clause: st.in_clause }
  }
}

# push / pop / read the clause resume binding.
fn st_set_clause_resume(st: InferState, rb: Option[ResumeBind]) : InferState =
  InferState { file: st.file, env: st.env, core_len: st.core_len, sub: st.sub,
               recs: st.recs, errs: st.errs, insts: st.insts, holes: st.holes,
               row: st.row, eff_uses: st.eff_uses, aliases: st.aliases,
               clause_resume: rb, op_eff_arities: st.op_eff_arities,
               ret_ty: st.ret_ty, type_aliases: st.type_aliases, op_to_eff: st.op_to_eff, proto_impls: st.proto_impls, sums: st.sums, diags: st.diags, deferred_fields: st.deferred_fields, op_payload_labels: st.op_payload_labels, op_res: st.op_res, in_clause: st.in_clause }

# mark whether the current scope is a handler op-clause body.
fn st_set_in_clause(st: InferState, b: Bool) : InferState =
  InferState { file: st.file, env: st.env, core_len: st.core_len, sub: st.sub,
               recs: st.recs, errs: st.errs, insts: st.insts, holes: st.holes,
               row: st.row, eff_uses: st.eff_uses, aliases: st.aliases,
               clause_resume: st.clause_resume, op_eff_arities: st.op_eff_arities,
               ret_ty: st.ret_ty, type_aliases: st.type_aliases, op_to_eff: st.op_to_eff, proto_impls: st.proto_impls, sums: st.sums, diags: st.diags, deferred_fields: st.deferred_fields, op_payload_labels: st.op_payload_labels, op_res: st.op_res, in_clause: b }

# stash/clear/restore the enclosing function's declared
# return type for `e!` propagation. Set by `infer_decl` before walking
# the body; cleared by `synth_lambda` so `!` inside a closure is
# rejected (would propagate from the lambda, not the surrounding fn).
fn st_set_ret_ty(st: InferState, rt: Option[Ty]) : InferState =
  InferState { file: st.file, env: st.env, core_len: st.core_len, sub: st.sub,
               recs: st.recs, errs: st.errs, insts: st.insts, holes: st.holes,
               row: st.row, eff_uses: st.eff_uses, aliases: st.aliases,
               clause_resume: st.clause_resume, op_eff_arities: st.op_eff_arities,
               ret_ty: rt, type_aliases: st.type_aliases, op_to_eff: st.op_to_eff, proto_impls: st.proto_impls, sums: st.sums, diags: st.diags, deferred_fields: st.deferred_fields, op_payload_labels: st.op_payload_labels, op_res: st.op_res, in_clause: st.in_clause }

# register a deferred field-access constraint (see
# `DeferredField`). Pushed by `synth_field` when the receiver type is
# still an unbound tyvar; drained by `infer_decl` after `check_body_row`.
fn st_push_deferred_field(st: InferState, df: DeferredField) : InferState =
  InferState { file: st.file, env: st.env, core_len: st.core_len, sub: st.sub,
               recs: st.recs, errs: st.errs, insts: st.insts, holes: st.holes,
               row: st.row, eff_uses: st.eff_uses, aliases: st.aliases,
               clause_resume: st.clause_resume, op_eff_arities: st.op_eff_arities,
               ret_ty: st.ret_ty, type_aliases: st.type_aliases, op_to_eff: st.op_to_eff, proto_impls: st.proto_impls, sums: st.sums, diags: st.diags, deferred_fields: [df, ...st.deferred_fields], op_payload_labels: st.op_payload_labels, op_res: st.op_res, in_clause: st.in_clause }

# record an op call's effect name + live row-arg tyvar ids
# BEFORE `st_add_label`'s dedup can drop the label. Only parametric ops
# (non-empty id list) carry a payload tyvar a deferred field could need.
fn st_push_op_payload_vars(st: InferState, eff: String, ids: [Int]) : InferState =
  match ids {
    [] -> st
    _  -> InferState { file: st.file, env: st.env, core_len: st.core_len, sub: st.sub,
                       recs: st.recs, errs: st.errs, insts: st.insts, holes: st.holes,
                       row: st.row, eff_uses: st.eff_uses, aliases: st.aliases,
                       clause_resume: st.clause_resume, op_eff_arities: st.op_eff_arities,
                       ret_ty: st.ret_ty, type_aliases: st.type_aliases, op_to_eff: st.op_to_eff, proto_impls: st.proto_impls, sums: st.sums, diags: st.diags, deferred_fields: st.deferred_fields, op_payload_labels: [OPV(eff, ids), ...st.op_payload_labels], op_res: st.op_res, in_clause: st.in_clause }
  }

#[doc("infer: `lookup_alias` — typer entry point invoked by the driver.")]
pub fn lookup_alias(aliases: [AliasBinding], name: String) : Option[String] {
  match aliases {
    [] -> None
    [AB(alias, eff, _), ...rest] ->
      if alias == name { Some(eff) } else { lookup_alias(rest, name) }
  }
}

# variant of lookup_alias that also returns the binding's
# taggability flag. Used by try_op_call's alias-fallback to decide
# whether to emit a tagged dispatch key.
fn lookup_alias_taggable(aliases: [AliasBinding], name: String) : Option[Bool] {
  match aliases {
    [] -> None
    [AB(alias, _, t), ...rest] ->
      if alias == name { Some(t) } else { lookup_alias_taggable(rest, name) }
  }
}

# mark every alias currently in scope as non-taggable.
# Called from synth_lambda before walking the body and reverted
# afterwards via the standard `st_restore_entries` snapshot.
fn aliases_disable_tag(aliases: [AliasBinding]) : [AliasBinding] {
  match aliases {
    [] -> []
    [AB(a, e, _), ...rest] -> [AB(a, e, false), ...aliases_disable_tag(rest)]
  }
}

fn st_disable_alias_tag(st: InferState) : InferState =
  InferState { file: st.file, env: st.env, core_len: st.core_len, sub: st.sub,
               recs: st.recs, errs: st.errs, insts: st.insts, holes: st.holes,
               row: st.row, eff_uses: st.eff_uses,
               aliases: aliases_disable_tag(st.aliases),
               clause_resume: st.clause_resume, op_eff_arities: st.op_eff_arities,
               ret_ty: st.ret_ty, type_aliases: st.type_aliases, op_to_eff: st.op_to_eff, proto_impls: st.proto_impls, sums: st.sums, diags: st.diags, deferred_fields: st.deferred_fields, op_payload_labels: st.op_payload_labels, op_res: st.op_res, in_clause: st.in_clause }

fn st_push_inst(st: InferState, cs: CallSite) : InferState =
  InferState { file: st.file, env: st.env, core_len: st.core_len, sub: st.sub,
               recs: st.recs, errs: st.errs, insts: [cs, ...st.insts], holes: st.holes,
               row: st.row, eff_uses: st.eff_uses, aliases: st.aliases,
               clause_resume: st.clause_resume, op_eff_arities: st.op_eff_arities,
               ret_ty: st.ret_ty, type_aliases: st.type_aliases, op_to_eff: st.op_to_eff, proto_impls: st.proto_impls, sums: st.sums, diags: st.diags, deferred_fields: st.deferred_fields, op_payload_labels: st.op_payload_labels, op_res: st.op_res, in_clause: st.in_clause }

fn st_push_hole(st: InferState, h: HoleSite) : InferState =
  InferState { file: st.file, env: st.env, core_len: st.core_len, sub: st.sub,
               recs: st.recs, errs: st.errs, insts: st.insts, holes: [h, ...st.holes],
               row: st.row, eff_uses: st.eff_uses, aliases: st.aliases,
               clause_resume: st.clause_resume, op_eff_arities: st.op_eff_arities,
               ret_ty: st.ret_ty, type_aliases: st.type_aliases, op_to_eff: st.op_to_eff, proto_impls: st.proto_impls, sums: st.sums, diags: st.diags, deferred_fields: st.deferred_fields, op_payload_labels: st.op_payload_labels, op_res: st.op_res, in_clause: st.in_clause }

# lookup the recorded first-use line/col of an effect label.
# Returns (-1, -1) when the effect was never tracked — that should
# only happen when the row was set via st_set_row from outside, in
# which case the caller falls back to the function's decl span.
fn lookup_eff_use(uses: [EffUse], target: String) : EffUse {
  match uses {
    [] -> EU(target, -1, -1)
    [u, ...rest] -> match u {
      EU(name, _, _) -> if name == target { u } else { lookup_eff_use(rest, target) }
    }
  }
}

# Half-open range [lo, hi) as a list of ints. Used to name the fresh
# TyVarT ids minted by one call-site's instantiation.
fn range_ids_loop(i: Int, hi: Int, acc: [Int]) : [Int] {
  if i >= hi { list_reverse(acc) }
  else { range_ids_loop(i + 1, hi, [i, ...acc]) }
}

fn range_ids(lo: Int, hi: Int) : [Int] = range_ids_loop(lo, hi, [])

fn ty_res(st: InferState, t: Ty) : TyRes = TyRes { st: st, ty: t }

fn mk_inferred(st: InferState, t: Ty, e: Expr) : Inferred =
  Inferred { st: st, ty: t, expr: e }

# Leaf expressions (literals, EVar, EUnder, EPlaceholder) have no
# sub-nodes to rebuild, so they annotate themselves in place.
fn inferred_leaf(st: InferState, t: Ty, e: Expr) : Inferred =
  mk_inferred(st, t, with_ty(e, t))

fn synth_byte_lit(st: InferState, n: Int, e: Expr) : Inferred / Console + File =
  if n >= 0 and n <= 255 { inferred_leaf(st, TyByte, e) }
  else {
    diag_error(st.file, e.line, e.col, "Byte literal out of range 0..255")
    inferred_leaf(st_bump_err(st), TyByte, e)
  }

fn st_fresh_ty(st: InferState) : TyRes {
  let n = st.env.fresh
  ty_res(st_set_env(st, fresh_var(st.env)), TyVarT(n))
}

fn st_unify(st: InferState, a: Ty, b: Ty, what: String, line: Int, col: Int) : InferState / Console + File + Mutable {


  match unify_env(st.env, a, b, st.sub) {
    Some(s2) -> st_set_sub(st, s2)
    None -> {
      let a1 = apply_ty(st.sub, a)
      let b1 = apply_ty(st.sub, b)
      # bounded subtyping for `T <: U` when `U`
      # is a `type U = A | B | ...` decl whose variants list contains
      # `T` as a component name. The upcast is the implicit promotion
      # described in `docs/unions-design.md` Decision 3 — a value of a
      # component type is usable wherever the union is expected. We
      # accept it after the symmetric `unify` failed, with no
      # substitution side-effects: the runtime layout is identical.
      if union_upcast_ok(st.env, a1, b1) { st }
      else {
        diag_error(st.file, line, col, "type mismatch in #{what}")
        emit_union_aware_notes(st.env, a1, b1)
        emit_type_hint(a1, b1)
        st_bump_err(st)
      }
    }
  }
}

# Template 1 — best-effort callee-name + argument-index
# augmentation for `type mismatch in function call`. Called after the
# generic `st_unify` has already emitted its error+notes; pinpoints
# which argument failed and surfaces the callee's signature.
#
# The callee may not be a bare name (it could be a higher-order
# expression or a method call), so name extraction is optional and
# we fall back to the generic message when nothing useful can be
# said.
fn callee_display_name(callee: Expr) : Option[String] {
  match callee.kind {
    EVar(n)        -> Some(n)
    EModCall(m, n) -> Some(string_concat(string_concat(m, "."), n))
    EField(_, f)   -> Some(f)
    _              -> None
  }
}

# Walk `callee_ty` and `arg_tys` in lockstep; return the 1-indexed
# position of the first argument whose type fails to unify against
# the corresponding parameter, or None if the mismatch is elsewhere
# (arity differs, or it's a return-type / row mismatch).
fn first_failing_arg(env: TyEnv, sub: Subst, callee_ty: Ty,
                       arg_tys: [Ty]) : Option[Int] / Mutable {
  match callee_ty {
    TyFnT(params, _ret, _row) -> {
      if list_length(params) == list_length(arg_tys) {
        first_failing_arg_loop(env, sub, params, arg_tys, 1)
      } else { None }
    }
    _ -> None
  }
}

fn first_failing_arg_loop(env: TyEnv, sub: Subst, params: [Ty],
                            args: [Ty], idx: Int) : Option[Int] / Mutable {
  match params {
    [] -> None
    [p, ...prest] -> match args {
      [] -> None
      [a, ...arest] -> {
        let p1 = apply_ty(sub, p)
        let a1 = apply_ty(sub, a)
        match unify_env(env, p1, a1, sub) {
          Some(_) -> first_failing_arg_loop(env, sub, prest, arest, idx + 1)
          None    -> if union_upcast_ok(env, p1, a1) {
            first_failing_arg_loop(env, sub, prest, arest, idx + 1)
          } else { Some(idx) }
        }
      }
    }
  }
}

# Emit Template 1 trailing notes — should be called when the generic
# unify has already errored. Suppresses if we cannot derive useful
# context (no callee name AND no resolvable signature).
fn emit_call_arg_notes(env: TyEnv, sub: Subst, callee: Expr,
                         callee_ty: Ty, arg_tys: [Ty]) : Unit / Console + Mutable {
  let resolved = apply_ty(sub, callee_ty)
  let name_opt = callee_display_name(callee)
  match first_failing_arg(env, sub, resolved, arg_tys) {
    Some(idx) -> {
      match name_opt {
        Some(nm) -> diag_note("in argument #{int_to_string(idx)} of `#{nm}`")
        None     -> diag_note("in argument #{int_to_string(idx)}")
      }
      match name_opt {
        Some(nm) -> match resolved {
          TyFnT(_, _, _) -> diag_note("`#{nm}` expects: #{inf_ty_to_string(resolved)}")
          _              -> ()
        }
        None -> ()
      }
    }
    None -> match name_opt {
      Some(nm) -> match resolved {
        TyFnT(_, _, _) -> diag_note("`#{nm}` expects: #{inf_ty_to_string(resolved)}")
        _              -> ()
      }
      None -> ()
    }
  }
}

# structured T1 Diagnostic builder. Mirrors the
# "type mismatch in function call" header that `st_unify` prints when
# `unify_list` fails, plus the trailing notes from `emit_call_arg_notes`.
# Pinned at the call-site (line, col); related infos cite the same span
# because the typer does not (yet) track per-argument spans.
fn build_call_type_mismatch_diag(env: TyEnv, sub: Subst, callee: Expr,
                                   callee_ty: Ty, arg_tys: [Ty],
                                   file: String, line: Int, col: Int) : Diagnostic / Mutable {
  let resolved = apply_ty(sub, callee_ty)
  let name_opt = callee_display_name(callee)
  let arg_notes = match first_failing_arg(env, sub, resolved, arg_tys) {
    Some(idx) -> match name_opt {
      Some(nm) -> [ri_note(file, line, col, "in argument #{int_to_string(idx)} of `#{nm}`")]
      None     -> [ri_note(file, line, col, "in argument #{int_to_string(idx)}")]
    }
    None -> []
  }
  let sig_notes = match name_opt {
    Some(nm) -> match resolved {
      TyFnT(_, _, _) -> [ri_note(file, line, col, "`#{nm}` expects: #{inf_ty_to_string(resolved)}")]
      _              -> []
    }
    None -> []
  }
  mk_diag(SevError, file, line, col,
          "type mismatch in function call",
          list_append(arg_notes, sig_notes))
}

# Template 4 — when the callee's resolved type is a fn with
# a different parameter count than the call site supplied, emit a
# canonical "wrong number of arguments" diagnostic in place of the
# generic "type mismatch in function call". The arity check runs as
# a preflight before `st_unify` so we never produce both diagnostics
# for the same site.
#
# `arg_tys` is the list of inferred argument types at the call site.
# `callee_ty` is the callee's instantiated function type (typically
# `TyFnT(params, ret, row)` after `apply_ty`). When the callee is
# polymorphic and not yet resolved to a `TyFnT`, we fall through to
# the generic path.
fn arity_mismatch_of(sub: Subst, callee_ty: Ty, arg_tys: [Ty]) : Option[Int] {
  match apply_ty(sub, callee_ty) {
    TyFnT(params, _ret, _row) -> {
      let np = list_length(params)
      let na = list_length(arg_tys)
      if np == na { None } else { Some(np) }
    }
    _ -> None
  }
}

# Emit Template 4 — wrong number of arguments. The callee's signature
# (when displayable) goes on a `note: \`fn\` expects: (T1, T2) -> R`
# line so users see exactly which arity was declared. When the callee
# is anonymous, the notes omit the name but still surface the param
# count + signature.
fn emit_wrong_arity(file: String, callee: Expr, callee_ty: Ty,
                      arg_tys: [Ty], line: Int, col: Int) : Unit / Console + File {

  let np = match callee_ty {
    TyFnT(params, _, _) -> list_length(params)
    _ -> 0
  }
  let na = list_length(arg_tys)
  let name_opt = callee_display_name(callee)
  match name_opt {
    Some(nm) -> diag_error(file, line, col, "wrong number of arguments to `#{nm}`")
    None     -> diag_error(file, line, col, "wrong number of arguments")
  }
  match name_opt {
    Some(nm) -> diag_note("`#{nm}` expects #{int_to_string(np)} argument(s), got #{int_to_string(na)}")
    None     -> diag_note("expected #{int_to_string(np)} argument(s), got #{int_to_string(na)}")
  }
  match name_opt {
    Some(nm) -> match callee_ty {
      TyFnT(_, _, _) -> diag_note("`#{nm}` expects: #{inf_ty_to_string(callee_ty)}")
      _              -> ()
    }
    None -> ()
  }
  if na < np {
    diag_help("add the missing argument(s) or use `_` as a placeholder hole")
  } else {
    diag_help("remove the extra argument(s) — `#{int_to_string(na - np)}` too many")
  }
}

# structured T4 Diagnostic builder. Mirrors the text emitted
# by `emit_wrong_arity` exactly so an LSP client can rebuild the same
# `error: / note: / help:` block from the collected value.
fn build_wrong_arity_diag(file: String, callee: Expr, callee_ty: Ty,
                            arg_tys: [Ty], line: Int, col: Int) : Diagnostic {
  let np = match callee_ty {
    TyFnT(params, _, _) -> list_length(params)
    _ -> 0
  }
  let na = list_length(arg_tys)
  let name_opt = callee_display_name(callee)
  let header = match name_opt {
    Some(nm) -> "wrong number of arguments to `#{nm}`"
    None     -> "wrong number of arguments"
  }
  let count_note = match name_opt {
    Some(nm) -> "`#{nm}` expects #{int_to_string(np)} argument(s), got #{int_to_string(na)}"
    None     -> "expected #{int_to_string(np)} argument(s), got #{int_to_string(na)}"
  }
  let sig_notes = match name_opt {
    Some(nm) -> match callee_ty {
      TyFnT(_, _, _) -> [ri_note(file, line, col, "`#{nm}` expects: #{inf_ty_to_string(callee_ty)}")]
      _              -> []
    }
    None -> []
  }
  let help_msg = if na < np {
    "add the missing argument(s) or use `_` as a placeholder hole"
  } else {
    "remove the extra argument(s) — `#{int_to_string(na - np)}` too many"
  }
  let related = list_append(
    [ri_note(file, line, col, count_note)],
    list_append(sig_notes, [ri_help(file, line, col, help_msg)])
  )
  mk_diag(SevError, file, line, col, header, related)
}

# Template 1 — wrapper around `st_unify` for call sites that
# want richer diagnostics. Preflights arity (Template 4) before
# delegating to `st_unify`; on failure, appends the argument-position
# + callee signature notes (Template 1) and the missing-effect notes
# (Template 5) when applicable.
fn st_unify_call(st: InferState, callee: Expr, callee_ty: Ty,
                   arg_tys: [Ty], expected_fn_ty: Ty,
                   line: Int, col: Int) : InferState / Console + File + Mutable {


  # Template 4 preflight: an arity mismatch produces a clearer
  # diagnostic than the generic "type mismatch in function call"
  # that `unify_list` would emit. We short-circuit so the caller's
  # error count still bumps and the rest of the pass keeps
  # progressing on the synthesised stub.
  let resolved_callee = apply_ty(st.sub, callee_ty)
  match arity_mismatch_of(st.sub, callee_ty, arg_tys) {
    Some(_np) -> {
      emit_wrong_arity(st.file, callee, resolved_callee, arg_tys, line, col)
      # T4 collected diagnostic.
      let d = build_wrong_arity_diag(st.file, callee, resolved_callee, arg_tys, line, col)
      st_bump_err(st_push_diag(st, d))
    }
    None -> {
      let pre_errs = st.errs
      let st1 = st_unify(st, callee_ty, expected_fn_ty, "function call", line, col)
      if st1.errs > pre_errs {
        emit_call_arg_notes(st1.env, st1.sub, callee, callee_ty, arg_tys)
        # T1 collected diagnostic. The header text mirrors
        # the generic "type mismatch in function call" line emitted by
        # `st_unify`; the related notes mirror `emit_call_arg_notes`.
        let d = build_call_type_mismatch_diag(st1.env, st1.sub, callee, callee_ty,
                                              arg_tys, st1.file, line, col)
        st_push_diag(st1, d)
      } else { st1 }
    }
  }
}


# when either side of a failed unification is a union
# (or a component of one), augment the generic `expected:` / `found:`
# notes with structural context — the union's component list and the
# found type's parent union, plus a concrete remediation hint. The
# plain notes still fire when neither side is union-flavoured.
fn emit_union_aware_notes(env: TyEnv, expected: Ty, found: Ty) : Unit / Console {
  diag_note("expected: #{inf_ty_to_string(expected)}")
  diag_note("found:    #{inf_ty_to_string(found)}")
  # Drill through matching wrappers (TyFn, TyCon-of-same-name with
  # mismatched args) to surface the first divergent TyCon pair. That
  # is where the union/component context is meaningful — at the
  # surface a function-shape mismatch hides whether the inner
  # divergence is a leaf-vs-leaf union upcast that almost-but-didn't
  # land.
  match find_mismatched_tycons(expected, found) {
    Some(pair) -> emit_union_focus_notes(env, pair.exp, pair.fnd)
    None       -> ()
  }
}

type TyConPair = { exp: Ty, fnd: Ty }

fn find_mismatched_tycons(expected: Ty, found: Ty) : Option[TyConPair] {
  match expected {
    TyFnT(eps, eret, _) -> match found {
      TyFnT(fps, fret, _) -> {
        match find_mismatch_in_list(eps, fps) {
          Some(p) -> Some(p)
          None    -> find_mismatched_tycons(eret, fret)
        }
      }
      _ -> tycon_pair_or_none(expected, found)
    }
    # Hanga Roa: same-name TyCons from different modules are a real
    # mismatch — flag them so the diagnostic can render the modules
    # and show the user the actual confusion.
    TyCon(em, en, eas) -> match found {
      TyCon(fm, fname, fas) -> if option_str_eq(em, fm) and en == fname {
        find_mismatch_in_list(eas, fas)
      } else {
        Some(TyConPair { exp: expected, fnd: found })
      }
      _ -> tycon_pair_or_none(expected, found)
    }
    _ -> tycon_pair_or_none(expected, found)
  }
}

fn find_mismatch_in_list(es: [Ty], fs: [Ty]) : Option[TyConPair] {
  match es {
    [] -> None
    [e, ...erest] -> match fs {
      [] -> None
      [f, ...frest] -> match find_mismatched_tycons(e, f) {
        Some(p) -> Some(p)
        None    -> find_mismatch_in_list(erest, frest)
      }
    }
  }
}

fn tycon_pair_or_none(expected: Ty, found: Ty) : Option[TyConPair] {
  match expected {
    TyCon(_, _, _) -> match found {
      TyCon(_, _, _) -> Some(TyConPair { exp: expected, fnd: found })
      _           -> None
    }
    _ -> None
  }
}

# Print the union-flavoured notes for a focused TyCon vs TyCon pair.
# Stays silent when neither side has union context — the caller has
# already emitted the generic expected/found notes, so no value in
# repeating them.
fn emit_union_focus_notes(env: TyEnv, expected: Ty, found: Ty) : Unit / Console {
  let exp_name = tycon_name_or_empty(expected)
  let fnd_name = tycon_name_or_empty(found)
  let exp_comps = if exp_name == "" { [] } else { variants_of_type(env, exp_name) }
  let fnd_comps = if fnd_name == "" { [] } else { variants_of_type(env, fnd_name) }
  let fnd_parents = if fnd_name == "" { [] } else { union_parents_of(env.unions, fnd_name) }
  match exp_comps {
    [] -> ()
    _  -> diag_note("union: `#{exp_name}` = #{inf_join_with(exp_comps, " | ")}")
  }
  match fnd_comps {
    [] -> match fnd_parents {
      [] -> ()
      [p, ..._rest] -> diag_note("`#{fnd_name}` is a component of `#{p}`")
    }
    _ -> diag_note("union: `#{fnd_name}` = #{inf_join_with(fnd_comps, " | ")}")
  }
  match exp_comps {
    [] -> ()
    _ -> match fnd_parents {
      [p, ..._rest] -> {
        if list_has(exp_comps, p) {
          # The expected union already lists the found's parent — so
          # the failure is the no-chains rule (D3 does not transit
          # through intermediate unions). Tell the user how to bridge.
          diag_help("the D3 upcast does not chain; lift through `#{p}` first (e.g. `let x: #{p} = ...`)")
        } else {
          diag_help("extend `#{exp_name}` to include `#{fnd_name}` (or its parent `#{p}`), or narrow via `match` before the call")
        }
      }
      # Found is itself a union (or a free TyCon with no parent).
      # Suggest the structural fix: include the found type, or narrow
      # via pattern matching at the call site.
      [] -> diag_help("extend `#{exp_name}` to include `#{fnd_name}`, or narrow via `match` before the call")
    }
  }
}

fn tycon_name_or_empty(t: Ty) : String {
  match t {
    TyCon(_, n, _) -> n
    _           -> ""
  }
}

# accept `expected = TyCon(None, U, [])` and
# `found = TyCon(None, T, [])` when `T` is registered as a variant of `U`
# in the env. This is the union-of-types upcast under the dual
# representation: `type U = A | B` adds `A` and `B` as
# zero-arg variants of `U`, so a value of type `A` lifts to `U`.
fn union_upcast_ok(env: TyEnv, expected: Ty, found: Ty) : Bool {
  match expected {
    TyCon(_, u_name, _) -> match found {
      TyCon(_, t_name, _) -> {
        let comps = variants_of_type(env, u_name)
        list_has(comps, t_name)
      }
      _ -> false
    }
    _ -> false
  }
}

# Known conversion pairs. `emit_type_hint(expected, found)` suggests
# a core helper that lifts `found` into `expected` (or vice versa)
# when the pair is one we already have a built-in for. Kept narrow
# on purpose: hints that nearly-always apply are the helpful ones.
fn emit_type_hint(expected: Ty, found: Ty) : Unit / Console {

  match expected {
    TyString -> match found {
      TyInt    -> diag_help("wrap the Int with `int_to_string(n)`")
      TyReal   -> diag_help("wrap the Real with `real_to_string(r)`")
      TyChar   -> diag_help("interpolate the Char into a String literal")
      _        -> ()
    }
    TyInt -> match found {
      TyString -> diag_help("parse with `string_to_int(s)` (returns Option[Int])")
      TyChar   -> diag_help("convert with `char_to_int(c)`")
      _        -> ()
    }
    TyReal -> match found {
      TyString -> diag_help("parse with `string_to_real(s)` (returns Option[Real])")
      _        -> ()
    }
    TyChar -> match found {
      TyInt -> diag_help("convert with `int_to_char(n)`")
      _     -> ()
    }
    TyCon(_, nm, _) -> {
      if nm == "Option" {
        diag_help("wrap the value with `Some(...)`, or use `None` if absent")
      } else { () }
    }
    _ -> ()
  }
}

# Wider instantiate result: also reports the fresh TyVarT ids that
# were minted to replace the scheme's bound vars. Those ids, run
# through the final substitution, give the call-site's concrete
# type arguments (M4b) and feed monomorphisation (M4c).
type TyInstRes = { st: InferState, ty: Ty, fresh: [Int], unit_fresh: [Int] }

fn st_instantiate(st: InferState, sc: TyScheme) : TyRes / Mutable {
  let r = st_instantiate_report(st, sc)
  ty_res(r.st, r.ty)
}

fn st_instantiate_report(st: InferState, sc: TyScheme) : TyInstRes / Mutable {
  match sc {
    Scheme(vars, rvars, uvars, ukinds, _) -> {
      let n = list_length(vars)
      let need = if n == 0 { 0 } else { max_id_loop(vars, 0) + 1 }
      let start = if st.env.fresh >= need { st.env.fresh } else { need }
      let inst = instantiate(st.env, sc)
      let fresh = range_ids(start, start + n)
      # also fresh-instantiate row vars. The temp substitution
      # rewrites each bound row-var id to a fresh one drawn from the
      # inferencer's row_fresh counter; we apply it once to the body
      # produced by `instantiate` (which rewrote type vars only) and
      # propagate the bumped row_fresh into the returned state.
      let st_env = st_set_env(st, inst.env)
      let mid = match rvars {
        [] -> TyInstRes { st: st_env, ty: inst.ty, fresh: fresh, unit_fresh: [] }
        _  -> {
          let frs = mk_fresh_row_subst(rvars, st_env.sub)
          let body1 = apply_ty(frs.temp, inst.ty)
          let st_out = st_set_sub(st_env, frs.sub)
          TyInstRes { st: st_out, ty: body1, fresh: fresh, unit_fresh: [] }
        }
      }
      # also fresh-instantiate unit-vars. Same shape as the
      # row-var step above but threaded through unit_slots.
      # capture the freshly-minted unit-var ids alongside
      # the type-var fresh ids so the call-site record can drive
      # per-unit specialisation downstream.
      match uvars {
        [] -> mid
        _  -> {
          let fus = mk_fresh_unit_subst(uvars, mid.st.sub)
          let body2 = apply_ty(fus.temp, mid.ty)
          # each fresh var inherits its scheme tparam's kind, so the
          # abelian pivot can refuse a cross-kind habitant bind.
          let sub2 = subst_add_unit_kinds(fus.sub, fus.fresh_ids, ukinds)
          let st_out2 = st_set_sub(mid.st, sub2)
          TyInstRes { st: st_out2, ty: body2, fresh: mid.fresh,
                      unit_fresh: fus.fresh_ids }
        }
      }
    }
  }
}

# Lexically scope a sub-walk: entries added during `inner` are dropped,
# but the fresh counter, substitution, record registry, and error
# counter propagate back to the caller.
fn st_restore_entries(outer: InferState, inner: InferState) : InferState =
  InferState {
    file: outer.file,
    env: TyEnv { entries: outer.env.entries, fresh: inner.env.fresh, unions: outer.env.unions, constructors: outer.env.constructors, head_owners: outer.env.head_owners, root_fns: outer.env.root_fns, row_kind: outer.env.row_kind, index: outer.env.index },
    core_len: outer.core_len,
    sub: inner.sub,
    recs: inner.recs,
    errs: inner.errs,
    insts: inner.insts,
    holes: inner.holes,
    row: inner.row,
    eff_uses: inner.eff_uses,
    aliases: outer.aliases,
    clause_resume: outer.clause_resume,
    op_eff_arities: outer.op_eff_arities,
    ret_ty: outer.ret_ty,
    type_aliases: outer.type_aliases,
    op_to_eff: outer.op_to_eff,
    proto_impls: outer.proto_impls,
    sums: outer.sums,
    diags: inner.diags,
    deferred_fields: inner.deferred_fields,
    op_payload_labels: inner.op_payload_labels,
    op_res: inner.op_res,
    in_clause: outer.in_clause
  }

# ---- parameter typing ----

fn param_ty_or_fresh(st: InferState, pm: Param) : TyRes {
  match pm.ptype {
    Some(te) -> ty_res(st, inf_resolve_ty(te))
    None     -> st_fresh_ty(st)
  }
}

fn param_ty_or_fresh_with_rvbinds(st: InferState, pm: Param, rbinds: [RVBind]) : TyRes =
  param_ty_or_fresh_with_binds(st, pm, [], rbinds)

# variant that also resolves type names against the fn-level
# tparams declared on the surrounding decl.
fn param_ty_or_fresh_with_binds(st: InferState, pm: Param,
                                tpbinds: [TPBind], rbinds: [RVBind]) : TyRes {
  match pm.ptype {
    Some(te) -> ty_res(st, resolve_ty_with_binds_rk(te, tpbinds, rbinds, st.env.row_kind))
    None     -> st_fresh_ty(st)
  }
}

# Add fn parameters to the type environment. Doesn't produce an Expr
# list (params aren't expressions), just the param types for later
# function-type construction.
type InferredParams = { st: InferState, tys: [Ty] }

fn add_infer_params_loop(st: InferState, ps: [Param], acc: [Ty]) : InferredParams {
  match ps {
    [] -> InferredParams { st: st, tys: list_reverse(acc) }
    [pm, ...rest] -> {
      let pr = param_ty_or_fresh(st, pm)
      let env2 = ty_env_add(pr.st.env, pm.pname, mono(pr.ty))
      let st2 = st_set_env(pr.st, env2)
      add_infer_params_loop(st2, rest, [pr.ty, ...acc])
    }
  }
}

fn add_infer_params(st: InferState, ps: [Param]) : InferredParams = add_infer_params_loop(st, ps, [])

# variant of `add_infer_params` that resolves param types
# under a row-variable binding context — used by `infer_decl` so the
# function body's view of every parameter type carries the same
# bound row-var ids that `fn_scheme_of_decl` chose for the scheme.
# The tpbinds half lets the body also see fn-level tparams as bound
# type variables (`fn id[T](x: T) : T = x`).
fn add_infer_params_with_binds_loop(st: InferState, ps: [Param],
                                    tpbinds: [TPBind], rbinds: [RVBind],
                                    acc: [Ty]) : InferredParams {
  match ps {
    [] -> InferredParams { st: st, tys: list_reverse(acc) }
    [pm, ...rest] -> {
      let pr = param_ty_or_fresh_with_binds(st, pm, tpbinds, rbinds)
      let env2 = ty_env_add(pr.st.env, pm.pname, mono(pr.ty))
      let st2 = st_set_env(pr.st, env2)
      add_infer_params_with_binds_loop(st2, rest, tpbinds, rbinds, [pr.ty, ...acc])
    }
  }
}

fn add_infer_params_with_binds(st: InferState, ps: [Param],
                               tpbinds: [TPBind], rbinds: [RVBind]) : InferredParams =
  add_infer_params_with_binds_loop(st, ps, tpbinds, rbinds, [])

fn add_infer_params_with_rvbinds(st: InferState, ps: [Param],
                                 rbinds: [RVBind]) : InferredParams =
  add_infer_params_with_binds(st, ps, [], rbinds)

# ---- record instantiation ----

type FTy = FT(String, Ty)

type RecInst = { st: InferState, result_ty: Ty, fields: [FTy] }

fn rec_tpbinds_loop(tps: [String], start: Int, i: Int, acc: [TPBind]) : [TPBind] {
  match tps {
    [] -> list_reverse(acc)
    [n, ...rest] -> rec_tpbinds_loop(rest, start, i + 1, [TPB(n, start + i), ...acc])
  }
}

fn rec_field_tys(fs: [FieldDecl], binds: [TPBind]) : [FTy] {
  match fs {
    [] -> []
    [f, ...rest] -> match f {
      FD(_, nm, te) -> [FT(nm, resolve_ty_with_tparams(te, binds)), ...rec_field_tys(rest, binds)]
    }
  }
}

fn fresh_tv_range_loop(start: Int, n: Int, i: Int, acc: [Ty]) : [Ty] {
  if i >= n { list_reverse(acc) }
  else { fresh_tv_range_loop(start, n, i + 1, [TyVarT(start + i), ...acc]) }
}

fn fresh_tv_range(start: Int, n: Int) : [Ty] = fresh_tv_range_loop(start, n, 0, [])

fn rec_instantiate(st: InferState, ri: RecInfo) : RecInst {
  match ri {
    # Hanga Roa: the resulting TyCon carries the RecInfo's
    # module_origin so the typer can distinguish, e.g.,
    # `tuple.Pair` (mo = Some("tuple")) from a user `type Pair`
    # in the root (mo = None). Without this both literals
    # would emit TyCon(None, "Pair", _) and unify spuriously.
    RI(nm, tps, fs, mo) -> {
      let start = st.env.fresh
      let n = list_length(tps)
      let env2 = advance_fresh(st.env, n)
      let binds = rec_tpbinds_loop(tps, start, 0, [])
      let flds = rec_field_tys(fs, binds)
      let atys = fresh_tv_range(start, n)
      RecInst {
        st: st_set_env(st, env2),
        result_ty: TyCon(mo, nm, atys),
        fields: flds
      }
    }
  }
}

fn fty_find_loop(fs: [FTy], target: String) : Option[Ty] {
  match fs {
    [] -> None
    [f, ...rest] -> match f {
      FT(nm, t) -> if nm == target { Some(t) } else { fty_find_loop(rest, target) }
    }
  }
}

fn fty_find(fs: [FTy], target: String) : Option[Ty] = fty_find_loop(fs, target)

fn fty_names(fs: [FTy]) : [String] = fty_names_loop(fs, [])

fn fty_names_loop(fs: [FTy], acc: [String]) : [String] {
  match fs {
    [] -> list_reverse(acc)
    [f, ...rest] -> match f {
      FT(nm, _) -> fty_names_loop(rest, [nm, ...acc])
    }
  }
}

fn field_hint(fs: [FTy], target: String) : String {
  match closest_name(target, fty_names(fs)) {
    Some(sug) -> " (did you mean `.#{sug}`?)"
    None      -> ""
  }
}

# ---- the walker ----

fn synth(st: InferState, e: Expr) : Inferred / Console + File + Mutable {


  match e.kind {
    EInt(_)        -> inferred_leaf(st, TyInt, e)
    # A suffix-tagged literal (`42i32`, `7u8`) carries its width type in
    # the node itself; that type IS the literal's type. Byte is the one
    # width whose range check the parser defers here.
    EFixed(span, ty) -> match ty {
      TyByte -> synth_byte_lit(st, decode_int(span), e)
      _      -> inferred_leaf(st, ty, e)
    }
    EReal(_, _)       -> inferred_leaf(st, TyReal, e)
    # A past-i64 integer literal with no concrete carrier in context is
    # out of range — the `n`/`bigint.from_string` escape hatch is named.
    EIntLit(span)  -> synth_lit_mint_or_err(st, e, EIntLit(span))
    # A `d`-suffixed literal always targets `Decimal`; the suffix
    # supplies the carrier locally, so mint it with no expected type.
    EDecimalLit(_) -> synth_lit_mint_or_err(st, e, e.kind)
    EBool(_)       -> inferred_leaf(st, TyBool, e)
    EChar(_)       -> inferred_leaf(st, TyChar, e)
    EStr(_, _)     -> inferred_leaf(st, TyString, e)
    EUnit          -> inferred_leaf(st, TyUnit, e)
    EUnder         -> inferred_leaf(st, TyAny, e)
    # a `.` placeholder that survives parsing in a
    # non-argument position is a hard error per
    # `docs/kaikai-minimal.md` §"Placeholder rules". The argument-
    # position desugar (`desugar_placeholder_arg`) wraps every
    # call-arg subtree containing a `.` into a unary lambda before
    # the typer ever sees it; reaching this arm means the user
    # wrote `.` outside that sugar.
    EPlaceholder   -> {
      diag_error(st.file, e.line, e.col,
        "`.` placeholder used outside lambda-expected position; use a named arrow `(x) => ...`")
      inferred_leaf(st_bump_err(st), TyAny, e)
    }
    # `resume` reaching the value-position read arm (call-position
    # `resume(...)` is intercepted by `try_resume_call` upstream) means it
    # escapes its clause as a first-class value — `let k = resume`,
    # `f(resume)`. The continuation has no value representation outside its
    # clause, so reject it cleanly (docs/effects.md).
    EVar(nm) ->
      if nm == "resume" and st.in_clause {
        diag_error(st.file, e.line, e.col,
          "`resume` may only be called, not used as a value: it cannot escape its handler clause")
        diag_help("call the continuation directly, e.g. `resume(v)`")
        inferred_leaf(st_bump_err(st), TyAny, e)
      } else { match ty_env_lookup(st.env, nm) {
        Some(sc) -> {
          let r = st_instantiate_report(st, sc)
          let st2 = if r.fresh == [] and r.unit_fresh == [] {
            r.st
          } else {
            st_push_inst(r.st, CS(nm, e.line, e.col, r.fresh, r.unit_fresh, None))
          }
          inferred_leaf(st2, r.ty, e)
        }
        None     -> inferred_leaf(st, TyAny, e)
      } }
    ECall(callee, args_)       -> synth_call(st, callee, args_, e.line, e.col)
    EField(obj, fnm)           -> synth_field(st, obj, fnm, e.line, e.col)
    EIndex(coll, ix)           -> synth_index(st, coll, ix, e.line, e.col)
    EBinop(op, l, r)           -> synth_binop(st, op, l, r, e.line, e.col)
    EUnop(op, x)               -> synth_unop(st, op, x, e.line, e.col)
    EIf(c, t_, eo)             -> synth_if(st, c, t_, eo, e.line, e.col)
    EMatch(scr, arms)          -> synth_match(st, scr, arms, e.line, e.col)
    ELambda(ps, body)          -> synth_lambda(st, ps, body, e.line, e.col)
    ERecordLit(nm, fis)        -> synth_record_lit(st, nm, fis, e.line, e.col)
    EList(els)                 -> synth_list_expr(st, els, e.line, e.col)
    ERange(lo, hi, stp)        -> synth_range(st, lo, hi, stp, e.line, e.col)
    EBlock(stmts, tail)        -> synth_block(st, stmts, tail, e.line, e.col)
    EPipe(lhs, rhs)            -> synth_pipe(st, lhs, rhs, e.line, e.col)
    EMapPipe(lhs, rhs)         -> synth_map_pipe(st, lhs, rhs, e.line, e.col)
    EFlatMapPipe(lhs, rhs)     -> synth_flat_map_pipe(st, lhs, rhs, e.line, e.col)
    EFilterPipe(lhs, rhs)      -> synth_filter_pipe(st, lhs, rhs, e.line, e.col)
    EHole(nm_opt)              -> synth_hole(st, nm_opt, e)
    ETodo(msg)                 -> synth_todo(st, msg, e)
    EExternBody(_)             -> synth_extern_body(st, e)
    EBang(inner)               -> synth_bang(st, inner, e.line, e.col)
    EHandle(_, _, _, _, _, _, _) -> synth_handle(st, e)
    # numeric literal with a unit annotation. The inner Expr is
    # always EInt or EReal; the literal's type is `TyDimT(base, u)`
    # where base is TyInt or TyReal and u is the canonical unit.
    ELitUnit(inner, u) -> synth_lit_unit(st, inner, u, e.line, e.col)
    # `variants[T]()`. Validate T is a sum type with
    # nullary-only variants, stamp the result with `[T]` (TyListT),
    # and bake the resolved variant names into the AST so codegen
    # has them without re-walking the env. Errors yield a TyAny
    # stub so cascade is graceful.
    EVariantsOf(ty_expr, _) -> synth_variants_of(st, ty_expr, e)
    # A loop intrinsic types exactly as the combinator call it replaced:
    # arg 0 is the original callee, so delegating to `synth_call` gives
    # the same scheme lookup, lambda checking, and row join. The stamped
    # pieces are re-wrapped; a non-call rewrite (e.g. a dispatch rewrite
    # that changes the node shape) falls back to the rewritten call,
    # dropping the intrinsic rather than guessing at its semantics.
    #
    # Any other `$<name>(args)` reaching `synth` is an error. The
    # clause-body path that legitimately admits `$extern_handler`
    # short-circuits before reaching this arm.
    EIntrinsic(nm, args_) ->
      if is_loop_intrinsic(nm) {
        match args_ {
          [callee, ...rest] -> {
            let r = synth_call(st, callee, rest, e.line, e.col)
            match r.expr.kind {
              ECall(callee2, rest2) ->
                Inferred { st: r.st, ty: r.ty,
                           expr: Expr { kind: EIntrinsic(nm, [callee2, ...rest2]),
                                        line: e.line, col: e.col,
                                        ty: r.expr.ty, mode: r.expr.mode } }
              _ -> r
            }
          }
          _ -> {
            diag_error(st.file, e.line, e.col,
              concat_all(["compiler intrinsic `$", nm, "` has a malformed argument list"]))
            inferred_leaf(st_bump_err(st), TyAny, e)
          }
        }
      } else {
        diag_error(st.file, e.line, e.col,
          concat_all(["compiler intrinsic `$", nm,
                      "` is not valid in this position"]))
        inferred_leaf(st_bump_err(st), TyAny, e)
      }
    # qualified call. rqc rewrites
    # `EField(EVar(mod), fname)` to `EModCall(mod, fname)` after
    # checking `fname` is in `mod`'s exports. Module fns register
    # under both the bare `fname` and a `<mod>::<fname>` key
    # (`add_decls_loop`); we consult the qualified key first so
    # two modules exporting the same name resolve unambiguously
    # to their declaring module instead of shadowing via insert
    # order. Bare lookup remains as a fallback for legacy
    # core-only schemes (`add_core_sigs`) that do not flow
    # through `add_decls_loop` and therefore have no qualified
    # entry.
    EModCall(m, fname) -> {
      let scheme_opt = match ty_env_lookup_qualified(st.env, m, fname) {
        Some(sc) -> Some(sc)
        None     -> ty_env_lookup(st.env, fname)
      }
      match scheme_opt {
        Some(sc) -> {
          let r = st_instantiate_report(st, sc)
          let st2 = if r.fresh == [] and r.unit_fresh == [] {
            r.st
          } else {
            st_push_inst(r.st, CS(fname, e.line, e.col, r.fresh, r.unit_fresh, None))
          }
          inferred_leaf(st2, r.ty, e)
        }
        None -> {
          # Should not happen — rqc only rewrites when fname is in
          # the module's exports. If we land here, the table and the
          # decl stream got out of sync; surface as a diagnostic
          # rather than a panic so the user sees a concrete location.
          diag_error(st.file, e.line, e.col,
            concat_all(["module '", m, "' does not export '", fname,
                        "' at the typer (rqc / TyEnv mismatch — internal)"]))
          inferred_leaf(st_bump_err(st), TyAny, e)
        }
      }
    }
  }
}

# type `variants[T]()` and validate T's shape.
# Constraints:
#   * T resolves to a TyCon (a named user-declared sum type).
#   * Every variant of T must be nullary (no payload).
# The first failure yields a single error; subsequent calls fall
# through to the TyAny stub so we don't cascade noise from one
# misuse.
fn synth_variants_of(st: InferState, ty_expr: TypeExpr, e: Expr) : Inferred / Console + File {


  let ty = inf_resolve_ty(ty_expr)
  match ty {
    TyCon(_, name, _) -> {
      let vc = check_variants_nullary(st.env, name)
      match vc {
        VCOk(names) -> {
          # Re-stamp the AST node with the resolved names so codegen
          # has them without re-walking the env. Result type is
          # `[T]` (TyListT of TyCon).
          # walker may visit both qualified
          # `<target>::<cname>` and bare `<cname>` entries that both
          # collapse to the same bare ctor name. Dedup before
          # emitting so `variants[Suit]()` returns each tag once.
          let names_dedup = union_merge_unique([], names)
          let result_ty = TyListT(TyCon(None, name, []))
          let resolved = with_ty(
            mk_expr(EVariantsOf(ty_expr, names_dedup), e.line, e.col),
            result_ty)
          mk_inferred(st, result_ty, resolved)
        }
        VCNotSum -> {
          diag_error(st.file, e.line, e.col,
            "`variants[T]()` requires T to be a declared sum type")
          diag_note("type: #{inf_ty_to_string(ty)}")
          diag_help("declare T as `type T = A | B | ...` or use a different builtin")
          inferred_leaf(st_bump_err(st), TyAny, e)
        }
        VCHasPayload(bad) -> {
          let bad_list = inf_join_with(bad, ", ")
          diag_error(st.file, e.line, e.col,
            "`variants[T]()` requires every variant of T to be nullary")
          diag_note("variants of `#{name}` with payload: #{bad_list}")
          diag_help("`variants[T]()` lists the inhabitants of a closed sum; this is ill-defined when a variant carries arguments")
          inferred_leaf(st_bump_err(st), TyAny, e)
        }
      }
    }
    _ -> {
      diag_error(st.file, e.line, e.col,
        "`variants[T]()` requires T to be a named user type")
      diag_note("type: #{inf_ty_to_string(ty)}")
      diag_help("T must be a `type T = A | B | ...` declaration; built-ins (Int, String, [a], etc.) are not supported")
      inferred_leaf(st_bump_err(st), TyAny, e)
    }
  }
}

# synth a literal annotated with a unit. Unit aliases were
# expanded by the resolver before the typer ever sees them; here we
# only canonicalise (sort/group) and stamp the dimensioned type onto
# the rebuilt expression node.
fn synth_lit_unit(st: InferState, inner: Expr, u: UnitExprT, line: Int, col: Int) : Inferred / Console + File + Mutable {


  let ri = synth(st, inner)
  let base = apply_ty(ri.st.sub, ri.ty)
  let canon_u = unit_canon(u)
  let ty = dim_collapse(base, canon_u)
  let root = with_ty(mk_expr(ELitUnit(ri.expr, canon_u), line, col), ty)
  mk_inferred(ri.st, ty, root)
}

# type-check `handle { body } with Eff [as alias] {
# clauses }`. The body is walked under a fresh row accumulator;
# the named effect is filtered out of whatever the body
# accumulates, and the remainder merges back into the outer
# function's row. Clause bodies and the optional return clause
# are not type-checked against the op signatures here, and alias
# resolution (`Eff as log`) is not handled here.
fn synth_handle(st: InferState, e: Expr) : Inferred / Console + File + Mutable {


  match e.kind {
    EHandle(body, eff_name, eff_tyargs, init_opt, alias_opt, clauses, ret_opt) -> {
      # type-check the init expression in the outer scope.
      # The init's inferred type IS the handler-state type — it is
      # propagated into the clauses so `state` / `log` and 2-arg
      # `resume(v, ns)` are typed precisely (no TyAny escape).
      let init_typed_st = match init_opt {
        Some(ie) -> {
          let ri = synth(st, ie)
          let ity = apply_ty(ri.st.sub, ri.ty)
          IT { st: ri.st, init_opt: Some(ri.expr), state_ty: Some(ity) }
        }
        None -> IT { st: st, init_opt: None, state_ty: None }
      }
      # alias rebinds the capability inside the body.
      let st_aliased = match alias_opt {
        Some(a) -> st_push_alias(init_typed_st.st, a, eff_name)
        None    -> init_typed_st.st
      }
      # when a stateful handler omits the explicit `[T]`
      # instantiation but supplies an `(init)`, infer the single
      # type argument from the init's type. This is the path for the
      # unannotated `var x = init` desugar:
      # `with State(init) as x { ... }` resolves to
      # `State[type_of_init]`. The fallback only fires when no syntactic
      # type args were written, so explicit `with State[Int](0)` still
      # round-trips verbatim.
      let resolved_eff_tyargs = match eff_tyargs {
        [] -> match init_typed_st.state_ty {
          Some(t) -> [t]
          None    -> []
        }
        _ -> inf_resolve_ty_list(eff_tyargs)
      }
      # A `with Eff as a` binding makes `a` a first-class capability value of
      # type `Eff[ty_args]` so it can be passed as a call argument (§6 named
      # instances). The capability type IS the effect's nominal type — no
      # `Handler[E]` wrapper (HKT stays banned). The alias entry on st.aliases
      # still drives op dispatch inside the handle body; this env binding is what
      # lets `a` cross into `f(a)` and type against a `c: Eff` parameter.
      # The capability type carries only the effect's own tparams, not the
      # handler's full state type: a non-parametric `Cell` is `TyCon("Cell", [])`
      # even when `with Cell(0)` infers an Int state. Truncating to the effect's
      # tparam arity makes the binding unify with a `c: Cell` parameter.
      let cap_arity = eff_tparam_arity(st_aliased.op_eff_arities, eff_name)
      let cap_tyargs = take_first_tys(resolved_eff_tyargs, cap_arity)
      let st_capbound = match alias_opt {
        Some(a) -> st_set_env(st_aliased,
                     ty_env_add(st_aliased.env, a, mono(TyCon(None, eff_name, cap_tyargs))))
        None    -> st_aliased
      }
      let prev_row = st_capbound.row
      let st_in = st_set_row(st_capbound, [])
      let rb = synth(st_in, body)
      # filter out *only* the labels whose ty_args unify with
      # the handler's instantiation. Labels with the same eff name but
      # non-unifiable ty_args remain and propagate to the outer row —
      # they need their own enclosing handler.
      # a `with State as i` handler discharges `State@i`
      # labels symmetrically with `label_eff_with_alias`, leaving a
      # sibling `State@go` cell for its own handler; an unaliased handler
      # (`alias_opt = None`) discharges bare `State`, unchanged. The
      # discharge binds the cell's type via `unify_list`, so thread the
      # resulting substitution into the handler's output state (all reads
      # of the cell converge on the handler's instantiation).
      # Discharge against the effect's own tparam tyargs (truncated to its
      # arity), not the full handler state type — a non-parametric `Cell` op
      # carries a `[]` label even when `with Cell(0)` infers an Int state, so
      # matching against `[Int]` would leave the label undischarged.
      let discharge_eff = label_eff_with_alias(eff_name, alias_opt)
      let filt = filter_labels_matching_res(rb.st.row, discharge_eff,
                                              cap_tyargs, rb.st.sub)
      let body_row_minus = filt.kept
      let rb_st1 = st_set_sub(rb.st, filt.sub)
      let merged = merge_label_lists(prev_row, body_row_minus, rb_st1.sub)
      let st_out0 = st_set_row(rb_st1, merged)
      let st_out1 = match alias_opt { Some(_) -> st_pop_alias(st_out0) None -> st_out0 }
      # verify `with <Eff>` names a known effect. When
      # `Eff` is unknown the body's labels still flow up via the
      # filter-and-merge step above (so a downstream "effect not
      # handled" still fires for what the body actually performs),
      # but we surface the parse-level mistake directly so the user
      # does not chase a "unknown op X on effect Y" cascade.
      let st_out_eff = check_handle_effect_known(st_out1, eff_name, e.line, e.col)
      # every clause name must be a declared op of `eff_name`.
      let st_out2 = check_clause_names(st_out_eff, eff_name, clauses, e.line, e.col)
      let stateful = match init_opt { Some(_) -> true None -> false }
      let cs_typed = check_clauses_types(st_out2, eff_name, clauses,
                                          stateful, init_typed_st.state_ty,
                                          resolved_eff_tyargs)
      let r_typed = check_return_clause_opt(cs_typed.st, ret_opt, rb.ty,
                                             stateful, init_typed_st.state_ty)
      let new_e = with_ty(
        mk_expr(EHandle(rb.expr, eff_name, eff_tyargs, init_typed_st.init_opt,
                         alias_opt, cs_typed.clauses, r_typed.ret_opt),
                e.line, e.col),
        r_typed.ty)
      mk_inferred(r_typed.st, r_typed.ty, new_e)
    }
    _ -> mk_inferred(st, TyAny, with_ty(e, TyAny))
  }
}

# thread an init's typed sub-expression and resolved
# handler-state type alongside the inferred state.
type IT = { st: InferState, init_opt: Option[Expr], state_ty: Option[Ty] }

type RetTyped = { st: InferState, ty: Ty, ret_opt: Option[HReturn] }

fn check_return_clause_opt(st: InferState, ret_opt: Option[HReturn],
                           body_ty: Ty, stateful: Bool,
                           state_ty: Option[Ty]) : RetTyped / Console + File + Mutable {


  match ret_opt {
    None    -> RetTyped { st: st, ty: body_ty, ret_opt: None }
    Some(r) -> match r {
      HR(pname, rexpr, line, col) -> {
        let outer = st
        let env1 = ty_env_add(st.env, pname, mono(body_ty))
        # `state` / `log` get the actual handler-state type
        # in the return clause so `return(x) -> (x, state)` types as
        # `(body_ty, state_ty)`.
        let sty = match state_ty { Some(t) -> t None -> TyAny }
        let env2 =
          if stateful {
            ty_env_add(ty_env_add(env1, "state", mono(sty)),
                       "log", mono(sty))
          } else { env1 }
        let st1 = st_set_env(st, env2)
        # (Option A): same alias-tag boundary as the
        # op clauses — the return clause also compiles to a
        # separate C function with no access to outer
        # `kai_alias_<a>_id` C locals.
        let st1_no_tag = st_disable_alias_tag(st1)
        let rr = synth(st1_no_tag, rexpr)
        let st_out = st_restore_entries(outer, rr.st)
        let ty = apply_ty(st_out.sub, rr.ty)
        RetTyped { st: st_out, ty: ty, ret_opt: Some(HR(pname, rr.expr, line, col)) }
      }
    }
  }
}

# type-check each handler clause body under an env that
# binds the op's args and `resume`. The trailing param is `resume`
# by surface convention; the rest map positionally to the op's
# declared parameter types. If the clause's arity does not match
# the op's signature we fall back to fresh tyvars for any unbound
# slot — clause-arity validation is a separate diagnostic-baseline
# task.
type ClausesTyped = { st: InferState, clauses: [HClause] }

fn check_clauses_types(st: InferState, eff_name: String, cs: [HClause],
                        stateful: Bool, state_ty: Option[Ty],
                        eff_tyargs: [Ty]) : ClausesTyped / Console + File + Mutable =


  check_clauses_types_loop(st, eff_name, cs, stateful, state_ty, eff_tyargs, [])

fn check_clauses_types_loop(st: InferState, eff_name: String, cs: [HClause],
                             stateful: Bool, state_ty: Option[Ty],
                             eff_tyargs: [Ty], acc: [HClause]) : ClausesTyped / Console + File + Mutable {


  match cs {
    [] -> ClausesTyped { st: st, clauses: list_reverse(acc) }
    [c, ...rest] -> match c {
      HC(op_name, params, body, line, col) -> {
        let outer = st
        # clause shape: the clause's positional parameter
        # count must equal the op's declared arity plus one (the
        # trailing `resume`). Without this check `print_io(s) -> 0`
        # (missing resume) or `print_io(a, b, c, resume) -> resume(())`
        # (too many user params for a single-param op) type-check
        # silently; the downstream C emitter then produces ill-formed
        # function pointers. Validation is gated on a known op scheme
        # so the unknown-op path keeps its dedicated diagnostic in
        # check_clause_names instead of layering an arity error on top.
        let st_arity = check_clause_arity(st, eff_name, op_name, params, line, col)
        # bind the clause params and unify the op's
        # effect-tparam tyvars with the handler's instantiation, so
        # the answer type is concrete (e.g., `Int` for State.get under
        # `with State[Int]`). `st.clause_resume` is then set with the
        # concrete answer/state types so `resume(v)` / `resume(v, ns)`
        # are typechecked precisely.
        let bind_res = bind_clause_env_typed(st_arity, eff_name, op_name, params,
                                              stateful, state_ty, eff_tyargs)
        let sty = match state_ty { Some(t) -> t None -> TyAny }
        let env_bound = bind_res.st.env
        let env_with_sl =
          if stateful {
            ty_env_add(ty_env_add(env_bound, "state", mono(sty)),
                       "log", mono(sty))
          } else { env_bound }
        let st_env = st_set_env(bind_res.st, env_with_sl)
        let answer_resolved = apply_ty(st_env.sub, bind_res.answer_ty)
        let st_resume = if stateful {
          match state_ty {
            Some(sv) -> st_set_clause_resume(st_env,
              Some(RB(answer_resolved, sv)))
            None -> st_env
          }
        } else { st_env }
        # (Option A): a clause body compiles to a
        # separate C function and `filter_clause_captures` strips
        # the `__alias_id__<a>` sentinels that would otherwise
        # thread an outer-bound capability's handler id into the
        # clause env. Disable alias tagging across the clause
        # body so op calls on those caps emit a bare dispatch key
        # (legacy name-keyed lookup) instead of the tagged form
        # that requires a `kai_alias_<a>_id` C local that is not
        # in scope here. Same boundary the rewrite-pass enforces
        # in `rewrite_alias_clause`.
        let st_clause_in = st_set_in_clause(st_disable_alias_tag(st_resume), true)
        let rb = synth(st_clause_in, body)
        let st_out0 = st_restore_entries(outer, rb.st)
        let st_out = st_set_clause_resume(st_out0, outer.clause_resume)
        # keep the typed body so the
        # alias-aware op resolution that fired inside `synth` (e.g.
        # rewriting `Console.print(...)` to `EVar("Stdout.print")`)
        # actually reaches the emit phase. Returning only `st` and
        # discarding `rb.expr` was the bug behind the `kai_Console`
        # leak in `demos/concurrent` — handler-clause bodies kept the
        # original `EField(EVar("Console"), "print")` shape.
        let new_clause = HC(op_name, params, rb.expr, line, col)
        check_clauses_types_loop(st_out, eff_name, rest, stateful, state_ty,
                                  eff_tyargs, [new_clause, ...acc])
      }
    }
  }
}

# bind clause params; also returns the answer type recovered
# from the op's instantiated signature so the caller can build a
# precise resume binding. The op's effect-tparam fresh tyvars are
# unified with `eff_tyargs` (the handler's `with Eff[T1, T2]`
# instantiation) so the answer type is concrete when the handler is
# instantiated to concrete types.
type ClauseBindRes = { st: InferState, answer_ty: Ty }

fn bind_clause_env_typed(st: InferState, eff_name: String, op_name: String,
                          params: [Param], stateful: Bool,
                          state_ty: Option[Ty], eff_tyargs: [Ty]) : ClauseBindRes / Console + File + Mutable {


  let key = string_concat(eff_name, string_concat(".", op_name))
  match ty_env_lookup(st.env, key) {
    None     -> ClauseBindRes { st: bind_params_lenient(st, params), answer_ty: TyAny }
    Some(sc) -> {
      let inst = st_instantiate_report(st, sc)
      # unify the op-scheme's effect-tparam fresh tyvars
      # with the handler's instantiation. For State[Int], `get`'s
      # bound `?Tfresh` becomes `Int`, so the resume answer type is
      # `Int` rather than a free tyvar.
      let st_unified = unify_eff_tparams(inst.st, inst.fresh, eff_tyargs,
                                          op_name)
      match inst.ty {
        TyFnT(arg_tys, ret_ty, _) -> {
          let bound = bind_params_with_sig_typed(st_unified, params, arg_tys, ret_ty,
                                                   stateful, state_ty)
          ClauseBindRes { st: bound, answer_ty: ret_ty }
        }
        _ -> ClauseBindRes { st: bind_params_lenient(st_unified, params), answer_ty: TyAny }
      }
    }
  }
}

# Unify each effect-tparam fresh tyvar (from the op's polymorphic
# scheme) with the corresponding handler instantiation type. Length
# mismatch is silent — the row-level arity check has already reported
# that error.
fn unify_eff_tparams(st: InferState, fresh: [Int], tys: [Ty],
                      op_name: String) : InferState / Console + File + Mutable {


  match fresh {
    [] -> st
    [id, ...frest] -> match tys {
      [] -> st
      [t, ...trest] -> {
        let st1 = st_unify(st, TyVarT(id), t,
                            string_concat("clause op tparam in ", op_name),
                            -1, -1)
        unify_eff_tparams(st1, frest, trest, op_name)
      }
    }
  }
}

fn bind_params_with_sig_typed(st: InferState, params: [Param], arg_tys: [Ty],
                                ret_ty: Ty, stateful: Bool,
                                state_ty: Option[Ty]) : InferState {
  match params {
    []      -> st
    [last]  -> bind_resume_param_typed(st, last, ret_ty, stateful, state_ty)
    [p, ...rest] -> match arg_tys {
      []           -> bind_params_lenient(st, params)
      [a, ...rest_a] -> {
        let env1 = ty_env_add(st.env, p.pname, mono(a))
        bind_params_with_sig_typed(st_set_env(st, env1), rest, rest_a, ret_ty,
                                     stateful, state_ty)
      }
    }
  }
}

# stateless clauses bind `resume : (answer_ty) -> ?fresh`.
# Stateful clauses still bind `resume` to mono(TyAny) at the env
# level (so name lookup succeeds and arity errors don't surface as
# "unknown identifier"); the actual precise typing of `resume(v)` and
# `resume(v, ns)` is performed by synth_call's special-case using the
# st.clause_resume binding pushed by check_clauses_types.
fn bind_resume_param_typed(st: InferState, p: Param, ret_ty: Ty,
                            stateful: Bool, state_ty: Option[Ty]) : InferState {
  if stateful {
    st_set_env(st, ty_env_add(st.env, p.pname, mono(TyAny)))
  } else {
    let f = st_fresh_ty(st)
    let resume_ty = TyFnT([ret_ty], f.ty, inf_row_empty())
    st_set_env(f.st, ty_env_add(f.st.env, p.pname, mono(resume_ty)))
  }
}

fn bind_params_lenient(st: InferState, params: [Param]) : InferState {
  match params {
    []      -> st
    [p, ...rest] -> {
      let f = st_fresh_ty(st)
      let env1 = ty_env_add(f.st.env, p.pname, mono(f.ty))
      bind_params_lenient(st_set_env(f.st, env1), rest)
    }
  }
}

fn check_handle_effect_known(st: InferState, eff: String,
                              line: Int, col: Int) : InferState / Console + File {
  if is_effect_in_env(st.env, eff) { st }
  else {
    let header = string_concat("unknown effect in `with`: `",
      string_concat(eff, "`"))
    diag_error(st.file, line, col, header)
    diag_note("`handle { ... } with #{eff} { ... }` references an undeclared effect")
    diag_help("either `effect #{eff} { ... }` it, or correct the name to a declared effect")
    st_bump_err(st)
  }
}

fn check_clause_names(st: InferState, eff: String, cs: [HClause],
                      line: Int, col: Int) : InferState / Console + File {


  match cs {
    [] -> st
    [c, ...rest] -> match c {
      HC(name, _, _, cline, ccol) -> {
        let key = string_concat(eff, string_concat(".", name))
        match ty_env_lookup(st.env, key) {
          Some(_) -> check_clause_names(st, eff, rest, line, col)
          None -> {
            diag_error(st.file, cline, ccol,
              string_concat("unknown op `",
                string_concat(name,
                  string_concat("` on effect `",
                    string_concat(eff, "`")))))
            diag_note("handler clauses must match an op declared in `effect #{eff} { ... }`")
            diag_help("either remove this clause, or add `#{name}(...)` to the effect declaration")
            check_clause_names(st_bump_err(st), eff, rest, line, col)
          }
        }
      }
    }
  }
}

# verify a handler clause's positional parameter count
# matches the op signature plus one for `resume`. Unknown ops fall
# through (None branch): `check_clause_names` already reports those
# and stacking an arity error would be confusing. The op scheme's
# fn arg-tys count is the user-declared arity; the clause body
# binds the user params positionally and the trailing param as
# `resume`, so the expected clause-side count is `arg_tys.length + 1`.
# We read the arg-tys length directly off the scheme's body — no
# instantiation needed for an arity-only check.
fn check_clause_arity(st: InferState, eff_name: String, op_name: String,
                       params: [Param], line: Int, col: Int) : InferState / Console + File {
  let key = string_concat(eff_name, string_concat(".", op_name))
  match ty_env_lookup(st.env, key) {
    None     -> st
    Some(sc) -> match sc {
      Scheme(_, _, _, _, body) -> match body {
        TyFnT(arg_tys, _, _) -> {
          let expected = list_length(arg_tys) + 1
          let got = list_length(params)
          if got == expected { st }
          else {
            let header = string_concat("handler clause `",
              string_concat(op_name,
                string_concat("` has wrong arity for effect `",
                  string_concat(eff_name, "`"))))
            diag_error(st.file, line, col, header)
            let n1 = "`#{eff_name}.#{op_name}` declares #{int_to_string(expected - 1)} parameter(s); the clause must take those plus a trailing `resume`, for a total of #{int_to_string(expected)}"
            let n2 = "got #{int_to_string(got)} clause parameter(s)"
            let h1 = "write `#{op_name}(#{int_to_string(expected - 1)} arg(s), resume) -> ...`"
            let h2 = "the trailing parameter is the resumption continuation; omitting it makes the clause uncallable"
            diag_note(n1)
            diag_note(n2)
            diag_help(h1)
            diag_help(h2)
            st_bump_err(st)
          }
        }
        _ -> st
      }
    }
  }
}

# filter labels whose `eff` matches `eff_name` AND whose
# ty_args unify with `tyargs`. This is the handler-removal path: only
# the labels matching the handler's instantiation are dropped from the
# body's row. A handler `with Reader[Int]` does NOT remove a body's
# `Reader[String]` label.
#
# the handler is the AUTHORITY on the type of the cell it
# discharges, so a matching label's ty_args are UNIFIED against the
# handler's `tyargs` (binding into the substitution), not merely
# shape-checked. Two reads of one cell that the row partition no longer
# cross-pairs (now that distinct cells carry distinct `@<alias>` tags)
# converge here instead: the first read pins the element type, the
# handler's `[?t0]` binds the label's `[?t15]`, and the threaded subst
# carries the binding to the next read so all reads of the cell agree.
# Match is a two-step "guard then bind": `label_args_dischargeable` is a
# pure, tyvar-permissive predicate (accepts a TyVar at any depth, rejects
# only a concrete-vs-concrete leaf clash) that DECIDES whether to
# discharge; only on a positive decision do we run the real `unify` that
# BINDS — so a non-matching label (`Reader[Int]` body under a
# `Reader[String]` handler) never leaves a partial binding behind.
type FilterResult = { kept: [Label], sub: Subst }

fn filter_labels_matching_res(xs: [Label], eff_name: String, tyargs: [Ty],
                               sub: Subst) : FilterResult / Mutable {
  match xs {
    [] -> FilterResult { kept: [], sub: sub }
    [h, ...rest] -> {
      if h.eff == eff_name and label_args_dischargeable(h.ty_args, tyargs, sub) {
        # Guard passed — bind the cell's element type via the real unify.
        # `unify_list` cannot widen the row, only resolve the shared
        # tyvars; on the rare structural-mismatch the guard let through
        # (it should not, being a superset check) we keep the old subst
        # and still discharge, preserving the prior shallow semantics.
        let sub1 = match unify_list(ty_env_empty(), h.ty_args, tyargs, sub) {
          Some(s) -> s
          None    -> sub
        }
        filter_labels_matching_res(rest, eff_name, tyargs, sub1)
      } else {
        let r = filter_labels_matching_res(rest, eff_name, tyargs, sub)
        FilterResult { kept: [h, ...r.kept], sub: r.sub }
      }
    }
  }
}

# Pure discharge guard: every arg position must be either flexibly
# unifiable (a TyVar on either side, at any nesting depth) or a
# structurally-equal concrete shape. Rejects a concrete-vs-concrete leaf
# clash (`Int` vs `String`) so a `Reader[Int]` handler still refuses a
# `Reader[String]` label. Unlike `labels_args_unify`, a TyVar nested
# inside a `[T]` / `Foo[T]` does NOT block the match — the binding is
# done afterward by the real unify.
fn label_args_dischargeable(a: [Ty], b: [Ty], s: Subst) : Bool {
  match a {
    [] -> match b { [] -> true _ -> false }
    [ah, ...arest] -> match b {
      [] -> false
      [bh, ...brest] ->
        if ty_dischargeable(apply_ty(s, ah), apply_ty(s, bh), s) {
          label_args_dischargeable(arest, brest, s)
        } else { false }
    }
  }
}

# Structural compatibility allowing a TyVar at any depth. Recurses
# through list / con / fn / union / dim shapes; a TyVar on either side
# at any node short-circuits to compatible (it will be bound by unify).
fn ty_dischargeable(a: Ty, b: Ty, s: Subst) : Bool {
  let ax = unwrap_refines(a)
  let bx = unwrap_refines(b)
  match ax {
    TyVarT(_) -> true
    TyAny     -> true
    _ -> match bx {
      TyVarT(_) -> true
      TyAny     -> true
      _ -> match ax {
        TyListT(ai) -> match bx { TyListT(bi) -> ty_dischargeable(ai, bi, s) _ -> false }
        TyCon(am, an, aas) -> match bx {
          TyCon(bm, bn, bas) ->
            module_slot_compat(am, bm) and an == bn and ty_list_dischargeable(aas, bas, s)
          _ -> false
        }
        TyFnT(aps, ar, _) -> match bx {
          TyFnT(bps, br, _) -> ty_list_dischargeable(aps, bps, s) and ty_dischargeable(ar, br, s)
          _ -> false
        }
        TyUnion(aps) -> match bx {
          TyUnion(bps) -> ty_list_dischargeable(aps, bps, s)
          _ -> false
        }
        TyDimT(ab, _) -> match bx { TyDimT(bb, _) -> ty_dischargeable(ab, bb, s) _ -> ty_eq_shape(ax, bx) }
        _ -> ty_eq_shape(ax, bx)
      }
    }
  }
}

fn ty_list_dischargeable(a: [Ty], b: [Ty], s: Subst) : Bool {
  match a {
    [] -> match b { [] -> true _ -> false }
    [ah, ...arest] -> match b {
      [] -> false
      [bh, ...brest] -> ty_dischargeable(apply_ty(s, ah), apply_ty(s, bh), s) and ty_list_dischargeable(arest, brest, s)
    }
  }
}

# Merge two label lists, deduplicating by (eff name + unifiable
# ty_args). Used when synth_handle stitches the outer row back with
# the body's residual labels.
fn merge_label_lists(a: [Label], b: [Label], sub: Subst) : [Label] {
  match b {
    [] -> a
    [h, ...rest] ->
      if label_present_unifiable(a, h, sub) {
        merge_label_lists(a, rest, sub)
      } else {
        merge_label_lists([h, ...a], rest, sub)
      }
  }
}

# A hole gets a fresh TyVarT and records its source position and the
# current scope snapshot. Named holes with the same name within the
# same decl share a TyVarT so both instances unify to the same type
# (matches the `if ... { ?x } else { ?x }` example in the doc).
fn synth_hole(st: InferState, nm_opt: Option[String], e: Expr) : Inferred {
  match nm_opt {
    Some(nm) -> match find_hole_by_name(st.holes, nm) {
      Some(prior_fresh) -> inferred_leaf(st, TyVarT(prior_fresh), e)
      None -> register_fresh_hole(st, HKHole(nm_opt), e)
    }
    None -> register_fresh_hole(st, HKHole(nm_opt), e)
  }
}

# register a `todo!(msg)` site as a hole-with-kind. Each
# occurrence is independent (no name-based sharing — `todo!` carries
# a free-form message, not an identifier), so we always allocate a
# fresh TyVarT.
fn synth_todo(st: InferState, msg: String, e: Expr) : Inferred {
  # Protocol-dispatcher markers reach `synth_todo` because they are
  # ETodos. They are NOT user-authored holes; the dispatcher fn typechecks
  # exactly like a regular polymorphic fn but emits a runtime shim at
  # codegen. Skip the hole register so `--holes-json` does not list the
  # marker as a user hole.
  if inf_string_starts_with_q(msg, inf_proto_dispatch_tag_prefix()) {
    let fresh_id = st.env.fresh
    let st1 = st_set_env(st, fresh_var(st.env))
    inferred_leaf(st1, TyVarT(fresh_id), e)
  } else {
    register_fresh_hole(st, HKTodo(msg), e)
  }
}

# An extern-fn body type-checks like a hole (any expected type fits)
# but is never a user hole: allocate a fresh tyvar without registering
# it, so `--holes-json` ignores it and no effect leaks from the body.
fn synth_extern_body(st: InferState, e: Expr) : Inferred {
  let fresh_id = st.env.fresh
  let st1 = st_set_env(st, fresh_var(st.env))
  inferred_leaf(st1, TyVarT(fresh_id), e)
}

# `expr!` typer.
# - Operand must be `Option[T]` or `Result[T, E]` (after substitution).
# - Enclosing function's declared return type must be the matching
#   `Option[U]` or `Result[U, E]` (same `E` — no `From` coercion).
# - Result type of the EBang node is the unwrapped success type `T`.
# Diagnostics name both types; the inner Expr is re-stamped with its
# resolved operand type so the C emitter can pick the correct
# discriminator (`Some` / `Ok`).
fn synth_bang(st: InferState, inner: Expr, line: Int, col: Int) : Inferred / Console + File + Mutable {


  let ri = synth(st, inner)
  let it_now = apply_ty(ri.st.sub, ri.ty)
  let inner_typed = with_ty(ri.expr, it_now)
  match it_now {
    TyCon(_, name, args_) ->
      if name == "Option" {
        match args_ {
          [t] -> bang_finish_option(ri.st, inner_typed, t, line, col)
          _   -> bang_bad_operand(ri.st, it_now, inner_typed, line, col)
        }
      } else if name == "Result" {
        match args_ {
          [t, e_ty] -> bang_finish_result(ri.st, inner_typed, e_ty, t, line, col)
          _ -> bang_bad_operand(ri.st, it_now, inner_typed, line, col)
        }
      } else {
        bang_bad_operand(ri.st, it_now, inner_typed, line, col)
      }
    _ -> bang_bad_operand(ri.st, it_now, inner_typed, line, col)
  }
}

# Validate `Option[t]` against the enclosing return type. The fn must
# return `Option[U]` for some `U` — we extract the U via a fresh
# tyvar so a generic `fn f[a]() : Option[a]` body still type-checks.
fn bang_finish_option(st: InferState, inner_typed: Expr, t: Ty,
                       line: Int, col: Int) : Inferred / Console + File {


  match st.ret_ty {
    None -> bang_no_enclosing_fn(st, "Option", t, inner_typed, line, col)
    Some(rt) -> {
      let rt_now = apply_ty(st.sub, rt)
      match rt_now {
        TyCon(_, rname, rargs) ->
          if rname == "Option" {
            match rargs {
              [_] ->
                mk_inferred(st, t, with_ty(mk_expr(EBang(inner_typed), line, col), t))
              _ -> bang_ret_mismatch(st, "Option", t, rt_now, inner_typed, line, col)
            }
          } else {
            bang_ret_mismatch(st, "Option", t, rt_now, inner_typed, line, col)
          }
        _ -> bang_ret_mismatch(st, "Option", t, rt_now, inner_typed, line, col)
      }
    }
  }
}

# Validate `Result[t, e_ty]` against the enclosing return type. The fn
# must return `Result[U, E]` for the same E — we unify e_ty with the
# function's declared error type (no implicit conversion).
fn bang_finish_result(st: InferState, inner_typed: Expr, e_ty: Ty, t: Ty,
                       line: Int, col: Int) : Inferred / Console + File + Mutable {


  match st.ret_ty {
    None -> bang_no_enclosing_fn(st, "Result", t, inner_typed, line, col)
    Some(rt) -> {
      let rt_now = apply_ty(st.sub, rt)
      match rt_now {
        TyCon(_, rname, rargs) ->
          if rname == "Result" {
            match rargs {
              [_, ret_e_ty] -> {
                # pass the enclosing function's
                # error type as `expected` so the unifier's D3 arm can
                # accept `e_ty <: ret_e_ty` when `e_ty` is a component
                # of the union `ret_e_ty`. Same-type Result use is
                # unaffected (head-unification succeeds before the
                # upcast arm fires).
                let st1 = st_unify(st, ret_e_ty, e_ty,
                  "`!` propagation requires the same error type as the enclosing function",
                  line, col)
                mk_inferred(st1, t, with_ty(mk_expr(EBang(inner_typed), line, col), t))
              }
              _ -> bang_ret_mismatch_result(st, e_ty, t, rt_now, inner_typed, line, col)
            }
          } else {
            bang_ret_mismatch_result(st, e_ty, t, rt_now, inner_typed, line, col)
          }
        _ -> bang_ret_mismatch_result(st, e_ty, t, rt_now, inner_typed, line, col)
      }
    }
  }
}

fn bang_bad_operand(st: InferState, found: Ty, inner_typed: Expr,
                     line: Int, col: Int) : Inferred / Console + File {


  diag_error(st.file, line, col,
    "`!` requires an `Option[T]` or `Result[T, E]` operand")
  diag_note("operand type: #{inf_ty_to_string(found)}")
  diag_help("`!` is reserved for the two compiler-blessed propagation types; convert the value explicitly first")
  let st1 = st_bump_err(st)
  let stub = with_ty(mk_expr(EBang(inner_typed), line, col), TyAny)
  mk_inferred(st1, TyAny, stub)
}

fn bang_no_enclosing_fn(st: InferState, fam: String, t: Ty, inner_typed: Expr,
                         line: Int, col: Int) : Inferred / Console + File {


  diag_error(st.file, line, col,
    "`!` is only valid inside a function body")
  diag_note("operand type: #{fam}[#{inf_ty_to_string(t)}]")
  diag_help("`!` propagates from the enclosing function; it cannot appear inside a lambda or at top level")
  let st1 = st_bump_err(st)
  let stub = with_ty(mk_expr(EBang(inner_typed), line, col), t)
  mk_inferred(st1, t, stub)
}

fn bang_ret_mismatch(st: InferState, fam: String, t: Ty, ret_ty: Ty,
                      inner_typed: Expr, line: Int, col: Int) : Inferred / Console + File {


  diag_error(st.file, line, col,
    "`!` on `#{fam}[#{inf_ty_to_string(t)}]` requires the enclosing function to return `#{fam}[U]`")
  diag_note("enclosing return type: #{inf_ty_to_string(ret_ty)}")
  diag_help("change the function's return type, or pattern-match the operand explicitly")
  let st1 = st_bump_err(st)
  let stub = with_ty(mk_expr(EBang(inner_typed), line, col), t)
  mk_inferred(st1, t, stub)
}

fn bang_ret_mismatch_result(st: InferState, e_ty: Ty, t: Ty, ret_ty: Ty,
                             inner_typed: Expr, line: Int, col: Int) : Inferred / Console + File {


  diag_error(st.file, line, col,
    "`!` on `Result[#{inf_ty_to_string(t)}, #{inf_ty_to_string(e_ty)}]` requires the enclosing function to return `Result[U, #{inf_ty_to_string(e_ty)}]`")
  diag_note("enclosing return type: #{inf_ty_to_string(ret_ty)}")
  diag_help("kaikai does not implicitly convert error types (no `From`); convert the error explicitly or change the function's return type")
  let st1 = st_bump_err(st)
  let stub = with_ty(mk_expr(EBang(inner_typed), line, col), t)
  mk_inferred(st1, t, stub)
}

fn register_fresh_hole(st: InferState, kind: HoleKind, e: Expr) : Inferred {
  let fresh_id = st.env.fresh
  let st1 = st_set_env(st, fresh_var(st.env))
  let site = HS(kind, e.line, e.col, fresh_id, st1.env.entries, st1.env.fresh)
  let st2 = st_push_hole(st1, site)
  inferred_leaf(st2, TyVarT(fresh_id), e)
}

fn find_hole_by_name(holes: [HoleSite], target: String) : Option[Int] {
  match holes {
    [] -> None
    [h, ...rest] -> match h {
      HS(kind, _, _, fresh, _, _) -> match kind {
        HKHole(nm_opt) -> match nm_opt {
          Some(nm) -> if nm == target { Some(fresh) } else { find_hole_by_name(rest, target) }
          None     -> find_hole_by_name(rest, target)
        }
        HKTodo(_) -> find_hole_by_name(rest, target)
      }
    }
  }
}

fn synth_many(st: InferState, es: [Expr]) : InferredList / Console + File + Mutable {


  match es {
    [] -> InferredList { st: st, tys: [], exprs: [] }
    [x, ...rest] -> {
      let r = synth(st, x)
      let rr = synth_many(r.st, rest)
      InferredList { st: rr.st, tys: [r.ty, ...rr.tys], exprs: [r.expr, ...rr.exprs] }
    }
  }
}

# The domain of a function type's first parameter, if any — the
# element type a combinator passes a point-free section's `__pl`.
fn fn_first_dom(t: Ty) : Option[Ty] = match t {
  TyFnT([dom, ...], _, _) -> Some(dom)
  _                       -> None
}

# Like `synth_many`, but each argument is paired with the declared
# parameter type at the same position (`param_tys`). A point-free
# section gets its `__pl` receiver pinned to that parameter's function
# domain before its body is walked, so `o.map(.length())` resolves the
# UFCS dispatch the same way the pipe forms do. Every other argument
# takes the plain synth path; a missing or non-function expected type
# is a no-op.
fn synth_many_threaded(st: InferState, es: [Expr],
                        param_tys: [Ty]) : InferredList / Console + File + Mutable {
  match es {
    [] -> InferredList { st: st, tys: [], exprs: [] }
    [x, ...rest] -> {
      let exp = match param_tys { [pt, ...] -> Some(apply_ty(st.sub, pt))  _ -> None }
      let prest = match param_tys { [_, ...pr] -> pr  _ -> [] }
      let r = synth_threaded_arg(st, x, exp)
      let rr = synth_many_threaded(r.st, rest, prest)
      InferredList { st: rr.st, tys: [r.ty, ...rr.tys], exprs: [r.expr, ...rr.exprs] }
    }
  }
}

fn synth_threaded_arg(st: InferState, x: Expr,
                       exp: Option[Ty]) : Inferred / Console + File + Mutable =
  if is_point_free_lambda(x) {
    match exp {
      Some(et) -> match fn_first_dom(et) {
        Some(dom) -> match x.kind {
          ELambda(ps, body) ->
            synth_lambda_threaded(st, ps, body, Some(dom), x.line, x.col)
          _ -> synth(st, x)
        }
        None -> synth(st, x)
      }
      None -> synth(st, x)
    }
  } else {
    match exp {
      Some(et) ->
        if arg_wants_vec_context(x, et) {
          check_expr_against(st, x, et, "argument", x.line, x.col)
        } else { synth(st, x) }
      None -> synth(st, x)
    }
  }

# A list literal / map-pipe chain in a Vec-typed parameter slot takes
# the bidirectional check path so it mints / collects — a plain synth
# would build the cons list and fail unification. A fixed-width slot
# (`Vec[T]<n>`) is Vec-typed under its brand.
fn arg_wants_vec_context(x: Expr, et: Ty) : Bool =
  if ty_vec_headed(et) {
    match x.kind {
      EList(_)       -> true
      EMapPipe(_, _) -> true
      _              -> false
    }
  } else { false }

# `synth_many` with the callee's declared params threaded per position,
# ONLY to route Vec-context args (literal / collect) through the
# bidirectional check; every other arg keeps the plain synth path.
fn synth_many_vec_args(st: InferState, es: [Expr],
                       param_tys: [Ty]) : InferredList / Console + File + Mutable {
  match es {
    [] -> InferredList { st: st, tys: [], exprs: [] }
    [x, ...rest] -> {
      let exp = match param_tys { [pt, ...] -> Some(apply_ty(st.sub, pt))  _ -> None }
      let prest = match param_tys { [_, ...pr] -> pr  _ -> [] }
      let r = match exp {
        Some(et) ->
          if arg_wants_vec_context(x, et) {
            check_expr_against(st, x, et, "argument", x.line, x.col)
          } else { synth(st, x) }
        None -> synth(st, x)
      }
      let rr = synth_many_vec_args(r.st, rest, prest)
      InferredList { st: rr.st, tys: [r.ty, ...rr.tys], exprs: [r.expr, ...rr.exprs] }
    }
  }
}

fn synth_call(st: InferState, callee: Expr, args_: [Expr], line: Int, col: Int) : Inferred / Console + File + Mutable {


  # The bare core IO builtins (`print`, `read_file`, `array_set`, …)
  # carry their effect in their own scheme row (`add_core_sigs` via
  # `fn_ty_eff`), so the standard call-inference path below — the open-row
  # unification of the callee's `TyFnT` plus `st_propagate_capability_labels`
  # — raises the label on the caller's row, exactly as for an explicit
  # `Eff.op(...)` call or a stdlib fn written `: T / Stdout`. No name-keyed
  # side table is needed; `check_body_row` still enforces row declaration
  # uniformly.
  let st_p = st
  match try_resume_call(st_p, callee, args_, line, col) {
    Some(inf) -> inf
    None ->
      match try_op_call(st_p, callee, args_, line, col) {
        Some(inf) -> inf
        None -> match try_ufcs_call(st_p, callee, args_, line, col) {
          Some(inf) -> inf
          None -> match try_constructor_call(st_p, callee, args_, line, col) {
            Some(inf) -> inf
            None -> match try_record_type_call(st_p, callee, args_, line, col) {
            Some(inf) -> inf
            None -> match try_bare_call_narrow(st_p, callee, args_, line, col) {
            Some(inf) -> inf
            None -> {
            let rc = synth(st_p, callee)
            # pair each arg with its declared param so a Vec-typed
            # param mints an EList / collects a map-pipe chain — the
            # argument-position face of the annotation-context rules.
            let vparams = match apply_ty(rc.st.sub, rc.ty) {
              TyFnT(ps, _, _) -> ps
              _               -> []
            }
            let ra = synth_many_vec_args(rc.st, args_, vparams)
            let rv = st_fresh_ty(ra.st)
            # build the expected function type with an *open*
            # row (a fresh row variable in the tail) so that calling a
            # function whose declared row is non-empty or carries its
            # own row variable doesn't force-bind the callee's tail to
            # the empty row at the call site. The fresh row var absorbs
            # whatever residual labels the callee carries; the caller's
            # effect tracking is handled separately by `st_add_label`
            # for op calls.
            #
            # transitive propagation of ALL callee row
            # labels is intentionally NOT done here. Doing so closes
            # the `pub_fn_transitive_effect.kai` silent contract but
            # ripples through stage2/compiler.kai (109+ helpers would
            # need explicit rows). Capability-only labels (today: Ffi)
            # ARE propagated via `st_propagate_capability_labels` so
            # `extern "C" fn ... / Ffi` calls demand `Ffi` in the
            # caller's row — closing the `ffi_call_no_capability.kai`
            # silent contract. The general retrofit is tracked in
            # the lane retro.
            let fr = subst_fresh_row(rv.st.sub)
            let st_fresh = st_set_sub(rv.st, fr.subst)
            let expected_row = Row { labels: [], tail: Some(fr.id), display_alias: None }
            let expected = TyFnT(ra.tys, rv.ty, expected_row)
            let st_unif = st_unify_call(st_fresh, callee, rc.ty, ra.tys, expected, line, col)
            let st2 = st_propagate_capability_labels(st_unif,
                        apply_ty(st_unif.sub, rc.ty), line, col)
            let ty = apply_ty(st2.sub, rv.ty)
            let root = with_ty(mk_expr(ECall(rc.expr, ra.exprs), line, col), ty)
            mk_inferred(st2, ty, root)
            }
          }
          }
          }
        }
      }
  }
}

# `#[constructor]` sugar: a call whose callee is a bare type name with
# a registered constructor desugars to a call to that fn via its home
# module, so `Rational(2, 3)` routes through `rational.make` — passing
# the fn's logic (canonicalisation, invariants), never the raw record
# literal — and its arg literals mint against `make`'s param types.
fn try_constructor_call(st: InferState, callee: Expr, args_: [Expr],
                        line: Int, col: Int) : Option[Inferred] / Console + File + Mutable {

  match callee.kind {
    EVar(nm) -> match constructor_lookup(st.env.constructors, nm) {
      Some(CtorE(_, home, fnm)) -> {
        let qcallee = mk_expr(EModCall(home, fnm), callee.line, callee.col)
        # coin bare numeric args to the marked fn's param types (its
        # scheme is concrete, e.g. `make(BigInt, BigInt)`), so
        # `Rational(2, 3)` mints `2`/`3` to `BigInt`. Call-arg minting
        # is not automatic, so the sugar does it explicitly here.
        let minted_args = match ty_env_lookup_qualified(st.env, home, fnm) {
          Some(sc) -> constructor_mint_args(st.env, sc, args_)
          None     -> args_
        }
        let rewritten = mk_expr(ECall(qcallee, minted_args), line, col)
        Some(synth(st, rewritten))
      }
      None -> None
    }
    _ -> None
  }
}

# Coin each bare numeric arg to the marked constructor's param type.
# The scheme is instantiated to read its `TyFnT` param list; an arg
# whose literal mints against its param is rewritten, others pass
# through untouched (the unifier still confirms the result).
fn constructor_mint_args(env: TyEnv, sc: TyScheme, args_: [Expr]) : [Expr] {
  match instantiate(env, sc).ty {
    TyFnT(param_tys, _, _) -> constructor_mint_zip(args_, param_tys)
    _                      -> args_
  }
}

fn constructor_mint_zip(args_: [Expr], param_tys: [Ty]) : [Expr] {
  match args_ {
    [] -> []
    [a, ...rest_a] -> match param_tys {
      [] -> args_
      [p, ...rest_p] -> {
        let a2 = match mint_literal(a, p) { MintOk(e2) -> e2  _ -> a }
        [a2, ...constructor_mint_zip(rest_a, rest_p)]
      }
    }
  }
}

# A record type is not callable: a bare-name callee with no scheme in
# the type env that names a declared record would otherwise fall
# through to the unknown-identifier TyAny fallback (unifies with
# anything) and only fail in the backend. Fns, sum-variant
# constructors and `#[constructor]` sugar all resolve upstream, so
# they stay callable.
fn try_record_type_call(st: InferState, callee: Expr, args_: [Expr],
                        line: Int, col: Int) : Option[Inferred] / Console + File + Mutable {
  match callee.kind {
    EVar(nm) -> match ty_env_lookup(st.env, nm) {
      Some(_) -> None
      None -> match rec_find(st.recs, nm) {
        Some(r) -> match r {
          RI(rnm, _, fs, _) -> {
            diag_error(st.file, line, col,
              concat_all(["record type `", rnm, "` cannot be called with positional arguments"]))
            diag_help(concat_all(["construct it with the record literal form: `",
                                  rnm, " { ", rec_fields_hint(fs), " }`"]))
            let root = with_ty(mk_expr(ECall(callee, args_), line, col), TyAny)
            Some(mk_inferred(st_bump_err(st), TyAny, root))
          }
        }
        None -> None
      }
    }
    _ -> None
  }
}

fn rec_fields_hint(fs: [FieldDecl]) : String = match fs {
  [] -> ""
  [f] -> match f { FD(_, nm, _) -> concat_all([nm, ": ..."]) }
  [f, ...rest] -> match f { FD(_, nm, _) -> concat_all([nm, ": ..., ", rec_fields_hint(rest)]) }
}

# when a bare-name callee resolves to multiple candidate
# schemes (`option.map`, `list.map`, `result.map`, ...), narrow by
# the type of the FIRST argument before instantiating. Without this
# step the default arm calls `synth(callee)` which routes through
# `ty_env_lookup` and picks the most-recently-prepended scheme by
# load order — which fails when the receiver/first-arg type doesn't
# match.
#
# Returns Some only when:
#   - callee is `EVar(nm)`,
#   - `nm` has 2+ candidates in the env (otherwise the default arm
#     does the right thing already),
#   - args_ is non-empty (we need a first-arg type to narrow on),
#   - some candidate's first param unifies with the first arg's type.
# Otherwise returns None and the caller falls through to the legacy
# default arm so existing diagnostics for missing names / arity
# mismatches keep firing unchanged.
fn try_bare_call_narrow(st: InferState, callee: Expr, args_: [Expr],
                         line: Int, col: Int) : Option[Inferred] / Console + File + Mutable {


  match callee.kind {
    EVar(nm) -> {
      # ctor names (uppercase first letter) are
      # NOT receiver-typed dispatch targets — narrow-by-first-arg was
      # designed for module-disambiguated FN candidates (e.g.
      # `option::map` vs `list::map`). When a user variant `Response.Ok`
      # shadows the core `Result.Ok`, both qualified entries appear
      # in the candidate list and `pick_by_first_arg` may prefer the
      # ctor whose first param is concrete (`String`) over the
      # polymorphic one (`T`), silently re-routing core `Ok(x)` to
      # `Response::Ok`. Skip the narrow path for ctors and let the
      # default arm pick the bare-lookup scheme — for ctors that is
      # the core builtin, which annotation/scrutinee disambiguation
      # rewrites to a qualified `EModCall` upstream when needed.
      let is_ctor = match char_at(nm, 0) {
        Some(c) -> c >= 'A' and c <= 'Z'
        None    -> false
      }
      # a root-file `fn nm` unconditionally shadows any
      # stdlib `pub fn nm`. Skip receiver-type narrowing entirely when
      # `nm` is a root shadow, so the bare lookup (which resolves to the
      # user's newest-registered decl) wins — even when a stdlib export
      # of the same name has a first param that matches the arg type
      # exactly (`length(String)` -> user's, not `string.length`). With
      # no root shadow this is False and the receiver-type narrowing
      # runs unchanged.
      if is_ctor or list_has(st.env.root_fns, nm) { None } else {
      let candidates = ty_env_collect_candidates(st.env, nm)
      let n_cand = list_length(candidates)
      if n_cand < 2 { None }
      else {
        match args_ {
          [] -> None
          [first_arg, ...rest_args] -> {
            let r0 = synth(st, first_arg)
            let first_ty = apply_ty(r0.st.sub, r0.ty)
            match pick_by_first_arg(r0.st, candidates, first_ty) {
              None -> None
              Some(pick) -> {
                let st_inst = if pick.fresh == [] and pick.unit_fresh == [] {
                  pick.st
                } else {
                  st_push_inst(pick.st, CS(nm, line, col, pick.fresh, pick.unit_fresh, None))
                }
                let ra_rest = synth_many(st_inst, rest_args)
                let all_arg_tys = [first_ty, ...ra_rest.tys]
                let all_arg_exprs = [r0.expr, ...ra_rest.exprs]
                let rv = st_fresh_ty(ra_rest.st)
                let fr = subst_fresh_row(rv.st.sub)
                let st_fresh = st_set_sub(rv.st, fr.subst)
                let expected_row = Row { labels: [], tail: Some(fr.id), display_alias: None }
                let expected = TyFnT(all_arg_tys, rv.ty, expected_row)
                # propagate capability-only labels only.
                let st_unif = st_unify_call(st_fresh, callee, pick.inst_ty, all_arg_tys, expected, line, col)
                let st2 = st_propagate_capability_labels(st_unif,
                            apply_ty(st_unif.sub, pick.inst_ty), line, col)
                let ty = apply_ty(st2.sub, rv.ty)
                # emit `EModCall(<mod>, nm)` so codegen
                # mints `kai_<mod>__<nm>` directly.
                let callee_node = with_ty(mk_expr(EModCall(pick.mod, nm), callee.line, callee.col), pick.inst_ty)
                let root = with_ty(mk_expr(ECall(callee_node, all_arg_exprs), line, col), ty)
                Some(mk_inferred(st2, ty, root))
              }
            }
          }
        }
      }
      }
    }
    _ -> None
  }
}

# type-check `resume(v)` in a STATELESS clause against `resume`'s env scheme
# (`bind_resume_param_typed` bound it to `(answer) -> ?fresh`). Done here
# rather than via the generic `synth(callee)` path so the callee `resume`
# never reaches the value-position guard in the `synth` `EVar` arm.
fn synth_resume_call_stateless(st: InferState, args_: [Expr], callee: Expr,
                                line: Int, col: Int) : Inferred / Console + File + Mutable {
  let callee_ty = match ty_env_lookup(st.env, "resume") {
    Some(sc) -> (st_instantiate_report(st, sc)).ty
    None     -> TyAny
  }
  let ra = synth_many(st, args_)
  let rv = st_fresh_ty(ra.st)
  let fr = subst_fresh_row(rv.st.sub)
  let st_fresh = st_set_sub(rv.st, fr.subst)
  let expected = TyFnT(ra.tys, rv.ty, Row { labels: [], tail: Some(fr.id), display_alias: None })
  let st_unif = st_unify_call(st_fresh, callee, callee_ty, ra.tys, expected, line, col)
  let ty = apply_ty(st_unif.sub, rv.ty)
  let resume_root = with_ty(mk_expr(EVar("resume"), callee.line, callee.col), callee_ty)
  let root = with_ty(mk_expr(ECall(resume_root, ra.exprs), line, col), ty)
  mk_inferred(st_unif, ty, root)
}

# type-check `resume(v)` / `resume(v, ns)` inside a clause body.
# Stateful clauses validate against `clause_resume` (precise answer/state
# types); stateless clauses type the call against `resume`'s env scheme.
# Intercepting the call here keeps the callee off the `synth` `EVar` arm,
# whose value-position guard would otherwise reject this legal call.
# Returns None when the call is not a resume inside a clause.
fn try_resume_call(st: InferState, callee: Expr, args_: [Expr],
                    line: Int, col: Int) : Option[Inferred] / Console + File + Mutable {


  match callee.kind {
    EVar(name) ->
      if name == "resume" {
        match st.clause_resume {
          Some(rb) -> Some(synth_resume_call(st, rb, args_, callee, line, col))
          None -> if st.in_clause {
            Some(synth_resume_call_stateless(st, args_, callee, line, col))
          } else { None }
        }
      } else { None }
    _ -> None
  }
}

fn synth_resume_call(st: InferState, rb: ResumeBind, args_: [Expr],
                      callee: Expr, line: Int, col: Int) : Inferred / Console + File + Mutable {


  match rb {
    RB(answer_ty, state_ty) -> {
      let ra = synth_many(st, args_)
      let rv = st_fresh_ty(ra.st)
      # st_unify treats the first arg as `expected` and the second as
      # `found`; the resume answer is what the clause must produce, so
      # answer_ty is the `expected` slot.
      let st_after = match ra.tys {
        [a]     -> st_unify(rv.st, answer_ty, a,
                             "resume answer", line, col)
        [a, ns] -> {
          let s1 = st_unify(rv.st, answer_ty, a,
                              "resume answer", line, col)
          st_unify(s1, state_ty, ns,
                    "resume new state", line, col)
        }
        _ -> {
          diag_error(rv.st.file, line, col,
            "resume call: expected 1 or 2 arguments inside a stateful clause")
          diag_note("`resume(v)` resumes with the answer; `resume(v, ns)` also writes the new handler state")
          diag_help("for `with State[T]` and `with Writer[W]`, use `resume(v, new_state)`; otherwise `resume(v)`")
          st_bump_err(rv.st)
        }
      }
      let ty = apply_ty(st_after.sub, rv.ty)
      let resume_root = with_ty(mk_expr(EVar("resume"), callee.line, callee.col), TyAny)
      let root = with_ty(mk_expr(ECall(resume_root, ra.exprs), line, col), ty)
      mk_inferred(st_after, ty, root)
    }
  }
}

# detect the surface shape `Eff.op(args)` and treat it as
# an op call. `Eff` must be a declared effect (its op signatures
# were registered under dotted keys by `add_effect_op_sigs`). Args
# are unified against the op's parameter types; the result type
# is the op's return type; `Eff` is added to the caller's row.
#
# An "effect name" is detected by scanning the env for any entry
# of the form `Eff.<something>` — equivalent to "this name has
# at least one op registered". If `Eff` is an effect but the op
# is missing, we emit a dedicated diagnostic instead of falling
# through to the generic `unknown identifier` path.
fn try_op_call(st: InferState, callee: Expr, args_: [Expr],
               line: Int, col: Int) : Option[Inferred] / Console + File + Mutable {


  match callee.kind {
    EField(base, op_name) -> match base.kind {
      EVar(name) -> {
        # First try the literal name (`Io`, `Mutable`, ...).
        let key = string_concat(name, string_concat(".", op_name))
        match ty_env_lookup(st.env, key) {
          Some(sc) -> Some(record_op_res(synth_op_call_with_scheme(st, sc, args_, key, line, col), key, None, false, line, col))
          None ->
            if is_effect_in_env(st.env, name) {
              Some(synth_op_call_unknown_op(st, name, op_name, line, col))
            } else {
              # maybe `name` is an alias bound by an
              # enclosing `handle ... with Eff as name`. Resolve
              # to the underlying effect and retry.
              # `@cap` desugars to `cap.get()` for every
              # capability shape; for a Reader-bound alias the op
              # is `ask`, not `get`. Remap here so the lookup hits.
              # A capability PARAMETER (`c: Eff`, not a `with..as` alias) is
              # provided by the caller, so it falls through to `cap_op_call`
              # below — its op does not join the row (§6 named instances).
              match lookup_alias(st.aliases, name) {
                None ->
                  # try type alias (`type Console =
                  # Stdout + Stderr + Stdin`, `type Io = Console + Env
                  # + File`). Find which component effect provides
                  # `op_name` and retry the lookup with that effect's
                  # qualified key. Body row label uses the resolved
                  # effect name so subset checking sees atomic labels
                  # and the runtime evidence stack is queried with
                  # the right key. Ambiguity (multiple components
                  # share an op_name) resolves to the leftmost.
                  match inf_find_alias(st.type_aliases, name) {
                    # Not an effect, not a `with..as` alias, not a type alias —
                    # last shot: a capability PARAMETER (`c: Eff`), provided by
                    # the caller (§6 named instances). Op dispatches against the
                    # param's evidence; effect does not join the row.
                    None -> cap_op_call(st, name, op_name, args_, line, col)
                    Some(AR(_, components)) ->
                      match inf_find_eff_for_alias_op(components, st.op_to_eff, op_name) {
                        None -> None
                        Some(real_eff) -> {
                          let key2 = string_concat(real_eff, string_concat(".", op_name))
                          match ty_env_lookup(st.env, key2) {
                            Some(sc) -> Some(record_op_res(synth_op_call_with_scheme(st, sc, args_, key2, line, col), key2, None, false, line, col))
                            None ->
                              if is_effect_in_env(st.env, real_eff) {
                                Some(synth_op_call_unknown_op(st, real_eff, op_name, line, col))
                              } else { None }
                          }
                        }
                      }
                  }
                Some(eff) -> {
                  let real_op = canonical_cap_getter(eff, op_name)
                  let lookup_key = string_concat(eff, string_concat(".", real_op))
                  # §6 named instances: a `with Eff as name` binding dispatches
                  # `name.op` against the handle's own evidence node, bound in the
                  # prologue as `kai_<name>`. The dispatch key carries `#<name>`
                  # so codegen reads that node directly — the same path a
                  # capability parameter uses, no by-id walk. Inside a lambda body
                  # the prologue local is out of scope, so the tag is suppressed
                  # and the bare name-keyed lookup runs (closure-capture path).
                  let taggable = match lookup_alias_taggable(st.aliases, name) {
                    Some(b) -> b
                    None    -> false
                  }
                  # `var`/State/Reader cells keep the legacy by-id dispatch (`@`):
                  # their naked-read sugar and nested-cell identity ride that path
                  # across the corpus. A user effect's `with Eff as name` uses the
                  # §6 capability dispatch (`#`) so it threads as a first-class
                  # value through calls — the named-instances surface.
                  let dispatch_key = if taggable {
                    if eff_is_cell_effect(eff) {
                      string_concat(lookup_key, string_concat("@", name))
                    } else {
                      string_concat(lookup_key, string_concat("#", name))
                    }
                  } else {
                    lookup_key
                  }
                  # this is the confirmed-alias branch, so
                  # `name` is a `with <eff> as <name>` cell. Tag the row
                  # label with the cell identity (`State@i`) so two
                  # distinct cells (`var i`, `var go`) stay distinct
                  # labels under row unification. Independent of
                  # `taggable`: the codegen dispatch tag is suppressed
                  # inside a lambda, but row identity must hold there too
                  # (the `while` thunks are lambdas).
                  match ty_env_lookup(st.env, lookup_key) {
                    Some(sc) -> Some(record_op_res(synth_op_call_with_scheme_keys(st, sc, args_, lookup_key, dispatch_key, Some(name), line, col), lookup_key, Some(name), taggable, line, col))
                    None ->
                      if is_effect_in_env(st.env, eff) {
                        Some(synth_op_call_unknown_op(st, eff, real_op, line, col))
                      } else { None }
                  }
                }
              }
            }
        }
      }
      _ -> None
    }
    _ -> None
  }
}

# UFCS dispatch for `receiver.method(args)` callees.
#
# Fires from `synth_call` when the callee shape is `EField(obj, ident)`
# and `try_op_call` already declined (so `obj` is not an effect-name
# reference). Walks `obj` once to learn its type, then applies the
# field-vs-function precedence rule:
#
#   1. If `obj` is a record value AND `ident` names a field of that
#      record, returns None — let `synth_call`'s generic path run
#      `synth(st, callee)` (which dispatches `synth_field`) so field
#      access wins on ties.
#   2. Else if `ident` resolves in the type env to a function whose
#      first parameter unifies with `obj`'s type, lowers the call to
#      `ECall(EVar(ident), [obj, ...args])` and finishes typing it
#      with the same expected-row pattern `synth_call`/`synth_pipe_dispatch`
#      use, so call-site row-tracking and unify diagnostics stay
#      identical to the prefix form.
#   3. Else, emits a Q4-style diagnostic naming the receiver type and
#      hinting at scope candidates whose first arg matches, then
#      stamps `TyAny` to keep cascade graceful.
#
# Returning Some always means "we handled this call site". Returning
# None always means "let the generic `synth(st, callee)` path run" —
# used for the field-wins precedence step.
fn try_ufcs_call(st: InferState, callee: Expr, args_: [Expr],
                  line: Int, col: Int) : Option[Inferred] / Console + File + Mutable {


  match callee.kind {
    EField(obj, ident) -> {
      let r = synth(st, obj)
      let obj_ty = apply_ty(r.st.sub, r.ty)
      if record_has_field(r.st, obj_ty, ident) { None }
      else {
        # `c := v` and `@c` for `c : Ref[T]` desugar in
        # the parser to `c.set(v)` / `c.get()`. `Ref[T]` is the
        # return type of `Mutable.ref_make[T]`; `get`/`set` aren't
        # inherent methods, but `Mutable` carries `ref_get`/`ref_set`
        # ops with matching signatures. Bridge here, mirroring the
        # `a[i] := v` → `Mutable.array_set(a, i, v)` precedent.
        # Effect-row injection rides for free: `synth_op_call_with_scheme`
        # already labels the row with `Mutable` for op calls.
        match try_ref_sugar_op(st, obj, obj_ty, ident, args_, line, col) {
          Some(inf) -> Some(inf)
          None -> Some(synth_ufcs_dispatch(r.st, ident, r.expr, obj_ty, args_, line, col))
        }
      }
    }
    _ -> None
  }
}

# rewrite `c.get()` / `c.set(v)` to `Mutable.ref_get(c)` /
# `Mutable.ref_set(c, v)` when `c : Ref[T]`. Returns None when the
# receiver is not a `Ref` or the ident is not `get` / `set`, so the
# caller falls back to the regular UFCS path (preserving the existing
# "method not found" diagnostic for unrelated names).
fn try_ref_sugar_op(st: InferState, obj: Expr, obj_ty: Ty, ident: String,
                     args_: [Expr], line: Int, col: Int) : Option[Inferred] / Console + File + Mutable {


  match obj_ty {
    TyCon(_, name, _) ->
      if name == "Ref" {
        let key_opt =
          if ident == "get" { Some("Mutable.ref_get") }
          else if ident == "set" { Some("Mutable.ref_set") }
          else { None }
        match key_opt {
          None -> None
          Some(key) -> match ty_env_lookup(st.env, key) {
            None -> None
            Some(sc) -> {
              # `obj` re-walks once inside `synth_op_call_with_scheme`
              # (via `synth_many`); `synth` on `EVar(name)` is a pure
              # env lookup, so a second walk is idempotent.
              let all_args = [obj, ...args_]
              Some(synth_op_call_with_scheme(st, sc, all_args, key, line, col))
            }
          }
        }
      } else { None }
    _ -> None
  }
}

# Returns true when `obj_ty` resolves to a record type that declares
# a field named `ident`. Used by `try_ufcs_call` to honour the
# field-wins-on-ties precedence rule before attempting UFCS lookup.
fn record_has_field(st: InferState, obj_ty: Ty, ident: String) : Bool {
  match obj_ty {
    TyCon(_, cname, cargs) -> match rec_find_with_field(st.recs, cname, list_length(cargs), ident) {
      None -> false
      Some(ri) -> {
        let inst = rec_instantiate(st, ri)
        match fty_find(inst.fields, ident) {
          Some(_) -> true
          None    -> false
        }
      }
    }
    _ -> false
  }
}

# result of `pick_by_first_arg`. The picked scheme has
# already been instantiated (state's `fresh` and `sub` advanced); the
# caller proceeds with the standard unify-arg-then-emit pipeline.
# `mod` carries the declaring module so the caller rewrites the
# callee to `EModCall(mod, fname)` and codegen mints
# `kai_<mod>__<fname>` directly, bypassing `efn_resolve`'s load-
# order tie-break.
type PickResult = { st: InferState, inst_ty: Ty, fresh: [Int], unit_fresh: [Int],
                    mod: String }

# shared shape used by `synth_ufcs_dispatch`. Pairs the
# instantiated state with the resolved callee form — `EModCall(m,
# fname)` for module-qualified picks, `EVar(fname)` for the bare-
# name fallback (root-file user fns with no `module_origin`).
type UfcsPick = { st: InferState, inst_ty: Ty, fresh: [Int], unit_fresh: [Int],
                  callee_kind: ExprKind }

# choose the candidate whose first parameter unifies
# with `target_ty`, preferring CONCRETE-headed matches over
# tyvar-headed ones.
#
# A scheme's first param can be either:
#   - concrete-headed: TyCon(None, "Result", [...]), TyListT(...), TyString,
#     etc. These match `target_ty` only when the heads agree, so a
#     `Result[String, Int]` arg never accidentally picks `list.map`.
#   - tyvar-headed: TyVarT(_), TyAny. Vacuously unifies with any
#     `target_ty` because instantiation refreshed the var. The
#     classic case is `pub fn repeat(x: a, n: Int) : [a]` whose
#     first param is `a` — given a `String` arg, list.repeat would
#     win the race against `string.repeat` even though the intent
#     is string.repeat.
#
# Walk strategy: a single pass that records two best candidates —
# the first concrete-headed match and the first tyvar-headed match.
# Concrete wins if any was found. Within each kind the most-recently-
# registered match wins (env order is newest first). This matches
# the legacy `ty_env_lookup` tie-break on the bare side and gives
# correct dispatch on the qualified side.
#
# Each tried candidate bumps the inference state's fresh counter
# (instantiation mints fresh tyvars). On a match the `sub` is *not*
# extended by the probe — `synth_ufcs_dispatch` and `synth_call`
# re-do the unify against the call's full expected fn type, which is
# what records the receiver / arg constraints into the substitution.
# So this helper only commits the instantiation, not the probe.
fn pick_by_first_arg(st: InferState, candidates: [TyCandidate],
                      target_ty: Ty) : Option[PickResult] / Mutable =
  pick_by_first_arg_loop(st, candidates, target_ty, None, None)

# Two-pick walker: the first arg slot is for the leading concrete
# match, the second for the leading tyvar match. After exhausting
# the candidates, prefer concrete; fall back to tyvar.
#
# each iteration's `st_instantiate_report` advances the
# inferencer's `env.fresh` and writes fresh tyvar slots. Subsequent
# iterations' probe `unify_env` may extend the (mutable) `slots`
# array with bindings — those bindings persist even though the
# returned Subst is discarded, because kaikai's stage 2 substitution
# arrays are opaque-mutable.
#
# Consequence: a `pick.st` captured early carries the stale
# `env.fresh` from before later candidates were probed. When the
# caller eventually allocates a fresh tyvar with `st_fresh_ty`, it
# reuses a slot ID that a later candidate's discarded probe already
# bound to a concrete type, and `apply_ty` returns that concrete
# type instead of an unconstrained var. This previously caused
# `loop.repeat`'s recursive call to be inferred as `Int` (leftover
# from `list.repeat(x: a, n: Int)` whose `a` was probe-unified to
# `Int`).
#
# Fix: after every iteration, refresh each pending pick's `st` to
# carry the LATEST `env.fresh` and `Subst` counters. The pick keeps
# its instantiation type (which only references slot IDs from its
# own iteration), but its state is bumped past any later
# instantiation. The caller's `st_fresh_ty` then never collides with
# a discarded-probe-binding slot.
fn pick_by_first_arg_loop(st: InferState, candidates: [TyCandidate],
                            target_ty: Ty,
                            best_concrete: Option[PickResult],
                            best_tyvar: Option[PickResult]) : Option[PickResult] / Mutable {
  match candidates {
    [] -> match best_concrete {
      Some(_) -> best_concrete
      None    -> best_tyvar
    }
    [c, ...rest] -> {
      let inst = st_instantiate_report(st, c.scheme)
      let probe = match inst.ty {
        TyFnT(params, _, _) -> match params {
          [] -> ProbeNoMatch
          [first, ..._rest_params] -> {
            let head_concrete = first_param_head_is_concrete(first)
            match unify_env(inst.st.env, first, target_ty, inst.st.sub) {
              None    -> ProbeNoMatch
              Some(_) -> if head_concrete { ProbeConcrete } else { ProbeTyvar }
            }
          }
        }
        _ -> ProbeNoMatch
      }
      let pick = PickResult { st: inst.st, inst_ty: inst.ty,
                               fresh: inst.fresh, unit_fresh: inst.unit_fresh,
                               mod: c.mod }
      let new_concrete = match probe {
        ProbeConcrete -> match best_concrete {
          Some(_) -> Some(pick_advance_st(best_concrete, inst.st))
          None    -> Some(pick)
        }
        _ -> match best_concrete {
          Some(_) -> Some(pick_advance_st(best_concrete, inst.st))
          None    -> best_concrete
        }
      }
      let new_tyvar = match probe {
        ProbeTyvar -> match best_tyvar {
          Some(_) -> Some(pick_advance_st(best_tyvar, inst.st))
          None    -> Some(pick)
        }
        _ -> match best_tyvar {
          Some(_) -> Some(pick_advance_st(best_tyvar, inst.st))
          None    -> best_tyvar
        }
      }
      pick_by_first_arg_loop(inst.st, rest, target_ty, new_concrete, new_tyvar)
    }
  }
}

# replace a pending pick's `st` with `latest_st` so the
# fresh-counters advance past every candidate's instantiation. The
# pick's `inst_ty`, `fresh`, `unit_fresh`, and `mod` are preserved
# unchanged. Returns the input verbatim when it's `None` (caller
# only invokes this on `Some(_)`).
fn pick_advance_st(p: Option[PickResult], latest_st: InferState) : PickResult {
  match p {
    None -> PickResult { st: latest_st, inst_ty: TyAny, fresh: [], unit_fresh: [], mod: "" }
    Some(pp) -> PickResult { st: latest_st, inst_ty: pp.inst_ty,
                              fresh: pp.fresh, unit_fresh: pp.unit_fresh, mod: pp.mod }
  }
}

type ProbeOutcome = ProbeNoMatch | ProbeTyvar | ProbeConcrete

# True when the head of `t` is a concrete type constructor (TyCon,
# TyListT, primitive). Tyvars (TyVarT) and TyAny match anything and
# count as ambiguous — the caller routes them to the tyvar bucket.
# `TyFnT` first params (a higher-order arg) are concrete: distinct
# arities or shapes won't accidentally unify with a `TyListT`-headed
# first param.
fn first_param_head_is_concrete(t: Ty) : Bool = match t {
  TyVarT(_)    -> false
  TyAny        -> false
  TyInt        -> true
  TyReal       -> true
  TyBool       -> true
  TyString     -> true
  TyChar       -> true
  TyUnit       -> true
  TyByte         -> true
  TyInt32        -> true
  TyUInt32       -> true
  TyUInt64       -> true
  TyInt128       -> true
  TyListT(_)   -> true
  TyFnT(_, _, _) -> true
  TyCon(_, _, _)  -> true
  TyDimT(_, _) -> true
  _            -> false
}

# Lowers `obj.ident(args)` to `ident(obj, args)`. Looks up `ident`
# in the type env; if missing or its first param doesn't unify with
# `obj_ty`, emits the Q4 method-not-found diagnostic and returns a
# TyAny stamp. Mirrors `synth_pipe_dispatch`'s open-row pattern so
# the dispatched call's effect labels and unify diagnostics match
# the prefix-form call (`ident(obj, args)`).
#
# `obj_expr` has already been walked by `try_ufcs_call`; we walk
# `args_` ourselves to avoid double-walking `obj` (the args may
# carry their own effect labels and CallSite entries which must
# stamp the final InferState).
fn synth_ufcs_dispatch(st: InferState, ident: String, obj_expr: Expr,
                        obj_ty: Ty, args_: [Expr],
                        line: Int, col: Int) : Inferred / Console + File + Mutable {


  # walk every `<mod>::<ident>` qualified candidate and
  # pick the first whose first parameter unifies with the receiver
  # type. Without this, two modules exporting `map` (option, list,
  # ...) collide and the legacy `ty_env_lookup` returns the most-
  # recently-prepended scheme — load-order, not receiver type.
  # On a match the callee is rewritten to `EModCall(mod, ident)` so
  # codegen mints `kai_<mod>__<ident>` directly and bypasses
  # `efn_resolve`'s name-only lookup.
  #
  # Fallback: when `ident` has no qualified candidates (a user-
  # defined fn in the root file with `module_origin = None`, e.g.
  # `paint(c: Color)` in `examples/ufcs/over_union_component.kai`),
  # consult the legacy bare-name `ty_env_lookup` path so root-file
  # UFCS dispatch keeps working unchanged.
  let candidates = ty_env_collect_candidates(st.env, ident)
  let picked = match pick_by_first_arg(st, candidates, obj_ty) {
    Some(p) -> Some(UfcsPick { st: p.st, inst_ty: p.inst_ty,
                                fresh: p.fresh, unit_fresh: p.unit_fresh,
                                callee_kind: EModCall(p.mod, ident) })
    None -> match ty_env_lookup(st.env, ident) {
      None -> None
      Some(sc) -> {
        let inst = st_instantiate_report(st, sc)
        Some(UfcsPick { st: inst.st, inst_ty: inst.ty,
                         fresh: inst.fresh, unit_fresh: inst.unit_fresh,
                         callee_kind: EVar(ident) })
      }
    }
  }
  match picked {
    None -> ufcs_method_not_found(st, ident, obj_expr, obj_ty, args_, line, col)
    Some(pick) -> {
      let inst_st = pick.st
      let inst_ty = pick.inst_ty
      let st_inst = if pick.fresh == [] and pick.unit_fresh == [] {
        inst_st
      } else {
        st_push_inst(inst_st, CS(ident, line, col, pick.fresh, pick.unit_fresh, None))
      }
      match inst_ty {
        TyFnT(params, _, _) -> match params {
          [] -> ufcs_method_not_found(st_inst, ident, obj_expr, obj_ty, args_, line, col)
          [first, ..._rest] -> match unify_env(st_inst.env, first, obj_ty, st_inst.sub) {
            None -> ufcs_method_not_found(st_inst, ident, obj_expr, obj_ty, args_, line, col)
            Some(_) -> {
              # Walk the remaining args (obj is already typed in obj_expr).
              # Thread each declared param type (skip the receiver at
              # params[0]) so a point-free section arg gets its receiver
              # pinned from the combinator's element type up front.
              let arg_param_tys = match params { [_, ...pr] -> pr  _ -> [] }
              let ra = synth_many_threaded(st_inst, args_, arg_param_tys)
              let all_arg_tys = [obj_ty, ...ra.tys]
              let all_arg_exprs = [obj_expr, ...ra.exprs]
              # Same expected-row pattern `synth_call` and
              # `synth_pipe_dispatch` use: open-row tail so the
              # callee's declared row variables don't force-bind the
              # call site's row.
              let rv = st_fresh_ty(ra.st)
              let fr = subst_fresh_row(rv.st.sub)
              let st_fresh = st_set_sub(rv.st, fr.subst)
              let expected_row = Row { labels: [], tail: Some(fr.id), display_alias: None }
              let expected = TyFnT(all_arg_tys, rv.ty, expected_row)
              let synth_callee = mk_expr(pick.callee_kind, line, col)
              # propagate capability-only labels through UFCS.
              let st_unif = st_unify_call(st_fresh, synth_callee, inst_ty, all_arg_tys, expected, line, col)
              let st2 = st_propagate_capability_labels(st_unif,
                          apply_ty(st_unif.sub, inst_ty), line, col)
              let ty = apply_ty(st2.sub, rv.ty)
              let callee_node = with_ty(synth_callee, inst_ty)
              let root = with_ty(mk_expr(ECall(callee_node, all_arg_exprs), line, col), ty)
              mk_inferred(st2, ty, root)
            }
          }
        }
        _ -> ufcs_method_not_found(st_inst, ident, obj_expr, obj_ty, args_, line, col)
      }
    }
  }
}

# Q4 diagnostic — the receiver's type is statically known (or `TyAny`
# from a cascade), no field of that type matches, and no scope
# function `ident(receiver_ty, ...)` was found. Cascade-friendly: we
# stamp `TyAny` and bump the error counter so downstream passes don't
# crash on a missing call lowering.
fn ufcs_method_not_found(st: InferState, ident: String, obj_expr: Expr,
                          obj_ty: Ty, args_: [Expr],
                          line: Int, col: Int) : Inferred / Console + File {


  let head_msg = match inf_ty_head_name(obj_ty) {
    Some(name) -> concat_all(["method `", ident, "` not found for type `", name, "`"])
    None       -> concat_all(["method `", ident, "` not found (receiver type unresolved)"])
  }
  diag_error(st.file, line, col, head_msg)
  diag_help(concat_all(["if `", ident, "` is a free function, ensure its first parameter ",
                        "type matches the receiver; otherwise check the spelling."]))
  let bare_callee = with_ty(mk_expr(EField(obj_expr, ident), line, col), TyAny)
  let root = with_ty(mk_expr(ECall(bare_callee, args_), line, col), TyAny)
  mk_inferred(st_bump_err(st), TyAny, root)
}

# When `name` is a value bound to a capability type — a parameter `c: Eff` or a
# `with Eff as name` binding (§6 named instances) — return the effect it carries.
# The capability type is the effect's own nominal `TyCon(None, Eff, args)`; an
# `Eff.op` exists in the env iff `Eff` is a declared effect, so a TyCon head that
# `is_effect_in_env` recognises is a capability. Returns the effect label with
# the resolved ty_args so the op-call instantiation pins the row instance.
fn cap_eff_of_var(st: InferState, name: String) : Option[Label] =
  match ty_env_lookup(st.env, name) {
    None     -> None
    Some(sc) -> match sc {
      Scheme(_, _, _, _, ty) -> match apply_ty(st.sub, ty) {
        TyCon(None, ename, args) ->
          if is_effect_in_env(st.env, ename) { Some(Label { eff: ename, ty_args: args }) }
          else { None }
        _ -> None
      }
    }
  }

# `State`/`Reader` are readable cells: a `var` desugars to `with State as name`
# and reads naked. Their dispatch keeps the legacy by-id path; a user effect's
# named instance uses the §6 capability path. Mirrors desugar's `eff_is_cell`.
fn eff_is_cell_effect(eff: String) : Bool = eff == "State" or eff == "Reader"

# Type `name.op(args)` where `name` is a capability value. Dispatch the op to the
# effect it carries; codegen reads `name`'s evidence node. The effect does NOT
# join the row — the capability is provided, not demanded.
fn cap_op_call(st: InferState, name: String, op_name: String, args_: [Expr],
               line: Int, col: Int) : Option[Inferred] / Console + File + Mutable =
  match cap_eff_of_var(st, name) {
    None      -> None
    Some(lab) -> {
      let cap_eff = lab.eff
      let cap_key = string_concat(cap_eff, string_concat(".", op_name))
      match ty_env_lookup(st.env, cap_key) {
        Some(sc) -> Some(synth_op_call_provided(st, sc, args_, name, cap_key, line, col))
        None     -> Some(synth_op_call_unknown_op(st, cap_eff, op_name, line, col))
      }
    }
  }

fn is_effect_in_env(env: TyEnv, eff_name: String) : Bool =
  is_effect_in_env_loop(env.entries, string_concat(eff_name, "."))

fn is_effect_in_env_loop(entries: [TyEntry], prefix: String) : Bool {
  match entries {
    [] -> false
    [e, ...rest] ->
      if string_has_prefix(e.name, prefix) { true }
      else { is_effect_in_env_loop(rest, prefix) }
  }
}

fn string_has_prefix(s: String, p: String) : Bool {
  let pl = string_length(p)
  if string_length(s) < pl { false }
  else { string_slice(s, 0, pl) == p }
}

fn synth_op_call_unknown_op(st: InferState, eff_name: String, op_name: String,
                             line: Int, col: Int) : Inferred / Console + File {


  diag_error(st.file, line, col,
    string_concat("unknown op `", string_concat(op_name,
      string_concat("` on effect `", string_concat(eff_name, "`")))))
  diag_note("`#{eff_name}.#{op_name}` is not declared in `effect #{eff_name} { ... }`")
  diag_help("declare `#{op_name}(...)` inside the effect, or call an existing op")
  let st1 = st_bump_err(st)
  mk_inferred(st1, TyAny, with_ty(mk_expr(EVar(eff_name), line, col), TyAny))
}

fn synth_op_call_with_scheme(st: InferState, sc: TyScheme, args_: [Expr],
                              key: String, line: Int, col: Int) : Inferred / Console + File + Mutable {


  # most call sites pass a single key — both the type
  # lookup key and the codegen dispatch key are the same. No alias:
  # a direct `Eff.op(...)` call is not a `with ... as <name>` cell, so
  # its row label keeps the bare effect name.
  synth_op_call_with_scheme_keys(st, sc, args_, key, key, None, line, col)
}

# An op call on a PROVIDED capability (`c.op(...)` where `c: Eff` is a value
# parameter, §6 named instances). Types the call exactly like a normal op call —
# instantiate, unify args against the op scheme — but does NOT add the effect to
# the body's row: a capability passed in is satisfied by the caller, not demanded
# by this function (design §3 "capability as a parameter does not enter the row").
# Codegen reads the evidence from the parameter's own slot, keyed by the variable
# name so distinct instances stay distinct by parameter position.
fn synth_op_call_provided(st: InferState, sc: TyScheme, args_: [Expr],
                           recv: String, key: String, line: Int, col: Int) : Inferred / Console + File + Mutable {
  let inst = st_instantiate_report(st, sc)
  let ra = synth_many(inst.st, args_)
  let rv = st_fresh_ty(ra.st)
  let expected = fn_ty(ra.tys, rv.ty)
  let st2 = st_unify(rv.st, inst.ty, expected, string_concat("cap op call ", key), line, col)
  let ty = apply_ty(st2.sub, rv.ty)
  # Dispatch key carries the receiver name so codegen reads `recv`'s own evidence
  # slot rather than walking by effect name — distinct capability params resolve
  # to distinct nodes. No row label: the capability is provided, not demanded.
  let root = with_ty(mk_expr(ECall(callee_expr_for_op(string_concat(key, string_concat("#", recv)), line, col), ra.exprs), line, col), ty)
  mk_inferred(st2, ty, root)
}

fn synth_op_call_with_scheme_keys(st: InferState, sc: TyScheme, args_: [Expr],
                                   lookup_key: String, dispatch_key: String,
                                   row_alias: Option[String],
                                   line: Int, col: Int) : Inferred / Console + File + Mutable {


  # capture the fresh ids minted by instantiation. For
  # parametric effects (where the scheme quantifies over the effect's
  # tparams) these fresh tyvars are the row label's ty_args. For
  # stateless effects the list is empty and we add a bare-name label.
  # per-op generic schemes also quantify over op-level
  # tparams; those are NOT part of the row label's ty_args. Use the
  # `op_eff_arities` table to take only the first N fresh ids
  # (corresponding to the effect's tparams) for the row.
  # alias-rewritten op calls carry a `dispatch_key` with an
  # `@<alias>` suffix so codegen can route through the handle's
  # `kai_alias_<a>_id` local. Type-level lookups (op_eff_arities,
  # row label) still use the bare `lookup_key`.
  let inst = st_instantiate_report(st, sc)
  let ra = synth_many(inst.st, args_)
  let rv = st_fresh_ty(ra.st)
  let expected = fn_ty(ra.tys, rv.ty)
  let st2 = st_unify(rv.st, inst.ty, expected, string_concat("op call ", lookup_key), line, col)
  let eff_n = dotted_prefix(lookup_key)
  let eff_arity = lookup_op_eff_arity(st2.op_eff_arities, lookup_key)
  let eff_fresh = take_first(inst.fresh, eff_arity)
  let row_args = resolve_fresh_ids(eff_fresh, st2.sub)
  # tag the row label with the cell alias so two distinct
  # `with <eff> as <name>` cells stay distinct labels (see
  # `label_eff_with_alias`). The suffix is discharged symmetrically by
  # the cell's own handler and stripped for display.
  let lab = Label { eff: label_eff_with_alias(eff_n, row_alias), ty_args: row_args }
  # stash the effect name + live payload tyvar ids before
  # `st_add_label`, whose dedup may drop this label against a sibling op's
  # concrete label of the same effect. The deferred-field drain reads it
  # to pin a receiver the dropped label was the only carrier for, under
  # the final sub so the `match` binder's receiver-to-payload link shows.
  let st2p = st_push_op_payload_vars(st2, label_eff_with_alias(eff_n, row_alias), eff_fresh)
  # The `@alias` in `lab.eff` keeps distinct cells apart, so this only
  # threads ty_args between ops of the same cell (`cur.set` → `cur.get`).
  let st2u = st_unify_dedup_label(st2p, lab, line, col)
  let st3 = st_add_label(st2u, lab, line, col)
  let ty = apply_ty(st3.sub, rv.ty)
  let root = with_ty(mk_expr(ECall(callee_expr_for_op(dispatch_key, line, col), ra.exprs), line, col), ty)
  mk_inferred(st3, ty, root)
}

fn lookup_op_eff_arity(table: [OpEffArity], key: String) : Int {
  match table {
    [] -> 0
    [h, ...rest] -> match h {
      OEA(k, n) -> if k == key { n } else { lookup_op_eff_arity(rest, key) }
    }
  }
}

# The tparam arity of an effect — how many type args its capability type carries.
# Found via any op key `<eff>.<op>` in the arity table (all ops of one effect
# share its tparam count). A non-parametric effect (`Cell`) returns 0 so its
# capability type is the bare `TyCon(None, "Cell", [])` a parameter annotates.
fn eff_tparam_arity(table: [OpEffArity], eff: String) : Int =
  eff_tparam_arity_loop(table, string_concat(eff, "."))

fn eff_tparam_arity_loop(table: [OpEffArity], prefix: String) : Int {
  match table {
    [] -> 0
    [h, ...rest] -> match h {
      OEA(k, n) -> if string_has_prefix(k, prefix) { n } else { eff_tparam_arity_loop(rest, prefix) }
    }
  }
}

fn take_first_tys(xs: [Ty], n: Int) : [Ty] {
  if n <= 0 { [] }
  else { match xs {
    [] -> []
    [h, ...rest] -> [h, ...take_first_tys(rest, n - 1)]
  } }
}

fn take_first(xs: [Int], n: Int) : [Int] {
  if n <= 0 { [] }
  else { match xs {
    [] -> []
    [h, ...rest] -> [h, ...take_first(rest, n - 1)]
  } }
}

# Apply the substitution to a list of fresh-tyvar ids, producing the
# resolved type for each. Avoids an inline lambda that would capture
# the substitution and confuse stage 1's capture analyser.
fn resolve_fresh_ids(ids: [Int], sub: Subst) : [Ty] {
  match ids {
    [] -> []
    [id, ...rest] -> [apply_ty(sub, TyVarT(id)), ...resolve_fresh_ids(rest, sub)]
  }
}

# Extract `Eff` from `Eff.op` so st_add_effect can record only the
# label, not the dotted form.
#[doc("infer: `dotted_prefix` — typer entry point invoked by the driver.")]
pub fn dotted_prefix(s: String) : String =
  dotted_prefix_loop(s, 0, string_length(s))

fn dotted_prefix_loop(s: String, i: Int, n: Int) : String {
  if i >= n { s }
  else {
    match char_at(s, i) {
      Some(c) -> if c == '.' { string_slice(s, 0, i) } else { dotted_prefix_loop(s, i + 1, n) }
      None    -> s
    }
  }
}

# pair to dotted_prefix. Extract `op` from `Eff.op`.
#[doc("infer: `dotted_suffix` — typer entry point invoked by the driver.")]
pub fn dotted_suffix(s: String) : String =
  dotted_suffix_loop(s, 0, string_length(s))

fn dotted_suffix_loop(s: String, i: Int, n: Int) : String {
  if i >= n { s }
  else {
    match char_at(s, i) {
      Some(c) -> if c == '.' { string_slice(s, i + 1, n) } else { dotted_suffix_loop(s, i + 1, n) }
      None    -> s
    }
  }
}

#[doc("infer: `string_contains_dot` — typer entry point invoked by the driver.")]
pub fn string_contains_dot(s: String) : Bool =
  string_contains_dot_loop(s, 0, string_length(s))

fn string_contains_dot_loop(s: String, i: Int, n: Int) : Bool {
  if i >= n { false }
  else {
    match char_at(s, i) {
      Some(c) -> if c == '.' { true } else { string_contains_dot_loop(s, i + 1, n) }
      None    -> false
    }
  }
}

# render a Real value as a C/LLVM floating-point
# literal. `real_to_string(9.0)` gives `"9"` (no trailing `.0`
# when the value is integer-valued); emitting that bare into C
# makes the backend lex it as `int`, so a Real-typed `9.0 / 2.0`
# silently degrades to integer division. Append `.0` only when the
# rendered form has neither a decimal point NOR an exponent
# (`1e+10` is already a valid floating literal — appending `.0`
# would produce `1e+10.0`, which is a syntax error in both C and
# LLVM IR).
#[doc("infer: `real_c_lit` — typer entry point invoked by the driver.")]
pub fn real_c_lit(s: String) : String {
  if real_lit_is_float_typed(s, 0, string_length(s)) { s }
  else { cat2(s, ".0") }
}

fn real_lit_is_float_typed(s: String, i: Int, n: Int) : Bool {
  if i >= n { false }
  else {
    match char_at(s, i) {
      Some(c) ->
        if c == '.' or c == 'e' or c == 'E' { true }
        else { real_lit_is_float_typed(s, i + 1, n) }
      None -> false
    }
  }
}

# (compiler integration) — locate the `@` separator the
# alias rewrite uses to tag op names. Returns the byte index, or
# -1 when no `@` is present.
#[doc("infer: `string_index_of_at` — typer entry point invoked by the driver.")]
pub fn string_index_of_at(s: String) : Int = string_index_of_at_loop(s, 0, string_length(s))

fn string_index_of_at_loop(s: String, i: Int, n: Int) : Int {
  if i >= n { -1 }
  else { match char_at(s, i) {
    Some(c) -> if c == '@' { i } else { string_index_of_at_loop(s, i + 1, n) }
    None    -> -1
  } }
}

# drop the `@<alias>` suffix from a tagged op key. When
# absent, returns the key unchanged.
#[doc("infer: `string_strip_alias_tag` — typer entry point invoked by the driver.")]
pub fn string_strip_alias_tag(s: String) : String {
  let at = string_index_of_at(s)
  if at < 0 { s } else { string_slice(s, 0, at) }
}

# Synthesise a placeholder callee for the typed AST that emit later
# turns into the runtime op-dispatch call. Keeps the original surface
# shape (EField/EVar) so the existing emitter path falls through.
fn callee_expr_for_op(key: String, line: Int, col: Int) : Expr =
  mk_expr(EVar(key), line, col)

fn field_root(obj_expr: Expr, fnm: String, line: Int, col: Int, ty: Ty) : Expr =
  with_ty(mk_expr(EField(obj_expr, fnm), line, col), ty)

fn synth_field(st: InferState, obj: Expr, fnm: String, line: Int, col: Int) : Inferred / Console + File + Mutable {


  let r = synth(st, obj)
  let applied = apply_ty(r.st.sub, r.ty)
  match applied {
    TyCon(_, cname, cargs) -> match rec_find_with_field(r.st.recs, cname, list_length(cargs), fnm) {
      None -> field_non_record_or_partial_app(r.st, r.expr, fnm, line, col)
      Some(ri) -> {
        let inst = rec_instantiate(r.st, ri)
        let st1 = st_unify(inst.st, inst.result_ty, r.ty, "record field access", line, col)
        match fty_find(inst.fields, fnm) {
          Some(t) -> {
            let ty = apply_ty(st1.sub, t)
            mk_inferred(st1, ty, field_root(r.expr, fnm, line, col, ty))
          }
          None -> {
            diag_error(st.file, line, col, "no field '#{fnm}' on #{cname}#{field_hint(inst.fields, fnm)}")
            mk_inferred(st_bump_err(st1), TyAny, field_root(r.expr, fnm, line, col, TyAny))
          }
        }
      }
    }
    # the receiver's type is still an unbound tyvar — the
    # canonical case is the payload of a generic effect op (`Some(b) ->
    # b.id` where `b : ?a` and `?a` is only pinned to the row's `Box`
    # later by `check_body_row`). We cannot decide field-vs-UFCS here:
    # eager UFCS (the `_` fallback below) is exactly the wrong guess —
    # it produces a bogus diagnostic. Defer instead — record a
    # constraint keyed on the receiver tyvar, stamp the access with a
    # FRESH result tyvar (not TyAny, so downstream uses stay connected),
    # and let `infer_decl` resolve it once the receiver settles. This is
    # purely a timing fix in the field-access path; it touches neither
    # effect-row inference nor the UFCS rule for resolved receivers.
    TyVarT(recv_id) -> {
      let fr = st_fresh_ty(r.st)
      let res_id = ty_var_id(fr.ty)
      let st1 = st_push_deferred_field(fr.st, DF(recv_id, fnm, res_id, line, col))
      mk_inferred(st1, fr.ty, field_root(r.expr, fnm, line, col, fr.ty))
    }
    _ -> field_non_record_or_partial_app(r.st, r.expr, fnm, line, col)
  }
}

# extract the id of a freshly-minted TyVarT. `st_fresh_ty`
# always returns a `TyVarT(n)`, so the `_` arm is unreachable in
# practice; it returns -1 (an id `apply_ty` can never bind) as a safe
# sentinel that drains to the "annotation needed" path.
fn ty_var_id(t: Ty) : Int = match t { TyVarT(n) -> n  _ -> -1 }

# drain the deferred field-access worklist. Called by
# `infer_decl` after `check_body_row`, so each receiver tyvar that was
# unbound at synth time (a generic effect-op payload, the canonical
# case) is now resolved. For each constraint, resolve the receiver:
#   - concrete record `TyCon` with the field  -> unify the result tyvar
#     with the field type (so the typed AST's stamped fresh var becomes
#     concrete via the finalise pass) and the access type-checks.
#   - concrete `TyCon` WITHOUT the field       -> the missing-field error
#     on that type (closes the Tier 1 escape: `b.zzz` on a generic-effect
#     payload is now rejected at compile time, not silently accepted).
#   - any other concrete type                  -> field access on a
#     non-record value.
#   - still an unbound tyvar                    -> "type annotation needed"
#     (the body never pins the receiver; mirrors OCaml's warning 18).
fn drain_deferred_fields(st: InferState, dfs: [DeferredField],
                          declared: [Label]) : InferState / Console + File + Mutable {
  match dfs {
    [] -> st
    [df, ...rest] -> match df {
      DF(recv_id, fnm, res_id, line, col) -> {
        # a receiver still free here had its only carrier
        # (`Repo.find`'s `Repo[?a, Int]` label) dropped by `st_add_label`
        # dedup against a sibling op's concrete label. Pin it from the
        # DECLARED row — the authoritative source — by unifying the
        # stashed op label that carries `recv_id` against its declared
        # counterpart. A no-op when the receiver is already concrete
        # (every other op's payload, pinned by usage) or no stashed label
        # carries it; never touches the row partition, so it cannot
        # perturb the row-mismatch diagnostic (m7b_11).
        let stp = pin_free_receiver_from_decl(st, recv_id, declared)
        let recv = apply_ty(stp.sub, TyVarT(recv_id))
        let st1 = drain_one_deferred_field(stp, recv, fnm, res_id, line, col)
        drain_deferred_fields(st1, rest, declared)
      }
    }
  }
}

# if `recv_id` is still a free tyvar after the body settled,
# find a stashed op whose payload shares the receiver's final
# representative — i.e. the body genuinely connected the receiver to that
# op's payload (the `match` binder did so) — and unify that op's label,
# resolved under the FINAL sub, against the declared row. That binds the
# receiver from the signature, the only sound source. An already-concrete
# receiver, no co-class op, or no matching declared label → `st`
# unchanged. The co-class precondition is what makes this sound for a
# discarded payload-free op (`let _ = self()` in a multi-instance row):
# its payload never joins the receiver's class, so no arbitrary binding.
fn pin_free_receiver_from_decl(st: InferState, recv_id: Int,
                                declared: [Label]) : InferState / Console + File + Mutable {
  match apply_ty(st.sub, TyVarT(recv_id)) {
    TyVarT(rrep) -> pin_via_op_vars(st, rrep, st.op_payload_labels, declared)
    _            -> st
  }
}

fn pin_via_op_vars(st: InferState, rrep: Int, ops: [OpPayloadVars],
                    declared: [Label]) : InferState / Console + File + Mutable {
  match ops {
    [] -> st
    [op, ...rest] -> match op {
      OPV(eff, ids) ->
        if ids_share_rep(ids, rrep, st.sub) {
          # The receiver is in this op's payload class. Rebuild the op's
          # label with ty_args resolved under the FINAL sub, then unify
          # it against its declared counterpart — pinning the receiver's
          # still-free class members (the payload position) to the
          # declared concrete type.
          let lab = Label { eff: eff, ty_args: resolve_fresh_ids(ids, st.sub) }
          match find_matching_declared(declared, lab, st) {
            Some(st1) -> st1
            None      -> pin_via_op_vars(st, rrep, rest, declared)
          }
        } else {
          pin_via_op_vars(st, rrep, rest, declared)
        }
    }
  }
}

# True iff some id resolves, under the final sub, to the receiver's final
# representative `rrep`. This is the co-class test: the body unified that
# payload position with the receiver. A position that resolved to a
# concrete type (already pinned by usage) is not a free `TyVarT(rrep)`
# and so does not match — correctly, it needs no pinning.
fn ids_share_rep(ids: [Int], rrep: Int, s: Subst) : Bool {
  match ids {
    [] -> false
    [i, ...rest] -> match apply_ty(s, TyVarT(i)) {
      TyVarT(n) -> if n == rrep { true } else { ids_share_rep(rest, rrep, s) }
      _         -> ids_share_rep(rest, rrep, s)
    }
  }
}

# declared-row labels with their ty_args resolved to Ty,
# for the deferred-field pinning step. Bare-name (stateless) labels and
# open / absent rows contribute nothing a payload tyvar could bind to.
fn decl_row_concrete_labels(row: RowExpr) : [Label] {
  match row {
    RClosed(lbs)  -> inf_row_labels_of_rls(lbs)
    ROpen(_, lbs) -> inf_row_labels_of_rls(lbs)
    REmpty        -> []
  }
}

fn drain_one_deferred_field(st: InferState, recv: Ty, fnm: String,
                             res_id: Int, line: Int, col: Int) : InferState / Console + File + Mutable {
  match recv {
    TyCon(_, cname, cargs) -> match rec_find_with_field(st.recs, cname, list_length(cargs), fnm) {
      Some(ri) -> {
        let inst = rec_instantiate(st, ri)
        let st1 = st_unify(inst.st, inst.result_ty, recv, "deferred field access", line, col)
        match fty_find(inst.fields, fnm) {
          Some(t) -> st_unify(st1, TyVarT(res_id), apply_ty(st1.sub, t), "deferred field access", line, col)
          None -> {
            diag_error(st.file, line, col, "no field '#{fnm}' on #{cname}#{field_hint(inst.fields, fnm)}")
            st_bump_err(st1)
          }
        }
      }
      None -> {
        diag_error(st.file, line, col, "no field '#{fnm}' on #{cname}")
        st_bump_err(st)
      }
    }
    TyVarT(_) -> {
      diag_error(st.file, line, col,
        concat_all(["type annotation needed: the receiver of `.", fnm,
                    "` is not resolved by the body — annotate it so the field can be checked"]))
      st_bump_err(st)
    }
    _ -> {
      diag_error(st.file, line, col,
        concat_all(["`.", fnm, "` is a field access on a non-record value"]))
      st_bump_err(st)
    }
  }
}

# When `EField(obj, fnm)` reaches `synth_field` with
# a non-record receiver, the failure is at type-check time,
# mirroring `try_ufcs_call`'s diagnostic but
# pointing the user at the call-site rule: UFCS only fires when the
# field-access shape is the callee of an `ECall`. A bare `r.fnm`
# (no parens) is rejected unconditionally — implicit partial
# application would force a closure decision out of context.
#
# We still stamp TyAny so cascade is graceful and downstream emit
# passes don't crash (they would otherwise emit `kai_op_field`,
# which crashes at runtime).
fn field_non_record_or_partial_app(st: InferState, obj_expr: Expr, fnm: String,
                                     line: Int, col: Int) : Inferred / Console + File {


  match ty_env_lookup(st.env, fnm) {
    Some(_) -> {
      diag_error(st.file, line, col,
        concat_all(["`", fnm, "` is a function in scope, not a field. ",
                    "UFCS only fires at call sites — write `expr.", fnm, "(args)`, ",
                    "not a bare `expr.", fnm, "`."]))
      mk_inferred(st_bump_err(st), TyAny, field_root(obj_expr, fnm, line, col, TyAny))
    }
    None -> mk_inferred(st, TyAny, field_root(obj_expr, fnm, line, col, TyAny))
  }
}

# `e1[e2]` dispatches on the container's inferred
# type. `Map[K, V]` lowers to `map.get(coll, ix)` and `HashMap[K, V]`
# to `hashmap.get(coll, ix)` (both return `Option[V]`); any
# other container — including unresolved type variables — falls back
# to `array_get(coll, ix)` so the unifier produces the existing
# "expected `Array[T]`" error message at the call site. The dispatch
# walks `coll` once with `synth` to read its inferred type, then
# constructs an `ECall` AST and re-synthesises it so the core
# scheme of the chosen callee is the source of truth for the argument
# types, return type, AND effect row — the `HashMap` lowering picks up
# `hashmap_get`'s `/ Mutable` automatically (HashMap is a mutable
# table; even a read dereferences its `Ref` cells). Re-walking `coll`
# is cheap and avoids us reimplementing the call-typing rule inline.
#
# Design note (not a smell — kept as a closed 3-case dispatch on
# purpose): a smell audit flagged the `name == "Map"` test as wanting
# an `Index` protocol. It does not. kaikai has exactly three indexable
# containers (Array, Map, HashMap), and the language bans
# type-class-style resolution — a closed compile-time dispatch is
# precisely what is preferred over a resolution mechanism. An `Index`
# protocol
# would not remove a hardcode, it would move it (the proto name + the
# builtin impls) across more sites and route every `[]` through the
# proto impl-table at runtime. Worse, it would degrade this error:
# the Array fallback for an unresolved type var is deliberate, and a
# protocol over `?t` can only emit a generic "no `Index` impl" or
# re-hardcode the Array bias inside the resolver.
fn synth_index(st: InferState, coll: Expr, ix: Expr, line: Int, col: Int) : Inferred / Console + File + Mutable {


  let probe = synth(st, coll)
  let coll_ty = apply_ty(probe.st.sub, probe.ty)
  match coll_ty {
    TyCon(_, cname, _) ->
      if cname == "Vec" { synth_vec_index(probe.st, coll, ix, line, col) }
      else {
        let callee =
          if cname == "Map"          { mk_expr(EModCall("map", "get"), line, col) }
          else if cname == "HashMap" { mk_expr(EModCall("hashmap", "get"), line, col) }
          else                       { mk_expr(EVar("array_get"), line, col) }
        synth(st, mk_expr(ECall(callee, [coll, ix]), line, col))
      }
    # A fixed-width vec (`Vec[T]<n>`) reads inline: a static literal index
    # is a bare struct field load with the bound proved at compile time
    # (no runtime check). A dynamic index is declined in v1.
    TyDimT(inner, _) -> match inner {
      TyCon(_, cname, _) ->
        if cname == "Vec" {
          if ty_is_fixed_vec(coll_ty) { synth_fixed_vec_index(probe.st, coll, ix, coll_ty, line, col) }
          else {
            let bare = mk_expr(ECall(mk_expr(EVar("__detach_unit"), line, col), [coll]), line, col)
            synth_vec_index(probe.st, bare, ix, line, col)
          }
        } else {
          synth(st, mk_expr(ECall(mk_expr(EVar("array_get"), line, col), [coll, ix]), line, col))
        }
      _ -> synth(st, mk_expr(ECall(mk_expr(EVar("array_get"), line, col), [coll, ix]), line, col))
    }
    _ -> synth(st, mk_expr(ECall(mk_expr(EVar("array_get"), line, col), [coll, ix]), line, col))
  }
}

# `xs[i]` on a Vec reads the element; `xs[a..b]` (inclusive, like the
# range literal) is the O(1) slice — the same view `[h, ...t]` binds.
fn synth_vec_index(st: InferState, coll: Expr, ix: Expr,
                   line: Int, col: Int) : Inferred / Console + File + Mutable =
  match ix.kind {
    ERange(a, b, None) -> {
      let slen = mk_expr(EBinop("+", mk_expr(EBinop("-", b, a), line, col),
                                mk_expr(EInt(1), line, col)),
                         line, col)
      synth(st, mk_expr(ECall(mk_expr(EVar("vec_slice"), line, col), [coll, a, slen]), line, col))
    }
    ERange(_, _, Some(_)) -> {
      diag_error(st.file, line, col, "a stepped range cannot slice a Vec — a slice is one contiguous view")
      mk_inferred(st_bump_err(st), TyAny, with_ty(mk_expr(EIndex(coll, ix), line, col), TyAny))
    }
    _ -> synth(st, mk_expr(ECall(mk_expr(EVar("vec_get"), line, col), [coll, ix]), line, col))
  }

# `v[k]` on a fixed-width `Vec[e]<n>`: a static literal index in range
# lowers to `__fixed_vec_get` — a bare struct field load, the bound
# proved here at compile time so no runtime check is emitted. Out of
# range is a compile error (strictly better than the dynamic vec's
# runtime trap). A dynamic index lowers to `__fixed_vec_get_dyn`, the
# same inline field load behind a bounds check against the static `n`.
fn synth_fixed_vec_index(st: InferState, coll: Expr, ix: Expr, coll_ty: Ty,
                         line: Int, col: Int) : Inferred / Console + File + Mutable {
  let n = fixed_vec_n(coll_ty)
  let elem = fixed_vec_elem(coll_ty)
  match ix.kind {
    EInt(k) ->
      if k >= 0 and k < n {
        fixed_vec_index_node(st, coll, ix, "__fixed_vec_get", elem, line, col)
      } else {
        diag_error(st.file, line, col,
          concat_all(["index ", int_to_string(k), " is out of range for a fixed-width `Vec` of length ", int_to_string(n)]))
        mk_inferred(st_bump_err(st), elem, with_ty(mk_expr(EIndex(coll, ix), line, col), elem))
      }
    _ -> {
      let ir = check_expr_against(st, ix, TyInt, "index", ix.line, ix.col)
      fixed_vec_index_node(ir.st, coll, ir.expr, "__fixed_vec_get_dyn", elem, line, col)
    }
  }
}

# The `__fixed_vec_get`/`_get_dyn` call node, typed at the element and
# marked unboxed: the read yields a raw scalar out of the flat aggregate.
fn fixed_vec_index_node(st: InferState, coll: Expr, ix: Expr, prim: String, elem: Ty,
                        line: Int, col: Int) : Inferred / Console + File + Mutable {
  let cr = synth(st, coll)
  let call = ECall(mk_expr(EVar(prim), line, col), [cr.expr, ix])
  let node = Expr { kind: call, line: line, col: col, ty: Some(elem), mode: MUnboxed }
  mk_inferred(cr.st, elem, node)
}

# Binop typing is deliberately coarse: numeric operators unify their
# two operands and return the shared type (usually `Int`); comparison
# operators unify operands and return `Bool`; logical `and`/`or` pin
# both sides to `Bool`; `%` pins operands to `Int`. There is no
# dedicated `//` operator — `Int / Int` already truncates via the
# `Div[Int]` impl.
fn binop_root(op: String, l_expr: Expr, r_expr: Expr, line: Int, col: Int, ty: Ty) : Expr =
  with_ty(mk_expr(EBinop(op, l_expr, r_expr), line, col), ty)

# `%` result type: a same-width fixed integer on both sides keeps that
# width (its own primitive `%`); anything else falls to `Int`.
fn fixed_mod_result(lt: Ty, rt: Ty) : Ty = match lt {
  TyByte   -> match rt { TyByte   -> TyByte   _ -> TyInt }
  TyInt32  -> match rt { TyInt32  -> TyInt32  _ -> TyInt }
  TyUInt32 -> match rt { TyUInt32 -> TyUInt32 _ -> TyInt }
  TyUInt64 -> match rt { TyUInt64 -> TyUInt64 _ -> TyInt }
  TyInt128 -> match rt { TyInt128 -> TyInt128 _ -> TyInt }
  _        -> TyInt
}

fn synth_binop(st: InferState, op: String, l: Expr, r: Expr, line: Int, col: Int) : Inferred / Console + File + Mutable {


  let rl = synth(st, l)
  let rr = synth(rl.st, r)
  if op == "++" {
    synth_concat(rr.st, rl.ty, rl.expr, rr.ty, rr.expr, line, col)
  } else if op == "and" or op == "or" {
    let s1 = st_unify(rr.st, rl.ty, TyBool, "boolean operator", line, col)
    let s2 = st_unify(s1, rr.ty, TyBool, "boolean operator", line, col)
    mk_inferred(s2, TyBool, binop_root(op, rl.expr, rr.expr, line, col, TyBool))
  } else if op == "==" or op == "!=" {
    # `==` / `!=` are sugar for Eq.eq. The typer keeps the existing
    # structural builtin form (`binop_root`, lowered to `kai_op_eq_v`);
    # the structural-vs-custom-impl decision is made later, per spec,
    # by `resolve_protocol_calls` over concrete types (it rewrites the
    # EBinop to a `__pimpl_Eq_<T>_eq` call when the type — or a field
    # at any depth — carries a custom `impl Eq`). Deciding here is
    # premature: inside a generic body the operand type is still a
    # `TyVarT` and only monomorphisation makes it concrete.
    let s1 = st_unify(rr.st, rl.ty, rr.ty, "comparison", line, col)
    mk_inferred(s1, TyBool, binop_root(op, rl.expr, rr.expr, line, col, TyBool))
  } else if op == "<" or op == ">" or op == "<=" or op == ">=" {
    # `<` / `>` / `<=` / `>=` are sugar for Ord.cmp. Same as `==`: the
    # typer keeps the structural builtin form and the per-spec protocol
    # resolver rewrites to `__pimpl_Ord_<T>_cmp` (reduced to Bool against
    # 0) when the concrete type has a custom `impl Ord`.
    let s1 = st_unify(rr.st, rl.ty, rr.ty, "comparison", line, col)
    mk_inferred(s1, TyBool, binop_root(op, rl.expr, rr.expr, line, col, TyBool))
  } else if op == "%" {
    # modulo over a `Rem` protocol. Primitive `Int % Int`
    # keeps the unify-and-emit fast path; concrete non-primitive
    # operands desugar to a `Rem.rem` protocol-method call so user
    # types can supply `impl Rem for T`. Heterogeneous routing follows
    # the same shape as `*` / `/`. `Real % Real` also routes through
    # the protocol, which dispatches to `impl Rem for Real` and lowers
    # to the `fmod` libm binding.
    let lty_now = apply_ty(rr.st.sub, rl.ty)
    let rty_now = apply_ty(rr.st.sub, rr.ty)
    if binop_should_dispatch_proto(lty_now, rty_now) {
      synth_binop_proto(rr.st, op, rl.expr, rr.expr, line, col)
    } else if binop_dispatch_proto_heterogeneous(rr.st, op, lty_now, rty_now) {
      synth_binop_proto(rr.st, op, rl.expr, rr.expr, line, col)
    } else if ty_is_real_head(lty_now) and ty_is_real_head(rty_now) {
      synth_binop_proto(rr.st, op, rl.expr, rr.expr, line, col)
    } else {
      # `T % T` over a same-width fixed integer keeps the primitive fast
      # path (`+`/`-`/`*`-style width wrap); everything else unifies with
      # `Int`.
      let modt = fixed_mod_result(lty_now, rty_now)
      let s1 = st_unify(rr.st, rl.ty, modt, "integer arithmetic", line, col)
      let s2 = st_unify(s1, rr.ty, modt, "integer arithmetic", line, col)
      mk_inferred(s2, modt, binop_root(op, rl.expr, rr.expr, line, col, modt))
    }
  } else if op == "*" or op == "/" {
    # when neither operand is primitive numeric (Int/Real,
    # optionally dim-wrapped) but both have concrete head TyCon (e.g.
    # Complex), desugar to a Mul/Div protocol-method call so the
    # post-inference rewrite can dispatch to `__pimpl_<P>_<T>_<op>`.
    # Falls through to the dim-aware path otherwise (keeps primitive
    # arithmetic on the zero-overhead unify-and-emit fast path).
    let lty_now = apply_ty(rr.st.sub, rl.ty)
    let rty_now = apply_ty(rr.st.sub, rr.ty)
    if binop_should_dispatch_proto(lty_now, rty_now) {
      if binop_same_head_dimmed(lty_now, rty_now) {
        # dimensioned protocol operands (`Decimal<USD>`): the impl
        # erases units (its signature is the bare carrier), so combine
        # them here exactly as the primitive dim path does — the
        # Module guard rejects habitant products, and the result
        # carries the combined unit.
        synth_binop_proto_dim_mul(rr.st, op, rl.expr, lty_now, rr.expr, rty_now, line, col)
      } else {
        synth_binop_proto(rr.st, op, rl.expr, rr.expr, line, col)
      }
    } else if binop_dispatch_proto_heterogeneous(rr.st, op, lty_now, rty_now) {
      # heterogeneous prim<->nonprim or cross-nonprim
      # routing, gated on impl-existence in the snapshot.
      synth_binop_proto(rr.st, op, rl.expr, rr.expr, line, col)
    } else {
      # multiplication and division of dimensioned values
      # combine units rather than requiring equality. The operand-type
      # rule still requires the *base* numeric types to agree (Real*Real
      # / Int*Int) — we delegate that to synth_dim_mul_div.
      synth_dim_mul_div(rr.st, op, rl.ty, rl.expr, rr.ty, rr.expr, line, col)
    }
  } else if op == "^" {
    # Integer-exponent power. Mirrors `*`/`/`'s UoM behaviour with one
    # twist: the result unit is `u^n`, which only resolves when `n`
    # is a literal Int known at compile time. If the exponent is not
    # a literal AND the base has a non-trivial unit, the rule is
    # rejected (no dependent types). Bare numeric bases (`Int`,
    # `Real<1>`, …) accept any `Int` exponent.
    synth_dim_pow(rr.st, rl.ty, rl.expr, rr.ty, rr.expr, line, col)
  } else {
    # protocol-method dispatch fall-through for `+` / `-`
    # when both operands resolve to a non-primitive concrete type.
    # Primitive `Int + Int` / `Real + Real` arithmetic still goes
    # through the unify-and-emit path; only user types (Complex,
    # Vector, ...) take the protocol detour.
    let lty_now = apply_ty(rr.st.sub, rl.ty)
    let rty_now = apply_ty(rr.st.sub, rr.ty)
    if binop_should_dispatch_proto(lty_now, rty_now) {
      # dimensioned protocol operands keep the primitive rule: `+` and
      # `-` demand unit equality. The impl signature is the bare
      # carrier and would silently swallow a unit mismatch.
      let st_d = if binop_same_head_dimmed(lty_now, rty_now) {
        let what = string_concat("arithmetic operator '", string_concat(op, "'"))
        st_unify(rr.st, rl.ty, rr.ty, what, line, col)
      } else { rr.st }
      synth_binop_proto(st_d, op, rl.expr, rr.expr, line, col)
    } else if binop_dispatch_proto_heterogeneous(rr.st, op, lty_now, rty_now) {
      # heterogeneous routing.
      synth_binop_proto(rr.st, op, rl.expr, rr.expr, line, col)
    } else {
      # `+` / `-` keep the unify-both-sides rule. The dim-aware unifier
      # checks the unit equality automatically.
      let what = string_concat("arithmetic operator '", string_concat(op, "'"))
      let s1 = st_unify(rr.st, rl.ty, rr.ty, what, line, col)
      let s2 = st_check_arith_string(s1, op, rl.ty, line, col)
      let ty = apply_ty(s2.sub, rl.ty)
      mk_inferred(s2, ty, binop_root(op, rl.expr, rr.expr, line, col, ty))
    }
  }
}

# returns true when (lt, rt) form a heterogeneous pair
# (prim<->nonprim or two distinct nonprim heads) for which a matching
# `impl P[A] for T` is registered in `st.proto_impls`. Same-prim pairs
# (`Int + Int`, `Real + Real`) and same-nonprim pairs already
# captured by `binop_should_dispatch_proto` are NOT matched here.
fn binop_dispatch_proto_heterogeneous(st: InferState, op: String,
                                        lt: Ty, rt: Ty) : Bool {
  let proto = binop_proto_name(op)
  if proto == "" { false }
  else {
    let l_prim = ty_is_concrete_prim(lt)
    let r_prim = ty_is_concrete_prim(rt)
    let l_user = ty_is_concrete_nonprim(lt)
    let r_user = ty_is_concrete_nonprim(rt)
    let pair_prim_user = (l_prim and r_user) or (r_prim and l_user)
    let pair_user_user_diff = l_user and r_user and not ty_same_head(lt, rt)
    if not (pair_prim_user or pair_user_user_diff) {
      false
    } else {
      match binop_pick_proto_dispatch(st.proto_impls, proto, binop_proto_method(op),
                                       lt, rt, st.sub) {
        Some(_) -> true
        None -> false
      }
    }
  }
}

fn binop_proto_name(op: String) : String {
  if op == "+" { "Add" }
  else if op == "-" { "Sub" }
  else if op == "*" { "Mul" }
  else if op == "/" { "Div" }
  else if op == "%" { "Rem" }
  else { "" }
}

fn ty_is_concrete_prim(t: Ty) : Bool {
  match t {
    TyInt -> true
    TyReal -> true
    TyDimT(inner, _) -> ty_is_concrete_prim(inner)
    TyRefineT(inner, _) -> ty_is_concrete_prim(inner)
    _ -> false
  }
}

# same-prim Real detection used by the `%` typer rule to
# route `Real % Real` through `impl Rem for Real` (libm `fmod`).
# Strips Dim / Refine wrappers like `ty_is_concrete_prim` does.
fn ty_is_real_head(t: Ty) : Bool {
  match t {
    TyReal -> true
    TyDimT(inner, _) -> ty_is_real_head(inner)
    TyRefineT(inner, _) -> ty_is_real_head(inner)
    _ -> false
  }
}

fn ty_same_head(a: Ty, b: Ty) : Bool {
  match inf_ty_head_name(a) {
    None -> false
    Some(an) -> match inf_ty_head_name(b) {
      None -> false
      Some(bn) -> an == bn
    }
  }
}

# predicate gating the operator → protocol-method
# rewrite. Returns true iff BOTH operands have a concrete non-primitive
# head type. Concrete = not a `TyVar` after substitution; non-primitive
# = not `Int`, `Real`, or one of those wrapped in `TyDimT` /
# `TyRefineT`. Mixed cases (`Int + Complex`) fall through to the
# unify-both-sides rule, which produces the standard mismatch
# diagnostic.
fn binop_should_dispatch_proto(lt: Ty, rt: Ty) : Bool =
  ty_is_concrete_nonprim(lt) and ty_is_concrete_nonprim(rt)


# heterogeneous-friendly variant. Returns the head type
# name of the dispatch receiver (`Self`) when an impl matching the
# (lhs, rhs) pair exists in the post-lower-protocols snapshot, or
# None when no such impl is registered. The choice between
# `(receiver=lhs, arg=rhs)` and `(receiver=rhs, arg=lhs)` is
# stable: the left operand wins iff `impl P[Rhs] for Lhs` is
# registered; otherwise the mirror `impl P[Lhs] for Rhs` is tried.
# Returning Some signals "route to __proto_<op>(l, r) and let the
# resolver pick the impl". Returning None lets the caller fall
# through to the unify-and-emit primitive arithmetic path (for
# matching primitive pairs) or the standard mismatch diagnostic
# (for everything else).
type BinopProtoChoice = BPC(String, [String])
#                          recv     proto_args (head names)

fn binop_pick_proto_dispatch(impls: [ProtoImplReg], proto: String, op: String,
                              lt: Ty, rt: Ty, sub: Subst) : Option[BinopProtoChoice] {
  let l = apply_ty(sub, lt)
  let r = apply_ty(sub, rt)
  let l_name = inf_ty_head_name(l)
  let r_name = inf_ty_head_name(r)
  match l_name {
    None -> None
    Some(ln) -> match r_name {
      None -> None
      Some(rn) -> {
        # Try (receiver = lhs, arg = rhs) first.
        if impl_pair_exists(impls, proto, op, ln, [rn]) {
          Some(BPC(ln, [rn]))
        # Mirror: (receiver = rhs, arg = lhs).
        } else if impl_pair_exists(impls, proto, op, rn, [ln]) {
          Some(BPC(rn, [ln]))
        } else {
          None
        }
      }
    }
  }
}

fn impl_pair_exists(impls: [ProtoImplReg], proto: String, op: String,
                     recv: String, args: [String]) : Bool {
  match impls {
    [] -> false
    [it, ...rest] -> match it {
      PIR(p, t, o, _, ans, _) ->
        if p == proto and t == recv and o == op and arg_names_match(ans, recv, args) {
          true
        } else {
          impl_pair_exists(rest, proto, op, recv, args)
        }
    }
  }
}

# legacy `impl P for X` is registered with arg_names = [].
# For matching purposes treat it as `impl P[X] for X` (i.e. the
# homogeneous default). The new heterogeneous form
# `impl P[Y] for X` registers arg_names = [Y]; matching is exact.
#[doc("infer: `arg_names_match` — typer entry point invoked by the driver.")]
pub fn arg_names_match(reg_args: [String], recv: String, want: [String]) : Bool {
  match reg_args {
    [] -> match want {
      [] -> true
      [w] -> w == recv
      _ -> false
    }
    _ -> eff_op_names_eq(reg_args, want)
  }
}

fn eff_op_names_eq(a: [String], b: [String]) : Bool {
  match a {
    [] -> match b { [] -> true _ -> false }
    [x, ...xrest] -> match b {
      [] -> false
      [y, ...yrest] -> x == y and eff_op_names_eq(xrest, yrest)
    }
  }
}

fn ty_is_concrete_nonprim(t: Ty) : Bool {
  match t {
    TyInt           -> false
    TyReal          -> false
    TyVarT(_)       -> false
    TyDimT(inner, _)    -> ty_is_concrete_nonprim(inner)
    TyRefineT(inner, _) -> ty_is_concrete_nonprim(inner)
    TyCon(_, _, _)     -> true
    _               -> false
  }
}

# build `ECall(EVar("__proto_<method>"), [l, r])` and walk
# it through `synth_call`. The lower-protocols pass has already
# generated the dispatcher fn under that name (when the matching
# protocol is declared); the post-inference rewrite then redirects to
# `__pimpl_<P>_<T>_<op>`.
fn binop_proto_method(op: String) : String {
  if op == "+" { "add" }
  else if op == "-" { "sub" }
  else if op == "*" { "mul" }
  else if op == "%" { "rem" }
  else { "div" }
}

fn synth_binop_proto(st: InferState, op: String, le: Expr, re: Expr,
                      line: Int, col: Int) : Inferred / Console + File + Mutable {


  let dispatcher = inf_proto_dispatcher_name(binop_proto_method(op))
  let callee = mk_expr(EVar(dispatcher), line, col)
  synth_call(st, callee, [le, re], line, col)
}

# both operands share a concrete TyCon head and at least one carries
# a unit decoration — the shapes where protocol dispatch would
# otherwise erase the units (the impl signature is the bare carrier).
fn binop_same_head_dimmed(lt: Ty, rt: Ty) : Bool =
  ty_same_head(lt, rt) and (ty_is_dimmed(lt) or ty_is_dimmed(rt))

fn ty_is_dimmed(t: Ty) : Bool = match t {
  TyDimT(_, _) -> true
  TyRefineT(inner, _) -> ty_is_dimmed(inner)
  _ -> false
}

# `*` / `/` over dimensioned protocol operands: combine the units the
# way the primitive dim path does, run the Module formation guard on
# the combined unit, dispatch to the impl on the bare carriers, and
# stamp the combined unit back onto the impl's result. `USD·USD` dies
# in the guard; `Decimal<USD> · Decimal` keeps the habitant; a full
# cancellation (`USD/USD`) yields the bare carrier.
fn synth_binop_proto_dim_mul(st: InferState, op: String,
                             le: Expr, lt: Ty, re: Expr, rt: Ty,
                             line: Int, col: Int) : Inferred / Console + File + Mutable {
  let ls = ty_split_dim(lt, st.sub)
  let rs = ty_split_dim(rt, st.sub)
  let combined = if op == "*" { UMul(ls.dim, rs.dim) }
                 else { UMul(ls.dim, UInv(rs.dim)) }
  let s1 = st_check_atomic_unit(st, op, combined, line, col)
  let inf = synth_binop_proto(s1, op, le, re, line, col)
  let base = (ty_split_dim(inf.ty, inf.st.sub)).base
  let ty = dim_collapse(base, unit_canon(combined))
  mk_inferred(inf.st, ty, with_ty(inf.expr, ty))
}

# Try to extract a compile-time integer literal from an expression.
# Recognises plain `EInt(n)` and the unary-minus form
# `EUnop("-", EInt(n))` produced by the parser for negative literals
# (the parser does not fold `-3` into `EInt(-3)`). Anything else —
# including `EBinop("-", EInt(0), EInt(3))` and bound names — returns
# `None`; the typer then refuses to lift a non-trivial unit through
# `^`.
fn try_int_literal(e: Expr) : Option[Int] {
  match e.kind {
    EInt(n) -> Some(n)
    EUnop(uop, inner) ->
      if uop == "-" {
        match inner.kind {
          EInt(n) -> Some(0 - n)
          _ -> None
        }
      } else { None }
    _ -> None
  }
}

fn synth_dim_pow(st: InferState, lt: Ty, le: Expr,
                  rt: Ty, re: Expr, line: Int, col: Int) : Inferred / Console + File + Mutable {


  # The exponent of `^` is always Int — pin it. We probe with a
  # targeted diagnostic so `r ^ 3.0` or `r ^ "a"` say "exponent of `^`
  # must be Int" instead of leaking the generic unifier's
  # expected/found ordering (the previous
  # `st_unify(rt, TyInt, ...)` passed args in the wrong order and
  # reported "expected: Real, found: Int" when the user wrote
  # `Real ^ Real`).
  let rt_now = apply_ty(st.sub, rt)
  let s1 = match unify_env(st.env, rt_now, TyInt, st.sub) {
    Some(s2) -> st_set_sub(st, s2)
    None -> {
      diag_error(st.file, line, col,
        "exponent of `^` must be Int")
      diag_note(string_concat("found: ", inf_ty_to_string(rt_now)))
      diag_help("convert the exponent to Int (e.g. `real_to_int(x)`), or use a stdlib helper like `Numeric.pow_int(base, n)` if the integer exponent is available separately")
      st_bump_err(st)
    }
  }
  let ls = ty_split_dim(apply_ty(s1.sub, lt), s1.sub)
  let lit = try_int_literal(re)
  match lit {
    Some(n) -> {
      # Literal exponent: lift the unit. `unit_canon` simplifies
      # `m^0` → 1 and `m^1` → m so trivial cases collapse cleanly.
      let new_unit = unit_canon(UPow(ls.dim, n))
      let s2 = st_check_atomic_unit(s1, "^", new_unit, line, col)
      let ty = dim_collapse(apply_ty(s2.sub, ls.base), new_unit)
      mk_inferred(s2, ty, binop_root("^", le, re, line, col, ty))
    }
    None -> {
      # Non-literal exponent. Only safe when the base has a trivial
      # unit; otherwise we would owe a dependent type.
      let canon_dim = unit_canon(ls.dim)
      if not unit_is_one(canon_dim) {
        diag_error(st.file, line, col,
          "operator `^` requires a literal Int exponent when the base has a non-trivial unit")
        diag_help("annotate the exponent as a literal (e.g. `r ^ 3`) or strip the unit on the base before the call")
        let ty = apply_ty(s1.sub, ls.base)
        mk_inferred(st_bump_err(s1), ty, binop_root("^", le, re, line, col, ty))
      } else {
        # Bare numeric base: result keeps the base type.
        let ty = apply_ty(s1.sub, ls.base)
        mk_inferred(s1, ty, binop_root("^", le, re, line, col, ty))
      }
    }
  }
}

# type rule for `*` and `/` over (possibly) dimensioned values.
# Splits each operand into (base_ty, unit_expr) — bare Real → unit
# `1`, TyDimT(b, u) → (b, u). The base types are unified; the units
# are combined into the result.
type DimSplit = { base: Ty, dim: UnitExprT }

fn ty_split_dim(t: Ty, s: Subst) : DimSplit {
  match apply_ty(s, t) {
    TyDimT(b, u) -> DimSplit { base: b, dim: u }
    other -> DimSplit { base: other, dim: UOne }
  }
}

# Primitive arithmetic never succeeds on a String operand (the runtime
# add/sub/mul/div traps on non-numeric payloads), so reject it at the
# operator. The dim wrapper is stripped first, so a String-carrier
# monetary value hits this exactly like a bare String.
fn st_check_arith_string(st: InferState, op: String, t: Ty,
                         line: Int, col: Int) : InferState / Console + File + Mutable {
  let split = ty_split_dim(t, st.sub)
  match split.base {
    TyString -> {
      diag_error(st.file, line, col,
        concat_all(["arithmetic operator `", op,
                    "` requires a numeric operand, found `String`"]))
      diag_help("string concatenation is `++`")
      st_bump_err(st)
    }
    _ -> st
  }
}

fn synth_dim_mul_div(st: InferState, op: String, lt: Ty, le: Expr,
                     rt: Ty, re: Expr, line: Int, col: Int) : Inferred / Console + File + Mutable {


  let ls = ty_split_dim(lt, st.sub)
  let rs = ty_split_dim(rt, st.sub)
  let what = string_concat("arithmetic operator '", string_concat(op, "'"))
  let s0 = st_check_arith_string(st, op, lt, line, col)
  let s1 = st_unify(s0, ls.base, rs.base, what, line, col)
  let combined = if op == "*" {
    UMul(ls.dim, rs.dim)
  } else {
    UMul(ls.dim, UInv(rs.dim))
  }
  let s2 = st_check_atomic_unit(s1, op, combined, line, col)
  let ty = dim_collapse(apply_ty(s2.sub, ls.base), unit_canon(combined))
  mk_inferred(s2, ty, binop_root(op, le, re, line, col, ty))
}

# Atomic-kind formation guard. Habitants of Module and Composition kinds
# have no product or power — and Semilattice habitants compound only
# through `+` in annotations — so the combined unit an operator would
# produce must keep every such habitant alone with exponent 1 (full
# cancellation is fine: `USD/USD` is a scalar ratio). Reports against
# the operator's source position; a no-op when no such kind is
# declared.
fn st_check_atomic_unit(st: InferState, op: String, u: UnitExprT,
                        line: Int, col: Int) : InferState / Console + File + Mutable {
  match st.sub.kind_theories {
    [] -> st
    _ -> {
      let t = unit_to_table_resolved(u, st.sub)
      match product_form_violation(utable_symexps(t), list_length(t.vars),
                                   st.sub.kind_theories) {
        None -> st
        Some(sym) -> {
          let kind = kind_sym_kind(sym)
          diag_error(st.file, line, col,
            concat_all(["operator `", op, "` cannot combine `", kind,
                        "` quantities: the result unit `",
                        inf_unit_expr_display(utable_to_tree(t)),
                        "` does not exist"]))
          diag_note(
            if kind_is_semilattice(st.sub.kind_theories, kind) {
              concat_all(["`", kind,
                "` habitants join with `+` inside `<>` annotations; operators never combine them"])
            } else {
              concat_all(["`", kind,
                "` habitants stand alone: a quantity is either scalar or carries exactly one habitant with exponent 1 — habitant products and powers are not expressible"])
            })
          st_bump_err(st)
        }
      }
    }
  }
}

# `++` typer. Two hardcoded rules:
#   String ++ String  : String
#   [a]    ++ [a]     : [a]
# We probe the lhs's resolved type first; if it is a TyVar we fall
# back to the rhs's resolved type (mirror case). If neither side
# pins the operator, we report a targeted diagnostic — the
# concatenation operator is intentionally not generic, the way `+`
# is intentionally not overloaded for strings.
fn synth_concat(st: InferState, lt: Ty, le: Expr, rt: Ty, re: Expr, line: Int, col: Int) : Inferred / Console + File + Mutable {


  let lt_now = apply_ty(st.sub, lt)
  match lt_now {
    TyString -> concat_finish(st, TyString, lt, le, rt, re, line, col)
    TyListT(elem) -> concat_finish(st, TyListT(elem), lt, le, rt, re, line, col)
    _ -> {
      let rt_now = apply_ty(st.sub, rt)
      match rt_now {
        TyString -> concat_finish(st, TyString, lt, le, rt, re, line, col)
        TyListT(elem) -> concat_finish(st, TyListT(elem), lt, le, rt, re, line, col)
        _ -> {
          diag_error(st.file, line, col,
            "operator `++` requires both operands to be `String` or both to be `[T]`")
          diag_help("annotate one of the operands so the compiler can pick the right rule")
          mk_inferred(st_bump_err(st), TyAny,
            with_ty(mk_expr(EBinop("++", le, re), line, col), TyAny))
        }
      }
    }
  }
}

fn concat_finish(st: InferState, target: Ty, lt: Ty, le: Expr, rt: Ty, re: Expr, line: Int, col: Int) : Inferred / Console + File + Mutable {


  let s1 = st_unify(st, lt, target, "concat operator", line, col)
  let s2 = st_unify(s1, rt, target, "concat operator", line, col)
  let result_ty = apply_ty(s2.sub, target)
  let root = with_ty(mk_expr(EBinop("++", le, re), line, col), result_ty)
  mk_inferred(s2, result_ty, root)
}

fn synth_unop(st: InferState, op: String, x: Expr, line: Int, col: Int) : Inferred / Console + File + Mutable {


  let r = synth(st, x)
  if op == "not" {
    let s1 = st_unify(r.st, r.ty, TyBool, "logical 'not'", line, col)
    let root = with_ty(mk_expr(EUnop(op, r.expr), line, col), TyBool)
    mk_inferred(s1, TyBool, root)
  } else {
    let root = with_ty(mk_expr(EUnop(op, r.expr), line, col), r.ty)
    mk_inferred(r.st, r.ty, root)
  }
}

fn synth_if(st: InferState, c: Expr, t_: Expr, eo: Option[Expr], line: Int, col: Int) : Inferred / Console + File + Mutable {


  let rc = synth(st, c)
  let s1 = st_unify(rc.st, rc.ty, TyBool, "if condition", line, col)
  let rt = synth(s1, t_)
  match eo {
    None -> {
      let root = with_ty(mk_expr(EIf(rc.expr, rt.expr, None), line, col), TyUnit)
      mk_inferred(rt.st, TyUnit, root)
    }
    Some(ee) -> {
      let re = synth(rt.st, ee)
      let s2 = st_unify(re.st, rt.ty, re.ty, "if/else branches", line, col)
      let ty = apply_ty(s2.sub, rt.ty)
      let root = with_ty(mk_expr(EIf(rc.expr, rt.expr, Some(re.expr)), line, col), ty)
      mk_inferred(s2, ty, root)
    }
  }
}

fn synth_lambda(st: InferState, ps: [Param], body: Expr, line: Int, col: Int) : Inferred / Console + File + Mutable =
  synth_lambda_threaded(st, ps, body, None, line, col)

# Like `synth_lambda`, but when `expected_first` is `Some(et)` the
# first parameter's type is unified with `et` BEFORE the body is
# walked. Point-free sections (`.method()`, `.a.b`) need the receiver
# pinned from the combinator's element type up front: the body's UFCS
# dispatch (`__pl.length()`) cannot defer the way a bare field access
# can, so the receiver must already be concrete when synth reaches it.
fn synth_lambda_threaded(st: InferState, ps: [Param], body: Expr,
                          expected_first: Option[Ty], line: Int, col: Int) : Inferred / Console + File + Mutable {


  let outer = st
  let added0 = add_infer_params(st, ps)
  let added = match expected_first {
    None -> added0
    Some(et) -> match added0.tys {
      [] -> added0
      [t0, ...] ->
        InferredParams { st: st_unify(added0.st, t0, et,
                                       "point-free receiver", line, col),
                          tys: added0.tys }
    }
  }
  # walk the body in an isolated row context. Effects
  # invoked inside the lambda body MUST NOT leak to the enclosing
  # function's row — they belong to the lambda type's own row.
  # Same pattern as `synth_handle` (snapshot, reset, walk, restore).
  # closure-capture: tagging stays enabled across the
  # lambda boundary now that `kai_alias_<a>_id` is captured by the
  # closure (see `fv_expr`'s tagged-op detection plus the
  # `__alias_id__<a>` lane in `emit_closure_caps` /
  # `emit_lam_cap_reads`). Without this the typer would emit a
  # bare dispatch key for every op call inside the lambda and the
  # innermost-name lookup would shadow outer cap binders — the
  # exact failure mode that broke `var n = ...; var m = ...; while
  # @n < lim { ... }` and routed `@n` to `m`.
  let prev_row = added.st.row
  let st_row = st_set_row(added.st, [])
  let st_in = st_row
  # `e!` propagates from the enclosing function, not from a
  # closure. Clear ret_ty inside the lambda body so any `!` site
  # inside reports a clean diagnostic. st_restore_entries (below)
  # restores ret_ty from `outer` after the walk, so subsequent
  # siblings of the lambda see the function-level ret_ty unchanged.
  let st_in2 = st_set_ret_ty(st_in, None)
  # the same boundary applies to clause_resume.
  # `resume(v)` only makes sense inside the immediate handler clause
  # that introduced it; a lambda lifted out of the clause body does
  # not have access to the clause's continuation. Without this, a lambda
  # inside `raise(resume) -> { (() => resume(v))() }` would type-
  # check `resume(v)` against the outer clause's answer/state types
  # — silently accepting code that, at runtime, calls the wrong
  # continuation. Mirror the alias-tag boundary at line 14294.
  # inside a lambda lifted out of the clause body, `resume` is an
  # ordinary identifier (a shadowing param binds it; otherwise it falls
  # to the env), so the value-position rejection does not apply here.
  let st_in3 = st_set_in_clause(st_set_clause_resume(st_in2, None), false)
  let rb = synth(st_in3, body)
  # keep the row labels in their raw form so a downstream
  # `unify_row` partition can see TyVar payloads (an `Actor[?T]` mint-
  # ed by `Actor.self()` inside this body should bias the enclosing
  # handler's `Msg` toward that `?T`). The previous `apply_labels`
  # call substituted bound TyVars away and forced the partition into
  # a row-position lottery; `find_remove_label_best`'s
  # `find_remove_label_tyvar_args` branch needs the raw shape to
  # prefer body-local labels over callee-propagated concrete labels.
  #
  # apply the Mutable-masking pass to the lambda
  # body too. `infer_decl` masks `Mutable` for a top-level fn whose
  # body only mutates locally-constructed Arrays (the `var i = 0`
  # desugar lowers to a `let i__slot = array_make(1, 0)` slot the
  # caller never observes), but a lambda body went through `synth`
  # alone and never reached that pass — so a `var` inside a thunk
  # leaked `Mutable` into the lambda's row. The thunk
  # `() => { var i = 0  i := @i + 1 }` would surface as
  # `() -> Unit / Mutable + ?e`, which then refused to unify against a
  # higher-order slot declared `() -> Unit / Stdout`. Masking here is
  # scoped to the lambda's own params + body and is a no-op when
  # `Mutable` is not in the body row, mirroring the fn-decl call site.
  let rb_masked = mask_local_mutable_demand(rb.st, ps, rb.expr)
  let lambda_row_labels = rb_masked.row
  let st_after = st_set_row(rb_masked, prev_row)
  let st2 = st_restore_entries(outer, st_after)
  # lambdas carry an *open* row with a
  # fresh tail var. Closed rows pinned row-polymorphic call sites
  # too eagerly: `while(pred, body)` would unify the pure-pred's
  # closed-empty row with `while`'s `e`, then reject `body`'s
  # `Stdout` row when the same `e` was already bound to empty.
  # The open form `[labels] + ?eN` lets sibling args' rows unify
  # via Rémy-style tail unification — the row variable absorbs
  # whatever residual labels each arg performs.
  let fr = subst_fresh_row(st2.sub)
  let st3 = st_set_sub(st2, fr.subst)
  let lam_row = Row { labels: lambda_row_labels,
                       tail: Some(fr.id),
                       display_alias: None }
  let lam_ty = TyFnT(apply_tys(st3.sub, added.tys),
                     apply_ty(st3.sub, rb.ty),
                     lam_row)
  let root = with_ty(mk_expr(ELambda(ps, rb.expr), line, col), lam_ty)
  mk_inferred(st3, lam_ty, root)
}

# build a closed Row from a labels list, dropping any
# duplicates that survived the body-row accumulator. Used by
# `synth_lambda` to attach the body's effect set to the lambda
# type itself.
fn labels_to_closed_row(labels: [Label]) : Row =
  Row { labels: labels, tail: None, display_alias: None }

fn synth_list_expr(st: InferState, els: [ListElem], line: Int, col: Int) : Inferred / Console + File + Mutable {


  let rv = st_fresh_ty(st)
  let elems = synth_list_elems(rv.st, els, rv.ty, line, col)
  let ty = TyListT(apply_ty(elems.st.sub, rv.ty))
  let root = with_ty(mk_expr(EList(elems.elems), line, col), ty)
  mk_inferred(elems.st, ty, root)
}

fn synth_list_elems(st: InferState, els: [ListElem], elem: Ty, line: Int, col: Int) : InferredElems / Console + File + Mutable {


  match els {
    [] -> InferredElems { st: st, elems: [] }
    [el, ...rest] -> match el {
      ElPlain(ex) -> {
        let r = synth(st, ex)
        let s1 = st_unify(r.st, elem, r.ty, "list element", line, col)
        let rr = synth_list_elems(s1, rest, elem, line, col)
        InferredElems { st: rr.st, elems: [ElPlain(r.expr), ...rr.elems] }
      }
      ElSpread(ex) -> {
        let r = synth(st, ex)
        let s1 = st_unify(r.st, TyListT(elem), r.ty, "list spread", line, col)
        let rr = synth_list_elems(s1, rest, elem, line, col)
        InferredElems { st: rr.st, elems: [ElSpread(r.expr), ...rr.elems] }
      }
    }
  }
}

fn synth_range(st: InferState, lo: Expr, hi: Expr, stp: Option[Expr], line: Int, col: Int) : Inferred / Console + File + Mutable {


  let rl = synth(st, lo)
  let s1 = st_unify(rl.st, rl.ty, TyInt, "range start", line, col)
  let rh = synth(s1, hi)
  let s2 = st_unify(rh.st, rh.ty, TyInt, "range end", line, col)
  match stp {
    None -> {
      let root = with_ty(mk_expr(ERange(rl.expr, rh.expr, None), line, col), TyListT(TyInt))
      mk_inferred(s2, TyListT(TyInt), root)
    }
    Some(se) -> {
      let rs_ = synth(s2, se)
      let s3 = st_unify(rs_.st, rs_.ty, TyInt, "range step", line, col)
      let root = with_ty(mk_expr(ERange(rl.expr, rh.expr, Some(rs_.expr)), line, col), TyListT(TyInt))
      mk_inferred(s3, TyListT(TyInt), root)
    }
  }
}

# `x |> f(y, z)` pipes `x` into `f` as its first argument. Rather
# than desugar and re-infer, we manually emit the same unify chain
# that an ECall would run, and rebuild EPipe around it so the emitter
# still sees the original shape (stage 2's emitter has its own
# desugaring of EPipe).
type PipeRes = { st: InferState, ty: Ty, rhs: Expr }

fn synth_pipe(st: InferState, lhs: Expr, rhs: Expr, line: Int, col: Int) : Inferred / Console + File + Mutable {


  let att = try_fuse_terminal_fold(st, lhs, rhs, line, col)
  match att.fused {
    Some(inf) -> inf
    None      -> synth_pipe_plain(att.st, lhs, rhs, line, col)
  }
}

fn synth_pipe_plain(st: InferState, lhs: Expr, rhs: Expr, line: Int, col: Int) : Inferred / Console + File + Mutable {


  let rl = synth(st, lhs)
  let res = match rhs.kind {
    ECall(f, pa) -> {
      # when the callee is a bare-name `EVar(nm)` whose
      # qualified env has multiple candidates (e.g. `filter` exported
      # by both `option` and `list`), narrow by the LHS's type — the
      # LHS becomes the callee's first argument under the pipe
      # rewrite. Fall back to the legacy `synth(f)` path when the
      # callee is not bare or has a single candidate.
      let rf = match f.kind {
        EVar(nm) -> {
          let candidates = ty_env_collect_candidates(rl.st.env, nm)
          if list_length(candidates) < 2 { synth(rl.st, f) }
          else {
            let lhs_ty = apply_ty(rl.st.sub, rl.ty)
            match pick_by_first_arg(rl.st, candidates, lhs_ty) {
              None -> synth(rl.st, f)
              Some(pick) -> {
                let st_inst = if pick.fresh == [] and pick.unit_fresh == [] {
                  pick.st
                } else {
                  st_push_inst(pick.st, CS(nm, f.line, f.col, pick.fresh, pick.unit_fresh, None))
                }
                let callee_node = with_ty(mk_expr(EModCall(pick.mod, nm), f.line, f.col), pick.inst_ty)
                mk_inferred(st_inst, pick.inst_ty, callee_node)
              }
            }
          }
        }
        _ -> synth(rl.st, f)
      }
      let ra = synth_many(rf.st, pa)
      let rv = st_fresh_ty(ra.st)
      # same open-row trick `synth_call`
      # uses — let the callee's row tail bind to a fresh row var so
      # `xs |> each(handler)` against a row-polymorphic combinator
      # passes type checking when `handler` carries effect labels.
      let fr = subst_fresh_row(rv.st.sub)
      let st_fresh = st_set_sub(rv.st, fr.subst)
      let expected_row = Row { labels: [], tail: Some(fr.id), display_alias: None }
      let expected = TyFnT([rl.ty, ...ra.tys], rv.ty, expected_row)
      let st2 = st_unify(st_fresh, rf.ty, expected, "pipe call", line, col)
      let ty = apply_ty(st2.sub, rv.ty)
      let typed_rhs = with_ty(mk_expr(ECall(rf.expr, ra.exprs), rhs.line, rhs.col), ty)
      PipeRes { st: st2, ty: ty, rhs: typed_rhs }
    }
    _ -> {
      let rf = synth(rl.st, rhs)
      let rv = st_fresh_ty(rf.st)
      let fr = subst_fresh_row(rv.st.sub)
      let st_fresh = st_set_sub(rv.st, fr.subst)
      let expected_row = Row { labels: [], tail: Some(fr.id), display_alias: None }
      let expected = TyFnT([rl.ty], rv.ty, expected_row)
      let st2 = st_unify(st_fresh, rf.ty, expected, "pipe call", line, col)
      let ty = apply_ty(st2.sub, rv.ty)
      PipeRes { st: st2, ty: ty, rhs: rf.expr }
    }
  }
  let root = with_ty(mk_expr(EPipe(rl.expr, res.rhs), line, col), res.ty)
  mk_inferred(res.st, res.ty, root)
}

# head-owner cache.
#
# `synth_pipe_dispatch` rewrites `xs | f`, `xs || f`, and `xs |? p`
# into a qualified call against the module that owns the LHS's head
# type — `List → list.map`, `MyBox → mypkg.mybox.map`, etc.
#
# Earlier this was a hardcoded `if head == "List" { Some("list") }`
# table that knew exactly one entry. That made any downstream package
# wishing to participate in `|` (ahu.stream.Source[T], henua.EventBus,
# manutara stream/sink types, …) require a recompile of `kaic2`.
# Unacceptable for a downstream-package ecosystem.
#
# Why convention beats annotation/protocol here:
#   * Operator protocols (`+`-style) require the op's signature to fit
#     `(Self, X) -> Y` shapes a protocol can express. `map`'s shape is
#     `F[A] -> (A -> B) -> F[B]` — higher-kinded. CLAUDE.md bans HKT in
#     the typer; protocols cannot express it.
#   * Effect rows in operator-protocol ops are also banned, but `map`
#     against an effectful function carries the function's effect row
#     into its own signature — protocols would have to admit row-poly
#     ops, which they don't.
#   * Annotations (`#pipe_dispatch`) cost a parser change and a new
#     visible concept for ~5 stdlib + future package decls. Convention
#     is free at the surface, costs ~70 LOC inside the compiler, and
#     mirrors how qualified-name resolution already works for
#     `EModCall`-driven calls.
#
# The cache shape: `[HOE(head_name, [module_path])]`. A single-element
# `module_path` list is the dispatchable case; a multi-element list is
# ambiguous and the typer reports the modules at the use site so the
# user can pick `mod.T` annotation or rename one of the conflicting
# `pub type T` declarations.
#
# Canonical signatures package authors must follow for their `pub type T`
# to participate in `|` / `||` / `|?` (the LHS receiver is always the
# first argument; the function/predicate is second; the return wraps
# the same head type):
#
#   pub fn map[A, B, e](xs: T[A], f: (A) -> B / e) : T[B] / e
#   pub fn flat_map[A, B, e](xs: T[A], f: (A) -> T[B] / e) : T[B] / e
#   pub fn filter[A, e](xs: T[A], p: (A) -> Bool / e) : T[A] / e
#
# A head carrying an `(element, row)` parameter list — `Stream[t, e]`,
# the streaming carrier whose effect row is a type parameter — also
# rides the pipes: dispatch is by head NAME (arity-agnostic), and the
# whole LHS type unifies against the canonical receiver, so the row
# slot threads via the row carrier (`row_arg_carrier`). The element
# unifies against the first slot; the row threads as `e`.
#
# A package that ships `map` with a swapped argument order or a missing
# row var still surfaces the standard call-inference signature mismatch
# — the typer does not need a separate diagnostic for "your map shape
# is wrong". (An extra *type* parameter that is NOT the trailing
# effect-row slot still mismatches; only the legitimate `(element, row)`
# shape is accepted.)
#
# Construction: linear over `(decls, modules)`, called once per
# `compile_source` invocation right before `infer_program_with_protos`
# runs the typer over the same decl stream. Lookup at each pipe call
# site is `find_head_owner` walking the cache; it is a small linear
# list (one entry per `pub type` across all modules in scope) and the
# constant-factor cost dominates over a hash map until the program
# crosses ~hundreds of pub types — hello-world programs sit at <50.

# Result of `find_head_owner` lookup. Distinguishing the three states
# at the use site lets the typer print the four error texts
# verbatim (missing module, missing op, ambiguous, signature mismatch
# falls through to the standard call-inference path).
type HeadLookup
  = HLOk(String)
  # Two or more modules declare `pub type Head`. The user must
  # disambiguate via a qualified annotation on the LHS.
  | HLAmbiguous([String])
  | HLNone

fn find_head_owner_loop(es: [HeadOwnerEntry], head: String) : HeadLookup {
  match es {
    [] -> HLNone
    [e, ...rest] -> match e {
      HOE(name, mods) ->
        if name == head {
          match mods {
            [m]      -> HLOk(m)
            [_, _, ...] -> HLAmbiguous(mods)
            _        -> HLNone
          }
        } else { find_head_owner_loop(rest, head) }
    }
  }
}

fn find_head_owner(env: TyEnv, head: String) : HeadLookup =
  find_head_owner_loop(env.head_owners, head)

# Build the head-owner cache from a `[Decl]` post-`expand_imports`
# stream paired with the module table the import resolver collected.
# For each `pub type T`, find the module(s) that export `T` (i.e. the
# `ModuleEntry` whose `exports` list contains the type name). Folding
# the same `T` from two modules produces a multi-element entry so the
# lookup can report ambiguity at the use site instead of silently
# picking the first definer.
#
# `pub type T` declared in the root file (not associated with any
# module entry) intentionally does NOT participate in pipe dispatch.
# Pipes against root-file types fall through to the "no module
# declaring type" diagnostic — which is the correct behaviour, since
# the root file has no qualified surface that a pipe rewrite can
# target. The user can extract the type into a module if they want
# pipes to dispatch against it.
#[doc("infer: `build_head_owner_map` — typer entry point invoked by the driver.")]
pub fn build_head_owner_map(decls: [Decl], modules: [ModuleEntry],
                         target_mod: String, edition: String) : [HeadOwnerEntry] {
  # gate the convention-based pipe dispatch on
  # edition >= hanga-roa. Pre-hanga-roa (tongariki) packages keep only
  # the seeded `List → list` mapping. User `pub type` heads
  # therefore route through the bare-name fallback in
  # `synth_pipe_dispatch` ("no module declaring type `T` is in scope"
  # via HLNone). An empty edition string also falls into the
  # tongariki branch.
  let walk_user_types = edition_at_least(edition, "hanga-roa")
  if walk_user_types {
    let pub_type_names = collect_pub_type_names(decls, [])
    # Filter out the target file's ME from the dispatch search. The
    # target ME's `exports` list is built over the post-`expand_imports`
    # decl stream, which transitively includes every imported module's
    # decls — so a `pub type T` exported by an imported module appears
    # in BOTH the imported module's ME and the target ME. Without this
    # filter every imported `pub type` would surface as ambiguously
    # declared by `(<owning_module>, <target_basename>)`. Filtering by
    # name preserves the cache's invariant that each entry's `mods`
    # list contains only modules that genuinely own the `pub type`
    # declaration. Pipes against `pub type` declared in the root file
    # are intentionally not dispatchable — the rejection diagnostic
    # ("no module declaring type `T` is in scope") is the design.
    let modules_filtered = filter_out_target(modules, target_mod, [])
    let from_decls = build_head_owner_loop(pub_type_names, modules_filtered, [])
    # `List` is a built-in head with no `pub type List`
    # declaration in any user-visible module — the parser stamps `[T]`
    # syntax directly to `TyListT`, and `core/list.kai` carries the
    # canonical `pub fn map / flat_map / filter` against it. Register
    # the `List → list` mapping unconditionally so the cache mirrors
    # what the earlier hardcoded `head_module_for` returned for the
    # only entry it knew. The dispatch site falls back to a bare-name
    # callee (`EVar("map")`) when `list::map` is not registered in the
    # qualified env — the test-sugars harness exercises this path by
    # invoking `kaic2` against `[1..6] |? p` without
    # `--core core/list.kai`, relying on the runtime
    # `kai_core_map` / `kai_core_filter` stubs.
    [HOE("List", ["list"]), ...from_decls]
  } else {
    # Tongariki: only the seeded built-in `List → list` participates.
    # User-defined `pub type T` is invisible to pipe dispatch and the
    # rejection diagnostic falls through to the standard HLNone path.
    [HOE("List", ["list"])]
  }
}

fn collect_pub_type_names(ds: [Decl], acc: [String]) : [String] {
  match ds {
    [] -> acc
    [d, ...rest] -> collect_pub_type_names(rest, collect_pub_type_name_one(d, acc))
  }
}

fn collect_pub_type_name_one(d: Decl, acc: [String]) : [String] = match d {
  DType(true, name, _, _, _, _, _, _) ->
    if list_has(acc, name) { acc } else { [name, ...acc] }
  DDerive(_, inner, _, _) -> collect_pub_type_name_one(inner, acc)
  DUnstable(inner, _, _) -> collect_pub_type_name_one(inner, acc)
  DProtoLaws(_, inner, _, _) -> collect_pub_type_name_one(inner, acc)
  DImplAxiom(_, inner, _, _) -> collect_pub_type_name_one(inner, acc)
  DConstructor(inner, _, _) -> collect_pub_type_name_one(inner, acc)
  _ -> acc
}

fn build_head_owner_loop(names: [String], modules: [ModuleEntry],
                          acc: [HeadOwnerEntry]) : [HeadOwnerEntry] {
  match names {
    [] -> acc
    [n, ...rest] -> {
      let mods = modules_declaring_type(modules, n, [])
      match mods {
        [] -> build_head_owner_loop(rest, modules, acc)
        _  -> build_head_owner_loop(rest, modules, [HOE(n, mods), ...acc])
      }
    }
  }
}

fn filter_out_target(modules: [ModuleEntry], target: String,
                      acc: [ModuleEntry]) : [ModuleEntry] {
  match modules {
    [] -> list_reverse(acc)
    [me, ...rest] -> match me {
      ME(mn, _, _, _) ->
        if mn == target { filter_out_target(rest, target, acc) }
        else { filter_out_target(rest, target, [me, ...acc]) }
    }
  }
}

fn modules_declaring_type(modules: [ModuleEntry], head: String,
                          acc: [String]) : [String] {
  match modules {
    [] -> list_reverse(acc)
    [me, ...rest] -> match me {
      ME(mn, exports, _, _) ->
        if list_has(exports, head) {
          modules_declaring_type(rest, head, [mn, ...acc])
        } else {
          modules_declaring_type(rest, head, acc)
        }
    }
  }
}

# Attach a freshly-built head-owner cache to a `TyEnv`, preserving
# the rest of the env. Called once per compile from `compile_source`
# right before the typer runs.
fn ty_env_with_head_owners(env: TyEnv, hos: [HeadOwnerEntry]) : TyEnv =
  TyEnv { entries: env.entries, fresh: env.fresh, unions: env.unions, constructors: env.constructors,
          head_owners: hos, root_fns: env.root_fns, row_kind: env.row_kind, index: env.index }

# attach the set of root-file (user) function names to the
# env. A root `fn foo` unconditionally shadows a stdlib `pub fn foo`;
# `try_bare_call_narrow` skips receiver-type narrowing for these names
# so the user's decl wins even when its signature matches a stdlib
# export exactly. Seeded once per compile.
fn ty_env_with_root_fns(env: TyEnv, rfns: [String]) : TyEnv =
  TyEnv { entries: env.entries, fresh: env.fresh, unions: env.unions, constructors: env.constructors,
          head_owners: env.head_owners, root_fns: rfns, row_kind: env.row_kind, index: env.index }

# collect the bare names of root-file (`mo = None`)
# functions from the full program decl stream. Imported / core decls
# are tagged `Some(<mod>)` by `tag_decls_module_origin` before they
# reach the typer, so a `mo = None` DFn is by construction authored in
# the user's root file. `main` is excluded — it never collides with a
# stdlib export and is never called by name from a module body.
pub fn collect_root_fn_names(decls: [Decl]) : [String] =
  collect_root_fn_names_loop(decls, [])

fn collect_root_fn_names_loop(decls: [Decl], acc: [String]) : [String] = match decls {
  [] -> list_reverse(acc)
  [d, ...rest] -> match d {
    DFn(_, n, _, _, _, _, _, _, _, None) ->
      if n == "main" { collect_root_fn_names_loop(rest, acc) }
      else           { collect_root_fn_names_loop(rest, [n, ...acc]) }
    _ -> collect_root_fn_names_loop(rest, acc)
  }
}

# Explicit, typed rejection for the
# `Option` / `Result` heads. Returns `Some(diagnostic)` for the
# rejected heads and `None` otherwise so callers can tell apart
# "rejected by name" from "no module mapping".
fn pipe_rejection_reason(head: String, op: String) : Option[String] {
  if head == "Option" {
    Some(concat_all([
      op, "-pipe is not supported on `Option`. Use `!` for ",
      "propagation (`x!`) or `option.and_then` for explicit chaining."
    ]))
  } else if head == "Result" {
    Some(concat_all([
      op, "-pipe is not supported on `Result`. Use `!` for ",
      "propagation (`x!`) or `result.and_then` for explicit chaining."
    ]))
  } else {
    None
  }
}

# Shared lowering for `EMapPipe` / `EFlatMapPipe` /
# `EFilterPipe`. Resolves the LHS's head type, consults the head-owner
# cache built once per compile from the module table, rewrites to
# `<module>.<op>(lhs, f)` when the lookup is unambiguous, and runs the
# standard call inference path (`synth_call` against an `EModCall`
# callee — same arms the explicit `list.map(xs, f)` qualified-call
# form uses).
#
# Errors stamp `TyAny` and bump `st.errs` so cascade is graceful and
# downstream passes don't crash on a missing pipe lowering.
#
# Diagnostic shape — the four error textual forms anchor on
# the user's pipe-call site and stay verbatim across releases so LSP
# clients can match them:
#   * "no module declaring type `T` is in scope" (HLNone after the
#      cache lookup), and
#   * "module `mod.path` declares `T` but does not export `op`"
#     (HLOk(mod) but the qualified `mod::op` entry is missing — the
#     module ships the type but not the canonical fn), and
#   * "ambiguous head type `T` — `mod_a` and `mod_b` both declare it.
#     Use qualified type annotation." (HLAmbiguous), and
#   * the standard call-inference signature mismatch (when `mod::op`
#     exists but its declared shape does not unify with the pipe's
#     expected `(T[A], (A) -> ...) -> T[B]`).
# True when some protocol impl for type `head` supplies operation `op`
# (`impl Sequence for Chain` provides `map`/`foldl` for head `Chain`),
# so a pipe over that head routes through the protocol.
fn pipe_op_has_impl(impls: [ProtoImplReg], head: String, op: String) : Bool = match impls {
  [] -> false
  [PIR(_, t, o, _, _, _), ...rest] ->
    if t == head and o == op { true } else { pipe_op_has_impl(rest, head, op) }
}

# `xs | f` where `f` takes the whole container instead of the element:
# the pipe-stage parameter unifies with `lhs_ty` but not with its
# element type. That is the `|` vs `|>` confusion, not a genuine type
# error, so the caller swaps the raw `map` mismatch for a targeted
# "did you mean `|>`" diagnostic. A stage that matches neither side is
# a real mismatch and returns None.
fn pipe_stage_wants_container(env: TyEnv, sub: Subst, lhs_ty: Ty,
                                stage_ty: Ty) : Option[Ty] / Mutable {
  match apply_ty(sub, stage_ty) {
    TyFnT([p], _ret, _row) -> {
      let param = apply_ty(sub, p)
      let container = apply_ty(sub, lhs_ty)
      # An open param (a bare lambda's, still a metavariable) unifies
      # with the container for free; only a committed shape is evidence
      # the user meant apply.
      let param_open = match param {
        TyVarT(_) -> true
        TyAny     -> true
        _         -> false
      }
      let takes_container = if param_open { false } else {
        match unify_env(env, param, container, sub) {
          Some(_) -> true
          None    -> false
        }
      }
      let takes_elem = match pipe_elem_ty(container) {
        Some(et) -> match unify_env(env, param, apply_ty(sub, et), sub) {
          Some(_) -> true
          None    -> false
        }
        None -> false
      }
      if takes_container and not takes_elem { Some(param) } else { None }
    }
    _ -> None
  }
}

# The operator the user typed, recovered from the op the pipe lowers to.
fn pipe_surface_op(op: String) : String =
  if op == "flat_map" { "||" } else if op == "filter" { "|?" } else { "|" }

# The `|` → `|>` suggestion. Names the stage when it has one so the
# message reads as the user's own code, not the desugared `map` call.
fn emit_pipe_wants_apply(file: String, op: String, stage: Expr, param: Ty,
                          lhs_ty: Ty, line: Int, col: Int) : Unit / Console + File {
  let what = match callee_display_name(stage) {
    Some(nm) -> "`#{nm}` takes"
    None     -> "the stage takes"
  }
  let elem_txt = match pipe_elem_ty(lhs_ty) {
    Some(et) -> inf_ty_to_string(et)
    None     -> "the element"
  }
  diag_error(file, line, col,
    concat_all(["`", pipe_surface_op(op), "` is element-wise; ", what, " `",
      inf_ty_to_string(param), "`, not `", elem_txt, "`"]))
  diag_help("did you mean `|>` (apply to the whole value)?")
}

fn synth_pipe_dispatch(st: InferState, op: String, lhs: Expr, rhs: Expr,
                        line: Int, col: Int) : Inferred / Console + File + Mutable {


  let rl = synth(st, lhs)
  let lhs_ty = apply_ty(rl.st.sub, rl.ty)
  match inf_ty_head_name(lhs_ty) {
    None -> {
      diag_error(rl.st.file, line, col,
        concat_all([op, "-pipe requires a concrete head type on the ",
          "left-hand side; got an unresolved type variable. Annotate ",
          "the LHS or restructure the pipeline."]))
      let root = with_ty(mk_expr(EFlatMapPipe(rl.expr, rhs), line, col), TyAny)
      mk_inferred(st_bump_err(rl.st), TyAny, root)
    }
    Some(head) -> match pipe_rejection_reason(head, op) {
      Some(msg) -> {
        diag_error(rl.st.file, line, col, msg)
        let root = with_ty(mk_expr(EFlatMapPipe(rl.expr, rhs), line, col), TyAny)
        mk_inferred(st_bump_err(rl.st), TyAny, root)
      }
      None -> match find_head_owner(rl.st.env, head) {
        HLNone -> {
          diag_error(rl.st.file, line, col,
            concat_all(["no module declaring type `", head, "` is in scope"]))
          let root = with_ty(mk_expr(EFlatMapPipe(rl.expr, rhs), line, col), TyAny)
          mk_inferred(st_bump_err(rl.st), TyAny, root)
        }
        HLAmbiguous(mods) -> {
          diag_error(rl.st.file, line, col,
            concat_all(["ambiguous head type `", head, "` — ",
              join_modules_for_diag(mods),
              " all declare it. Use qualified type annotation."]))
          let root = with_ty(mk_expr(EFlatMapPipe(rl.expr, rhs), line, col), TyAny)
          mk_inferred(st_bump_err(rl.st), TyAny, root)
        }
        HLOk(module_name) -> {
          # emit `EModCall(module_name, op)` when the
          # qualified `<module>::<op>` entry is registered — that is
          # the dispatch-eligible case (the diagnostic surface
          # `pipe_no_map` checks). When
          # no qualified entry exists we fall back to a bare-name
          # callee (`EVar(op)`); this preserves the earlier
          # behaviour for the only seeded head, `List → list`, when
          # invoked by harnesses that do not load `core/list.kai`
          # as a core (the runtime `kai_core_map` /
          # `kai_core_flat_map` / `kai_core_filter` stubs
          # take over). For user-defined heads whose declaring
          # module IS in scope but ships no canonical op, the
          # bare-name fallback then triggers the standard
          # call-inference signature mismatch — distinguishable
          # from the seeded `List` case because the `from_decls`
          # branch of `build_head_owner_map` only includes user
          # heads that are actually module-resident, so reaching
          # `HLOk` for a user head implies the module IS loaded
          # and the missing qualified entry IS the user's bug.
          let qualified = ty_env_lookup_qualified(rl.st.env, module_name, op)
          # A `Shape`-protocol impl (`impl Sequence for Chain { map, ... }`)
          # provides the pipe op even when the head's module ships no
          # `map` function: emit the bare op so `resolve_protocol_calls`
          # dispatches it to `__pimpl_<P>_<head>_<op>` post-typing.
          let head_proto_op = pipe_op_has_impl(rl.st.proto_impls, head, op)
          let callee_kind = match qualified {
            Some(_) -> EModCall(module_name, op)
            None    -> EVar(op)
          }
          # emit the "module declares T but does not
          # export op" diagnostic only when the head was contributed
          # by the from_decls walk — i.e. a real user `pub type` —
          # AND the module ships no qualified op. The seeded
          # `List → list` case stays silent and routes through the
          # bare-name fallback so existing test-sugars fixtures (no
          # `--core core/list.kai`) continue to compile.
          let st_after_diag = match qualified {
            Some(_) -> rl.st
            None ->
              if head == "List" or head_proto_op { rl.st }
              else {
                diag_error(rl.st.file, line, col,
                  concat_all(["module `", module_name, "` declares `", head,
                    "` but does not export `", op, "`"]))
                st_bump_err(rl.st)
              }
          }
          let rf = synth_pipe_rhs(st_after_diag, rhs, lhs_ty)
          let rc = synth(rf.st, with_ty(mk_expr(callee_kind, line, col), TyAny))
          let rv = st_fresh_ty(rc.st)
          let fr = subst_fresh_row(rv.st.sub)
          let st_fresh = st_set_sub(rv.st, fr.subst)
          let expected_row = Row { labels: [], tail: Some(fr.id), display_alias: None }
          let expected = TyFnT([rl.ty, rf.ty], rv.ty, expected_row)
          # Use the same unify-message label as `synth_call` so existing
          # diagnostics-pinning fixtures (e.g.
          # `examples/sugars/map_pipe_type_mismatch.err.expected`)
          # match identically — the surface-level lane should not
          # change unrelated diagnostic strings.
          let pipe_callee = mk_expr(callee_kind, line, col)
          let st2 = match pipe_stage_wants_container(st_fresh.env, st_fresh.sub, rl.ty, rf.ty) {
            Some(param) -> {
              emit_pipe_wants_apply(st_fresh.file, op, rhs, param,
                                    apply_ty(st_fresh.sub, rl.ty), line, col)
              st_bump_err(st_fresh)
            }
            None ->
              st_unify_call(st_fresh, pipe_callee, rc.ty, [rl.ty, rf.ty], expected, line, col)
          }
          let ty = apply_ty(st2.sub, rv.ty)
          let fused = try_fuse_map_pipe(st2, op, rc.expr, rl.expr, rf.expr, ty, line, col)
          mk_inferred(fused.st, ty, fused.root)
        }
      }
    }
  }
}

# A pipe-lowering result: the emitted call and the threaded state.
type FusedPipe = { root: Expr, st: InferState }

# Map-map deforestation (issue #1134). When an already-lowered `map`
# stage feeds another `map` stage and both stage closures are pure,
# collapse `map(map(xs, f), g)` into `map(xs, x => g(f(x)))` — one
# traversal, one result list, zero intermediates. Types are already
# resolved here; the composed lambda is built typed (never re-synthesised)
# so the shared, in-place-mutated substitution is not forked. Any other
# `op`, an impure stage, or a non-map LHS leaves the call untouched.
fn try_fuse_map_pipe(st: InferState, op: String, callee: Expr,
                     lhs: Expr, stage: Expr, ty: Ty,
                     line: Int, col: Int) : FusedPipe {
  let unfused = with_ty(mk_expr(ECall(callee, [lhs, stage]), line, col), ty)
  if op != "map" { FusedPipe { root: unfused, st: st } }
  else { match pipe_fusion_as_map_call(lhs) {
    None -> FusedPipe { root: unfused, st: st }
    Some(inner) ->
      if fuse_stages_pure(st.sub, inner.stage, stage) {
        fuse_emit(st, callee, inner, stage, ty, line, col)
      } else { FusedPipe { root: unfused, st: st } }
  } }
}

# Both stage closures must be pure to reorder them. Reads the resolved
# effect row off each `TyFnT`; an unresolved tail is fine (lambdas are
# always open-tailed), only realised labels outside `{Mutable}` block.
fn fuse_stages_pure(sub: Subst, inner_stage: Expr, outer_stage: Expr) : Bool =
  fuse_stage_pure(sub, inner_stage) and fuse_stage_pure(sub, outer_stage)

fn fuse_stage_pure(sub: Subst, stage: Expr) : Bool =
  match pipe_fusion_fn_row(apply_ty(sub, fuse_expr_ty(stage))) {
    None      -> false
    Some(row) -> pipe_fusion_labels_pure(apply_row(sub, row).labels)
  }

# Emit the fused `map(source, compose(inner, outer))`, threading the
# fresh row tail the composed lambda needs into the substitution.
fn fuse_emit(st: InferState, callee: Expr, inner: FusedMapCall,
             stage: Expr, ty: Ty, line: Int, col: Int) : FusedPipe {
  let fr = subst_fresh_row(st.sub)
  let tys = fuse_types(fr.subst, inner.stage, stage, fr.id)
  let lam = pipe_fusion_compose(inner.stage, stage, tys, line, col)
  let fused = with_ty(mk_expr(ECall(callee, [inner.source, lam]), line, col), ty)
  FusedPipe { root: fused, st: st_set_sub(st, fr.subst) }
}

# Project the composed lambda's types off the resolved stage types:
# parameter = inner domain, mid = inner codomain, result = outer
# codomain, row = merged concrete labels under a fresh tail.
fn fuse_types(sub: Subst, inner: Expr, outer: Expr, tail: Int) : FuseTypes {
  let it = apply_ty(sub, fuse_expr_ty(inner))
  let ot = apply_ty(sub, fuse_expr_ty(outer))
  let row = Row { labels: label_concat(fuse_row_labels(sub, it), fuse_row_labels(sub, ot)),
                  tail: Some(tail), display_alias: None }
  FuseTypes { param: fuse_fn_domain(it), mid: fuse_fn_codomain(it),
              result: fuse_fn_codomain(ot), row: row }
}

fn fuse_row_labels(sub: Subst, t: Ty) : [Label] =
  match pipe_fusion_fn_row(t) {
    None      -> []
    Some(row) -> apply_row(sub, row).labels
  }

fn fuse_fn_domain(t: Ty) : Ty =
  match t {
    TyFnT([a, ...], _, _) -> a
    _                     -> TyAny
  }

fn fuse_fn_codomain(t: Ty) : Ty =
  match t {
    TyFnT(_, b, _) -> b
    _              -> TyAny
  }

fn fuse_expr_ty(e: Expr) : Ty =
  match e.ty {
    Some(t) -> t
    None    -> TyAny
  }

# Terminal-fold deforestation (issue #1134). A `map`-into-`foldl` chain
# — `xs | stage |> foldl(init, combine)` — folds over a full mapped list
# built first. When both closures are pure, rewrite to the stdlib
# `map_foldl` (or `range_map_foldl` for a range head), which folds
# `combine` over `stage(x)` in one pass, materialising nothing: the
# mapped list disappears, and a range head never allocates at all.
#
# The purity gate synthesises `stage` and `combine` in isolation to read
# their effect rows (fresh tvars each time, so this does not poison the
# shared substitution). If both are pure the raw rewrite is synthesised
# once — `synth_call` instantiates the generic stdlib scheme cleanly, so
# no node type is built by hand.
# A gated fusion attempt. `st` is threaded, never discarded: the
# isolation synths advance the fresh-tvar counter against the in-place-
# mutated substitution, so a caller that rewound the counter would
# re-mint ids the isolation pass already bound and types would silently
# cross between chains.
type FuseAttempt = { st: InferState, fused: Option[Inferred] }

type FuseGate = { st: InferState, ok: Bool }

fn try_fuse_terminal_fold(st: InferState, lhs: Expr, rhs: Expr,
                          line: Int, col: Int) : FuseAttempt / Console + File + Mutable =
  match pipe_fusion_as_terminal_fold(lhs, rhs) {
    None -> FuseAttempt { st: st, fused: None }
    Some(ff) -> {
      let g = fuse_terminal_gate(st, ff)
      if g.ok {
        # Peek the source head; the peek synth advances the fresh-tvar
        # counter and binds in the shared `sub`, so the rewrite synth must
        # continue from the RETURNED state (`peek.0`), not `g.st` — reusing
        # the old counter re-mints the peek's already-bound ids (#1186).
        let peek = fuse_source_is_protocol_seq(g.st, ff)
        let st_after = match peek { FSP(s, _) -> s }
        let is_seq = match peek { FSP(_, b) -> b }
        let rewrite = if is_seq {
          pipe_fusion_generic_fold_rewrite(ff, inf_proto_dispatcher_name("foldl"), line, col)
        } else {
          pipe_fusion_fold_rewrite(ff, line, col)
        }
        FuseAttempt { st: st_after, fused: Some(synth(st_after, rewrite)) }
      } else { FuseAttempt { st: g.st, fused: None } }
    }
  }

# A non-`List` source whose head type has a protocol `foldl` impl fuses
# via the generic single-traversal rewrite, not the `list.map_foldl`
# fast-path. Peeking the head SYNTHS the source, which mints fresh tvars and
# binds them in the shared mutable `sub`. The verdict is returned WITH the
# post-peek state so the real rewrite synth continues from the advanced
# fresh counter — reusing the caller's OLD counter would re-mint the ids the
# peek already bound, so the rewrite's stage lambda binds its param to the
# peek's stale binding (`(r) => r.active` reads `r: [Record]` → spurious
# "annotation needed", #1186). Deferred fields ARE rolled back: head
# detection needs no field resolution, and the peek's orphan receiver must
# not leak into the worklist.
type FuseSeqPeek = FSP(InferState, Bool)

fn fuse_source_is_protocol_seq(st: InferState, ff: FusedFold) : FuseSeqPeek / Console + File + Mutable {
  let r = synth(st, ff.source)
  let head_ok = match inf_ty_head_name(apply_ty(r.st.sub, r.ty)) {
    Some(head) -> head != "List" and pipe_op_has_impl(st.proto_impls, head, "foldl")
    None -> false
  }
  FSP(st_restore_deferred_fields(r.st, st.deferred_fields), head_ok)
}

# An explicit `foldl` keeps the Mutable-masked purity gate — its stage
# and combine still run, only reordered. An implicit terminal (`sum`,
# `product`, `length`) rewrites to a target with a row-less stage
# parameter — and `length` drops the stages — so it demands strictly
# empty labels.
fn fuse_terminal_gate(st: InferState, ff: FusedFold) : FuseGate / Console + File + Mutable =
  match ff.term {
    TermFoldl(_, combine) -> {
      let g = fuse_all_raw(st, ff.stages, false)
      if g.ok { fuse_raw(g.st, combine, false) } else { g }
    }
    _ -> fuse_all_raw(st, ff.stages, true)
  }

fn fuse_all_raw(st: InferState, closures: [Expr], strict: Bool) : FuseGate / Console + File + Mutable =
  match closures {
    [] -> FuseGate { st: st, ok: true }
    [c, ...rest] -> {
      let g = fuse_raw(st, c, strict)
      if g.ok { fuse_all_raw(g.st, rest, strict) } else { g }
    }
  }

# Synthesise a raw stage/combine closure solely to read its effect row.
# The typed node is discarded — only the verdict and the threaded state
# are kept. The probe's `deferred_fields` are rolled back: a stage body
# `(r) => r.field` with an unannotated `r` synthesised in isolation defers
# the field against a receiver tyvar that this probe never pins (only the
# re-synthesised rewrite call binds the real stage param to the element
# type). Left in the worklist, that orphan receiver drains to a spurious
# "annotation needed". The fresh-tvar counter and substitution still ride
# forward — rewinding those would re-mint ids the probe already bound.
fn fuse_raw(st: InferState, closure: Expr, strict: Bool) : FuseGate / Console + File + Mutable {
  let r = synth(st, closure)
  let ok = if strict { fuse_row_strict(r.st.sub, r.expr) }
           else { fuse_stage_pure(r.st.sub, r.expr) }
  FuseGate { st: st_restore_deferred_fields(r.st, st.deferred_fields), ok: ok }
}

fn st_restore_deferred_fields(st: InferState, dfs: [DeferredField]) : InferState =
  InferState { file: st.file, env: st.env, core_len: st.core_len, sub: st.sub,
               recs: st.recs, errs: st.errs, insts: st.insts, holes: st.holes,
               row: st.row, eff_uses: st.eff_uses, aliases: st.aliases,
               clause_resume: st.clause_resume, op_eff_arities: st.op_eff_arities,
               ret_ty: st.ret_ty, type_aliases: st.type_aliases, op_to_eff: st.op_to_eff, proto_impls: st.proto_impls, sums: st.sums, diags: st.diags, deferred_fields: dfs, op_payload_labels: st.op_payload_labels, op_res: st.op_res, in_clause: st.in_clause }

fn fuse_row_strict(sub: Subst, stage: Expr) : Bool =
  match pipe_fusion_fn_row(apply_ty(sub, fuse_expr_ty(stage))) {
    None      -> false
    Some(row) -> match apply_row(sub, row).labels {
      [] -> true
      _  -> false
    }
  }

# Format a list of module names for the ambiguous-head diagnostic.
# Two modules become "`a` and `b`"; three or more become "`a`, `b`,
# and `c`". Output is wrapped in backticks for the diagnostic.
fn join_modules_for_diag(mods: [String]) : String {
  match mods {
    []        -> ""
    [a]       -> concat_all(["`", a, "`"])
    [a, b]    -> concat_all(["`", a, "` and `", b, "`"])
    [a, ...rest] ->
      concat_all(["`", a, "`, ", join_modules_for_diag(rest)])
  }
}

fn synth_map_pipe(st: InferState, lhs: Expr, rhs: Expr, line: Int, col: Int) : Inferred / Console + File + Mutable =


  synth_pipe_dispatch(st, "map", lhs, rhs, line, col)

fn synth_flat_map_pipe(st: InferState, lhs: Expr, rhs: Expr, line: Int, col: Int) : Inferred / Console + File + Mutable =


  synth_pipe_dispatch(st, "flat_map", lhs, rhs, line, col)

# `xs |? p` — filter-pipe. Mirrors `synth_map_pipe` /
# `synth_flat_map_pipe` but resolves to `<module>.filter`. The
# canonical signature `(xs: [a], p: (a) -> Bool / e) : [a] / e` is
# enforced by the standard call-inference path (no special-casing).
fn synth_filter_pipe(st: InferState, lhs: Expr, rhs: Expr, line: Int, col: Int) : Inferred / Console + File + Mutable =


  synth_pipe_dispatch(st, "filter", lhs, rhs, line, col)

# Mutable provenance / masking pass.
#
# The bare `array_set` / `array_grow` builtins raise `Mutable` on the
# caller's row through their scheme (`add_core_sigs` via `fn_ty_eff`)
# when the body calls them (the desugar of
# `a[i] := v`). That over-approximates: a function that
# constructs an Array locally, mutates it before returning, and
# never lets the caller observe the act of mutation is
# semantically pure from the caller's POV (the Koka observable-
# effects discipline pinned in `docs/effects-stdlib.md`
# §`Mutable`). This pass walks the typed body, classifies each
# Mutable demand as local-non-escaping vs external, and drops
# `Mutable` from the inferred row when every demand is local.
#
# Algorithm (Pass 1 + Pass 2):
#   Pass 1 — provenance scan. Walks every `let n = rhs` binding
#     and records `n` as "local" iff `rhs` is a direct call to
#     `array_make`, or a call to `array_set` / `array_grow`
#     whose first arg is itself a previously-recorded local
#     name. Names introduced via `var x = init` desugar to
#     `let x__slot = array_make(1, init)` and pick up the same
#     local label for free.
#   Escape scan. A name escapes if it appears as an argument
#     position of any call other than `array_make`,
#     `array_length`, `array_get`, `array_set`, `array_grow`.
#     Returning the name as the function's tail value is NOT an
#     escape (the caller receives a settled value, not a
#     witnessable mutation). Passing a local Array to ANOTHER
#     function that may mutate it is conservatively treated as escape.
#   Pass 2 — demand classification. Walks every call to a callee
#     declared `/ Mutable` (the core `array_set`/`array_grow`,
#     the qualified `Mutable.array_set`/`ref_set`, a Ref-backed
#     container op like `hashmap.put`, or any user fn `/ Mutable`).
#     The demand is "local" iff every argument that CARRIES MUTATION
#     (head `Array`/`Ref`, or a record with a transitive `Array`/`Ref`
#     field) is an `EVar(n)` with `n` local-constructed, not a
#     parameter, and not escaped. Otherwise the demand is "external".
#   If every demand is local, `Mutable` is removed from
#   `st.row` (and from `st.eff_uses` to keep diagnostics
#   consistent). Otherwise the row is left untouched.
#
# this used to split mutable values into DIRECT (`Array`,
# mutated by a bare C call, maskable when local) and DISPATCH (`Ref` /
# Ref-backed containers, mutated through the evidence stack, NEVER
# maskable even when local because the masked row dropped the handler
# install). The default handler for `Mutable` is now installed
# UNCONDITIONALLY at the base of the evidence stack (see
# `ensure_unconditional_defaults`, emit_shared), so a local Ref/HashMap
# whose row drops `Mutable` still finds a handler at the dispatch site.
# The direct/dispatch distinction is gone: a value carries mutation or
# it does not, and the only question is whether it escapes. The masking
# invariant: a callee `/ Mutable` is masked iff every mutation-carrying
# argument is a local, non-parameter, non-escaping `EVar`; an argument
# that carries mutation and is a parameter or escapes keeps `Mutable`.

fn mask_local_mutable_demand(st: InferState, params: [Param], body: Expr) : InferState {
  if not list_has_label(st.row, "Mutable") { st }
  else {
    let body_resolved = finalise_typed_expr(st.sub, body)
    # The mutation-carrying record names (every record with a transitive
    # `Array`/`Ref` field, e.g. `HashMap` / `HashSet` / `{ arr: Array }`)
    # come from the program's records. An argument of such a type carries
    # mutation, so passing it to a `/ Mutable` callee is observable iff that
    # argument is a parameter or escapes. Computed up front: both the local-set
    # scan and the demand classifier consult it.
    let dmut = mutating_record_type_names(st.recs)
    let local_set = collect_local_arrays(body_resolved, [], dmut)
    let param_names = mut_collect_param_names(params, [])
    let escaped_set = collect_escaped_names(body_resolved, [])
    if all_demands_local(body_resolved, local_set, escaped_set, param_names, dmut) {
      st_drop_label(st, "Mutable")
    } else { st }
  }
}

fn list_has_label(row: [Label], eff: String) : Bool {
  match row {
    []           -> false
    [h, ...rest] -> if h.eff == eff { true } else { list_has_label(rest, eff) }
  }
}

fn st_drop_label(st: InferState, eff: String) : InferState {
  let row1 = drop_labels_named(st.row, eff)
  let uses1 = drop_eff_uses_named(st.eff_uses, eff)
  InferState { file: st.file, env: st.env, core_len: st.core_len, sub: st.sub,
               recs: st.recs, errs: st.errs, insts: st.insts, holes: st.holes,
               row: row1, eff_uses: uses1, aliases: st.aliases,
               clause_resume: st.clause_resume, op_eff_arities: st.op_eff_arities,
               ret_ty: st.ret_ty, type_aliases: st.type_aliases, op_to_eff: st.op_to_eff, proto_impls: st.proto_impls, sums: st.sums, diags: st.diags, deferred_fields: st.deferred_fields, op_payload_labels: st.op_payload_labels, op_res: st.op_res, in_clause: st.in_clause }
}

fn drop_labels_named(row: [Label], eff: String) : [Label] {
  match row {
    []           -> []
    [h, ...rest] ->
      if h.eff == eff { drop_labels_named(rest, eff) }
      else { [h, ...drop_labels_named(rest, eff)] }
  }
}

fn drop_eff_uses_named(uses: [EffUse], eff: String) : [EffUse] {
  match uses {
    []           -> []
    [h, ...rest] -> match h {
      EU(name, _, _) ->
        if name == eff { drop_eff_uses_named(rest, eff) }
        else { [h, ...drop_eff_uses_named(rest, eff)] }
    }
  }
}

fn mut_collect_param_names(ps: [Param], acc: [String]) : [String] {
  match ps {
    []           -> acc
    [p, ...rest] -> mut_collect_param_names(rest, [p.pname, ...acc])
  }
}

# Walk the typed body and accumulate names bound to a locally-
# constructed mutable value (an Array, a Ref, or a Ref-backed
# container — `dmut` lists the mutating record names). Recurses
# through every sub-expression so locals introduced inside
# if/match/block branches are caught.
fn collect_local_arrays(e: Expr, acc: [String], dmut: [String]) : [String] =
  collect_local_arrays_kind(e.kind, acc, dmut)

fn collect_local_arrays_kind(k: ExprKind, acc: [String], dmut: [String]) : [String] {
  match k {
    EBlock(stmts, tail) -> {
      let acc1 = collect_local_in_stmts(stmts, acc, dmut)
      match tail {
        Some(t) -> collect_local_arrays(t, acc1, dmut)
        None    -> acc1
      }
    }
    EIf(c, t_, eo) -> {
      let a1 = collect_local_arrays(c, acc, dmut)
      let a2 = collect_local_arrays(t_, a1, dmut)
      match eo {
        Some(e2) -> collect_local_arrays(e2, a2, dmut)
        None     -> a2
      }
    }
    EMatch(scr, arms) -> {
      let a1 = collect_local_arrays(scr, acc, dmut)
      collect_local_in_arms(arms, a1, dmut)
    }
    ECall(callee, args_) -> {
      let a1 = collect_local_arrays(callee, acc, dmut)
      collect_local_in_exprs(args_, a1, dmut)
    }
    EBinop(_, a, b)   -> collect_local_arrays(b, collect_local_arrays(a, acc, dmut), dmut)
    EUnop(_, x)       -> collect_local_arrays(x, acc, dmut)
    EField(b, _)      -> collect_local_arrays(b, acc, dmut)
    EIndex(a, b)      -> collect_local_arrays(b, collect_local_arrays(a, acc, dmut), dmut)
    EPipe(a, b)       -> collect_local_arrays(b, collect_local_arrays(a, acc, dmut), dmut)
    EMapPipe(a, b)    -> collect_local_arrays(b, collect_local_arrays(a, acc, dmut), dmut)
    EFlatMapPipe(a, b)-> collect_local_arrays(b, collect_local_arrays(a, acc, dmut), dmut)
    EFilterPipe(a, b) -> collect_local_arrays(b, collect_local_arrays(a, acc, dmut), dmut)
    ELambda(_, b)     -> collect_local_arrays(b, acc, dmut)
    ERecordLit(_, fs) -> collect_local_in_field_inits(fs, acc, dmut)
    EList(els)        -> collect_local_in_list_elems(els, acc, dmut)
    ERange(a, b, oc)  -> {
      let a1 = collect_local_arrays(b, collect_local_arrays(a, acc, dmut), dmut)
      match oc { Some(c) -> collect_local_arrays(c, a1, dmut) None -> a1 }
    }
    EHandle(body, _, _, init_opt, _, clauses, ret_opt) -> {
      let a1 = collect_local_arrays(body, acc, dmut)
      let a2 = match init_opt { Some(i) -> collect_local_arrays(i, a1, dmut) None -> a1 }
      let a3 = collect_local_in_hclauses(clauses, a2, dmut)
      match ret_opt {
        Some(HR(_, body, _, _)) -> collect_local_arrays(body, a3, dmut)
        None              -> a3
      }
    }
    ELitUnit(inner, _) -> collect_local_arrays(inner, acc, dmut)
    EBang(inner)       -> collect_local_arrays(inner, acc, dmut)
    _ -> acc
  }
}

fn collect_local_in_exprs(es: [Expr], acc: [String], dmut: [String]) : [String] = match es {
  []           -> acc
  [h, ...rest] -> collect_local_in_exprs(rest, collect_local_arrays(h, acc, dmut), dmut)
}

fn collect_local_in_field_inits(fs: [FieldInit], acc: [String], dmut: [String]) : [String] = match fs {
  []           -> acc
  [h, ...rest] -> match h {
    FI(_, v) -> collect_local_in_field_inits(rest, collect_local_arrays(v, acc, dmut), dmut)
  }
}

fn collect_local_in_list_elems(els: [ListElem], acc: [String], dmut: [String]) : [String] = match els {
  []           -> acc
  [h, ...rest] -> match h {
    ElPlain(x)  -> collect_local_in_list_elems(rest, collect_local_arrays(x, acc, dmut), dmut)
    ElSpread(x) -> collect_local_in_list_elems(rest, collect_local_arrays(x, acc, dmut), dmut)
  }
}

fn collect_local_in_arms(arms: [Arm], acc: [String], dmut: [String]) : [String] = match arms {
  []           -> acc
  [h, ...rest] -> match h {
    Arm(_, g, b) -> {
      let a1 = match g { Some(gx) -> collect_local_arrays(gx, acc, dmut) None -> acc }
      collect_local_in_arms(rest, collect_local_arrays(b, a1, dmut), dmut)
    }
  }
}

fn collect_local_in_hclauses(cs: [HClause], acc: [String], dmut: [String]) : [String] = match cs {
  []           -> acc
  [h, ...rest] -> match h {
    HC(_, _, b, _, _) -> collect_local_in_hclauses(rest, collect_local_arrays(b, acc, dmut), dmut)
  }
}

fn collect_local_in_stmts(stmts: [Stmt], acc: [String], dmut: [String]) : [String] = match stmts {
  []           -> acc
  [s, ...rest] -> collect_local_in_stmts(rest, collect_local_in_stmt(s, acc, dmut), dmut)
}

fn collect_local_in_stmt(s: Stmt, acc: [String], dmut: [String]) : [String] {
  match s {
    SLet(p, _, rhs) -> {
      # Recurse into rhs first (a let RHS may itself contain nested
      # local-construction bindings inside an if/match branch).
      let acc1 = collect_local_arrays(rhs, acc, dmut)
      match p.pkind {
        PBind(name) ->
          if rhs_is_local_origin(rhs, acc1, dmut) {
            [name, ...acc1]
          } else { acc1 }
        _ -> acc1
      }
    }
    SAssert(c, m) -> {
      let a1 = collect_local_arrays(c, acc, dmut)
      match m { Some(mx) -> collect_local_arrays(mx, a1, dmut) None -> a1 }
    }
    SExprStmt(x)                -> collect_local_arrays(x, acc, dmut)
    SIndexAssign(b, i, v, _, _) ->
      collect_local_arrays(v, collect_local_arrays(i, collect_local_arrays(b, acc, dmut), dmut), dmut)
    SVar(_, _, rhs, _, _)       -> collect_local_arrays(rhs, acc, dmut)
    SUse(_, _, _)               -> acc
  }
}

# True iff `rhs` ORIGINATES a fresh local mutable value the caller never
# observes. Covers every mutable kind (not Array alone),
# using the fresh-vs-borrowed distinction of region inference
# (Tofte-Talpin) / JVM escape analysis (Choi et al. 1999): a value whose
# identity did not come in from a parameter is local.
#
#   * an alias `EVar(n)` is local iff `n` is already local (propagate —
#     never decide by type, so `let m2 = param_map` stays non-local);
#   * an `if`/`match`/block-tail is local iff EVERY tail branch is local
#     (so `if c { local_a } else { param_ref }` is correctly non-local);
#   * an in-place op (`array_set` / `array_grow` of an already-local first
#     arg) returns the same cell — local iff that arg is local;
#   * any OTHER call is a constructor of a local value iff its result type
#     carries mutation AND no argument carries mutation. A call that takes
#     no mutable argument cannot return an alias of one — it can only build
#     a fresh value (`array_make`, `Mutable.ref_make`, `hashmap.empty`,
#     `from_pairs`). A call that DOES take a mutable argument (a user helper
#     that might return it) is conservatively non-local.
fn rhs_is_local_origin(rhs: Expr, local_so_far: [String], dmut: [String]) : Bool =
  match rhs.kind {
    EVar(n)            -> list_has(local_so_far, n)
    EBlock(_, tail)    -> {
      match tail {
        Some(t) -> rhs_is_local_origin(t, local_so_far, dmut)
        None    -> false
      }
    }
    EIf(_, t_, eo)     -> {
      match eo {
        Some(e2) -> both_local_origin(t_, e2, local_so_far, dmut)
        None     -> false
      }
    }
    EMatch(_, arms)    -> arms_all_local_origin(arms, local_so_far, dmut)
    ECall(callee, args_) -> {
      if rhs_is_inplace_local(callee, args_, local_so_far) { true }
      else if rhs_is_constructor(rhs.ty, args_, dmut) { true }
      # threading in-place: a call whose result carries mutation and ALL of
      # whose carrier args are local-origin returns a local value — it can
      # only alias a carrier it received, and every one was local. Covers
      # `mixed1 = string_builder.append(mixed0, ...)` (append returns the
      # same buffer it grew). A carrier arg that is shared (param) makes the
      # result potentially-shared, so this stays false.
      else { rhs_threads_local_carrier(rhs.ty, args_, local_so_far, dmut) }
    }
    # A record literal builds a fresh value; it is local iff no field
    # init aliases a non-local mutation carrier. `Box { arr: array_make(..) }`
    # is local; `Box { arr: param_arr }` is not (it aliases the caller's
    # buffer, so a callee mutating `b.arr` is observable through the param).
    ERecordLit(_, fs)  -> field_inits_all_local_origin(fs, local_so_far, dmut)
    _ -> false
  }

fn field_inits_all_local_origin(fs: [FieldInit], local_so_far: [String], dmut: [String]) : Bool =
  match fs {
    []           -> true
    [f, ...rest] -> match f {
      FI(_, v) ->
        if field_init_local(v, local_so_far, dmut) {
          field_inits_all_local_origin(rest, local_so_far, dmut)
        } else { false }
    }
  }

# A field init keeps the record local iff it does not bring in a
# non-local mutation carrier: a non-carrier value is harmless, and a
# carrier value must itself be locally originated.
fn field_init_local(v: Expr, local_so_far: [String], dmut: [String]) : Bool =
  match v.ty {
    Some(t) -> if ty_carries_mutation(t, dmut) { rhs_is_local_origin(v, local_so_far, dmut) }
               else { true }
    None    -> true
  }

fn both_local_origin(a: Expr, b: Expr, local_so_far: [String], dmut: [String]) : Bool =
  if rhs_is_local_origin(a, local_so_far, dmut) { rhs_is_local_origin(b, local_so_far, dmut) }
  else { false }

fn arms_all_local_origin(arms: [Arm], local_so_far: [String], dmut: [String]) : Bool = match arms {
  []           -> true
  [h, ...rest] -> match h {
    Arm(_, _, b) ->
      if rhs_is_local_origin(b, local_so_far, dmut) { arms_all_local_origin(rest, local_so_far, dmut) }
      else { false }
  }
}

# In-place ops (`array_set` / `array_grow`, bare or qualified) return the
# SAME cell they were given, so the binding is local iff the first arg is
# already a local name. Checked BEFORE the constructor rule because these
# DO take a mutable first arg (which the constructor rule would reject).
fn rhs_is_inplace_local(callee: Expr, args_: [Expr], local_so_far: [String]) : Bool =
  match callee.kind {
    EVar(name) ->
      if is_inplace_array_op(name) {
        match args_ {
          [first, ..._ignore] -> match first.kind {
            EVar(n) -> list_has(local_so_far, n)
            _       -> false
          }
          [] -> false
        }
      } else { false }
    _ -> false
  }

fn is_inplace_array_op(name: String) : Bool =
  name == "array_set" or name == "array_grow" or name == "Mutable.array_set" or name == "Mutable.array_grow"

# A call is a fresh-value constructor iff its result type carries mutation
# and NO argument carries mutation (it cannot alias a mutable value it never
# received). The result-type guard also rejects pure non-mutable calls.
fn rhs_is_constructor(ret_ty: Option[Ty], args_: [Expr], dmut: [String]) : Bool =
  match ret_ty {
    None    -> false
    Some(t) -> ty_carries_mutation(t, dmut) and not any_arg_carries_mutation(args_, dmut)
  }

# A call threads a local carrier iff its result carries mutation and every
# carrier argument is local-origin: the returned carrier can only alias one
# it received, and all were local. (`string_builder.append(local, s)`.)
fn rhs_threads_local_carrier(ret_ty: Option[Ty], args_: [Expr],
                             local_so_far: [String], dmut: [String]) : Bool =
  match ret_ty {
    None    -> false
    Some(t) -> ty_carries_mutation(t, dmut) and carrier_args_all_local(args_, local_so_far, dmut)
  }

fn carrier_args_all_local(args_: [Expr], local_so_far: [String], dmut: [String]) : Bool = match args_ {
  []           -> true
  [h, ...rest] -> {
    let arg_ty = match h.ty { Some(t) -> t  None -> TyAny }
    if ty_carries_mutation(arg_ty, dmut) {
      if rhs_is_local_origin(h, local_so_far, dmut) { carrier_args_all_local(rest, local_so_far, dmut) }
      else { false }
    } else { carrier_args_all_local(rest, local_so_far, dmut) }
  }
}

fn any_arg_carries_mutation(args_: [Expr], dmut: [String]) : Bool = match args_ {
  []           -> false
  [h, ...rest] -> {
    let arg_ty = match h.ty { Some(t) -> t  None -> TyAny }
    if ty_carries_mutation(arg_ty, dmut) { true }
    else { any_arg_carries_mutation(rest, dmut) }
  }
}

# Collect names that appear as argument positions of any call other
# than the safe array_* whitelist. Conservative escape: passing a
# locally-constructed Array to a helper assumes the helper might
# mutate it. The whitelist covers reads
# (array_get / array_length) and writes the demand pass already
# inspects (array_set / array_grow / array_make).
fn collect_escaped_names(e: Expr, acc: [String]) : [String] =
  collect_escaped_names_kind(e.kind, acc)

fn collect_escaped_names_kind(k: ExprKind, acc: [String]) : [String] {
  match k {
    ECall(callee, args_) -> {
      # generalised the previous `is_array_safe_callee`
      # whitelist (which hardcoded specific stdlib names) into a row-
      # consulting rule:
      #   * Runtime-builtin Array primitives (array_make / set / grow / …)
      #     are still whitelisted by name.
      #   * Any other callee whose row does NOT carry `Mutable` (post-
      #     substitution) cannot mutate the arrays it receives, so its
      #     args do not leak for masking purposes. This covers all pure
      #     user-defined helpers and HOFs instantiated with a pure
      #     callback (`bin_foldl(xs, init, pure_lambda)`).
      #   * A callee whose row DOES carry `Mutable` could mutate; its
      #     args are conservatively treated as escaped here. The masking
      #     pass's `mutable_callee_args_all_local` then decides per call
      #     site whether the locally-constructed Arrays are still safe
      #     (every Array/Ref arg must be a local non-param non-escaped
      #     EVar). The two checks agree: if every Array arg is local,
      #     escape's pessimism is overridden by the demand check.
      # every named callee (`EVar`) is safe for escape
      # purposes. The masking pass's `mutable_callee_args_all_local`
      # is the sole authority on whether passing an Array/Ref to a
      # callee `/ Mutable` is observable mutation. For non-Mutable
      # callees the question doesn't arise. Non-EVar callees (lambdas,
      # field accesses, etc.) remain conservative.
      # a callee whose row carries `/ Mutable` (a module op
      # like `hashmap.put`, or any user fn `/ Mutable`) is NOT an escape:
      # the masking demand-check (`mutable_callee_args_all_local`) is the
      # sole authority on whether passing a local mutable value to it is
      # observable. Treating it as escape here would mark a locally-built
      # `HashMap` as escaped the moment it is read or written through its
      # own module ops, defeating the masking entirely. A named `EVar`
      # callee stays safe as before; a `/ Mutable` `EModCall` now joins it.
      let callee_ty = match callee.ty { Some(t) -> t  None -> TyAny }
      let safe = match callee.kind {
        EVar(_) -> true
        _       -> ty_callee_has_mutable(callee_ty)
      }
      let a0 = collect_escaped_names(callee, acc)
      if safe { collect_escaped_in_exprs_safe(args_, a0) }
      else    { collect_escaped_in_exprs(args_, a0) }
    }
    EBlock(stmts, tail) -> {
      let a1 = collect_escaped_in_stmts(stmts, acc)
      match tail { Some(t) -> collect_escaped_names(t, a1) None -> a1 }
    }
    EIf(c, t_, eo) -> {
      let a1 = collect_escaped_names(c, acc)
      let a2 = collect_escaped_names(t_, a1)
      match eo { Some(e2) -> collect_escaped_names(e2, a2) None -> a2 }
    }
    EMatch(scr, arms) -> {
      let a1 = collect_escaped_names(scr, acc)
      collect_escaped_in_arms(arms, a1)
    }
    EBinop(_, a, b)   -> collect_escaped_names(b, collect_escaped_names(a, acc))
    EUnop(_, x)       -> collect_escaped_names(x, acc)
    EField(b, _)      -> collect_escaped_names(b, acc)
    EIndex(a, b)      -> collect_escaped_names(b, collect_escaped_names(a, acc))
    EPipe(a, b)       -> collect_escaped_via_pipe(a, b, acc)
    EMapPipe(a, b)    -> collect_escaped_via_pipe(a, b, acc)
    EFlatMapPipe(a, b)-> collect_escaped_via_pipe(a, b, acc)
    EFilterPipe(a, b) -> collect_escaped_via_pipe(a, b, acc)
    ELambda(_, b)     -> collect_escaped_names(b, acc)
    # A record literal stores values into fields — that hands the
    # reference to a structured carrier the caller may inspect or
    # mutate. Treat field-init args as escaping.
    ERecordLit(_, fs) -> collect_escaped_in_field_inits(fs, acc)
    EList(els)        -> collect_escaped_in_list_elems(els, acc)
    ERange(a, b, oc)  -> {
      let a1 = collect_escaped_names(b, collect_escaped_names(a, acc))
      match oc { Some(c) -> collect_escaped_names(c, a1) None -> a1 }
    }
    EHandle(body, _, _, init_opt, _, clauses, ret_opt) -> {
      let a1 = collect_escaped_names(body, acc)
      let a2 = match init_opt { Some(i) -> collect_escaped_names(i, a1) None -> a1 }
      let a3 = collect_escaped_in_hclauses(clauses, a2)
      match ret_opt {
        Some(HR(_, body, _, _)) -> collect_escaped_names(body, a3)
        None              -> a3
      }
    }
    ELitUnit(inner, _) -> collect_escaped_names(inner, acc)
    EBang(inner)       -> collect_escaped_names(inner, acc)
    _ -> acc
  }
}

# Pipe `a |> b` desugars to `b(a)` — the LHS is in argument position
# of the RHS callee. Treat as escaping unless the RHS is a safe
# array_* core name. This matches the user's intuition that
# `arr |> some_helper` lets the helper mutate `arr`.
fn collect_escaped_via_pipe(a: Expr, b: Expr, acc: [String]) : [String] {
  let safe = match b.kind {
    EVar(n) -> is_array_safe_callee(n)
    _       -> false
  }
  let a1 = collect_escaped_names(b, acc)
  if safe { collect_escaped_names(a, a1) }
  else { match a.kind {
    EVar(n) -> [n, ...collect_escaped_names(a, a1)]
    _       -> collect_escaped_names(a, a1)
  } }
}

fn is_array_safe_callee(name: String) : Bool {
  # Runtime builtins for Array — their first argument is the array
  # they read or mutate. The masking pass already classifies each
  # call site as local-vs-external by inspecting that argument, so
  # treating the callees themselves as non-escaping is sound.
  #
  # previously this list also held `array_concat_bytes`
  # and `bin_write_len4` (stdlib functions hardcoded by name). Those
  # entries crossed an abstraction boundary — the compiler should
  # not know about specific stdlib symbols. They are gone; their
  # callers now propagate `/ Mutable` honestly through the row.
  if name == "array_make" { true }
  else if name == "array_length" { true }
  else if name == "array_get" { true }
  else if name == "array_set" { true }
  else if name == "array_grow" { true }
  else { false }
}

# Variant for argument lists of safe (whitelisted) callees:
# argument names that are direct `EVar` references DO NOT escape,
# but we still recurse structurally so deeper calls inside e.g.
# `array_set(local, idx, helper(local))` register `helper(local)`'s
# escape correctly.
fn collect_escaped_in_exprs_safe(es: [Expr], acc: [String]) : [String] = match es {
  []           -> acc
  [h, ...rest] -> match h.kind {
    EVar(_) -> collect_escaped_in_exprs_safe(rest, acc)
    _       -> collect_escaped_in_exprs_safe(rest, collect_escaped_names(h, acc))
  }
}

# Variant for argument lists of NON-whitelisted callees: every direct
# `EVar(n)` argument escapes (the callee may mutate it). Otherwise
# recurse.
fn collect_escaped_in_exprs(es: [Expr], acc: [String]) : [String] = match es {
  []           -> acc
  [h, ...rest] -> match h.kind {
    EVar(n) -> collect_escaped_in_exprs(rest, [n, ...acc])
    _       -> collect_escaped_in_exprs(rest, collect_escaped_names(h, acc))
  }
}

fn collect_escaped_in_stmts(stmts: [Stmt], acc: [String]) : [String] = match stmts {
  []           -> acc
  [s, ...rest] -> collect_escaped_in_stmts(rest, collect_escaped_in_stmt(s, acc))
}

fn collect_escaped_in_stmt(s: Stmt, acc: [String]) : [String] {
  match s {
    SLet(_, _, rhs)             -> collect_escaped_names(rhs, acc)
    SAssert(c, m) -> {
      let a1 = collect_escaped_names(c, acc)
      match m { Some(mx) -> collect_escaped_names(mx, a1) None -> a1 }
    }
    SExprStmt(x)                -> collect_escaped_names(x, acc)
    SIndexAssign(b, i, v, _, _) ->
      collect_escaped_names(v, collect_escaped_names(i, collect_escaped_names(b, acc)))
    SVar(_, _, rhs, _, _)       -> collect_escaped_names(rhs, acc)
    SUse(_, _, _)               -> acc
  }
}

fn collect_escaped_in_arms(arms: [Arm], acc: [String]) : [String] = match arms {
  []           -> acc
  [h, ...rest] -> match h {
    Arm(_, g, b) -> {
      let a1 = match g { Some(gx) -> collect_escaped_names(gx, acc) None -> acc }
      collect_escaped_in_arms(rest, collect_escaped_names(b, a1))
    }
  }
}

fn collect_escaped_in_hclauses(cs: [HClause], acc: [String]) : [String] = match cs {
  []           -> acc
  [h, ...rest] -> match h {
    HC(_, _, b, _, _) -> collect_escaped_in_hclauses(rest, collect_escaped_names(b, acc))
  }
}

fn collect_escaped_in_field_inits(fs: [FieldInit], acc: [String]) : [String] = match fs {
  []           -> acc
  [h, ...rest] -> match h {
    FI(_, v) -> match v.kind {
      EVar(n) -> collect_escaped_in_field_inits(rest, [n, ...acc])
      _       -> collect_escaped_in_field_inits(rest, collect_escaped_names(v, acc))
    }
  }
}

fn collect_escaped_in_list_elems(els: [ListElem], acc: [String]) : [String] = match els {
  []           -> acc
  [h, ...rest] -> match h {
    ElPlain(x) -> match x.kind {
      EVar(n) -> collect_escaped_in_list_elems(rest, [n, ...acc])
      _       -> collect_escaped_in_list_elems(rest, collect_escaped_names(x, acc))
    }
    ElSpread(x) -> collect_escaped_in_list_elems(rest, collect_escaped_names(x, acc))
  }
}

# Pass 2: walk every `array_set(first, ...)` / `array_grow(first, ...)`
# call site and decide whether the demand is local or external.
# Returns true iff EVERY demand encountered is local-non-escaping.
# An empty body (no demands) returns true vacuously — but the caller
# only invokes us when `Mutable` is actually in the row, so the body
# must contain at least one demand.
# true iff `t` is a function type whose declared row
# carries the `Mutable` label. Used by the masking pass to recognise
# call sites whose Mutable contribution comes from the callee's
# declared row rather than a direct `array_set` / `ref_set`.
fn ty_callee_has_mutable(t: Ty) : Bool = match t {
  TyFnT(_, _, row) -> labels_contain_mutable(row.labels)
  _                -> false
}

fn labels_contain_mutable(labels: [Label]) : Bool = match labels {
  []           -> false
  [h, ...rest] -> if h.eff == "Mutable" { true } else { labels_contain_mutable(rest) }
}

# True iff the call's callee is a qualified op of the `Mutable` effect —
# `EVar("Mutable.<op>")` (possibly `Mutable.<op>@<alias>`). Its `.ty` is the
# op's result type, so `ty_callee_has_mutable` cannot see the demand; the
# dispatch-key prefix is the effect-level signal. This is NOT a per-op
# whitelist — `array_set`, `ref_set`, `ref_get`, `ref_make`, and any other
# `Mutable` op all match.
fn callee_is_mutable_op(callee: Expr) : Bool = match callee.kind {
  EVar(name) -> dotted_prefix(strip_alias_suffix(name)) == "Mutable"
  _          -> false
}

# True iff `t` is `Array[_]` or `Ref[_]` — the two head constructors that
# directly carry a mutable cell. Records that EMBED one are caught by
# `mutating_record_type_names` instead.
fn ty_is_mutable_ref(t: Ty) : Bool = match t {
  TyCon(_, name, _) -> if name == "Array" { true } else if name == "Ref" { true } else { false }
  _              -> false
}

# The names of record types whose mutation is OBSERVABLE to a caller that
# shares the value: every record with a transitive `Array` or `Ref` field
# (`HashMap`'s `buckets : Ref[..]`, `HashSet`'s `inner : HashMap`, a plain
# `{ arr : Array[..] }`). `Array`/`Ref` seed the set. Computed once over the
# program's records (`st.recs`) so the escape check needs no hard-coded
# container list — a new mutable-backed user type is picked up for free.
#
# `Array` seeds the set because a record the caller shares, whose array a
# callee mutates in place, is observable regardless of the Array-vs-Ref
# backing — the field aliases the caller's buffer. This governs the
# ESCAPE/observability question only; the always-installed default handler
# answers the orthogonal handler-install question. A locally-constructed
# bare `Array` (never wrapped in a parameter record) still masks via the
# `ty_is_mutable_ref` + local-origin path, so threading a freshly-built
# buffer keeps its row clean.
fn mutating_record_type_names(recs: [RecInfo]) : [String] =
  mutrec_fixpoint(recs, ["Ref", "Array"], 0)

# Closure: a record carries mutation iff a field's type names `Array`/`Ref`
# or an already-known mutating type. Iterate to a fixpoint so a type that
# only embeds another mutating record (HashSet → HashMap → Ref) is caught.
# Bounded by `length(recs)` passes (each adds ≥1 name or stops).
fn mutrec_fixpoint(recs: [RecInfo], known: [String], passes: Int) : [String] =
  if passes > list_length(recs) { known }
  else {
    let next = mutrec_scan(recs, known, known)
    if list_length(next) == list_length(known) { known }
    else { mutrec_fixpoint(recs, next, passes + 1) }
  }

fn mutrec_scan(recs: [RecInfo], known: [String], acc: [String]) : [String] = match recs {
  []           -> acc
  [r, ...rest] -> match r {
    RI(name, _, fields, _) ->
      if list_has(acc, name) { mutrec_scan(rest, known, acc) }
      else if rec_fields_name_mutating(fields, known) {
        mutrec_scan(rest, known, [name, ...acc])
      } else { mutrec_scan(rest, known, acc) }
  }
}

fn rec_fields_name_mutating(fields: [FieldDecl], known: [String]) : Bool = match fields {
  []           -> false
  [f, ...rest] -> match f {
    FD(_, _, te) ->
      if te_names_mutating(te, known) { true }
      else { rec_fields_name_mutating(rest, known) }
  }
}

# Does a field's type-expression NAME a mutation carrier (`Array`/`Ref`) or a
# known mutating record — at its head or nested in a type argument / list
# element? `known` seeds with `Array`/`Ref`, so an Array-backed field counts:
# a record the caller shares observes its in-place array mutation.
fn te_names_mutating(te: TypeExpr, known: [String]) : Bool = match te.tkind {
  TyName(name, targs) ->
    if list_has(known, name) { true }
    else { te_list_names_mutating(targs, known) }
  TyList(elem) -> te_names_mutating(elem, known)
  _ -> false
}

fn te_list_names_mutating(tes: [TypeExpr], known: [String]) : Bool = match tes {
  []           -> false
  [t, ...rest] -> if te_names_mutating(t, known) { true }
                  else { te_list_names_mutating(rest, known) }
}

# True iff `t` CARRIES MUTATION: head is `Array`/`Ref`, or names a mutating
# record (`HashMap` / `HashSet` / any user record with a transitive cell).
# This is the single uniform predicate the escape check consults.
fn ty_carries_mutation(t: Ty, dmut: [String]) : Bool =
  if ty_is_mutable_ref(t) { true }
  else { match t {
    TyCon(_, name, _) -> list_has(dmut, name)
    _                 -> false
  } }

# For a callee declared `/ Mutable`, decide whether the mutation it performs
# is local to the caller. Each argument that CARRIES MUTATION must be a
# locally-originated, non-parameter, non-escaping value; an argument of any
# other type cannot carry mutation and is ignored. An escaping or parameter
# mutable argument makes the demand observable, so `Mutable` stays on the row.
#
# A mutation-carrying arg is local iff it is `local_origin` (a local `EVar`,
# a fresh-constructor inline like `string_builder.new()`, or a record literal
# whose fields are all local) — which lets `foldl(xs, new(), \b -> mutate(b))`
# mask: the HOF's local `init` makes the lambda's accumulator local. A shared
# parameter or a constructor that wraps a shared value is rejected (its arg
# carries mutation and is not local).
fn mutable_callee_args_all_local(args_: [Expr], locals: [String],
                                  escaped: [String], params: [String], dmut: [String]) : Bool = match args_ {
  []           -> true
  [h, ...rest] -> {
    let arg_ty = match h.ty { Some(t) -> t  None -> TyAny }
    if ty_carries_mutation(arg_ty, dmut) {
      if arg_is_local_carrier(h, locals, escaped, dmut) {
        mutable_callee_args_all_local(rest, locals, escaped, params, dmut)
      } else { false }
    } else { mutable_callee_args_all_local(rest, locals, escaped, params, dmut) }
  }
}

# A mutation-carrying argument is local iff its origin is local AND, when it
# names a local, that name is not escaped. `rhs_is_local_origin` covers the
# fresh-constructor and record-literal shapes (recursing into args/fields, so
# a `wrap(shared)` factory is correctly non-local).
fn arg_is_local_carrier(h: Expr, locals: [String], escaped: [String], dmut: [String]) : Bool =
  match h.kind {
    EVar(n) -> if list_has(escaped, n) { false } else { list_has(locals, n) }
    _       -> rhs_is_local_origin(h, locals, dmut)
  }

fn all_demands_local(body: Expr, locals: [String], escaped: [String],
                     params: [String], dmut: [String]) : Bool =
  all_demands_local_kind(body.kind, locals, escaped, params, dmut)

fn all_demands_local_kind(k: ExprKind, locals: [String], escaped: [String],
                           params: [String], dmut: [String]) : Bool {
  match k {
    ECall(callee, args_) -> {
      # every Mutable demand now flows through ONE rule: a
      # callee whose type carries `/ Mutable` contributes a demand that is
      # local iff every mutation-carrying argument is a locally-constructed,
      # non-escaping value (`mutable_callee_args_all_local`). This is uniform
      # across all the spellings that reach here:
      #   * the core `array_set` / `array_grow` (their scheme carries
      #     `/ Mutable`, so the first `Array` arg is the mutation carrier);
      #   * the qualified `Mutable.array_set` / `Mutable.ref_set` dispatch
      #     keys (rewritten to `EVar("Mutable.…")` by
      #     `synth_op_call_with_scheme_keys`, type also `/ Mutable`);
      #   * a Ref-backed container op (`hashmap.put`, an `EModCall` whose
      #     type is `/ Mutable`);
      #   * any user fn declared `/ Mutable`.
      # A mutable PARAMETER or escaping value is never local, so `Mutable`
      # stays on the row. A higher-order combinator like `list.foldl(xs,
      # init, fn)` carries `Mutable` transitively from its callback with no
      # mutation-carrying argument of its own, so it is maskable when its
      # real mutation is a local cell — the per-argument check, not a blanket
      # decision, is what keeps `array.from` and friends maskable.
      # A qualified `Mutable.<op>` op-call has its callee rewritten to
      # `EVar("Mutable.<op>")` (`synth_op_call_with_scheme_keys` →
      # `callee_expr_for_op`), and that `EVar`'s `.ty` is the op's RESULT
      # type, not a `/ Mutable` fn type — the effect lives on the caller's
      # row, not the callee node. So `ty_callee_has_mutable` alone misses
      # the dispatched-op spelling. Recognising the callee by its `Mutable.`
      # dispatch prefix is the effect-level check (NOT a per-op whitelist):
      # every op of `Mutable` — `array_set`, `ref_set`, `ref_get`,
      # `ref_make`, and any future op — flows through the same escape rule.
      let callee_ty = match callee.ty { Some(t) -> t  None -> TyAny }
      let demands_mutable =
        ty_callee_has_mutable(callee_ty) or callee_is_mutable_op(callee)
      let here =
        if demands_mutable {
          mutable_callee_args_all_local(args_, locals, escaped, params, dmut)
        } else { true }
      if not here { false }
      else if not all_demands_local(callee, locals, escaped, params, dmut) { false }
      # When the call passed the carrier-locality check, a lambda argument
      # threads a local accumulator: its params inherit the locality the
      # init proved at this site (`foldl(xs, new(), \b -> mutate(b))`). Pass
      # the lambda's params as locals into its body walk. The inheritance is
      # SOUND only because `here` verified every carrier arg (including the
      # init) is local; a shared init would have set `here` false above.
      else { all_demands_local_in_exprs(args_, locals, escaped, params, dmut, here) }
    }
    EBlock(stmts, tail) -> {
      if not all_demands_local_in_stmts(stmts, locals, escaped, params, dmut) { false }
      else { match tail {
        Some(t) -> all_demands_local(t, locals, escaped, params, dmut)
        None    -> true
      } }
    }
    EIf(c, t_, eo) -> {
      if not all_demands_local(c, locals, escaped, params, dmut) { false }
      else if not all_demands_local(t_, locals, escaped, params, dmut) { false }
      else { match eo {
        Some(e2) -> all_demands_local(e2, locals, escaped, params, dmut)
        None     -> true
      } }
    }
    EMatch(scr, arms) ->
      if not all_demands_local(scr, locals, escaped, params, dmut) { false }
      else { all_demands_local_in_arms(arms, locals, escaped, params, dmut) }
    EBinop(_, a, b)   ->
      if not all_demands_local(a, locals, escaped, params, dmut) { false }
      else { all_demands_local(b, locals, escaped, params, dmut) }
    EUnop(_, x)       -> all_demands_local(x, locals, escaped, params, dmut)
    EField(b, _)      -> all_demands_local(b, locals, escaped, params, dmut)
    EIndex(a, b)      ->
      if not all_demands_local(a, locals, escaped, params, dmut) { false }
      else { all_demands_local(b, locals, escaped, params, dmut) }
    EPipe(a, b)       ->
      if not all_demands_local(a, locals, escaped, params, dmut) { false }
      else { all_demands_local(b, locals, escaped, params, dmut) }
    EMapPipe(a, b)    ->
      if not all_demands_local(a, locals, escaped, params, dmut) { false }
      else { all_demands_local(b, locals, escaped, params, dmut) }
    EFlatMapPipe(a, b)->
      if not all_demands_local(a, locals, escaped, params, dmut) { false }
      else { all_demands_local(b, locals, escaped, params, dmut) }
    EFilterPipe(a, b) ->
      if not all_demands_local(a, locals, escaped, params, dmut) { false }
      else { all_demands_local(b, locals, escaped, params, dmut) }
    ELambda(_, b)     -> all_demands_local(b, locals, escaped, params, dmut)
    ERecordLit(_, fs) -> all_demands_local_in_field_inits(fs, locals, escaped, params, dmut)
    EList(els)        -> all_demands_local_in_list_elems(els, locals, escaped, params, dmut)
    ERange(a, b, oc)  -> {
      if not all_demands_local(a, locals, escaped, params, dmut) { false }
      else if not all_demands_local(b, locals, escaped, params, dmut) { false }
      else { match oc {
        Some(c) -> all_demands_local(c, locals, escaped, params, dmut)
        None    -> true
      } }
    }
    EHandle(body, _, _, init_opt, _, clauses, ret_opt) -> {
      if not all_demands_local(body, locals, escaped, params, dmut) { false }
      else if not (match init_opt {
        Some(i) -> all_demands_local(i, locals, escaped, params, dmut)
        None    -> true
      }) { false }
      else if not all_demands_local_in_hclauses(clauses, locals, escaped, params, dmut) { false }
      else { match ret_opt {
        Some(HR(_, b, _, _)) -> all_demands_local(b, locals, escaped, params, dmut)
        None           -> true
      } }
    }
    ELitUnit(inner, _) -> all_demands_local(inner, locals, escaped, params, dmut)
    EBang(inner)       -> all_demands_local(inner, locals, escaped, params, dmut)
    _ -> true
  }
}

# `hof_local` is set when the enclosing call passed the carrier-locality
# check: a lambda argument's params then inherit that proven locality and
# are walked as locals (the `foldl(xs, new(), \b -> mutate(b))` thread).
fn all_demands_local_in_exprs(es: [Expr], locals: [String], escaped: [String],
                              params: [String], dmut: [String], hof_local: Bool) : Bool = match es {
  []           -> true
  [h, ...rest] -> {
    let ok = match h.kind {
      ELambda(ps, body) ->
        if hof_local {
          let locals2 = mut_collect_param_names(ps, locals)
          all_demands_local(body, locals2, escaped, params, dmut)
        } else { all_demands_local(h, locals, escaped, params, dmut) }
      _ -> all_demands_local(h, locals, escaped, params, dmut)
    }
    if not ok { false }
    else { all_demands_local_in_exprs(rest, locals, escaped, params, dmut, hof_local) }
  }
}

fn all_demands_local_in_stmts(stmts: [Stmt], locals: [String],
                              escaped: [String], params: [String], dmut: [String]) : Bool = match stmts {
  []           -> true
  [s, ...rest] ->
    if not all_demands_local_in_stmt(s, locals, escaped, params, dmut) { false }
    else { all_demands_local_in_stmts(rest, locals, escaped, params, dmut) }
}

fn all_demands_local_in_stmt(s: Stmt, locals: [String], escaped: [String],
                              params: [String], dmut: [String]) : Bool {
  match s {
    SLet(_, _, rhs)             -> all_demands_local(rhs, locals, escaped, params, dmut)
    SAssert(c, m) -> {
      if not all_demands_local(c, locals, escaped, params, dmut) { false }
      else { match m {
        Some(mx) -> all_demands_local(mx, locals, escaped, params, dmut)
        None     -> true
      } }
    }
    SExprStmt(x)                -> all_demands_local(x, locals, escaped, params, dmut)
    SIndexAssign(b, i, v, _, _) ->
      if not all_demands_local(b, locals, escaped, params, dmut) { false }
      else if not all_demands_local(i, locals, escaped, params, dmut) { false }
      else { all_demands_local(v, locals, escaped, params, dmut) }
    SVar(_, _, rhs, _, _)       -> all_demands_local(rhs, locals, escaped, params, dmut)
    SUse(_, _, _)               -> true
  }
}

fn all_demands_local_in_arms(arms: [Arm], locals: [String], escaped: [String],
                              params: [String], dmut: [String]) : Bool = match arms {
  []           -> true
  [h, ...rest] -> match h {
    Arm(_, g, b) -> {
      let g_ok = match g {
        Some(gx) -> all_demands_local(gx, locals, escaped, params, dmut)
        None     -> true
      }
      if not g_ok { false }
      else if not all_demands_local(b, locals, escaped, params, dmut) { false }
      else { all_demands_local_in_arms(rest, locals, escaped, params, dmut) }
    }
  }
}

fn all_demands_local_in_hclauses(cs: [HClause], locals: [String],
                                  escaped: [String], params: [String], dmut: [String]) : Bool = match cs {
  []           -> true
  [h, ...rest] -> match h {
    HC(_, _, b, _, _) ->
      if not all_demands_local(b, locals, escaped, params, dmut) { false }
      else { all_demands_local_in_hclauses(rest, locals, escaped, params, dmut) }
  }
}

fn all_demands_local_in_field_inits(fs: [FieldInit], locals: [String],
                                     escaped: [String], params: [String], dmut: [String]) : Bool = match fs {
  []           -> true
  [h, ...rest] -> match h {
    FI(_, v) ->
      if not all_demands_local(v, locals, escaped, params, dmut) { false }
      else { all_demands_local_in_field_inits(rest, locals, escaped, params, dmut) }
  }
}

fn all_demands_local_in_list_elems(els: [ListElem], locals: [String],
                                    escaped: [String], params: [String], dmut: [String]) : Bool = match els {
  []           -> true
  [h, ...rest] -> match h {
    ElPlain(x) ->
      if not all_demands_local(x, locals, escaped, params, dmut) { false }
      else { all_demands_local_in_list_elems(rest, locals, escaped, params, dmut) }
    ElSpread(x) ->
      if not all_demands_local(x, locals, escaped, params, dmut) { false }
      else { all_demands_local_in_list_elems(rest, locals, escaped, params, dmut) }
  }
}

fn synth_record_lit(st: InferState, nm: String, fis: [FieldInit], line: Int, col: Int) : Inferred / Console + File + Mutable {


  # disambiguate same-(name, arity) record collisions by
  # field name. `synth_record_lit` is called with the construction's
  # `[FieldInit]`; use the first init's name to pick the `RI` whose
  # declared field set includes that name. Two arity-0 `Thread`
  # records (private core + user redeclaration) are distinguished
  # this way: the user's `Thread { id, name }` literal probes for
  # `id` and matches the user's `RI`; the core's `Thread {
  # state_id, captures }` literal probes for `state_id` and matches
  # the core's `RI`. Falls back to bare arity-aware lookup when
  # no fields are present (zero-field constructions are rare and
  # arity alone suffices).
  let probe_field = match fis {
    [] -> ""
    [fi, ..._] -> match fi { FI(fnm, _) -> fnm }
  }
  let lookup = if probe_field == "" {
    rec_find(st.recs, nm)
  } else {
    rec_find_with_field(st.recs, nm, -1, probe_field)
  }
  match lookup {
    None -> {
      let r = synth_field_inits(st, fis, [], line, col)
      let ty = TyCon(None, nm, [])
      let root = with_ty(mk_expr(ERecordLit(nm, r.fis), line, col), ty)
      mk_inferred(r.st, ty, root)
    }
    Some(ri) -> {
      let inst = rec_instantiate(st, ri)
      let r = synth_field_inits(inst.st, fis, inst.fields, line, col)
      let ty = apply_ty(r.st.sub, inst.result_ty)
      let root = with_ty(mk_expr(ERecordLit(nm, r.fis), line, col), ty)
      mk_inferred(r.st, ty, root)
    }
  }
}

# lower a `4.0<USD>` / `42<sec>`-style numeric UoM literal
# into an inline `Decimal { raw, scale }` record-literal when the
# surrounding context expects `Decimal<u>`. The rewrite is narrow on
# purpose:
#
#   • Expected type must canonicalise to `Decimal<u_field>`.
#   • Source AST must be `ELitUnit(EInt | EReal, u_lit)`.
#   • Units must match (`inf_unit_eq(u_lit, u_field)`); when they don't,
#     we leave the original AST and let the regular unifier produce
#     the unit-mismatch diagnostic at the call site.
#
# The lowering decodes the numeric value at compile time:
#   • `n<u>`         → `Decimal { raw: n,  scale: 0 }`
#   • `4.0<u>`       → `Decimal { raw: 4,  scale: 0 }` (the `%g`
#     formatter strips trailing zeros, so the source-level scale-2
#     intent is not preserved — see the `dec_lit` note in
#     stdlib/decimal.kai for the same trade-off).
#
# Returns the rewritten Expr (typed as `Decimal<u_field>`) on a
# match, the original expression untouched otherwise. The existing
# unifier picks up from there: on success it sees equal types and
# produces the empty substitution; on a unit mismatch (or any other
# fall-through) it surfaces the same diagnostic it produced before
# this lane landed.
fn try_lower_decimal_uom_lit(value: Expr, expected: Ty) : Expr {
  match expected {
    TyDimT(TyCon(None, "Decimal", _), u_field) -> match value.kind {
      ELitUnit(inner, u_lit) ->
        if inf_unit_eq(u_lit, u_field) {
          let target_ty = TyDimT(TyCon(None, "Decimal", []), unit_canon(u_field))
          match inner.kind {
            EInt(n)  -> mk_decimal_record(n, 0, value.line, value.col, target_ty)
            EReal(r, _) -> {
              let parts = real_to_dec_parts(r)
              mk_decimal_record(parts.raw, parts.scale, value.line, value.col, target_ty)
            }
            _ -> value
          }
        } else { value }
      _ -> value
    }
    _ -> value
  }
}

# Build the `Decimal { raw, scale }` record-literal AST node and
# stamp it with the unit-decorated type. Unit info is erased at the
# carrier level — this is the same pattern existing UoM literals
# follow (`Real<USD>` is a TyDimT decoration over a plain Real).
# `raw` rides an `EFixed` typed `Int128` (the carrier's field type);
# a bare `EInt` would emit a 64-bit Int and trap in boxed arithmetic.
fn mk_decimal_record(raw: Int, scale: Int, line: Int, col: Int, ty: Ty) : Expr {
  let raw_lit = with_ty(mk_expr(EFixed(int_to_string(raw), TyInt128), line, col), TyInt128)
  let scale_lit = mk_expr(EInt(scale), line, col)
  let fields = [FI("raw", raw_lit), FI("scale", scale_lit)]
  with_ty(mk_expr(ERecordLit("Decimal", fields), line, col), ty)
}

# Decode an EReal value into the carrier's `(raw, scale)` parts via
# the platform's `%g` formatter (re-using the same path the runtime
# uses for `decimal.parse`). `%g` strips trailing zeros, so a source
# literal `4.00<USD>` lowers as `{ raw: 4, scale: 0 }` rather than
# `{ raw: 400, scale: 2 }` — mathematically equivalent under
# `dec_align`/`decimal.eq`, lossy on stringification scale. A
# scale-preserving variant is a follow-up that needs source-span
# preservation on numeric literals.
type DecParts = { raw: Int, scale: Int }

fn real_to_dec_parts(r: Real) : DecParts {
  let s = real_to_string(r)
  let n = string_length(s)
  let neg_check = match char_at(s, 0) { Some(c) -> c == '-' None -> false }
  let body_start = if neg_check { 1 } else { 0 }
  let dot = real_dec_find_dot(s, body_start, n)
  if dot < 0 {
    let mag = parse_decimal_or_zero(string_slice(s, body_start, n - body_start))
    let signed = if neg_check { 0 - mag } else { mag }
    DecParts { raw: signed, scale: 0 }
  } else {
    let int_str = string_slice(s, body_start, dot - body_start)
    let frac_str = string_slice(s, dot + 1, n - dot - 1)
    let frac_len = string_length(frac_str)
    let int_mag = parse_decimal_or_zero(int_str)
    let frac_v = parse_decimal_or_zero(frac_str)
    let mag = int_mag * pow10_int(frac_len) + frac_v
    let signed = if neg_check { 0 - mag } else { mag }
    DecParts { raw: signed, scale: frac_len }
  }
}

fn real_dec_find_dot(s: String, i: Int, n: Int) : Int {
  if i >= n { 0 - 1 }
  else { match char_at(s, i) {
    None    -> 0 - 1
    Some(c) -> if c == '.' { i } else { real_dec_find_dot(s, i + 1, n) }
  } }
}

fn parse_decimal_or_zero(s: String) : Int =
  match parse_decimal(s) { Some(v) -> v None -> 0 }

fn pow10_int(n: Int) : Int =
  if n <= 0 { 1 } else { pow10_int_loop(1, n) }

fn pow10_int_loop(acc: Int, n: Int) : Int =
  if n <= 0 { acc } else { pow10_int_loop(acc * 10, n - 1) }

# Same rewrite, threading the resulting type back to the caller so
# downstream unify sees equal types. Returned ty is the input
# `value_ty` when no rewrite applies, otherwise the lowered
# `Decimal<u>` shape.
fn maybe_lower_decimal_lit(value: Expr, value_ty: Ty, expected: Ty) : ExprTy {
  let rewritten = try_lower_decimal_uom_lit(value, expected)
  let new_ty = match rewritten.ty { Some(t) -> t None -> value_ty }
  ExprTy { expr: rewritten, ty: new_ty }
}

type ExprTy = { expr: Expr, ty: Ty }

type MintedExpr = { st: InferState, pair: ExprTy }

# Coin a numeric literal to a concrete carrier resolved from context.
# `expected` must already be `apply_ty`-resolved: a concrete carrier
# mints (or errors on overflow / shape mismatch); a type variable falls
# through to the Decimal-with-unit lowering and then the shape default,
# so unification stays the authority and principality is preserved.
fn maybe_mint_literal(st: InferState, value: Expr, value_ty: Ty, expected: Ty,
                      line: Int, col: Int) : MintedExpr / Console + File + Mutable {
  match mint_literal(value, expected) {
    MintOk(e2) -> {
      let new_ty = match e2.ty { Some(t) -> t None -> value_ty }
      MintedExpr { st: st, pair: ExprTy { expr: e2, ty: new_ty } }
    }
    MintErr(msg) -> {
      diag_error(st.file, line, col, msg)
      MintedExpr { st: st_bump_err(st), pair: ExprTy { expr: value, ty: value_ty } }
    }
    MintNone -> MintedExpr { st: st, pair: maybe_lower_decimal_lit(value, value_ty, expected) }
  }
}

# The synth-side entry for the textual literal nodes that carry no shape
# default. A `d` suffix mints to `Decimal` unconditionally; a bare
# past-i64 integer with no concrete carrier in context is out of range
# and names the `n` / `bigint.from_string` escape hatch.
fn synth_lit_mint_or_err(st: InferState, e: Expr, kind: ExprKind) : Inferred / Console + File + Mutable {
  match kind {
    EDecimalLit(_) -> synth_mint_decimal(st, e)
    EIntLit(span)  -> {
      diag_error(st.file, e.line, e.col, lit_mint_int_range_error(span))
      mk_inferred(st_bump_err(st), TyInt, e)
    }
    _ -> {
      diag_error(st.file, e.line, e.col, "numeric literal has no concrete type in context")
      mk_inferred(st_bump_err(st), TyInt, e)
    }
  }
}

# A let-RHS under annotation. A textual numeric literal
# (`EIntLit`/`EDecimalLit`) coins against the resolved annotation here,
# before `synth` would error on the missing context; everything else
# synths normally and the post-synth `maybe_mint_literal` covers the
# `EInt`/`EReal` cases.
fn synth_let_rhs_or_mint(st: InferState, rhs: Expr, te: TypeExpr,
                         line: Int, col: Int) : Inferred / Console + File + Mutable {
  match rhs.kind {
    EIntLit(_)     -> mint_let_textual(st, rhs, te, line, col)
    EDecimalLit(_) -> mint_let_textual(st, rhs, te, line, col)
    _ -> synth(st, rhs)
  }
}

fn mint_let_textual(st: InferState, rhs: Expr, te: TypeExpr,
                    line: Int, col: Int) : Inferred / Console + File + Mutable {
  let expected = apply_ty(st.sub, inf_resolve_ty_rk(te, st.env.row_kind))
  match mint_literal(rhs, expected) {
    MintOk(e2) -> {
      let ty = match e2.ty { Some(t) -> t None -> expected }
      mk_inferred(st, ty, e2)
    }
    MintErr(msg) -> {
      diag_error(st.file, line, col, msg)
      mk_inferred(st_bump_err(st), expected, rhs)
    }
    MintNone -> synth(st, rhs)
  }
}

fn synth_mint_decimal(st: InferState, e: Expr) : Inferred / Console + File + Mutable {
  match mint_literal(e, TyCon(None, "Decimal", [])) {
    MintOk(e2) -> {
      let ty = match e2.ty { Some(t) -> t None -> TyCon(None, "Decimal", []) }
      mk_inferred(st, ty, e2)
    }
    MintErr(msg) -> {
      diag_error(st.file, e.line, e.col, msg)
      mk_inferred(st_bump_err(st), TyCon(None, "Decimal", []), e)
    }
    MintNone -> {
      diag_error(st.file, e.line, e.col, "numeric literal has no concrete type in context")
      mk_inferred(st_bump_err(st), TyCon(None, "Decimal", []), e)
    }
  }
}

fn synth_field_inits(st: InferState, fis: [FieldInit], fields: [FTy], line: Int, col: Int) : InferredFInits / Console + File + Mutable {


  match fis {
    [] -> InferredFInits { st: st, fis: [] }
    [fi, ...rest] -> match fi {
      FI(fnm, ex) -> {
        let r = synth(st, ex)
        let minted = match fty_find(fields, fnm) {
          None -> MintedExpr { st: r.st, pair: ExprTy { expr: r.expr, ty: r.ty } }
          Some(ft) -> maybe_mint_literal(r.st, r.expr, r.ty, apply_ty(r.st.sub, ft), line, col)
        }
        let lower_pair = minted.pair
        let s1 = match fty_find(fields, fnm) {
          None -> minted.st
          Some(ft) -> {
            let what = string_concat("record field '", string_concat(fnm, "'"))
            st_unify(minted.st, ft, lower_pair.ty, what, line, col)
          }
        }
        let rr = synth_field_inits(s1, rest, fields, line, col)
        InferredFInits { st: rr.st, fis: [FI(fnm, lower_pair.expr), ...rr.fis] }
      }
    }
  }
}

fn synth_block(st: InferState, stmts: [Stmt], tail: Option[Expr], line: Int, col: Int) : Inferred / Console + File + Mutable {


  let outer = st
  let is = synth_stmts(st, stmts)
  let rt_kind = match tail {
    None     -> BlockTail { st: is.st, ty: TyUnit, expr_opt: None }
    Some(te) -> {
      let r = synth(is.st, te)
      BlockTail { st: r.st, ty: r.ty, expr_opt: Some(r.expr) }
    }
  }
  let st2 = st_restore_entries(outer, rt_kind.st)
  let ty = apply_ty(st2.sub, rt_kind.ty)
  let root = with_ty(mk_expr(EBlock(is.stmts, rt_kind.expr_opt), line, col), ty)
  mk_inferred(st2, ty, root)
}

# Local record so the two `match tail` branches return the same
# shape; kaikai-minimal has no tuples.
type BlockTail = { st: InferState, ty: Ty, expr_opt: Option[Expr] }

type OneStmt = { st: InferState, stmt: Stmt }
type InferredOptExpr = { st: InferState, expr: Option[Expr] }

fn synth_stmts(st: InferState, stmts: [Stmt]) : InferredStmts / Console + File + Mutable {


  match stmts {
    [] -> InferredStmts { st: st, stmts: [] }
    [one, ...rest] -> {
      let r = synth_stmt(st, one)
      let rr = synth_stmts(r.st, rest)
      InferredStmts { st: rr.st, stmts: [r.stmt, ...rr.stmts] }
    }
  }
}

fn synth_stmt(st: InferState, stmt: Stmt) : OneStmt / Console + File + Mutable {


  match stmt {
    SLet(pat, ann, rhs) -> {
      # bare-unannotated ctor ambiguity. Run the
      # ambiguity diagnostic at SLet sites with NO annotation when the
      # RHS is a bare ctor reference — that is the canonical
      # "silently resolves to core" shape. With an annotation the
      # ambiguity is resolved by the annotation context; with a more
      # complex RHS the ctor is typically embedded in a typed
      # surrounding context. Limiting the diagnostic to SLet-no-ann
      # avoids spurious fires from core code whose `Ok(...)` is
      # nested under typed handlers.
      let amb_st = match ann {
        None -> match rhs.kind {
          ECall(c, _) -> match c.kind {
            EVar(nm) -> report_ctor_ambiguity_if_any(st, nm, c.line, c.col)
            _ -> st
          }
          EVar(nm) -> report_ctor_ambiguity_if_any(st, nm, rhs.line, rhs.col)
          _ -> st
        }
        Some(_) -> st
      }
      # when the let is annotated and the RHS is an
      # `EMatch`, drive the RHS in check-mode so the expected
      # type reaches every arm via `check_match`. The non-match
      # path is unchanged (synth + post-hoc unify against `declared`
      # below). Decimal-literal lowering relies on `rr.ty` being the
      # synthesised RHS type, which is preserved in both paths.
      # same routing for `EIf` via `check_if`.
      let rr = match ann {
        Some(te) -> match rhs.kind {
          EMatch(_, _) -> {
            let exp_resolved = inf_resolve_ty_rk(te, amb_st.env.row_kind)
            check_expr_against(amb_st, rhs, exp_resolved, "let annotation", pat.line, pat.col)
          }
          EIf(_, _, _) -> {
            let exp_resolved = inf_resolve_ty_rk(te, amb_st.env.row_kind)
            check_expr_against(amb_st, rhs, exp_resolved, "let annotation", pat.line, pat.col)
          }
          # Fix B: route EList through bidirectional check so element
          # literals can be retagged to Byte when expected is [Byte]
          # (and a Vec annotation mints the literal to a vec build).
          EList(_) -> {
            let exp_resolved = inf_resolve_ty_rk(te, amb_st.env.row_kind)
            check_expr_against(amb_st, rhs, exp_resolved, "let annotation", pat.line, pat.col)
          }
          # a Vec-annotated map-pipe chain collects into the vec
          # (pre-sized when the head is a pure range).
          EMapPipe(_, _) -> {
            let exp_resolved = inf_resolve_ty_rk(te, amb_st.env.row_kind)
            check_expr_against(amb_st, rhs, exp_resolved, "let annotation", pat.line, pat.col)
          }
          # route ECall/EVar with annotation
          # context through check_expr_against so a bare ctor whose
          # qualified `<parent>::<cname>` matches the annotation
          # resolves to the qualified scheme.
          ECall(_, _) -> {
            let exp_resolved = inf_resolve_ty_rk(te, amb_st.env.row_kind)
            check_expr_against(amb_st, rhs, exp_resolved, "let annotation", pat.line, pat.col)
          }
          EVar(_) -> {
            let exp_resolved = inf_resolve_ty_rk(te, amb_st.env.row_kind)
            check_expr_against(amb_st, rhs, exp_resolved, "let annotation", pat.line, pat.col)
          }
          # a bare numeric literal coins directly to the annotated carrier
          # from its source lexeme, before synth would stamp a default
          # type (or error on a textual `EIntLit`/`EDecimalLit`).
          _ -> synth_let_rhs_or_mint(amb_st, rhs, te, pat.line, pat.col)
        }
        None -> synth(amb_st, rhs)
      }
      # when the let binding is annotated, coin a numeric RHS literal to
      # the declared carrier: a point literal to an exact Decimal, an
      # integer to any numeric type, from the source lexeme. The
      # Decimal-with-unit lowering is folded into `maybe_mint_literal`.
      # `st_unify` below still confirms the minted type equals the
      # declared one, so the unifier stays the authority.
      let minted = match ann {
        None -> MintedExpr { st: rr.st, pair: ExprTy { expr: rr.expr, ty: rr.ty } }
        Some(te) -> maybe_mint_literal(rr.st, rr.expr, rr.ty,
                                       apply_ty(rr.st.sub, inf_resolve_ty_rk(te, rr.st.env.row_kind)),
                                       pat.line, pat.col)
      }
      let lower_pair = minted.pair
      let binding_st = match ann {
        None -> minted.st
        Some(te) -> {
          let declared = inf_resolve_ty_rk(te, minted.st.env.row_kind)
          st_unify(minted.st, declared, lower_pair.ty, "let annotation", pat.line, pat.col)
        }
      }
      let binding_ty0 = match ann {
        None -> lower_pair.ty
        Some(te) -> inf_resolve_ty_rk(te, rr.st.env.row_kind)
      }
      # The fixed-width inline representation is an optimisation of a
      # LITERAL: a `let x : Vec[e]<n> = [ ... ]` binds a flat aggregate.
      # A `<n>`-typed value that came from anything else (a function
      # return, a field) is a dynamic heap `Vec` at runtime, so the
      # binder de-brands to `Vec[e]` — otherwise codegen would cast a
      # boxed value into a fixed struct.
      let binding_ty = if ty_is_fixed_vec(binding_ty0) and not is_fixed_vec_lit(lower_pair.expr) {
        fixed_vec_unbrand(binding_ty0)
      } else { binding_ty0 }
      let dup_st = check_pattern_no_dup_binds(binding_st, pat)
      let after = check_pattern(dup_st, pat, binding_ty)
      OneStmt { st: after, stmt: SLet(pat, ann, lower_pair.expr) }
    }
    SAssert(cond, msg) -> {
      let rc = synth(st, cond)
      let s1 = st_unify(rc.st, rc.ty, TyBool, "assert condition", cond.line, cond.col)
      let rm = match msg {
        None -> InferredOptExpr { st: s1, expr: None }
        Some(mx) -> {
          let r = synth(s1, mx)
          InferredOptExpr { st: r.st, expr: Some(r.expr) }
        }
      }
      OneStmt { st: rm.st, stmt: SAssert(rc.expr, rm.expr) }
    }
    SExprStmt(ex) -> {
      let r = synth(st, ex)
      OneStmt { st: r.st, stmt: SExprStmt(r.expr) }
    }
    # dispatch the indexed write by container type.
    # `Array[T]` lowers to `array_set(b, i, v)`. `Map[K, V]` is
    # rejected with a typed error that points at `map_put`; the
    # node returned is harmless filler so downstream passes never
    # see a typed `SIndexAssign` survive.
    SIndexAssign(b, i, v, line, col) -> {
      let probe = synth(st, b)
      let base_ty = apply_ty(probe.st.sub, probe.ty)
      match base_ty {
        TyCon(None, "Map", _) -> {
          let ri = synth(probe.st, i)
          let rv = synth(ri.st, v)
          diag_error(st.file, line, col,
            "indexed write `m[k] := v` is not supported for `Map[K, V]` in v1")
          diag_help("use `map.put(m, k, v)` and rebind; the v2 design lands alongside the HAMT carrier")
          OneStmt { st: st_bump_err(rv.st), stmt: SExprStmt(probe.expr) }
        }
        _ -> {
          let callee = mk_expr(EVar("array_set"), line, col)
          let call_node = mk_expr(ECall(callee, [b, i, v]), line, col)
          let rc = synth(st, call_node)
          OneStmt { st: rc.st, stmt: SExprStmt(rc.expr) }
        }
      }
    }
    # `var name = init` — desugar pass not yet implemented.
    # The resolve pass (chk_stmt) already emits the explicit "not yet
    # implemented" diagnostic and short-circuits before infer normally
    # runs. If a future caller invokes inference on the raw AST, return
    # the init's type without binding `name`, so we never silently
    # produce a `let`-equivalent.
    SVar(name, ann, rhs, line, col) -> {
      let rr = synth(st, rhs)
      OneStmt { st: rr.st, stmt: SVar(name, ann, rr.expr, line, col) }
    }
    # SUse stripped pre-typer; if we ever reach here, treat
    # as a no-op (no expressions, no bindings).
    SUse(n, line, col) -> OneStmt { st: st, stmt: SUse(n, line, col) }
  }
}

# ---- patterns ----

# a single pattern that binds the same name
# twice (e.g. `MkPair(x, x)`) is silently accepted today — the
# second binding shadows the first within the same arm. Per
# ML/Haskell-family convention this is a hard error: the user
# almost certainly intended an equality check (`MkPair(x, y) if
# x == y -> ...`). We walk the pattern once, gather every PBind
# / PAs name, and report duplicates before typing the pattern.
# Wildcards never collide; `_` is not a binding. Pattern holes
# (`?` / `?name`) bind no value either and so are skipped here.
fn pattern_collect_binds(pat: Pattern, acc: [String]) : [String] {
  match pat.pkind {
    PWild      -> acc
    PHole(_)   -> acc
    PLit(_)    -> acc
    PRange(_, _) -> acc
    PBind(nm)  -> [nm, ...acc]
    PNarrow(nm, _) -> [nm, ...acc]
    PAs(nm, sub) -> pattern_collect_binds(sub, [nm, ...acc])
    PList(subs, rest_opt) -> {
      let acc1 = pattern_collect_binds_list(subs, acc)
      match rest_opt {
        None      -> acc1
        Some(rnm) -> [rnm, ...acc1]
      }
    }
    PVariant(_, subs) -> pattern_collect_binds_list(subs, acc)
    PVariantRecord(_, pfs) -> pattern_collect_binds_pfields(pfs, acc)
    PRecord(pfs) -> pattern_collect_binds_pfields(pfs, acc)
  }
}

fn pattern_collect_binds_list(ps: [Pattern], acc: [String]) : [String] {
  match ps {
    [] -> acc
    [p, ...rest] -> pattern_collect_binds_list(rest, pattern_collect_binds(p, acc))
  }
}

fn pattern_collect_binds_pfields(pfs: [PField], acc: [String]) : [String] {
  match pfs {
    [] -> acc
    [pf, ...rest] -> match pf {
      PField(_, sub, _) -> pattern_collect_binds_pfields(rest, pattern_collect_binds(sub, acc))
    }
  }
}

fn pattern_first_duplicate(names: [String], seen: [String]) : Option[String] {
  match names {
    [] -> None
    [n, ...rest] -> if list_has(seen, n) {
      Some(n)
    } else {
      pattern_first_duplicate(rest, [n, ...seen])
    }
  }
}

fn check_pattern_no_dup_binds(st: InferState, pat: Pattern) : InferState / Console + File {
  let binds = pattern_collect_binds(pat, [])
  match pattern_first_duplicate(binds, []) {
    None -> st
    Some(nm) -> {
      diag_error(st.file, pat.line, pat.col, "duplicate binding in pattern: `#{nm}`")
      diag_note("binding `#{nm}` already used elsewhere in this pattern")
      diag_help("use a different name, or extract the equality with a guard: `MkPair(x, y) if x == y -> ...`")
      st_bump_err(st)
    }
  }
}

fn check_pattern(st: InferState, pat: Pattern, expected: Ty) : InferState / Console + File + Mutable {


  match pat.pkind {
    PWild      -> st
    PBind(nm)  -> {
      let env2 = ty_env_add(st.env, nm, mono(apply_ty(st.sub, expected)))
      st_set_env(st, env2)
    }
    PLit(lit)  -> {
      let r = synth(st, lit)
      st_unify(r.st, expected, r.ty, "literal pattern", pat.line, pat.col)
    }
    # `PRange` is desugared to a binder + comparison guard before the
    # typer runs, so it never reaches here.
    PRange(_, _) -> st
    PList(subpats, rest_opt) -> {
      let rv = st_fresh_ty(st)
      let s1 = st_unify(rv.st, expected, TyListT(rv.ty), "list pattern", pat.line, pat.col)
      let s2 = check_list_subpats(s1, subpats, rv.ty)
      match rest_opt {
        None -> s2
        Some(rnm) -> {
          let env2 = ty_env_add(s2.env, rnm, mono(TyListT(apply_ty(s2.sub, rv.ty))))
          st_set_env(s2, env2)
        }
      }
    }
    PVariant(cname, sub_pats) ->
      check_variant_pattern(st, cname, sub_pats, expected, pat.line, pat.col)
    PVariantRecord(cname, pfs) ->
      check_variant_record_pattern(st, cname, pfs, expected, pat.line, pat.col)
    PRecord(pfs) ->
      check_record_pattern(st, pfs, expected, pat.line, pat.col)
    PHole(nm_opt) -> check_hole_pattern(st, nm_opt, expected, pat.line, pat.col)
    # bind the as-name to the scrutinee at the *expected*
    # type, then continue typing the inner pattern at the same type.
    # The inner pattern owns its own bindings; the as-binding adds
    # one more name that aliases the whole scrutinee.
    PAs(nm, sub) -> {
      let env2 = ty_env_add(st.env, nm, mono(apply_ty(st.sub, expected)))
      check_pattern(st_set_env(st, env2), sub, expected)
    }
    # type-narrowing pattern. The scrutinee must
    # be a `TyUnion` containing the narrow type as a component; bind
    # `name` at the narrow type so the arm body can call APIs that
    # accept the component directly. Exhaustiveness treats this as
    # full coverage of the component's variants (see
    # `check_exhaustive`). Codegen never sees `PNarrow` — it is
    # rewritten to a sequence of `PAs(name, PVariant(Vi, []))` arms
    # in `expand_narrow_arms` after typing.
    PNarrow(name, ty_expr) -> check_narrow_pattern(st, name, ty_expr, expected, pat.line, pat.col)
  }
}

# validate `name : T` against the scrutinee type.
# Two scrutinee shapes are accepted:
#   - `TyUnion(parts)` (first-class union form, not currently produced
#     anywhere in stage 2 but kept symmetric for forward compat).
#   - `TyCon(_, u, [])` whose env-recorded variants include the narrow
#     type's tycon name as a "component" (the dual-representation
#     path: `type T = A | B` registers `A` and `B` as zero-arg
#     variants of `T`, their names validated against pre-declared
#     types by `validate_union_collisions`).
fn check_narrow_pattern(st: InferState, name: String, ty_expr: TypeExpr,
                         expected: Ty, line: Int, col: Int) : InferState / Console + File {


  let narrow_ty = inf_resolve_ty(ty_expr)
  let scrut_now = apply_ty(st.sub, expected)
  match scrut_now {
    TyUnion(parts) -> if ty_list_contains(parts, narrow_ty) {
      let env2 = ty_env_add(st.env, name, mono(narrow_ty))
      st_set_env(st, env2)
    } else {
      diag_error(st.file, line, col,
        "type-narrowing pattern targets `#{inf_ty_to_string(narrow_ty)}`, which is not a component of `#{inf_ty_to_string(scrut_now)}`")
      diag_help("the narrow type must appear as one of the union's components, declared via `type T = A | B`")
      let env2 = ty_env_add(st.env, name, mono(narrow_ty))
      st_bump_err(st_set_env(st, env2))
    }
    TyCon(_, u_name, _) -> {
      let narrow_name = match narrow_ty {
        TyCon(_, n, _) -> n
        _           -> ""
      }
      let comps = if narrow_name == "" { [] } else { variants_of_type(st.env, u_name) }
      if narrow_name != "" and list_has(comps, narrow_name) {
        let env2 = ty_env_add(st.env, name, mono(narrow_ty))
        st_set_env(st, env2)
      } else {
        diag_error(st.file, line, col,
          "type-narrowing pattern targets `#{inf_ty_to_string(narrow_ty)}`, which is not a component of `#{inf_ty_to_string(scrut_now)}`")
        diag_help("the narrow type must appear as one of the union's components, declared via `type T = A | B`")
        let env2 = ty_env_add(st.env, name, mono(narrow_ty))
        st_bump_err(st_set_env(st, env2))
      }
    }
    _ -> {
      diag_error(st.file, line, col,
        "type-narrowing pattern `#{name} : #{inf_ty_to_string(narrow_ty)}` requires a union scrutinee, found `#{inf_ty_to_string(scrut_now)}`")
      let env2 = ty_env_add(st.env, name, mono(narrow_ty))
      st_bump_err(st_set_env(st, env2))
    }
  }
}

fn ty_list_contains(tys: [Ty], target: Ty) : Bool {
  match tys {
    [] -> false
    [t, ...rest] -> if inf_ty_eq(t, target) { true } else { ty_list_contains(rest, target) }
  }
}

# A hole in pattern position behaves like PWild at runtime (matches
# anything, binds nothing) but additionally registers a HoleSite so
# the report surfaces the expected pattern type and the scope. For
# named pattern holes we reuse the same name-sharing rule as the
# expression form: two `?x` in the same decl unify to one TyVar.
fn check_hole_pattern(st: InferState, nm_opt: Option[String], expected: Ty, line: Int, col: Int) : InferState / Console + File + Mutable {


  let expected_now = apply_ty(st.sub, expected)
  match nm_opt {
    Some(nm) -> match find_hole_by_name(st.holes, nm) {
      Some(prior_fresh) -> st_unify(st, TyVarT(prior_fresh), expected_now, "pattern hole", line, col)
      None -> register_fresh_pattern_hole(st, nm_opt, expected_now, line, col)
    }
    None -> register_fresh_pattern_hole(st, nm_opt, expected_now, line, col)
  }
}

fn register_fresh_pattern_hole(st: InferState, nm_opt: Option[String], expected: Ty, line: Int, col: Int) : InferState / Console + File + Mutable {


  let fresh_id = st.env.fresh
  let st1 = st_set_env(st, fresh_var(st.env))
  let site = HS(HKHole(nm_opt), line, col, fresh_id, st1.env.entries, st1.env.fresh)
  let st2 = st_push_hole(st1, site)
  st_unify(st2, TyVarT(fresh_id), expected, "pattern hole", line, col)
}

fn check_list_subpats(st: InferState, ps: [Pattern], elem: Ty) : InferState / Console + File + Mutable {


  match ps {
    [] -> st
    [p, ...rest] -> check_list_subpats(check_pattern(st, p, elem), rest, elem)
  }
}

fn check_variant_pattern(st: InferState, cname: String, subpats: [Pattern], expected: Ty, line: Int, col: Int) : InferState / Console + File + Mutable {


  # scrutinee-driven ctor disambiguation. When the
  # expected type resolves to a `TyCon(_, parent, _)`, prefer the qualified
  # `parent::cname` scheme if it exists; this is how a user variant
  # `Response.Ok` shadows the core `Result.Ok` in patterns matching a
  # `Response` scrutinee. Fall back to bare lookup so core variants
  # and non-shadowing user variants keep working.
  let applied = apply_ty(st.sub, expected)
  let sc_opt = match applied {
    TyCon(_, parent, _) -> match ty_env_lookup_qualified(st.env, parent, cname) {
      Some(sc) -> Some(sc)
      None     -> ty_env_lookup(st.env, cname)
    }
    _ -> ty_env_lookup(st.env, cname)
  }
  match sc_opt {
    None -> {
      let hint = match closest_name(cname, ty_env_uppercase_names(st.env)) {
        Some(sug) -> " (did you mean `#{sug}`?)"
        None      -> ""
      }
      diag_error(st.file, line, col, "unknown variant '#{cname}'#{hint}")
      check_unknown_subpats(st_bump_err(st), subpats)
    }
    Some(sc) -> {
      let inst = st_instantiate(st, sc)
      match inst.ty {
        TyFnT(aps, ret, _) -> {
          let what = string_concat("variant pattern '", string_concat(cname, "'"))
          let s1 = st_unify(inst.st, expected, ret, what, line, col)
          check_subpat_list(s1, subpats, aps, line, col)
        }
        _ -> {
          let what = string_concat("variant pattern '", string_concat(cname, "'"))
          let s1 = st_unify(inst.st, expected, inst.ty, what, line, col)
          match subpats {
            [] -> s1
            _  -> {
              diag_error(st.file, line, col, "variant '#{cname}' takes no args but pattern has #{int_to_string(list_length(subpats))}")
              st_bump_err(s1)
            }
          }
        }
      }
    }
  }
}

fn check_unknown_subpats(st: InferState, ps: [Pattern]) : InferState / Console + File + Mutable {


  match ps {
    [] -> st
    [p, ...rest] -> check_unknown_subpats(check_pattern(st, p, TyAny), rest)
  }
}

fn check_subpat_list(st: InferState, ps: [Pattern], tys: [Ty], line: Int, col: Int) : InferState / Console + File + Mutable {


  variant_arity_check(st, ps, tys, line, col, list_length(tys), list_length(ps))
}

fn variant_arity_check(st: InferState, ps: [Pattern], tys: [Ty],
                        line: Int, col: Int, expected: Int, found: Int) : InferState / Console + File + Mutable {


  match ps {
    [] -> match tys {
      [] -> st
      _  -> {
        diag_error(st.file, line, col, "variant pattern has too few sub-patterns")
        diag_note("expected #{int_to_string(expected)}, found #{int_to_string(found)}")
        diag_help("add #{int_to_string(expected - found)} more sub-pattern(s), or use a wildcard `_` for each")
        st_bump_err(st)
      }
    }
    [p, ...pr] -> match tys {
      [] -> {
        diag_error(st.file, line, col, "variant pattern has too many sub-patterns")
        diag_note("expected #{int_to_string(expected)}, found #{int_to_string(found)}")
        diag_help("remove #{int_to_string(found - expected)} sub-pattern(s) so the count matches the variant's declared arity")
        st_bump_err(st)
      }
      [t, ...tr] -> variant_arity_check(check_pattern(st, p, t), pr, tr, line, col, expected, found)
    }
  }
}

fn pfield_list_probe(pfs: [PField]) : String = match pfs {
  [] -> ""
  [pf, ..._] -> match pf { PField(nm, _, _) -> nm }
}

fn check_variant_record_pattern(st: InferState, cname: String, pfs: [PField], expected: Ty, line: Int, col: Int) : InferState / Console + File + Mutable {


  let probe = pfield_list_probe(pfs)
  let lookup = if probe == "" {
    rec_find(st.recs, cname)
  } else {
    rec_find_with_field(st.recs, cname, -1, probe)
  }
  match lookup {
    None -> check_unknown_pfields(st, pfs)
    Some(ri) -> {
      let inst = rec_instantiate(st, ri)
      let what = string_concat("record pattern '", string_concat(cname, "'"))
      let s1 = st_unify(inst.st, expected, inst.result_ty, what, line, col)
      check_pfield_list(s1, pfs, inst.fields, line, col)
    }
  }
}

fn check_record_pattern(st: InferState, pfs: [PField], expected: Ty, line: Int, col: Int) : InferState / Console + File + Mutable {


  let applied = apply_ty(st.sub, expected)
  match applied {
    TyCon(_, nm, nargs) -> {
      let probe = pfield_list_probe(pfs)
      let arity = list_length(nargs)
      let lookup = if probe == "" {
        rec_find_arity(st.recs, nm, arity)
      } else {
        rec_find_with_field(st.recs, nm, arity, probe)
      }
      match lookup {
        None -> check_unknown_pfields(st, pfs)
        Some(ri) -> {
          let inst = rec_instantiate(st, ri)
          let s1 = st_unify(inst.st, expected, inst.result_ty, "record pattern", line, col)
          check_pfield_list(s1, pfs, inst.fields, line, col)
        }
      }
    }
    _ -> check_unknown_pfields(st, pfs)
  }
}

fn check_unknown_pfields(st: InferState, pfs: [PField]) : InferState / Console + File + Mutable {


  match pfs {
    [] -> st
    [pf, ...rest] -> match pf {
      PField(_, sub, _) -> check_unknown_pfields(check_pattern(st, sub, TyAny), rest)
    }
  }
}

fn check_pfield_list(st: InferState, pfs: [PField], fields: [FTy], line: Int, col: Int) : InferState / Console + File + Mutable {


  match pfs {
    [] -> st
    [pf, ...rest] -> match pf {
      PField(fnm, sub, _) -> {
        let s1 = match fty_find(fields, fnm) {
          Some(ft) -> check_pattern(st, sub, ft)
          None -> {
            diag_error(st.file, line, col, "no field '#{fnm}' in record pattern#{field_hint(fields, fnm)}")
            check_pattern(st_bump_err(st), sub, TyAny)
          }
        }
        check_pfield_list(s1, rest, fields, line, col)
      }
    }
  }
}

# ---- match ----

# redundant arms in a `match`. Two
# arms whose patterns trivially overlap and that share guard
# shape (both unguarded) make the second arm dead code. Today
# the language accepts; the user's intent (compute via the
# second arm) is silently dropped. We fingerprint each arm's
# head: variant ctor name, literal value, or catch-all marker.
# Two arms with the same fingerprint, both unguarded, is a hard
# error. A catch-all (`_`, bare binding) unguarded arm makes any
# later arm unreachable; we flag the first such later arm. We
# stay deliberately syntactic: nothing here recurses into
# variant payloads (`Some(x)` vs `Some(y)` is shape 2; `Some(x)`
# vs `Some(Just z)` is NOT). The shape matches what real ML/HM
# frontends report.
type ArmHead
  = AhCatchAll                          # PWild / PBind / PAs over wild — covers everything
  | AhVariant(String)                   # PVariant(nm, []) or all-catch-all subpats — totally open shape
  | AhLitInt(Int)
  | AhLitBool(Bool)
  | AhLitChar(Char)
  | AhLitStr(String)                    # raw source span, includes quotes (EStr shape)
  | AhUnclassified                      # nested / record / list / hole / narrow — skip

# Returns true when a sub-pattern carries no discriminating
# information — it matches every value at its type. We use this
# to decide if a `PVariant(nm, subs)` arm is "totally open"; two
# such arms with the same ctor name overlap completely and the
# second is dead code. A variant arm with a literal payload like
# `Some(true)` is NOT totally open — `Some(true)` and `Some(false)`
# are legitimately distinct arms.
fn pat_is_catch_all_subpat(pat: Pattern) : Bool {
  match pat.pkind {
    PWild       -> true
    PBind(_)    -> true
    PHole(_)    -> true
    PAs(_, sub) -> pat_is_catch_all_subpat(sub)
    _           -> false
  }
}

fn all_subpats_catch_all(ps: [Pattern]) : Bool {
  match ps {
    [] -> true
    [p, ...rest] -> if pat_is_catch_all_subpat(p) { all_subpats_catch_all(rest) } else { false }
  }
}

fn all_pfields_catch_all(pfs: [PField]) : Bool {
  match pfs {
    [] -> true
    [pf, ...rest] -> match pf {
      PField(_, sub, _) -> if pat_is_catch_all_subpat(sub) { all_pfields_catch_all(rest) } else { false }
    }
  }
}

fn arm_head_of(pat: Pattern) : ArmHead {
  match pat.pkind {
    PWild       -> AhCatchAll
    PBind(_)    -> AhCatchAll
    PHole(_)    -> AhCatchAll
    PAs(_, sub) -> arm_head_of(sub)
    PVariant(nm, subs) -> if all_subpats_catch_all(subs) { AhVariant(nm) } else { AhUnclassified }
    PVariantRecord(nm, pfs) -> if all_pfields_catch_all(pfs) { AhVariant(nm) } else { AhUnclassified }
    PLit(lit_expr) -> match lit_expr.kind {
      EInt(n)     -> AhLitInt(n)
      EBool(b)    -> AhLitBool(b)
      EChar(c)    -> AhLitChar(c)
      EStr(s, _)  -> AhLitStr(s)
      _           -> AhUnclassified
    }
    PList(_, _)    -> AhUnclassified
    PRecord(_)     -> AhUnclassified
    PNarrow(_, _)  -> AhUnclassified
    PRange(_, _)   -> AhUnclassified
  }
}

fn arm_head_eq(a: ArmHead, b: ArmHead) : Bool {
  match a {
    AhCatchAll -> match b { AhCatchAll -> true _ -> false }
    AhVariant(na) -> match b {
      AhVariant(nb) -> na == nb
      _ -> false
    }
    AhLitInt(va) -> match b {
      AhLitInt(vb) -> va == vb
      _ -> false
    }
    AhLitBool(va) -> match b {
      AhLitBool(vb) -> va == vb
      _ -> false
    }
    AhLitChar(va) -> match b {
      AhLitChar(vb) -> va == vb
      _ -> false
    }
    AhLitStr(va) -> match b {
      AhLitStr(vb) -> va == vb
      _ -> false
    }
    AhUnclassified -> false
  }
}

fn arm_head_describe(h: ArmHead) : String {
  match h {
    AhCatchAll       -> "catch-all"
    AhVariant(nm)    -> "variant `#{nm}`"
    AhLitInt(n)      -> "literal `#{int_to_string(n)}`"
    AhLitBool(b)     -> if b { "literal `true`" } else { "literal `false`" }
    AhLitChar(_)     -> "this character literal"
    AhLitStr(s)      -> "literal #{s}"
    AhUnclassified   -> "this pattern"
  }
}

fn arm_is_unguarded(a: Arm) : Bool {
  match a {
    Arm(_, guard, _) -> match guard { None -> true Some(_) -> false }
  }
}

fn arm_pat_of(a: Arm) : Pattern {
  match a {
    Arm(pat, _, _) -> pat
  }
}

# A wildcard fallthrough arm emitted by `build_marm_columns` (the
# multi-arg-match desugar) inherits the outer EMatch's source span:
# `mk_pat(PWild, line, col)` where `(line, col)` are the match
# header. The user-written wildcards always carry their own pattern
# span, so equality of pat.line/col with the match's line/col is a
# reliable "synthetic" marker. We skip those arms in redundancy
# bookkeeping so the desugared chain of two-arm matches never
# triggers a false positive against itself.
fn arm_is_synthetic_fallthrough(a: Arm, match_line: Int, match_col: Int) : Bool {
  match a {
    Arm(pat, guard, _) -> {
      let unguarded = match guard { None -> true Some(_) -> false }
      if not unguarded { false }
      else if pat.line != match_line { false }
      else if pat.col != match_col { false }
      else { match pat.pkind { PWild -> true _ -> false } }
    }
  }
}

# Scan arms in order, accumulating the heads of unguarded arms
# already seen. Errors fire on the FIRST redundant arm — once
# diagnostic per offender — so a chain `1 -> 1 -> 1 -> _` reports
# two errors (the two trailing `1`s), not one report listing
# every collision. `match_line`/`match_col` pin the outer match
# header so synthetic fallthrough arms can be filtered.
fn check_arms_redundancy(st: InferState, arms: [Arm], seen: [ArmHead],
                          saw_catch_all: Bool,
                          match_line: Int, match_col: Int) : InferState / Console + File {
  match arms {
    [] -> st
    [a, ...rest] -> {
      if arm_is_synthetic_fallthrough(a, match_line, match_col) {
        check_arms_redundancy(st, rest, seen, saw_catch_all, match_line, match_col)
      } else {
        let pat = arm_pat_of(a)
        let head = arm_head_of(pat)
        let unguarded = arm_is_unguarded(a)
        if saw_catch_all and unguarded {
          diag_error(st.file, pat.line, pat.col,
            "unreachable match arm: previous arm matched every value")
          diag_note("an earlier unguarded `_` or bare binding already covers this case")
          diag_help("remove this arm, or move it before the catch-all")
          let st1 = st_bump_err(st)
          check_arms_redundancy(st1, rest, seen, saw_catch_all, match_line, match_col)
        } else if unguarded and arm_head_classified(head) and arm_head_in(seen, head) {
          diag_error(st.file, pat.line, pat.col,
            "duplicate match arm: #{arm_head_describe(head)} is already matched above")
          diag_help("remove this arm, or distinguish it with a guard (`#{arm_head_describe(head)} if cond -> ...`)")
          let st1 = st_bump_err(st)
          check_arms_redundancy(st1, rest, seen, saw_catch_all, match_line, match_col)
        } else {
          let seen1 = if unguarded and arm_head_classified(head) {
            [head, ...seen]
          } else {
            seen
          }
          let saw_ca1 = saw_catch_all or (unguarded and arm_head_is_catch_all(head))
          check_arms_redundancy(st, rest, seen1, saw_ca1, match_line, match_col)
        }
      }
    }
  }
}

fn arm_head_classified(h: ArmHead) : Bool {
  match h {
    AhUnclassified -> false
    AhCatchAll     -> false              # tracked via the saw_catch_all flag
    _              -> true
  }
}

fn arm_head_is_catch_all(h: ArmHead) : Bool {
  match h {
    AhCatchAll -> true
    _          -> false
  }
}

fn arm_head_in(seen: [ArmHead], target: ArmHead) : Bool {
  match seen {
    [] -> false
    [h, ...rest] -> if arm_head_eq(h, target) { true } else { arm_head_in(rest, target) }
  }
}

fn synth_match(st: InferState, scr: Expr, arms: [Arm], line: Int, col: Int) : Inferred / Console + File + Mutable {


  let st0 = check_arms_redundancy(st, arms, [], false, line, col)
  let rs_ = synth(st0, scr)
  let scr_ty0 = apply_ty(rs_.st.sub, rs_.ty)
  if fixed_vec_match_route(scr_ty0, arms) {
    synth_fixed_vec_match(rs_.st, rs_.expr, arms, scr_ty0, None, line, col)
  } else if vec_match_route(scr_ty0, arms) {
    synth_vec_match(rs_.st, scr, arms, None, line, col)
  } else {
  let rv = st_fresh_ty(rs_.st)
  let ra = synth_arms(rv.st, arms, rs_.ty, rv.ty, line, col)
  let ty = apply_ty(ra.st.sub, rv.ty)
  let scr_final = apply_ty(ra.st.sub, rs_.ty)
  let st_post = check_exhaustive(ra.st, ra.arms, scr_final, line, col)
  # expand `PNarrow(name, T)` arms into one
  # `PAs(name, PVariant(Vi, []))` arm per variant of T so codegen
  # never sees `PNarrow`. Variants come from the post-resolve env
  # (same accessor used by exhaustiveness). The rewrite is purely
  # structural — `name`'s narrow type was bound during typing in
  # `check_narrow_pattern`, so the body's typed AST is already
  # consistent.
  let arms_narrowed = expand_narrow_arms(ra.arms, st_post.env)
  # the parser emits `PVariantRecord(name, fields)` for
  # any `Name { ... }` pattern, even when `Name` is a record alias
  # (`type P = { x: Int, y: Int }`) rather than a sum-type ctor with
  # named fields. The typer accepts both shapes via
  # `check_variant_record_pattern`, but the emitter's
  # `emit_pat_test_variant_record` always tests `KAI_VARIANT` — which
  # never matches a `KAI_RECORD` value, so the arm falls through to
  # the runtime "non-exhaustive match" panic. Rewriting to `PRecord`
  # post-typing routes codegen through `emit_pat_test_record` (the
  # `KAI_RECORD` check) without touching the typer.
  let arms_codegen = rewrite_record_alias_arms(arms_narrowed, st_post.recs)
  let root = with_ty(mk_expr(EMatch(rs_.expr, arms_codegen), line, col), ty)
  mk_inferred(st_post, ty, root)
  }
}

# bidirectional check variant of `synth_match`. When the
# match appears in a position with a known expected type — annotated
# function return, annotated `let` RHS — the caller passes that type
# in as `expected`, and each arm is unified against it directly
# instead of against a freshly-fabricated TyVar. This carries the
# implicit-upcast behaviour across match arms: with the
# expected union shape in scope when the first arm unifies, the
# `union_upcast_ok` rule in `unify_heads` accepts a narrower component
# type without the typer pinning `body_ty` to it.
# Synthesise mode (`synth_match`) is preserved verbatim for
# unannotated positions so existing inference is unchanged.
fn check_match(st: InferState, scr: Expr, arms: [Arm], expected: Ty,
               line: Int, col: Int) : Inferred / Console + File + Mutable {


  let st0 = check_arms_redundancy(st, arms, [], false, line, col)
  let rs_ = synth(st0, scr)
  let scr_ty0 = apply_ty(rs_.st.sub, rs_.ty)
  if fixed_vec_match_route(scr_ty0, arms) {
    synth_fixed_vec_match(rs_.st, rs_.expr, arms, scr_ty0, Some(expected), line, col)
  } else if vec_match_route(scr_ty0, arms) {
    synth_vec_match(rs_.st, scr, arms, Some(expected), line, col)
  } else {
  # walk arms via `check_arms` so the expected type
  # propagates into nested EMatch / EIf / EBlock-tailed-by-match
  # arm bodies — the shape produced by the multi-clause fn-body
  # desugar for fns with N>=2 parameters. With `synth_arms`
  # the nested match was synthesised against a fresh body-ty var,
  # which re-exposed the same arm-vs-arm asymmetry already handled at
  # the top level. The 1-arg multi-clause shape is already covered because
  # `check_body_against_ret` reaches the outer EMatch directly.
  let ra = check_arms(rs_.st, arms, rs_.ty, expected, line, col)
  let ty = apply_ty(ra.st.sub, expected)
  let scr_final = apply_ty(ra.st.sub, rs_.ty)
  let st_post = check_exhaustive(ra.st, ra.arms, scr_final, line, col)
  let arms_narrowed = expand_narrow_arms(ra.arms, st_post.env)
  let arms_codegen  = rewrite_record_alias_arms(arms_narrowed, st_post.recs)
  let root = with_ty(mk_expr(EMatch(rs_.expr, arms_codegen), line, col), ty)
  mk_inferred(st_post, ty, root)
  }
}

# A match routes through the Vec rewrite when the scrutinee resolved to
# `Vec[T]` and some arm is list-shaped. List arms over a Vec never reach
# the cons/nil machinery: `synth_vec_match` rebuilds the whole match as
# an if-chain over `vec_length` / `vec_get` / `vec_tail_from`.
fn vec_match_route(scr_ty: Ty, arms: [Arm]) : Bool =
  match scr_ty {
    TyCon(_, name, _) -> name == "Vec" and vec_match_has_list_arm(arms)
    _                 -> false
  }

# A fixed-width `Vec[T]<n>` scrutinee routes to the static rewrite: the
# length is the type, so `synth_fixed_vec_match` picks the one matching
# arm at compile time — no if-chain, no dynamic-vec op.
fn fixed_vec_match_route(scr_ty: Ty, arms: [Arm]) : Bool =
  ty_is_fixed_vec(scr_ty) and vec_match_has_list_arm(arms)

# Rewrite a fixed-vec match to the selected arm's body. Arms ride the
# same shape contract as the dynamic rewrite (no guards, simple head
# binders); the length test is decided here instead of at runtime, so a
# vec whose length no arm covers is a compile error, not a fallthrough.
fn synth_fixed_vec_match(st: InferState, scr: Expr, arms: [Arm], scr_ty: Ty,
                         expected: Option[Ty], line: Int, col: Int) : Inferred / Console + File + Mutable {
  let g = vec_match_check_arms(st, arms)
  if g.ok {
    let n = fixed_vec_n(scr_ty)
    match fixed_vec_match_arm(arms, n) {
      Some(a) -> {
        let body = fixed_vec_arm_build(a, scr, scr_ty)
        match expected {
          None    -> synth(g.st, body)
          Some(t) -> check_expr_against(g.st, body, t, "match arm", line, col)
        }
      }
      None -> {
        diag_error(g.st.file, line, col,
          concat_all(["no arm matches a fixed-width `Vec` of length ", int_to_string(n)]))
        diag_help("add an arm for that length, a spread pattern (`[a, ...rest]`), or a wildcard `_`")
        mk_inferred(st_bump_err(g.st), TyAny, with_ty(mk_expr(EMatch(scr, arms), line, col), TyAny))
      }
    }
  } else {
    mk_inferred(g.st, TyAny, with_ty(mk_expr(EMatch(scr, arms), line, col), TyAny))
  }
}

type VecMatchGate = { st: InferState, ok: Bool }

# The rewrite's contract, diagnosed before building: no guards, heads
# are simple binders, and the arms cover every length (a catch-all, or
# `[]` plus a spread arm — the list-exhaustiveness rule).
fn vec_match_validate(st: InferState, arms: [Arm], line: Int, col: Int) : VecMatchGate / Console + File {
  let g = vec_match_check_arms(st, arms)
  let exhaustive = any_arm(arms, vec_arm_catchall) or
                   (any_arm(arms, arm_pat_empty_list) and any_arm(arms, arm_pat_spread_list))
  if exhaustive { g }
  else {
    diag_error(g.st.file, line, col,
      "non-exhaustive match on Vec: cover both `[]` and a spread pattern (`[_, ...rest]`), or add a wildcard `_` arm")
    VecMatchGate { st: st_bump_err(g.st), ok: false }
  }
}

fn vec_arm_catchall(a: Arm) : Bool =
  match a {
    Arm(p, guard, _) -> match guard {
      Some(_) -> false
      None -> match vec_arm_kind(p) {
        VArmCatch(_) -> true
        _            -> false
      }
    }
  }

fn vec_match_check_arms(st: InferState, arms: [Arm]) : VecMatchGate / Console + File =
  match arms {
    [] -> VecMatchGate { st: st, ok: true }
    [Arm(p, guard, _), ...rest] -> {
      let g1 = match guard {
        None -> VecMatchGate { st: st, ok: true }
        Some(gx) -> {
          diag_error(st.file, gx.line, gx.col,
            "guards are not supported on Vec match arms")
          diag_help("test the condition with `if` inside the arm body")
          VecMatchGate { st: st_bump_err(st), ok: false }
        }
      }
      let g2 = match vec_arm_kind(p) {
        VArmUnsupported -> {
          diag_error(g1.st.file, p.line, p.col,
            "Vec match arms support `[]` / `[a, b, ...rest]` with simple binders, and a catch-all")
          diag_help("bind the element and match it separately: `[h, ...t] -> match h { ... }`")
          VecMatchGate { st: st_bump_err(g1.st), ok: false }
        }
        _ -> g1
      }
      let dup_st = check_pattern_no_dup_binds(g2.st, p)
      let g2b = VecMatchGate { st: dup_st, ok: g2.ok and dup_st.errs == g2.st.errs }
      let gr = vec_match_check_arms(g2b.st, rest)
      VecMatchGate { st: gr.st, ok: g2b.ok and gr.ok }
    }
  }

# Rewrite a Vec-scrutinee match into the vec_match if-chain and type it
# ONCE (check-mode when an expected type is in play). The scrutinee was
# already synthesised to learn its type; the returned state is threaded
# so its fresh-tvar mints stay bound — the chain re-synthesises the raw
# scrutinee node under that same state.
fn synth_vec_match(st: InferState, scr: Expr, arms: [Arm], expected: Option[Ty],
                   line: Int, col: Int) : Inferred / Console + File + Mutable {
  let g = vec_match_validate(st, arms, line, col)
  if g.ok {
    let chain = vec_match_build(scr, arms, line, col)
    match expected {
      None    -> synth(g.st, chain)
      Some(t) -> check_expr_against(g.st, chain, t, "match arm", line, col)
    }
  } else {
    mk_inferred(g.st, TyAny, with_ty(mk_expr(EMatch(scr, arms), line, col), TyAny))
  }
}

# bidirectional walker over match arms. Mirrors
# `synth_arms` but routes each arm body through
# `check_body_against_ret`, which dispatches EMatch / EIf /
# EBlock-tailed-by-match to their check-mode helpers. The trailing
# unify against `expected` is preserved so non-match leaf bodies
# behave exactly as in synth_arms (synth + post-hoc unify against
# `expected`). For the propagating shapes the unify collapses to
# a no-op since `check_match` / `check_if` already pinned the body
# type to `expected`.
fn check_arms(st: InferState, arms: [Arm], scrut_ty: Ty, expected: Ty,
              line: Int, col: Int) : InferredArms / Console + File + Mutable {


  match arms {
    [] -> InferredArms { st: st, arms: [] }
    [a, ...rest] -> match a {
      Arm(pat, guard, body) -> {
        let outer = st
        let st_dup = check_pattern_no_dup_binds(st, pat)
        let s_p = check_pattern(st_dup, pat, scrut_ty)
        let guard_res = match guard {
          None -> InferredOptExpr { st: s_p, expr: None }
          Some(gx) -> {
            let rg = synth(s_p, gx)
            let s_g = st_unify(rg.st, rg.ty, TyBool, "match guard", gx.line, gx.col)
            InferredOptExpr { st: s_g, expr: Some(rg.expr) }
          }
        }
        let rb = check_body_against_ret(guard_res.st, body, expected, "match arm", body.line, body.col)
        let s_b = st_unify(rb.st, expected, rb.ty, "match arm", body.line, body.col)
        let s_scoped = st_restore_entries(outer, s_b)
        let rr = check_arms(s_scoped, rest, scrut_ty, expected, line, col)
        InferredArms { st: rr.st, arms: [Arm(pat, guard_res.expr, rb.expr), ...rr.arms] }
      }
    }
  }
}

# bidirectional check variant of `synth_if`, parallel to
# `check_match`. When the if/else appears in a position
# with a known expected type — annotated function return, annotated
# `let` RHS — the caller passes that type in as `expected`, and each
# branch is unified against it directly instead of against the
# synthesised `then`-branch type. This carries the implicit-upcast
# behaviour across if/else branches: with the
# expected union shape in scope when the first branch unifies, the
# `union_upcast_ok` rule in `unify_heads` accepts a narrower component
# type without the typer pinning `body_ty` to it.
# Synthesise mode (`synth_if`) is preserved verbatim for unannotated
# positions so existing inference is unchanged.
fn check_if(st: InferState, c: Expr, t_: Expr, eo: Option[Expr],
            expected: Ty, line: Int, col: Int) : Inferred / Console + File + Mutable {


  let rc = synth(st, c)
  let s1 = st_unify(rc.st, rc.ty, TyBool, "if condition", line, col)
  # thread `expected` into the then-branch ONLY
  # when it is shaped like a bare ctor expression (`EBlock` whose tail
  # is a ctor / nullary ctor, ECall(EVar, _), or EVar) so a user
  # `Response.Ok` shadowing the core `Result.Ok` can be picked by
  # annotation context. Other branch shapes stay on synth to avoid
  # regressions in non-ctor expression types.
  let rt = check_branch_for_ctor(s1, t_, expected)
  match eo {
    None -> {
      let root = with_ty(mk_expr(EIf(rc.expr, rt.expr, None), line, col), TyUnit)
      mk_inferred(rt.st, TyUnit, root)
    }
    Some(ee) -> {
      let s_t = st_unify(rt.st, expected, rt.ty, "if/else branches", line, col)
      let re = check_branch_for_ctor(s_t, ee, expected)
      let s2 = st_unify(re.st, expected, re.ty, "if/else branches", line, col)
      let ty = apply_ty(s2.sub, expected)
      let root = with_ty(mk_expr(EIf(rc.expr, rt.expr, Some(re.expr)), line, col), ty)
      mk_inferred(s2, ty, root)
    }
  }
}

# Helper: route a branch through `check_expr_against`
# when it is a bare ctor reference (or a block whose tail is), so the
# annotation context can disambiguate. Other shapes fall through to
# `synth` to keep existing behaviour.
fn check_branch_for_ctor(st: InferState, br: Expr, expected: Ty) : Inferred / Console + File + Mutable {

  match br.kind {
    ECall(c, _) -> match c.kind {
      EVar(_) -> check_expr_against(st, br, expected, "if branch", br.line, br.col)
      _ -> synth(st, br)
    }
    EVar(_) -> check_expr_against(st, br, expected, "if branch", br.line, br.col)
    EBlock(_, tail) -> match tail {
      Some(te) -> match te.kind {
        ECall(c, _) -> match c.kind {
          EVar(_) -> check_expr_against(st, br, expected, "if branch", br.line, br.col)
          _ -> synth(st, br)
        }
        EVar(_) -> check_expr_against(st, br, expected, "if branch", br.line, br.col)
        _ -> synth(st, br)
      }
      None -> synth(st, br)
    }
    _ -> synth(st, br)
  }
}

# route an expression through `check_match` when its
# AST head is `EMatch`, otherwise fall back to synth. The post-hoc
# unify in the caller (`infer_decl`, `synth_stmt` for SLet) handles
# the non-match case; for match the propagation already happened
# inside `check_match`.
# extends to `EIf` via `check_if`.
fn check_expr_against(st: InferState, e: Expr, expected: Ty,
                      what: String, line: Int, col: Int) : Inferred / Console + File + Mutable {


  match e.kind {
    EMatch(scr, arms) -> check_match(st, scr, arms, expected, e.line, e.col)
    EIf(c, t_, eo)    -> check_if(st, c, t_, eo, expected, e.line, e.col)
    # Fix B: bidirectional list literals. When the typer expects
    # `[T]`, propagate `T` to each element. Specifically lets
    # `let bs: [Byte] = [65, 66]` work — Int literals get rewritten
    # to Byte literals (range-checked 0..255) when the expected
    # element type is TyByte.
    EList(els) -> match apply_ty(st.sub, expected) {
      TyListT(elem_ty) -> check_list_elems_against(st, els, elem_ty, e.line, e.col)
      # Vec-context minting (the #1091 shape for containers): the
      # literal builds a pre-sized vec instead of a cons list. A BARE
      # literal keeps denoting the cons list — only annotation /
      # argument context reaches here.
      TyCon(_, hname, hargs) ->
        if hname == "Vec" { check_vec_lit_against(st, els, hargs, e.line, e.col) }
        else { synth(st, e) }
      # Fixed-width Vec context: `Vec[T]<k>` fixes the literal's
      # length by its habitant.
      TyDimT(inner, u) -> match inner {
        TyCon(_, hname, hargs) ->
          if hname == "Vec" { check_fixed_vec_lit(st, els, hargs, u, e.line, e.col) }
          else { synth(st, e) }
        _ -> synth(st, e)
      }
      _                -> synth(st, e)
    }
    # Vec-context pipeline collect: a map-pipe chain in Vec-expected
    # position collects into a vec. Pure range-headed chains rewrite to
    # the pre-sized collect combinator (one buffer, zero intermediates);
    # anything else materialises once through `vec_from_list`.
    EMapPipe(_, _) -> {
      let exp = apply_ty(st.sub, expected)
      if ty_is_fixed_vec(exp) { check_map_pipe_fixed_collect(st, e, exp, e.line, e.col) }
      else if ty_is_vec_head(exp) { check_map_pipe_vec_collect(st, e, e.line, e.col) }
      else { synth(st, e) }
    }
    # annotation-driven ctor disambiguation. When
    # the expected type is `TyCon(_, parent, _)` and the callee is a bare
    # `EVar(cname)` whose qualified `parent::cname` scheme exists,
    # rewrite the callee to `EModCall(parent, cname)` so the core's
    # bare-name table never wins. Falls through to synth otherwise.
    ECall(callee, args_) ->
      ctor_check_or_synth(st, e, callee, args_, expected, line, col)
    # nullary ctor disambiguation. A bare
    # `EVar(cname)` (e.g. `NotFound`) in annotation context whose
    # qualified `parent::cname` exists picks the qualified scheme.
    EVar(_) -> nullary_ctor_check_or_synth(st, e, expected)
    # thread expected into block tails so a
    # `{ ...stmts...; ctor(args) }` body benefits from the same
    # annotation-driven disambiguation as a bare ctor expression.
    EBlock(stmts, tail) -> match tail {
      Some(te) -> {
        let outer = st
        let is_ = synth_stmts(st, stmts)
        let r = check_expr_against(is_.st, te, expected, what, te.line, te.col)
        let st2 = st_restore_entries(outer, r.st)
        let ty = apply_ty(st2.sub, r.ty)
        let root = with_ty(mk_expr(EBlock(is_.stmts, Some(r.expr)), e.line, e.col), ty)
        mk_inferred(st2, ty, root)
      }
      None -> synth(st, e)
    }
    _ -> synth(st, e)
  }
}

# Helper: rewrite a bare-ctor call `EVar(cname)(args)`
# to `EModCall(parent, cname)(args)` whenever a qualified `parent::cname`
# entry exists. The rewrite is unconditional within annotation context —
# `parent` IS the expected type, so the qualified scheme is the correct
# one and the rewrite ALSO bypasses the bare-unannotated ambiguity
# diagnostic in `synth_call` (which would otherwise fire whenever a
# user variant shadows `Result.Ok` / `Option.Some`). Falls through to
# `synth` when no qualified entry exists.
fn ctor_check_or_synth(st: InferState, e: Expr, callee: Expr, args_: [Expr],
                          expected: Ty, line: Int, col: Int) : Inferred / Console + File + Mutable {

  match callee.kind {
    EVar(cname) -> {
      let applied = apply_ty(st.sub, expected)
      match applied {
        TyCon(_, parent, _) -> match ty_env_lookup_qualified(st.env, parent, cname) {
          Some(_) -> {
            let qcallee = mk_expr(EModCall(parent, cname), callee.line, callee.col)
            let rewritten = mk_expr(ECall(qcallee, args_), line, col)
            synth(st, rewritten)
          }
          None -> synth(st, e)
        }
        _ -> synth(st, e)
      }
    }
    _ -> synth(st, e)
  }
}

# Helper: a bare nullary ctor `EVar(cname)` in
# annotation context whose qualified `parent::cname` exists picks the
# qualified scheme.
fn nullary_ctor_check_or_synth(st: InferState, e: Expr, expected: Ty) : Inferred / Console + File + Mutable {

  match e.kind {
    EVar(cname) -> {
      let applied = apply_ty(st.sub, expected)
      match applied {
        TyCon(_, parent, _) -> match ty_env_lookup_qualified(st.env, parent, cname) {
          Some(_) -> {
            let qe = mk_expr(EModCall(parent, cname), e.line, e.col)
            synth(st, qe)
          }
          None -> synth(st, e)
        }
        _ -> synth(st, e)
      }
    }
    _ -> synth(st, e)
  }
}

# collect the qualified parents of `cname` —
# every `<X>::<cname>` key in the env where `X` looks like a sum type
# (starts uppercase, contains no `::` itself). Used by the bare-
# unannotated ambiguity diagnostic to list candidates the user must
# disambiguate among.
fn ty_env_qualified_parents(env: TyEnv, cname: String) : [String] =
  ty_env_qualified_parents_loop(env.entries, cname, [])

fn ty_env_qualified_parents_loop(es: [TyEntry], cname: String, acc: [String]) : [String] {
  match es {
    [] -> list_reverse(acc)
    [e, ...rest] -> {
      let suffix = string_concat("::", cname)
      let kn = string_length(e.name)
      let sn = string_length(suffix)
      if kn <= sn {
        ty_env_qualified_parents_loop(rest, cname, acc)
      } else {
        let tail = string_slice(e.name, kn - sn, sn)
        if tail == suffix {
          let parent = string_slice(e.name, 0, kn - sn)
          # Skip sentinel keys (`<tname>::__type_decl_arity_<N>__`) —
          # their `cname` is `__type_decl_arity_<N>__`, never a real
          # ctor name; but defend by checking the parent starts
          # uppercase (sentinels and real sum types both do, so the
          # length / suffix shape carries the discriminator). The
          # uppercase guard also filters effect-op qualified keys
          # (`Eff.op` was stored under a `.` separator pre-`::`).
          let parent_upper = match char_at(parent, 0) {
            Some(c) -> c >= 'A' and c <= 'Z'
            None    -> false
          }
          if parent_upper and not list_has(acc, parent) {
            ty_env_qualified_parents_loop(rest, cname, [parent, ...acc])
          } else {
            ty_env_qualified_parents_loop(rest, cname, acc)
          }
        } else {
          ty_env_qualified_parents_loop(rest, cname, acc)
        }
      }
    }
  }
}

# emit a diagnostic when a bare ctor name is
# genuinely ambiguous (its bare slot is occupied by a core builtin
# Result/Option ctor AND at least one user type registers a qualified
# `<X>::<cname>` entry whose parent is NOT Result/Option). Returns
# the input state bumped by one error if the diagnostic fires;
# otherwise the input state unchanged. Idempotent — the predicate is
# pure and the diagnostic carries the call site.
fn report_ctor_ambiguity_if_any(st: InferState, cname: String,
                                   line: Int, col: Int) : InferState / Console + File {

  match ty_env_lookup(st.env, cname) {
    None -> st
    Some(bare_sc) -> match extract_return_tycon(bare_sc) {
      None -> st
      Some(bare_parent) ->
        if bare_parent == "Result" or bare_parent == "Option" {
          let user_parents = ty_env_qualified_parents_excluding_builtin(st.env, cname)
          match user_parents {
            [] -> st
            _ -> {
              let candidates_str = format_ctor_candidates(cname,
                                                            [bare_parent, ...user_parents])
              diag_error(st.file, line, col,
                concat_all(["ambiguous constructor '", cname,
                            "' — matches both the core '",
                            bare_parent, ".", cname,
                            "' and user-declared variant(s)"]))
              diag_note(concat_all(["candidates: ", candidates_str]))
              diag_help("annotate the binding with `let <name> : <Parent> = ...` to disambiguate")
              st_bump_err(st)
            }
          }
        } else { st }
    }
  }
}

# Helper: list the qualified parents of `cname` registered in `env`
# that are NOT the Result/Option core. Each parent appears at most
# once; order mirrors the env's newest-first registration order.
fn ty_env_qualified_parents_excluding_builtin(env: TyEnv, cname: String) : [String] =
  filter_builtin_parents(ty_env_qualified_parents(env, cname), [])

fn filter_builtin_parents(parents: [String], acc: [String]) : [String] {
  match parents {
    [] -> list_reverse(acc)
    [p, ...rest] -> if p == "Result" or p == "Option" {
      filter_builtin_parents(rest, acc)
    } else {
      filter_builtin_parents(rest, [p, ...acc])
    }
  }
}

# Helper: render `Result.Ok, Response.Ok` for the ambiguity note.
fn format_ctor_candidates(cname: String, parents: [String]) : String =
  format_ctor_candidates_loop(cname, parents, "")

fn format_ctor_candidates_loop(cname: String, parents: [String], acc: String) : String {
  match parents {
    [] -> acc
    [p, ...rest] -> {
      let one = concat_all([p, ".", cname])
      let sep = if string_length(acc) == 0 { "" } else { ", " }
      format_ctor_candidates_loop(cname, rest, concat_all([acc, sep, one]))
    }
  }
}

# Predicate: is there a genuine ctor ambiguity for
# `cname` between the bare slot and a qualified `<parent>::<cname>`
# entry? Returns true only when:
#   - a qualified `<parent>::<cname>` entry exists, AND
#   - the bare `cname` entry exists, AND
#   - the bare entry's return tycon name differs from `parent`.
# In that case the bare lookup would silently pick the wrong scheme
# (the core builtin or an earlier-declared user variant) and we
# must rewrite the callee to `EModCall(parent, cname)` so resolution
# pins the user variant. When no bare entry exists or bare already
# returns `parent`, the synth path resolves correctly without
# rewriting.
fn ctor_needs_qualification(env: TyEnv, cname: String, parent: String) : Bool {
  match ty_env_lookup_qualified(env, parent, cname) {
    None -> false
    Some(_) -> match ty_env_lookup(env, cname) {
      None -> false
      Some(bare_sc) -> match extract_return_tycon(bare_sc) {
        Some(bare_parent) -> bare_parent != parent
        None -> false
      }
    }
  }
}

# Fix B helper: walk list elements, type-check each against expected
# element type. For plain `EInt(n)` literals expected to be Byte,
# validate 0..255 and retag the node as TyByte; the emitter handles
# the kai_byte(...) lowering.
fn ty_is_vec_head(t: Ty) : Bool =
  match t {
    TyCon(_, name, _) -> name == "Vec"
    _                 -> false
  }

# `[e1, ..., en]` under a `Vec[T]` expectation: coin numeric elements
# against `T` (the #1091 lattice), check the rest against `T` (Byte
# retag included), then hand the TYPED elements to the typed chain
# build — never re-synthesised, so retags survive. The caller's
# trailing unify confirms the result against the annotation. Spread
# elements have no vec build; they are rejected here.
fn check_vec_lit_against(st: InferState, els: [ListElem], hargs: [Ty],
                         line: Int, col: Int) : Inferred / Console + File + Mutable {
  if vec_lit_has_spread(els) {
    diag_error(st.file, line, col, "spread elements are not supported in a Vec literal")
    diag_help("build the list first and convert it: `vec_from_list([...xs, y])`")
    let r = synth(st_bump_err(st), mk_expr(EList(els), line, col))
    r
  } else {
    let elem_exp = match hargs { [t] -> apply_ty(st.sub, t)  _ -> TyAny }
    let checked = check_vec_elems(st, els, elem_exp, line, col, [])
    let vty = TyCon(None, "Vec", [apply_ty(checked.st.sub, elem_exp)])
    mk_inferred(checked.st, vty, vec_lit_build(list_reverse(checked.elems), vty, line, col))
  }
}

# `[e1, ..., en]` under a `Vec[T]<k>` expectation: the habitant IS
# the length. A known value index must equal the element count; an
# unbound index variable brands the literal with its own length and
# the caller's trailing unify binds it (the kind gate rejects a
# non-`Dim` variable there). A habitant that is no `Int` value index
# cannot fix a length — the carrier guard at the formation site.
fn check_fixed_vec_lit(st: InferState, els: [ListElem], hargs: [Ty], u: UnitExprT,
                       line: Int, col: Int) : Inferred / Console + File + Mutable {
  let r = check_vec_lit_against(st, els, hargs, line, col)
  let hab = apply_unit(r.st.sub, u)
  let n = list_length(els)
  match fixed_vec_hab(hab, n) {
    FVOk(h) -> {
      let bty = TyDimT(r.ty, h)
      if ty_is_fixed_vec(bty) { fixed_vec_lit_inferred(r, els, hargs, bty, line, col) }
      else { brand_vec_lit(r, h) }
    }
    FVLen(k) -> {
      diag_error(r.st.file, line, col,
        concat_all(["vector literal has ", int_to_string(n), " elements, but its type fixes the length to ", int_to_string(k)]))
      brand_vec_lit(mk_inferred(st_bump_err(r.st), r.ty, r.expr), hab)
    }
    FVCarrier -> {
      diag_error(r.st.file, line, col,
        concat_all(["`", inf_unit_canon_display(hab), "` cannot fix a `Vec` length — the index of a fixed-width `Vec` is an `Int` value habitant (`Dim`)"]))
      brand_vec_lit(mk_inferred(st_bump_err(r.st), r.ty, r.expr), hab)
    }
  }
}

# A concrete `Vec[e]<n>` literal builds the fixed inline representation:
# the elements are re-checked (already coined once, so this only re-reads
# the typed forms) and handed to the `__fixed_vec_lit` intrinsic the C
# emitter lowers to a flat `(cname){ .a = {...} }` aggregate. The node is
# MUnboxed — a fixed vec has no boxed form.
fn fixed_vec_lit_inferred(r: Inferred, els: [ListElem], hargs: [Ty], bty: Ty,
                          line: Int, col: Int) : Inferred / Console + File + Mutable {
  let elem_exp = match hargs { [t] -> apply_ty(r.st.sub, t)  _ -> TyAny }
  let checked = check_vec_elems(r.st, els, elem_exp, line, col, [])
  let call = fixed_vec_lit_build(list_reverse(checked.elems), bty, line, col)
  mk_inferred(checked.st, bty, unboxed_expr(call))
}

fn unboxed_expr(e: Expr) : Expr =
  Expr { kind: e.kind, line: e.line, col: e.col, ty: e.ty, mode: MUnboxed }

# True when `e` already HOLDS the flat inline representation: the
# `__fixed_vec_lit` intrinsic itself, or a read of a binder that holds
# one (an aliasing `let`, the fixed-vec match's whole-vec binder). Any
# other `Vec[e]<n>`-typed expression (a function return, a field read) is
# a dynamic heap vec at runtime, so its binder de-brands.
fn is_fixed_vec_lit(e: Expr) : Bool = match e.kind {
  ECall(callee, _) -> match callee.kind { EVar(nm) -> nm == "__fixed_vec_lit"  _ -> false }
  EVar(_) -> match e.ty { Some(t) -> ty_is_fixed_vec(t)  None -> false }
  _ -> false
}

# Drop the `Dim` brand off a fixed vec, yielding the dynamic `Vec[e]`.
fn fixed_vec_unbrand(t: Ty) : Ty = match t { TyDimT(base, _) -> base  _ -> t }

# The verdict on a fixed-Vec habitant against a literal of `n`
# elements: the habitant to brand with, a length mismatch carrying
# the fixed length, or a non-index habitant.
type FixedVecHab = FVOk(UnitExprT) | FVLen(Int) | FVCarrier

fn fixed_vec_hab(hab: UnitExprT, n: Int) : FixedVecHab = match hab {
  UOne -> if n == 1 { FVOk(UOne) } else { FVLen(1) }
  USym(s) -> {
    let bare = kind_sym_bare(s)
    if unit_sym_value_domain(bare) == "Int" {
      if decode_int(bare) == n { FVOk(hab) } else { FVLen(decode_int(bare)) }
    } else { FVCarrier }
  }
  UVar(_) -> FVOk(USym(kind_qualify_sym(dim_kind_name(), int_to_string(n))))
  _ -> FVCarrier
}

fn brand_vec_lit(r: Inferred, hab: UnitExprT) : Inferred {
  let bty = TyDimT(r.ty, hab)
  mk_inferred(r.st, bty, with_ty(r.expr, bty))
}

type VecElems = { st: InferState, elems: [Expr] }

fn check_vec_elems(st: InferState, els: [ListElem], elem_ty: Ty,
                   line: Int, col: Int, acc: [Expr]) : VecElems / Console + File + Mutable =
  match els {
    [] -> VecElems { st: st, elems: acc }
    [el, ...rest] -> match el {
      ElPlain(ex) -> match mint_literal(ex, apply_ty(st.sub, elem_ty)) {
        MintOk(m) -> check_vec_elems(st, rest, elem_ty, line, col, [m, ...acc])
        MintErr(msg) -> {
          diag_error(st.file, ex.line, ex.col, msg)
          check_vec_elems(st_bump_err(st), rest, elem_ty, line, col, [ex, ...acc])
        }
        MintNone -> {
          let r = check_elem_against(st, ex, apply_ty(st.sub, elem_ty), line, col)
          check_vec_elems(r.st, rest, elem_ty, line, col, [r.expr, ...acc])
        }
      }
      ElSpread(ex) -> check_vec_elems(st, rest, elem_ty, line, col, [ex, ...acc])
    }
  }

fn vec_lit_has_spread(els: [ListElem]) : Bool =
  match els {
    [] -> false
    [el, ...rest] -> match el {
      ElSpread(_) -> true
      ElPlain(_)  -> vec_lit_has_spread(rest)
    }
  }

# A Vec-typed map-pipe chain. Pure stages over a range head collect
# into ONE pre-sized buffer (`range_map_collect_vec`); an impure stage
# or a non-range source keeps the ordinary list pipeline and converts
# once via `vec_from_list` — same semantics, one materialisation.
fn check_map_pipe_vec_collect(st: InferState, e: Expr,
                              line: Int, col: Int) : Inferred / Console + File + Mutable =
  match pipe_fusion_as_collect(e) {
    None -> synth(st, e)
    Some(fc) -> {
      let g = fuse_all_raw(st, fc.stages, false)
      if g.ok {
        match pipe_fusion_collect_rewrite(fc, line, col) {
          Some(rewritten) -> synth(g.st, rewritten)
          None            -> synth(g.st, vec_collect_via_list(e, line, col))
        }
      } else { synth(g.st, vec_collect_via_list(e, line, col)) }
    }
  }

fn vec_collect_via_list(e: Expr, line: Int, col: Int) : Expr =
  mk_expr(ECall(mk_expr(EVar("vec_from_list"), line, col), [e]), line, col)

# A map-pipe chain in a `Vec[e]<n>` slot: a fixed vec has no runtime
# length, so the chain may only collect there when its length is proved
# HERE. A map is 1:1, so the length is the source's — provable for a
# literal head (`[a, b, c] | f`), where the chain unrolls to one literal
# of per-element stage applications and rides the fixed-vec literal path.
# Any other head has a statically-unknown length and is declined loudly,
# never silently collected into a wrong-length aggregate.
fn check_map_pipe_fixed_collect(st: InferState, e: Expr, expected: Ty,
                                line: Int, col: Int) : Inferred / Console + File + Mutable =
  match pipe_fusion_as_collect(e) {
    None -> synth(st, e)
    Some(fc) -> match fixed_collect_unroll(fc, line, col) {
      Some(unrolled) -> check_expr_against(st, unrolled, expected, "fixed-width vector collect", line, col)
      None -> {
        diag_error(st.file, line, col,
          concat_all(["a `|` chain cannot collect into a fixed-width `Vec[t]<",
            int_to_string(fixed_vec_n(expected)),
            ">`: its length is not known at compile time"]))
        diag_help("start the chain from a vector literal, or collect into a dynamic `Vec` first")
        mk_inferred(st_bump_err(st), expected, with_ty(e, expected))
      }
    }
  }

# Unroll `[e0, ..., ek] | f | g` into `[g(f(e0)), ..., g(f(ek))]`. Only a
# spread-free literal head qualifies: its length is the count, and each
# element is applied independently so no stage runs more than once per
# element (the map semantics). The result is a bare literal, so it rides
# the fixed-vec literal path unchanged.
fn fixed_collect_unroll(fc: FusedCollect, line: Int, col: Int) : Option[Expr] =
  match fc.source.kind {
    EList(els) ->
      if vec_lit_has_spread(els) { None }
      else { Some(mk_expr(EList(fixed_collect_elems(els, fc.stages, line, col)), line, col)) }
    _ -> None
  }

fn fixed_collect_elems(els: [ListElem], stages: [Expr], line: Int, col: Int) : [ListElem] =
  fixed_collect_elems_at(els, stages, 0, line, col)

# Every per-element copy of a stage takes its own column: perceus keys
# last-use on node position, and a lambda stage lifts to a symbol named
# after its position — duplicate positions would collide on both.
fn fixed_collect_elems_at(els: [ListElem], stages: [Expr], i: Int,
                          line: Int, col: Int) : [ListElem] =
  match els {
    [] -> []
    [el, ...rest] -> {
      let tail = fixed_collect_elems_at(rest, stages, i + 1, line, col)
      match el {
        ElPlain(x) -> [ElPlain(fixed_collect_apply(x, stages, i, 0, line, col)), ...tail]
        ElSpread(_) -> tail
      }
    }
  }

fn fixed_collect_apply(x: Expr, stages: [Expr], i: Int, j: Int, line: Int, col: Int) : Expr =
  match stages {
    [] -> x
    [s, ...rest] -> {
      let sref = Expr { kind: s.kind, line: s.line, col: col + i * 100 + j, ty: s.ty, mode: s.mode }
      fixed_collect_apply(mk_expr(ECall(sref, [x]), line, col), rest, i, j + 1, line, col)
    }
  }

fn check_list_elems_against(st: InferState, els: [ListElem], elem_ty: Ty,
                            line: Int, col: Int) : Inferred / Console + File + Mutable {


  let acc = check_list_elems_loop(st, els, elem_ty, line, col, [])
  let ty = TyListT(elem_ty)
  let root = with_ty(mk_expr(EList(list_reverse(acc.elems)), line, col), ty)
  mk_inferred(acc.st, ty, root)
}

fn check_list_elems_loop(st: InferState, els: [ListElem], elem_ty: Ty,
                         line: Int, col: Int, acc: [ListElem]) : InferredElems / Console + File + Mutable {


  match els {
    [] -> InferredElems { st: st, elems: acc }
    [el, ...rest] -> match el {
      ElPlain(ex) -> {
        let r = check_elem_against(st, ex, elem_ty, line, col)
        check_list_elems_loop(r.st, rest, elem_ty, line, col, [ElPlain(r.expr), ...acc])
      }
      ElSpread(ex) -> {
        let r = synth(st, ex)
        let s1 = st_unify(r.st, TyListT(elem_ty), r.ty, "list spread", line, col)
        check_list_elems_loop(s1, rest, elem_ty, line, col, [ElSpread(r.expr), ...acc])
      }
    }
  }
}

fn check_elem_against(st: InferState, ex: Expr, elem_ty: Ty,
                      line: Int, col: Int) : Inferred / Console + File + Mutable {


  match elem_ty {
    TyByte -> match ex.kind {
      EInt(n) -> if n >= 0 and n <= 255 {
        let retagged = with_ty(mk_expr(EInt(n), ex.line, ex.col), TyByte)
        mk_inferred(st, TyByte, retagged)
      } else {
        let r = synth(st, ex)
        let s1 = st_unify(r.st, elem_ty, r.ty, "Byte literal out of range 0..255", line, col)
        mk_inferred(s1, elem_ty, r.expr)
      }
      _ -> elem_synth_unify(st, ex, elem_ty, line, col)
    }
    # A list literal against a Vec-typed element (a fixed-width
    # matrix row) re-enters the bidirectional path, so the inner
    # literal builds a vec and its length habitant binds.
    _ -> match ex.kind {
      EList(_) ->
        if ty_vec_headed(elem_ty) {
          let r = check_expr_against(st, ex, elem_ty, "list element", ex.line, ex.col)
          let s1 = st_unify(r.st, elem_ty, r.ty, "list element", line, col)
          mk_inferred(s1, apply_ty(s1.sub, r.ty), r.expr)
        } else { elem_synth_unify(st, ex, elem_ty, line, col) }
      _ -> elem_synth_unify(st, ex, elem_ty, line, col)
    }
  }
}

fn elem_synth_unify(st: InferState, ex: Expr, elem_ty: Ty,
                    line: Int, col: Int) : Inferred / Console + File + Mutable {
  let r = synth(st, ex)
  let s1 = st_unify(r.st, elem_ty, r.ty, "list element", line, col)
  mk_inferred(s1, elem_ty, r.expr)
}

#[doc("True when a type is `Vec`-headed, seeing through any `Dim` brand — the fixed-width representation reads this to keep a `Vec<1>` distinct from the dynamic `Vec`.")]
pub fn ty_vec_headed(t: Ty) : Bool = match t {
  TyDimT(inner, _) -> ty_vec_headed(inner)
  TyCon(_, name, _) -> name == "Vec"
  _ -> false
}

# same idea but threaded through an EBlock when the tail
# is itself an EMatch. The fn-body case `fn f(...) : T = match { ... }`
# parses as a bare EMatch (handled by `check_expr_against`), but
# `fn f(...) : T { ...stmts... match { ... } }` parses as an EBlock
# whose tail is an EMatch — synth_block ignores the expected type, so
# we recreate just enough of synth_block here to route the tail
# through check_match while the prefix stmts still synth normally.
fn check_body_against_ret(st: InferState, body: Expr, expected: Ty,
                          what: String, line: Int, col: Int) : Inferred / Console + File + Mutable {


  match body.kind {
    EMatch(scr, arms) -> check_match(st, scr, arms, expected, body.line, body.col)
    EIf(c, t_, eo)    -> check_if(st, c, t_, eo, expected, body.line, body.col)
    EBlock(stmts, tail) -> match tail {
      Some(te) -> match te.kind {
        EMatch(scr, arms) -> {
          let outer = st
          let is_ = synth_stmts(st, stmts)
          let r = check_match(is_.st, scr, arms, expected, te.line, te.col)
          let st2 = st_restore_entries(outer, r.st)
          let ty = apply_ty(st2.sub, r.ty)
          let root = with_ty(mk_expr(EBlock(is_.stmts, Some(r.expr)), body.line, body.col), ty)
          mk_inferred(st2, ty, root)
        }
        EIf(c, t_, eo) -> {
          let outer = st
          let is_ = synth_stmts(st, stmts)
          let r = check_if(is_.st, c, t_, eo, expected, te.line, te.col)
          let st2 = st_restore_entries(outer, r.st)
          let ty = apply_ty(st2.sub, r.ty)
          let root = with_ty(mk_expr(EBlock(is_.stmts, Some(r.expr)), body.line, body.col), ty)
          mk_inferred(st2, ty, root)
        }
        # thread `expected` into the block tail
        # when the tail is a bare ctor reference (`ECall(EVar, _)` or
        # `EVar`), so annotation-driven disambiguation can pick a
        # qualified user variant over the core builtin. Other
        # tail shapes keep synthing the whole body as before to avoid
        # regressions in non-ctor expression types.
        ECall(_, _) -> {
          let outer = st
          let is_ = synth_stmts(st, stmts)
          let r = check_expr_against(is_.st, te, expected, what, te.line, te.col)
          let st2 = st_restore_entries(outer, r.st)
          let ty = apply_ty(st2.sub, r.ty)
          let root = with_ty(mk_expr(EBlock(is_.stmts, Some(r.expr)), body.line, body.col), ty)
          mk_inferred(st2, ty, root)
        }
        EVar(_) -> {
          let outer = st
          let is_ = synth_stmts(st, stmts)
          let r = check_expr_against(is_.st, te, expected, what, te.line, te.col)
          let st2 = st_restore_entries(outer, r.st)
          let ty = apply_ty(st2.sub, r.ty)
          let root = with_ty(mk_expr(EBlock(is_.stmts, Some(r.expr)), body.line, body.col), ty)
          mk_inferred(st2, ty, root)
        }
        _ -> synth(st, body)
      }
      None -> synth(st, body)
    }
    # bare-expression body benefits from
    # annotation-driven ctor disambiguation when it is a ctor call
    # or a nullary ctor reference. Other shapes stay on synth to
    # avoid regressing existing inference paths.
    ECall(_, _) -> check_expr_against(st, body, expected, what, body.line, body.col)
    EVar(_) -> check_expr_against(st, body, expected, what, body.line, body.col)
    _ -> synth(st, body)
  }
}

# walk arms and rewrite `PVariantRecord(name, fields)` to
# `PRecord(fields)` whenever `name` is a record-alias declaration
# (registered in `recs` via `collect_records`). Recurses into nested
# patterns so a `PVariantRecord` buried inside `PAs` / `PList` /
# another record field is also rewritten.
fn rewrite_record_alias_arms(arms: [Arm], recs: [RecInfo]) : [Arm] {
  match arms {
    [] -> []
    [a, ...rest] -> match a {
      Arm(pat, guard, body) ->
        [Arm(rewrite_record_alias_pat(pat, recs), guard, body),
         ...rewrite_record_alias_arms(rest, recs)]
    }
  }
}

fn rewrite_record_alias_pat(pat: Pattern, recs: [RecInfo]) : Pattern {
  match pat.pkind {
    PVariantRecord(name, fs) -> {
      let fs_r = rewrite_record_alias_pfields(fs, recs)
      match rec_find(recs, name) {
        Some(_) -> Pattern { pkind: PRecord(fs_r), line: pat.line, col: pat.col }
        None    -> Pattern { pkind: PVariantRecord(name, fs_r), line: pat.line, col: pat.col }
      }
    }
    PRecord(fs) ->
      Pattern { pkind: PRecord(rewrite_record_alias_pfields(fs, recs)),
                line: pat.line, col: pat.col }
    PVariant(name, subs) ->
      Pattern { pkind: PVariant(name, rewrite_record_alias_pat_list(subs, recs)),
                line: pat.line, col: pat.col }
    PList(subs, rest) ->
      Pattern { pkind: PList(rewrite_record_alias_pat_list(subs, recs), rest),
                line: pat.line, col: pat.col }
    PAs(name, inner) ->
      Pattern { pkind: PAs(name, rewrite_record_alias_pat(inner, recs)),
                line: pat.line, col: pat.col }
    _ -> pat
  }
}

fn rewrite_record_alias_pat_list(ps: [Pattern], recs: [RecInfo]) : [Pattern] {
  match ps {
    [] -> []
    [p, ...rest] -> [rewrite_record_alias_pat(p, recs),
                     ...rewrite_record_alias_pat_list(rest, recs)]
  }
}

fn rewrite_record_alias_pfields(fs: [PField], recs: [RecInfo]) : [PField] {
  match fs {
    [] -> []
    [f, ...rest] -> match f {
      PField(name, sub, sh) -> [PField(name, rewrite_record_alias_pat(sub, recs), sh),
                                ...rewrite_record_alias_pfields(rest, recs)]
    }
  }
}

# rewrite every `PNarrow(name, T)` arm into a
# sequence of `PAs(name, PVariant(Vi, []))` arms — one per variant
# of T plus one for the component's own dual-rep ctor name. Under
# the dual representation the parent `type U = A | B`
# decl registers `A` and `B` as zero-arg ctors of `U`, so a value
# may carry either the parent's variant tag (`A`) OR an inner-type
# variant tag (any variant of `A`'s own decl). Dispatching on both
# keeps narrowing observably correct under whichever runtime layout
# the user constructed the value with.
fn expand_narrow_arms(arms: [Arm], env: TyEnv) : [Arm] {
  match arms {
    [] -> []
    [a, ...rest] -> match a {
      Arm(pat, guard, body) -> match pat.pkind {
        PNarrow(name, ty_expr) -> {
          let narrow_ty = inf_resolve_ty(ty_expr)
          let tycon_name = match narrow_ty {
            TyCon(_, n, _) -> n
            _           -> ""
          }
          let inner_vs = if tycon_name == "" { [] } else { variants_of_type(env, tycon_name) }
          # Cover both the dual-rep ctor name (matches values built
          # via the parent union's own variant ctor) and each inner
          # variant (matches values built via the component type's
          # own ctors).
          let all_vs = if tycon_name == "" { inner_vs } else { [tycon_name, ...inner_vs] }
          let expanded = expand_narrow_one(all_vs, name, guard, body, pat.line, pat.col)
          list_append(expanded, expand_narrow_arms(rest, env))
        }
        _ -> [a, ...expand_narrow_arms(rest, env)]
      }
    }
  }
}

fn expand_narrow_one(vs: [String], name: String, guard: Option[Expr],
                      body: Expr, line: Int, col: Int) : [Arm] {
  match vs {
    [] -> []
    [v, ...rest] -> {
      let inner = mk_pat(PVariant(v, []), line, col)
      let pas = mk_pat(PAs(name, inner), line, col)
      [Arm(pas, guard, body), ...expand_narrow_one(rest, name, guard, body, line, col)]
    }
  }
}

# ---- exhaustiveness checking ----
#
# Flag match expressions that miss a constructor of a known sum
# type. Scope: built-in Option / Result and any user sum whose
# TyCon name appears in the env. "Known variants" is derived by
# walking the env and collecting uppercase-lead entries whose
# return type is that TyCon — cheap since errors are the only
# callers.

fn is_catch_all_pat(pat: Pattern) : Bool {
  match pat.pkind {
    PWild     -> true
    PBind(_)  -> true
    PHole(_)  -> true
    # `name @ catch_all` is itself a catch-all — the binding
    # does not narrow the cases the arm covers.
    PAs(_, sub) -> is_catch_all_pat(sub)
    _         -> false
  }
}

fn has_catch_all(arms: [Arm]) : Bool {
  match arms {
    [] -> false
    [a, ...rest] -> match a {
      Arm(pat, guard, _) -> {
        let catch = is_catch_all_pat(pat)
        let unguarded = match guard { None -> true Some(_) -> false }
        if catch and unguarded { true }
        else { has_catch_all(rest) }
      }
    }
  }
}

fn variant_name_of_arm(a: Arm) : Option[String] {
  match a {
    Arm(pat, _, _) -> variant_name_of_pat(pat)
  }
}

# drill through `name @ inner` so `Some(x) @ pat` and
# similar shapes still report their variant for exhaustiveness.
fn variant_name_of_pat(pat: Pattern) : Option[String] {
  match pat.pkind {
    PVariant(nm, _)       -> Some(nm)
    PVariantRecord(nm, _) -> Some(nm)
    PAs(_, sub)           -> variant_name_of_pat(sub)
    _                     -> None
  }
}

fn arms_cover_variant(arms: [Arm], target: String) : Bool {
  match arms {
    [] -> false
    [a, ...rest] -> match variant_name_of_arm(a) {
      Some(nm) -> if nm == target { true } else { arms_cover_variant(rest, target) }
      None     -> arms_cover_variant(rest, target)
    }
  }
}

fn extract_return_tycon(sc: TyScheme) : Option[String] {
  match sc {
    Scheme(_, _, _, _, ty) -> match ty {
      TyFnT(_, ret, _) -> match ret {
        TyCon(_, nm, _) -> Some(nm)
        _            -> None
      }
      TyCon(_, nm, _) -> Some(nm)
      _            -> None
    }
  }
}

fn variants_of_type_loop(es: [TyEntry], target: String, acc: [String]) : [String] =
  variants_of_type_loop_arity(es, target, -1, acc)

# arity-aware entry point. Callers that know the
# scrutinee's `TyCon(_, name, args)` shape pass `list_length(args)` so
# the walker picks variants whose return tycon has the SAME arity.
# This discriminates `Tree` (arity 0, user redeclaration) from
# `Tree[k, v]` (arity 2, private `stdlib/collections/map.kai`).
# Callers that don't know the arity pass `variants_of_type_loop`'s
# legacy entry point and accept the "pin to first variant seen"
# behaviour.
fn variants_of_type_loop_with_arity(es: [TyEntry], target: String,
                                       arity: Int, acc: [String]) : [String] =
  variants_of_type_loop_arity(es, target, arity, acc)

# walk newest-first; track the arity (number of type
# arguments on the return tycon) of the first variant we accept and
# skip any subsequent variant of the same `target` name whose return
# tycon has a DIFFERENT arity. The arity discriminates `Tree`
# (user, arity 0) from `Tree[k, v]` (core `stdlib/collections/
# map.kai`, arity 2) when both register variants under the shared
# bare-name table. Without this filter, a non-`pub` core type's
# variants leaked into the user-scope match-exhaustiveness check
# any time the user redeclared the same type name.
#
# `pin = -1` is the "not yet seen" sentinel — the first matching
# variant pins the canonical arity for this walk. A subsequent
# variant with a different arity belongs to an unrelated (shadowed
# or unrelated-but-same-name) declaration and is ignored.
#
# When the user's redeclaration has the same arity as the core
# type, this filter alone is not sufficient — but that case is
# already caught by `validate_type_name_collisions_decls` for `pub`
# cores, and the `top_names` shadow guard in `add_variants_loop`
# strips zero-arg ctors that collide with another top-level type.
# Private same-arity collisions in distinct stdlib modules are
# rare; we currently leave them for a follow-up if they surface.
fn variants_of_type_loop_arity(es: [TyEntry], target: String,
                                  pin: Int, acc: [String]) : [String] {
  match es {
    [] -> list_reverse(acc)
    [e, ...rest] -> {
      # sentinel boundary check. The marker name has
      # the form `<target>::__type_decl_arity_<N>__`. If we have
      # already pinned an arity and we cross a marker for the same
      # target whose arity equals our pin, we have left the
      # newest declaration's variant region and entered an earlier
      # (shadowed) one — stop.
      if pin >= 0 and e.name == ty_env_decl_marker_name(target, pin) {
        # Same-(target, arity) marker reached after we already
        # collected at least one variant (or pinned). Either way,
        # the variants we have are the canonical set.
        list_reverse(acc)
      } else {
      # Effect ops are registered as `Eff.op` — those
      # names also start uppercase but are not sum-type constructors,
      # so the exhaustiveness check would otherwise treat them as
      # missing variants of any matching return type.
      let first_upper = match char_at(e.name, 0) {
        Some(c) -> c >= 'A' and c <= 'Z'
        None    -> false
      }
      # user variants registered under the
      # qualified `<target>::<cname>` key (because a core builtin
      # occupied the bare slot) must still surface as variants of
      # `target`. Strip the `<target>::` prefix and recurse with the
      # bare name as the candidate variant. Other qualified entries
      # (`<other>::<cname>`, sentinels, effect ops) remain filtered.
      let qual_strip = ty_env_strip_qualified_prefix(e.name, target)
      match qual_strip {
        Some(bare) -> {
          # bare must itself be uppercase (sum-ctor convention) and
          # not contain `.` (effect-op `Eff.op` was registered under a
          # dotted name pre-`::` keying and must still be excluded).
          let bare_upper = match char_at(bare, 0) {
            Some(c) -> c >= 'A' and c <= 'Z'
            None    -> false
          }
          if bare_upper and not string_contains_dot(bare) {
            match extract_return_tycon_arity(e.scheme) {
              Some(ta) -> match ta {
                TCA(tn, ar) -> if tn == target {
                  if pin < 0 {
                    variants_of_type_loop_arity(rest, target, ar, [bare, ...acc])
                  } else if ar == pin {
                    variants_of_type_loop_arity(rest, target, pin, [bare, ...acc])
                  } else {
                    variants_of_type_loop_arity(rest, target, pin, acc)
                  }
                } else {
                  variants_of_type_loop_arity(rest, target, pin, acc)
                }
              }
              None -> variants_of_type_loop_arity(rest, target, pin, acc)
            }
          } else {
            variants_of_type_loop_arity(rest, target, pin, acc)
          }
        }
        None ->
          if first_upper and not string_contains_dot(e.name) {
            match extract_return_tycon_arity(e.scheme) {
              Some(ta) -> match ta {
                TCA(tn, ar) -> if tn == target {
                  if pin < 0 {
                    variants_of_type_loop_arity(rest, target, ar, [e.name, ...acc])
                  } else if ar == pin {
                    variants_of_type_loop_arity(rest, target, pin, [e.name, ...acc])
                  } else {
                    variants_of_type_loop_arity(rest, target, pin, acc)
                  }
                } else {
                  variants_of_type_loop_arity(rest, target, pin, acc)
                }
              }
              None -> variants_of_type_loop_arity(rest, target, pin, acc)
            }
          } else {
            variants_of_type_loop_arity(rest, target, pin, acc)
          }
      }
      }
    }
  }
}

# return tycon paired with the arity of its type-arg
# list. `TCA(name, arity)` lets `variants_of_type_loop_arity`
# distinguish `Tree` (arity 0) from `Tree[k, v]` (arity 2).
type TyConArity = TCA(String, Int)

# sentinel marker name. Inserted into `env.entries`
# right after a `DType`'s variants are registered, with format
# `<tname>::__type_decl_arity_<N>__`. The walker that enumerates
# a tycon's variants stops at the first matching sentinel after
# accepting at least one variant, which closes the boundary of an
# earlier same-name same-arity declaration (e.g. a private core
# `type SplitN = SplitOk | SplitShort` shadowed by a user
# redeclaration of the same name and arity).
#
# The format keeps the sentinel filtered out by the existing
# uppercase-name walkers (`__` does not start with `A`..`Z`) and
# by the `::<fname>` qualified-key suffix scan (the sentinel ends
# with `__type_decl_arity_<N>__`, not `::<user_target>`).
fn ty_env_decl_marker_name(tname: String, arity: Int) : String =
  concat_all([tname, "::__type_decl_arity_",
              int_to_string(arity), "__"])

fn ty_env_add_decl_marker(env: TyEnv, tname: String, arity: Int) : TyEnv = {
  # The sentinel's scheme is a closed `Scheme([], [], [], [], TyAny)`
  # so any accidental read returns `None` from
  # `extract_return_tycon_arity`. The walker keys on the name
  # alone and never dereferences the scheme.
  let dummy = mono(TyAny)
  ty_env_add(env, ty_env_decl_marker_name(tname, arity), dummy)
}

fn extract_return_tycon_arity(sc: TyScheme) : Option[TyConArity] {
  # NOTE: name the slot `tas` (not `args`); `args` shadows the
  # core's CLI-args fn and the codegen wires the call to the
  # closure instead of the local binding (see CLAUDE.md / global
  # feedback memo on the `args` shadow).
  match sc {
    Scheme(_, _, _, _, ty) -> match ty {
      TyFnT(_, ret, _) -> match ret {
        TyCon(_, nm, tas) -> Some(TCA(nm, list_length(tas)))
        _              -> None
      }
      TyCon(_, nm, tas) -> Some(TCA(nm, list_length(tas)))
      _              -> None
    }
  }
}

# components recorded in `env.unions` (the per-decl
# summary) are merged with the env-entry walk so shadow components
# (a variant whose name matches an existing top-level type
# and is therefore not registered as a zero-arg ctor) still surface
# as components. Names from the variant table win when both lists
# would otherwise duplicate; the merge preserves the entry-side
# order to avoid spurious selfhost output diffs.
fn variants_of_type(env: TyEnv, tycon: String) : [String] = {
  let from_entries = variants_of_type_loop(env.entries, tycon, [])
  let from_summary = union_components_of(env.unions, tycon)
  # the entry walker emits one variant name per
  # matching entry, and the ctor-overloading walker registers both bare (`Ok`) and qualified
  # (`Result::Ok`) keys for core builtins (and qualified-only for
  # user variants that collide with bare). Dedup the entry list before
  # merging so exhaustiveness does not see double-counted variants.
  let entries_dedup = union_merge_unique([], from_entries)
  union_merge_unique(entries_dedup, from_summary)
}

# arity-aware variant of `variants_of_type`. Callers
# that have the scrutinee's full `TyCon(_, name, args)` use this to
# select variants whose return tycon has the matching arity, so a
# private core `Tree[k, v]` (arity 2) does not leak its variants
# into the exhaustiveness check of a user-declared `Tree` (arity 0)
# and vice-versa. Falls back to the bare-name walk when no entry
# matches the arity (legacy single-arity types stay byte-identical).
fn variants_of_type_arity(env: TyEnv, tycon: String, arity: Int) : [String] = {
  # dedup the entry walker's output before any
  # downstream merge. Bare (`Ok`) and qualified (`Result::Ok`) entries
  # both produce the same bare ctor name; without dedup exhaustiveness
  # double-counts and reports phantom missing variants.
  let raw_entries = variants_of_type_loop_with_arity(env.entries, tycon, arity, [])
  let from_entries = union_merge_unique([], raw_entries)
  match from_entries {
    [] -> {
      # No arity-matched entries — fall back to the bare-name walk
      # so records / opaque tycons whose schemes the variant table
      # does not register still surface their union components.
      # The fallback consults `env.unions` (the shadow path) and is
      # non-arity-aware; this is acceptable
      # because the fallback only fires when the variant entries
      # produced no arity match — i.e. no genuine ambiguity exists.
      let raw_fallback = variants_of_type_loop(env.entries, tycon, [])
      let fallback = union_merge_unique([], raw_fallback)
      union_merge_unique(fallback, union_components_of(env.unions, tycon))
    }
    # Arity-matched entries from the variant table are the
    # canonical view; `env.unions` is non-arity-aware and would
    # re-introduce the other arity's components if merged in
    # blindly. Filter the summary against the matched entries'
    # parent declaration by keeping only summary entries that
    # also surface (or are already in) the entry-list.
    _ -> union_merge_with_summary_filtered(from_entries,
                                              env.unions, tycon, arity, env.entries)
  }
}

# merge `from_entries` (already arity-matched) with the
# subset of `env.unions` components that *also* belong to the same
# (name, arity) declaration. A `UnionInfo` does not carry arity
# directly, so we infer it from any entry whose return tycon
# matches `(tycon, arity)` — `UnionInfo`'s `parent` field. If a
# `UnionInfo` for `tycon` exists whose listed components include at
# least one of the variants we already pulled from entries, we
# merge in its full component list; otherwise we ignore it (the
# other-arity union is structurally unrelated).
fn union_merge_with_summary_filtered(from_entries: [String],
                                        unions: [UnionInfo], tycon: String,
                                        arity: Int, es: [TyEntry]) : [String] {
  match unions {
    [] -> from_entries
    [u, ...rest] -> match u {
      UI(parent, comps, _, _) ->
        if parent == tycon {
          let cnames = ty_component_names(comps, [])
          if any_str_in(cnames, from_entries) {
            union_merge_unique(from_entries,
              union_merge_with_summary_filtered_collect(cnames, []))
          } else {
            union_merge_with_summary_filtered(from_entries, rest, tycon, arity, es)
          }
        } else {
          union_merge_with_summary_filtered(from_entries, rest, tycon, arity, es)
        }
    }
  }
}

fn union_merge_with_summary_filtered_collect(xs: [String], acc: [String]) : [String] {
  match xs {
    [] -> list_reverse(acc)
    [h, ...rest] -> union_merge_with_summary_filtered_collect(rest, [h, ...acc])
  }
}

fn ty_component_names(ts: [Ty], acc: [String]) : [String] {
  match ts {
    [] -> list_reverse(acc)
    [t, ...rest] -> match t {
      TyCon(_, nm, _) -> ty_component_names(rest, [nm, ...acc])
      _ -> ty_component_names(rest, acc)
    }
  }
}

fn any_str_in(xs: [String], ys: [String]) : Bool {
  match xs {
    [] -> false
    [h, ...rest] -> if list_has(ys, h) { true } else { any_str_in(rest, ys) }
  }
}

fn union_merge_unique(a: [String], b: [String]) : [String] {
  match b {
    [] -> a
    [n, ...rest] -> if list_has(a, n) { union_merge_unique(a, rest) }
                    else { union_merge_unique(list_append(a, [n]), rest) }
  }
}

# classify a type's variants for `variants[T]()`. The
# builtin restricts T to *nullary-only* sum types: once a variant
# takes arguments, "list all inhabitants" is ill-defined. This walker
# partitions
# the env entries that mention `target` as their return tycon
# into nullary names and payload-bearing names; it also reports
# the "no such sum type" case (no entry matches at all).
type VariantsCheck = VCOk([String]) | VCNotSum | VCHasPayload([String])

fn check_variants_nullary(env: TyEnv, target: String) : VariantsCheck {
  check_variants_nullary_loop(env.entries, target, [], [])
}

fn check_variants_nullary_loop(es: [TyEntry], target: String,
                                ok_acc: [String], err_acc: [String]) : VariantsCheck {
  match es {
    # NOTE on order: `env.entries` is most-recent-first (ty_env_add
    # prepends). For sum-type variants registered via
    # `add_variants_loop`, that means the head of `entries` is the
    # *last*-declared variant. Walking head-to-tail and prepending to
    # `acc` therefore double-inverts back to declaration order, so
    # the accumulators here are returned **without** a final reverse.
    # `variants[T]()`'s spec guarantees declaration order; relying on
    # this ordering is intentional. (variants_of_type_loop does the
    # opposite — it list_reverses — but its caller, exhaustiveness,
    # is order-insensitive, so the bug never surfaced there.)
    [] -> {
      let ok_empty  = match ok_acc  { [] -> true _ -> false }
      let err_empty = match err_acc { [] -> true _ -> false }
      if ok_empty and err_empty { VCNotSum }
      else if err_empty { VCOk(ok_acc) }
      else { VCHasPayload(err_acc) }
    }
    [e, ...rest] -> {
      # qualified entries `<target>::<cname>` are
      # registered alongside bare entries for variants whose bare
      # slot would shadow a core builtin (Ok/Err/Some/None). The
      # variants walker must use the BARE name (the variant tag
      # runtime keys on), and bare AND qualified entries collapse to
      # the same tag — emit the bare form, and dedup via the caller.
      # Other qualified entries (e.g. `Eff.op` under a `.` separator)
      # were already filtered by the `string_contains_dot` check.
      let visible_name = match ty_env_strip_qualified_prefix(e.name, target) {
        Some(bare) -> bare
        None       -> e.name
      }
      let first_upper = match char_at(visible_name, 0) {
        Some(c) -> c >= 'A' and c <= 'Z'
        None    -> false
      }
      if first_upper and not string_contains_dot(visible_name) {
        match e.scheme {
          Scheme(_, _, _, _, ty) -> match ty {
            # Zero-arg variant: scheme is the bare TyCon (e.g. `Hearts`
            # for `type Suit = Hearts | ...`).
            TyCon(_, nm, _) ->
              if nm == target {
                check_variants_nullary_loop(rest, target, [visible_name, ...ok_acc], err_acc)
              } else {
                check_variants_nullary_loop(rest, target, ok_acc, err_acc)
              }
            # N-ary variant: scheme is a TyFnT returning the target.
            # Empty args list means nullary; non-empty means payload.
            TyFnT(args, ret, _) -> match ret {
              TyCon(_, nm, _) ->
                if nm == target {
                  let args_empty = match args { [] -> true _ -> false }
                  if args_empty {
                    check_variants_nullary_loop(rest, target, [visible_name, ...ok_acc], err_acc)
                  } else {
                    check_variants_nullary_loop(rest, target, ok_acc, [visible_name, ...err_acc])
                  }
                } else {
                  check_variants_nullary_loop(rest, target, ok_acc, err_acc)
                }
              _ -> check_variants_nullary_loop(rest, target, ok_acc, err_acc)
            }
            _ -> check_variants_nullary_loop(rest, target, ok_acc, err_acc)
          }
        }
      } else {
        check_variants_nullary_loop(rest, target, ok_acc, err_acc)
      }
    }
  }
}

fn find_missing_variants(needed: [String], arms: [Arm], acc: [String]) : [String] {
  match needed {
    [] -> list_reverse(acc)
    [v, ...rest] -> {
      if arms_cover_variant(arms, v) {
        find_missing_variants(rest, arms, acc)
      } else {
        find_missing_variants(rest, arms, [v, ...acc])
      }
    }
  }
}

# Inverse of find_missing_variants — used by the match diagnostics to print
# the "covered:" note alongside "missing:". Walking the needed list
# again is cheaper than caching given the small variant counts.
fn find_covered_variants(needed: [String], arms: [Arm], acc: [String]) : [String] {
  match needed {
    [] -> list_reverse(acc)
    [v, ...rest] -> {
      if arms_cover_variant(arms, v) {
        find_covered_variants(rest, arms, [v, ...acc])
      } else {
        find_covered_variants(rest, arms, acc)
      }
    }
  }
}

# Template 2 — common note + help block for non-exhaustive
# match diagnostics. The header diag_error already carries the type
# name and missing list (kept verbatim so existing fixtures still
# match); these notes add per-missing-variant lines, the covered list,
# and the canonical Rust/Elm-style help.
fn emit_nonexhaustive_notes(missing: [String], covered: [String]) : Unit / Console {
  emit_missing_notes(missing)
  match covered {
    [] -> ()
    _  -> diag_note("covered: #{inf_join_with(covered, ", ")}")
  }
  emit_nonexhaustive_help(missing)
}

fn emit_missing_notes(ms: [String]) : Unit / Console {
  match ms {
    [] -> ()
    [m, ...rest] -> {
      diag_note("missing variant: `#{m}`")
      emit_missing_notes(rest)
    }
  }
}

fn emit_nonexhaustive_help(missing: [String]) : Unit / Console {
  match missing {
    []      -> diag_help("add a wildcard `_ -> ...` arm")
    [m, ..._] -> diag_help("add an arm `#{m} -> ...` or a wildcard `_ -> ...`")
  }
}

# structured T2 Diagnostic builder. Mirrors the text emitted
# by `diag_error` + `emit_nonexhaustive_notes` so the stderr block and
# the collected Diagnostic carry the same content.
fn build_nonexhaustive_related(file: String, line: Int, col: Int,
                                 missing: [String], covered: [String]) : [RelatedInfo] {
  let miss_notes = map(missing, (m) => ri_note(file, line, col, "missing variant: `#{m}`"))
  let cov_notes = match covered {
    [] -> []
    _  -> [ri_note(file, line, col, "covered: #{inf_join_with(covered, ", ")}")]
  }
  let help_msg = match missing {
    []        -> "add a wildcard `_ -> ...` arm"
    [m, ..._] -> "add an arm `#{m} -> ...` or a wildcard `_ -> ...`"
  }
  let help_ri = [ri_help(file, line, col, help_msg)]
  list_append(miss_notes, list_append(cov_notes, help_ri))
}

fn build_nonexhaustive_diag(file: String, line: Int, col: Int,
                              header: String, missing: [String],
                              covered: [String]) : Diagnostic =
  mk_diag(SevError, file, line, col, header,
          build_nonexhaustive_related(file, line, col, missing, covered))

fn check_exhaustive(st: InferState, arms: [Arm], scr_ty: Ty, line: Int, col: Int) : InferState / Console + File {

  if has_catch_all(arms) { st }
  else {
    match scr_ty {
      TyCon(_, tycon, scr_tas) -> {
        # thread the scrutinee's tycon arity so private
        # core types of the same bare name but different arity
        # (e.g. `Tree[k, v]` in `stdlib/collections/map.kai`) do not
        # leak their variants into the user's exhaustiveness check.
        # The slot is named `scr_tas` (not `args`) to avoid the
        # `args`-core shadow that bites the stage 0/1 resolver.
        let needed = variants_of_type_arity(st.env, tycon, list_length(scr_tas))
        match needed {
          [] -> st                     # unknown sum (e.g. Int, lists): skip
          _  -> {
            # under dual representation a `type
            # T = A | B` decl registers `A` and `B` as zero-arg
            # variants of `T`. When the user wrote a `PNarrow(_,C)`
            # arm targeting one of those names, the match is a
            # union-of-types form; recurse per-component so a
            # narrowing arm covers every variant of that component
            # transparently. When NO arm is a PNarrow we keep
            # today's flat exhaustiveness — narrowing has not been
            # used and reverting protects existing match shapes
            # (regular sum types whose variant names happen to
            # collide with other top-level type names — e.g.
            # `ExprKind`'s variant `EVar` and the unrelated
            # `type EVar = EV(...)` decl).
            #
            # also recurse per-component when the
            # scrutinee tycon is itself declared as a union
            # (`type ErrAB = ErrA | ErrB`), regardless of arm shape.
            # Without this, a match enumerating every variant of
            # every component is reported as "missing ErrA, ErrB"
            # because the flat path looks for arms named after the
            # components themselves. The union-decl test relies on
            # `env.unions`, which records explicit union parents
            # only — collision shapes (`type EVar = ...` whose name
            # collides with another type's variant) are NOT in
            # `env.unions`, so this trigger preserves the existing
            # flat behavior for those.
            if any_arm_is_narrow(arms) or is_union_of_types(st.env, tycon) {
              check_union_components_under_tycon(st, arms, tycon, needed, line, col)
            } else {
              let missing = find_missing_variants(needed, arms, [])
              match missing {
                [] -> st
                _  -> {
                  let header = "non-exhaustive match on #{tycon}: missing #{inf_join_with(missing, ", ")}"
                  diag_error(st.file, line, col, header)
                  let covered = find_covered_variants(needed, arms, [])
                  emit_nonexhaustive_notes(missing, covered)
                  # T2 collected diagnostic.
                  let d = build_nonexhaustive_diag(st.file, line, col, header, missing, covered)
                  st_bump_err(st_push_diag(st, d))
                }
              }
            }
          }
        }
      }
      TyListT(_) -> check_list_exhaustive(st, arms, line, col)
      # walk union components. A component is
      # covered if (a) a `PNarrow(_, T)` arm targets the whole
      # component, or (b) every variant of that component is covered
      # by a `PVariant`-style arm. Diagnostics name the
      # component-of-origin so the user knows which `type T = ...`
      # declaration the missing variant belongs to.
      TyUnion(parts) -> check_union_exhaustive(st, arms, parts, line, col)
      _ -> st
    }
  }
}

# per-component exhaustiveness over a union
# scrutinee. Iterates each component; for components fully covered
# by a `PNarrow` arm we are done; otherwise we walk the component's
# variants and report any not covered by an arm.
fn check_union_exhaustive(st: InferState, arms: [Arm], parts: [Ty],
                            line: Int, col: Int) : InferState / Console + File {


  match parts {
    [] -> st
    [p, ...rest] -> {
      let st1 = check_union_component(st, arms, p, line, col)
      check_union_exhaustive(st1, arms, rest, line, col)
    }
  }
}

fn check_union_component(st: InferState, arms: [Arm], comp: Ty,
                           line: Int, col: Int) : InferState / Console + File {


  match comp {
    TyCon(_, tycon, comp_tas) -> {
      if arms_cover_narrow(arms, tycon) { st }
      else {
        # arity-aware variant lookup; see `check_exhaustive`.
        # Use `comp_tas` (not `args`) to avoid the core-`args` shadow.
        let needed = variants_of_type_arity(st.env, tycon, list_length(comp_tas))
        match needed {
          [] -> st       # not a sum component (record / primitive); skip
          _  -> {
            let missing = find_missing_variants(needed, arms, [])
            match missing {
              [] -> st
              _  -> {
                let header = "non-exhaustive match: missing #{inf_join_with(missing, ", ")} (component of #{tycon})"
                diag_error(st.file, line, col, header)
                let covered = find_covered_variants(needed, arms, [])
                emit_missing_notes(missing)
                match covered {
                  [] -> ()
                  _  -> diag_note("covered: #{inf_join_with(covered, ", ")}")
                }
                let help_msg = "add an arm for each missing variant, a `name : #{tycon}` narrowing arm covering the whole component, or a wildcard `_` arm"
                diag_help(help_msg)
                # T2 collected diagnostic (union component path).
                let miss_notes = map(missing, (m) => ri_note(st.file, line, col, "missing variant: `#{m}`"))
                let cov_notes = match covered {
                  [] -> []
                  _  -> [ri_note(st.file, line, col, "covered: #{inf_join_with(covered, ", ")}")]
                }
                let related = list_append(miss_notes,
                                list_append(cov_notes,
                                  [ri_help(st.file, line, col, help_msg)]))
                let d = mk_diag(SevError, st.file, line, col, header, related)
                st_bump_err(st_push_diag(st, d))
              }
            }
          }
        }
      }
    }
    _ -> st              # non-nominal component (record / primitive / nested union): skip
  }
}

# a tycon is a "union of types" when it was declared
# as `type T = A | B | ...` where every A, B, ... is itself a
# declared type with its own variants (e.g. `type ErrAB = ErrA |
# ErrB` with `type ErrA = ...`). `env.unions` records every
# `TBSum` decl, so we can't simply ask "is tycon in env.unions";
# regular sum types like `type ExprKind = EInt | EReal | ...` are
# also there but their variant names (`EInt`, `EReal`, ...) are
# not themselves declared types. Requiring EVERY component to be
# a declared sum/union type isolates true unions-of-types from
# regular sum types and from union collision shapes.
fn is_union_of_types(env: TyEnv, tycon: String) : Bool {
  match union_components_of(env.unions, tycon) {
    [] -> false
    comps -> all_components_are_declared_types(env, comps)
  }
}

fn all_components_are_declared_types(env: TyEnv, comps: [String]) : Bool {
  match comps {
    [] -> true
    [c, ...rest] -> match union_components_of(env.unions, c) {
      [] -> false
      _  -> all_components_are_declared_types(env, rest)
    }
  }
}

# trigger for the per-component recursive
# exhaustiveness check. Returns true iff any arm uses a `PNarrow`
# pattern, which is the signal that the user is matching on a
# union-of-types and wants per-component coverage.
fn any_arm_is_narrow(arms: [Arm]) : Bool {
  match arms {
    [] -> false
    [a, ...rest] -> match a {
      Arm(pat, _, _) -> match pat.pkind {
        PNarrow(_, _) -> true
        _             -> any_arm_is_narrow(rest)
      }
    }
  }
}

# walk the variants of a top-level TyCon. For
# each variant name `c` we ask: is `c` itself a declared type with
# its own sub-variants (a component of a union-of-types parent)? If
# so, treat it as a component — covered iff a PNarrow arm targets
# it OR all of its sub-variants are covered. Otherwise it's an
# atomic variant and we check direct arm coverage.
fn check_union_components_under_tycon(st: InferState, arms: [Arm], parent: String,
                                        comps: [String], line: Int, col: Int) : InferState / Console + File {


  match comps {
    [] -> st
    [c, ...rest] -> {
      let st1 = check_one_union_comp(st, arms, parent, c, line, col)
      check_union_components_under_tycon(st1, arms, parent, rest, line, col)
    }
  }
}

fn check_one_union_comp(st: InferState, arms: [Arm], parent: String, comp: String,
                          line: Int, col: Int) : InferState / Console + File {


  if arms_cover_narrow(arms, comp) { st }
  else {
    # If `comp` is itself a declared type with its own variants,
    # this is a component of a union-of-types decl. Walk its
    # variants and require each to be covered.
    let sub_variants = variants_of_type(st.env, comp)
    match sub_variants {
      [] -> {
        # Atomic variant of `parent` — direct coverage required.
        if arms_cover_variant(arms, comp) { st }
        else {
          let header = "non-exhaustive match on #{parent}: missing #{comp}"
          diag_error(st.file, line, col, header)
          diag_note("missing variant: `#{comp}`")
          let help_msg = "add an arm `#{comp} -> ...` or a wildcard `_ -> ...`"
          diag_help(help_msg)
          # T2 collected diagnostic (atomic variant path).
          let related = [
            ri_note(st.file, line, col, "missing variant: `#{comp}`"),
            ri_help(st.file, line, col, help_msg)
          ]
          let d = mk_diag(SevError, st.file, line, col, header, related)
          st_bump_err(st_push_diag(st, d))
        }
      }
      _ -> {
        let missing = find_missing_variants(sub_variants, arms, [])
        match missing {
          [] -> st
          _  -> {
            let header = "non-exhaustive match: missing #{inf_join_with(missing, ", ")} (component of #{comp})"
            diag_error(st.file, line, col, header)
            let covered = find_covered_variants(sub_variants, arms, [])
            emit_missing_notes(missing)
            match covered {
              [] -> ()
              _  -> diag_note("covered: #{inf_join_with(covered, ", ")}")
            }
            let help_msg = "add an arm for each missing variant, a `name : #{comp}` narrowing arm covering the whole component, or a wildcard `_` arm"
            diag_help(help_msg)
            # T2 collected diagnostic (component sub-variant path).
            let miss_notes = map(missing, (m) => ri_note(st.file, line, col, "missing variant: `#{m}`"))
            let cov_notes = match covered {
              [] -> []
              _  -> [ri_note(st.file, line, col, "covered: #{inf_join_with(covered, ", ")}")]
            }
            let related = list_append(miss_notes,
                            list_append(cov_notes,
                              [ri_help(st.file, line, col, help_msg)]))
            let d = mk_diag(SevError, st.file, line, col, header, related)
            st_bump_err(st_push_diag(st, d))
          }
        }
      }
    }
  }
}

fn arms_cover_narrow(arms: [Arm], tycon: String) : Bool {
  match arms {
    [] -> false
    [a, ...rest] -> match a {
      Arm(pat, guard, _) -> {
        let unguarded = match guard { None -> true Some(_) -> false }
        let hit = match pat.pkind {
          PNarrow(_, ty) -> match ty.tkind {
            TyName(nm, _) -> nm == tycon
            _             -> false
          }
          _ -> false
        }
        if hit and unguarded { true } else { arms_cover_narrow(rest, tycon) }
      }
    }
  }
}


# A list match is exhaustive when (a) some unguarded arm matches the
# empty list `[]` and (b) some unguarded arm matches at least one
# non-empty shape. Any spread-bearing list pattern (`[_, ...rest]`,
# `[a, b, ...rest]`, …) collectively covers every list of length ≥
# its fixed portion; requiring one such arm is a pragmatic cover for
# non-empty. Fixed-length arms alone leave gaps (e.g. `[a]` matches
# size 1 only) — we flag that.

fn arm_pat_empty_list(a: Arm) : Bool {
  match a {
    Arm(pat, guard, _) -> {
      let unguarded = match guard { None -> true Some(_) -> false }
      if not unguarded { false } else { pat_is_empty_list(pat) }
    }
  }
}

# drill through `name @ inner` for the list-exhaustiveness
# helpers so an as-pattern wrapping `[]` or `[_, ...rest]` still
# satisfies the check.
fn pat_is_empty_list(pat: Pattern) : Bool {
  match pat.pkind {
    PList(ps, rest_opt) -> match ps {
      [] -> match rest_opt { None -> true Some(_) -> false }
      _  -> false
    }
    PAs(_, sub) -> pat_is_empty_list(sub)
    _ -> false
  }
}

fn arm_pat_spread_list(a: Arm) : Bool {
  match a {
    Arm(pat, guard, _) -> {
      let unguarded = match guard { None -> true Some(_) -> false }
      if not unguarded { false } else { pat_is_spread_list(pat) }
    }
  }
}

fn pat_is_spread_list(pat: Pattern) : Bool {
  match pat.pkind {
    PList(_, rest_opt) -> match rest_opt {
      Some(_) -> true
      None    -> false
    }
    PAs(_, sub) -> pat_is_spread_list(sub)
    _ -> false
  }
}

fn any_arm(arms: [Arm], pred: (Arm) -> Bool) : Bool {
  match arms {
    [] -> false
    [a, ...rest] -> if pred(a) { true } else { any_arm(rest, pred) }
  }
}

fn check_list_exhaustive(st: InferState, arms: [Arm], line: Int, col: Int) : InferState / Console + File {


  let has_empty  = any_arm(arms, arm_pat_empty_list)
  let has_spread = any_arm(arms, arm_pat_spread_list)
  if has_empty and has_spread { st }
  else {
    let missing = if has_empty { "non-empty lists (e.g. `[_, ...rest]`)" }
                  else if has_spread { "the empty list `[]`" }
                  else { "the empty list `[]` and non-empty lists (e.g. `[_, ...rest]`)" }
    let header = "non-exhaustive match on list: missing #{missing}"
    diag_error(st.file, line, col, header)
    let help_msg = "cover both `[]` and a spread pattern, or add a wildcard `_` arm"
    diag_help(help_msg)
    # T2 collected diagnostic (list path).
    let d = mk_diag(SevError, st.file, line, col, header,
                    [ri_help(st.file, line, col, help_msg)])
    st_bump_err(st_push_diag(st, d))
  }
}

fn synth_arms(st: InferState, arms: [Arm], scrut_ty: Ty, body_ty: Ty, line: Int, col: Int) : InferredArms / Console + File + Mutable {


  match arms {
    [] -> InferredArms { st: st, arms: [] }
    [a, ...rest] -> match a {
      Arm(pat, guard, body) -> {
        let outer = st
        let st_dup = check_pattern_no_dup_binds(st, pat)
        let s_p = check_pattern(st_dup, pat, scrut_ty)
        let guard_res = match guard {
          None -> InferredOptExpr { st: s_p, expr: None }
          Some(gx) -> {
            let rg = synth(s_p, gx)
            let s_g = st_unify(rg.st, rg.ty, TyBool, "match guard", gx.line, gx.col)
            InferredOptExpr { st: s_g, expr: Some(rg.expr) }
          }
        }
        let rb = synth(guard_res.st, body)
        let s_b = st_unify(rb.st, body_ty, rb.ty, "match arm", body.line, body.col)
        let s_scoped = st_restore_entries(outer, s_b)
        let rr = synth_arms(s_scoped, rest, scrut_ty, body_ty, line, col)
        InferredArms { st: rr.st, arms: [Arm(pat, guard_res.expr, rb.expr), ...rr.arms] }
      }
    }
  }
}

# ---- per-decl entry + dumper ----

fn print_inferred_fn(nm: String, final_ret: Ty, param_tys: [Ty], line: Int, col: Int) : Unit / Console {
  let fn_t = fn_ty(param_tys, final_ret)
  print("fn #{nm} : #{inf_ty_to_string(fn_t)} @#{int_to_string(line)}:#{int_to_string(col)}")
}

# A CallSite whose fresh var ids have been resolved via the final
# substitution to concrete types. Consumed by monomorphisation later
# and surfaced as-is by `--dump-mono`. The trailing `[UnitExprT]`
# carries the resolved units for the scheme's unit-kind tparams
# — used to differentiate impl `Show for Real<u>`
# specialisations that share an empty type tuple but bind `u` to
# distinct concrete units (USD vs EUR vs `m^2` ...).
# `mo` propagates from the originating CallSite — see CallSite's
# Hanga Roa note for why downstream consumers need it.
#[doc("infer: a resolved call-site instantiation consumed by monomorphisation.")]
pub type ResolvedCS = RCS(String, Int, Int, [Ty], [UnitExprT], Option[String])  # name, line, col, concrete tys, concrete units, module_origin

fn resolve_callsite_tys(ids: [Int], sub: Subst) : [Ty] {
  match ids {
    [] -> []
    [i, ...rest] -> [apply_ty(sub, TyVarT(i)), ...resolve_callsite_tys(rest, sub)]
  }
}

fn resolve_callsite_units(ids: [Int], sub: Subst) : [UnitExprT] {
  match ids {
    [] -> []
    [i, ...rest] -> [apply_unit(sub, UVar(i)), ...resolve_callsite_units(rest, sub)]
  }
}

fn resolve_callsites(css: [CallSite], sub: Subst, mo: Option[String]) : [ResolvedCS] {
  match css {
    [] -> []
    [cs, ...rest] -> match cs {
      # The mo parameter overrides the mo carried on the CS itself.
      # `infer_decl` walks all CS produced inside one DFn body, so
      # tagging them with the enclosing DFn's `module_origin` is
      # correct and avoids threading home_mod through every
      # InferState constructor (28 of them).
      CS(nm, line, col, ids, uids, _) ->
        [RCS(nm, line, col, resolve_callsite_tys(ids, sub),
             resolve_callsite_units(uids, sub), mo), ...resolve_callsites(rest, sub, mo)]
    }
  }
}

# A hole resolved against the final substitution: the expected type
# is the TyVarT ran through sub, which usually pins to a concrete
# type from context but can remain a TyVarT if the hole sits in a
# position that doesn't constrain (e.g. the whole body of a fn with
# no declared return).
#[doc("infer: `ResolvedHole` — driver-facing type.")]
pub type ResolvedHole = RH(HoleKind, Int, Int, Ty, [TyEntry], Int)

# a typed effect-hole resolution. Recorded
# per occurrence of `?` or `?name` in row tail position; one instance
# per parser placeholder regardless of how many times the same source
# name (`?e`) appears in a signature — each `?e` is its own anonymous
# row variable, not a re-use, so the reporter mirrors that.
#
# Fields:
#   - source name (`Some("e")` for `?e`, `None` for bare `?`)
#   - source line/col (location of the `?` token in the input file)
#   - enclosing fn name
#   - resolved Row (apply_row of the row-var the hole was bound to)
#   - body_row: labels actually performed by the fn's body. Useful
#     because `check_body_row` skips unification when the declared
#     row is `ROpen` (a hole IS an open row), so `resolved` is often
#     just the unbound tail variable. Consumers (LLMs) want to know
#     the body's effective row to fill the hole with. Order matches
#     the order labels were first encountered during inference.
#[doc("infer: `ResolvedRowHole` — driver-facing type.")]
pub type ResolvedRowHole = RRH(Option[String], Int, Int, String, Row, [String])

# Parse an internal row-hole placeholder name back into its
# components. Mirrors the format minted by parse_row_labels:
#   - `__rowhole__anon_<line>_<col>` for `?`     → (None, line, col)
#   - `__rowhole_<name>_<line>_<col>` for `?nm`  → (Some(name), line, col)
# Anything else returns None — defensive in case a non-hole rvar
# gets passed in by mistake.
type RowHoleSplit = { name: Option[String], line: Int, col: Int }

fn split_row_hole_name(s: String) : Option[RowHoleSplit] {
  if not inf_string_starts_with_q(s, "__rowhole_") { None }
  else {
    let n = string_length(s)
    # Find the last `_` (between line and col).
    match find_last_underscore(s, n - 1) {
      None -> None
      Some(p_col) -> {
        # Find the second-to-last `_` (between name and line).
        match find_last_underscore(s, p_col - 1) {
          None -> None
          Some(p_line) -> {
            let col_s  = substring_range(s, p_col + 1, n)
            let line_s = substring_range(s, p_line + 1, p_col)
            let name_part = substring_range(s, 10, p_line)
            # 10 = length of "__rowhole_"; remaining is either "_anon"
            # (anonymous `?`) or the user-written name (`e`, `eff`, …).
            let nm = if name_part == "_anon" { None } else { Some(name_part) }
            match parse_decimal(line_s) {
              None -> None
              Some(line) -> match parse_decimal(col_s) {
                None -> None
                Some(col) ->
                  Some(RowHoleSplit { name: nm, line: line, col: col })
              }
            }
          }
        }
      }
    }
  }
}

fn find_last_underscore(s: String, from: Int) : Option[Int] {
  if from < 0 { None }
  else {
    match char_at(s, from) {
      Some(c) -> if c == '_' { Some(from) } else { find_last_underscore(s, from - 1) }
      None    -> find_last_underscore(s, from - 1)
    }
  }
}

fn substring_range(s: String, lo: Int, hi: Int) : String =
  substring_loop(s, lo, hi, "")

fn substring_loop(s: String, i: Int, hi: Int, acc: String) : String {
  if i >= hi { acc }
  else {
    match char_at(s, i) {
      Some(c) -> substring_loop(s, i + 1, hi, string_concat(acc, "#{c}"))
      None    -> acc
    }
  }
}

fn parse_decimal(s: String) : Option[Int] = parse_decimal_loop(s, 0, string_length(s), 0, false)

fn parse_decimal_loop(s: String, i: Int, n: Int, acc: Int, any: Bool) : Option[Int] {
  if i >= n { if any { Some(acc) } else { None } }
  else {
    match char_at(s, i) {
      None -> None
      Some(c) -> {
        let d = char_to_int(c) - char_to_int('0')
        if d < 0 or d > 9 { None }
        else { parse_decimal_loop(s, i + 1, n, acc * 10 + d, true) }
      }
    }
  }
}

# Build the [ResolvedRowHole] for one decl. For each rvar name in the
# decl that matches the row-hole placeholder format, look up its
# allocated id in `rbinds`, resolve `Row { tail: Some(id) }` under the
# final substitution, and emit one entry. Non-hole row variables (the
# user-written tail `e` in `... / Io + e`) are skipped — they are not
# typed-hole resolutions and belong to a different reporter.
fn extract_row_holes(d: Decl, rbinds: [RVBind], sub: Subst, body_row: [Label]) : [ResolvedRowHole] {
  match d {
    DFn(_, fn_name, _, _, _, _, _, _, _, _) -> {
      let names = collect_decl_rvars(d)
      let body_labels = map(apply_labels(sub, body_row), (l) => l.eff)
      extract_row_holes_loop(names, fn_name, rbinds, sub, body_labels, [])
    }
    _ -> []
  }
}

fn extract_row_holes_loop(names: [String], fn_name: String,
                           rbinds: [RVBind], sub: Subst,
                           body_labels: [String],
                           acc: [ResolvedRowHole]) : [ResolvedRowHole] {
  match names {
    [] -> list_reverse(acc)
    [n, ...rest] -> {
      match split_row_hole_name(n) {
        None -> extract_row_holes_loop(rest, fn_name, rbinds, sub, body_labels, acc)
        Some(split) -> {
          match inf_rvbind_lookup(rbinds, n) {
            None -> extract_row_holes_loop(rest, fn_name, rbinds, sub, body_labels, acc)
            Some(id) -> {
              let r = apply_row(sub, Row { labels: [], tail: Some(id),
                                             display_alias: None })
              let entry = RRH(split.name, split.line, split.col, fn_name, r, body_labels)
              extract_row_holes_loop(rest, fn_name, rbinds, sub, body_labels, [entry, ...acc])
            }
          }
        }
      }
    }
  }
}
#                       kind     line col expected scope     env_fresh

fn take_entries(es: [TyEntry], n: Int, acc: [TyEntry]) : [TyEntry] {
  if n <= 0 { list_reverse(acc) }
  else { match es {
    [] -> list_reverse(acc)
    [h, ...rest] -> take_entries(rest, n - 1, [h, ...acc])
  } }
}

fn drop_last_entries(es: [TyEntry], n: Int) : [TyEntry] {
  let total = list_length(es)
  let keep = total - n
  if keep <= 0 { [] } else { take_entries(es, keep, []) }
}

fn resolve_holes(hs: [HoleSite], sub: Subst) : [ResolvedHole] {
  match hs {
    [] -> []
    [h, ...rest] -> match h {
      HS(kind, line, col, fresh, scope, env_fresh) ->
        [RH(kind, line, col, apply_ty(sub, TyVarT(fresh)), scope, env_fresh),
         ...resolve_holes(rest, sub)]
    }
  }
}

# Decls after inference: type-annotated body (or original decl for
# non-DFn). Also carries the error count, the resolved call-site
# instantiations, and the resolved hole reports.
type TypedDecl = { decl: Decl, errs: Int, insts: [ResolvedCS],
                    holes: [ResolvedHole], row_holes: [ResolvedRowHole],
                    # per-decl collected diagnostics (T1, T2,
                    # T4, T5). Stored in source order (already reversed
                    # at the per-decl level, since `infer_all_loop`
                    # reverses again when assembling `TypedProgram`).
                    diags: [Diagnostic],
                    # per-decl op-call resolutions (#820 evidence
                    # analysis). Mirrors `diags`' aggregation: stored
                    # source-order here, reversed into `TypedProgram`.
                    op_res: [OpResolution] }

# Walk to the expression whose type is what the function body
# "produces". For block bodies that's the tail expression (or the
# block's closing brace if tail is absent). This lets return-type
# mismatches point at the offending expression instead of the `fn`
# header.
fn return_site_of(e: Expr) : Expr {
  match e.kind {
    EBlock(_, opt_tail) -> match opt_tail {
      Some(tail) -> return_site_of(tail)
      None       -> e
    }
    _ -> e
  }
}

fn infer_decl(file: String, env: TyEnv, core_len: Int, recs: [RecInfo],
              op_eff_arities: [OpEffArity],
              type_aliases: [AliasResult], op_to_eff: [OpToEff],
              sums: [SumInfo],
              proto_impls: [ProtoImplReg],
              all_decls: [Decl],
              kind_theories: [KindTheory],
              d: Decl, verbose: Bool) : TypedDecl / Console + File + Mutable {


  match d {
    DFn(is_pub, nm, tparams, ps, opt_ret, row, body, line, col, mo) -> {
      # row-variable binding context for this decl. The
      # bound ids match those produced by fn_scheme_of_decl so the
      # body's params and any internal references to row-poly user
      # functions agree with the scheme stored in the env. The
      # inferencer's row_fresh counter is advanced past the highest
      # bound id, so future fresh row vars can never alias these.
      # same idea for tpbinds — fn-level tparams resolve
      # to small bound ids reused by the inferencer when fresh-
      # instantiating at call sites.
      # include row vars sourced only in a `T[..., e]` slot (the
      # `from_list(...) : Stream[t, e]` case) so the body walk's rbinds
      # match the registered scheme's; consult `env.row_kind`.
      let rbinds = mk_rvbinds(list_append(collect_decl_rvars(d),
                                          collect_rowkind_args_decl(d, env.row_kind)))
      # pick up implicit lowercase tparams the
      # signature uses but did not declare in `[…]`, matching the
      # set fn_scheme_of_decl built into the registered scheme.
      let implicit = collect_implicit_tparams_in_decl(d, tparams)
      let effective_tparams = list_append(tparams, implicit)
      let tpbinds = mk_tpbinds(effective_tparams)
      # Hanga Roa modular typecheck: the per-module fold in
      # `typecheck_program_loop` already feeds this decl's typer
      # only the records / sums its bucket inherits from
      # upstream modules. The legacy `rerank_recs_for` /
      # `rerank_sums_for` parches (which dropped consumer-root
      # records when typing core bodies) are no longer load-
      # bearing: a core module's recs simply never see the
      # target's recs in the same `RecInfo[]`.
      let st_init0 = infer_state_new_full_aliases(file, env, core_len, recs,
                                                    op_eff_arities, type_aliases, op_to_eff,
                                                    kind_theories)
      # install the protocol impl table snapshot so
      # `synth_binop` can decide whether a (prim, nonprim) /
      # (nonprim, nonprim cross) pair routes to a registered impl.
      let st_init1 = st_set_proto_impls(st_init0, proto_impls)
      # Install the sum-type registry so `synth_binop` can decide
      # structural-vs-dispatch for `==` / `<` over compound types.
      let st_init = st_set_sums(st_init1, sums)
      # reserve one extra row-var id for the phantom row
      # variable inserted by `fn_scheme_of_decl` into REmpty signatures.
      # Without this advance, the inferencer's first fresh row var
      # would alias `phantom_id = len(rbinds)`, which the scheme
      # already quantifies over.
      let phantom_extra = if elaborate_phantom_row(row, nm) { 1 } else { 0 }
      let st0 = advance_row_fresh(st_init, list_length(rbinds) + phantom_extra)
      # mk_tpbinds allocates ids 0..n-1 for the fn-level tparams, but
      # infer_state_new starts env.fresh at 0 too. Without bumping the
      # counter past the tparam ids, the first fresh ty-var minted in
      # the body (e.g., the result of synth_op_call_with_scheme inside
      # `pub fn spawn.spawn[T, e](...) = Spawn.spawn(f)`) aliases `T`,
      # which then fails the return-type unify with an occurs-check
      # error ("expected: Fiber[?t0], found: ?t0"). Advance the env's
      # fresh counter past the tpbinds the same way we already advance
      # the row_fresh counter past the rbinds above.
      let st0a = st_set_env(st0, advance_fresh(st0.env, list_length(tpbinds)))
      # parallel to the env.fresh bump above, advance the
      # unit_fresh counter past any unit-kind tpbinds so fresh uvars
      # minted while typing the body do not alias the impl-level bound
      # uvar id (the unifier's `utable_pick_min_var` would otherwise
      # always select the bound id and bind it to a fresh id, leaving
      # `x : Real<UVar(N)>` for some chained fresh N — breaking the
      # body subst map that keys on the bound id from `tparam_id_split`).
      # The advance alone is not sufficient: even with reserved ids,
      # `utable_pick_min_var` picks the smallest-id var in the diff,
      # which is still the bound id when it appears alongside a fresh
      # one. The post-finalise canonicalisation pass below redirects
      # the chain endpoint back to the bound id.
      let unit_tpcount = tparam_unit_count(effective_tparams)
      let st0b0 = if unit_tpcount > 0 { advance_unit_fresh(st0a, unit_tpcount) } else { st0a }
      # constrain the reserved tparam uvar ids (0..n-1, in tparam
      # order) to their declared kinds, so body-side binds of the
      # tparam var refuse habitants of another kind.
      let st0b = if unit_tpcount > 0 {
        st_set_sub(st0b0, subst_add_unit_kinds(st0b0.sub,
          range_ids(0, unit_tpcount), tparam_unit_kinds(effective_tparams)))
      } else { st0b0 }
      let added = add_infer_params_with_binds(st0b, ps, tpbinds, rbinds)
      # when the user omits the return-type
      # annotation, infer it from the body's actual type. The
      # `fn x() = expr` form (and `fn x() { ... last_expr }`) signals
      # "the function's value is the body's value", so forcing TyUnit
      # would break programs whose tail produces a real value (the
      # canonical case is `fn main() = { ... 0 }` returning Int).
      # The scheme registered earlier in `fn_scheme_of_decl` still
      # assumes TyUnit when opt_ret is None — fine for `main` (never
      # called from user code); a future pass threading the inferred
      # return into the scheme is the proper fix for callable helpers.
      let opt_declared = match opt_ret {
        Some(rty) -> Some(resolve_ty_with_binds_rk(rty, tpbinds, rbinds, env.row_kind))
        None      -> None
      }
      # thread the declared return type through the body walk
      # so `e!` can validate the propagation target. Cleared on entry
      # to lambda bodies (synth_lambda) — `!` does not propagate from
      # closures.
      let st_ready = st_set_ret_ty(added.st, opt_declared)
      let what = string_concat("return type of ", nm)
      let ret_site = return_site_of(body)
      # when the fn has an annotated return type, drive the
      # body in check-mode so the expected type reaches every match-arm
      # via `check_match`. The post-hoc unify below collapses to a
      # no-op (`apply_ty(sub, expected)` is already pinned), but is
      # kept for non-match bodies whose synthesised type still needs
      # the unification step. The synthesise-only behaviour is preserved
      # exactly when `opt_declared = None`.
      let rb = match opt_declared {
        Some(rty) -> check_body_against_ret(st_ready, body, rty, what, ret_site.line, ret_site.col)
        None      -> synth(st_ready, body)
      }
      let declared_ret = match opt_declared {
        Some(rty) -> rty
        None      -> rb.ty
      }
      let st1 = match opt_declared {
        Some(rty) -> st_unify(rb.st, rty, rb.ty, what, ret_site.line, ret_site.col)
        None      -> rb.st
      }
      # shallow region-brand check. The full brand machinery tags every
      # Fiber[T] / Pid[Msg] handle with the brand of its enclosing
      # nursery scope and rejects values whose brand has expired. This
      # check is the pragmatic syntactic approximation: any function
      # declared OUTSIDE
      # stdlib/ whose declared return type contains Fiber[T] (at any
      # nesting depth — list, option, record, etc.) is rejected at
      # the type-annotation line. Internal stdlib helpers
      # (spawn.spawn, etc.) are exempt by file-path because they are
      # the legitimate constructors of Fiber[T] values.
      let st1b = check_no_fiber_escape(st1, file, nm, opt_ret, sums, line, col)
      # Mutable masking. Drop `Mutable` from the
      # inferred row when every `array_set` / `array_grow` demand
      # the body raised targets a locally-constructed Array that
      # never escapes to a helper. Walks the typed body once via
      # `mask_local_mutable_demand` and is a no-op when `Mutable`
      # is not in the row to begin with.
      let st1c = mask_local_mutable_demand(st1b, ps, rb.expr)
      let st2pre = check_body_row(st1c, nm, row, line, col, all_decls)
      # drain the deferred field-access constraints now that
      # the body's tyvars have settled — `check_body_row` above unified
      # the inferred effect row against the declared one, so a generic
      # op's payload tyvar (`?a` in `Repo.find : Option[a]`) is pinned to
      # the row's concrete `Box`. Each pending `b.field` is resolved
      # against the now-concrete receiver type, closing the field-vs-UFCS
      # decision the synth pass had to postpone. The list is in reverse
      # registration order; drain order does not matter (each constraint
      # is independent and only extends the substitution / reports an
      # error). Recurses on its own sub so a field whose result type is
      # itself the receiver of a later deferred field resolves too.
      let st2 = drain_deferred_fields(st2pre, list_reverse(st2pre.deferred_fields),
                                       decl_row_concrete_labels(row))
      let _ = if verbose {
        print_inferred_fn(nm, apply_ty(st2.sub, declared_ret), apply_tys(st2.sub, added.tys), line, col)
      } else { () }
      # Hanga Roa: tag every call-site instance with the enclosing
      # DFn's module_origin so downstream consumers (`--dump-mono`,
      # the monomorphiser, the test runner) can distinguish
      # instances authored in the user's root file from those that
      # come through core or other modules.
      let resolved0 = resolve_callsites(list_reverse(st2.insts), st2.sub, mo)
      let hole_reports = resolve_holes(list_reverse(st2.holes), st2.sub)
      # apply the final substitution to every
      # `Expr.ty` annotation in the body so the post-inference protocol-
      # call rewrite can read concrete head types from sites whose
      # `synth` saved a TyVar that later unified with a concrete type
      # — most visibly the parameters of lambdas passed to generic
      # higher-order ops (`each`, `map`, `filter`).
      let final_body0 = finalise_typed_expr(st2.sub, rb.expr)
      # canonicalise the body's UVar / TyVarT ids back
      # to the impl's bound ids. The unifier may have redirected
      # `UVar(b) -> UVar(f)` (chain through fresh ids) when typing
      # `unit_name(x)` etc., so post-finalise the body's `Expr.ty`
      # references the chain endpoint UVar, not the bound id. The
      # body subst map keys on the bound id (since `tparam_id_split`
      # numbers them 0..n-1), so without this canonicalisation the
      # subst is a no-op in the spec body. We compute the redirect
      # map by chasing each bound id through `st2.sub` and rewriting
      # any UVar(endpoint) / TyVarT(endpoint) in the body's tys.
      let split_for_canon = tparam_id_split(effective_tparams)
      let canon_uvars = build_uvar_canon_map(split_for_canon.uvars, st2.sub, [])
      let canon_tvars = build_tvar_canon_map(split_for_canon.tvars, st2.sub, [])
      let final_body = if list_length(canon_uvars) == 0 and list_length(canon_tvars) == 0 {
        final_body0
      } else {
        canon_uvars_expr(canon_tvars_expr(final_body0, canon_tvars), canon_uvars)
      }
      # Apply the same canonicalisation to the resolved CSs so the
      # body subst map (keyed on bound ids 0..n-1) and the recorded
      # CS tys/units agree. Without this, an inner-call CS in a
      # polymorphic-flow-through position records the chain endpoint
      # id and the substitution becomes a no-op for transitive specs.
      let resolved = if list_length(canon_uvars) == 0 and list_length(canon_tvars) == 0 {
        resolved0
      } else {
        canon_resolved_css(resolved0, canon_tvars, canon_uvars)
      }
      # main-row inference. When `main` ships without a
      # declared row, write the body-performed row back into the
      # DFn so `emit_main_wrapper` / `main_row_labels` install the
      # default handlers for every builtin the body uses. Helpers
      # are not affected — only `main` gets this exception.
      # extend main's inferred row with effects
      # reached transitively via helpers. `st2.row` only carries
      # labels from *direct* op calls (`Stdout.print(x)` /
      # `print(x)`); helper-only call chains were silent at the
      # caller level, so the wrapper installed no default handlers
      # and any `Stdout.print` segfaulted at runtime. The post-
      # typing walker `collect_call_labels` reads the resolved
      # callee type at every ECall in the typed body and merges
      # those labels into the main-only row. Caller-side typing
      # behaviour is unchanged for non-main fns, so signatures of
      # higher-order helpers like `inf_map_expr_kind` (which pass
      # lambdas with effecting bodies) keep their current shape.
      let final_row = match row {
        REmpty -> if nm == "main" {
          let extended = collect_call_labels(final_body, st2.row)
          inferred_main_row(extended)
        } else { row }
        _      -> row
      }
      let row_holes = extract_row_holes(d, rbinds, st2.sub, st2.row)
      TypedDecl {
        decl: DFn(is_pub, nm, tparams, ps, opt_ret, final_row, final_body, line, col, mo),
        errs: st2.errs,
        insts: resolved,
        holes: hole_reports,
        row_holes: row_holes,
        diags: finalize_diags(st2.diags),
        op_res: stamp_op_res_fname(list_reverse(st2.op_res), nm)
      }
    }
    # `test` / `bench` / `check` bodies were previously
    # returned untyped (the catch-all below), so `try_bare_call_narrow`
    # (first-arg narrowing) and the protocol-call rewrite — both of
    # which depend on a typed body — never fired inside them. A bare
    # cross-module name (`repeat("x", 3)` with both `string.repeat` and
    # `list.repeat` in scope) then resolved to the wrong candidate. Run
    # the same body walk a paramless `fn` gets so the typed AST carries
    # resolved `EModCall` callees. `check` blocks bind their `with`
    # params first. The body is run like `main`'s REmpty row (the test
    # harness installs the identical builtin default handlers), so
    # `print`/`assert` and effecting helpers type without a declared row.
    DTest(_, body, line, col) -> infer_test_body(file, env, core_len, recs,
      op_eff_arities, type_aliases, op_to_eff, sums, proto_impls, all_decls,
      kind_theories, [], body, d, line, col)
    DBench(_, body, line, col) -> infer_test_body(file, env, core_len, recs,
      op_eff_arities, type_aliases, op_to_eff, sums, proto_impls, all_decls,
      kind_theories, [], body, d, line, col)
    DCheck(_, ps, body, line, col) -> infer_test_body(file, env, core_len, recs,
      op_eff_arities, type_aliases, op_to_eff, sums, proto_impls, all_decls,
      kind_theories, ps, body, d, line, col)
    # `#[constructor]` wrapper: type-check the inner fn and unwrap it —
    # the marker has done its job (the registry was built in
    # `add_decls_loop`), so the emitter sees a plain `DFn`.
    DProtoLaws(_, inner, _, _) -> infer_decl(file, env, core_len, recs,
                                            op_eff_arities, type_aliases, op_to_eff,
                                            sums, proto_impls, all_decls, kind_theories,
                                            inner, verbose)
    DImplAxiom(_, inner, _, _) -> infer_decl(file, env, core_len, recs,
                                            op_eff_arities, type_aliases, op_to_eff,
                                            sums, proto_impls, all_decls, kind_theories,
                                            inner, verbose)
    DConstructor(inner, _, _) -> infer_decl(file, env, core_len, recs,
                                            op_eff_arities, type_aliases, op_to_eff,
                                            sums, proto_impls, all_decls, kind_theories,
                                            inner, verbose)
    _ -> TypedDecl { decl: d, errs: 0, insts: [], holes: [], row_holes: [], diags: [], op_res: [] }
  }
}

# type-check a `test` / `bench` / `check` body so the typed
# AST it produces carries resolved callees (`EModCall`) for downstream
# passes. Mirrors the paramless-`fn` slice of `infer_decl`'s DFn arm:
# install the proto-impl + sum registries, add any `check` params to
# scope, `synth` the body, then absorb the body's builtin effects the
# way `main` does (the test runner installs those defaults). The decl
# shape itself is returned unchanged with its now-typed body.
fn infer_test_body(file: String, env: TyEnv, core_len: Int,
                   recs: [RecInfo], op_eff_arities: [OpEffArity],
                   type_aliases: [AliasResult], op_to_eff: [OpToEff],
                   sums: [SumInfo], proto_impls: [ProtoImplReg],
                   all_decls: [Decl], kind_theories: [KindTheory],
                   ps: [Param], body: Expr,
                   d: Decl, line: Int, col: Int) : TypedDecl / Console + File + Mutable {
  let st_init0 = infer_state_new_full_aliases(file, env, core_len, recs,
                                                op_eff_arities, type_aliases, op_to_eff,
                                                kind_theories)
  let st_init1 = st_set_proto_impls(st_init0, proto_impls)
  let st_init = st_set_sums(st_init1, sums)
  let added = add_infer_params_with_binds(st_init, ps, [], [])
  let rb = synth(added.st, body)
  # A test/bench/check body has no declared row; absorb the builtin
  # effects it performs exactly as `main` does (the runner installs the
  # same default handlers). `check_body_row`'s REmpty branch keys this
  # absorption on `fname == "main"`.
  let st2 = check_body_row(rb.st, "main", REmpty, line, col, all_decls)
  let resolved = resolve_callsites(list_reverse(st2.insts), st2.sub, None)
  let hole_reports = resolve_holes(list_reverse(st2.holes), st2.sub)
  let final_body = finalise_typed_expr(st2.sub, rb.expr)
  TypedDecl {
    decl: test_decl_with_body(d, final_body),
    errs: st2.errs,
    insts: resolved,
    holes: hole_reports,
    row_holes: [],
    diags: finalize_diags(st2.diags),
    op_res: stamp_op_res_fname(list_reverse(st2.op_res), "main")
  }
}

# Rebuild a DTest / DBench / DCheck decl with its body replaced by the
# typed one. Other decl shapes are returned unchanged (never reached —
# `infer_test_body` is only called on the three test-like shapes).
fn test_decl_with_body(d: Decl, body: Expr) : Decl {
  match d {
    DTest(desc, _, l, c)      -> DTest(desc, body, l, c)
    DBench(desc, _, l, c)     -> DBench(desc, body, l, c)
    DCheck(desc, ps, _, l, c) -> DCheck(desc, ps, body, l, c)
    _                         -> d
  }
}

# Walk a typed Expr applying the per-decl substitution to every
# `Expr.ty`. Recurses through every kind that contains sub-Exprs.
# Patterns and Stmts are walked too because they hold Exprs whose
# `ty` field is read by downstream passes (notably the protocol-call
# rewrite). Pure structural; no type checking, no error production.
fn finalise_typed_expr(s: Subst, e: Expr) : Expr {
  let ty1 = match e.ty {
    Some(t) -> Some(apply_ty(s, t))
    None    -> None
  }
  Expr { kind: finalise_typed_kind(s, e.kind),
         line: e.line, col: e.col, ty: ty1, mode: e.mode }
}

fn finalise_typed_kind(s: Subst, k: ExprKind) : ExprKind =
  # Pure structural recursion: every kind delegates to the visitor,
  # which threads `finalise_typed_expr` through every sub-Expr. The
  # per-Expr work (applying `apply_ty(s, t)` to `e.ty`) lives in
  # `finalise_typed_expr` itself, so the closure in the visitor
  # carries it through automatically.
  inf_map_expr_kind(k, (sub) => finalise_typed_expr(s, sub))

# shallow region-brand check on Fiber[T]. Walks the type
# annotation (the user-written TypeExpr, not the resolved Ty, so
# the diagnostic can point at the exact text the user wrote) and
# rejects any occurrence of `Fiber[...]` (or `Pid[...]`) in the
# return-type position of a fn that is NOT one of the legitimate
# stdlib producers (`spawn.spawn` family in stdlib/spawn.kai). See
# the comment at the call site in infer_decl for the design trade-off
# (path-based exemption doesn't work because import decls inherit
# the importer's file path through expand_imports).
#
# Tier 2: symmetrise the check across `Fiber[T]` and
# `Pid[Msg]` so a stdlib-external helper can no longer return a
# raw Pid either.
#
# (option (a)): the walker now also descends
# into user-defined sum-type constructor payloads via the
# `[SumInfo]` registry collected in `infer_program`. A
# `type Boxed = Wrap(Fiber[Int])` return value used to escape the
# shallow walker — its surface TypeExpr is `TyName("Boxed", [])`
# and the Fiber lives in the variant payload, not in the TypeExpr
# the walker saw. The deep walker substitutes the type's tparams
# into each variant's payload TypeExprs and recurses, with a
# `visited` set to terminate on recursive sums (`type Tree[T] =
# Leaf(T) | Node(Tree[T], Tree[T])`).
#
# The full TyBranded(Ty, BrandId) machinery from
# `docs/structured-concurrency.md` §*Type system* — propagating a
# brand through every binding form (let, match, list literal,
# record field, fn arg) and rejecting brand-mismatch between
# sibling nurseries — has not landed. Its structural prerequisite
# is the cap-binding form `nursery { n -> ... }` which
# also has not landed: today `nursery { ... }` is a plain helper
# with no `n` parameter, so sibling-nursery brand mismatch is
# unwritable in user code. Until the cap binding lands, the
# brand-mismatch detection has no surface to attach to.
fn check_no_fiber_escape(st: InferState, file: String, fname: String,
                          opt_ret: Option[TypeExpr], sums: [SumInfo],
                          line: Int, col: Int) : InferState / Console + File {


  if is_fiber_producer_helper(fname) { st }
  else {
    match opt_ret {
      None -> st
      Some(rty) -> {
        match ty_expr_find_handle("Fiber", rty, sums, []) {
          Some(breach) -> {
            let lline = if rty.line > 0 { rty.line } else { line }
            let lcol  = if rty.col  > 0 { rty.col  } else { col  }
            diag_error(file, lline, lcol,
              string_concat(string_concat("Fiber[T] cannot escape `", fname),
                            "`'s structured-concurrency scope"))
            diag_note("a `Fiber[T]` handle is bound to the nursery that created it")
            diag_note("returning one from a function lets it outlive that scope")
            emit_handle_breach_note("Fiber", breach)
            diag_help("process the fiber inside the nursery (e.g. with `spawn.await`), or pass a thunk in and a value out instead")
            st_bump_err(st)
          }
          None -> match ty_expr_find_handle("Pid", rty, sums, []) {
            Some(breach) -> {
              let lline = if rty.line > 0 { rty.line } else { line }
              let lcol  = if rty.col  > 0 { rty.col  } else { col  }
              diag_error(file, lline, lcol,
                string_concat(string_concat("Pid[Msg] cannot escape `", fname),
                              "`'s structured-concurrency scope"))
              diag_note("a `Pid[Msg]` handle is bound to the actor scope that created it")
              diag_note("returning one from a function lets it outlive that scope")
              emit_handle_breach_note("Pid", breach)
              diag_help("process the pid inside the scope (e.g. with `Actor.send`), or pass a thunk in and a value out instead")
              st_bump_err(st)
            }
            None -> st
          }
        }
      }
    }
  }
}

# when the breach goes through a user-defined sum
# payload, surface the type + constructor name so the user can
# see exactly which carrier smuggled the handle out. Direct
# breaches (Fiber/Pid as a top-level type-arg or return type)
# emit no extra note — the existing Fiber/Pid pointer is enough.
fn emit_handle_breach_note(hname: String, breach: HandleBreach) : Unit / Console {

  match breach {
    HBDirect -> ()
    HBSum(tname, cname) ->
      diag_note(concat_all(["`", hname,
                            "` is wrapped by constructor `", cname,
                            "` of sum type `", tname, "`"]))
  }
}

# Allow-list of stdlib helpers permitted to mention Fiber[T] / Pid[Msg]
# in their return type. Kept intentionally narrow — these are the only
# legitimate constructors / passthroughs of Fiber / Pid values today
# (stdlib/spawn.kai + stdlib/actor.kai). Any new helper that needs to
# return either handle must be added here on purpose. The full
# TyBranded(Ty, BrandId) machinery — proper brand propagation through
# every binding form so an arbitrary helper can be admitted without an
# allow-list — is not yet wired up; this allow-list stands in for it.
#
# The Pid producers `alloc_for_policy` and `spawn_actor` are also on
# the list; both shape a Pid as part of the `with_mailbox`/`spawn_actor`
# structured-concurrency surface.
fn fiber_producer_helpers() : [String] =
  ["spawn.spawn",
   # qualified-call canonical names for
   # stdlib/spawn.kai. `spawn` is the bare export reached via
   # `spawn.spawn(f)`; `spawn.spawn` stays as the legacy alias.
   "spawn",
   # Tier 2 Pid surface helpers (stdlib/actor.kai).
   "alloc_for_policy", "spawn_actor",
   # explicit-policy spawn surface (stdlib/actor.kai).
   "alloc_unowned_for_policy", "spawn_actor_policy"]

fn is_fiber_producer_helper(fname: String) : Bool =
  list_has(fiber_producer_helpers(), fname)

# (option (a)): a single deep walker
# parameterised by the handle name (`Fiber` or `Pid`). Returns
# `Some(HBDirect)` for a top-level/recursive-shallow occurrence
# (Fiber[Int], Result[_, Fiber[Int]], Option[Pid[Msg]], …) and
# `Some(HBSum(tname, cname))` when the handle is hidden inside a
# user-defined sum's variant payload (`type Boxed =
# Wrap(Fiber[Int])`). The `visited` set guards recursive sums
# (`type Tree[T] = Leaf(T) | Node(Tree[T], Tree[T])`).
type HandleBreach = HBDirect | HBSum(String, String)

fn ty_expr_find_handle(hname: String, t: TypeExpr,
                        sums: [SumInfo], visited: [String]) : Option[HandleBreach] {
  match t.tkind {
    TyName(name, tas) -> {
      if name == hname { Some(HBDirect) }
      else {
        match ty_expr_list_find_handle(hname, tas, sums, visited) {
          Some(b) -> Some(b)
          None -> {
            if list_has(visited, name) { None }
            else {
              match sum_find(sums, name) {
                None -> None
                Some(si) -> match si {
                  SI(sname, tps, vs, _) -> {
                    let mapping = build_tparam_mapping(tps, tas)
                    variants_find_handle(hname, vs, mapping, sums,
                                          [sname, ...visited], sname)
                  }
                }
              }
            }
          }
        }
      }
    }
    TyList(inner) -> ty_expr_find_handle(hname, inner, sums, visited)
    TyFn(ps, ret, _) -> {
      match ty_expr_list_find_handle(hname, ps, sums, visited) {
        Some(b) -> Some(b)
        None -> ty_expr_find_handle(hname, ret, sums, visited)
      }
    }
    # dimensioned types never carry a Fiber/Pid — recurse into base.
    TyDim(base, _) -> ty_expr_find_handle(hname, base, sums, visited)
    # refinement predicates cannot mention Fiber/Pid (predicate
    # subset is data-only); only the base type matters.
    TyRefine(base, _) -> ty_expr_find_handle(hname, base, sums, visited)
    # a compound row carries effect labels, never a
    # Fiber/Pid handle type — no breach to find.
    TyRow(_) -> None
  }
}

fn ty_expr_list_find_handle(hname: String, ts: [TypeExpr],
                              sums: [SumInfo], visited: [String]) : Option[HandleBreach] {
  match ts {
    [] -> None
    [t, ...rest] -> match ty_expr_find_handle(hname, t, sums, visited) {
      Some(b) -> Some(b)
      None    -> ty_expr_list_find_handle(hname, rest, sums, visited)
    }
  }
}

fn variants_find_handle(hname: String, vs: [Variant],
                          mapping: [TParamMapEntry], sums: [SumInfo],
                          visited: [String], sname: String) : Option[HandleBreach] {
  match vs {
    [] -> None
    [v, ...rest] -> match v {
      Var(cname, payload) -> match payload_find_handle(hname, payload, mapping, sums, visited) {
        Some(_) -> Some(HBSum(sname, cname))
        None    -> variants_find_handle(hname, rest, mapping, sums, visited, sname)
      }
    }
  }
}

fn payload_find_handle(hname: String, payload: [TypeExpr],
                         mapping: [TParamMapEntry], sums: [SumInfo],
                         visited: [String]) : Option[HandleBreach] {
  match payload {
    [] -> None
    [te, ...rest] -> {
      let te_subst = subst_tparams_te(te, mapping)
      match ty_expr_find_handle(hname, te_subst, sums, visited) {
        Some(b) -> Some(b)
        None    -> payload_find_handle(hname, rest, mapping, sums, visited)
      }
    }
  }
}

# Tparam->TypeExpr mapping built from a sum's [tparams] zipped with
# the type-args at the use site. When the use site provides fewer
# type-args than the type declares (rare, but possible on a not-yet-
# fully-applied alias), the missing entries are skipped — the walker
# treats the unbound name as opaque (no Fiber/Pid hidden behind it).
type TParamMapEntry = TPM(String, TypeExpr)

fn build_tparam_mapping(tps: [String], tas: [TypeExpr]) : [TParamMapEntry] {
  match tps {
    [] -> []
    [tp, ...tps_rest] -> match tas {
      [] -> []
      [ta, ...tas_rest] -> [TPM(tp, ta), ...build_tparam_mapping(tps_rest, tas_rest)]
    }
  }
}

fn tparam_lookup(mapping: [TParamMapEntry], name: String) : Option[TypeExpr] {
  match mapping {
    [] -> None
    [m, ...rest] -> match m {
      TPM(n, te) -> if n == name { Some(te) } else { tparam_lookup(rest, name) }
    }
  }
}

# substitute tparam references in a payload TypeExpr
# with their concrete TypeExpr at the use site. Only `TyName(n, [])`
# entries are candidates for substitution — a higher-arity name is
# a real type constructor, not a tparam reference. The substitution
# is purely structural; positions are preserved.
fn subst_tparams_te(t: TypeExpr, mapping: [TParamMapEntry]) : TypeExpr {
  match t.tkind {
    TyName(n, tas) -> {
      if list_length(tas) == 0 {
        match tparam_lookup(mapping, n) {
          Some(replacement) -> replacement
          None              -> t
        }
      } else {
        mk_ty(TyName(n, subst_tparams_tes(tas, mapping)), t.line, t.col)
      }
    }
    TyList(inner) ->
      mk_ty(TyList(subst_tparams_te(inner, mapping)), t.line, t.col)
    TyFn(ps, ret, row) ->
      mk_ty(TyFn(subst_tparams_tes(ps, mapping),
                 subst_tparams_te(ret, mapping), row), t.line, t.col)
    TyDim(base, u) ->
      mk_ty(TyDim(subst_tparams_te(base, mapping), u), t.line, t.col)
    TyRefine(base, p) ->
      mk_ty(TyRefine(subst_tparams_te(base, mapping), p), t.line, t.col)
    # a compound-row payload is passed through unchanged,
    # matching the `TyFn` arm above (which leaves its row untouched).
    # The carrier is dissolved by alias substitution, not here.
    TyRow(_) -> t
  }
}

fn subst_tparams_tes(ts: [TypeExpr], mapping: [TParamMapEntry]) : [TypeExpr] {
  match ts {
    [] -> []
    [t, ...rest] -> [subst_tparams_te(t, mapping),
                     ...subst_tparams_tes(rest, mapping)]
  }
}

# enforce that every effect the body performs appears in
# the declared row. ROpen carries a row variable that
# absorbs any extras — every body row is admissible against an
# open declared row.
fn check_body_row(st: InferState, fname: String, declared: RowExpr,
                  line: Int, col: Int, decls: [Decl]) : InferState / Console + File + Mutable {


  # every body label must match a declared label by
  # eff name AND unifiable ty_args. `Reader[Int]` body label paired
  # with `Reader[String]` declared label is a row mismatch.
  # an open row (ROpen) absorbs extras through its tail
  # variable, so the body-vs-declared subset check is unconstrained.
  match declared {
    REmpty       ->
      # `fn main() { ... }` without an explicit row absorbs every
      # builtin effect the body performs. Helpers must still declare
      # their row — body-row enforcement still bites where it matters.
      #
      # `Ffi` is the one builtin that does NOT get a
      # default handler from `emit_main_wrapper` (it declares zero
      # ops and is a capability tag, not a handlable effect; per
      # docs/design.md §Baseline architecture FFI crosses to C via
      # the Ffi capability). Absorbing it silently would let
      # `extern "C" fn puts ... / Ffi` called from `main : Unit`
      # compile cleanly — exactly the silent contract documented in
      # `examples/negative/silent_contract/ffi_call_no_capability.kai`.
      # Filter Ffi out of the absorbed set so main must declare
      # `/ Ffi` explicitly when it performs FFI calls directly.
      #
      # main's REmpty branch also absorbed user-defined
      # effects and any builtin without a runtime default handler.
      # `effect Net { ... }` called from `main` compiled silently and
      # SIGSEGV'd at runtime (no handler installed). Reject the same
      # way Ffi is rejected: only labels with an `emit_main_wrapper`
      # default handler should be absorbed.
      # also absorb user-declared effects that carry a
      # source-level `default { }` block. Stage A's `default_setups_from_block`
      # wires shims for them at `main`, so the runtime IS evidence-backed.
      if fname == "main" {
        check_body_row_label_loop(st, fname,
                                  only_non_absorbed_labels(st, st.row, decls),
                                  [], line, col)
      }
      else { check_body_row_label_loop(st, fname, st.row, [], line, col) }
    RClosed(lbs) -> {
      # for `main`, every declared row label must also
      # have an `emit_main_wrapper` default handler. `main : Int / Net`
      # for a user-defined `Net` previously accepted, then segfaulted
      # at runtime because no handler was installed before `kai_main()`.
      # The body-vs-declared subset check is still the primary check;
      # this added pass surfaces the unhandled top-level row.
      let st1 = check_body_row_label_loop(st, fname, st.row,
                                            inf_row_labels_of_rls(lbs),
                                            line, col)
      if fname == "main" {
        check_main_row_handlable(st1, st.row, line, col, decls)
      } else { st1 }
    }
    ROpen(_, _)  -> st
  }
}

# Labels for which `emit_main_wrapper` does NOT
# install a default handler. The runtime default-handler set is the
# fixed list in `default_shims_for` (Stdout, Stderr, Fail, Stdin,
# Env, File, Clock, Random, SecureRandom, NetTcp, Signal, Process,
# Log, Mutable, Cancel, Link, Monitor, Spawn). Anything outside that
# set — `Ffi` (capability tag, no default handler by design) plus any
# user-defined effect (no runtime evidence wired up) — must NOT be
# absorbed by main; reject explicitly so the program does not segfault.
fn only_non_absorbed_labels(st: InferState, row: [Label], decls: [Decl]) : [Label] {
  match row {
    [] -> []
    [h, ...rest] ->
      if effect_has_default_handler(st, h.eff, decls) {
        only_non_absorbed_labels(st, rest, decls)
      } else {
        [h, ...only_non_absorbed_labels(st, rest, decls)]
      }
  }
}

# predicate matching the absorbable-by-main set.
# Stays in sync with the builtin effects injected by
# `inject_builtin_effects`: the fixed default-handler list from
# `default_shims_for` (Stdout..Spawn) plus the parametric stdlib
# effects (State, Reader, Writer) whose handlers are installed by
# user-written or desugar-generated `with State[T](init) { ... }`
# wrappers rather than by `emit_main_wrapper`. `Ffi` is excluded
# (capability tag with no handler). Anything
# outside this list is either a user-declared effect or a
# capability-only label and must NOT be absorbed silently by main.
#
# The `st` parameter lets the check confirm that the in-scope
# `effect <name>` declaration matches the runtime's expected op
# shape (parallels emit-time `effect_default_compatible`): a user-
# declared `effect Log { trace }` shadows the canonical `Log` and
# the runtime's default handler is NOT installed, so the label
# must NOT be absorbed.
fn effect_has_default_handler(st: InferState, name: String, decls: [Decl]) : Bool {
  # absorption is gated on the source-level `default { }`
  # block carrying all-`$extern_handler` clauses. Parametric stdlib
  # effects (State[T], Reader[T], Writer[W]) keep their earlier
  # absorption since they have no runtime default — `var x = init`
  # depends on it (the row-arithmetic gap discussed in the historic
  # comment on `is_absorbable_stdlib_eff`).
  let _ = st
  if inf_effect_default_block_all_extern(name, decls) { true }
  else if is_parametric_handlerless_stdlib_eff(name) { true }
  else { false }
}

# Parametric stdlib effects whose handlers are always user-installed
# (`var x = init` desugar wraps `with State[T](init) { ... }`). They
# carry no runtime default but main absorption stays true so the sugar
# surface keeps compiling — see the long comment on the legacy
# `is_absorbable_stdlib_eff` for the row-arithmetic rationale.
fn is_parametric_handlerless_stdlib_eff(name: String) : Bool {
  name == "State" or name == "Reader" or name == "Writer"
}

# walk `main`'s body row reporting any label whose
# effect lacks an `emit_main_wrapper` default handler. Catches
# `main : Int / Net` where `Net` is user-declared: nothing installs
# a handler, the binary segfaults the first time the op runs.
# `Ffi` is naturally caught here too.
fn check_main_row_handlable(st: InferState, body_row: [Label],
                             line: Int, col: Int, decls: [Decl]) : InferState / Console + File {
  match body_row {
    [] -> st
    [h, ...rest] -> {
      # `Ffi` is the capability-only effect that crosses
      # to C. There is no `emit_main_wrapper` shim for it (by design;
      # the C ABI is the handler), but declaring it in main's row is
      # exactly how a program "earns" the right to call extern fns
      # directly. Treat it as handlable here so `main : Int / Ffi`
      # still typechecks; the REmpty path keeps rejecting an
      # undeclared Ffi label so the silent contract holds.
      let st1 = if h.eff == "Ffi" or effect_has_default_handler(st, h.eff, decls) { st }
      else {
        let use_eu = lookup_eff_use(st.eff_uses, h.eff)
        match use_eu {
          EU(_, uline, ucol) -> {
            let ln = if uline >= 0 { uline } else { line }
            let cl = if ucol  >= 0 { ucol  } else { col  }
            let header = string_concat("`main` declares effect `",
              string_concat(h.eff,
                "` but no default handler is installed for it"))
            diag_error(st.file, ln, cl, header)
            diag_note("only the canonical stdlib effects (Stdout, Stderr, Fail, Stdin, Env, File, Clock, Random, SecureRandom, NetTcp, Signal, Process, Log, Mutable, Cancel, Link, Monitor, Spawn) receive a default handler from the `main` wrapper")
            diag_note("`#{h.eff}` is either user-declared or a capability-only effect (e.g. `Ffi`); the runtime would have no evidence for it at the top level")
            diag_help("wrap the body in `handle { ... } with #{h.eff} { ... }` so the effect is closed before reaching `main`'s scope")
            diag_help("or remove `/ #{h.eff}` from `main`'s declared row if the call site is dead code")
            st_bump_err(st)
          }
        }
      }
      check_main_row_handlable(st1, rest, line, col, decls)
    }
  }
}

# `Console` is the auto-injected alias `type Console = Stdout +
# Stderr + Stdin`; row labels are expanded to atomics by
# `expand_aliases_in_decls` at the program level before any DFn
# row reaches `check_body_row`. There is no per-effect hardcoded
# expansion here.

# label-aware body-vs-declared check. For each label the
# body performed, look for an `eff`-name match in the declared list;
# unify ty_args with `unify_label_args` (extends the substitution).
# Unification failure or absence both report "effect not handled" with
# the parametric label rendered in full.
fn check_body_row_label_loop(st: InferState, fname: String, performed: [Label],
                              declared: [Label], fline: Int, fcol: Int) : InferState / Console + File + Mutable {


  match performed {
    [] -> st
    [lab, ...rest] -> {
      let st1 = match find_matching_declared(declared, lab, st) {
        Some(s_after) -> s_after
        None -> {
          let use_eu = lookup_eff_use(st.eff_uses, lab.eff)
          match use_eu {
            EU(_, uline, ucol) -> {
              let line = if uline >= 0 { uline } else { fline }
              let col  = if ucol  >= 0 { ucol  } else { fcol  }
              let lab_str = label_to_string(apply_label_args(st.sub, lab))
              # Template 5 — missing effect. Header keeps the
              # legacy "effect not handled: <label>" wording so all
              # prior fixtures still match; the shape notes
              # surface the enclosing function's actual row and split
              # the help into two actionable lines (declare-the-effect
              # vs handle-locally) instead of the single combined hint.
              let header = string_concat("effect not handled: ", lab_str)
              diag_error(st.file, line, col, header)
              let n1 = "`#{fname}`'s declared row does not include `#{lab_str}`"
              let n2 = "missing effect: `#{lab_str}`"
              let n3 = "enclosing row: #{render_declared_row(declared)}"
              let h1 = "either declare `#{fname} : ... / #{lab_str}`, or wrap this call site in `handle { ... } with #{lab_str} { ... }`"
              let h2 = "add `/ #{lab_str}` to `#{fname}`'s return type"
              let h3 = "or wrap the call in `handle { ... } with #{lab_str} { ... }`"
              diag_note(n1)
              diag_note(n2)
              diag_note(n3)
              diag_help(h1)
              diag_help(h2)
              diag_help(h3)
              # T5 collected diagnostic.
              let related = [
                ri_note(st.file, line, col, n1),
                ri_note(st.file, line, col, n2),
                ri_note(st.file, line, col, n3),
                ri_help(st.file, line, col, h1),
                ri_help(st.file, line, col, h2),
                ri_help(st.file, line, col, h3)
              ]
              let d = mk_diag(SevError, st.file, line, col, header, related)
              st_bump_err(st_push_diag(st, d))
            }
          }
        }
      }
      check_body_row_label_loop(st1, fname, rest, declared, fline, fcol)
    }
  }
}

# Template 5 — render the declared row labels for the
# `note: enclosing row` line. Empty declared list → "(empty)".
fn render_declared_row(declared: [Label]) : String {
  match declared {
    [] -> "(empty)"
    _  -> inf_join_with(map(declared, label_to_string), " + ")
  }
}

# find a declared label whose eff name and ty_args unify
# with the body's label. Side effect: if a match is found, the unifier
# may bind tyvars on the body label's ty_args to concrete declared
# types. Returns the post-unification InferState, or None on no match.
fn find_matching_declared(declared: [Label], target: Label,
                            st: InferState) : Option[InferState] / Console + File + Mutable {


  match declared {
    [] -> None
    [d, ...rest] ->
      if d.eff == target.eff and labels_args_unify(d.ty_args, target.ty_args, st.sub) {
        Some(unify_label_args_into(d.ty_args, target.ty_args, st))
      } else {
        find_matching_declared(rest, target, st)
      }
  }
}

# Unify two ty_arg lists, propagating any new bindings into st.sub.
# Mismatched length → no-op (caller already excluded that case via
# labels_args_unify which requires equal length).
fn unify_label_args_into(a: [Ty], b: [Ty], st: InferState) : InferState / Console + File + Mutable {


  match a {
    [] -> st
    [ah, ...arest] -> match b {
      [] -> st
      [bh, ...brest] -> {
        let st1 = st_unify(st, ah, bh, "row label type argument", -1, -1)
        unify_label_args_into(arest, brest, st1)
      }
    }
  }
}

# render a Label for diagnostics. Bare-name labels render
# as the eff name; parameterised labels render as `Eff[T1, T2]` with
# each ty_arg passed through `inf_ty_to_string` so unbound TyVars show as
# `?tN`.
#[doc("infer: `label_to_string` — driver-facing type.")]
pub fn label_to_string(l: Label) : String {
  # strip the internal `@<cell>` identity suffix so a
  # `State@i` label renders as `State` in diagnostics.
  let eff = strip_label_alias(l.eff)
  match l.ty_args {
    [] -> eff
    _ -> concat_all([
      eff, "[", inf_join_with(map(l.ty_args, inf_ty_to_string), ", "), "]"
    ])
  }
}

#[doc("infer: the result of inference — typed decls, errors, instantiations, holes.")]
pub type TypedProgram = { decls: [Decl], errs: Int, insts: [ResolvedCS],
                      holes: [ResolvedHole], row_holes: [ResolvedRowHole],
                      core_len: Int,
                      # length of the top-level env the root module's
                      # decl bodies start from. A hole's scope entries
                      # past this boundary (counted from the tail) are
                      # top-level/core bindings; the head slice is
                      # the hole's locals.
                      toplevel_len: Int,
                      # the root file's module-level
                      # `#[doc(...)]` text, lifted from the DModuleDoc
                      # carrier decl that rides the stream into the
                      # typer. None when the file has no module doc.
                      module_doc: Option[String],
                      # structured collected diagnostics for
                      # templates T1, T2, T4, T5. The T3 unbound-
                      # name diagnostic lives on `Env` and is folded in
                      # by `compile_to_module_with_diags` when it runs
                      # `check_program`.
                      diags: [Diagnostic],
                      # per op-call resolution side data (#820 evidence
                      # analysis). Read-only; the typer never consults it.
                      op_res: [OpResolution] }

#[doc("A copy of `tp` with its `decls` replaced — the post-inference rewrite passes swap in a transformed decl stream without restating every field.")]
pub fn typed_prog_with_decls(tp: TypedProgram, ds: [Decl]) : TypedProgram =
  TypedProgram { decls: ds, errs: tp.errs, insts: tp.insts, holes: tp.holes,
                 row_holes: tp.row_holes, core_len: tp.core_len,
                 toplevel_len: tp.toplevel_len, module_doc: tp.module_doc,
                 diags: tp.diags, op_res: tp.op_res }

fn infer_all_loop(file: String, env: TyEnv, core_len: Int, recs: [RecInfo],
                   op_eff_arities: [OpEffArity],
                   ds: [Decl], verbose: Bool,
                   acc_decls: [Decl], acc_errs: Int, acc_insts: [ResolvedCS],
                   acc_holes: [ResolvedHole],
                   acc_row_holes: [ResolvedRowHole],
                   acc_diags: [Diagnostic],
                   acc_op_res: [OpResolution],
                   type_aliases: [AliasResult],
                   op_to_eff: [OpToEff],
                   sums: [SumInfo],
                   proto_impls: [ProtoImplReg],
                   all_decls: [Decl],
                   kind_theories: [KindTheory]) : TypedProgram / Console + File {


  match ds {
    [] -> TypedProgram {
      decls: list_reverse(acc_decls), errs: acc_errs,
      insts: list_reverse(acc_insts), holes: list_reverse(acc_holes),
      row_holes: list_reverse(acc_row_holes),
      core_len: core_len,
      toplevel_len: list_length(env.entries),
      module_doc: doc_module_doc_text(all_decls),
      diags: list_reverse(acc_diags),
      op_res: list_reverse(acc_op_res)
    }
    [d, ...rest] -> {
      let r = infer_decl(file, env, core_len, recs, op_eff_arities,
                          type_aliases, op_to_eff, sums, proto_impls,
                          # pass program-level decls so
                          # check_body_row / check_main_row_handlable can
                          # consult source-level `default { }` blocks
                          # when deciding row absorption at `main`.
                          all_decls,
                          kind_theories,
                          d, verbose)
      infer_all_loop(file, env, core_len, recs, op_eff_arities, rest, verbose,
                     [r.decl, ...acc_decls],
                     acc_errs + r.errs,
                     llvm_prepend_reverse(r.insts, acc_insts),
                     prepend_reverse_holes(r.holes, acc_holes),
                     prepend_reverse_row_holes(r.row_holes, acc_row_holes),
                     prepend_reverse_diags(r.diags, acc_diags),
                     prepend_reverse_op_res(r.op_res, acc_op_res),
                     type_aliases, op_to_eff, sums, proto_impls,
                     all_decls, kind_theories)
    }
  }
}

fn prepend_reverse_row_holes(xs: [ResolvedRowHole], acc: [ResolvedRowHole]) : [ResolvedRowHole] {
  match xs {
    [] -> acc
    [x, ...rest] -> prepend_reverse_row_holes(rest, [x, ...acc])
  }
}

fn prepend_reverse_op_res(xs: [OpResolution], acc: [OpResolution]) : [OpResolution] {
  match xs {
    [] -> acc
    [x, ...rest] -> prepend_reverse_op_res(rest, [x, ...acc])
  }
}

# stamp the enclosing function name onto every resolution captured while
# walking that function's body — the attribution the #820 dump uses
# instead of source lines (an interpolation re-parse rewrites lines).
fn stamp_op_res_fname(xs: [OpResolution], fname: String) : [OpResolution] =
  map(xs, (o) => match o {
    OPR(_, op, cands, chosen, alias, tagged, line, col) -> OPR(fname, op, cands, chosen, alias, tagged, line, col)
  })

# Prepend `xs` onto `acc` in reverse order so `list_reverse(acc)` at
# the end restores document order. Saves a full list_append per decl.
fn llvm_prepend_reverse(xs: [ResolvedCS], acc: [ResolvedCS]) : [ResolvedCS] {
  match xs {
    [] -> acc
    [x, ...rest] -> llvm_prepend_reverse(rest, [x, ...acc])
  }
}

fn prepend_reverse_holes(xs: [ResolvedHole], acc: [ResolvedHole]) : [ResolvedHole] {
  match xs {
    [] -> acc
    [x, ...rest] -> prepend_reverse_holes(rest, [x, ...acc])
  }
}

# prepend `xs` onto `acc` in reverse order so the final
# `list_reverse(acc)` at infer_all_loop's terminal restores source
# order. Matches the pattern used for holes / row_holes / insts above.
fn prepend_reverse_diags(xs: [Diagnostic], acc: [Diagnostic]) : [Diagnostic] {
  match xs {
    [] -> acc
    [x, ...rest] -> prepend_reverse_diags(rest, [x, ...acc])
  }
}

# alias expansion pre-pass.
#
# Walks decls, collecting the body of every `unit Newton = ...` alias
# into a flat table, then rewrites every USym(name) inside a TyDim or
# ELitUnit to that body recursively. After this pass the typer never
# sees an alias symbol — it only sees atomic units and unit-vars.

pub type UAliasEntry = UAE(String, UnitExprT)

fn collect_unit_alias_table(decls: [Decl]) : [UAliasEntry] =
  collect_unit_alias_table_loop(decls, [])

fn collect_unit_alias_table_loop(decls: [Decl], acc: [UAliasEntry]) : [UAliasEntry] {
  match decls {
    [] -> acc
    [d, ...rest] -> match d {
      DUnit(_, name, UBAlias(body), _, _, _) -> collect_unit_alias_table_loop(rest, [UAE(name, body), ...acc])
      _ -> collect_unit_alias_table_loop(rest, acc)
    }
  }
}

# Unit hygiene: walk the decl stream collecting every name
# introduced by a `unit <Name>` declaration (atomic or aliased). The
# typer's unit machinery uses this set to flag references to
# undeclared symbols at use sites — `Real<USD>` only makes sense
# after `unit USD` has been seen.
#[doc("infer: `collect_declared_unit_names` — typer entry point invoked by the driver.")]
pub fn collect_declared_unit_names(decls: [Decl]) : [String] =
  collect_declared_unit_names_loop(decls, [])

fn collect_declared_unit_names_loop(decls: [Decl], acc: [String]) : [String] {
  match decls {
    [] -> acc
    [d, ...rest] -> match d {
      DUnit(_, name, _, _, _, _) -> collect_declared_unit_names_loop(rest, [name, ...acc])
      DDerive(_, inner, _, _) -> collect_declared_unit_names_loop([inner, ...rest], acc)
      DUnstable(inner, _, _) -> collect_declared_unit_names_loop([inner, ...rest], acc)
      DProtoLaws(_, inner, _, _) -> collect_declared_unit_names_loop([inner, ...rest], acc)
      DImplAxiom(_, inner, _, _) -> collect_declared_unit_names_loop([inner, ...rest], acc)
      DConstructor(inner, _, _) -> collect_declared_unit_names_loop([inner, ...rest], acc)
      _ -> collect_declared_unit_names_loop(rest, acc)
    }
  }
}

# Unit hygiene cross-module: only `pub unit X` decls cross
# module boundaries. A consumer can reference `Real<X>` when `X`
# is either declared locally (any visibility) or exported from
# another module via `pub unit`. Internal `unit X` decls stay
# module-private.
fn collect_pub_unit_names(decls: [Decl]) : [String] =
  collect_pub_unit_names_loop(decls, [])

fn collect_pub_unit_names_loop(decls: [Decl], acc: [String]) : [String] {
  match decls {
    [] -> acc
    [d, ...rest] -> match d {
      DUnit(true, name, _, _, _, _) -> collect_pub_unit_names_loop(rest, [name, ...acc])
      DDerive(_, inner, _, _) -> collect_pub_unit_names_loop([inner, ...rest], acc)
      DUnstable(inner, _, _) -> collect_pub_unit_names_loop([inner, ...rest], acc)
      DProtoLaws(_, inner, _, _) -> collect_pub_unit_names_loop([inner, ...rest], acc)
      DImplAxiom(_, inner, _, _) -> collect_pub_unit_names_loop([inner, ...rest], acc)
      DConstructor(inner, _, _) -> collect_pub_unit_names_loop([inner, ...rest], acc)
      _ -> collect_pub_unit_names_loop(rest, acc)
    }
  }
}

# Unit hygiene: walk every `UnitExprT` reachable from the decl
# stream and report an error for each `USym(name)` whose `name` is
# neither a built-in dimension symbol nor declared by a `unit` decl
# present in the merged stream. Returns the number of diagnostics
# emitted; the driver folds it into the exit-code aggregator.
#
# Scoping rules:
#   - Any `unit X` declaration anywhere in the merged stream is
#     visible to every decl in the stream. Cross-module privacy of
#     unit symbols is enforced at the import boundary: `expand_imports`
#     filters non-`pub` decls out before they reach a consumer, so a
#     private `unit X` of module M never appears in the merged stream
#     a different module sees. No bucket / home / visibility table is
#     needed here.
#   - Unit-kind tparams (`impl[u: Measure] ...`) extend the visible
#     set for the duration of a single decl; that scoping is handled
#     in `validate_unit_refs_decl` itself.
#[doc("infer: `validate_unit_refs_decls` — typer entry point invoked by the driver.")]
pub fn validate_unit_refs_decls(decls: [Decl], scope: UnitScope,
                              file: String) : Int / Console + File =
  validate_unit_refs_decls_loop(decls, scope, file, 0)

fn validate_unit_refs_decls_loop(decls: [Decl], scope: UnitScope,
                                    file: String, errs: Int) : Int / Console + File {
  match decls {
    [] -> errs
    [d, ...rest] -> {
      let e1 = errs + validate_unit_refs_decl(d, scope, file)
      validate_unit_refs_decls_loop(rest, scope, file, e1)
    }
  }
}

fn validate_unit_refs_decl(d: Decl, scope: UnitScope, file: String) : Int / Console + File = match d {
  DFn(_, _, tparams, ps, ret, _, body, _, _, _) -> {
    # Extend the scope with this fn's unit-kind tparams (parametric
    # impls like `impl[u: Measure] Show for Real<u>` introduce `u` as
    # a unit symbol valid only inside this body).
    let local_scope = unit_scope_add_locals(scope, collect_unit_tparam_names(tparams))
    let e0 = validate_unit_refs_params(ps, local_scope, file, 0)
    let e1 = match ret {
      Some(te) -> e0 + validate_unit_refs_te(te, local_scope, file)
      None -> e0
    }
    e1 + validate_unit_refs_expr(body, local_scope, file)
  }
  # a type decl's unit-kind tparams scope over its body
  # (`type Money[c: Currency] = Decimal<c>`), same as fn tparams.
  DType(_, _, tparams, body, _, _, _, _) ->
    validate_unit_refs_typebody(body,
      unit_scope_add_locals(scope, collect_unit_tparam_names(tparams)), file)
  # a unit alias body is shape-checked at its declaration —
  # expansion happens after this pass, so a Module-kind product could
  # otherwise ride in through the alias name.
  DUnit(_, _, UBAlias(body), _, line, col) ->
    validate_unit_expr(body, scope, file, line, col) +
    validate_module_unit_shape(body, scope, file, line, col) +
    validate_semilattice_unit_shape(body, scope, file, line, col)
  DTest(_, body, _, _) -> validate_unit_refs_expr(body, scope, file)
  DBench(_, body, _, _) -> validate_unit_refs_expr(body, scope, file)
  DCheck(_, ps, body, _, _) ->
    validate_unit_refs_params(ps, scope, file, 0) +
    validate_unit_refs_expr(body, scope, file)
  DEffect(_, _, _, ops, _, _, _, _) -> validate_unit_refs_eops(ops, scope, file, 0)
  DImpl(_, _, _, sub_decls, _, _) ->
    validate_unit_refs_decls_loop(sub_decls, scope, file, 0)
  DDerive(_, inner, _, _) -> validate_unit_refs_decl(inner, scope, file)
  DUnstable(inner, _, _) -> validate_unit_refs_decl(inner, scope, file)
  DProtoLaws(_, inner, _, _) -> validate_unit_refs_decl(inner, scope, file)
  DImplAxiom(_, inner, _, _) -> validate_unit_refs_decl(inner, scope, file)
  DConstructor(inner, _, _) -> validate_unit_refs_decl(inner, scope, file)
  _ -> 0
}

# Strip the `#Unit` suffix from every unit-kind tparam name and
# return the surface names (the lexically valid identifiers the
# user wrote in `impl[u: Measure] ...`).
fn collect_unit_tparam_names(tparams: [String]) : [String] =
  collect_unit_tparam_names_loop(tparams, [])

fn collect_unit_tparam_names_loop(tparams: [String], acc: [String]) : [String] {
  match tparams {
    [] -> acc
    [n, ...rest] ->
      if tp_kind_is_unit(n) {
        collect_unit_tparam_names_loop(rest, [tp_strip_kind(n), ...acc])
      } else {
        collect_unit_tparam_names_loop(rest, acc)
      }
  }
}

fn validate_unit_refs_params(ps: [Param], scope: UnitScope, file: String,
                                acc: Int) : Int / Console + File = match ps {
  [] -> acc
  [p, ...rest] -> {
    let e1 = match p.ptype {
      Some(te) -> acc + validate_unit_refs_te(te, scope, file)
      None -> acc
    }
    validate_unit_refs_params(rest, scope, file, e1)
  }
}

fn validate_unit_refs_eops(ops: [EffectOp], scope: UnitScope, file: String,
                              acc: Int) : Int / Console + File = match ops {
  [] -> acc
  [op, ...rest] -> match op {
    EOp(_, _, ps, ret, _, _) -> {
      let e1 = acc + validate_unit_refs_params(ps, scope, file, 0) +
                validate_unit_refs_te(ret, scope, file)
      validate_unit_refs_eops(rest, scope, file, e1)
    }
  }
}

fn validate_unit_refs_typebody(b: TypeBody, scope: UnitScope, file: String) : Int / Console + File = match b {
  TBAlias(te) -> validate_unit_refs_te(te, scope, file)
  TBRecord(fs) -> validate_unit_refs_fdecls(fs, scope, file, 0)
  TBSum(vs) -> validate_unit_refs_variants(vs, scope, file, 0)
  TBEffectAlias(_) -> 0
}

fn validate_unit_refs_fdecls(fs: [FieldDecl], scope: UnitScope, file: String,
                                acc: Int) : Int / Console + File = match fs {
  [] -> acc
  [f, ...rest] -> match f {
    FD(_, _, te) -> {
      let e1 = acc + validate_unit_refs_te(te, scope, file)
      validate_unit_refs_fdecls(rest, scope, file, e1)
    }
  }
}

fn validate_unit_refs_variants(vs: [Variant], scope: UnitScope, file: String,
                                  acc: Int) : Int / Console + File = match vs {
  [] -> acc
  [v, ...rest] -> match v {
    Var(_, payload_tes) -> {
      let e1 = acc + validate_unit_refs_te_list(payload_tes, scope, file, 0)
      validate_unit_refs_variants(rest, scope, file, e1)
    }
  }
}

fn validate_unit_refs_te(te: TypeExpr, scope: UnitScope, file: String) : Int / Console + File = match te.tkind {
  TyName(_, targs) -> validate_unit_refs_te_list(targs, scope, file, 0)
  TyList(inner) -> validate_unit_refs_te(inner, scope, file)
  TyFn(ps, ret, _) -> validate_unit_refs_te_list(ps, scope, file, 0) +
                       validate_unit_refs_te(ret, scope, file)
  TyDim(base, u) -> validate_unit_refs_te(base, scope, file) +
                     validate_unit_expr(u, scope, file, te.line, te.col) +
                     validate_module_unit_shape(u, scope, file, te.line, te.col) +
                     validate_semilattice_unit_shape(u, scope, file, te.line, te.col) +
                     validate_habitant_slots(base, u, scope, file, te.line, te.col)
  TyRefine(base, _) -> validate_unit_refs_te(base, scope, file)
  # a compound row as a type argument — validate units
  # inside any parameterised labels it carries (`Reader[Int<m>]`).
  TyRow(row) -> validate_unit_refs_row(row, scope, file)
}

# The head type name of a `TyDim`'s base (`Vec[Real]` -> `Vec`), or
# empty when the base is not a named type.
fn dim_base_head_name(base: TypeExpr) : String = match base.tkind {
  TyName(n, _) -> n
  TyRefine(inner, _) -> dim_base_head_name(inner)
  _ -> ""
}

# The positional habitant components of a `<>` annotation: a `UDims`
# splays into its list, any other unit expression is a single habitant.
fn dim_habitant_components(u: UnitExprT) : [UnitExprT] = match u {
  UDims(us) -> us
  _ -> [u]
}

# The kind a single-habitant unit expression inhabits, for slot-kind
# checking. A local unit-kind tparam (`[n: Dim]`) is a variable, not a
# concrete habitant — its kind is fixed by its binder and unification,
# so it is skipped (empty). A qualified symbol names its kind; a bare
# symbol that resolves keeps the default `Measure` kind (its qualifier
# is elided); an unresolved symbol yields empty (the unit-hygiene
# validator already reports it). A compound expression is not a single
# habitant and yields empty.
fn dim_habitant_kind(u: UnitExprT, scope: UnitScope) : String = match u {
  USym(s) ->
    if scope_is_local(scope, s) { "" }
    else if kind_sym_is_qualified(s) { kind_sym_kind(s) }
    else { match scope_resolve_sym(scope, s) {
      SRok(q) -> if kind_sym_is_qualified(q) { kind_sym_kind(q) } else { measure_kind_name() }
      _ -> ""
    } }
  _ -> ""
}

# Validate a `<>` annotation against the head type's declared habitant
# slots: arity (component count == slot count — a written annotation
# names every slot) and per-slot kind (each component's kind == the
# declared slot kind, positionally). A type absent from the slot table
# declares no slots, so its annotation is a free brand and this check
# is a no-op.
fn validate_habitant_slots(base: TypeExpr, u: UnitExprT, scope: UnitScope,
                           file: String, line: Int, col: Int) : Int / Console + File {
  match scope_habitant_slots_of(scope, dim_base_head_name(base)) {
    None -> 0
    Some(slot_kinds) -> {
      let comps = dim_habitant_components(u)
      let nc = list_length(comps)
      let ns = list_length(slot_kinds)
      if not (nc == ns) {
        diag_error(file, line, col,
          concat_all(["`", dim_base_head_name(base), "` declares ", int_to_string(ns),
                      if ns == 1 { " habitant slot" } else { " habitant slots" },
                      ", but the annotation has ", int_to_string(nc)]))
        1
      } else {
        validate_slot_kinds(dim_base_head_name(base), comps, slot_kinds, scope, file, line, col, 0)
      }
    }
  }
}

fn validate_slot_kinds(tname: String, comps: [UnitExprT], slot_kinds: [String],
                       scope: UnitScope, file: String, line: Int, col: Int,
                       idx: Int) : Int / Console + File = match comps {
  [] -> 0
  [comp, ...rest] -> match slot_kinds {
    [] -> 0
    [want, ...rest_kinds] -> {
      let got = dim_habitant_kind(comp, scope)
      let e = if got == "" or got == want { 0 }
        else {
          diag_error(file, line, col,
            concat_all(["habitant slot ", int_to_string(idx + 1), " of `", tname,
                        "` expects a `", want, "` habitant, but got a `", got, "` one"]))
          1
        }
      e + validate_slot_kinds(tname, rest, rest_kinds, scope, file, line, col, idx + 1)
    }
  }
}

# Atomic-kind shape check on a written unit (annotation or literal):
# a Module or Composition habitant stands alone with exponent 1 or not
# at all. Runs on the canonical table of the whole expression, so
# `USD^1` collapses cleanly and `USD^2`, `USD*m`, `USD/EUR` are
# rejected at the source position that wrote them.
fn validate_module_unit_shape(u: UnitExprT, scope: UnitScope, file: String,
                              line: Int, col: Int) : Int / Console + File {
  match u {
    # Each position of a habitant list stands alone; the shape check
    # runs per component, never on their merged table.
    UDims(us) -> validate_module_unit_shapes(us, scope, file, line, col)
    _ -> validate_module_unit_shape_one(u, scope, file, line, col)
  }
}

fn validate_module_unit_shapes(us: [UnitExprT], scope: UnitScope, file: String,
                               line: Int, col: Int) : Int / Console + File = match us {
  [] -> 0
  [u, ...rest] -> validate_module_unit_shape(u, scope, file, line, col) +
                  validate_module_unit_shapes(rest, scope, file, line, col)
}

fn validate_module_unit_shape_one(u: UnitExprT, scope: UnitScope, file: String,
                                  line: Int, col: Int) : Int / Console + File {
  match scope_kind_theories(scope) {
    [] -> 0
    kts -> match utable_atom_violation(unit_to_table(u), kts) {
      None -> 0
      Some(sym) -> {
        let kind = kind_sym_kind(sym)
        diag_error(file, line, col,
          concat_all(["unit `", inf_unit_expr_display(unit_canon(u)),
                      "` does not exist: `", kind,
                      "` habitants have no products or powers"]))
        diag_note(concat_all(["`", kind,
          "` habitants stand alone: a quantity is either scalar or carries exactly one habitant with exponent 1"]))
        1
      }
    }
  }
}

# Semilattice shape check on a written unit tree (annotation or
# literal): habitants of a Semilattice kind compound only through `+`,
# and a join admits only habitant symbols of one Semilattice kind.
# Tree-based on purpose: the canonical table cannot tell `read*write`
# from `read + write`.
fn validate_semilattice_unit_shape(u: UnitExprT, scope: UnitScope, file: String,
                                   line: Int, col: Int) : Int / Console + File {
  match scope_kind_theories(scope) {
    [] -> 0
    kts -> match sl_shape_violation(u, kts) {
      None -> 0
      Some(v) -> {
        match v {
          SlvProduct(sym) ->
            diag_error(file, line, col,
              concat_all(["`", kind_sym_bare(sym), "` is a `", kind_sym_kind(sym),
                          "` habitant: it joins with `+` and admits no product,",
                          " inverse, or power"]))
          SlvJoinLeaf(what) ->
            diag_error(file, line, col,
              concat_all(["`+` joins habitants of a Semilattice kind, and `",
                          what, "` is not one"]))
          SlvJoinMix(k1, k2) ->
            diag_error(file, line, col,
              concat_all(["habitants of `", k1, "` and `", k2,
                          "` belong to different kinds and cannot join"]))
        }
        1
      }
    }
  }
}

fn validate_unit_refs_row(row: RowExpr, scope: UnitScope, file: String) : Int / Console + File =
  match row {
    REmpty -> 0
    RClosed(labels) -> validate_unit_refs_rls(labels, scope, file, 0)
    ROpen(_, labels) -> validate_unit_refs_rls(labels, scope, file, 0)
  }

fn validate_unit_refs_rls(ls: [RowLabel], scope: UnitScope, file: String,
                             acc: Int) : Int / Console + File = match ls {
  [] -> acc
  [RL(_, ts), ...rest] -> {
    let e1 = acc + validate_unit_refs_te_list(ts, scope, file, 0)
    validate_unit_refs_rls(rest, scope, file, e1)
  }
}

fn validate_unit_refs_te_list(ts: [TypeExpr], scope: UnitScope, file: String,
                                 acc: Int) : Int / Console + File = match ts {
  [] -> acc
  [t, ...rest] -> {
    let e1 = acc + validate_unit_refs_te(t, scope, file)
    validate_unit_refs_te_list(rest, scope, file, e1)
  }
}

fn validate_unit_refs_expr(e: Expr, scope: UnitScope, file: String) : Int / Console + File =
  validate_unit_refs_kind(e.kind, scope, file, e.line, e.col)

fn validate_unit_refs_kind(k: ExprKind, scope: UnitScope, file: String,
                              line: Int, col: Int) : Int / Console + File = match k {
  EInt(_)        -> 0
  EReal(_, _)       -> 0
  EIntLit(_)        -> 0
  EDecimalLit(_)    -> 0
  EFixed(_, _)      -> 0
  EBool(_)       -> 0
  EChar(_)       -> 0
  EStr(_, _)     -> 0
  EUnit          -> 0
  EVar(_)        -> 0
  EUnder         -> 0
  EPlaceholder   -> 0
  EHole(_)       -> 0
  ETodo(_)       -> 0
  EExternBody(_) -> 0
  EVariantsOf(_, _) -> 0
  EModCall(_, _) -> 0
  EIntrinsic(_, args_) -> validate_unit_refs_expr_list(args_, scope, file, 0)
  ECall(callee, args_) -> validate_unit_refs_expr(callee, scope, file) +
                           validate_unit_refs_expr_list(args_, scope, file, 0)
  EField(base, _) -> validate_unit_refs_expr(base, scope, file)
  EIndex(a, b) -> validate_unit_refs_expr(a, scope, file) +
                  validate_unit_refs_expr(b, scope, file)
  EBinop(_, a, b) -> validate_unit_refs_expr(a, scope, file) +
                     validate_unit_refs_expr(b, scope, file)
  EUnop(_, x) -> validate_unit_refs_expr(x, scope, file)
  EIf(c, t_, eo) -> validate_unit_refs_expr(c, scope, file) +
                     validate_unit_refs_expr(t_, scope, file) +
                     validate_unit_refs_opt_expr(eo, scope, file)
  EMatch(scr, arms) -> validate_unit_refs_expr(scr, scope, file) +
                        validate_unit_refs_arms(arms, scope, file, 0)
  ELambda(_, b) -> validate_unit_refs_expr(b, scope, file)
  ERecordLit(_, fs) -> validate_unit_refs_fields(fs, scope, file, 0)
  EList(els) -> validate_unit_refs_elems(els, scope, file, 0)
  ERange(a, b, opt_step) -> validate_unit_refs_expr(a, scope, file) +
                             validate_unit_refs_expr(b, scope, file) +
                             validate_unit_refs_opt_expr(opt_step, scope, file)
  EBlock(stmts, tail) -> validate_unit_refs_stmts(stmts, scope, file, 0) +
                          validate_unit_refs_opt_expr(tail, scope, file)
  EPipe(a, b)        -> validate_unit_refs_expr(a, scope, file) +
                         validate_unit_refs_expr(b, scope, file)
  EMapPipe(a, b)     -> validate_unit_refs_expr(a, scope, file) +
                         validate_unit_refs_expr(b, scope, file)
  EFlatMapPipe(a, b) -> validate_unit_refs_expr(a, scope, file) +
                         validate_unit_refs_expr(b, scope, file)
  EFilterPipe(a, b)  -> validate_unit_refs_expr(a, scope, file) +
                         validate_unit_refs_expr(b, scope, file)
  EHandle(body, _, _, init_opt, _, clauses, ret_opt) ->
    validate_unit_refs_expr(body, scope, file) +
    validate_unit_refs_opt_expr(init_opt, scope, file) +
    validate_unit_refs_clauses(clauses, scope, file, 0) +
    validate_unit_refs_opt_return(ret_opt, scope, file)
  ELitUnit(inner, u) -> validate_unit_refs_expr(inner, scope, file) +
                         validate_unit_expr(u, scope, file, line, col) +
                         validate_module_unit_shape(u, scope, file, line, col) +
                         validate_semilattice_unit_shape(u, scope, file, line, col)
  EBang(inner) -> validate_unit_refs_expr(inner, scope, file)
}

fn validate_unit_refs_expr_list(es: [Expr], scope: UnitScope, file: String,
                                   acc: Int) : Int / Console + File = match es {
  [] -> acc
  [e, ...rest] -> {
    let e1 = acc + validate_unit_refs_expr(e, scope, file)
    validate_unit_refs_expr_list(rest, scope, file, e1)
  }
}

fn validate_unit_refs_opt_expr(opt: Option[Expr], scope: UnitScope,
                                  file: String) : Int / Console + File = match opt {
  None -> 0
  Some(e) -> validate_unit_refs_expr(e, scope, file)
}

fn validate_unit_refs_arms(arms: [Arm], scope: UnitScope, file: String,
                              acc: Int) : Int / Console + File = match arms {
  [] -> acc
  [a, ...rest] -> match a {
    Arm(_, g, b) -> {
      let e1 = acc + validate_unit_refs_opt_expr(g, scope, file) +
                validate_unit_refs_expr(b, scope, file)
      validate_unit_refs_arms(rest, scope, file, e1)
    }
  }
}

fn validate_unit_refs_fields(fs: [FieldInit], scope: UnitScope, file: String,
                                acc: Int) : Int / Console + File = match fs {
  [] -> acc
  [f, ...rest] -> match f {
    FI(_, v) -> {
      let e1 = acc + validate_unit_refs_expr(v, scope, file)
      validate_unit_refs_fields(rest, scope, file, e1)
    }
  }
}

fn validate_unit_refs_elems(els: [ListElem], scope: UnitScope, file: String,
                               acc: Int) : Int / Console + File = match els {
  [] -> acc
  [el, ...rest] -> {
    let e1 = match el {
      ElPlain(x)  -> acc + validate_unit_refs_expr(x, scope, file)
      ElSpread(x) -> acc + validate_unit_refs_expr(x, scope, file)
    }
    validate_unit_refs_elems(rest, scope, file, e1)
  }
}

fn validate_unit_refs_stmts(stmts: [Stmt], scope: UnitScope, file: String,
                               acc: Int) : Int / Console + File = match stmts {
  [] -> acc
  [s, ...rest] -> {
    let e1 = match s {
      SLet(_, ann, rhs)           -> acc + validate_unit_refs_opt_te(ann, scope, file) +
                                           validate_unit_refs_expr(rhs, scope, file)
      SAssert(c, m) -> match m {
        Some(me) -> acc + validate_unit_refs_expr(c, scope, file) +
                          validate_unit_refs_expr(me, scope, file)
        None     -> acc + validate_unit_refs_expr(c, scope, file)
      }
      SExprStmt(x)                -> acc + validate_unit_refs_expr(x, scope, file)
      SIndexAssign(b, i, v, _, _) -> acc + validate_unit_refs_expr(b, scope, file) +
                                            validate_unit_refs_expr(i, scope, file) +
                                            validate_unit_refs_expr(v, scope, file)
      SVar(_, ann, rhs, _, _)     -> acc + validate_unit_refs_opt_te(ann, scope, file) +
                                           validate_unit_refs_expr(rhs, scope, file)
      SUse(_, _, _)               -> acc
    }
    validate_unit_refs_stmts(rest, scope, file, e1)
  }
}

fn validate_unit_refs_clauses(cs: [HClause], scope: UnitScope, file: String,
                                 acc: Int) : Int / Console + File = match cs {
  [] -> acc
  [c, ...rest] -> match c {
    HC(_, _, b, _, _) -> {
      let e1 = acc + validate_unit_refs_expr(b, scope, file)
      validate_unit_refs_clauses(rest, scope, file, e1)
    }
  }
}

fn validate_unit_refs_opt_te(opt: Option[TypeExpr], scope: UnitScope,
                             file: String) : Int / Console + File = match opt {
  None -> 0
  Some(te) -> validate_unit_refs_te(te, scope, file)
}

fn validate_unit_refs_opt_return(opt: Option[HReturn], scope: UnitScope,
                                    file: String) : Int / Console + File = match opt {
  None -> 0
  Some(r) -> match r { HR(_, b, _, _) -> validate_unit_refs_expr(b, scope, file) }
}

# Walk a UnitExprT and emit one diagnostic per unresolved habitant
# symbol. After kind resolution a resolved symbol is qualified
# (`Metric$m`); a still-bare `USym` either resolves to zero kinds
# (undeclared) or several with no `use kind` (ambiguous). The scope
# carries the kind context and the decl's local unit-kind tparams.
fn validate_unit_expr(u: UnitExprT, scope: UnitScope,
                         file: String, line: Int, col: Int) : Int / Console + File = match u {
  UOne -> 0
  UVar(_) -> 0
  USym(s) ->
    if kind_sym_is_qualified(s) { validate_qualified_habitant(s, scope, file, line, col) }
    else { match scope_resolve_sym(scope, s) {
      SRok(_) -> 0
      SRunknown -> {
        let dom = unit_sym_value_domain(s)
        if dom == "" {
          diag_error(file, line, col,
            concat_all(["unknown unit `", s, "`; declare it with `unit ", s,
                        "` (atomic) or `unit ", s, " = <expr>` (alias) before use"]))
        } else {
          diag_error(file, line, col,
            concat_all(["no kind in scope declares `", dom, "` value habitants — `<",
                        s, ">` needs a `kind K : ... with ", dom, "` declaration"]))
        }
        1
      }
      SRambig(kinds) -> {
        let hint =
          if unit_sym_value_domain(s) == "" {
            concat_all(["qualify it (`<", ambig_first_kind(kinds), ".", s,
                        ">`) or add `use kind ", ambig_first_kind(kinds), "`"])
          } else {
            concat_all(["add `use kind ", ambig_first_kind(kinds), "`"])
          }
        diag_error(file, line, col,
          concat_all(["unit `", s, "` is ambiguous — it is declared in ",
                      join_with(kinds, " and "), "; ", hint]))
        1
      }
    } }
  UMul(a, b) -> validate_unit_expr(a, scope, file, line, col) +
                validate_unit_expr(b, scope, file, line, col)
  UInv(a) -> validate_unit_expr(a, scope, file, line, col)
  UPow(a, _) -> validate_unit_expr(a, scope, file, line, col)
  UJoin(a, b) -> validate_unit_expr(a, scope, file, line, col) +
                 validate_unit_expr(b, scope, file, line, col)
  UDims(us) -> validate_unit_exprs(us, scope, file, line, col)
}

fn validate_unit_exprs(us: [UnitExprT], scope: UnitScope,
                       file: String, line: Int, col: Int) : Int / Console + File = match us {
  [] -> 0
  [u, ...rest] -> validate_unit_expr(u, scope, file, line, col) +
                  validate_unit_exprs(rest, scope, file, line, col)
}

# First candidate kind of an ambiguous symbol, for the "qualify as
# <Kind.sym>" hint. The candidate list is never empty here (ambiguity
# means >= 2), but a fallback keeps the walker total.
fn ambig_first_kind(kinds: [String]) : String = match kinds {
  [] -> "Kind"
  [h, ..._] -> h
}

# A qualified habitant (`Kind$sym`) checked against its kind's own
# habitant policy: a value-domain kind admits only values of its
# domain; a closed-set kind admits only its fixed atoms. Every other
# kind passes — the qualifier already pinned it.
fn validate_qualified_habitant(s: String, scope: UnitScope, file: String,
                               line: Int, col: Int) : Int / Console + File {
  let kind = kind_sym_kind(s)
  let bare = kind_sym_bare(s)
  let dom = scope_value_domain_of(scope, kind)
  if not (dom == "") {
    if unit_sym_value_domain(bare) == dom { 0 }
    else {
      diag_error(file, line, col,
        concat_all(["`", bare, "` is not a habitant of `", kind, "` — its habitants",
                    " are `", dom, "` values written directly in `<>`",
                    if dom == "Int" { " (e.g. `<3>`)" } else { " (e.g. `<\"tag\">`)" }]))
      1
    }
  } else {
    let atoms = scope_closed_atoms_of(scope, kind)
    match atoms {
      [] -> 0
      _ ->
        if list_has(atoms, bare) { 0 }
        else {
          diag_error(file, line, col,
            concat_all(["`", bare, "` is not a habitant of the closed kind `", kind,
                        "` — its habitants are: ", join_with(atoms, ", ")]))
          1
        }
    }
  }
}

# Reserved unit symbols the compiler treats as built-in (currently
# none — `Real<1>` parses as UOne, not USym("1")). This hook keeps
# the validator forward-compatible with future built-in dimensions
# (e.g. SI base units shipped as part of the language) without
# editing the per-fixture declaration list.
fn is_builtin_unit_symbol(_s: String) : Bool = false

# ----------------------------------------------------------------------
# Shape-application formation pass.
#
# A `[s: Shape]` tparam is an arity-1 constructor applied as `s[A]`.
# Formation is strict: `s` takes exactly one type argument, and that
# argument may not itself be a bare shape variable (no `s[t[A]]`
# composition — the case that would reintroduce higher-order
# unification). Both are rejected here with a clear diagnostic, at the
# signature that writes them, so the user gets a recipe rather than a
# downstream unification failure.

#[doc("infer: validate `Shape`-tparam application formation across the decl stream; returns the error count.")]
pub fn validate_shape_refs_decls(decls: [Decl], file: String) : Int / Console + File =
  validate_shape_refs_loop(decls, file, 0)

fn validate_shape_refs_loop(decls: [Decl], file: String, errs: Int) : Int / Console + File =
  match decls {
    [] -> errs
    [d, ...rest] -> validate_shape_refs_loop(rest, file, errs + validate_shape_refs_decl(d, file))
  }

fn validate_shape_refs_decl(d: Decl, file: String) : Int / Console + File = match d {
  DFn(_, _, tparams, ps, ret, _, _, _, _, _) -> {
    let shapes = collect_shape_tparam_names(tparams)
    let e0 = validate_shape_refs_params(ps, shapes, file, 0)
    match ret {
      Some(te) -> e0 + validate_shape_refs_te(te, shapes, file)
      None -> e0
    }
  }
  DProtocol(_, _, tparams, ops, _, _) -> {
    let shapes = collect_shape_tparam_names(tparams)
    validate_shape_refs_protoops(ops, shapes, file, 0)
  }
  DEffect(_, _, _, ops, _, _, _, _) -> validate_shape_refs_eops(ops, [], file, 0)
  DImpl(_, _, _, sub_decls, _, _) -> validate_shape_refs_loop(sub_decls, file, 0)
  DDerive(_, inner, _, _) -> validate_shape_refs_decl(inner, file)
  DUnstable(inner, _, _) -> validate_shape_refs_decl(inner, file)
  DProtoLaws(_, inner, _, _) -> validate_shape_refs_decl(inner, file)
  DImplAxiom(_, inner, _, _) -> validate_shape_refs_decl(inner, file)
  DConstructor(inner, _, _) -> validate_shape_refs_decl(inner, file)
  _ -> 0
}

# The surface names of a decl's `Shape`-kind tparams (the applied
# constructor variables valid in its signature).
fn collect_shape_tparam_names(tparams: [String]) : [String] =
  collect_shape_tparam_names_loop(tparams, [])

fn collect_shape_tparam_names_loop(tparams: [String], acc: [String]) : [String] = match tparams {
  [] -> list_reverse(acc)
  [n, ...rest] ->
    if tp_kind_is_shape(n) { collect_shape_tparam_names_loop(rest, [tp_strip_kind(n), ...acc]) }
    else { collect_shape_tparam_names_loop(rest, acc) }
}

fn validate_shape_refs_params(ps: [Param], shapes: [String], file: String,
                              acc: Int) : Int / Console + File = match ps {
  [] -> acc
  [p, ...rest] -> {
    let e1 = match p.ptype {
      Some(te) -> acc + validate_shape_refs_te(te, shapes, file)
      None -> acc
    }
    validate_shape_refs_params(rest, shapes, file, e1)
  }
}

fn validate_shape_refs_protoops(ops: [ProtoOp], shapes: [String], file: String,
                                acc: Int) : Int / Console + File = match ops {
  [] -> acc
  [POp(_, _, ps, ret, _, _), ...rest] -> {
    let e1 = acc + validate_shape_refs_params(ps, shapes, file, 0) +
              validate_shape_refs_te(ret, shapes, file)
    validate_shape_refs_protoops(rest, shapes, file, e1)
  }
}

fn validate_shape_refs_eops(ops: [EffectOp], shapes: [String], file: String,
                            acc: Int) : Int / Console + File = match ops {
  [] -> acc
  [EOp(_, _, ps, ret, _, _), ...rest] -> {
    let e1 = acc + validate_shape_refs_params(ps, shapes, file, 0) +
              validate_shape_refs_te(ret, shapes, file)
    validate_shape_refs_eops(rest, shapes, file, e1)
  }
}

# Walk a signature TypeExpr; a `TyName(s, args)` whose head is a shape
# variable must apply it to exactly one argument, and that argument may
# not be a bare shape variable (composition). Nested positions recurse.
fn validate_shape_refs_te(te: TypeExpr, shapes: [String], file: String) : Int / Console + File =
  match te.tkind {
    TyName(name, targs) ->
      if list_has(shapes, name) {
        let e_arity = if list_length(targs) == 1 { 0 } else {
          eprint(concat_all([file, ":", int_to_string(te.line), ":", int_to_string(te.col),
            ": error: shape `", name, "` must be applied to exactly one type argument (`",
            name, "[A]`); it is an arity-1 constructor"]))
          1
        }
        e_arity + validate_shape_refs_te_list(targs, shapes, file, 0)
      } else {
        # a concrete head whose argument is a bare shape var is
        # composition `t[s[..]]` only when the arg head is itself a
        # shape variable — checked as we recurse below.
        validate_shape_refs_te_composition(targs, shapes, file, 0)
      }
    TyList(inner) -> validate_shape_refs_te(inner, shapes, file)
    TyFn(ps, ret, _) -> validate_shape_refs_te_list(ps, shapes, file, 0) +
                        validate_shape_refs_te(ret, shapes, file)
    TyDim(base, _) -> validate_shape_refs_te(base, shapes, file)
    TyRefine(base, _) -> validate_shape_refs_te(base, shapes, file)
    TyRow(_) -> 0
  }

# The argument of a shape application must not be a bare shape variable:
# `s[t[Int]]` with `t` a shape var is composition, rejected at formation.
fn validate_shape_refs_te_list(tes: [TypeExpr], shapes: [String], file: String,
                               acc: Int) : Int / Console + File = match tes {
  [] -> acc
  [t, ...rest] -> {
    let e_comp = match t.tkind {
      TyName(hn, _) ->
        if list_has(shapes, hn) {
          eprint(concat_all([file, ":", int_to_string(t.line), ":", int_to_string(t.col),
            ": error: shape composition `s[t[..]]` is not supported: `", hn,
            "` is a shape variable and may not stand under another shape application"]))
          1
        } else { 0 }
      _ -> 0
    }
    validate_shape_refs_te_list(rest, shapes, file, acc + e_comp + validate_shape_refs_te(t, shapes, file))
  }
}

fn validate_shape_refs_te_composition(tes: [TypeExpr], shapes: [String], file: String,
                                      acc: Int) : Int / Console + File = match tes {
  [] -> acc
  [t, ...rest] ->
    validate_shape_refs_te_composition(rest, shapes, file,
      acc + validate_shape_refs_te(t, shapes, file))
}

# ----------------------------------------------------------------------
# Pub-signature privacy pass (Hanga Roa import-filter lane, step 1).
#
# Walks every `pub` declaration in the merged decl stream and reports
# an error whenever its signature mentions a NON-`pub` symbol declared
# in the same module. Examples of the leak this catches:
#
#   # lib.kai
#   type Secret = Hidden(Int)             # not pub
#   pub fn unwrap(s: Secret) : Int = ...  # leaks `Secret` to importers
#
# Why this lives here, not in the post-typer cross-module walker: the
# next step of the same lane filters non-`pub` decls out of the import
# stream entirely, so by the time a consumer sees `lib`'s exports the
# private types are physically absent. A consumer that references
# `Secret` would simply fail to resolve the name — but that diagnostic
# would fire in the consumer, not in `lib`. This pass moves the error
# to the right place: the module whose signature is the leak.
#
# Scope of "private name of the same module":
#   - DType names whose `is_pub == false`.
#   - DEffect names whose `is_pub == false` (referenced as row labels).
#   - DProtocol names whose `is_pub == false`.
#   - DConst names are not type-level and cannot appear in signatures;
#     skipped.
#   - DUnit cross-module privacy is handled by validate_unit_refs after
#     the import filter lands. Intra-module unit hygiene already runs
#     in validate_unit_refs_decls.
#
# Walked positions for each pub decl:
#   - DFn / DAxiom: params, return type, row labels.
#   - DConst: declared type.
#   - DType (TBAlias / TBRecord / TBSum): every embedded TypeExpr.
#     TBEffectAlias labels reference effect names — those check too.
#   - DEffect: every op's params and return.
#   - DProtocol: every op's params and return.
#   - DImpl: target type + all sub_decls walked as pub-equivalent (an
#     impl pub exposes its methods).
#
# Implementation: bucket decls by home module via the same anchor
# walker validate_pub_access uses. For each bucket compute the set of
# private type / effect / protocol names. Walk every pub decl in that
# bucket and report references into the private set.

# Per-decl private-name table. `home` is the module the entry was
# declared in; `name` is the surface identifier; `kind` is "type",
# "effect", "protocol", or "unit" so the diagnostic can use the
# right word. The same table answers two questions:
#   - given a TyName at the current home, is its name a private of
#     that home? (covered by priv_lookup)
#   - given a USym at the current home, is its symbol a private of
#     that home? (covered by priv_unit_lookup)
type PubLeakPriv = PLPriv(String, String, String)
#                         home    name    kind

fn collect_pub_leak_privates(decls: [Decl], homes: [HomeAnchor],
                                acc: [PubLeakPriv]) : [PubLeakPriv] = match decls {
  [] -> acc
  [d, ...rest_d] -> match homes {
    [] -> acc
    [h, ...rest_h] -> {
      let acc1 = pub_leak_priv_one(d, ha_home(h), acc)
      collect_pub_leak_privates(rest_d, rest_h, acc1)
    }
  }
}

fn pub_leak_priv_one(d: Decl, home: String,
                        acc: [PubLeakPriv]) : [PubLeakPriv] = match d {
  DType(p, name, _, _, _, _, _, _) ->
    if p { acc } else { [PLPriv(home, name, "type"), ...acc] }
  DEffect(p, name, _, _, _, _, _, _) ->
    if p { acc } else { [PLPriv(home, name, "effect"), ...acc] }
  DProtocol(p, name, _, _, _, _) ->
    if p { acc } else { [PLPriv(home, name, "protocol"), ...acc] }
  DUnit(p, name, _, _, _, _) ->
    if p { acc } else { [PLPriv(home, name, "unit"), ...acc] }
  DDerive(_, inner, _, _) -> pub_leak_priv_one(inner, home, acc)
  DUnstable(inner, _, _) -> pub_leak_priv_one(inner, home, acc)
  DProtoLaws(_, inner, _, _) -> pub_leak_priv_one(inner, home, acc)
  DImplAxiom(_, inner, _, _) -> pub_leak_priv_one(inner, home, acc)
  DConstructor(inner, _, _) -> pub_leak_priv_one(inner, home, acc)
  _ -> acc
}

fn priv_lookup(table: [PubLeakPriv], home: String,
                  name: String) : Option[String] = match table {
  [] -> None
  [e, ...rest] -> match e {
    PLPriv(h, n, k) ->
      if h == home and n == name { Some(k) }
      else { priv_lookup(rest, home, name) }
  }
}

# Top-level driver. Walks the merged decl stream; for each `pub` decl
# (or `pub`-equivalent member of a `pub`/non-`pub` impl), recurse into
# its signature pieces and emit a diagnostic for every reference into
# the private name table for the decl's home module.
#[doc("infer: `validate_module_pub_signatures` — typer entry point invoked by the driver.")]
pub fn validate_module_pub_signatures(decls: [Decl], file: String) : Int / Console + File = {
  let target_mod = inf_core_module_name(file)
  let homes = imports_home_anchors(decls, target_mod, target_mod, [])
  let priv_table = collect_pub_leak_privates(decls, homes, [])
  vmps_walk(decls, homes, priv_table, file, 0)
}

fn vmps_walk(decls: [Decl], homes: [HomeAnchor],
               priv_table: [PubLeakPriv], file: String,
               errs: Int) : Int / Console + File = match decls {
  [] -> errs
  [d, ...rest_d] -> match homes {
    [] -> errs
    [h, ...rest_h] -> {
      let e1 = errs + vmps_decl(d, ha_home(h), priv_table, file)
      vmps_walk(rest_d, rest_h, priv_table, file, e1)
    }
  }
}

fn vmps_decl(d: Decl, home: String, priv_table: [PubLeakPriv],
               file: String) : Int / Console + File = match d {
  DFn(is_pub, name, _, ps, ret, row, _, line, col, _) ->
    if is_pub {
      vmps_fn_sig(name, "fn", ps, ret, row, home, priv_table, file, line, col)
    } else { 0 }
  DAxiom(is_pub, _, name, _, _, ps, ret, row, line, col) ->
    if is_pub {
      vmps_fn_sig(name, "axiom", ps, Some(ret), row, home, priv_table, file, line, col)
    } else { 0 }
  DConst(is_pub, name, te, _, _, line, col) ->
    if is_pub {
      vmps_te(te, name, "const", home, priv_table, file, line, col)
    } else { 0 }
  DType(is_pub, name, _, body, line, col, _, _) ->
    if is_pub {
      vmps_typebody(body, name, home, priv_table, file, line, col)
    } else { 0 }
  DEffect(is_pub, name, _, ops, _, line, col, _) ->
    if is_pub {
      vmps_eops(ops, name, home, priv_table, file, line, col, 0)
    } else { 0 }
  DProtocol(is_pub, name, _, ops, line, col) ->
    if is_pub {
      vmps_pops(ops, name, home, priv_table, file, line, col, 0)
    } else { 0 }
  DImpl(_, _, _, _, _, _) ->
    # Intra-module: an `impl P for T` does not expose T as a name
    # to other modules — the protocol dispatcher looks it up by
    # value type at the call site, not by syntactic reference. So
    # neither the target type nor the methods are walked here:
    # whatever leak they might carry is caught cross-module by
    # `validate_pub_access`'s signature walker (step 2) when the
    # types are referenced by name from another module.
    0
  DDerive(_, inner, _, _) -> vmps_decl(inner, home, priv_table, file)
  DUnstable(inner, _, _) -> vmps_decl(inner, home, priv_table, file)
  DProtoLaws(_, inner, _, _) -> vmps_decl(inner, home, priv_table, file)
  DImplAxiom(_, inner, _, _) -> vmps_decl(inner, home, priv_table, file)
  DConstructor(inner, _, _) -> vmps_decl(inner, home, priv_table, file)
  _ -> 0
}

fn vmps_fn_sig(decl_name: String, decl_kind: String, ps: [Param],
                 ret: Option[TypeExpr], row: RowExpr, home: String,
                 priv_table: [PubLeakPriv], file: String,
                 line: Int, col: Int) : Int / Console + File = {
  let e0 = vmps_params(ps, decl_name, decl_kind, home, priv_table, file, 0)
  let e1 = match ret {
    Some(te) -> e0 + vmps_te(te, decl_name, decl_kind, home,
                                priv_table, file, line, col)
    None -> e0
  }
  e1 + vmps_row(row, decl_name, decl_kind, home, priv_table, file, line, col)
}

fn vmps_params(ps: [Param], decl_name: String, decl_kind: String,
                  home: String, priv_table: [PubLeakPriv], file: String,
                  acc: Int) : Int / Console + File = match ps {
  [] -> acc
  [p, ...rest] -> {
    let e1 = match p.ptype {
      Some(te) -> acc + vmps_te(te, decl_name, decl_kind, home,
                                   priv_table, file, te.line, te.col)
      None -> acc
    }
    vmps_params(rest, decl_name, decl_kind, home, priv_table, file, e1)
  }
}

fn vmps_typebody(b: TypeBody, decl_name: String, home: String,
                    priv_table: [PubLeakPriv], file: String,
                    line: Int, col: Int) : Int / Console + File = match b {
  TBAlias(te) -> vmps_te(te, decl_name, "type", home, priv_table, file, te.line, te.col)
  TBRecord(fs) -> vmps_fdecls(fs, decl_name, home, priv_table, file, 0)
  TBSum(vs) -> vmps_variants(vs, decl_name, home, priv_table, file, 0)
  TBEffectAlias(labels) ->
    vmps_effect_alias_labels(labels, decl_name, home, priv_table, file, line, col, 0)
}

fn vmps_fdecls(fs: [FieldDecl], decl_name: String, home: String,
                  priv_table: [PubLeakPriv], file: String,
                  acc: Int) : Int / Console + File = match fs {
  [] -> acc
  [f, ...rest] -> match f {
    # `priv` field — invisible outside the module, so its type cannot
    # leak. The companion check in `vpa_sig_fdecls` applies the same
    # rule on the pub-access side.
    FD(true, _, te) -> {
      let e1 = acc + vmps_te(te, decl_name, "type", home, priv_table,
                                file, te.line, te.col)
      vmps_fdecls(rest, decl_name, home, priv_table, file, e1)
    }
    FD(false, _, _) -> vmps_fdecls(rest, decl_name, home, priv_table, file, acc)
  }
}

fn vmps_variants(vs: [Variant], decl_name: String, home: String,
                    priv_table: [PubLeakPriv], file: String,
                    acc: Int) : Int / Console + File = match vs {
  [] -> acc
  [v, ...rest] -> match v {
    Var(_, payload_tes) -> {
      let e1 = acc + vmps_te_list(payload_tes, decl_name, "type", home,
                                     priv_table, file, 0)
      vmps_variants(rest, decl_name, home, priv_table, file, e1)
    }
  }
}

fn vmps_effect_alias_labels(labels: [String], decl_name: String,
                               home: String, priv_table: [PubLeakPriv],
                               file: String, line: Int, col: Int,
                               acc: Int) : Int / Console + File = match labels {
  [] -> acc
  [l, ...rest] -> {
    let e1 = acc + vmps_check_name(l, decl_name, "type", home, priv_table,
                                      file, line, col)
    vmps_effect_alias_labels(rest, decl_name, home, priv_table, file,
                                line, col, e1)
  }
}

fn vmps_eops(ops: [EffectOp], decl_name: String, home: String,
                priv_table: [PubLeakPriv], file: String,
                line: Int, col: Int, acc: Int) : Int / Console + File = match ops {
  [] -> acc
  [op, ...rest] -> match op {
    EOp(_, _, ps, ret, ol, oc) -> {
      let ep = vmps_params(ps, decl_name, "effect", home, priv_table, file, 0)
      let er = vmps_te(ret, decl_name, "effect", home, priv_table, file, ol, oc)
      vmps_eops(rest, decl_name, home, priv_table, file, line, col, acc + ep + er)
    }
  }
}

fn vmps_pops(ops: [ProtoOp], decl_name: String, home: String,
                priv_table: [PubLeakPriv], file: String,
                line: Int, col: Int, acc: Int) : Int / Console + File = match ops {
  [] -> acc
  [op, ...rest] -> match op {
    POp(_, _, ps, ret, ol, oc) -> {
      let pp = vmps_params(ps, decl_name, "protocol", home, priv_table, file, 0)
      let pr = vmps_te(ret, decl_name, "protocol", home, priv_table, file, ol, oc)
      vmps_pops(rest, decl_name, home, priv_table, file, line, col, acc + pp + pr)
    }
  }
}

fn vmps_row(row: RowExpr, decl_name: String, decl_kind: String,
              home: String, priv_table: [PubLeakPriv], file: String,
              line: Int, col: Int) : Int / Console + File = match row {
  REmpty -> 0
  RClosed(labels) -> vmps_row_labels(labels, decl_name, decl_kind, home,
                                        priv_table, file, line, col, 0)
  ROpen(_, labels) -> vmps_row_labels(labels, decl_name, decl_kind, home,
                                         priv_table, file, line, col, 0)
}

fn vmps_row_labels(ls: [RowLabel], decl_name: String, decl_kind: String,
                      home: String, priv_table: [PubLeakPriv], file: String,
                      line: Int, col: Int,
                      acc: Int) : Int / Console + File = match ls {
  [] -> acc
  [l, ...rest] -> match l {
    RL(name, targs) -> {
      let cn = vmps_check_name(name, decl_name, decl_kind, home,
                                  priv_table, file, line, col)
      let cl = vmps_te_list(targs, decl_name, decl_kind, home,
                               priv_table, file, 0)
      vmps_row_labels(rest, decl_name, decl_kind, home, priv_table, file,
                         line, col, acc + cn + cl)
    }
  }
}

fn vmps_te(te: TypeExpr, decl_name: String, decl_kind: String,
              home: String, priv_table: [PubLeakPriv], file: String,
              line: Int, col: Int) : Int / Console + File = match te.tkind {
  TyName(n, targs) -> {
    let cn = vmps_check_name(n, decl_name, decl_kind, home, priv_table, file,
                                te.line, te.col)
    let cl = vmps_te_list(targs, decl_name, decl_kind, home, priv_table, file, 0)
    cn + cl
  }
  TyList(inner) -> vmps_te(inner, decl_name, decl_kind, home, priv_table, file,
                              te.line, te.col)
  TyFn(ps, ret, row) -> {
    let cp = vmps_te_list(ps, decl_name, decl_kind, home, priv_table, file, 0)
    let cr = vmps_te(ret, decl_name, decl_kind, home, priv_table, file, te.line, te.col)
    let cw = vmps_row(row, decl_name, decl_kind, home, priv_table, file, te.line, te.col)
    cp + cr + cw
  }
  TyDim(base, u) -> {
    let cb = vmps_te(base, decl_name, decl_kind, home, priv_table, file,
                        te.line, te.col)
    let cu = vmps_uexpr(u, decl_name, decl_kind, home, priv_table, file,
                          te.line, te.col)
    cb + cu
  }
  TyRefine(base, _) -> vmps_te(base, decl_name, decl_kind, home, priv_table, file,
                                  te.line, te.col)
  # a compound row as a type argument — validate the
  # privacy of any labels it carries before alias substitution
  # dissolves the carrier.
  TyRow(row) -> vmps_row(row, decl_name, decl_kind, home, priv_table, file,
                            te.line, te.col)
}

fn vmps_uexpr(u: UnitExprT, decl_name: String, decl_kind: String,
                 home: String, priv_table: [PubLeakPriv], file: String,
                 line: Int, col: Int) : Int / Console + File = match u {
  UOne -> 0
  UVar(_) -> 0
  USym(s) -> vmps_check_name(s, decl_name, decl_kind, home, priv_table,
                                file, line, col)
  UMul(a, b) -> {
    let ca = vmps_uexpr(a, decl_name, decl_kind, home, priv_table, file, line, col)
    let cb = vmps_uexpr(b, decl_name, decl_kind, home, priv_table, file, line, col)
    ca + cb
  }
  UInv(a) -> vmps_uexpr(a, decl_name, decl_kind, home, priv_table, file, line, col)
  UPow(a, _) -> vmps_uexpr(a, decl_name, decl_kind, home, priv_table, file, line, col)
  UJoin(a, b) -> {
    let ea = vmps_uexpr(a, decl_name, decl_kind, home, priv_table, file, line, col)
    let eb = vmps_uexpr(b, decl_name, decl_kind, home, priv_table, file, line, col)
    ea + eb
  }
  UDims(us) -> vmps_uexprs(us, decl_name, decl_kind, home, priv_table, file, line, col)
}

fn vmps_uexprs(us: [UnitExprT], decl_name: String, decl_kind: String,
               home: String, priv_table: [PubLeakPriv], file: String,
               line: Int, col: Int) : Int / Console + File = match us {
  [] -> 0
  [u, ...rest] -> vmps_uexpr(u, decl_name, decl_kind, home, priv_table, file, line, col) +
                  vmps_uexprs(rest, decl_name, decl_kind, home, priv_table, file, line, col)
}

fn vmps_te_list(ts: [TypeExpr], decl_name: String, decl_kind: String,
                   home: String, priv_table: [PubLeakPriv], file: String,
                   acc: Int) : Int / Console + File = match ts {
  [] -> acc
  [t, ...rest] -> {
    let e1 = acc + vmps_te(t, decl_name, decl_kind, home, priv_table,
                              file, t.line, t.col)
    vmps_te_list(rest, decl_name, decl_kind, home, priv_table, file, e1)
  }
}

fn vmps_check_name(n: String, decl_name: String, decl_kind: String,
                      home: String, priv_table: [PubLeakPriv],
                      file: String, line: Int,
                      col: Int) : Int / Console + File =
  match priv_lookup(priv_table, home, n) {
    None -> 0
    Some(kind_word) -> {
      diag_error(file, line, col,
        concat_all(["pub ", decl_kind, " `", decl_name,
                    "` exposes non-pub ", kind_word, " `", n,
                    "` from module `", home,
                    "`; mark `", n, "` as `pub` or remove it from the signature"]))
      1
    }
  }

fn unit_alias_lookup(aliases: [UAliasEntry], name: String) : Option[UnitExprT] {
  match aliases {
    [] -> None
    [a, ...rest] -> match a {
      UAE(n, b) -> if n == name { Some(b) } else { unit_alias_lookup(rest, name) }
    }
  }
}

# Walk a UnitExprT and replace USym(name) with the alias body whenever
# `name` is registered as an alias. Recursive — alias-of-alias chains
# expand fully. The `seen` parameter guards against accidental cycles
# (the spec rules them out, but a defensive guard keeps the
# compiler from looping if a future refactor introduces one).
fn expand_unit_aliases_in_unit(u: UnitExprT, aliases: [UAliasEntry], seen: [String]) : UnitExprT {
  match u {
    UOne -> u
    UVar(_) -> u
    USym(s) -> {
      if list_has_string(seen, s) { u }
      else {
        match unit_alias_lookup(aliases, s) {
          Some(body) -> expand_unit_aliases_in_unit(body, aliases, [s, ...seen])
          None -> u
        }
      }
    }
    UMul(a, b) -> UMul(expand_unit_aliases_in_unit(a, aliases, seen),
                      expand_unit_aliases_in_unit(b, aliases, seen))
    UInv(a) -> UInv(expand_unit_aliases_in_unit(a, aliases, seen))
    UPow(a, n) -> UPow(expand_unit_aliases_in_unit(a, aliases, seen), n)
    UJoin(a, b) -> UJoin(expand_unit_aliases_in_unit(a, aliases, seen),
                         expand_unit_aliases_in_unit(b, aliases, seen))
    UDims(us) -> UDims(expand_unit_aliases_in_units(us, aliases, seen))
  }
}

fn expand_unit_aliases_in_units(us: [UnitExprT], aliases: [UAliasEntry], seen: [String]) : [UnitExprT] = match us {
  [] -> []
  [u, ...rest] -> [expand_unit_aliases_in_unit(u, aliases, seen),
                   ...expand_unit_aliases_in_units(rest, aliases, seen)]
}

fn expand_unit_aliases_decls(ds: [Decl], aliases: [UAliasEntry]) : [Decl] =
  map_units_decls(ds, (u) => expand_unit_aliases_in_unit(u, aliases, []))

# Per-module typer env deltas.
#
# `ModuleEnvDelta` is the diff a single module contributes to the
# typer env. It is the load-bearing data type for the stdlib cache:
# the core's delta gets serialised; cold
# starts re-apply it on top of the freshly-built built-in seed.
#
# Diff (not full env) so the cache stays independent of the
# built-in env baked into the compiler. `add_core_sigs` +
# `add_builtin_variant_sigs` re-run every invocation; only the
# user-visible decls live in the delta.
#
# Scope A (this lane): ty_entries, unions, op_eff_arities, recs,
# sums, op_to_eff, unit_aliases. Effect aliases, transparent
# aliases, and protocol impls are produced by the pre-typer cascade
# (cross-module by design) and threaded around the fold as separate
# args. The record's shape is open so scope B/C can add fields
# without rewriting downstream consumers.
pub type ModuleEnvDelta = {
  name:           Option[String],
  ty_entries:     [TyEntry],
  unions:         [UnionInfo],
  op_eff_arities: [OpEffArity],
  recs:           [RecInfo],
  sums:           [SumInfo],
  op_to_eff:      [OpToEff],
  unit_aliases:   [UAliasEntry],
  constructors:   [CtorEntry]
}

fn module_env_delta_empty() : ModuleEnvDelta = ModuleEnvDelta {
  name: None, ty_entries: [], unions: [], op_eff_arities: [],
  recs: [], sums: [], op_to_eff: [], unit_aliases: [], constructors: []
}

# Compose a child delta onto a parent. Cons-front so the child's
# bindings shadow the parent's (Rule B: locals shadow imports).
# Data-only tables (recs, sums, op_eff_arities, etc.) are
# prepended so downstream lookups see the same precedence as the
# pre-refactor merged stream.
fn merge_env_deltas(parent: ModuleEnvDelta, child: ModuleEnvDelta) : ModuleEnvDelta =
  ModuleEnvDelta {
    name:           child.name,
    ty_entries:     list_append(child.ty_entries, parent.ty_entries),
    unions:         list_append(child.unions, parent.unions),
    op_eff_arities: list_append(child.op_eff_arities, parent.op_eff_arities),
    recs:           list_append(child.recs, parent.recs),
    sums:           list_append(child.sums, parent.sums),
    op_to_eff:      list_append(child.op_to_eff, parent.op_to_eff),
    unit_aliases:   list_append(child.unit_aliases, parent.unit_aliases),
    constructors:   list_append(child.constructors, parent.constructors)
  }

# A single module's view of the decl stream. `name = None` is the
# synthetic seed; everything else carries its source module name
# (or the target file's basename for the root). Used by
# `typecheck_program` to partition `all_decls` into per-module
# sub-streams.
type ModuleDecls = { name: Option[String], decls: [Decl] }

#[doc("infer: run HM + bidirectional inference over a program, returning the TypedProgram.")]
pub fn infer_program(file: String, decls: [Decl], verbose: Bool) : TypedProgram / Console + File =


  infer_program_with_protos(file, decls, verbose, [])

# pre-typer data tables collected once over the full
# decl stream. `infer_program_with_protos` (and the per-module fold
# composing it) read these tables; under scope A the cascade
# computes them globally and the fold inherits them without
# recomputing.
type ProgramData = {
  decls_a:    [Decl],            # decls after unit-alias expansion
  built:      BuiltEnv,
  recs:       [RecInfo],
  alias_res:  AliasResolution,
  op_to_eff:  [OpToEff],
  sums:       [SumInfo]
}

# variant that seeds the working tables from an
# inherited `ModuleEnvDelta` (typically the core's). Each table
# (TyEnv entries, op_eff_arities, recs, sums, op_to_eff, unions,
# unit_aliases, type aliases) is computed for the current module
# and composed with the inherited contribution so the typer sees
# the same view it would over `inherited.decls ++ decls` flattened.
#
# Composition rules (cons-front so this module's bindings shadow
# the inherited ones — Rule B, locals shadow imports):
#   - `entries` / `op_eff_arities` / `unions`: append this module's
#     contribution at the FRONT (handled by `build_ty_env_inherited`
#     for entries / arities; this fn for unions).
#   - `recs` / `sums` / `op_to_eff` / `unit_aliases`: list_append
#     `this_module ++ inherited` for the same reason.
#   - `alias_res`: resolved over `decls` only — alias resolution is
#     scope-A-global and the caller threads its result separately;
#     for a per-module fold each segment resolves its own aliases
#     against the inherited effect-name namespace.
#
# When `inherited == module_env_delta_empty()` the function reduces
# to the original `collect_program_data` shape — byte-identical to
# the earlier baseline.
fn collect_program_data_inherited(file: String, decls: [Decl],
                                    inherited: ModuleEnvDelta,
                                    all_program_decls: [Decl])
                                    : ProgramData / Console + File {
  # expand `unit Newton = kg * m / sec^2` aliases at the AST
  # level before any pass that calls inf_resolve_ty. After this pass no
  # USym in any TyDim or ELitUnit refers to an alias name.
  let aliases_here = collect_unit_alias_table(decls)
  # when this module references a unit alias declared
  # by an upstream module, the inherited table participates in
  # expansion. Cons-front so local aliases shadow inherited ones.
  let aliases_all = unit_alias_compose(aliases_here, inherited.unit_aliases)
  let decls_a = expand_unit_aliases_decls(decls, aliases_all)
  # seed the typer env from `inherited.ty_entries` on
  # top of the built-in seed; collect unions across the inherited
  # set + this module so cross-module variant lookups still resolve.
  let seed = build_ty_env_seed()
  let unions_here = collect_unions(decls_a)
  let unions_all = list_append(unions_here, inherited.unions)
  let top_names = collect_top_type_names(decls_a)
  # row-kind table over the FULL program decl stream so a
  # `T[..., e]` annotation in one module resolves the row slot of a
  # type declared in another (a root `fn : Stream[t, e]` against
  # stdlib's `Stream`). Same whole-program scoping as alias resolution.
  let rk_src_decls = if list_length(all_program_decls) > 0 {
    all_program_decls
  } else { decls_a }
  let rk_table = compute_row_kind_slots(rk_src_decls)
  let built = build_ty_env_inherited_rk(seed, inherited, decls_a,
                                       unions_all, top_names, rk_table)
  let recs_here = collect_records(decls_a)
  let recs_all = list_append(recs_here, inherited.recs)
  # rebuild the type-alias resolution table here so
  # `try_op_call` can resolve `Aliasname.opname` for aliases like
  # `Console = Stdout + Stderr + Stdin` and `Io = Console + Env +
  # File`. The work duplicates `compile_source`'s alias resolution
  # but avoids threading 10+ call sites with two extra parameters.
  #
  # Hanga Roa modular typecheck: collect alias candidates over the
  # FULL program decl stream so an alias declared in one bucket
  # (e.g. the built-in `Console` alias) is still resolvable from
  # any other bucket's bodies. Without this, a target file that
  # writes `Console.print(s)` looks up `Console` only in its own
  # bucket's decls and falls back to the legacy 2-arg shape (op
  # call passing the effect-value as the first arg).
  let alias_src_decls = if list_length(all_program_decls) > 0 {
    all_program_decls
  } else { decls_a }
  let alias_cands = inf_collect_alias_cands(alias_src_decls)
  let eff_names_for_alias = collect_effect_names(alias_src_decls)
  let alias_res = inf_resolve_alias_cands(alias_cands, eff_names_for_alias, file)
  let op_to_eff_here = inf_collect_op_to_eff(decls_a)
  let op_to_eff_all = list_append(op_to_eff_here, inherited.op_to_eff)
  # sum-type registry for the region-brand walker.
  let sums_here = collect_sums(decls_a)
  let sums_all = list_append(sums_here, inherited.sums)
  ProgramData {
    decls_a: decls_a, built: built, recs: recs_all,
    alias_res: alias_res, op_to_eff: op_to_eff_all, sums: sums_all
  }
}

# cons-front unit-alias composition. Child shadows
# parent: `unit Newton = kg * m / sec^2` declared locally hides any
# inherited alias of the same name. Linear in the child + parent
# count, called once per module fold step.
fn unit_alias_compose(child: [UAliasEntry], parent: [UAliasEntry])
                       : [UAliasEntry] = list_append(child, parent)

# public per-module typecheck entry point.
#
# Typechecks `mod.decls` against the env carried by `inherited`
# and returns the typed decls plus the delta this module
# contributes. The composed result of folding `typecheck_module`
# over a list of modules is byte-identical to the monolithic
# pre-refactor `infer_program_with_protos` on the concatenation.
#
# A single-module call collects ProgramData over its
# `decls` and runs `infer_all_loop` once. Multi-module fold lives
# in `typecheck_program` and flattens to a single segment so the
# byte-identical baseline holds.
type TypecheckedModule = { typed: TypedProgram, delta: ModuleEnvDelta }

fn typecheck_module(file: String, mod: ModuleDecls,
                     inherited: ModuleEnvDelta,
                     all_program_decls: [Decl],
                     proto_impls: [ProtoImplReg],
                     head_owners: [HeadOwnerEntry],
                     kind_theories: [KindTheory],
                     verbose: Bool) : TypecheckedModule / Console + File {


  let data0 = collect_program_data_inherited(file, mod.decls, inherited,
                                                all_program_decls)
  # attach the per-compile head-owner cache to the env
  # the typer walks. The cache is built once per `compile_source`
  # invocation from the post-`expand_imports` decl stream + module
  # table; threading it here keeps `synth_pipe_dispatch`'s lookup
  # `O(1)` per call site.
  # seed the root-file function-name set so
  # `try_bare_call_narrow` lets a user `fn foo` shadow a same-named
  # stdlib export even when their signatures match. ONLY the target
  # bucket (the user's root file) sees this set; an imported core
  # module typechecks against an EMPTY one. The directional-visibility
  # invariant: core never observes the user, so a user root fn cannot
  # shift core's typed AST through the bare-call narrowing guard.
  #
  # The target bucket is `None` (the single-bucket fallback) or
  # `Some(m)` with `m == inf_core_module_name(file)`; every other
  # `Some(m)` is an imported core/core module.
  let env_with_owners0 = ty_env_with_head_owners(data0.built.env, head_owners)
  let is_target_bucket = match mod.name {
    None    -> true
    Some(m) -> m == inf_core_module_name(file)
  }
  let root_fns_here = if is_target_bucket {
    collect_root_fn_names(if list_length(all_program_decls) > 0 { all_program_decls } else { data0.decls_a })
  } else { [] }
  let env_with_owners = ty_env_with_root_fns(env_with_owners0, root_fns_here)
  let built1 = BuiltEnv { env: env_with_owners,
                          core_len: data0.built.core_len,
                          op_eff_arities: data0.built.op_eff_arities }
  let data = ProgramData { decls_a: data0.decls_a, built: built1,
                            recs: data0.recs, alias_res: data0.alias_res,
                            op_to_eff: data0.op_to_eff, sums: data0.sums }
  # Hanga Roa modular typecheck: `infer_all_loop` keeps a per-decl
  # `all_decls` pointer so `check_main_row_handlable` /
  # `check_body_row` can look up `DEffect default { ... }` blocks
  # from any module. Pass the full program's decl list (not just
  # this module's) so cross-module effect-default lookups stay
  # honest after the partition.
  let all_decls_for_typer = if list_length(all_program_decls) > 0 {
    all_program_decls
  } else { data.decls_a }
  let tp = infer_all_loop(file, data.built.env, data.built.core_len, data.recs,
                 data.built.op_eff_arities, data.decls_a, verbose, [], 0, [], [], [], [], [],
                 data.alias_res.aliases, data.op_to_eff, data.sums, proto_impls,
                 all_decls_for_typer, kind_theories)
  # Stage B coverage check. Runs after row-level inference
  # is complete so the typed body carries the resolved `EVar("Eff.op")`
  # callees the walker keys on. Adds its diagnostics directly to stderr
  # and folds the count into TypedProgram.errs.
  #
  # Pass `all_decls_for_typer` (whole program) as the second list so
  # effect-existence and default-block lookups see DEffects that the
  # modular partition placed in a different pass than the body that
  # performs the op. Without this, `is_effect_declared` returns false
  # for any user effect declared in the same file but partitioned away
  # from its `fn main()`, silencing the per-op coverage walker.
  let cov_errs = check_default_coverage(file, tp.decls, all_decls_for_typer)
  # priv-fields lane: reject cross-module reads / constructions that
  # touch a `priv` record field. The record's declaring module lives
  # in the field's TyCon module_origin; this walker compares against
  # `mod.name` (the current module's home — None for the root file,
  # Some(m) for an imported module). Runs post-typing so `obj.ty` is
  # the resolved record type, not a free variable.
  let priv_errs = check_field_privacy(file, mod.name, tp.decls, all_decls_for_typer)
  let typed = TypedProgram {
    decls: tp.decls, errs: tp.errs + cov_errs + priv_errs,
    insts: tp.insts, holes: tp.holes, row_holes: tp.row_holes,
    core_len: tp.core_len, toplevel_len: tp.toplevel_len,
    module_doc: tp.module_doc,
    diags: tp.diags, op_res: tp.op_res
  }
  # the returned delta carries ONLY this module's
  # contribution (i.e. the slice of working-table state that
  # `decls_a` added on top of `inherited`). The fold's `acc_delta`
  # composes these per-module slices via `merge_env_deltas`, so a
  # downstream cache hit can serialise this slice in isolation and
  # the next loader hands it back through `inherited` to skip the
  # work this call did.
  #
  # `ty_entries` extracted by length-diff against `inherited`: every
  # entry past `len(inherited.ty_entries) + len(seed_entries)` was
  # added by `add_decls_loop` over this module. `add_decls_loop`
  # cons-prepends, so the new entries occupy the head of the list;
  # the same shape holds for `op_eff_arities`.
  let n_inherited = list_length(inherited.ty_entries) +
                     list_length(build_ty_env_seed().env.entries)
  let n_total = list_length(data.built.env.entries)
  let n_new = n_total - n_inherited
  let new_entries = take_entries(data.built.env.entries, n_new, [])
  let n_ar_inherited = list_length(inherited.op_eff_arities)
  let n_ar_total = list_length(data.built.op_eff_arities)
  let new_arities = take_op_eff_arities(data.built.op_eff_arities,
                                          n_ar_total - n_ar_inherited, [])
  let delta = ModuleEnvDelta {
    name:           mod.name,
    ty_entries:     new_entries,
    unions:         collect_unions(data.decls_a),
    op_eff_arities: new_arities,
    recs:           collect_records(data.decls_a),
    sums:           collect_sums(data.decls_a),
    op_to_eff:      inf_collect_op_to_eff(data.decls_a),
    unit_aliases:   collect_unit_alias_table(mod.decls),
    constructors:   collect_constructors(data.decls_a, [])
  }
  TypecheckedModule { typed: typed, delta: delta }
}

# take the first `n` op-eff arity records, mirroring
# `take_entries`. Used by `typecheck_module` to extract the head
# slice that `add_decls_loop` cons-prepended for this module's
# contribution. Tail-recursive on `acc` for arity-list sizes that
# scale with the effect-op count of every loaded module.
fn take_op_eff_arities(xs: [OpEffArity], n: Int,
                         acc: [OpEffArity]) : [OpEffArity] {
  if n <= 0 { list_reverse(acc) }
  else { match xs {
    [] -> list_reverse(acc)
    [h, ...rest] -> take_op_eff_arities(rest, n - 1, [h, ...acc])
  } }
}

# fold `typecheck_module` left-to-right across the
# per-module decl streams, threading the accumulating
# `ModuleEnvDelta` as `inherited` for each segment. The fold is
# trivial when `modules` has a single segment (the path every legacy
# caller still uses): one iteration, `inherited = empty_delta`,
# identical to the earlier flatten-and-call shape. Multi-segment
# callers (the stdlib cache loader, core/user split) drive
# real fold dynamics — see `typecheck_program_loop`.
fn typecheck_program(file: String, modules: [ModuleDecls],
                      proto_impls: [ProtoImplReg],
                      verbose: Bool) : TypedProgram / Console + File =
  typecheck_program_with_head_owners(file, modules, proto_impls, [], [], verbose)

# variant accepting the per-compile head-owner cache. The
# cache is built once by `compile_source` after `expand_imports`
# completes; legacy callers (test helpers, dump utilities) pass `[]`
# via `typecheck_program` and any pipe call sites in those test inputs
# fall back to the "no module declaring type" diagnostic — the right
# behaviour given those harnesses do not load a module table.
fn typecheck_program_with_head_owners(file: String, modules: [ModuleDecls],
                                       proto_impls: [ProtoImplReg],
                                       head_owners: [HeadOwnerEntry],
                                       kind_theories: [KindTheory],
                                       verbose: Bool) : TypedProgram / Console + File {


  # Flatten every bucket's decls in the order they appear in
  # `modules` so the per-module typechecker can still cross-reference
  # `DEffect default { ... }` blocks (and other program-wide
  # decl-shaped data) without seeing the partition boundary.
  let all_program_decls = flatten_module_decls(modules, [])
  typecheck_program_loop(file, modules, module_env_delta_empty(),
                          all_program_decls,
                          proto_impls, head_owners, kind_theories, verbose,
                          [], 0, [], [], [], [], [], 0, 0)
}

fn flatten_module_decls(mods: [ModuleDecls], acc: [Decl]) : [Decl] = match mods {
  [] -> acc
  [m, ...rest] -> flatten_module_decls(rest, list_append(acc, m.decls))
}

# Tail-recursive fold accumulator. Each iteration typechecks one
# `ModuleDecls` against the running delta, merges the produced delta
# into the accumulator, and appends the typed module's pieces to
# `acc_*`. `core_len_acc` keeps the first non-zero `core_len`
# returned by any module — every call shares the
# same built-in seed length, so the value is identical regardless of
# which module reports it. The reverse step at the terminal restores
# document order on the accumulated lists.
fn typecheck_program_loop(file: String, modules: [ModuleDecls],
                            acc_delta: ModuleEnvDelta,
                            all_program_decls: [Decl],
                            proto_impls: [ProtoImplReg],
                            head_owners: [HeadOwnerEntry],
                            kind_theories: [KindTheory],
                            verbose: Bool,
                            acc_decls: [Decl],
                            acc_errs: Int,
                            acc_insts: [ResolvedCS],
                            acc_holes: [ResolvedHole],
                            acc_row_holes: [ResolvedRowHole],
                            acc_diags: [Diagnostic],
                            acc_op_res: [OpResolution],
                            core_len_acc: Int,
                            # last module's top-level env length. The
                            # target file is typed last, so this is the
                            # boundary its holes' locals sit above.
                            toplevel_len_acc: Int) : TypedProgram / Console + File {

  match modules {
    [] -> TypedProgram {
      decls: list_reverse(acc_decls), errs: acc_errs,
      insts: list_reverse(acc_insts), holes: list_reverse(acc_holes),
      row_holes: list_reverse(acc_row_holes),
      core_len: core_len_acc,
      toplevel_len: toplevel_len_acc,
      module_doc: doc_module_doc_text(all_program_decls),
      diags: list_reverse(acc_diags),
      op_res: list_reverse(acc_op_res)
    }
    [m, ...rest] -> {
      let r = typecheck_module(file, m, acc_delta, all_program_decls,
                                  proto_impls, head_owners, kind_theories, verbose)
      let next_delta = merge_env_deltas(acc_delta, r.delta)
      let next_core_len = match core_len_acc {
        0 -> r.typed.core_len
        _ -> core_len_acc
      }
      typecheck_program_loop(file, rest, next_delta, all_program_decls,
                              proto_impls, head_owners, kind_theories, verbose,
                              prepend_reverse_decls(r.typed.decls, acc_decls),
                              acc_errs + r.typed.errs,
                              llvm_prepend_reverse(r.typed.insts, acc_insts),
                              prepend_reverse_holes(r.typed.holes, acc_holes),
                              prepend_reverse_row_holes(r.typed.row_holes,
                                                         acc_row_holes),
                              prepend_reverse_diags(r.typed.diags, acc_diags),
                              prepend_reverse_op_res(r.typed.op_res, acc_op_res),
                              next_core_len, r.typed.toplevel_len)
    }
  }
}

# prepend `xs` onto `acc` reversed; the final
# `list_reverse(acc)` at terminal restores source order. Mirrors the
# pattern used by `prepend_reverse_holes` / `llvm_prepend_reverse`
# inside `infer_all_loop`.
fn prepend_reverse_decls(xs: [Decl], acc: [Decl]) : [Decl] {
  match xs {
    [] -> acc
    [x, ...rest] -> prepend_reverse_decls(rest, [x, ...acc])
  }
}

# Hanga Roa modular typecheck: partition a post-cascade flat decl
# stream into per-module sub-streams. Each decl is attributed to
# its declaring module based on its OWN `module_origin` field (or
# the target's basename when the field is `None`); the result is a
# list of `ModuleDecls` in first-appearance order so the typer
# fold processes cores in the order the loader saw them, and
# the target file last.
#
# This deliberately does NOT reuse `imports_home_anchors` — that
# walker propagates the running home backward to fix up untagged
# DTypes at module boundaries, which is correct for the pub-access
# table but wrong here. We need a static, decl-local rule so a
# post-cascade decl interleaved (e.g. a target-file fn sitting
# between a core's last DFn and its later-emitted protocol
# impl methods) lands in its own bucket instead of being absorbed
# by the surrounding core's home.
#
# The partition is structural — once it runs, the typer can no
# longer see a core module's records leaking into the target
# (or vice versa). The legacy `rerank_recs_for` patch is no longer
# load-bearing once every call site goes through this partition.
fn partition_decls_by_home(decls: [Decl], target_mod: String) : [ModuleDecls] = {
  partition_by_homes_loop(decls, target_mod, [])
}

# Walk decls left-to-right, bucketing each decl under its home
# module. Buckets are accumulated in first-appearance order;
# within a bucket decls keep source order.
#
# Two-phase walk:
#   (`seen_anchor=false`): builtin / synthetic decls
#     (`inject_builtin_effects` emits DEffect / DType for the
#     canonical Stdout/Stderr/... before any user decl). They are
#     untagged but conceptually language-level, not target-level.
#     We collect them into the `__builtin__` bucket so the target
#     does not absorb them.
#   (`seen_anchor=true`): every untagged decl is target-
#     authored (the cascade preserves source order, so once any
#     anchored decl appears we are past the synthetic core).
#
# The phase flip happens at the first decl carrying an explicit
# `module_origin` of its own.
fn partition_by_homes_loop(decls: [Decl], target_mod: String,
                              acc: [ModuleDecls]) : [ModuleDecls] =
  partition_by_homes_walk(decls, target_mod, "__builtin__", acc)

# Walk decls left-to-right, threading the running `current_anchor`
# module (= the home of the most recently seen DFn / DType /
# DAttribPure that carried an explicit `module_origin`). Decls
# whose own kind cannot carry a `module_origin` (DEffect, DUnit,
# DUse) attribute to the `current_anchor` — they live in the same
# physical .kai file as the surrounding tagged DFns. The starting
# anchor is `__builtin__`, so any untagged decl emitted before
# the first real module's first tagged DFn (the synthetic
# `inject_builtin_effects` block) lands in `__builtin__`.
fn partition_by_homes_walk(decls: [Decl], target_mod: String,
                              current_anchor: String,
                              acc: [ModuleDecls]) : [ModuleDecls] = match decls {
  [] -> acc
  [d, ...rest_d] -> {
    let explicit = decl_explicit_module_origin(d)
    let anchor1 = match explicit {
      Some(m) -> m
      None    -> current_anchor
    }
    let home = decide_partition_home(d, target_mod, anchor1)
    # once a genuine target-authored decl (a `mo = None`
    # DFn, which `decide_partition_home` routes to `target_mod`) is
    # seen, advance the anchor to `target_mod` so the target file's own
    # `test`/`bench` blocks — which carry no origin and now resolve to
    # the anchor — stay in the target bucket rather than leaking back
    # to the last core module. Core tests keep their module's
    # anchor; only the post-core target decls flip this.
    let next_anchor = if home == target_mod { target_mod } else { anchor1 }
    let acc1 = bucket_append(acc, home, d, [])
    partition_by_homes_walk(rest_d, target_mod, next_anchor, acc1)
  }
}

# Per-decl bucketing rule, given the running anchor module:
#   - DFn with an explicit `mo`: that module (anchor).
#   - DFn with `mo = None`: `target_mod` (target-authored fns).
#   - DType with `mo = Some(m)`: that module.
#   - DType with `mo = None`: `anchor` (untagged DType belongs
#     to the same physical file as the surrounding tagged DFns).
#   - DEffect with `mo = Some(m)`: that module; `mo = None`:
#     `target_mod` (a root-declared effect is target-authored).
#   - DUnit / DUse / DAxiom: `anchor` for the same "same-file" reason.
#   - DTest / DBench / DCheck: `target_mod` (these never live
#     inside a core file).
#   - Wrappers (DAttribPure, DDerive, DUnstable, DImpl): recurse
#     into the inner decl.
fn decide_partition_home(d: Decl, target_mod: String,
                            anchor: String) : String = match d {
  DFn(_, _, _, _, _, _, _, _, _, mo) -> match mo {
    Some(m) -> m
    None    -> target_mod
  }
  DType(_, _, _, _, _, _, mo, _) -> match mo {
    Some(m) -> m
    None    -> anchor
  }
  DEffect(_, _, _, _, _, _, _, mo) -> match mo {
    Some(m) -> m
    None    -> target_mod
  }
  DUnit(_, _, _, _, _, _)             -> anchor
  DUse(_, _, _)                        -> anchor
  DUseKind(_, _, _)                    -> anchor
  DAxiom(_, _, _, _, _, _, _, _, _, _) -> anchor
  # a `test`/`bench`/`check` block lives in the same
  # physical .kai file as the surrounding decls, so it belongs to the
  # running `anchor` module — NOT unconditionally `target_mod`. The
  # old `-> target_mod` rule assumed tests never appear in a core
  # module file; when a core module IS the intrinsic-test target it
  # sent core/char.kai's test blocks to the target bucket, *creating*
  # that bucket before tuple/option/list contributed their records, so
  # the target was typed too early and could not see `Pair`/`Option`.
  # With the anchor seeded to `target_mod` once a genuine target decl
  # is seen (see `partition_by_homes_walk`), a target-authored test
  # still resolves to `target_mod` while a core test stays with its module.
  DTest(_, _, _, _)                    -> anchor
  DBench(_, _, _, _)                   -> anchor
  DCheck(_, _, _, _, _)                -> anchor
  DDerive(_, inner, _, _)              -> decide_partition_home(inner, target_mod, anchor)
  DUnstable(inner, _, _)               -> decide_partition_home(inner, target_mod, anchor)
  DProtoLaws(_, inner, _, _)           -> decide_partition_home(inner, target_mod, anchor)
  DImplAxiom(_, inner, _, _)           -> decide_partition_home(inner, target_mod, anchor)
  DConstructor(inner, _, _)            -> decide_partition_home(inner, target_mod, anchor)
  DImpl(_, _, _, sub, _, _)            -> match sub {
    [] -> anchor
    [m, ..._] -> decide_partition_home(m, target_mod, anchor)
  }
  _ -> anchor
}

# Like `decl_explicit_home` but specialised for the partition
# walker: returns `Some(m)` when this decl declares its OWN home,
# `None` when it inherits from the running anchor. DType and DEffect
# count as explicit because the `tag_*` passes write their `mo`;
# DUnit does not (it carries no `module_origin` field).
fn decl_explicit_module_origin(d: Decl) : Option[String] = match d {
  DFn(_, _, _, _, _, _, _, _, _, mo) -> mo
  DType(_, _, _, _, _, _, mo, _)        -> mo
  DEffect(_, _, _, _, _, _, _, mo)   -> mo
  DDerive(_, inner, _, _)         -> decl_explicit_module_origin(inner)
  DUnstable(inner, _, _)          -> decl_explicit_module_origin(inner)
  DProtoLaws(_, inner, _, _)      -> decl_explicit_module_origin(inner)
  DImplAxiom(_, inner, _, _)      -> decl_explicit_module_origin(inner)
  DConstructor(inner, _, _)       -> decl_explicit_module_origin(inner)
  DImpl(_, _, _, sub, _, _)       -> match sub {
    [] -> None
    [m, ..._] -> decl_explicit_module_origin(m)
  }
  _ -> None
}

fn opt_str_is_some(o: Option[String]) : Bool = match o {
  None -> false
  Some(_) -> true
}

# Decide a decl's home module from its own `module_origin` field,
# falling back to `target_mod` when the field is absent. The
# DAttribPure / DDerive / DUnstable wrappers delegate to the inner
# decl; DImpl peeks at its first method (the post-`lower_protocols`
# stream never contains DImpl, but we cover it defensively).
fn partition_home_for(d: Decl, target_mod: String) : String = match d {
  DFn(_, _, _, _, _, _, _, _, _, mo) -> home_or_target(mo, target_mod)
  DType(_, _, _, _, _, _, mo, _)        -> home_or_target(mo, target_mod)
  DDerive(_, inner, _, _)         -> partition_home_for(inner, target_mod)
  DUnstable(inner, _, _)          -> partition_home_for(inner, target_mod)
  DProtoLaws(_, inner, _, _)      -> partition_home_for(inner, target_mod)
  DImplAxiom(_, inner, _, _)      -> partition_home_for(inner, target_mod)
  DConstructor(inner, _, _)       -> partition_home_for(inner, target_mod)
  DImpl(_, _, _, sub, _, _)       -> match sub {
    [] -> target_mod
    [m, ..._] -> partition_home_for(m, target_mod)
  }
  _ -> target_mod
}

fn home_or_target(mo: Option[String], target_mod: String) : String = match mo {
  Some(m) -> m
  None    -> target_mod
}

# Append `d` to the bucket whose `name = Some(home)`. Creates the
# bucket at the END of `acc` (preserves first-appearance order)
# when no bucket for `home` exists yet. `done` accumulates the
# already-walked head of `acc` so the in-progress buckets stay in
# order without reversing twice.
fn bucket_append(acc: [ModuleDecls], home: String, d: Decl,
                    done: [ModuleDecls]) : [ModuleDecls] = match acc {
  [] -> list_append(list_reverse(done),
          [ModuleDecls { name: Some(home), decls: [d] }])
  [m, ...rest] -> {
    let mname = match m.name { None -> "" Some(s) -> s }
    if mname == home {
      let updated = ModuleDecls { name: m.name,
                                    decls: list_append(m.decls, [d]) }
      list_append(list_reverse(done), [updated, ...rest])
    } else {
      bucket_append(rest, home, d, [m, ...done])
    }
  }
}

# variant accepting a snapshot of the protocol impl table
# from `lower_protocols`. `synth_binop` consults it to gate dispatch
# on impl existence (heterogeneous `Real + Complex` etc.).
#
# thin wrapper around `typecheck_program` over a
# single-module input. Every legacy caller of
# infer_program_with_protos goes through here; the per-module fold
# entry point is `typecheck_program`.
# Kind theories: recomputed from the decl stream so the library/LSP
# entry points get the theory dispatch too; the driver's main path
# passes its pre-strip capture through the cached variant instead
# (kind decls are stripped before the typer there).
fn infer_program_with_protos(file: String, decls: [Decl], verbose: Bool,
                               proto_impls: [ProtoImplReg]) : TypedProgram / Console + File =
  infer_program_with_protos_cached(file, decls, verbose, proto_impls, [],
                                   atomic_kind_theories(decls))

# variant accepting the per-compile head-owner cache. The
# `compile_source` driver builds the cache from the post-`expand_imports`
# decl stream + module table once per invocation and passes it here so
# `synth_pipe_dispatch` can resolve any in-scope `pub type T` against
# its declaring module without a hardcoded compiler table.
#[doc("infer: infer a program with protocol-impl registry + per-compile cache hooks.")]
pub fn infer_program_with_protos_cached(file: String, decls: [Decl], verbose: Bool,
                                       proto_impls: [ProtoImplReg],
                                       head_owners: [HeadOwnerEntry],
                                       kind_theories: [KindTheory]) : TypedProgram / Console + File {


  # Hanga Roa modular typecheck: partition the post-cascade decl
  # stream by home module so each core is typed against the
  # inherited delta of the modules loaded before it, and the target
  # file is typed last. Without this partition, every module sees
  # every other module's records (and sums), so a user `type Pair =
  # ...` in the target file leaks into the typecheck of `core/list.kai`
  # and clobbers `tuple.Pair[a, b]`. The fold is byte-identical to
  # the pre-refactor flatten-and-call path when there is only one
  # bucket — which is the case for legacy callers passing a target-
  # only decl stream.
  let target_mod = inf_core_module_name(file)
  let mods0 = partition_decls_by_home(decls, target_mod)
  let mods = match mods0 {
    []           -> [ModuleDecls { name: None, decls: decls }]
    [_]          -> [ModuleDecls { name: None, decls: decls }]
    _            -> mods0
  }
  typecheck_program_with_head_owners(file, mods, proto_impls, head_owners, kind_theories, verbose)
}

#[doc("infer: --infer dump of inferred top-level signatures.")]
pub fn dump_infer(file: String, decls: [Decl]) : Int / Console + File {


  let r = infer_program(file, decls, true)
  r.errs
}

# ---- `--dump-typed`: typed AST pretty-printer ----
#
# Runs inference and walks the resulting annotated tree, printing a
# compact `<kind> : <ty>` line per Expr node. The point of the flag
# is diagnostic — every Expr node the walker returned is expected to
# carry a `Some(ty)`, so a `?` in the output indicates a missed
# rebuild path.

fn ty_tag(e: Expr) : String {
  match e.ty {
    Some(t) -> string_concat(" : ", inf_ty_to_string(t))
    None    -> " : ?"
  }
}

fn tag_of_kind(k: ExprKind) : String {
  match k {
    EInt(n)        -> concat_all(["int ", int_to_string(n)])
    EFixed(span, _)   -> concat_all(["fixed ", span])
    EReal(_, _)       -> "real"
    EIntLit(_)        -> "real"
    EDecimalLit(_)    -> "real"
    EBool(b)       -> if b { "bool true" } else { "bool false" }
    EChar(_)       -> "char"
    EStr(_, _)     -> "string"
    EUnit          -> "unit"
    EVar(nm)       -> concat_all(["ident ", nm])
    EUnder         -> "_"
    EPlaceholder   -> "."
    ECall(_, _)    -> "call"
    EField(_, nm)  -> concat_all(["field .", nm])
    EIndex(_, _)   -> "index"
    EBinop(op, _, _) -> concat_all(["binop ", op])
    EUnop(op, _)   -> concat_all(["unop ", op])
    EIf(_, _, _)   -> "if"
    EMatch(_, _)   -> "match"
    ELambda(_, _)  -> "lambda"
    ERecordLit(nm, _) -> concat_all(["record ", nm])
    EList(_)       -> "list"
    ERange(_, _, _) -> "range"
    EBlock(_, _)   -> "block"
    EPipe(_, _)    -> "pipe"
    EMapPipe(_, _) -> "map_pipe"
    EFlatMapPipe(_, _) -> "flat_map_pipe"
    EFilterPipe(_, _) -> "filter_pipe"
    EHole(nm_opt)  -> match nm_opt {
      Some(nm) -> concat_all(["hole ?", nm])
      None     -> "hole ?"
    }
    ETodo(msg)     -> concat_all(["todo \"", msg, "\""])
    EExternBody(over) -> concat_all(["extern-body \"", over, "\""])
    EBang(_)       -> "bang"
    EHandle(_, eff_name, _, _, _, _, _) -> concat_all(["handle ", eff_name])
    ELitUnit(_, u) -> concat_all(["lit-unit <", inf_unit_canon_display(u), ">"])
    EVariantsOf(ty, _) -> concat_all(["variants-of ", inf_type_expr_display(ty)])
    # qualified module call dump label.
    EModCall(m, fname) -> concat_all(["modcall ", m, ".", fname])
    EIntrinsic(name, _) -> concat_all(["intrinsic $", name])
  }
}

fn dump_typed_expr(e: Expr, depth: Int) : Unit / Console {

  inf_emit_line(depth, concat_all([tag_of_kind(e.kind), ty_tag(e)]))
  dump_typed_subexprs(e.kind, depth + 1)
}

# Note: stage 1's capture analyser doesn't recognise pattern bindings
# inside a lambda body as locals, which turns a seemingly-innocent
# `each((a) => match a { Arm(_, g, body) -> ... })` into "capture
# g, body from outer scope" and fails to compile. Every iteration in
# this dumper therefore uses explicit recursive helpers with pattern
# matching at top level rather than inline lambdas.

fn dump_typed_exprs(xs: [Expr], depth: Int) : Unit / Console {

  match xs {
    [] -> ()
    [x, ...rest] -> { dump_typed_expr(x, depth) dump_typed_exprs(rest, depth) }
  }
}

fn dump_typed_arms(arms: [Arm], depth: Int) : Unit / Console {

  match arms {
    [] -> ()
    [a, ...rest] -> {
      match a {
        Arm(_, g, body) -> {
          match g {
            Some(gx) -> dump_typed_expr(gx, depth)
            None -> ()
          }
          dump_typed_expr(body, depth)
        }
      }
      dump_typed_arms(rest, depth)
    }
  }
}

fn dump_typed_fis(fis: [FieldInit], depth: Int) : Unit / Console {

  match fis {
    [] -> ()
    [fi, ...rest] -> {
      match fi { FI(_, v) -> dump_typed_expr(v, depth) }
      dump_typed_fis(rest, depth)
    }
  }
}

fn dump_typed_elems(els: [ListElem], depth: Int) : Unit / Console {

  match els {
    [] -> ()
    [el, ...rest] -> {
      match el {
        ElPlain(x)  -> dump_typed_expr(x, depth)
        ElSpread(x) -> dump_typed_expr(x, depth)
      }
      dump_typed_elems(rest, depth)
    }
  }
}

fn dump_typed_stmts(ss: [Stmt], depth: Int) : Unit / Console {

  match ss {
    [] -> ()
    [s, ...rest] -> { dump_typed_stmt(s, depth) dump_typed_stmts(rest, depth) }
  }
}

fn dump_typed_subexprs(k: ExprKind, depth: Int) : Unit / Console {

  match k {
    ECall(callee, xs) -> {
      dump_typed_expr(callee, depth)
      dump_typed_exprs(xs, depth)
    }
    EField(base, _)   -> dump_typed_expr(base, depth)
    EIndex(a, b)      -> { dump_typed_expr(a, depth) dump_typed_expr(b, depth) }
    EBinop(_, a, b)   -> { dump_typed_expr(a, depth) dump_typed_expr(b, depth) }
    EUnop(_, x)       -> dump_typed_expr(x, depth)
    EIf(c, a, eo)     -> {
      dump_typed_expr(c, depth)
      dump_typed_expr(a, depth)
      match eo { Some(b) -> dump_typed_expr(b, depth) None -> () }
    }
    EMatch(scr, arms) -> {
      dump_typed_expr(scr, depth)
      dump_typed_arms(arms, depth)
    }
    ELambda(_, body)  -> dump_typed_expr(body, depth)
    ERecordLit(_, fis) -> dump_typed_fis(fis, depth)
    EList(els) -> dump_typed_elems(els, depth)
    ERange(a, b, so) -> {
      dump_typed_expr(a, depth)
      dump_typed_expr(b, depth)
      match so { Some(s) -> dump_typed_expr(s, depth) None -> () }
    }
    EBlock(ss, tail) -> {
      dump_typed_stmts(ss, depth)
      match tail { Some(t) -> dump_typed_expr(t, depth) None -> () }
    }
    EPipe(a, b) -> { dump_typed_expr(a, depth) dump_typed_expr(b, depth) }
    EMapPipe(a, b) -> { dump_typed_expr(a, depth) dump_typed_expr(b, depth) }
    EFlatMapPipe(a, b) -> { dump_typed_expr(a, depth) dump_typed_expr(b, depth) }
    EFilterPipe(a, b) -> { dump_typed_expr(a, depth) dump_typed_expr(b, depth) }
    EBang(inner) -> dump_typed_expr(inner, depth)
    _ -> ()
  }
}

fn dump_typed_stmt(s: Stmt, depth: Int) : Unit / Console {

  match s {
    SLet(_, _, rhs)  -> { inf_emit_line(depth, "let") dump_typed_expr(rhs, depth + 1) }
    SAssert(c, mo)   -> {
      inf_emit_line(depth, "assert")
      dump_typed_expr(c, depth + 1)
      match mo { Some(m) -> dump_typed_expr(m, depth + 1) None -> () }
    }
    SExprStmt(ex)    -> dump_typed_expr(ex, depth)
    SIndexAssign(b, i, v, _, _) -> {
      inf_emit_line(depth, "index-assign")
      dump_typed_expr(b, depth + 1)
      dump_typed_expr(i, depth + 1)
      dump_typed_expr(v, depth + 1)
    }
    SVar(n, _, rhs, _, _) -> {
      inf_emit_line(depth, "var #{n}")
      dump_typed_expr(rhs, depth + 1)
    }
    SUse(n, _, _) -> inf_emit_line(depth, "use #{n}")
  }
}

fn dump_typed_decl(d: Decl) : Unit / Console {
  match d {
    # Hanga Roa: with core auto-loaded, `all_decls` carries both the
    # root file and the entire core set. Only dump decls authored in
    # the root file (module_origin = None); core / imported modules
    # have `Some(mod)`. This keeps the --dump-typed output focused on
    # what the user actually wrote — the same scope the legacy
    # behaviour gave before core became implicit.
    DFn(_, nm, _, _, _, _, body, line, col, mo) -> match mo {
      None -> {
        print("fn #{nm} @#{int_to_string(line)}:#{int_to_string(col)}")
        dump_typed_expr(body, 1)
      }
      Some(_) -> ()
    }
    _ -> ()
  }
}

#[doc("infer: --dump-typed dump of the fully typed AST.")]
pub fn dump_typed(file: String, decls: [Decl]) : Int / Console + File {

  let r = infer_program(file, decls, false)
  dump_typed_loop(r.decls)
  r.errs
}

fn dump_typed_loop(ds: [Decl]) : Unit / Console {
  match ds {
    [] -> ()
    [d, ...rest] -> { dump_typed_decl(d) dump_typed_loop(rest) }
  }
}

# The independence-oracle dump: same machinery as dump_typed, but the
# predicate is inverted — only core / imported decls (module_origin =
# Some) are printed, the root file (None) is hidden. Diffing this dump
# across two runs that share the same core but differ only in the user
# file proves whether the user contaminated core's typed AST.
fn dump_typed_core_decl(d: Decl) : Unit / Console {
  match d {
    DFn(_, nm, _, _, _, _, body, line, col, mo) -> match mo {
      Some(m) -> {
        print("fn #{m}.#{nm} @#{int_to_string(line)}:#{int_to_string(col)}")
        dump_typed_expr(body, 1)
      }
      None -> ()
    }
    _ -> ()
  }
}

#[doc("infer: --dump-typed-core dump of the typed AST of core / imported modules only (the independence oracle's probe).")]
pub fn dump_typed_core(file: String, decls: [Decl]) : Int / Console + File {

  let r = infer_program(file, decls, false)
  dump_typed_core_loop(r.decls)
  r.errs
}

fn dump_typed_core_loop(ds: [Decl]) : Unit / Console {
  match ds {
    [] -> ()
    [d, ...rest] -> { dump_typed_core_decl(d) dump_typed_core_loop(rest) }
  }
}


# ====================================================================
# L7 — typed-AST diagnostic dumps (main.kai 33266-34037; L6 TCO at
# 32115-33265 stays in main with the emit_c lane)
# ====================================================================

fn dump_last_use_for_param(p: Param, uses: [Use]) : Unit / Console {
  let lu = inf_last_use_for(p.pname, uses)
  match lu {
    LUAt(nm, ln, cl) -> print("  param #{nm}: last-use at #{int_to_string(ln)}:#{int_to_string(cl)}")
    LUBlocked(nm)    -> print("  param #{nm}: blocked by closure capture")
    LUUnused(nm)     -> print("  param #{nm}: never used")
  }
}

fn dump_last_use_for_decl(d: Decl) : Unit / Console {
  match d {
    DFn(_, nm, _, params, _, _, body, ln, _, _) -> {
      print("fn #{nm}@#{int_to_string(ln)}:")
      let uses = inf_scan_uses_expr(body, false)
      params |> each((p) => dump_last_use_for_param(p, uses))
    }
    _ -> {}
  }
}

#[doc("infer: --dump-last-use Perceus last-use diagnostic over typed decls.")]
pub fn dump_last_use(file: String, decls: [Decl]) : Int / Console + File {


  let r = infer_program(file, decls, false)
  r.decls |> each(dump_last_use_for_decl)
  r.errs
}

# dump per-fn body intervals. Runs the typer to anchor
# every Expr's `.ty`, then walks each user-defined DFn's body with
# the interval propagator and prints the inferred range. Useful for
# pinning the lattice's behaviour in fixtures before the unifier
# reshape consumes it.
#[doc("infer: --dump-intervals refinement-interval dump.")]
pub fn dump_intervals(file: String, decls: [Decl]) : Int / Console + File {

  let r = infer_program(file, decls, false)
  # Hanga Roa: core auto-load surfaces every stdlib DFn alongside the
  # target file's. The dump's pre-Hanga shape pinned one line per
  # target-file fn; without the filter, the dump explodes to ~320
  # lines mixing core helpers with the target. Keep only decls whose
  # module-origin is `None` — the root file's own declarations.
  r.decls |> each(dump_intervals_for_decl)
  r.errs
}

fn dump_intervals_for_decl(d: Decl) : Unit / Console = match d {
  DFn(_, name, _, _, _, _, _, _, _, mo) -> match mo {
    None    -> {
      let iv = ival_of_decl(d)
      print("#{name}: #{ival_show(iv)}")
    }
    Some(_) -> ()
  }
  _ -> ()
}

# ---- `--holes`: typed-hole reports ----
#
# For each `?` / `?name` in the program, print the expected type
# (recovered from the final substitution) and the bindings visible
# at that point. Candidate synthesis — what the doc calls "a bounded
# enumeration of fillable expressions" — lands in a later milestone;
# this pass covers the "stop, record, keep going" half.
#
# Output mirrors the example in docs/typed-holes.md closely.

fn dump_scope_entry(te: TyEntry) : Unit / Console =
  print("    #{te.name} : #{scheme_to_string(te.scheme)}")

fn dump_hole_candidate(c: String) : Unit / Console =
  print("    #{c}")

# The default report lists only the hole's LOCAL bindings (params +
# lets); the surrounding top-level scope — hundreds of stdlib entries
# — is summarised as a count and dumped only under `--holes-scope`.
fn dump_hole_report(file: String, rh: ResolvedHole, core_len: Int,
                    toplevel_len: Int, full: Bool) : Unit / Console {
  match rh {
    RH(kind, line, col, ty, scope, env_fresh) -> {
      let label = hole_kind_label(kind)
      let user_scope = drop_last_entries(scope, core_len)
      let shown = if full { user_scope }
                  else { drop_last_entries(scope, toplevel_len) }
      let elided = list_length(user_scope) - list_length(shown)
      let cands = synth_candidates(scope, ty, env_fresh)
      print("#{file}:#{int_to_string(line)}:#{int_to_string(col)}: type hole #{label}")
      print("")
      print("  expected: #{inf_ty_to_string(ty)}")
      print("")
      let scope_label = if full { "  in scope:" } else { "  in scope (local):" }
      match shown {
        [] -> { print(if full { "  in scope: (empty)" } else { "  in scope (local): (empty)" }) print("") }
        _  -> {
          print(scope_label)
          shown |> each(dump_scope_entry)
          print("")
        }
      }
      match cands {
        [] -> ()
        _  -> {
          print("  candidates that fit:")
          cands |> each(dump_hole_candidate)
          print("")
        }
      }
      match elided {
        0 -> ()
        _ -> {
          print("  #{int_to_string(elided)} more bindings in scope (--holes-scope lists them)")
          print("")
        }
      }
    }
  }
}

# Human-readable label for a hole site. `?`, `?name`, or
# `todo!("msg")`. Used by `--holes` and `--strict-holes`.
fn hole_kind_label(k: HoleKind) : String {
  match k {
    HKHole(nm_opt) -> match nm_opt {
      Some(nm) -> cat2("?", nm)
      None     -> "?"
    }
    HKTodo(msg) -> concat_all(["todo!(\"", msg, "\")"])
  }
}

fn dump_holes_loop(file: String, hs: [ResolvedHole], core_len: Int,
                   toplevel_len: Int, full: Bool) : Unit / Console {

  match hs {
    [] -> ()
    [h, ...rest] -> {
      dump_hole_report(file, h, core_len, toplevel_len, full)
      dump_holes_loop(file, rest, core_len, toplevel_len, full)
    }
  }
}

# ---- bounded candidate synthesis ----
#
# Given a hole's expected type `E` and the visible scope, enumerate a
# small set of expressions the user (or an LLM) might plug in. The
# doc calls this a "bounded enumeration": we do not explore beyond a
# single application, and we never nest candidates. Two classes:
#   1. direct: `name` where `name : T` and `T ~= E`.
#   2. application: `f(x1, .., xn)` where `f : (T1..Tn) -> R`, `R ~= E`,
#      and each `Ti` unifies with some in-scope name's type.
# Entries whose *immediate* return type is a bare polymorphic var (e.g.
# `panic`, `exit`) are rejected from class 2 — they'd match any hole
# and drown useful suggestions. A shared `env_fresh` counter keeps
# each instantiation's fresh TyVars disjoint from the hole's own
# residual vars.

#[doc("infer: `list_has_int` — typer entry point invoked by the driver.")]
pub fn list_has_int(xs: [Int], n: Int) : Bool {
  match xs {
    [] -> false
    [h, ...rest] -> if h == n { true } else { list_has_int(rest, n) }
  }
}

# Reject entries whose return type after stripping TyFnT is a bare
# bound variable — the scheme accepts anything, so suggesting it is
# noise. Accept structural return types (TyCon, TyList, primitives),
# which still constrain the substitution meaningfully.
fn synth_return_structural(sc: TyScheme) : Bool {
  match sc {
    Scheme(vars, _, _, _, ty) -> match ty {
      TyFnT(_, ret, _) -> match ret {
        TyVarT(v) -> not list_has_int(vars, v)
        _         -> true
      }
      TyVarT(v) -> not list_has_int(vars, v)
      _         -> true
    }
  }
}

fn list_has_string(xs: [String], s: String) : Bool {
  match xs {
    [] -> false
    [h, ...rest] -> if h == s { true } else { list_has_string(rest, s) }
  }
}

# Walk scope looking for the first entry whose instantiated type
# unifies with `want`. Returns the name on hit, None otherwise.
# `avoid` prevents obvious circular fills like `f(f)` when f itself
# is the candidate head.
type ArgMatch = { name: String, sub: Subst, fresh: Int }

fn synth_find_arg(scope: [TyEntry], want: Ty, fresh: Int, avoid: [String], sub: Subst) : Option[ArgMatch] / Mutable {
  match scope {
    [] -> None
    [te, ...rest] -> {
      if list_has_string(avoid, te.name) or (not synth_return_structural(te.scheme)) {
        synth_find_arg(rest, want, fresh, avoid, sub)
      } else {
        let inst = instantiate(TyEnv { entries: [], fresh: fresh, unions: [], constructors: [], head_owners: [], root_fns: [], row_kind: [], index: idx_empty() }, te.scheme)
        match unify(inst.ty, want, sub) {
          Some(sub1) -> Some(ArgMatch { name: te.name, sub: sub1, fresh: inst.env.fresh })
          None       -> synth_find_arg(rest, want, fresh, avoid, sub)
        }
      }
    }
  }
}

type ArgsMatch = { names: [String], sub: Subst, fresh: Int }

fn synth_find_args(scope: [TyEntry], params: [Ty], fresh: Int, avoid: [String],
                   sub: Subst, acc: [String]) : Option[ArgsMatch] / Mutable {
  match params {
    [] -> Some(ArgsMatch { names: list_reverse(acc), sub: sub, fresh: fresh })
    [p, ...rest] -> {
      let p_now = apply_ty(sub, p)
      match synth_find_arg(scope, p_now, fresh, avoid, sub) {
        Some(am) -> synth_find_args(scope, rest, am.fresh, avoid, am.sub, [am.name, ...acc])
        None     -> None
      }
    }
  }
}

# Try entry `te` as a direct match or a 1-level application against
# `expected`. Returns rendered candidate text or None.
fn synth_try_entry(all_scope: [TyEntry], te: TyEntry, expected: Ty, fresh: Int) : Option[String] / Mutable {
  let inst = instantiate(TyEnv { entries: [], fresh: fresh, unions: [], constructors: [], head_owners: [], root_fns: [], row_kind: [], index: idx_empty() }, te.scheme)
  match unify(inst.ty, expected, subst_empty()) {
    Some(_) -> Some(te.name)
    None    -> match inst.ty {
      TyFnT(ps, r, _) -> {
        if synth_return_structural(te.scheme) {
          match unify(r, expected, subst_empty()) {
            None     -> None
            Some(s0) -> match synth_find_args(all_scope, ps, inst.env.fresh, [te.name], s0, []) {
              None    -> None
              Some(m) -> Some(concat_all([te.name, "(", inf_join_with(m.names, ", "), ")"]))
            }
          }
        } else { None }
      }
      _ -> None
    }
  }
}

fn synth_candidates_loop(all: [TyEntry], cur: [TyEntry], expected: Ty, fresh: Int,
                         acc: [String], max: Int) : [String] {
  if list_length(acc) >= max { list_reverse(acc) }
  else { match cur {
    [] -> list_reverse(acc)
    [te, ...rest] -> match synth_try_entry(all, te, expected, fresh) {
      Some(expr) -> synth_candidates_loop(all, rest, expected, fresh, [expr, ...acc], max)
      None       -> synth_candidates_loop(all, rest, expected, fresh, acc, max)
    }
  } }
}

fn synth_candidates(scope: [TyEntry], expected: Ty, fresh: Int) : [String] =
  synth_candidates_loop(scope, scope, expected, fresh, [], 8)

#[doc("infer: --holes human-readable typed-hole report over the build front-end's typed program. `full` lists every reachable binding instead of the hole's locals.")]
pub fn dump_holes(file: String, tp: TypedProgram, full: Bool) : Int / Console + File {

  match tp.holes {
    [] -> { print("(no typed holes)") tp.errs }
    _  -> { dump_holes_loop(file, tp.holes, tp.core_len, tp.toplevel_len, full) tp.errs }
  }
}

# ---- `--holes-json`: machine-readable hole reports ----
#
# Emits a single JSON array, stable schema per docs/typed-holes.md.
# Each element carries {file, line, col, name, expected_type, in_scope,
# candidates, scope_elided}. By default `in_scope` lists the hole's
# LOCAL bindings (params + lets) and `scope_elided` counts the
# reachable bindings not listed; `--holes-json-scope` lists everything
# (core included) with `scope_elided: 0`.

# the JSON string escaper moved to compiler/util.kai
# (json_escape / json_quote) so doc_attr.kai can share it without
# importing the typer. json_str stays as the typer-side alias.
#[doc("infer: `json_str` — typer entry point invoked by the driver.")]
pub fn json_str(s: String) : String = json_quote(s)

#[doc("infer: `json_null` — typer entry point invoked by the driver.")]
pub fn json_null() : String = "null"

fn json_scope_entry(te: TyEntry) : String =
  concat_all([
    "{\"name\": ", json_str(te.name),
    ", \"type\": ", json_str(scheme_to_string(te.scheme)), "}"
  ])

fn json_scope_entries(es: [TyEntry]) : String =
  concat_all(["[", inf_join_with(map(es, json_scope_entry), ", "), "]"])

fn json_candidate(expr: String) : String =
  concat_all(["{\"expr\": ", json_str(expr), ", \"kind\": \"synth\"}"])

fn json_candidates(cs: [String]) : String =
  concat_all(["[", inf_join_with(map(cs, json_candidate), ", "), "]"])

fn json_hole_report(file: String, doc_items: [DocItem], rh: ResolvedHole,
                    toplevel_len: Int, full: Bool) : String {
  match rh {
    RH(kind, line, col, ty, scope, env_fresh) -> {
      let kj = hole_kind_json(kind)
      let shown = if full { scope } else { drop_last_entries(scope, toplevel_len) }
      let elided = list_length(scope) - list_length(shown)
      let cands = synth_candidates(scope, ty, env_fresh)
      # the surrounding declaration's `#[doc(...)]` text,
      # resolved by source position against the root file's doc side
      # table. null when the surrounding decl is undocumented.
      let doc_field = match doc_for_line(doc_items, line) {
        Some(s) -> json_str(s)
        None    -> json_null()
      }
      concat_all([
        "{",
        "\"file\": ", json_str(file),
        ", \"line\": ", int_to_string(line),
        ", \"col\": ", int_to_string(col),
        ", \"kind\": ", kj.kind,
        ", \"name\": ", kj.name,
        ", \"message\": ", kj.message,
        ", \"expected_type\": ", json_str(inf_ty_to_string(ty)),
        ", \"in_scope\": ", json_scope_entries(shown),
        ", \"scope_elided\": ", int_to_string(elided),
        ", \"candidates\": ", json_candidates(cands),
        ", \"doc\": ", doc_field,
        "}"
      ])
    }
  }
}

# Triple of JSON fields derived from a HoleKind: the discriminator
# string, the optional `name` payload (only `?name` populates it),
# and the optional `message` payload (only `todo!(msg)` populates).
type HoleKindJson = { kind: String, name: String, message: String }

fn hole_kind_json(k: HoleKind) : HoleKindJson {
  match k {
    HKHole(nm_opt) -> {
      let nm_field = match nm_opt {
        Some(nm) -> json_str(nm)
        None     -> json_null()
      }
      HoleKindJson { kind: json_str("hole"), name: nm_field, message: json_null() }
    }
    HKTodo(msg) ->
      HoleKindJson { kind: json_str("todo"), name: json_null(), message: json_str(msg) }
  }
}

#[doc("infer: --holes-json structured typed-hole report over the build front-end's typed program. doc_items is the root file's doc side table; `full` lists every reachable binding instead of the hole's locals.")]
pub fn dump_holes_json(file: String, tp: TypedProgram, doc_items: [DocItem], full: Bool) : Int / Console + File {

  let body = inf_join_with(map(tp.holes, (h) => json_hole_report(file, doc_items, h, tp.toplevel_len, full)), ", ")
  print(concat_all(["[", body, "]"]))
  tp.errs
}

# ---- `--effects-json`: per-fn effect graph as data ----
#
# For each user-declared `DFn` in the typed AST, emit a JSON object
# capturing the effects performed by the body and the handlers
# installed within it. Effect detection is post-inference: the typed
# `EVar("Eff.op")` references inside the body name the effects;
# `EHandle` nodes name the handlers. Returns the inference's error
# count so a typer-rejected program still produces a non-zero exit.
#
# Schema (stable):
#   [{"fn": String, "line": Int, "col": Int,
#     "effects": [String],
#     "handlers_installed": [{"effect": String, "line": Int, "col": Int}]}]
#
# `effects` lists each *distinct* effect performed by the body in
# declaration order of first appearance (sorted lexicographically
# would also be fine — the schema does not promise an order, but
# stable across runs is the only invariant a consumer needs).
# Compiler-internal aliases like `__proto_show` are filtered out.

type EffUseAcc = { effs: [String], handlers: [EffHandle] }
type EffHandle = EH(String, Int, Int)

#[doc("infer: --effects-json structured effect-row report over the build front-end's typed program.")]
pub fn dump_effects_json(file: String, tp: TypedProgram) : Int / Console + File {

  let entries = effects_walk_decls(tp.decls, [])
  let body = inf_join_with(map(entries, effects_json_entry), ", ")
  print(concat_all(["[", body, "]"]))
  tp.errs
}

# ---- `--effect-holes-json`: typed effect-hole resolutions as data ----
#
# For each `?` or `?name` that appeared in a row tail position, emit
# what the inferencer resolved it to. Consumers (LLMs, IDEs, the
# author themselves) read this to know which effect row goes where
# the hole was written.
#
# Schema (stable):
#   [{
#     "file": String, "fn": String,
#     "line": Int, "col": Int,
#     "name": String | null,        # `?e` → "e"; bare `?` → null
#     "labels": [String],           # resolved effect labels (sorted)
#     "open": Bool,                 # true if the tail is still a free row var
#     "tail_var": String | null     # "?eN" id when open, else null
#   }]
#[doc("infer: structured effect-hole report over the build front-end's typed program.")]
pub fn dump_effect_holes_json(file: String, tp: TypedProgram) : Int / Console + File {

  let body = inf_join_with(map(tp.row_holes, (rh) => json_row_hole_report(file, rh)), ", ")
  print(concat_all(["[", body, "]"]))
  tp.errs
}

fn json_row_hole_report(file: String, rrh: ResolvedRowHole) : String {
  match rrh {
    RRH(nm_opt, line, col, fn_name, row, body_labels) -> {
      let name_field = match nm_opt {
        Some(n) -> json_str(n)
        None    -> json_null()
      }
      let label_strs = map(row.labels, (l) => json_str(l.eff))
      let labels_field = concat_all(["[", inf_join_with(label_strs, ", "), "]"])
      let body_strs = map(body_labels, json_str)
      let body_field = concat_all(["[", inf_join_with(body_strs, ", "), "]"])
      let open = match row.tail { Some(_) -> true None -> false }
      let tail_field = match row.tail {
        Some(v) -> json_str(concat_all(["?e", int_to_string(v)]))
        None    -> json_null()
      }
      concat_all([
        "{",
        "\"file\": ", json_str(file),
        ", \"fn\": ", json_str(fn_name),
        ", \"line\": ", int_to_string(line),
        ", \"col\": ", int_to_string(col),
        ", \"name\": ", name_field,
        ", \"labels\": ", labels_field,
        ", \"open\": ", if open { "true" } else { "false" },
        ", \"tail_var\": ", tail_field,
        ", \"body_row\": ", body_field,
        "}"
      ])
    }
  }
}

type EffEntry = { fn_name: String, line: Int, col: Int,
                  effs: [String], handlers: [EffHandle] }

fn effects_walk_decls(decls: [Decl], acc: [EffEntry]) : [EffEntry] {
  match decls {
    [] -> list_reverse(acc)
    [d, ...rest] -> match d {
      DFn(_, name, _, _, _, _, body, line, col, _) ->
        if effects_skip_internal(name) {
          effects_walk_decls(rest, acc)
        } else {
          let acc0 = EffUseAcc { effs: [], handlers: [] }
          let used = effects_collect_expr(body, acc0)
          let entry = EffEntry { fn_name: name, line: line, col: col,
                                  effs: used.effs, handlers: used.handlers }
          effects_walk_decls(rest, [entry, ...acc])
        }
      _ -> effects_walk_decls(rest, acc)
    }
  }
}

# Skip compiler-generated names (protocol dispatchers, impl bodies,
# auto-derived ops). They all start with `__`; the user did not
# write them and an LLM consuming the JSON does not care about
# them.
fn effects_skip_internal(name: String) : Bool =
  effects_starts_with_underscore_pair(name)

fn effects_starts_with_underscore_pair(name: String) : Bool {
  match char_at(name, 0) {
    Some(c0) -> if c0 == '_' {
      match char_at(name, 1) {
        Some(c1) -> c1 == '_'
        None     -> false
      }
    } else { false }
    None -> false
  }
}

# Walker over typed Expr — collects (a) every effect whose op is
# called via `EVar("Eff.op")` (post-desugar_op_calls form), and
# (b) every EHandle's effect+location. Recurse via inf_map_expr_kind
# for the structural cases; explicit cases for EVar (the source of
# truth) and EHandle (handler installation).
fn effects_collect_expr(e: Expr, acc: EffUseAcc) : EffUseAcc =
  effects_collect_kind(e.kind, e.line, e.col, acc)

fn effects_collect_kind(k: ExprKind, line: Int, col: Int,
                         acc: EffUseAcc) : EffUseAcc {
  match k {
    EVar(name) -> {
      # `Eff.op` qualified names — desugar_op_calls flattens
      # EField(EVar(eff), op) into EVar("eff.op") before this point.
      match effects_split_qualified(name) {
        Some(eff) -> EffUseAcc {
          effs: effects_add_unique(eff, acc.effs),
          handlers: acc.handlers
        }
        None -> acc
      }
    }
    EHandle(body, eff_name, _, init_opt, _, clauses, ret_opt) -> {
      let h = EH(eff_name, line, col)
      let acc1 = EffUseAcc { effs: acc.effs,
                              handlers: [h, ...acc.handlers] }
      let acc2 = effects_collect_expr(body, acc1)
      let acc3 = match init_opt {
        Some(e2) -> effects_collect_expr(e2, acc2)
        None     -> acc2
      }
      let acc4 = effects_collect_clauses(clauses, acc3)
      effects_collect_opt_return(ret_opt, acc4)
    }
    EBlock(stmts, tail) -> {
      let a1 = effects_collect_stmts(stmts, acc)
      match tail {
        Some(t) -> effects_collect_expr(t, a1)
        None    -> a1
      }
    }
    EMatch(scr, arms) -> {
      let a1 = effects_collect_expr(scr, acc)
      effects_collect_arms(arms, a1)
    }
    ECall(callee, args_) -> {
      let a1 = effects_collect_expr(callee, acc)
      effects_collect_exprs(args_, a1)
    }
    EField(base, _) -> effects_collect_expr(base, acc)
    EIndex(a, b) -> {
      let a1 = effects_collect_expr(a, acc)
      effects_collect_expr(b, a1)
    }
    EBinop(_, a, b) -> {
      let a1 = effects_collect_expr(a, acc)
      effects_collect_expr(b, a1)
    }
    EUnop(_, x) -> effects_collect_expr(x, acc)
    EIf(c, t_, eo) -> {
      let a1 = effects_collect_expr(c, acc)
      let a2 = effects_collect_expr(t_, a1)
      match eo {
        Some(e2) -> effects_collect_expr(e2, a2)
        None     -> a2
      }
    }
    ELambda(_, b) -> effects_collect_expr(b, acc)
    ERecordLit(_, fields) -> effects_collect_fields(fields, acc)
    EList(elems) -> effects_collect_elems(elems, acc)
    ERange(a, b, opt_step) -> {
      let a1 = effects_collect_expr(a, acc)
      let a2 = effects_collect_expr(b, a1)
      match opt_step {
        Some(s) -> effects_collect_expr(s, a2)
        None    -> a2
      }
    }
    EPipe(a, b) -> {
      let a1 = effects_collect_expr(a, acc)
      effects_collect_expr(b, a1)
    }
    EMapPipe(a, b) -> {
      let a1 = effects_collect_expr(a, acc)
      effects_collect_expr(b, a1)
    }
    EFlatMapPipe(a, b) -> {
      let a1 = effects_collect_expr(a, acc)
      effects_collect_expr(b, a1)
    }
    EFilterPipe(a, b) -> {
      let a1 = effects_collect_expr(a, acc)
      effects_collect_expr(b, a1)
    }
    ELitUnit(inner, _) -> effects_collect_expr(inner, acc)
    EBang(inner) -> effects_collect_expr(inner, acc)
    _ -> acc
  }
}

fn effects_collect_exprs(es: [Expr], acc: EffUseAcc) : EffUseAcc {
  match es {
    [] -> acc
    [h, ...rest] -> effects_collect_exprs(rest, effects_collect_expr(h, acc))
  }
}

fn effects_collect_stmts(ss: [Stmt], acc: EffUseAcc) : EffUseAcc {
  match ss {
    [] -> acc
    [s, ...rest] -> match s {
      SLet(_, _, rhs) -> effects_collect_stmts(rest, effects_collect_expr(rhs, acc))
      SAssert(c, m) -> {
        let a1 = effects_collect_expr(c, acc)
        let a2 = match m { Some(mx) -> effects_collect_expr(mx, a1) None -> a1 }
        effects_collect_stmts(rest, a2)
      }
      SExprStmt(x) -> effects_collect_stmts(rest, effects_collect_expr(x, acc))
      SIndexAssign(b, i, v, _, _) -> {
        let a1 = effects_collect_expr(b, acc)
        let a2 = effects_collect_expr(i, a1)
        let a3 = effects_collect_expr(v, a2)
        effects_collect_stmts(rest, a3)
      }
      SVar(_, _, rhs, _, _) -> effects_collect_stmts(rest, effects_collect_expr(rhs, acc))
      SUse(_, _, _) -> effects_collect_stmts(rest, acc)
    }
  }
}

fn effects_collect_arms(arms: [Arm], acc: EffUseAcc) : EffUseAcc {
  match arms {
    [] -> acc
    [a, ...rest] -> match a {
      Arm(_, g, b) -> {
        let a1 = match g { Some(gg) -> effects_collect_expr(gg, acc) None -> acc }
        let a2 = effects_collect_expr(b, a1)
        effects_collect_arms(rest, a2)
      }
    }
  }
}

fn effects_collect_fields(fs: [FieldInit], acc: EffUseAcc) : EffUseAcc {
  match fs {
    [] -> acc
    [f, ...rest] -> match f {
      FI(_, v) -> effects_collect_fields(rest, effects_collect_expr(v, acc))
    }
  }
}

fn effects_collect_elems(els: [ListElem], acc: EffUseAcc) : EffUseAcc {
  match els {
    [] -> acc
    [el, ...rest] -> match el {
      ElPlain(x)  -> effects_collect_elems(rest, effects_collect_expr(x, acc))
      ElSpread(x) -> effects_collect_elems(rest, effects_collect_expr(x, acc))
    }
  }
}

fn effects_collect_clauses(cs: [HClause], acc: EffUseAcc) : EffUseAcc {
  match cs {
    [] -> acc
    [c, ...rest] -> match c {
      HC(_, _, b, _, _) -> effects_collect_clauses(rest, effects_collect_expr(b, acc))
    }
  }
}

fn effects_collect_opt_return(opt: Option[HReturn], acc: EffUseAcc) : EffUseAcc {
  match opt {
    None -> acc
    Some(r) -> match r {
      HR(_, b, _, _) -> effects_collect_expr(b, acc)
    }
  }
}

# Split `"Eff.op"` into `Some("Eff")` if the name has the qualified
# shape that desugar_op_calls produces. Reject names that start with
# `__` (compiler-generated dispatchers, impl bodies, etc.) so
# protocol dispatch traffic doesn't pollute the effect graph.
fn effects_split_qualified(name: String) : Option[String] {
  if effects_starts_with_underscore_pair(name) { None }
  else { effects_find_dot(name, 0, string_length(name)) }
}

fn effects_find_dot(name: String, i: Int, n: Int) : Option[String] {
  if i >= n { None }
  else {
    match char_at(name, i) {
      Some(c) -> {
        if c == '.' {
          let prefix = string_slice(name, 0, i)
          # First char must be uppercase so we don't catch e.g.
          # `list.length` (records) — kaikai effects are uppercase.
          let upper = match char_at(prefix, 0) {
            Some(p) -> p >= 'A' and p <= 'Z'
            None    -> false
          }
          if upper { Some(prefix) } else { None }
        } else {
          effects_find_dot(name, i + 1, n)
        }
      }
      None -> None
    }
  }
}

fn effects_add_unique(eff: String, effs: [String]) : [String] {
  if list_has(effs, eff) { effs } else { list_append(effs, [eff]) }
}

fn effects_json_entry(e: EffEntry) : String =
  concat_all([
    "{",
    "\"fn\": ", json_str(e.fn_name),
    ", \"line\": ", int_to_string(e.line),
    ", \"col\": ", int_to_string(e.col),
    ", \"effects\": [",
    inf_join_with(map(e.effs, json_str), ", "),
    "], \"handlers_installed\": [",
    inf_join_with(map(e.handlers, effects_json_handler), ", "),
    "]}"
  ])

fn effects_json_handler(h: EffHandle) : String {
  match h {
    EH(eff, line, col) -> concat_all([
      "{\"effect\": ", json_str(eff),
      ", \"line\": ", int_to_string(line),
      ", \"col\": ", int_to_string(col), "}"
    ])
  }
}

# --strict-holes uses this on the normal compile path: emit a
# one-line diagnostic per hole to stderr, and promote the hole count
# to the return code so the driver skips emission. Users who want the
# rich report should run --holes or --holes-json explicitly.
fn strict_holes_report_loop(file: String, hs: [ResolvedHole]) : Unit / Console + File {


  match hs {
    [] -> ()
    [h, ...rest] -> {
      match h {
        RH(kind, line, col, ty, _, _) -> {
          let label = hole_kind_label(kind)
          diag_error(file, line, col, "unfilled hole #{label} : #{inf_ty_to_string(ty)}")
          diag_help("replace `#{label}` with an expression of type `#{inf_ty_to_string(ty)}`")
          diag_note("--strict-holes blocks emission until every `?` / `?name` / `todo!` is filled")
        }
      }
      strict_holes_report_loop(file, rest)
    }
  }
}

#[doc("infer: --strict-holes gate that fails the build on any unfilled hole.")]
pub fn strict_holes_check(file: String, decls: [Decl]) : Int / Console + File {

  let r = infer_program(file, decls, false)
  let n = list_length(r.holes)
  if n == 0 { r.errs }
  else {
    strict_holes_report_loop(file, r.holes)
    eprint("#{file}: #{int_to_string(n)} unfilled hole(s) (--strict-holes)")
    r.errs + n
  }
}

