# compiler/kir_lower_variant.kai — shared-tag sub-discrimination for the
# variant `match` decision.
#
# The variant path of `lower_match` (kir_lower_walk.kai) switches on the
# scrutinee's top-level tag (`KTagOf` → `KSwitch`). That tag-switch is the
# O(1) jump table for the common case — every arm a DISTINCT constructor
# (`Ok`/`Err`, `Some`/`None`, the AST node tags). It breaks the moment two
# arms SHARE a top-level tag but discriminate on a sub-pattern of the
# payload:
#
#     match e { Exited(0) -> A   Exited(_) -> B   Signaled(_) -> C }
#     match n { Branch(Red, _) -> A   Branch(Black, _) -> B   Leaf -> C }
#
# `plan_arms` would emit two `KC(Exited_tag, ..)` cases — a duplicate i32
# switch case LLVM rejects (`module verify failed: Duplicate integer as
# switch case`) — AND, even were it accepted, the second arm would be dead:
# nothing TESTS the payload, so the first `Exited(..)` captures every
# `Exited`. This is the largest native-parity gap family.
#
# The fix mirrors the C-direct oracle (`emit_pat_test_variant_subs`) WITHOUT
# losing the switch: group the arms by tag (kir_lower_walk's `plan_arms`),
# emit ONE switch case per tag, and for a tag shared by N>1 arms route that
# case to a GROUP block holding a sub-fail-chain — a `condbr` per arm over
# the conjunction of its payload sub-tests, exactly the record-match
# fail-chain (kir_lower_rec.kai) but reading positional slots and testing
# the variant_tag of a nullary sub-constructor. The unique-tag cases keep
# the bare switch jump.
#
# This module owns the PURE half: the per-arm payload sub-test conjunction
# (`var_emit_subtests`) and the catch-all classification + tag grouping. It
# NEVER recurses into `lower_expr` — the arm BODY is lowered by the walk's
# `lower_variant_groups` driver in the Expr-SCC `kir_lower_walk`, the same
# split list / literal / record decision trees use.
#
# SCOPE (asu review): the sub-tests cover the load-bearing shapes — a
# LITERAL slot (`Exited(0)`: `kai_eq_raw slot lit`) and a NULLARY ctor /
# enum slot (`Branch(Red, ..)`: `kai_tag_eq slot ctor_tag`). A sub-pattern
# that BINDS under a tag test (`Some(Node(x))` — a nested variant whose
# inner names also need projecting) stays the nested-variant-test gap and
# keeps trapping loud via `bind_pattern_fields`'s `bind_unsupported_nested`;
# it is a documented follow-up, not a silent miscompile.

import compiler.ast
import compiler.kir
import compiler.kir_lower

# A positional sub-pattern that DISCRIMINATES (carries a test the switch
# tag does not): a literal field, or a nullary constructor in the slot. A
# `PWild`/`PBind`/`PHole` carries no test (it only binds). `PAs` discriminates
# iff its inner pattern does. Drives both `var_arm_is_tag_catchall` (an arm
# with no discriminating sub-pattern is the tag's catch-all) and the
# per-slot test emission.
pub fn psub_is_discriminating(p: Pattern) : Bool = match p.pkind {
  PLit(_)              -> true
  PVariant(_, _)       -> true
  PVariantRecord(_, _) -> true
  # A list pattern in a slot imposes a length constraint (`[x, y]` demands
  # exactly two elements; `[x, ...t]` at least one), so it ALWAYS discriminates
  # — the arm must NOT be treated as its tag's catch-all. The walk's
  # `emit_arm_subtests_and_binds` lowers the slot's length test + binds via
  # `lm_emit_cells`; `var_seal_test` below traps loud if a list slot ever
  # reaches the per-slot test path directly (it should not — the walk diverts
  # the whole arm first).
  PList(_, _)          -> true
  PAs(_, inner)        -> psub_is_discriminating(inner)
  _                    -> false
}

# Does a variant arm DISCRIMINATE within its tag (any payload sub-pattern
# carries a test), or is it the tag's catch-all (`Exited(_)`, `Branch(c, k)`
# — all binders/wilds)? A catch-all arm ends its group's sub-chain
# unconditionally, so it must come LAST in source among its tag's arms — the
# typer guarantees this (an `Exited(_)` before `Exited(0)` makes `Exited(0)`
# unreachable, which the exhaustiveness/redundancy check rejects).
pub fn var_arm_is_tag_catchall(p: Pattern) : Bool = match p.pkind {
  PVariant(_, subs)         -> not any_discriminating(subs)
  PVariantRecord(_, fields) -> not any_field_discriminating(fields)
  # An as-pattern is its tag's catch-all iff its inner pattern is — the binder
  # adds no payload discriminant (`a @ Some(0)` still tests the slot).
  PAs(_, inner)             -> var_arm_is_tag_catchall(inner)
  _                         -> true
}

pub fn any_discriminating(subs: [Pattern]) : Bool = match subs {
  [] -> false
  [sp, ...rest] -> if psub_is_discriminating(sp) { true } else { any_discriminating(rest) }
}

fn any_field_discriminating(fields: [PField]) : Bool = match fields {
  [] -> false
  [PField(_, sub, _), ...rest] ->
    if psub_is_discriminating(sub) { true } else { any_field_discriminating(rest) }
}

# Emit the conjunction of payload sub-tests for ONE discriminating arm
# against `scrv`, sealing the current block so a full match flows to
# `body_lbl` and any mismatch to `fail_lbl`. The scrutinee tag is ALREADY
# matched (the switch case routed here), so this only tests the payload
# slots. Returns the state REOPENED at `body_lbl`, ready for the field
# binds + body (the test seals leave the cursor on a fresh fail/cont block,
# so the explicit reopen positions the next statements correctly — mirror
# of the record path's `reopen(st2, body_lbl)`). Reading positional slots
# (`KProj`) instead of named fields is the only difference from `rec_emit_tests`.
pub fn var_emit_subtests(p: Pattern, scrv: KVal, body_lbl: String,
                         fail_lbl: String, st: LowerSt) : LowerSt / Console = match p.pkind {
  PVariant(_, subs) -> reopen(var_emit_slot_tests(subs, scrv, 0, body_lbl, fail_lbl, st), body_lbl)
  PAs(_, inner)     -> var_emit_subtests(inner, scrv, body_lbl, fail_lbl, st)
  _                 -> reopen(ls_seal(st, KBr(body_lbl, KNoPos), body_lbl), body_lbl)
}

# Walk the positional payload slots, emitting a test for each discriminating
# sub-pattern and chaining them through fresh continue blocks (all must
# pass). A non-discriminating slot (binder/wild) carries no test. The last
# test branches to `body_lbl`; with no discriminating slot left the block
# branches unconditionally to `body_lbl` (its caller only reaches here for a
# discriminating arm, so at least one test was emitted before).
pub fn var_emit_slot_tests(subs: [Pattern], scrv: KVal, idx: Int, body_lbl: String,
                       fail_lbl: String, st: LowerSt) : LowerSt / Console = match subs {
  [] -> ls_seal(st, KBr(body_lbl, KNoPos), body_lbl)
  [sp, ...rest] ->
    if psub_is_discriminating(sp) {
      var_emit_one_test(sp, scrv, idx, rest, body_lbl, fail_lbl, st)
    } else {
      var_emit_slot_tests(rest, scrv, idx + 1, body_lbl, fail_lbl, st)
    }
}

# One discriminating slot's test. If more discriminating slots follow, open a
# fresh continue block for the success path and recurse; otherwise the
# success path is `body_lbl` directly. The slot value is read with the
# borrowing `KProj` (the native `kaix_variant_arg` borrows pointer slots, so
# a failing test leaks no ref); the immortal Bool result needs no drop.
fn var_emit_one_test(sp: Pattern, scrv: KVal, idx: Int, rest: [Pattern], body_lbl: String,
                     fail_lbl: String, st: LowerSt) : LowerSt / Console =
  if any_discriminating(rest) {
    match ls_fresh_label(st) { LSLabel(cont, st1) -> {
      let st2 = var_seal_test(sp, scrv, idx, cont, fail_lbl, st1)
      var_emit_slot_tests(rest, scrv, idx + 1, body_lbl, fail_lbl, reopen(st2, cont))
    } }
  } else { var_seal_test(sp, scrv, idx, body_lbl, fail_lbl, st) }

# `condbr <test> ? ok_lbl : fail_lbl` for slot `idx`'s sub-pattern. A
# LITERAL slot reads the slot and compares with the non-consuming
# `kai_eq_raw` (mirror of the literal/record paths); a NULLARY ctor slot
# reads the slot and tests its variant_tag with `kai_tag_eq` (mirror of the
# oracle's `emit_enum_slot_test` / `emit_variant_tag_test`). A PAYLOAD-
# bearing nested ctor (`Node(Red, a, ..)`) tests its tag THEN recurses into
# the payload's own discriminating sub-slots (the nested-variant-test path,
# mirror of the oracle's recursive `emit_pat_test`). An as-pattern tests its
# inner sub-pattern.
fn var_seal_test(sp: Pattern, scrv: KVal, idx: Int, ok_lbl: String,
                 fail_lbl: String, st: LowerSt) : LowerSt / Console = match sp.pkind {
  PLit(lit)           -> var_seal_eq(idx, var_lit_atom(lit), scrv, ok_lbl, fail_lbl, sp, st)
  PVariant(cn, subs)  -> var_seal_variant(idx, cn, subs, scrv, ok_lbl, fail_lbl, sp, st)
  PAs(_, inner)       -> var_seal_test(inner, scrv, idx, ok_lbl, fail_lbl, st)
  # A list slot must be lowered by the walk's `emit_arm_subtests_and_binds`
  # (length test + binds interleaved via `lm_emit_cells`), which diverts the
  # whole arm BEFORE this per-slot path. Reaching here means a list slot the
  # lone-list detector did not catch (a mixed multi-discriminating-slot
  # payload). Trap loud — never seal `KBr(ok_lbl)` (a length-less pass that
  # would match any list, the false-green the lone-arm bug taught us to avoid).
  PList(_, _)         -> var_seal_list_unsupported(sp, ok_lbl, st)
  _                   -> ls_seal(st, KBr(ok_lbl, KNoPos), ok_lbl)
}

# A list slot reached the per-slot test path (a mixed payload the lone-list
# detector rejected). Emit nothing testable and report the subset gap; the
# binders stay unbound, so the backend refuses the module rather than matching
# every list. Mirror of `bind_unsupported_nested`'s loud-trap discipline.
fn var_seal_list_unsupported(sp: Pattern, ok_lbl: String, st: LowerSt) : LowerSt / Console = {
  eprint(concat_all(["kir: list pattern in a mixed variant slot needs interleaved test+bind ",
                     "(subset gap: list-in-multi-slot) at ", int_to_string(sp.line), ":", int_to_string(sp.col)]))
  ls_seal(st, KBr(ok_lbl, KNoPos), ok_lbl)
}

# A nested ctor slot: project the slot, then test the projected value's tag
# and payload (`var_seal_ctor_of`).
fn var_seal_variant(idx: Int, cn: String, subs: [Pattern], scrv: KVal, ok_lbl: String,
                    fail_lbl: String, sp: Pattern, st: LowerSt) : LowerSt / Console =
  match bind_op(st, KProj(scrv, idx), KAt(sp.line, sp.col)) { LRes(sv, st1) ->
    var_seal_ctor_of(cn, subs, sv, ok_lbl, fail_lbl, sp, st1) }

# Full ctor test over an ALREADY-PROJECTED value `sv` (a variant slot, a list
# head, a record field): a NULLARY ctor (`Red`) is a bare tag test; a PAYLOAD-
# bearing ctor (`Node(Red, ..)`) tests its tag, and on success descends into
# the payload's discriminating sub-slots before reaching `ok_lbl`. The descent
# reuses `var_emit_slot_tests`, so arbitrary nesting depth (`Some(Node(Red, ..))`)
# falls out by recursion. A mismatch at any depth routes to the SAME `fail_lbl`
# — the whole arm fails as a unit, exactly the oracle's `&&` conjunction.
# Callers that test only the tag drop the payload's discriminants and match
# every sibling ctor sharing the tag — the nested-nullary-in-cons-arm miscompile.
pub fn var_seal_ctor_of(cn: String, subs: [Pattern], sv: KVal, ok_lbl: String,
                        fail_lbl: String, sp: Pattern, st: LowerSt) : LowerSt / Console =
  if any_discriminating(subs) {
    match ls_fresh_label(st) { LSLabel(sub_lbl, st1) -> {
      let st2 = var_seal_tag_of(sv, cn, sub_lbl, fail_lbl, sp, st1)
      var_emit_slot_tests(subs, sv, 0, ok_lbl, fail_lbl, reopen(st2, sub_lbl))
    } }
  } else { var_seal_tag_of(sv, cn, ok_lbl, fail_lbl, sp, st) }

# `condbr (kai_eq_raw (proj scr idx) lit) ? ok : fail` — a literal slot.
fn var_seal_eq(idx: Int, lit: KVal, scrv: KVal, ok_lbl: String, fail_lbl: String,
               sp: Pattern, st: LowerSt) : LowerSt / Console =
  match bind_op(st, KProj(scrv, idx), KAt(sp.line, sp.col)) { LRes(sv, st1) ->
    match bind_op(st1, KPrim("kai_eq_raw", [sv, lit]), KAt(sp.line, sp.col)) { LRes(cond, st2) ->
      ls_seal(st2, KCondBr(cond, ok_lbl, fail_lbl, KAt(sp.line, sp.col)), fail_lbl) } }

# `condbr (kai_tag_eq sv ctor_tag) ? ok : fail` — bare tag test of an
# already-projected value `sv`. The ctor tag is materialised as a `KIntV`
# the native prim reads as the i32 operand of the mixed
# `kaix_tag_eq(ptr, i32) -> ptr` shim.
pub fn var_seal_tag_of(sv: KVal, cname: String, ok_lbl: String, fail_lbl: String,
                       sp: Pattern, st: LowerSt) : LowerSt / Console =
  match bind_op(st, KPrim("kai_tag_eq", [sv, KIntV(ls_variant_tag(st, cname))]),
                KAt(sp.line, sp.col)) { LRes(cond, st1) ->
    ls_seal(st1, KCondBr(cond, ok_lbl, fail_lbl, KAt(sp.line, sp.col)), fail_lbl) }

# The KIR atom for a literal slot pattern's expression (Int / Bool / Char /
# String / Real). A non-literal is a typer invariant violation — lower to
# unit so the equality is well-formed but always false (loud divergence vs
# the oracle, never a silent miscompile). Mirror of `lit_atom` / `rec_lit_atom`.
fn var_lit_atom(lit: Expr) : KVal = match lit.kind {
  EInt(n)       -> KIntV(n)
  EBool(b)      -> KBoolV(b)
  EChar(c)      -> KCharV(c)
  EStr(span, _) -> KStrV(span)
  EReal(r, _)   -> KRealV(r)
  EFixed(span, ty) -> KFixedV(span, ty)
  _             -> KUnitV
}

# A variant arm whose SOLE discriminating payload slot is a LIST PATTERN
# (`Some([x, y])`, `Ok([h, ...t])`). The list pattern interleaves its length
# test with its head/tail binds, so it cannot be split into the test-then-bind
# the rest of this module uses — the walk lowers it with `lm_emit_cells`
# against the projected slot (see `emit_arm_subtests_and_binds`). Carries the
# slot index, the fixed element sub-patterns, and the optional rest binder.
pub type VListSlot = VLSlot(Int, [Pattern], Option[String])

# Detect the sole-list-slot shape. The arm must be a `PVariant` whose ONLY
# discriminating slot is a `PList`; every other slot is a binder / wildcard
# (which the post-test `bind_pattern_fields` reads). A multi-slot payload that
# mixes a list with ANOTHER discriminating slot stays the documented subset
# gap (`bind_unsupported_nested` traps loud), not silently mis-lowered here.
pub fn var_arm_lone_list_slot(p: Pattern) : Option[VListSlot] = match p.pkind {
  PVariant(_, subs) -> vls_scan(subs, 0, None)
  _                 -> None
}

# Walk the slots: the first PList found becomes the candidate; a SECOND
# discriminating slot (or a second list) disqualifies the shape (return None).
fn vls_scan(subs: [Pattern], idx: Int, found: Option[VListSlot]) : Option[VListSlot] = match subs {
  [] -> found
  [sp, ...rest] -> match sp.pkind {
    PList(pats, opt_rest) -> match found {
      None    -> vls_scan(rest, idx + 1, Some(VLSlot(idx, pats, opt_rest)))
      Some(_) -> None
    }
    _ -> if psub_is_discriminating(sp) { None } else { vls_scan(rest, idx + 1, found) }
  }
}

# Project payload slot `idx` of a variant into a fresh register, borrowing
# (the native `kaix_variant_arg` borrows pointer slots, so a failing list test
# leaks no ref — the same projection `var_seal_variant` uses). The walk feeds
# the result to `lm_emit_cells` as the list cursor.
pub fn var_proj_slot(scrv: KVal, idx: Int, sp: Pattern, st: LowerSt) : LRes / Console =
  bind_op(st, KProj(scrv, idx), KAt(sp.line, sp.col))
