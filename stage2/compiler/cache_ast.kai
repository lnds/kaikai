#[doc("""
KAB2 codec for the typed AST: resolved `Ty` / `Row` / `TyScheme` plus
`TypeExpr` / `Expr` / `Pattern` / `Stmt` / `Decl` and the shapes they
nest.

These share one module because they are mutually recursive: an `Expr`
carries `ty: Option[Ty]`, a `Ty` carries `TyRefineT(Ty, Expr)`, and a
`TypeExpr` carries `TyRefine(TypeExpr, Expr)`. `compiler.cache` keeps
what sits upstream of that knot — the primitives, `UnitExprT` and
`Diagnostic` — plus the blob header.

`Expr.ty` rides the wire: a post-parse node carries `None`, a typed
node carries its inferred type. Serialising it is what lets a cached
typed module be restored into something monomorph and emit can lower.

Wire conventions: sum types open with a 1-byte tag (never 0x00),
records emit fields in declaration order, lists emit `u32 length + each
element`. Every decoder returns `Option[Cache<T>Pos]` whose second slot
is the cursor past the consumed bytes.
""")]

import compiler.ast
import compiler.diag
import compiler.cache

# ---- resolved Ty / Row / TyScheme ------------------------------------
#
# `Ty` and `Expr` are mutually recursive (`TyRefineT(Ty, Expr)` one way,
# `Expr.ty: Option[Ty]` the other), so their codecs share this module.

pub type CacheTyRPos  = CTyRP(Ty, Int)
pub type CacheTyRLPos = CTyRLP([Ty], Int)
pub type CacheRowRPos = CRowRP(Row, Int)
pub type CacheLblPos  = CLblP(Label, Int)
pub type CacheLblLPos = CLblLP([Label], Int)
pub type CacheSchPos  = CSchP(TyScheme, Int)
pub type CacheOptIntPos3 = COIP3(Option[Int], Int)

# ---- resolved Ty ------------------------------------------------------
# Tags 1..21 follow the declaration order in ast.kai; nullary arms carry
# no payload. `TyRefineT` closes back to `Expr`, reusing the KAB2 Expr
# codec; `TyDimT` reuses the UnitExprT codec.

# The nullary arms are keyed by a small match; the payload-carrying
# arms live in `enc_ty_compound`. Splitting keeps each match small — a
# single 21-arm match over `Ty` mixing nullary and multi-slot arms
# mis-dispatches the `TyCon` arm under the stage1 bootstrap compiler.
pub fn cache_tyr_to_hex(t: Ty) : String = match t {
  TyInt          -> cache_byte_to_hex(1)
  TyReal         -> cache_byte_to_hex(2)
  TyBool         -> cache_byte_to_hex(3)
  TyString       -> cache_byte_to_hex(4)
  TyChar         -> cache_byte_to_hex(5)
  TyUnit         -> cache_byte_to_hex(6)
  TyByte         -> cache_byte_to_hex(7)
  TyInt32        -> cache_byte_to_hex(8)
  TyUInt32       -> cache_byte_to_hex(9)
  TyUInt64       -> cache_byte_to_hex(10)
  TyInt128       -> cache_byte_to_hex(11)
  TyHandle       -> cache_byte_to_hex(12)
  TyAny          -> cache_byte_to_hex(13)
  _              -> enc_ty_compound(t)
}

# A `[Ty]` slot read from a variant must be consumed with `map` inside
# the arm that destructured it — passing it positionally to a helper
# that `match`es it corrupts the list under the stage1 bootstrap
# compiler (the canonical idiom in law_checks.kai `lc_shape_of_variant`).
# So each arm below maps its `[Ty]` slot to per-element chunks in place
# and only then concatenates.
fn enc_ty_compound(t: Ty) : String = match t {
  TyListT(inner) -> concat_all([cache_byte_to_hex(14), cache_tyr_to_hex(inner)])
  TyFnT(as_, ret, row) -> {
    let achunks = map(as_, (a) => cache_tyr_to_hex(a))
    concat_all([cache_byte_to_hex(15), cache_u32_to_hex(list_length(as_)),
                concat_all(achunks), cache_tyr_to_hex(ret), cache_rowr_to_hex(row)])
  }
  TyCon(mo, nm, args) -> {
    let achunks = map(args, (a) => cache_tyr_to_hex(a))
    concat_all([cache_byte_to_hex(16), cache_opt_string_to_hex(mo),
                cache_string_to_hex(nm), cache_u32_to_hex(list_length(args)),
                concat_all(achunks)])
  }
  TyVarT(id)     -> concat_all([cache_byte_to_hex(17), cache_int_to_hex(id)])
  TyDimT(inner, u) -> concat_all([cache_byte_to_hex(18), cache_tyr_to_hex(inner),
                                   cache_unit_to_hex(u)])
  TyRefineT(base, pred) -> concat_all([cache_byte_to_hex(19), cache_tyr_to_hex(base),
                                        cache_expr_to_hex(pred)])
  TyUnion(cs)    -> {
    let cchunks = map(cs, (c) => cache_tyr_to_hex(c))
    concat_all([cache_byte_to_hex(20), cache_u32_to_hex(list_length(cs)),
                concat_all(cchunks)])
  }
  TyShapeApp(id, arg) -> concat_all([cache_byte_to_hex(21), cache_int_to_hex(id),
                                      cache_tyr_to_hex(arg)])
  _              -> ""
}

pub fn cache_hex_to_tyr(buf: String, pos: Int) : Option[CacheTyRPos] {
  match cache_hex_byte_at(buf, pos) {
    None -> None
    Some(b) -> cache_hex_to_tyr_body(buf, pos + 1, b)
  }
}

# Tags 1..13 name a nullary `Ty` and consume no payload; anything above
# routes to the payload decoders. Kept as two small functions so neither
# carries the whole 21-way dispatch.
fn cache_hex_to_tyr_body(buf: String, pos: Int, tag: Int) : Option[CacheTyRPos] {
  if tag <= 13 { match tyr_nullary_of_tag(tag) {
    None -> None
    Some(t) -> Some(CTyRP(t, pos))
  } }
  else { cache_hex_to_tyr_payload(buf, pos, tag) }
}

fn tyr_nullary_of_tag(tag: Int) : Option[Ty] {
  if tag == 1 { Some(TyInt) } else if tag == 2 { Some(TyReal) }
  else if tag == 3 { Some(TyBool) } else if tag == 4 { Some(TyString) }
  else if tag == 5 { Some(TyChar) } else if tag == 6 { Some(TyUnit) }
  else if tag == 7 { Some(TyByte) } else if tag == 8 { Some(TyInt32) }
  else if tag == 9 { Some(TyUInt32) } else if tag == 10 { Some(TyUInt64) }
  else if tag == 11 { Some(TyInt128) } else if tag == 12 { Some(TyHandle) }
  else if tag == 13 { Some(TyAny) } else { None }
}

fn cache_hex_to_tyr_payload(buf: String, pos: Int, tag: Int) : Option[CacheTyRPos] {
  if tag == 14 { cache_hex_to_tyr_list1(buf, pos) }
  else if tag == 15 { cache_hex_to_tyr_fn(buf, pos) }
  else if tag == 16 { cache_hex_to_tyr_con(buf, pos) }
  else if tag == 17 { cache_hex_to_tyr_var(buf, pos) }
  else if tag == 18 { cache_hex_to_tyr_dim(buf, pos) }
  else if tag == 19 { cache_hex_to_tyr_refine(buf, pos) }
  else if tag == 20 { cache_hex_to_tyr_union(buf, pos) }
  else if tag == 21 { cache_hex_to_tyr_shape(buf, pos) }
  else { None }
}

fn cache_hex_to_tyr_list1(buf: String, pos: Int) : Option[CacheTyRPos] {
  match cache_hex_to_tyr(buf, pos) {
    None -> None
    Some(c) -> match c { CTyRP(inner, p2) -> Some(CTyRP(TyListT(inner), p2)) }
  }
}

fn cache_hex_to_tyr_var(buf: String, pos: Int) : Option[CacheTyRPos] {
  match cache_hex_to_int(buf, pos) {
    None -> None
    Some(c) -> match c { CIP(id, p2) -> Some(CTyRP(TyVarT(id), p2)) }
  }
}

fn cache_hex_to_tyr_dim(buf: String, pos: Int) : Option[CacheTyRPos] {
  match cache_hex_to_tyr(buf, pos) {
    None -> None
    Some(c) -> match c { CTyRP(inner, p2) -> match cache_hex_to_unit(buf, p2) {
      None -> None
      Some(cu) -> match cu { CUP(u, p3) -> Some(CTyRP(TyDimT(inner, u), p3)) }
    } }
  }
}

fn cache_hex_to_tyr_refine(buf: String, pos: Int) : Option[CacheTyRPos] {
  match cache_hex_to_tyr(buf, pos) {
    None -> None
    Some(c) -> match c { CTyRP(base, p2) -> match cache_hex_to_expr(buf, p2) {
      None -> None
      Some(ce) -> match ce { CEP(pred, p3) -> Some(CTyRP(TyRefineT(base, pred), p3)) }
    } }
  }
}

fn cache_hex_to_tyr_union(buf: String, pos: Int) : Option[CacheTyRPos] {
  match cache_hex_to_tyr_list(buf, pos) {
    None -> None
    Some(cl) -> match cl { CTyRLP(cs, p2) -> Some(CTyRP(TyUnion(cs), p2)) }
  }
}

fn cache_hex_to_tyr_shape(buf: String, pos: Int) : Option[CacheTyRPos] {
  match cache_hex_to_int(buf, pos) {
    None -> None
    Some(c) -> match c { CIP(id, p2) -> match cache_hex_to_tyr(buf, p2) {
      None -> None
      Some(ca) -> match ca { CTyRP(arg, p3) -> Some(CTyRP(TyShapeApp(id, arg), p3)) }
    } }
  }
}

fn cache_hex_to_tyr_fn(buf: String, pos: Int) : Option[CacheTyRPos] {
  match cache_hex_to_tyr_list(buf, pos) {
    None -> None
    Some(c) -> match c { CTyRLP(as_, p) -> tyfn_after_args(buf, p, as_) }
  }
}

fn tyfn_after_args(buf: String, pos: Int, as_: [Ty]) : Option[CacheTyRPos] {
  match cache_hex_to_tyr(buf, pos) {
    None -> None
    Some(c) -> match c { CTyRP(ret, p) -> tyfn_after_ret(buf, p, as_, ret) }
  }
}

fn tyfn_after_ret(buf: String, pos: Int, as_: [Ty], ret: Ty) : Option[CacheTyRPos] {
  match cache_hex_to_rowr(buf, pos) {
    None -> None
    Some(c) -> match c { CRowRP(row, p) -> Some(CTyRP(TyFnT(as_, ret, row), p)) }
  }
}

fn cache_hex_to_tyr_con(buf: String, pos: Int) : Option[CacheTyRPos] {
  match cache_hex_to_opt_string(buf, pos) {
    None -> None
    Some(c) -> match c { COSP(mo, p) -> tycon_after_mo(buf, p, mo) }
  }
}

fn tycon_after_mo(buf: String, pos: Int, mo: Option[String]) : Option[CacheTyRPos] {
  match cache_hex_to_string(buf, pos) {
    None -> None
    Some(c) -> match c { CSP(nm, p) -> tycon_after_name(buf, p, mo, nm) }
  }
}

fn tycon_after_name(buf: String, pos: Int, mo: Option[String],
                     nm: String) : Option[CacheTyRPos] {
  match cache_hex_to_tyr_list(buf, pos) {
    None -> None
    Some(c) -> match c { CTyRLP(args, p) -> Some(CTyRP(TyCon(mo, nm, args), p)) }
  }
}

# ---- [Ty] -------------------------------------------------------------

pub fn cache_hex_to_tyr_list(buf: String, pos: Int) : Option[CacheTyRLPos] {
  match cache_hex_to_u32(buf, pos) {
    None -> None
    Some(cip) -> match cip { CIP(n, p2) -> cache_hex_collect_tyr_list(buf, p2, n, []) }
  }
}

fn cache_hex_collect_tyr_list(buf: String, pos: Int, remaining: Int,
                               acc: [Ty]) : Option[CacheTyRLPos] {
  if remaining <= 0 { Some(CTyRLP(list_reverse(acc), pos)) }
  else {
    match cache_hex_to_tyr(buf, pos) {
      None -> None
      Some(c) -> match c { CTyRP(t, p2) ->
        cache_hex_collect_tyr_list(buf, p2, remaining - 1, [t, ...acc]) }
    }
  }
}

# ---- Row / Label ------------------------------------------------------

fn cache_opt_int_to_hex3(o: Option[Int]) : String = match o {
  None    -> cache_byte_to_hex(0)
  Some(n) -> string_concat(cache_byte_to_hex(1), cache_int_to_hex(n))
}

fn cache_hex_to_opt_int3(buf: String, pos: Int) : Option[CacheOptIntPos3] {
  match cache_hex_byte_at(buf, pos) {
    None -> None
    Some(0) -> Some(COIP3(None, pos + 1))
    Some(1) -> match cache_hex_to_int(buf, pos + 1) {
      None -> None
      Some(c) -> match c { CIP(n, p2) -> Some(COIP3(Some(n), p2)) }
    }
    Some(_) -> None
  }
}

pub fn cache_lbl_to_hex(l: Label) : String {
  let achunks = map(l.ty_args, (a) => cache_tyr_to_hex(a))
  concat_all([cache_string_to_hex(l.eff), sch_len_prefixed(achunks)])
}

fn cache_hex_to_lbl(buf: String, pos: Int) : Option[CacheLblPos] {
  match cache_hex_to_string(buf, pos) {
    None -> None
    Some(cs) -> match cs { CSP(eff, p2) -> match cache_hex_to_tyr_list(buf, p2) {
      None -> None
      Some(cl) -> match cl { CTyRLP(args, p3) ->
        Some(CLblP(Label { eff: eff, ty_args: args }, p3)) }
    } }
  }
}

fn cache_hex_to_lbl_list(buf: String, pos: Int) : Option[CacheLblLPos] {
  match cache_hex_to_u32(buf, pos) {
    None -> None
    Some(cip) -> match cip { CIP(n, p2) -> cache_hex_collect_lbl_list(buf, p2, n, []) }
  }
}

fn cache_hex_collect_lbl_list(buf: String, pos: Int, remaining: Int,
                               acc: [Label]) : Option[CacheLblLPos] {
  if remaining <= 0 { Some(CLblLP(list_reverse(acc), pos)) }
  else {
    match cache_hex_to_lbl(buf, pos) {
      None -> None
      Some(c) -> match c { CLblP(l, p2) ->
        cache_hex_collect_lbl_list(buf, p2, remaining - 1, [l, ...acc]) }
    }
  }
}

pub fn cache_rowr_to_hex(r: Row) : String {
  let lchunks = map(r.labels, (l) => cache_lbl_to_hex(l))
  concat_all([sch_len_prefixed(lchunks),
              cache_opt_int_to_hex3(r.tail),
              cache_opt_string_to_hex(r.display_alias)])
}

pub fn cache_hex_to_rowr(buf: String, pos: Int) : Option[CacheRowRPos] {
  match cache_hex_to_lbl_list(buf, pos) {
    None -> None
    Some(c) -> match c { CLblLP(labels, p) -> row_after_labels(buf, p, labels) }
  }
}

fn row_after_labels(buf: String, pos: Int, labels: [Label]) : Option[CacheRowRPos] {
  match cache_hex_to_opt_int3(buf, pos) {
    None -> None
    Some(c) -> match c { COIP3(tail, p) -> row_after_tail(buf, p, labels, tail) }
  }
}

fn row_after_tail(buf: String, pos: Int, labels: [Label],
                   tail: Option[Int]) : Option[CacheRowRPos] {
  match cache_hex_to_opt_string(buf, pos) {
    None -> None
    Some(c) -> match c { COSP(alias, p) ->
      Some(CRowRP(Row { labels: labels, tail: tail, display_alias: alias }, p)) }
  }
}

# ---- TyScheme ---------------------------------------------------------
# Scheme([Int], [Int], [Int], [String], Ty): quantified type vars, row
# vars, dim vars, string params, body.

# The list slots (`tvs`/`rvs`/`dvs`/`sps`) are consumed with `map` in
# the arm that destructured the `Scheme` variant; passing them
# positionally to a `match`-driven helper corrupts them under the stage1
# bootstrap compiler.
pub fn cache_scheme_to_hex(s: TyScheme) : String = match s {
  Scheme(tvs, rvs, dvs, sps, body) -> {
    let tv = map(tvs, (i) => cache_int_to_hex(i))
    let rv = map(rvs, (i) => cache_int_to_hex(i))
    let dv = map(dvs, (i) => cache_int_to_hex(i))
    let sp = map(sps, (x) => cache_string_to_hex(x))
    concat_all([sch_len_prefixed(tv), sch_len_prefixed(rv), sch_len_prefixed(dv),
                sch_len_prefixed(sp), cache_tyr_to_hex(body)])
  }
}

fn sch_len_prefixed(chunks: [String]) : String =
  concat_all([cache_u32_to_hex(list_length(chunks)), concat_all(chunks)])

# Decoded field-by-field through a chain of one-step continuations, so
# no single function carries the whole five-level nest.
pub fn cache_hex_to_scheme(buf: String, pos: Int) : Option[CacheSchPos] {
  match cache_hex_to_int_list(buf, pos) {
    None -> None
    Some(c) -> match c { CILP(tvs, p) -> sch_after_tvs(buf, p, tvs) }
  }
}

fn sch_after_tvs(buf: String, pos: Int, tvs: [Int]) : Option[CacheSchPos] {
  match cache_hex_to_int_list(buf, pos) {
    None -> None
    Some(c) -> match c { CILP(rvs, p) -> sch_after_rvs(buf, p, tvs, rvs) }
  }
}

fn sch_after_rvs(buf: String, pos: Int, tvs: [Int], rvs: [Int]) : Option[CacheSchPos] {
  match cache_hex_to_int_list(buf, pos) {
    None -> None
    Some(c) -> match c { CILP(dvs, p) -> sch_after_dvs(buf, p, tvs, rvs, dvs) }
  }
}

fn sch_after_dvs(buf: String, pos: Int, tvs: [Int], rvs: [Int],
                  dvs: [Int]) : Option[CacheSchPos] {
  match cache_hex_to_string_list(buf, pos) {
    None -> None
    Some(c) -> match c { CSLP(sps, p) -> sch_after_sps(buf, p, tvs, rvs, dvs, sps) }
  }
}

fn sch_after_sps(buf: String, pos: Int, tvs: [Int], rvs: [Int], dvs: [Int],
                  sps: [String]) : Option[CacheSchPos] {
  match cache_hex_to_tyr(buf, pos) {
    None -> None
    Some(c) -> match c { CTyRP(body, p) ->
      Some(CSchP(Scheme(tvs, rvs, dvs, sps, body), p)) }
  }
}

# ---- [Int] ------------------------------------------------------------

pub type CacheIntLPos = CILP([Int], Int)

pub fn cache_hex_to_int_list(buf: String, pos: Int) : Option[CacheIntLPos] {
  match cache_hex_to_u32(buf, pos) {
    None -> None
    Some(cip) -> match cip { CIP(n, p2) -> cache_hex_collect_int_list(buf, p2, n, []) }
  }
}

fn cache_hex_collect_int_list(buf: String, pos: Int, remaining: Int,
                               acc: [Int]) : Option[CacheIntLPos] {
  if remaining <= 0 { Some(CILP(list_reverse(acc), pos)) }
  else {
    match cache_hex_to_int(buf, pos) {
      None -> None
      Some(c) -> match c { CIP(v, p2) ->
        cache_hex_collect_int_list(buf, p2, remaining - 1, [v, ...acc]) }
    }
  }
}


# ---- TypeExpr / TyKind ----------------------------------------------------
#
# `TyRefine(TypeExpr, Expr)` closes the TypeExpr <-> Expr loop; the
# Expr serde lives below and is forward-referenced by name.

#[doc("KAB2 codec primitive: `cache_typeexpr_to_hex`.")]
pub fn cache_typeexpr_to_hex(t: TypeExpr) : String =
  concat_all([cache_int_to_hex(t.line),
              cache_int_to_hex(t.col),
              cache_tykind_to_hex(t.tkind)])

fn cache_tykind_to_hex(k: TyKind) : String = match k {
  TyName(s, ts)   -> concat_all([cache_byte_to_hex(1), cache_string_to_hex(s),
                                  cache_typeexpr_list_to_hex(ts)])
  TyList(t)       -> concat_all([cache_byte_to_hex(2), cache_typeexpr_to_hex(t)])
  TyFn(as_, ret, row) -> concat_all([cache_byte_to_hex(3), cache_typeexpr_list_to_hex(as_),
                                       cache_typeexpr_to_hex(ret),
                                       cache_row_to_hex(row)])
  TyDim(t, u)     -> concat_all([cache_byte_to_hex(4), cache_typeexpr_to_hex(t),
                                  cache_unit_to_hex(u)])
  TyRefine(t, e)  -> concat_all([cache_byte_to_hex(5), cache_typeexpr_to_hex(t),
                                  cache_expr_to_hex(e)])
  # issue #772: compound row as a type argument (`Stream[Int, Stdout +
  # Fail]`). Serialised with tag 6, payload is the carried row.
  TyRow(row)      -> concat_all([cache_byte_to_hex(6), cache_row_to_hex(row)])
}

#[doc("KAB2 codec primitive: `cache_hex_to_typeexpr`.")]
pub fn cache_hex_to_typeexpr(buf: String, pos: Int) : Option[CacheTyPos] {
  match cache_hex_to_int(buf, pos) {
    None -> None
    Some(c1) -> match c1 {
      CIP(line, p1) -> match cache_hex_to_int(buf, p1) {
        None -> None
        Some(c2) -> match c2 {
          CIP(col, p2) -> cache_hex_to_typeexpr_at(buf, p2, line, col)
        }
      }
    }
  }
}

fn cache_hex_to_typeexpr_at(buf: String, pos: Int, line: Int,
                               col: Int) : Option[CacheTyPos] {
  match cache_hex_byte_at(buf, pos) {
    None -> None
    Some(1) -> match cache_hex_to_string(buf, pos + 1) {
      None -> None
      Some(csp) -> match csp { CSP(s, p3) ->
        match cache_hex_to_typeexpr_list(buf, p3) {
          None -> None
          Some(ctl) -> match ctl { CTyLP(ts, p4) ->
            Some(CTyP(TypeExpr { tkind: TyName(s, ts), line: line, col: col }, p4))
          }
        }
      }
    }
    Some(2) -> match cache_hex_to_typeexpr(buf, pos + 1) {
      None -> None
      Some(ct) -> match ct { CTyP(inner, p3) ->
        Some(CTyP(TypeExpr { tkind: TyList(inner), line: line, col: col }, p3))
      }
    }
    Some(3) -> cache_hex_to_typeexpr_fn(buf, pos + 1, line, col)
    Some(4) -> cache_hex_to_typeexpr_dim(buf, pos + 1, line, col)
    Some(5) -> cache_hex_to_typeexpr_refine(buf, pos + 1, line, col)
    # issue #772: compound row as a type argument (tag 6).
    Some(6) -> match cache_hex_to_row(buf, pos + 1) {
      None -> None
      Some(cr) -> match cr { CRowP(row, p3) ->
        Some(CTyP(TypeExpr { tkind: TyRow(row), line: line, col: col }, p3))
      }
    }
    Some(_) -> None
  }
}

fn cache_hex_to_typeexpr_fn(buf: String, pos: Int, line: Int,
                               col: Int) : Option[CacheTyPos] {
  match cache_hex_to_typeexpr_list(buf, pos) {
    None -> None
    Some(ctl) -> match ctl { CTyLP(as_, p3) ->
      match cache_hex_to_typeexpr(buf, p3) {
        None -> None
        Some(ct) -> match ct { CTyP(ret, p4) ->
          match cache_hex_to_row(buf, p4) {
            None -> None
            Some(cr) -> match cr { CRowP(row, p5) ->
              Some(CTyP(TypeExpr { tkind: TyFn(as_, ret, row), line: line, col: col }, p5))
            }
          }
        }
      }
    }
  }
}

fn cache_hex_to_typeexpr_dim(buf: String, pos: Int, line: Int,
                                col: Int) : Option[CacheTyPos] {
  match cache_hex_to_typeexpr(buf, pos) {
    None -> None
    Some(ct) -> match ct { CTyP(inner, p3) ->
      match cache_hex_to_unit(buf, p3) {
        None -> None
        Some(cu) -> match cu { CUP(u, p4) ->
          Some(CTyP(TypeExpr { tkind: TyDim(inner, u), line: line, col: col }, p4))
        }
      }
    }
  }
}

fn cache_hex_to_typeexpr_refine(buf: String, pos: Int, line: Int,
                                   col: Int) : Option[CacheTyPos] {
  match cache_hex_to_typeexpr(buf, pos) {
    None -> None
    Some(ct) -> match ct { CTyP(inner, p3) ->
      match cache_hex_to_expr(buf, p3) {
        None -> None
        Some(ce) -> match ce { CEP(e, p4) ->
          Some(CTyP(TypeExpr { tkind: TyRefine(inner, e), line: line, col: col }, p4))
        }
      }
    }
  }
}

# `Option[TypeExpr]` — 1 tag byte, then the encoded TypeExpr.
#[doc("KAB2 codec primitive: `cache_opt_typeexpr_to_hex`.")]
pub fn cache_opt_typeexpr_to_hex(o: Option[TypeExpr]) : String = match o {
  None    -> cache_byte_to_hex(0)
  Some(t) -> concat_all([cache_byte_to_hex(1), cache_typeexpr_to_hex(t)])
}

#[doc("KAB2 codec primitive: `cache_hex_to_opt_typeexpr`.")]
pub fn cache_hex_to_opt_typeexpr(buf: String, pos: Int) : Option[CacheOptTyPos] {
  match cache_hex_byte_at(buf, pos) {
    None -> None
    Some(0) -> Some(COTyP(None, pos + 1))
    Some(1) -> match cache_hex_to_typeexpr(buf, pos + 1) {
      None -> None
      Some(ct) -> match ct { CTyP(t, p2) -> Some(COTyP(Some(t), p2)) }
    }
    Some(_) -> None
  }
}

# `[TypeExpr]` — length + per-element.
#[doc("KAB2 codec primitive: `cache_typeexpr_list_to_hex`.")]
pub fn cache_typeexpr_list_to_hex(xs: [TypeExpr]) : String =
  concat_all([cache_u32_to_hex(list_length(xs)),
              concat_all(list_reverse(cache_typeexpr_list_loop(xs, [])))])

fn cache_typeexpr_list_loop(xs: [TypeExpr], acc: [String]) : [String] = match xs {
  [] -> acc
  [h, ...t] -> cache_typeexpr_list_loop(t, [cache_typeexpr_to_hex(h), ...acc])
}

#[doc("KAB2 codec primitive: `cache_hex_to_typeexpr_list`.")]
pub fn cache_hex_to_typeexpr_list(buf: String, pos: Int) : Option[CacheTyListPos] {
  match cache_hex_to_u32(buf, pos) {
    None -> None
    Some(cip) -> match cip { CIP(n, p2) ->
      cache_hex_collect_typeexpr_list(buf, p2, n, [])
    }
  }
}

fn cache_hex_collect_typeexpr_list(buf: String, pos: Int, remaining: Int,
                                      acc: [TypeExpr]) : Option[CacheTyListPos] {
  if remaining <= 0 { Some(CTyLP(list_reverse(acc), pos)) }
  else {
    match cache_hex_to_typeexpr(buf, pos) {
      None -> None
      Some(ct) -> match ct { CTyP(t, p2) ->
        cache_hex_collect_typeexpr_list(buf, p2, remaining - 1, [t, ...acc])
      }
    }
  }
}

# ---- RowExpr / RowLabel ----------------------------------------------------

#[doc("KAB2 codec primitive: `cache_row_to_hex`.")]
pub fn cache_row_to_hex(r: RowExpr) : String = match r {
  REmpty           -> cache_byte_to_hex(1)
  RClosed(ls)      -> concat_all([cache_byte_to_hex(2), cache_rowlabel_list_to_hex(ls)])
  ROpen(v, ls)     -> concat_all([cache_byte_to_hex(3), cache_string_to_hex(v),
                                   cache_rowlabel_list_to_hex(ls)])
}

#[doc("KAB2 codec primitive: `cache_hex_to_row`.")]
pub fn cache_hex_to_row(buf: String, pos: Int) : Option[CacheRowPos] {
  match cache_hex_byte_at(buf, pos) {
    None -> None
    Some(1) -> Some(CRowP(REmpty, pos + 1))
    Some(2) -> match cache_hex_to_rowlabel_list(buf, pos + 1) {
      None -> None
      Some(crll) -> match crll { CRLLP(ls, p2) -> Some(CRowP(RClosed(ls), p2)) }
    }
    Some(3) -> match cache_hex_to_string(buf, pos + 1) {
      None -> None
      Some(csp) -> match csp { CSP(v, p2) ->
        match cache_hex_to_rowlabel_list(buf, p2) {
          None -> None
          Some(crll) -> match crll { CRLLP(ls, p3) ->
            Some(CRowP(ROpen(v, ls), p3))
          }
        }
      }
    }
    Some(_) -> None
  }
}

fn cache_rowlabel_to_hex(rl: RowLabel) : String = match rl {
  RL(s, ts) -> concat_all([cache_string_to_hex(s),
                            cache_typeexpr_list_to_hex(ts)])
}

fn cache_hex_to_rowlabel(buf: String, pos: Int) : Option[CacheRLPos] {
  match cache_hex_to_string(buf, pos) {
    None -> None
    Some(csp) -> match csp { CSP(s, p2) ->
      match cache_hex_to_typeexpr_list(buf, p2) {
        None -> None
        Some(ctl) -> match ctl { CTyLP(ts, p3) -> Some(CRLP(RL(s, ts), p3)) }
      }
    }
  }
}

fn cache_rowlabel_list_to_hex(xs: [RowLabel]) : String =
  concat_all([cache_u32_to_hex(list_length(xs)),
              concat_all(list_reverse(cache_rowlabel_list_loop(xs, [])))])

fn cache_rowlabel_list_loop(xs: [RowLabel], acc: [String]) : [String] = match xs {
  [] -> acc
  [h, ...t] -> cache_rowlabel_list_loop(t, [cache_rowlabel_to_hex(h), ...acc])
}

fn cache_hex_to_rowlabel_list(buf: String, pos: Int) : Option[CacheRLListPos] {
  match cache_hex_to_u32(buf, pos) {
    None -> None
    Some(cip) -> match cip { CIP(n, p2) ->
      cache_hex_collect_rowlabel_list(buf, p2, n, [])
    }
  }
}

fn cache_hex_collect_rowlabel_list(buf: String, pos: Int, remaining: Int,
                                      acc: [RowLabel]) : Option[CacheRLListPos] {
  if remaining <= 0 { Some(CRLLP(list_reverse(acc), pos)) }
  else {
    match cache_hex_to_rowlabel(buf, pos) {
      None -> None
      Some(crl) -> match crl { CRLP(rl, p2) ->
        cache_hex_collect_rowlabel_list(buf, p2, remaining - 1, [rl, ...acc])
      }
    }
  }
}

# ---- Param ------------------------------------------------------------------

fn cache_param_to_hex(p: Param) : String =
  concat_all([cache_string_to_hex(p.pname),
              cache_opt_typeexpr_to_hex(p.ptype),
              cache_int_to_hex(p.pline),
              cache_int_to_hex(p.pcol),
              cache_bool_to_hex(p.pborrow)])

fn cache_hex_to_param(buf: String, pos: Int) : Option[CacheParamPos] {
  match cache_hex_to_string(buf, pos) {
    None -> None
    Some(csp) -> match csp { CSP(pname, p1) ->
      match cache_hex_to_opt_typeexpr(buf, p1) {
        None -> None
        Some(coty) -> match coty { COTyP(ptype, p2) ->
          match cache_hex_to_int(buf, p2) {
            None -> None
            Some(c1) -> match c1 { CIP(pline, p3) ->
              match cache_hex_to_int(buf, p3) {
                None -> None
                Some(c2) -> match c2 { CIP(pcol, p4) ->
                  match cache_hex_to_bool(buf, p4) {
                    None -> None
                    Some(cb) -> match cb { CBP(pborrow, p5) ->
                      Some(CPmP(Param { pname: pname, ptype: ptype,
                                        pline: pline, pcol: pcol, pborrow: pborrow }, p5))
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}

#[doc("KAB2 codec primitive: `cache_param_list_to_hex`.")]
pub fn cache_param_list_to_hex(xs: [Param]) : String =
  concat_all([cache_u32_to_hex(list_length(xs)),
              concat_all(list_reverse(cache_param_list_loop(xs, [])))])

fn cache_param_list_loop(xs: [Param], acc: [String]) : [String] = match xs {
  [] -> acc
  [h, ...t] -> cache_param_list_loop(t, [cache_param_to_hex(h), ...acc])
}

#[doc("KAB2 codec primitive: `cache_hex_to_param_list`.")]
pub fn cache_hex_to_param_list(buf: String, pos: Int) : Option[CacheParamLPos] {
  match cache_hex_to_u32(buf, pos) {
    None -> None
    Some(cip) -> match cip { CIP(n, p2) ->
      cache_hex_collect_param_list(buf, p2, n, [])
    }
  }
}

fn cache_hex_collect_param_list(buf: String, pos: Int, remaining: Int,
                                  acc: [Param]) : Option[CacheParamLPos] {
  if remaining <= 0 { Some(CPmLP(list_reverse(acc), pos)) }
  else {
    match cache_hex_to_param(buf, pos) {
      None -> None
      Some(cp) -> match cp { CPmP(p, p2) ->
        cache_hex_collect_param_list(buf, p2, remaining - 1, [p, ...acc])
      }
    }
  }
}

# ---- ValueMode (3-state enum) ----------------------------------------------

#[doc("KAB2 codec primitive: `cache_valuemode_to_hex`.")]
pub fn cache_valuemode_to_hex(v: ValueMode) : String = match v {
  MUnknown -> cache_byte_to_hex(1)
  MBoxed   -> cache_byte_to_hex(2)
  MUnboxed -> cache_byte_to_hex(3)
}

#[doc("KAB2 codec primitive: `cache_hex_to_valuemode`.")]
pub fn cache_hex_to_valuemode(buf: String, pos: Int) : Option[CacheVMPos] {
  match cache_hex_byte_at(buf, pos) {
    None -> None
    Some(1) -> Some(CVMP(MUnknown, pos + 1))
    Some(2) -> Some(CVMP(MBoxed, pos + 1))
    Some(3) -> Some(CVMP(MUnboxed, pos + 1))
    Some(_) -> None
  }
}

# ---- Expr / ExprKind -------------------------------------------------------
#
# `ty` rides the wire: a post-parse node carries `None`, but a typed
# node carries the inferred type that monomorph and emit read. Dropping
# it would restore a program the back end cannot lower.

pub fn cache_expr_to_hex(e: Expr) : String =
  concat_all([cache_int_to_hex(e.line),
              cache_int_to_hex(e.col),
              cache_valuemode_to_hex(e.mode),
              cache_opt_tyr_to_hex(e.ty),
              cache_exprkind_to_hex(e.kind)])

fn cache_opt_tyr_to_hex(o: Option[Ty]) : String = match o {
  None    -> cache_byte_to_hex(0)
  Some(t) -> string_concat(cache_byte_to_hex(1), cache_tyr_to_hex(t))
}

type CacheOptTyRPos = COTyRP(Option[Ty], Int)

fn cache_hex_to_opt_tyr(buf: String, pos: Int) : Option[CacheOptTyRPos] {
  match cache_hex_byte_at(buf, pos) {
    None -> None
    Some(0) -> Some(COTyRP(None, pos + 1))
    Some(1) -> match cache_hex_to_tyr(buf, pos + 1) {
      None -> None
      Some(c) -> match c { CTyRP(t, p) -> Some(COTyRP(Some(t), p)) }
    }
    Some(_) -> None
  }
}

pub fn cache_hex_to_expr(buf: String, pos: Int) : Option[CacheExprPos] {
  match cache_hex_to_int(buf, pos) {
    None -> None
    Some(c1) -> match c1 { CIP(line, p1) ->
      match cache_hex_to_int(buf, p1) {
        None -> None
        Some(c2) -> match c2 { CIP(col, p2) ->
          match cache_hex_to_valuemode(buf, p2) {
            None -> None
            Some(cvm) -> match cvm { CVMP(mode, p3) ->
              cache_expr_after_mode(buf, p3, line, col, mode)
            }
          }
        }
      }
    }
  }
}

# Discriminant byte for an `EFixed` literal's width type (and back),
# so the cache serializes the 4 fixed-width kinds compactly.
fn cache_fixed_width_tag(ty: Ty) : Int = match ty {
  TyInt32  -> 0
  TyUInt32 -> 1
  TyUInt64 -> 2
  TyByte   -> 4
  _        -> 3
}

fn cache_fixed_width_of_tag(b: Int) : Ty =
  if b == 0 { TyInt32 } else if b == 1 { TyUInt32 }
  else if b == 2 { TyUInt64 } else if b == 4 { TyByte } else { TyInt128 }

# `cache_hex_to_exprkind` returns CacheExprPos with a stub-wrapped
# Expr (line/col/mode are placeholders; the caller fills them).
fn cache_exprkind_to_hex(k: ExprKind) : String = match k {
  EInt(n)            -> concat_all([cache_byte_to_hex(1), cache_int_to_hex(n)])
  EReal(r, span)     -> concat_all([cache_byte_to_hex(2), cache_real_to_hex(r), cache_string_to_hex(span)])
  EFixed(span, ty)   -> concat_all([cache_byte_to_hex(35), cache_string_to_hex(span),
                                     cache_byte_to_hex(cache_fixed_width_tag(ty))])
  # Textual literals are minted away by the typer before caching runs.
  EIntLit(_)         -> panic("cache_exprkind_to_hex: EIntLit must be minted before caching")
  EDecimalLit(_)     -> panic("cache_exprkind_to_hex: EDecimalLit must be minted before caching")
  EBool(b)           -> concat_all([cache_byte_to_hex(3), cache_bool_to_hex(b)])
  EChar(c)           -> concat_all([cache_byte_to_hex(4), cache_char_to_hex(c)])
  EStr(s, t)         -> concat_all([cache_byte_to_hex(5), cache_string_to_hex(s),
                                     cache_bool_to_hex(t)])
  EUnit              -> cache_byte_to_hex(6)
  EVar(s)            -> concat_all([cache_byte_to_hex(7), cache_string_to_hex(s)])
  EUnder             -> cache_byte_to_hex(8)
  EPlaceholder       -> cache_byte_to_hex(9)
  ECall(f, as_)      -> concat_all([cache_byte_to_hex(10), cache_expr_to_hex(f),
                                     cache_expr_list_to_hex(as_)])
  EField(e, s)       -> concat_all([cache_byte_to_hex(11), cache_expr_to_hex(e),
                                     cache_string_to_hex(s)])
  EIndex(a, i)       -> concat_all([cache_byte_to_hex(12), cache_expr_to_hex(a),
                                     cache_expr_to_hex(i)])
  EBinop(op, a, b)   -> concat_all([cache_byte_to_hex(13), cache_string_to_hex(op),
                                     cache_expr_to_hex(a), cache_expr_to_hex(b)])
  EUnop(op, a)       -> concat_all([cache_byte_to_hex(14), cache_string_to_hex(op),
                                     cache_expr_to_hex(a)])
  EIf(c, t, eo)      -> concat_all([cache_byte_to_hex(15), cache_expr_to_hex(c),
                                     cache_expr_to_hex(t),
                                     cache_opt_expr_to_hex(eo)])
  EMatch(s, arms)    -> concat_all([cache_byte_to_hex(16), cache_expr_to_hex(s),
                                     cache_arm_list_to_hex(arms)])
  ELambda(ps, body)  -> concat_all([cache_byte_to_hex(17), cache_param_list_to_hex(ps),
                                     cache_expr_to_hex(body)])
  ERecordLit(n, fs)  -> concat_all([cache_byte_to_hex(18), cache_string_to_hex(n),
                                     cache_fi_list_to_hex(fs)])
  EList(es)          -> concat_all([cache_byte_to_hex(19), cache_le_list_to_hex(es)])
  ERange(a, b, c)    -> concat_all([cache_byte_to_hex(20), cache_expr_to_hex(a),
                                     cache_expr_to_hex(b),
                                     cache_opt_expr_to_hex(c)])
  EBlock(ss, eo)     -> concat_all([cache_byte_to_hex(21), cache_stmt_list_to_hex(ss),
                                     cache_opt_expr_to_hex(eo)])
  EPipe(a, b)        -> concat_all([cache_byte_to_hex(22), cache_expr_to_hex(a),
                                     cache_expr_to_hex(b)])
  EMapPipe(a, b)     -> concat_all([cache_byte_to_hex(23), cache_expr_to_hex(a),
                                     cache_expr_to_hex(b)])
  EFlatMapPipe(a, b) -> concat_all([cache_byte_to_hex(24), cache_expr_to_hex(a),
                                     cache_expr_to_hex(b)])
  EFilterPipe(a, b)  -> concat_all([cache_byte_to_hex(25), cache_expr_to_hex(a),
                                     cache_expr_to_hex(b)])
  EHole(on)          -> concat_all([cache_byte_to_hex(26), cache_opt_string_to_hex(on)])
  ETodo(s)           -> concat_all([cache_byte_to_hex(27), cache_string_to_hex(s)])
  EBang(e)           -> concat_all([cache_byte_to_hex(28), cache_expr_to_hex(e)])
  EHandle(body, eff, targs, init, alias, cls, ret) -> concat_all([
    cache_byte_to_hex(29), cache_expr_to_hex(body), cache_string_to_hex(eff),
    cache_typeexpr_list_to_hex(targs),
    cache_opt_expr_to_hex(init),
    cache_opt_string_to_hex(alias),
    cache_hc_list_to_hex(cls),
    cache_opt_hr_to_hex(ret)
  ])
  ELitUnit(inner, u) -> concat_all([cache_byte_to_hex(30), cache_expr_to_hex(inner),
                                     cache_unit_to_hex(u)])
  EVariantsOf(t, ns) -> concat_all([cache_byte_to_hex(31), cache_typeexpr_to_hex(t),
                                     cache_string_list_to_hex(ns)])
  EModCall(m, f)     -> concat_all([cache_byte_to_hex(32), cache_string_to_hex(m),
                                     cache_string_to_hex(f)])
  EIntrinsic(n, as_) -> concat_all([cache_byte_to_hex(33), cache_string_to_hex(n),
                                     cache_expr_list_to_hex(as_)])
  EExternBody(over)  -> concat_all([cache_byte_to_hex(34), cache_string_to_hex(over)])
}

# Decode an ExprKind. Returns `Some(CEP(stubExpr, pos))` where
# stubExpr carries the kind in `kind` plus placeholder header fields
# that the caller (cache_hex_to_expr) overrides.
fn cache_hex_to_exprkind(buf: String, pos: Int) : Option[CacheExprPos] {
  match cache_hex_byte_at(buf, pos) {
    None -> None
    Some(b) -> cache_hex_to_exprkind_body(buf, pos + 1, b)
  }
}

fn mk_stub_expr(k: ExprKind, p: Int) : CacheExprPos =
  CEP(Expr { kind: k, line: 0, col: 0, ty: None, mode: MUnknown }, p)

fn cache_hex_to_exprkind_body(buf: String, pos: Int,
                                tag: Int) : Option[CacheExprPos] {
  if tag == 1 {
    match cache_hex_to_int(buf, pos) {
      None -> None
      Some(cip) -> match cip { CIP(n, p2) -> Some(mk_stub_expr(EInt(n), p2)) }
    }
  } else if tag == 2 {
    match cache_hex_to_real(buf, pos) {
      None -> None
      Some(crp) -> match crp { CRP(r, p2) ->
        match cache_hex_to_string(buf, p2) {
          None -> None
          Some(csp) -> match csp { CSP(span, p3) ->
            Some(mk_stub_expr(EReal(r, span), p3))
          }
        }
      }
    }
  } else if tag == 3 {
    match cache_hex_to_bool(buf, pos) {
      None -> None
      Some(cbp) -> match cbp { CBP(b, p2) -> Some(mk_stub_expr(EBool(b), p2)) }
    }
  } else if tag == 4 {
    match cache_hex_to_char(buf, pos) {
      None -> None
      Some(ccp) -> match ccp { CCP(c, p2) -> Some(mk_stub_expr(EChar(c), p2)) }
    }
  } else if tag == 5 {
    match cache_hex_to_string(buf, pos) {
      None -> None
      Some(csp) -> match csp { CSP(s, p2) ->
        match cache_hex_to_bool(buf, p2) {
          None -> None
          Some(cbp) -> match cbp { CBP(t, p3) ->
            Some(mk_stub_expr(EStr(s, t), p3))
          }
        }
      }
    }
  } else if tag == 6 {
    Some(mk_stub_expr(EUnit, pos))
  } else if tag == 7 {
    match cache_hex_to_string(buf, pos) {
      None -> None
      Some(csp) -> match csp { CSP(s, p2) -> Some(mk_stub_expr(EVar(s), p2)) }
    }
  } else if tag == 8 {
    Some(mk_stub_expr(EUnder, pos))
  } else if tag == 9 {
    Some(mk_stub_expr(EPlaceholder, pos))
  } else if tag == 10 {
    match cache_hex_to_expr(buf, pos) {
      None -> None
      Some(ce1) -> match ce1 { CEP(f, p2) ->
        match cache_hex_to_expr_list(buf, p2) {
          None -> None
          Some(cel) -> match cel { CExpLP(as_, p3) ->
            Some(mk_stub_expr(ECall(f, as_), p3))
          }
        }
      }
    }
  } else if tag == 11 {
    match cache_hex_to_expr(buf, pos) {
      None -> None
      Some(ce1) -> match ce1 { CEP(e, p2) ->
        match cache_hex_to_string(buf, p2) {
          None -> None
          Some(csp) -> match csp { CSP(s, p3) ->
            Some(mk_stub_expr(EField(e, s), p3))
          }
        }
      }
    }
  } else if tag == 12 {
    match cache_hex_to_expr(buf, pos) {
      None -> None
      Some(ce1) -> match ce1 { CEP(a, p2) ->
        match cache_hex_to_expr(buf, p2) {
          None -> None
          Some(ce2) -> match ce2 { CEP(i, p3) ->
            Some(mk_stub_expr(EIndex(a, i), p3))
          }
        }
      }
    }
  } else if tag == 13 {
    match cache_hex_to_string(buf, pos) {
      None -> None
      Some(csp) -> match csp { CSP(op, p2) ->
        match cache_hex_to_expr(buf, p2) {
          None -> None
          Some(ce1) -> match ce1 { CEP(a, p3) ->
            match cache_hex_to_expr(buf, p3) {
              None -> None
              Some(ce2) -> match ce2 { CEP(b, p4) ->
                Some(mk_stub_expr(EBinop(op, a, b), p4))
              }
            }
          }
        }
      }
    }
  } else if tag == 14 {
    match cache_hex_to_string(buf, pos) {
      None -> None
      Some(csp) -> match csp { CSP(op, p2) ->
        match cache_hex_to_expr(buf, p2) {
          None -> None
          Some(ce1) -> match ce1 { CEP(a, p3) ->
            Some(mk_stub_expr(EUnop(op, a), p3))
          }
        }
      }
    }
  } else if tag == 15 {
    match cache_hex_to_expr(buf, pos) {
      None -> None
      Some(ce1) -> match ce1 { CEP(c, p2) ->
        match cache_hex_to_expr(buf, p2) {
          None -> None
          Some(ce2) -> match ce2 { CEP(t, p3) ->
            match cache_hex_to_opt_expr(buf, p3) {
              None -> None
              Some(coep) -> match coep { COExpP(eo, p4) ->
                Some(mk_stub_expr(EIf(c, t, eo), p4))
              }
            }
          }
        }
      }
    }
  } else if tag == 16 {
    match cache_hex_to_expr(buf, pos) {
      None -> None
      Some(ce1) -> match ce1 { CEP(s, p2) ->
        match cache_hex_to_arm_list(buf, p2) {
          None -> None
          Some(cal) -> match cal { CArmLP(arms, p3) ->
            Some(mk_stub_expr(EMatch(s, arms), p3))
          }
        }
      }
    }
  } else if tag == 17 {
    match cache_hex_to_param_list(buf, pos) {
      None -> None
      Some(cpl) -> match cpl { CPmLP(ps, p2) ->
        match cache_hex_to_expr(buf, p2) {
          None -> None
          Some(ce1) -> match ce1 { CEP(body, p3) ->
            Some(mk_stub_expr(ELambda(ps, body), p3))
          }
        }
      }
    }
  } else if tag == 18 {
    match cache_hex_to_string(buf, pos) {
      None -> None
      Some(csp) -> match csp { CSP(n, p2) ->
        match cache_hex_to_fi_list(buf, p2) {
          None -> None
          Some(cfl) -> match cfl { CFILP(fs, p3) ->
            Some(mk_stub_expr(ERecordLit(n, fs), p3))
          }
        }
      }
    }
  } else if tag == 19 {
    match cache_hex_to_le_list(buf, pos) {
      None -> None
      Some(clel) -> match clel { CLELP(es, p2) ->
        Some(mk_stub_expr(EList(es), p2))
      }
    }
  } else if tag == 20 {
    match cache_hex_to_expr(buf, pos) {
      None -> None
      Some(ce1) -> match ce1 { CEP(a, p2) ->
        match cache_hex_to_expr(buf, p2) {
          None -> None
          Some(ce2) -> match ce2 { CEP(b, p3) ->
            match cache_hex_to_opt_expr(buf, p3) {
              None -> None
              Some(coep) -> match coep { COExpP(c, p4) ->
                Some(mk_stub_expr(ERange(a, b, c), p4))
              }
            }
          }
        }
      }
    }
  } else if tag == 21 {
    match cache_hex_to_stmt_list(buf, pos) {
      None -> None
      Some(csl) -> match csl { CSMLP(ss, p2) ->
        match cache_hex_to_opt_expr(buf, p2) {
          None -> None
          Some(coep) -> match coep { COExpP(eo, p3) ->
            Some(mk_stub_expr(EBlock(ss, eo), p3))
          }
        }
      }
    }
  } else if tag == 22 {
    match cache_hex_to_expr(buf, pos) {
      None -> None
      Some(ce1) -> match ce1 { CEP(a, p2) ->
        match cache_hex_to_expr(buf, p2) {
          None -> None
          Some(ce2) -> match ce2 { CEP(b, p3) ->
            Some(mk_stub_expr(EPipe(a, b), p3))
          }
        }
      }
    }
  } else if tag == 23 {
    match cache_hex_to_expr(buf, pos) {
      None -> None
      Some(ce1) -> match ce1 { CEP(a, p2) ->
        match cache_hex_to_expr(buf, p2) {
          None -> None
          Some(ce2) -> match ce2 { CEP(b, p3) ->
            Some(mk_stub_expr(EMapPipe(a, b), p3))
          }
        }
      }
    }
  } else if tag == 24 {
    match cache_hex_to_expr(buf, pos) {
      None -> None
      Some(ce1) -> match ce1 { CEP(a, p2) ->
        match cache_hex_to_expr(buf, p2) {
          None -> None
          Some(ce2) -> match ce2 { CEP(b, p3) ->
            Some(mk_stub_expr(EFlatMapPipe(a, b), p3))
          }
        }
      }
    }
  } else if tag == 25 {
    match cache_hex_to_expr(buf, pos) {
      None -> None
      Some(ce1) -> match ce1 { CEP(a, p2) ->
        match cache_hex_to_expr(buf, p2) {
          None -> None
          Some(ce2) -> match ce2 { CEP(b, p3) ->
            Some(mk_stub_expr(EFilterPipe(a, b), p3))
          }
        }
      }
    }
  } else if tag == 26 {
    match cache_hex_to_opt_string(buf, pos) {
      None -> None
      Some(cosp) -> match cosp { COSP(on, p2) ->
        Some(mk_stub_expr(EHole(on), p2))
      }
    }
  } else if tag == 27 {
    match cache_hex_to_string(buf, pos) {
      None -> None
      Some(csp) -> match csp { CSP(s, p2) ->
        Some(mk_stub_expr(ETodo(s), p2))
      }
    }
  } else if tag == 28 {
    match cache_hex_to_expr(buf, pos) {
      None -> None
      Some(ce1) -> match ce1 { CEP(e, p2) ->
        Some(mk_stub_expr(EBang(e), p2))
      }
    }
  } else if tag == 29 {
    cache_hex_to_handle_body(buf, pos)
  } else if tag == 30 {
    match cache_hex_to_expr(buf, pos) {
      None -> None
      Some(ce1) -> match ce1 { CEP(inner, p2) ->
        match cache_hex_to_unit(buf, p2) {
          None -> None
          Some(cu) -> match cu { CUP(u, p3) ->
            Some(mk_stub_expr(ELitUnit(inner, u), p3))
          }
        }
      }
    }
  } else if tag == 31 {
    match cache_hex_to_typeexpr(buf, pos) {
      None -> None
      Some(ct) -> match ct { CTyP(t, p2) ->
        match cache_hex_to_string_list(buf, p2) {
          None -> None
          Some(csl) -> match csl { CSLP(ns, p3) ->
            Some(mk_stub_expr(EVariantsOf(t, ns), p3))
          }
        }
      }
    }
  } else if tag == 32 {
    match cache_hex_to_string(buf, pos) {
      None -> None
      Some(csp1) -> match csp1 { CSP(m, p2) ->
        match cache_hex_to_string(buf, p2) {
          None -> None
          Some(csp2) -> match csp2 { CSP(f, p3) ->
            Some(mk_stub_expr(EModCall(m, f), p3))
          }
        }
      }
    }
  } else if tag == 33 {
    match cache_hex_to_string(buf, pos) {
      None -> None
      Some(csp) -> match csp { CSP(n, p2) ->
        match cache_hex_to_expr_list(buf, p2) {
          None -> None
          Some(cel) -> match cel { CExpLP(as_, p3) ->
            Some(mk_stub_expr(EIntrinsic(n, as_), p3))
          }
        }
      }
    }
  } else if tag == 34 {
    match cache_hex_to_string(buf, pos) {
      None -> None
      Some(csp) -> match csp { CSP(over, p2) ->
        Some(mk_stub_expr(EExternBody(over), p2))
      }
    }
  } else if tag == 35 {
    match cache_hex_to_string(buf, pos) {
      None -> None
      Some(csp) -> match csp { CSP(span, p2) ->
        match cache_hex_byte_at(buf, p2) {
          None -> None
          Some(wb) -> Some(mk_stub_expr(EFixed(span, cache_fixed_width_of_tag(wb)), p2 + 1))
        }
      }
    }
  } else { None }
}

# `EHandle` has 7 fields — split to keep the if-chain readable.
fn cache_hex_to_handle_body(buf: String, pos: Int) : Option[CacheExprPos] {
  match cache_hex_to_expr(buf, pos) {
    None -> None
    Some(ce1) -> match ce1 { CEP(body, p1) ->
      match cache_hex_to_string(buf, p1) {
        None -> None
        Some(csp) -> match csp { CSP(eff, p2) ->
          match cache_hex_to_typeexpr_list(buf, p2) {
            None -> None
            Some(ctl) -> match ctl { CTyLP(targs, p3) ->
              match cache_hex_to_opt_expr(buf, p3) {
                None -> None
                Some(coe) -> match coe { COExpP(init, p4) ->
                  match cache_hex_to_opt_string(buf, p4) {
                    None -> None
                    Some(cos) -> match cos { COSP(alias, p5) ->
                      match cache_hex_to_hc_list(buf, p5) {
                        None -> None
                        Some(chcl) -> match chcl { CHCLP(cls, p6) ->
                          match cache_hex_to_opt_hr(buf, p6) {
                            None -> None
                            Some(cohr) -> match cohr { COHRP(ret, p7) ->
                              Some(mk_stub_expr(EHandle(body, eff, targs, init,
                                                         alias, cls, ret), p7))
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}

# `Option[Expr]` codec.
fn cache_opt_expr_to_hex(o: Option[Expr]) : String = match o {
  None -> cache_byte_to_hex(0)
  Some(e) -> concat_all([cache_byte_to_hex(1), cache_expr_to_hex(e)])
}

fn cache_hex_to_opt_expr(buf: String, pos: Int) : Option[CacheOptExpPos] {
  match cache_hex_byte_at(buf, pos) {
    None -> None
    Some(0) -> Some(COExpP(None, pos + 1))
    Some(1) -> match cache_hex_to_expr(buf, pos + 1) {
      None -> None
      Some(ce) -> match ce { CEP(e, p2) -> Some(COExpP(Some(e), p2)) }
    }
    Some(_) -> None
  }
}

# `[Expr]` codec.
fn cache_expr_list_to_hex(xs: [Expr]) : String =
  concat_all([cache_u32_to_hex(list_length(xs)),
              concat_all(list_reverse(cache_expr_list_loop(xs, [])))])

fn cache_expr_list_loop(xs: [Expr], acc: [String]) : [String] = match xs {
  [] -> acc
  [h, ...t] -> cache_expr_list_loop(t, [cache_expr_to_hex(h), ...acc])
}

fn cache_hex_to_expr_list(buf: String, pos: Int) : Option[CacheExprLPos] {
  match cache_hex_to_u32(buf, pos) {
    None -> None
    Some(cip) -> match cip { CIP(n, p2) ->
      cache_hex_collect_expr_list(buf, p2, n, [])
    }
  }
}

fn cache_hex_collect_expr_list(buf: String, pos: Int, remaining: Int,
                                 acc: [Expr]) : Option[CacheExprLPos] {
  if remaining <= 0 { Some(CExpLP(list_reverse(acc), pos)) }
  else {
    match cache_hex_to_expr(buf, pos) {
      None -> None
      Some(ce) -> match ce { CEP(e, p2) ->
        cache_hex_collect_expr_list(buf, p2, remaining - 1, [e, ...acc])
      }
    }
  }
}

# ---- ListElem --------------------------------------------------------------

fn cache_le_to_hex(le: ListElem) : String = match le {
  ElPlain(e)  -> concat_all([cache_byte_to_hex(1), cache_expr_to_hex(e)])
  ElSpread(e) -> concat_all([cache_byte_to_hex(2), cache_expr_to_hex(e)])
}

fn cache_hex_to_le(buf: String, pos: Int) : Option[CacheLEPos] {
  match cache_hex_byte_at(buf, pos) {
    None -> None
    Some(1) -> match cache_hex_to_expr(buf, pos + 1) {
      None -> None
      Some(ce) -> match ce { CEP(e, p2) -> Some(CLEP(ElPlain(e), p2)) }
    }
    Some(2) -> match cache_hex_to_expr(buf, pos + 1) {
      None -> None
      Some(ce) -> match ce { CEP(e, p2) -> Some(CLEP(ElSpread(e), p2)) }
    }
    Some(_) -> None
  }
}

fn cache_le_list_to_hex(xs: [ListElem]) : String =
  concat_all([cache_u32_to_hex(list_length(xs)),
              concat_all(list_reverse(cache_le_list_loop(xs, [])))])

fn cache_le_list_loop(xs: [ListElem], acc: [String]) : [String] = match xs {
  [] -> acc
  [h, ...t] -> cache_le_list_loop(t, [cache_le_to_hex(h), ...acc])
}

fn cache_hex_to_le_list(buf: String, pos: Int) : Option[CacheLELPos] {
  match cache_hex_to_u32(buf, pos) {
    None -> None
    Some(cip) -> match cip { CIP(n, p2) ->
      cache_hex_collect_le_list(buf, p2, n, [])
    }
  }
}

fn cache_hex_collect_le_list(buf: String, pos: Int, remaining: Int,
                               acc: [ListElem]) : Option[CacheLELPos] {
  if remaining <= 0 { Some(CLELP(list_reverse(acc), pos)) }
  else {
    match cache_hex_to_le(buf, pos) {
      None -> None
      Some(cle) -> match cle { CLEP(le, p2) ->
        cache_hex_collect_le_list(buf, p2, remaining - 1, [le, ...acc])
      }
    }
  }
}

# ---- Arm -------------------------------------------------------------------

fn cache_arm_to_hex(a: Arm) : String = match a {
  Arm(p, g, body) -> concat_all([cache_pat_to_hex(p),
                                   cache_opt_expr_to_hex(g),
                                   cache_expr_to_hex(body)])
}

fn cache_hex_to_arm(buf: String, pos: Int) : Option[CacheArmPos] {
  match cache_hex_to_pat(buf, pos) {
    None -> None
    Some(cp) -> match cp { CPaP(p, p1) ->
      match cache_hex_to_opt_expr(buf, p1) {
        None -> None
        Some(coe) -> match coe { COExpP(g, p2) ->
          match cache_hex_to_expr(buf, p2) {
            None -> None
            Some(ce) -> match ce { CEP(body, p3) ->
              Some(CArmP(Arm(p, g, body), p3))
            }
          }
        }
      }
    }
  }
}

fn cache_arm_list_to_hex(xs: [Arm]) : String =
  concat_all([cache_u32_to_hex(list_length(xs)),
              concat_all(list_reverse(cache_arm_list_loop(xs, [])))])

fn cache_arm_list_loop(xs: [Arm], acc: [String]) : [String] = match xs {
  [] -> acc
  [h, ...t] -> cache_arm_list_loop(t, [cache_arm_to_hex(h), ...acc])
}

fn cache_hex_to_arm_list(buf: String, pos: Int) : Option[CacheArmLPos] {
  match cache_hex_to_u32(buf, pos) {
    None -> None
    Some(cip) -> match cip { CIP(n, p2) ->
      cache_hex_collect_arm_list(buf, p2, n, [])
    }
  }
}

fn cache_hex_collect_arm_list(buf: String, pos: Int, remaining: Int,
                                acc: [Arm]) : Option[CacheArmLPos] {
  if remaining <= 0 { Some(CArmLP(list_reverse(acc), pos)) }
  else {
    match cache_hex_to_arm(buf, pos) {
      None -> None
      Some(ca) -> match ca { CArmP(a, p2) ->
        cache_hex_collect_arm_list(buf, p2, remaining - 1, [a, ...acc])
      }
    }
  }
}

# ---- FieldInit -------------------------------------------------------------

fn cache_fi_to_hex(fi: FieldInit) : String = match fi {
  FI(n, e) -> concat_all([cache_string_to_hex(n), cache_expr_to_hex(e)])
}

fn cache_hex_to_fi(buf: String, pos: Int) : Option[CacheFIPos] {
  match cache_hex_to_string(buf, pos) {
    None -> None
    Some(csp) -> match csp { CSP(n, p1) ->
      match cache_hex_to_expr(buf, p1) {
        None -> None
        Some(ce) -> match ce { CEP(e, p2) -> Some(CFIP(FI(n, e), p2)) }
      }
    }
  }
}

fn cache_fi_list_to_hex(xs: [FieldInit]) : String =
  concat_all([cache_u32_to_hex(list_length(xs)),
              concat_all(list_reverse(cache_fi_list_loop(xs, [])))])

fn cache_fi_list_loop(xs: [FieldInit], acc: [String]) : [String] = match xs {
  [] -> acc
  [h, ...t] -> cache_fi_list_loop(t, [cache_fi_to_hex(h), ...acc])
}

fn cache_hex_to_fi_list(buf: String, pos: Int) : Option[CacheFILPos] {
  match cache_hex_to_u32(buf, pos) {
    None -> None
    Some(cip) -> match cip { CIP(n, p2) ->
      cache_hex_collect_fi_list(buf, p2, n, [])
    }
  }
}

fn cache_hex_collect_fi_list(buf: String, pos: Int, remaining: Int,
                                acc: [FieldInit]) : Option[CacheFILPos] {
  if remaining <= 0 { Some(CFILP(list_reverse(acc), pos)) }
  else {
    match cache_hex_to_fi(buf, pos) {
      None -> None
      Some(cf) -> match cf { CFIP(fi, p2) ->
        cache_hex_collect_fi_list(buf, p2, remaining - 1, [fi, ...acc])
      }
    }
  }
}

# ---- Pattern / PatKind / PField -------------------------------------------

fn cache_pat_to_hex(p: Pattern) : String =
  concat_all([cache_int_to_hex(p.line),
              cache_int_to_hex(p.col),
              cache_patkind_to_hex(p.pkind)])

fn cache_patkind_to_hex(k: PatKind) : String = match k {
  PWild                  -> cache_byte_to_hex(1)
  PLit(e)                -> concat_all([cache_byte_to_hex(2), cache_expr_to_hex(e)])
  PBind(s)               -> concat_all([cache_byte_to_hex(3), cache_string_to_hex(s)])
  PList(ps, on)          -> concat_all([cache_byte_to_hex(4), cache_pat_list_to_hex(ps),
                                         cache_opt_string_to_hex(on)])
  PVariant(s, ps)        -> concat_all([cache_byte_to_hex(5), cache_string_to_hex(s),
                                         cache_pat_list_to_hex(ps)])
  PVariantRecord(s, pfs) -> concat_all([cache_byte_to_hex(6), cache_string_to_hex(s),
                                         cache_pf_list_to_hex(pfs)])
  PRecord(pfs)           -> concat_all([cache_byte_to_hex(7), cache_pf_list_to_hex(pfs)])
  PHole(on)              -> concat_all([cache_byte_to_hex(8), cache_opt_string_to_hex(on)])
  PAs(s, p)              -> concat_all([cache_byte_to_hex(9), cache_string_to_hex(s),
                                         cache_pat_to_hex(p)])
  PNarrow(s, t)          -> concat_all([cache_byte_to_hex(10), cache_string_to_hex(s),
                                         cache_typeexpr_to_hex(t)])
  PRange(lo, hi)         -> concat_all([cache_byte_to_hex(11), cache_expr_to_hex(lo),
                                         cache_expr_to_hex(hi)])
}

fn cache_hex_to_pat(buf: String, pos: Int) : Option[CachePatPos] {
  match cache_hex_to_int(buf, pos) {
    None -> None
    Some(c1) -> match c1 { CIP(line, p1) ->
      match cache_hex_to_int(buf, p1) {
        None -> None
        Some(c2) -> match c2 { CIP(col, p2) ->
          match cache_hex_to_patkind(buf, p2) {
            None -> None
            Some(cpk) -> match cpk { CPaP(stub, p3) ->
              Some(CPaP(Pattern { pkind: stub.pkind, line: line, col: col }, p3))
            }
          }
        }
      }
    }
  }
}

fn mk_stub_pat(k: PatKind, p: Int) : CachePatPos =
  CPaP(Pattern { pkind: k, line: 0, col: 0 }, p)

fn cache_hex_to_patkind(buf: String, pos: Int) : Option[CachePatPos] {
  match cache_hex_byte_at(buf, pos) {
    None -> None
    Some(b) -> cache_hex_to_patkind_body(buf, pos + 1, b)
  }
}

fn cache_hex_to_patkind_body(buf: String, pos: Int,
                               tag: Int) : Option[CachePatPos] {
  if tag == 1 {
    Some(mk_stub_pat(PWild, pos))
  } else if tag == 2 {
    match cache_hex_to_expr(buf, pos) {
      None -> None
      Some(ce) -> match ce { CEP(e, p2) -> Some(mk_stub_pat(PLit(e), p2)) }
    }
  } else if tag == 3 {
    match cache_hex_to_string(buf, pos) {
      None -> None
      Some(csp) -> match csp { CSP(s, p2) -> Some(mk_stub_pat(PBind(s), p2)) }
    }
  } else if tag == 4 {
    match cache_hex_to_pat_list(buf, pos) {
      None -> None
      Some(cpl) -> match cpl { CPaLP(ps, p2) ->
        match cache_hex_to_opt_string(buf, p2) {
          None -> None
          Some(cos) -> match cos { COSP(on, p3) ->
            Some(mk_stub_pat(PList(ps, on), p3))
          }
        }
      }
    }
  } else if tag == 5 {
    match cache_hex_to_string(buf, pos) {
      None -> None
      Some(csp) -> match csp { CSP(s, p2) ->
        match cache_hex_to_pat_list(buf, p2) {
          None -> None
          Some(cpl) -> match cpl { CPaLP(ps, p3) ->
            Some(mk_stub_pat(PVariant(s, ps), p3))
          }
        }
      }
    }
  } else if tag == 6 {
    match cache_hex_to_string(buf, pos) {
      None -> None
      Some(csp) -> match csp { CSP(s, p2) ->
        match cache_hex_to_pf_list(buf, p2) {
          None -> None
          Some(cpfl) -> match cpfl { CPFLP(pfs, p3) ->
            Some(mk_stub_pat(PVariantRecord(s, pfs), p3))
          }
        }
      }
    }
  } else if tag == 7 {
    match cache_hex_to_pf_list(buf, pos) {
      None -> None
      Some(cpfl) -> match cpfl { CPFLP(pfs, p2) ->
        Some(mk_stub_pat(PRecord(pfs), p2))
      }
    }
  } else if tag == 8 {
    match cache_hex_to_opt_string(buf, pos) {
      None -> None
      Some(cos) -> match cos { COSP(on, p2) ->
        Some(mk_stub_pat(PHole(on), p2))
      }
    }
  } else if tag == 9 {
    match cache_hex_to_string(buf, pos) {
      None -> None
      Some(csp) -> match csp { CSP(s, p2) ->
        match cache_hex_to_pat(buf, p2) {
          None -> None
          Some(cpi) -> match cpi { CPaP(p, p3) ->
            Some(mk_stub_pat(PAs(s, p), p3))
          }
        }
      }
    }
  } else if tag == 10 {
    match cache_hex_to_string(buf, pos) {
      None -> None
      Some(csp) -> match csp { CSP(s, p2) ->
        match cache_hex_to_typeexpr(buf, p2) {
          None -> None
          Some(ct) -> match ct { CTyP(t, p3) ->
            Some(mk_stub_pat(PNarrow(s, t), p3))
          }
        }
      }
    }
  } else if tag == 11 {
    match cache_hex_to_expr(buf, pos) {
      None -> None
      Some(clo) -> match clo { CEP(lo, p2) ->
        match cache_hex_to_expr(buf, p2) {
          None -> None
          Some(chi) -> match chi { CEP(hi, p3) ->
            Some(mk_stub_pat(PRange(lo, hi), p3))
          }
        }
      }
    }
  } else { None }
}

fn cache_pat_list_to_hex(xs: [Pattern]) : String =
  concat_all([cache_u32_to_hex(list_length(xs)),
              concat_all(list_reverse(cache_pat_list_loop(xs, [])))])

fn cache_pat_list_loop(xs: [Pattern], acc: [String]) : [String] = match xs {
  [] -> acc
  [h, ...t] -> cache_pat_list_loop(t, [cache_pat_to_hex(h), ...acc])
}

fn cache_hex_to_pat_list(buf: String, pos: Int) : Option[CachePatLPos] {
  match cache_hex_to_u32(buf, pos) {
    None -> None
    Some(cip) -> match cip { CIP(n, p2) ->
      cache_hex_collect_pat_list(buf, p2, n, [])
    }
  }
}

fn cache_hex_collect_pat_list(buf: String, pos: Int, remaining: Int,
                                acc: [Pattern]) : Option[CachePatLPos] {
  if remaining <= 0 { Some(CPaLP(list_reverse(acc), pos)) }
  else {
    match cache_hex_to_pat(buf, pos) {
      None -> None
      Some(cp) -> match cp { CPaP(p, p2) ->
        cache_hex_collect_pat_list(buf, p2, remaining - 1, [p, ...acc])
      }
    }
  }
}

fn cache_pf_to_hex(pf: PField) : String = match pf {
  PField(n, p, sh) -> concat_all([cache_string_to_hex(n),
                                    cache_pat_to_hex(p),
                                    cache_bool_to_hex(sh)])
}

fn cache_hex_to_pf(buf: String, pos: Int) : Option[CachePFPos] {
  match cache_hex_to_string(buf, pos) {
    None -> None
    Some(csp) -> match csp { CSP(n, p1) ->
      match cache_hex_to_pat(buf, p1) {
        None -> None
        Some(cp) -> match cp { CPaP(p, p2) ->
          match cache_hex_to_bool(buf, p2) {
            None -> None
            Some(cbp) -> match cbp { CBP(sh, p3) ->
              Some(CPFP(PField(n, p, sh), p3))
            }
          }
        }
      }
    }
  }
}

fn cache_pf_list_to_hex(xs: [PField]) : String =
  concat_all([cache_u32_to_hex(list_length(xs)),
              concat_all(list_reverse(cache_pf_list_loop(xs, [])))])

fn cache_pf_list_loop(xs: [PField], acc: [String]) : [String] = match xs {
  [] -> acc
  [h, ...t] -> cache_pf_list_loop(t, [cache_pf_to_hex(h), ...acc])
}

fn cache_hex_to_pf_list(buf: String, pos: Int) : Option[CachePFLPos] {
  match cache_hex_to_u32(buf, pos) {
    None -> None
    Some(cip) -> match cip { CIP(n, p2) ->
      cache_hex_collect_pf_list(buf, p2, n, [])
    }
  }
}

fn cache_hex_collect_pf_list(buf: String, pos: Int, remaining: Int,
                               acc: [PField]) : Option[CachePFLPos] {
  if remaining <= 0 { Some(CPFLP(list_reverse(acc), pos)) }
  else {
    match cache_hex_to_pf(buf, pos) {
      None -> None
      Some(cpf) -> match cpf { CPFP(pf, p2) ->
        cache_hex_collect_pf_list(buf, p2, remaining - 1, [pf, ...acc])
      }
    }
  }
}

# ---- Stmt ------------------------------------------------------------------

fn cache_stmt_to_hex(s: Stmt) : String = match s {
  SLet(p, ot, e)         -> concat_all([cache_byte_to_hex(1), cache_pat_to_hex(p),
                                          cache_opt_typeexpr_to_hex(ot),
                                          cache_expr_to_hex(e)])
  SAssert(c, om)         -> concat_all([cache_byte_to_hex(2), cache_expr_to_hex(c),
                                          cache_opt_expr_to_hex(om)])
  SExprStmt(e)           -> concat_all([cache_byte_to_hex(3), cache_expr_to_hex(e)])
  SIndexAssign(a, i, v, l, c) -> concat_all([cache_byte_to_hex(4), cache_expr_to_hex(a),
                                          cache_expr_to_hex(i),
                                          cache_expr_to_hex(v),
                                          cache_int_to_hex(l),
                                          cache_int_to_hex(c)])
  SVar(n, ot, init, l, c) -> concat_all([cache_byte_to_hex(5), cache_string_to_hex(n),
                                          cache_opt_typeexpr_to_hex(ot),
                                          cache_expr_to_hex(init),
                                          cache_int_to_hex(l),
                                          cache_int_to_hex(c)])
  SUse(n, l, c)          -> concat_all([cache_byte_to_hex(6), cache_string_to_hex(n),
                                          cache_int_to_hex(l),
                                          cache_int_to_hex(c)])
}

fn cache_hex_to_stmt(buf: String, pos: Int) : Option[CacheStmtPos] {
  match cache_hex_byte_at(buf, pos) {
    None -> None
    Some(b) -> cache_hex_to_stmt_body(buf, pos + 1, b)
  }
}

fn cache_hex_to_stmt_body(buf: String, pos: Int,
                            tag: Int) : Option[CacheStmtPos] {
  if tag == 1 {
    match cache_hex_to_pat(buf, pos) {
      None -> None
      Some(cp) -> match cp { CPaP(p, p1) ->
        match cache_hex_to_opt_typeexpr(buf, p1) {
          None -> None
          Some(cot) -> match cot { COTyP(ot, p2) ->
            match cache_hex_to_expr(buf, p2) {
              None -> None
              Some(ce) -> match ce { CEP(e, p3) ->
                Some(CSMP(SLet(p, ot, e), p3))
              }
            }
          }
        }
      }
    }
  } else if tag == 2 {
    match cache_hex_to_expr(buf, pos) {
      None -> None
      Some(ce) -> match ce { CEP(c, p1) ->
        match cache_hex_to_opt_expr(buf, p1) {
          None -> None
          Some(coe) -> match coe { COExpP(om, p2) ->
            Some(CSMP(SAssert(c, om), p2))
          }
        }
      }
    }
  } else if tag == 3 {
    match cache_hex_to_expr(buf, pos) {
      None -> None
      Some(ce) -> match ce { CEP(e, p1) -> Some(CSMP(SExprStmt(e), p1)) }
    }
  } else if tag == 4 {
    match cache_hex_to_expr(buf, pos) {
      None -> None
      Some(ce1) -> match ce1 { CEP(a, p1) ->
        match cache_hex_to_expr(buf, p1) {
          None -> None
          Some(ce2) -> match ce2 { CEP(i, p2) ->
            match cache_hex_to_expr(buf, p2) {
              None -> None
              Some(ce3) -> match ce3 { CEP(v, p3) ->
                match cache_hex_to_int(buf, p3) {
                  None -> None
                  Some(cl) -> match cl { CIP(ln, p4) ->
                    match cache_hex_to_int(buf, p4) {
                      None -> None
                      Some(cc) -> match cc { CIP(cn, p5) ->
                        Some(CSMP(SIndexAssign(a, i, v, ln, cn), p5))
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  } else if tag == 5 {
    match cache_hex_to_string(buf, pos) {
      None -> None
      Some(csp) -> match csp { CSP(n, p1) ->
        match cache_hex_to_opt_typeexpr(buf, p1) {
          None -> None
          Some(cot) -> match cot { COTyP(ot, p2) ->
            match cache_hex_to_expr(buf, p2) {
              None -> None
              Some(ce) -> match ce { CEP(init, p3) ->
                match cache_hex_to_int(buf, p3) {
                  None -> None
                  Some(cl) -> match cl { CIP(ln, p4) ->
                    match cache_hex_to_int(buf, p4) {
                      None -> None
                      Some(cc) -> match cc { CIP(cn, p5) ->
                        Some(CSMP(SVar(n, ot, init, ln, cn), p5))
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  } else if tag == 6 {
    match cache_hex_to_string(buf, pos) {
      None -> None
      Some(csp) -> match csp { CSP(n, p1) ->
        match cache_hex_to_int(buf, p1) {
          None -> None
          Some(cl) -> match cl { CIP(ln, p2) ->
            match cache_hex_to_int(buf, p2) {
              None -> None
              Some(cc) -> match cc { CIP(cn, p3) ->
                Some(CSMP(SUse(n, ln, cn), p3))
              }
            }
          }
        }
      }
    }
  } else { None }
}

fn cache_stmt_list_to_hex(xs: [Stmt]) : String =
  concat_all([cache_u32_to_hex(list_length(xs)),
              concat_all(list_reverse(cache_stmt_list_loop(xs, [])))])

fn cache_stmt_list_loop(xs: [Stmt], acc: [String]) : [String] = match xs {
  [] -> acc
  [h, ...t] -> cache_stmt_list_loop(t, [cache_stmt_to_hex(h), ...acc])
}

fn cache_hex_to_stmt_list(buf: String, pos: Int) : Option[CacheStmtLPos] {
  match cache_hex_to_u32(buf, pos) {
    None -> None
    Some(cip) -> match cip { CIP(n, p2) ->
      cache_hex_collect_stmt_list(buf, p2, n, [])
    }
  }
}

fn cache_hex_collect_stmt_list(buf: String, pos: Int, remaining: Int,
                                 acc: [Stmt]) : Option[CacheStmtLPos] {
  if remaining <= 0 { Some(CSMLP(list_reverse(acc), pos)) }
  else {
    match cache_hex_to_stmt(buf, pos) {
      None -> None
      Some(cs) -> match cs { CSMP(s, p2) ->
        cache_hex_collect_stmt_list(buf, p2, remaining - 1, [s, ...acc])
      }
    }
  }
}

# ---- HClause / HReturn / DefaultBlock -------------------------------------

fn cache_hc_to_hex(hc: HClause) : String = match hc {
  HC(name, ps, body, l, c) -> concat_all([cache_string_to_hex(name),
                                            cache_param_list_to_hex(ps),
                                            cache_expr_to_hex(body),
                                            cache_int_to_hex(l),
                                            cache_int_to_hex(c)])
}

fn cache_hex_to_hc(buf: String, pos: Int) : Option[CacheHCPos] {
  match cache_hex_to_string(buf, pos) {
    None -> None
    Some(csp) -> match csp { CSP(name, p1) ->
      match cache_hex_to_param_list(buf, p1) {
        None -> None
        Some(cpl) -> match cpl { CPmLP(ps, p2) ->
          match cache_hex_to_expr(buf, p2) {
            None -> None
            Some(ce) -> match ce { CEP(body, p3) ->
              match cache_hex_to_int(buf, p3) {
                None -> None
                Some(cl) -> match cl { CIP(ln, p4) ->
                  match cache_hex_to_int(buf, p4) {
                    None -> None
                    Some(cc) -> match cc { CIP(cn, p5) ->
                      Some(CHCP(HC(name, ps, body, ln, cn), p5))
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}

fn cache_hc_list_to_hex(xs: [HClause]) : String =
  concat_all([cache_u32_to_hex(list_length(xs)),
              concat_all(list_reverse(cache_hc_list_loop(xs, [])))])

fn cache_hc_list_loop(xs: [HClause], acc: [String]) : [String] = match xs {
  [] -> acc
  [h, ...t] -> cache_hc_list_loop(t, [cache_hc_to_hex(h), ...acc])
}

fn cache_hex_to_hc_list(buf: String, pos: Int) : Option[CacheHCLPos] {
  match cache_hex_to_u32(buf, pos) {
    None -> None
    Some(cip) -> match cip { CIP(n, p2) ->
      cache_hex_collect_hc_list(buf, p2, n, [])
    }
  }
}

fn cache_hex_collect_hc_list(buf: String, pos: Int, remaining: Int,
                                acc: [HClause]) : Option[CacheHCLPos] {
  if remaining <= 0 { Some(CHCLP(list_reverse(acc), pos)) }
  else {
    match cache_hex_to_hc(buf, pos) {
      None -> None
      Some(chc) -> match chc { CHCP(hc, p2) ->
        cache_hex_collect_hc_list(buf, p2, remaining - 1, [hc, ...acc])
      }
    }
  }
}

fn cache_hr_to_hex(hr: HReturn) : String = match hr {
  HR(name, body, l, c) -> concat_all([cache_string_to_hex(name),
                                        cache_expr_to_hex(body),
                                        cache_int_to_hex(l),
                                        cache_int_to_hex(c)])
}

fn cache_hex_to_hr(buf: String, pos: Int) : Option[CacheHRPos] {
  match cache_hex_to_string(buf, pos) {
    None -> None
    Some(csp) -> match csp { CSP(name, p1) ->
      match cache_hex_to_expr(buf, p1) {
        None -> None
        Some(ce) -> match ce { CEP(body, p2) ->
          match cache_hex_to_int(buf, p2) {
            None -> None
            Some(cl) -> match cl { CIP(ln, p3) ->
              match cache_hex_to_int(buf, p3) {
                None -> None
                Some(cc) -> match cc { CIP(cn, p4) ->
                  Some(CHRP(HR(name, body, ln, cn), p4))
                }
              }
            }
          }
        }
      }
    }
  }
}

fn cache_opt_hr_to_hex(o: Option[HReturn]) : String = match o {
  None     -> cache_byte_to_hex(0)
  Some(hr) -> concat_all([cache_byte_to_hex(1), cache_hr_to_hex(hr)])
}

fn cache_hex_to_opt_hr(buf: String, pos: Int) : Option[CacheOptHRPos] {
  match cache_hex_byte_at(buf, pos) {
    None -> None
    Some(0) -> Some(COHRP(None, pos + 1))
    Some(1) -> match cache_hex_to_hr(buf, pos + 1) {
      None -> None
      Some(chr) -> match chr { CHRP(hr, p2) -> Some(COHRP(Some(hr), p2)) }
    }
    Some(_) -> None
  }
}

fn cache_db_to_hex(d: DefaultBlock) : String = match d {
  DBlk(cls, ret, l, c) -> concat_all([cache_hc_list_to_hex(cls),
                                        cache_opt_hr_to_hex(ret),
                                        cache_int_to_hex(l),
                                        cache_int_to_hex(c)])
}

fn cache_hex_to_db(buf: String, pos: Int) : Option[CacheDBPos] {
  match cache_hex_to_hc_list(buf, pos) {
    None -> None
    Some(chcl) -> match chcl { CHCLP(cls, p1) ->
      match cache_hex_to_opt_hr(buf, p1) {
        None -> None
        Some(cohr) -> match cohr { COHRP(ret, p2) ->
          match cache_hex_to_int(buf, p2) {
            None -> None
            Some(cl) -> match cl { CIP(ln, p3) ->
              match cache_hex_to_int(buf, p3) {
                None -> None
                Some(cc) -> match cc { CIP(cn, p4) ->
                  Some(CDBP(DBlk(cls, ret, ln, cn), p4))
                }
              }
            }
          }
        }
      }
    }
  }
}

fn cache_opt_db_to_hex(o: Option[DefaultBlock]) : String = match o {
  None    -> cache_byte_to_hex(0)
  Some(d) -> concat_all([cache_byte_to_hex(1), cache_db_to_hex(d)])
}

fn cache_hex_to_opt_db(buf: String, pos: Int) : Option[CacheOptDBPos] {
  match cache_hex_byte_at(buf, pos) {
    None -> None
    Some(0) -> Some(CODBP(None, pos + 1))
    Some(1) -> match cache_hex_to_db(buf, pos + 1) {
      None -> None
      Some(cdb) -> match cdb { CDBP(d, p2) -> Some(CODBP(Some(d), p2)) }
    }
    Some(_) -> None
  }
}

# ---- FieldAttr ------------------------------------------------------------

pub type CacheFAPos     = CFAP([FieldAttr], Int)
type CacheFA1Pos    = CFA1(FieldAttr, Int)

# `[FieldAttr]` round-trip: a u32 length, then one tag byte per attr
# (0=rename, 1=default, 2=skip) with its payload. The default's Expr
# rides the shared expr codec, so a `default = 0` -> `default = 1` edit
# changes the serialised bytes and invalidates the incremental rebuild.
#[doc("Serialise a field's `[FieldAttr]` list for the module cache and the delta hash, including the default expression so a default-value edit invalidates the rebuild.")]
pub fn cache_fattrs_to_hex(attrs: [FieldAttr]) : String =
  concat_all([cache_u32_to_hex(list_length(attrs)),
              concat_all(list_reverse(cache_fattrs_loop(attrs, [])))])

fn cache_fattrs_loop(attrs: [FieldAttr], acc: [String]) : [String] = match attrs {
  [] -> acc
  [a, ...t] -> cache_fattrs_loop(t, [cache_fattr_to_hex(a), ...acc])
}

fn cache_fattr_to_hex(a: FieldAttr) : String = match a {
  FAJsonRename(n)  -> concat_all([cache_byte_to_hex(0), cache_string_to_hex(n)])
  FAJsonDefault(e) -> concat_all([cache_byte_to_hex(1), cache_expr_to_hex(e)])
  FAJsonSkip       -> cache_byte_to_hex(2)
}

#[doc("Decode a field's `[FieldAttr]` list at `pos`; the second slot is the cursor past the consumed bytes.")]
pub fn cache_hex_to_fattrs(buf: String, pos: Int) : Option[CacheFAPos] {
  match cache_hex_to_u32(buf, pos) {
    None -> None
    Some(cip) -> match cip { CIP(n, p2) ->
      cache_hex_collect_fattrs(buf, p2, n, [])
    }
  }
}

fn cache_hex_collect_fattrs(buf: String, pos: Int, remaining: Int,
                             acc: [FieldAttr]) : Option[CacheFAPos] {
  if remaining <= 0 { Some(CFAP(list_reverse(acc), pos)) }
  else {
    match cache_hex_to_fattr(buf, pos) {
      None -> None
      Some(cfa) -> match cfa { CFA1(a, p2) ->
        cache_hex_collect_fattrs(buf, p2, remaining - 1, [a, ...acc])
      }
    }
  }
}

fn cache_hex_to_fattr(buf: String, pos: Int) : Option[CacheFA1Pos] {
  match cache_hex_byte_at(buf, pos) {
    None -> None
    Some(tag) -> {
      let p1 = pos + 1
      if tag == 0 {
        match cache_hex_to_string(buf, p1) {
          None -> None
          Some(csp) -> match csp { CSP(n, p2) -> Some(CFA1(FAJsonRename(n), p2)) }
        }
      } else if tag == 1 {
        match cache_hex_to_expr(buf, p1) {
          None -> None
          Some(cep) -> match cep { CEP(e, p2) -> Some(CFA1(FAJsonDefault(e), p2)) }
        }
      } else {
        Some(CFA1(FAJsonSkip, p1))
      }
    }
  }
}

# ---- FieldDecl / Variant / TypeBody ---------------------------------------

fn cache_fd_to_hex(fd: FieldDecl) : String = match fd {
  FD(is_pub, n, t, attrs) -> concat_all([cache_bool_to_hex(is_pub),
                                   cache_string_to_hex(n),
                                   cache_typeexpr_to_hex(t),
                                   cache_fattrs_to_hex(attrs)])
}

fn cache_hex_to_fd(buf: String, pos: Int) : Option[CacheFDPos] {
  match cache_hex_to_bool(buf, pos) {
    None -> None
    Some(cbp) -> match cbp { CBP(is_pub, p0) ->
      match cache_hex_to_string(buf, p0) {
        None -> None
        Some(csp) -> match csp { CSP(n, p1) ->
          match cache_hex_to_typeexpr(buf, p1) {
            None -> None
            Some(ct) -> match ct { CTyP(t, p2) ->
              match cache_hex_to_fattrs(buf, p2) {
                None -> None
                Some(cfap) -> match cfap { CFAP(attrs, p3) ->
                  Some(CFDP(FD(is_pub, n, t, attrs), p3))
                }
              }
            }
          }
        }
      }
    }
  }
}

fn cache_fd_list_to_hex(xs: [FieldDecl]) : String =
  concat_all([cache_u32_to_hex(list_length(xs)),
              concat_all(list_reverse(cache_fd_list_loop(xs, [])))])

fn cache_fd_list_loop(xs: [FieldDecl], acc: [String]) : [String] = match xs {
  [] -> acc
  [h, ...t] -> cache_fd_list_loop(t, [cache_fd_to_hex(h), ...acc])
}

#[doc("Decode a `[FieldDecl]` payload chunk at `pos`; the second slot is the cursor past the consumed bytes.")]
pub fn cache_hex_to_fd_list(buf: String, pos: Int) : Option[CacheFDLPos] {
  match cache_hex_to_u32(buf, pos) {
    None -> None
    Some(cip) -> match cip { CIP(n, p2) ->
      cache_hex_collect_fd_list(buf, p2, n, [])
    }
  }
}

fn cache_hex_collect_fd_list(buf: String, pos: Int, remaining: Int,
                                acc: [FieldDecl]) : Option[CacheFDLPos] {
  if remaining <= 0 { Some(CFDLP(list_reverse(acc), pos)) }
  else {
    match cache_hex_to_fd(buf, pos) {
      None -> None
      Some(cfd) -> match cfd { CFDP(fd, p2) ->
        cache_hex_collect_fd_list(buf, p2, remaining - 1, [fd, ...acc])
      }
    }
  }
}

fn cache_var_to_hex(v: Variant) : String = match v {
  Var(n, ts) -> concat_all([cache_string_to_hex(n),
                              cache_typeexpr_list_to_hex(ts)])
}

fn cache_hex_to_var(buf: String, pos: Int) : Option[CacheVarPos] {
  match cache_hex_to_string(buf, pos) {
    None -> None
    Some(csp) -> match csp { CSP(n, p1) ->
      match cache_hex_to_typeexpr_list(buf, p1) {
        None -> None
        Some(ctl) -> match ctl { CTyLP(ts, p2) -> Some(CVarP(Var(n, ts), p2)) }
      }
    }
  }
}

fn cache_var_list_to_hex(xs: [Variant]) : String =
  concat_all([cache_u32_to_hex(list_length(xs)),
              concat_all(list_reverse(cache_var_list_loop(xs, [])))])

fn cache_var_list_loop(xs: [Variant], acc: [String]) : [String] = match xs {
  [] -> acc
  [h, ...t] -> cache_var_list_loop(t, [cache_var_to_hex(h), ...acc])
}

#[doc("Decode a `[Variant]` payload chunk at `pos`; the second slot is the cursor past the consumed bytes.")]
pub fn cache_hex_to_var_list(buf: String, pos: Int) : Option[CacheVarLPos] {
  match cache_hex_to_u32(buf, pos) {
    None -> None
    Some(cip) -> match cip { CIP(n, p2) ->
      cache_hex_collect_var_list(buf, p2, n, [])
    }
  }
}

fn cache_hex_collect_var_list(buf: String, pos: Int, remaining: Int,
                                acc: [Variant]) : Option[CacheVarLPos] {
  if remaining <= 0 { Some(CVarLP(list_reverse(acc), pos)) }
  else {
    match cache_hex_to_var(buf, pos) {
      None -> None
      Some(cv) -> match cv { CVarP(v, p2) ->
        cache_hex_collect_var_list(buf, p2, remaining - 1, [v, ...acc])
      }
    }
  }
}

fn cache_tb_to_hex(tb: TypeBody) : String = match tb {
  TBAlias(t)       -> concat_all([cache_byte_to_hex(1), cache_typeexpr_to_hex(t)])
  TBRecord(fds)    -> concat_all([cache_byte_to_hex(2), cache_fd_list_to_hex(fds)])
  TBSum(vs)        -> concat_all([cache_byte_to_hex(3), cache_var_list_to_hex(vs)])
  TBEffectAlias(ls) -> concat_all([cache_byte_to_hex(4), cache_string_list_to_hex(ls)])
}

fn cache_hex_to_tb(buf: String, pos: Int) : Option[CacheTBPos] {
  match cache_hex_byte_at(buf, pos) {
    None -> None
    Some(1) -> match cache_hex_to_typeexpr(buf, pos + 1) {
      None -> None
      Some(ct) -> match ct { CTyP(t, p2) -> Some(CTBP(TBAlias(t), p2)) }
    }
    Some(2) -> match cache_hex_to_fd_list(buf, pos + 1) {
      None -> None
      Some(cfdl) -> match cfdl { CFDLP(fds, p2) -> Some(CTBP(TBRecord(fds), p2)) }
    }
    Some(3) -> match cache_hex_to_var_list(buf, pos + 1) {
      None -> None
      Some(cvl) -> match cvl { CVarLP(vs, p2) -> Some(CTBP(TBSum(vs), p2)) }
    }
    Some(4) -> match cache_hex_to_string_list(buf, pos + 1) {
      None -> None
      Some(csl) -> match csl { CSLP(ls, p2) -> Some(CTBP(TBEffectAlias(ls), p2)) }
    }
    Some(_) -> None
  }
}

# ---- ImportKind -----------------------------------------------------------

fn cache_ik_to_hex(ik: ImportKind) : String = match ik {
  IkPath(p)            -> concat_all([cache_byte_to_hex(1), cache_string_to_hex(p)])
  IkAlias(p, a)        -> concat_all([cache_byte_to_hex(2), cache_string_to_hex(p),
                                       cache_string_to_hex(a)])
  IkSelective(p, names) -> concat_all([cache_byte_to_hex(3), cache_string_to_hex(p),
                                       cache_string_list_to_hex(names)])
  IkHole(name)         -> concat_all([cache_byte_to_hex(4), cache_string_to_hex(name)])
}

fn cache_hex_to_ik(buf: String, pos: Int) : Option[CacheIKPos] {
  match cache_hex_byte_at(buf, pos) {
    None -> None
    Some(1) -> match cache_hex_to_string(buf, pos + 1) {
      None -> None
      Some(csp) -> match csp { CSP(p, p2) -> Some(CIKP(IkPath(p), p2)) }
    }
    Some(2) -> match cache_hex_to_string(buf, pos + 1) {
      None -> None
      Some(c1) -> match c1 { CSP(p, p2) ->
        match cache_hex_to_string(buf, p2) {
          None -> None
          Some(c2) -> match c2 { CSP(a, p3) -> Some(CIKP(IkAlias(p, a), p3)) }
        }
      }
    }
    Some(3) -> match cache_hex_to_string(buf, pos + 1) {
      None -> None
      Some(c1) -> match c1 { CSP(p, p2) ->
        match cache_hex_to_string_list(buf, p2) {
          None -> None
          Some(csl) -> match csl { CSLP(names, p3) ->
            Some(CIKP(IkSelective(p, names), p3))
          }
        }
      }
    }
    Some(4) -> match cache_hex_to_string(buf, pos + 1) {
      None -> None
      Some(csp) -> match csp { CSP(name, p2) -> Some(CIKP(IkHole(name), p2)) }
    }
    Some(_) -> None
  }
}

# ---- ProtoOp / EffectOp ---------------------------------------------------

fn cache_po_to_hex(p: ProtoOp) : String = match p {
  POp(n, tps, prms, rt, l, c) -> concat_all([cache_string_to_hex(n),
                                                cache_string_list_to_hex(tps),
                                                cache_param_list_to_hex(prms),
                                                cache_typeexpr_to_hex(rt),
                                                cache_int_to_hex(l),
                                                cache_int_to_hex(c)])
}

fn cache_hex_to_po(buf: String, pos: Int) : Option[CachePOPos] {
  match cache_hex_to_string(buf, pos) {
    None -> None
    Some(csp) -> match csp { CSP(n, p1) ->
      match cache_hex_to_string_list(buf, p1) {
        None -> None
        Some(csl) -> match csl { CSLP(tps, p2) ->
          match cache_hex_to_param_list(buf, p2) {
            None -> None
            Some(cpl) -> match cpl { CPmLP(prms, p3) ->
              match cache_hex_to_typeexpr(buf, p3) {
                None -> None
                Some(ct) -> match ct { CTyP(rt, p4) ->
                  match cache_hex_to_int(buf, p4) {
                    None -> None
                    Some(cl) -> match cl { CIP(ln, p5) ->
                      match cache_hex_to_int(buf, p5) {
                        None -> None
                        Some(cc) -> match cc { CIP(cn, p6) ->
                          Some(CPOP(POp(n, tps, prms, rt, ln, cn), p6))
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}

fn cache_po_list_to_hex(xs: [ProtoOp]) : String =
  concat_all([cache_u32_to_hex(list_length(xs)),
              concat_all(list_reverse(cache_po_list_loop(xs, [])))])

fn cache_po_list_loop(xs: [ProtoOp], acc: [String]) : [String] = match xs {
  [] -> acc
  [h, ...t] -> cache_po_list_loop(t, [cache_po_to_hex(h), ...acc])
}

fn cache_hex_to_po_list(buf: String, pos: Int) : Option[CachePOLPos] {
  match cache_hex_to_u32(buf, pos) {
    None -> None
    Some(cip) -> match cip { CIP(n, p2) ->
      cache_hex_collect_po_list(buf, p2, n, [])
    }
  }
}

fn cache_hex_collect_po_list(buf: String, pos: Int, remaining: Int,
                                acc: [ProtoOp]) : Option[CachePOLPos] {
  if remaining <= 0 { Some(CPOLP(list_reverse(acc), pos)) }
  else {
    match cache_hex_to_po(buf, pos) {
      None -> None
      Some(cpo) -> match cpo { CPOP(p, p2) ->
        cache_hex_collect_po_list(buf, p2, remaining - 1, [p, ...acc])
      }
    }
  }
}

fn cache_eo_to_hex(e: EffectOp) : String = match e {
  EOp(n, tps, prms, rt, l, c) -> concat_all([cache_string_to_hex(n),
                                                cache_string_list_to_hex(tps),
                                                cache_param_list_to_hex(prms),
                                                cache_typeexpr_to_hex(rt),
                                                cache_int_to_hex(l),
                                                cache_int_to_hex(c)])
}

fn cache_hex_to_eo(buf: String, pos: Int) : Option[CacheEOPos] {
  match cache_hex_to_string(buf, pos) {
    None -> None
    Some(csp) -> match csp { CSP(n, p1) ->
      match cache_hex_to_string_list(buf, p1) {
        None -> None
        Some(csl) -> match csl { CSLP(tps, p2) ->
          match cache_hex_to_param_list(buf, p2) {
            None -> None
            Some(cpl) -> match cpl { CPmLP(prms, p3) ->
              match cache_hex_to_typeexpr(buf, p3) {
                None -> None
                Some(ct) -> match ct { CTyP(rt, p4) ->
                  match cache_hex_to_int(buf, p4) {
                    None -> None
                    Some(cl) -> match cl { CIP(ln, p5) ->
                      match cache_hex_to_int(buf, p5) {
                        None -> None
                        Some(cc) -> match cc { CIP(cn, p6) ->
                          Some(CEOP(EOp(n, tps, prms, rt, ln, cn), p6))
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}

fn cache_eo_list_to_hex(xs: [EffectOp]) : String =
  concat_all([cache_u32_to_hex(list_length(xs)),
              concat_all(list_reverse(cache_eo_list_loop(xs, [])))])

fn cache_eo_list_loop(xs: [EffectOp], acc: [String]) : [String] = match xs {
  [] -> acc
  [h, ...t] -> cache_eo_list_loop(t, [cache_eo_to_hex(h), ...acc])
}

fn cache_hex_to_eo_list(buf: String, pos: Int) : Option[CacheEOLPos] {
  match cache_hex_to_u32(buf, pos) {
    None -> None
    Some(cip) -> match cip { CIP(n, p2) ->
      cache_hex_collect_eo_list(buf, p2, n, [])
    }
  }
}

fn cache_hex_collect_eo_list(buf: String, pos: Int, remaining: Int,
                                acc: [EffectOp]) : Option[CacheEOLPos] {
  if remaining <= 0 { Some(CEOLP(list_reverse(acc), pos)) }
  else {
    match cache_hex_to_eo(buf, pos) {
      None -> None
      Some(ceo) -> match ceo { CEOP(e, p2) ->
        cache_hex_collect_eo_list(buf, p2, remaining - 1, [e, ...acc])
      }
    }
  }
}

# ---- Optional Unit (for DUnit alias) --------------------------------------

fn cache_unit_body_to_hex(b: UnitBody) : String = match b {
  UBNone       -> cache_byte_to_hex(0)
  UBAlias(u)   -> concat_all([cache_byte_to_hex(1), cache_unit_to_hex(u)])
  UBMeasure(m) -> concat_all([cache_byte_to_hex(2), cache_string_to_hex(m)])
}

type CacheUnitBodyPos = CUBP(UnitBody, Int)

fn cache_hex_to_unit_body(buf: String, pos: Int) : Option[CacheUnitBodyPos] {
  match cache_hex_byte_at(buf, pos) {
    None -> None
    Some(0) -> Some(CUBP(UBNone, pos + 1))
    Some(1) -> match cache_hex_to_unit(buf, pos + 1) {
      None -> None
      Some(cu) -> match cu { CUP(u, p2) -> Some(CUBP(UBAlias(u), p2)) }
    }
    Some(2) -> match cache_hex_to_string(buf, pos + 1) {
      None -> None
      Some(cs) -> match cs { CSP(m, p2) -> Some(CUBP(UBMeasure(m), p2)) }
    }
    Some(_) -> None
  }
}

# ---- Decl ------------------------------------------------------------------

fn cache_decl_to_hex(d: Decl) : String = match d {
  DFn(is_pub, name, tps, prms, ort, row, body, l, c, omo) -> concat_all([
    cache_byte_to_hex(1), cache_bool_to_hex(is_pub), cache_string_to_hex(name),
    cache_string_list_to_hex(tps),
    cache_param_list_to_hex(prms),
    cache_opt_typeexpr_to_hex(ort),
    cache_row_to_hex(row),
    cache_expr_to_hex(body),
    cache_int_to_hex(l), cache_int_to_hex(c),
    cache_opt_string_to_hex(omo)
  ])
  DType(is_pub, name, tps, body, l, c, mo, slots) -> concat_all([
    cache_byte_to_hex(2), cache_bool_to_hex(is_pub), cache_string_to_hex(name),
    cache_string_list_to_hex(tps), cache_tb_to_hex(body),
    cache_int_to_hex(l), cache_int_to_hex(c), cache_opt_string_to_hex(mo),
    cache_string_list_to_hex(slots)
  ])
  DTest(desc, body, l, c) -> concat_all([
    cache_byte_to_hex(3), cache_string_to_hex(desc), cache_expr_to_hex(body),
    cache_int_to_hex(l), cache_int_to_hex(c)
  ])
  DBench(desc, body, l, c) -> concat_all([
    cache_byte_to_hex(4), cache_string_to_hex(desc), cache_expr_to_hex(body),
    cache_int_to_hex(l), cache_int_to_hex(c)
  ])
  DCheck(desc, params, body, l, c) -> concat_all([
    cache_byte_to_hex(5), cache_string_to_hex(desc), cache_param_list_to_hex(params),
    cache_expr_to_hex(body), cache_int_to_hex(l), cache_int_to_hex(c)
  ])
  DImport(kind, l, c) -> concat_all([
    cache_byte_to_hex(6), cache_ik_to_hex(kind), cache_int_to_hex(l), cache_int_to_hex(c)
  ])
  DEffect(is_pub, name, tps, ops, odb, l, c, mo) -> concat_all([
    cache_byte_to_hex(7), cache_bool_to_hex(is_pub), cache_string_to_hex(name),
    cache_string_list_to_hex(tps), cache_eo_list_to_hex(ops),
    cache_opt_db_to_hex(odb),
    cache_int_to_hex(l), cache_int_to_hex(c), cache_opt_string_to_hex(mo)
  ])
  DProtocol(is_pub, name, tps, ops, l, c) -> concat_all([
    cache_byte_to_hex(8), cache_bool_to_hex(is_pub), cache_string_to_hex(name),
    cache_string_list_to_hex(tps), cache_po_list_to_hex(ops),
    cache_int_to_hex(l), cache_int_to_hex(c)
  ])
  DImpl(pname, targs, target, body, l, c) -> concat_all([
    cache_byte_to_hex(9), cache_string_to_hex(pname), cache_typeexpr_list_to_hex(targs),
    cache_typeexpr_to_hex(target), cache_decl_list_to_hex(body),
    cache_int_to_hex(l), cache_int_to_hex(c)
  ])
  DDerive(names, inner, l, c) -> concat_all([
    cache_byte_to_hex(10), cache_string_list_to_hex(names), cache_decl_to_hex(inner),
    cache_int_to_hex(l), cache_int_to_hex(c)
  ])
  DUnit(is_pub, name, body, kind, l, c) -> concat_all([
    cache_byte_to_hex(12), cache_bool_to_hex(is_pub), cache_string_to_hex(name),
    cache_unit_body_to_hex(body), cache_string_to_hex(kind),
    cache_int_to_hex(l), cache_int_to_hex(c)
  ])
  DUse(name, l, c) -> concat_all([
    cache_byte_to_hex(13), cache_string_to_hex(name), cache_int_to_hex(l), cache_int_to_hex(c)
  ])
  DAxiom(extc, ec_flag, name, csym, tps, prms, rt, row, l, c) -> concat_all([
    cache_byte_to_hex(14), cache_bool_to_hex(extc), cache_bool_to_hex(ec_flag),
    cache_string_to_hex(name), cache_string_to_hex(csym),
    cache_string_list_to_hex(tps), cache_param_list_to_hex(prms),
    cache_typeexpr_to_hex(rt), cache_row_to_hex(row),
    cache_int_to_hex(l), cache_int_to_hex(c)
  ])
  DConst(is_pub, name, ty, body, mo, l, c) -> concat_all([
    cache_byte_to_hex(15), cache_bool_to_hex(is_pub), cache_string_to_hex(name),
    cache_typeexpr_to_hex(ty), cache_expr_to_hex(body),
    cache_opt_string_to_hex(mo),
    cache_int_to_hex(l), cache_int_to_hex(c)
  ])
  DUnstable(inner, l, c) -> concat_all([
    cache_byte_to_hex(16), cache_decl_to_hex(inner),
    cache_int_to_hex(l), cache_int_to_hex(c)
  ])
  DConstructor(inner, l, c) -> concat_all([
    cache_byte_to_hex(18), cache_decl_to_hex(inner),
    cache_int_to_hex(l), cache_int_to_hex(c)
  ])
  # Law wrappers are stripped before the module cache is written, so
  # they never reach serialisation; the arms keep the walker total,
  # transparently emitting the inner decl.
  DProtoLaws(_, inner, _, _) -> cache_decl_to_hex(inner)
  DImplAxiom(_, inner, _, _) -> cache_decl_to_hex(inner)
  # A foreign type. Body byte 0 = opaque (no payload), 1 = struct
  # (field list follows). Lets a driver module's `extern "C"
  # opaque`/`type` survive the .kab module cache.
  DExternType(name, body, l, c) -> match body {
    ETOpaque -> concat_all([
      cache_byte_to_hex(17), cache_string_to_hex(name), cache_byte_to_hex(0),
      cache_int_to_hex(l), cache_int_to_hex(c)
    ])
    ETStruct(fields) -> concat_all([
      cache_byte_to_hex(17), cache_string_to_hex(name), cache_byte_to_hex(1),
      cache_fd_list_to_hex(fields),
      cache_int_to_hex(l), cache_int_to_hex(c)
    ])
  }
  # Issue #681: doc wrappers are stripped by `doc_strip_all` in the
  # core loaders BEFORE any decl stream reaches the serializer, so
  # these arms are unreachable — the .kab format stays doc-free and
  # the cache format version does not bump. Panic loudly if a future
  # caller serialises an unstripped stream.
  DDoc(_, _, _, _, _) -> panic("cache_decl_to_hex: DDoc must be stripped before caching (issue #681)")
  DModuleDoc(_, _, _, _) -> panic("cache_decl_to_hex: DModuleDoc must be stripped before caching (issue #681)")
  DTheory(_, _, _, _) -> panic("cache_decl_to_hex: DTheory must be stripped before caching")
  DKind(_, _, _, _, _, _, _) -> panic("cache_decl_to_hex: DKind must be stripped before caching")
  DUseKind(_, _, _) -> panic("cache_decl_to_hex: DUseKind must be stripped before caching")
}

fn cache_hex_to_decl(buf: String, pos: Int) : Option[CacheDeclPos] {
  match cache_hex_byte_at(buf, pos) {
    None -> None
    Some(b) -> cache_hex_to_decl_body(buf, pos + 1, b)
  }
}

fn cache_hex_to_decl_body(buf: String, pos: Int,
                            tag: Int) : Option[CacheDeclPos] {
  if tag == 1 {
    cache_hex_to_dfn(buf, pos)
  } else if tag == 2 {
    cache_hex_to_dtype(buf, pos)
  } else if tag == 3 {
    cache_hex_to_dtest_like(buf, pos, 3)
  } else if tag == 4 {
    cache_hex_to_dtest_like(buf, pos, 4)
  } else if tag == 5 {
    cache_hex_to_dcheck(buf, pos)
  } else if tag == 6 {
    match cache_hex_to_ik(buf, pos) {
      None -> None
      Some(cik) -> match cik { CIKP(k, p1) ->
        match cache_hex_to_int(buf, p1) {
          None -> None
          Some(cl) -> match cl { CIP(ln, p2) ->
            match cache_hex_to_int(buf, p2) {
              None -> None
              Some(cc) -> match cc { CIP(cn, p3) ->
                Some(CDP(DImport(k, ln, cn), p3))
              }
            }
          }
        }
      }
    }
  } else if tag == 7 {
    cache_hex_to_deffect(buf, pos)
  } else if tag == 8 {
    cache_hex_to_dprotocol(buf, pos)
  } else if tag == 9 {
    cache_hex_to_dimpl(buf, pos)
  } else if tag == 10 {
    cache_hex_to_dderive(buf, pos)
  } else if tag == 12 {
    cache_hex_to_dunit(buf, pos)
  } else if tag == 13 {
    match cache_hex_to_string(buf, pos) {
      None -> None
      Some(csp) -> match csp { CSP(n, p1) ->
        match cache_hex_to_int(buf, p1) {
          None -> None
          Some(cl) -> match cl { CIP(ln, p2) ->
            match cache_hex_to_int(buf, p2) {
              None -> None
              Some(cc) -> match cc { CIP(cn, p3) ->
                Some(CDP(DUse(n, ln, cn), p3))
              }
            }
          }
        }
      }
    }
  } else if tag == 14 {
    cache_hex_to_daxiom(buf, pos)
  } else if tag == 15 {
    cache_hex_to_dconst(buf, pos)
  } else if tag == 16 {
    cache_hex_to_dunstable(buf, pos)
  } else if tag == 17 {
    cache_hex_to_dexterntype(buf, pos)
  } else if tag == 18 {
    cache_hex_to_dconstructor(buf, pos)
  } else { None }
}

# Deserialise a `DExternType`. Layout mirrors `cache_decl_to_hex`'s
# tag-17 arm: name, body byte (0=opaque, 1=struct + field list), line,
# col.
fn cache_hex_to_dexterntype(buf: String, pos: Int) : Option[CacheDeclPos] {
  match cache_hex_to_string(buf, pos) {
    None -> None
    Some(csp) -> match csp { CSP(name, p1) ->
      match cache_hex_byte_at(buf, p1) {
        None -> None
        Some(kind) -> {
          let p2 = p1 + 1
          if kind == 0 {
            cache_hex_to_dexterntype_tail(buf, p2, name, ETOpaque)
          } else {
            match cache_hex_to_fd_list(buf, p2) {
              None -> None
              Some(cfdl) -> match cfdl { CFDLP(fields, p3) ->
                cache_hex_to_dexterntype_tail(buf, p3, name, ETStruct(fields))
              }
            }
          }
        }
      }
    }
  }
}

fn cache_hex_to_dexterntype_tail(buf: String, pos: Int, name: String,
                                 body: ExternTypeBody) : Option[CacheDeclPos] {
  match cache_hex_to_int(buf, pos) {
    None -> None
    Some(cl) -> match cl { CIP(ln, p1) ->
      match cache_hex_to_int(buf, p1) {
        None -> None
        Some(cc) -> match cc { CIP(cn, p2) ->
          Some(CDP(DExternType(name, body, ln, cn), p2))
        }
      }
    }
  }
}

fn cache_hex_to_dfn(buf: String, pos: Int) : Option[CacheDeclPos] {
  match cache_hex_to_bool(buf, pos) {
    None -> None
    Some(cbp) -> match cbp { CBP(is_pub, p1) ->
      match cache_hex_to_string(buf, p1) {
        None -> None
        Some(csp) -> match csp { CSP(name, p2) ->
          match cache_hex_to_string_list(buf, p2) {
            None -> None
            Some(csl) -> match csl { CSLP(tps, p3) ->
              match cache_hex_to_param_list(buf, p3) {
                None -> None
                Some(cpl) -> match cpl { CPmLP(prms, p4) ->
                  cache_hex_to_dfn_tail(buf, p4, is_pub, name, tps, prms)
                }
              }
            }
          }
        }
      }
    }
  }
}

fn cache_hex_to_dfn_tail(buf: String, pos: Int, is_pub: Bool, name: String,
                            tps: [String], prms: [Param]) : Option[CacheDeclPos] {
  match cache_hex_to_opt_typeexpr(buf, pos) {
    None -> None
    Some(cot) -> match cot { COTyP(ort, p1) ->
      match cache_hex_to_row(buf, p1) {
        None -> None
        Some(crw) -> match crw { CRowP(row, p2) ->
          match cache_hex_to_expr(buf, p2) {
            None -> None
            Some(ce) -> match ce { CEP(body, p3) ->
              match cache_hex_to_int(buf, p3) {
                None -> None
                Some(cl) -> match cl { CIP(ln, p4) ->
                  match cache_hex_to_int(buf, p4) {
                    None -> None
                    Some(cc) -> match cc { CIP(cn, p5) ->
                      match cache_hex_to_opt_string(buf, p5) {
                        None -> None
                        Some(cos) -> match cos { COSP(omo, p6) ->
                          Some(CDP(DFn(is_pub, name, tps, prms, ort, row,
                                       body, ln, cn, omo), p6))
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}

fn cache_hex_to_dtype(buf: String, pos: Int) : Option[CacheDeclPos] {
  match cache_hex_to_bool(buf, pos) {
    None -> None
    Some(cbp) -> match cbp { CBP(is_pub, p1) ->
      match cache_hex_to_string(buf, p1) {
        None -> None
        Some(csp) -> match csp { CSP(name, p2) ->
          match cache_hex_to_string_list(buf, p2) {
            None -> None
            Some(csl) -> match csl { CSLP(tps, p3) ->
              match cache_hex_to_tb(buf, p3) {
                None -> None
                Some(ctb) -> match ctb { CTBP(body, p4) ->
                  match cache_hex_to_int(buf, p4) {
                    None -> None
                    Some(cl) -> match cl { CIP(ln, p5) ->
                      match cache_hex_to_int(buf, p5) {
                        None -> None
                        Some(cc) -> match cc { CIP(cn, p6) ->
                          match cache_hex_to_opt_string(buf, p6) {
                            None -> None
                            Some(cmo) -> match cmo { COSP(mo, p7) ->
                              match cache_hex_to_string_list(buf, p7) {
                                None -> None
                                Some(csl2) -> match csl2 { CSLP(slots, p8) ->
                                  Some(CDP(DType(is_pub, name, tps, body, ln, cn, mo, slots), p8))
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}

# DTest / DBench share the same shape (desc, body, l, c).
fn cache_hex_to_dtest_like(buf: String, pos: Int,
                              which: Int) : Option[CacheDeclPos] {
  match cache_hex_to_string(buf, pos) {
    None -> None
    Some(csp) -> match csp { CSP(desc, p1) ->
      match cache_hex_to_expr(buf, p1) {
        None -> None
        Some(ce) -> match ce { CEP(body, p2) ->
          match cache_hex_to_int(buf, p2) {
            None -> None
            Some(cl) -> match cl { CIP(ln, p3) ->
              match cache_hex_to_int(buf, p3) {
                None -> None
                Some(cc) -> match cc { CIP(cn, p4) ->
                  if which == 3 {
                    Some(CDP(DTest(desc, body, ln, cn), p4))
                  } else {
                    Some(CDP(DBench(desc, body, ln, cn), p4))
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}

fn cache_hex_to_dcheck(buf: String, pos: Int) : Option[CacheDeclPos] {
  match cache_hex_to_string(buf, pos) {
    None -> None
    Some(csp) -> match csp { CSP(desc, p1) ->
      match cache_hex_to_param_list(buf, p1) {
        None -> None
        Some(cpl) -> match cpl { CPmLP(params, p2) ->
          match cache_hex_to_expr(buf, p2) {
            None -> None
            Some(ce) -> match ce { CEP(body, p3) ->
              match cache_hex_to_int(buf, p3) {
                None -> None
                Some(cl) -> match cl { CIP(ln, p4) ->
                  match cache_hex_to_int(buf, p4) {
                    None -> None
                    Some(cc) -> match cc { CIP(cn, p5) ->
                      Some(CDP(DCheck(desc, params, body, ln, cn), p5))
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}

fn cache_hex_to_deffect(buf: String, pos: Int) : Option[CacheDeclPos] {
  match cache_hex_to_bool(buf, pos) {
    None -> None
    Some(cbp) -> match cbp { CBP(is_pub, p1) ->
      match cache_hex_to_string(buf, p1) {
        None -> None
        Some(csp) -> match csp { CSP(name, p2) ->
          match cache_hex_to_string_list(buf, p2) {
            None -> None
            Some(csl) -> match csl { CSLP(tps, p3) ->
              match cache_hex_to_eo_list(buf, p3) {
                None -> None
                Some(ceol) -> match ceol { CEOLP(ops, p4) ->
                  match cache_hex_to_opt_db(buf, p4) {
                    None -> None
                    Some(codb) -> match codb { CODBP(odb, p5) ->
                      match cache_hex_to_int(buf, p5) {
                        None -> None
                        Some(cl) -> match cl { CIP(ln, p6) ->
                          match cache_hex_to_int(buf, p6) {
                            None -> None
                            Some(cc) -> match cc { CIP(cn, p7) ->
                              match cache_hex_to_opt_string(buf, p7) {
                                None -> None
                                Some(cmo) -> match cmo { COSP(mo, p8) ->
                                  Some(CDP(DEffect(is_pub, name, tps, ops, odb, ln, cn, mo), p8))
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}

