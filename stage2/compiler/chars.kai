# compiler/chars.kai — Char classification primitives.
#
# Pure functions over a single `Char`, with no dependency on lexer,
# parser, or any other compiler state. First module extracted from
# the monolithic `compiler.kai` under issue #677 Phase 1.
#
# The `#[doc("...")]` attributes follow the surface proposed in
# issue #681. Until #681 Phase 1 lands, the compiler parses them
# and drops them (see `parse_attr_unknown_body`), so the doc
# strings here ship today as forward-compat noise that becomes
# machine-readable the moment #681 lands.
#
# Single-line `#[doc(...)]` only — kaic1 (which consumes the
# concatenated bundle until separate-compilation lands in Phase 2
# of #677) does not support triple-quoted strings. Module-level
# documentation that wants multiple paragraphs stays in the `#`
# header block above instead of inside an attribute.

#[doc("True when `c` is an ASCII decimal digit ('0'..='9').")]
pub fn ch_is_digit(c: Char) : Bool = c >= '0' and c <= '9'

#[doc("True when `c` is an ASCII lowercase letter ('a'..='z').")]
pub fn ch_is_lower(c: Char) : Bool = c >= 'a' and c <= 'z'

#[doc("True when `c` is an ASCII uppercase letter ('A'..='Z').")]
pub fn ch_is_upper(c: Char) : Bool = c >= 'A' and c <= 'Z'

#[doc("True when `c` is a letter or underscore — the leading-character class for kaikai identifiers.")]
pub fn ch_is_alpha(c: Char) : Bool = ch_is_lower(c) or ch_is_upper(c) or c == '_'

#[doc("True when `c` is alphanumeric — the continuation-character class for kaikai identifiers.")]
pub fn ch_is_alnum(c: Char) : Bool = ch_is_alpha(c) or ch_is_digit(c)

#[doc("True when `c` is intra-line whitespace (space, tab, or carriage return). Newline is NOT whitespace here because the kaikai lexer is newline-significant.")]
pub fn ch_is_space(c: Char) : Bool = c == ' ' or c == '\t' or c == '\r'
