# compiler/emit_c.kai — the C backend (+ TCO pre-pass).
#
# Extracted from main.kai under issue #677 Phase 1r, the final
# pipeline-layer extraction before the driver (apex) lane. This module
# owns the C emitter that produces the portable C the stage-2 bootstrap
# compiles: `emit_program` walks a resolved + monomorphised + Perceus'd
# decl list and emits forward decls, closure thunks, the FFI bridge, the
# expression/statement lowering, and the `int main` scaffolding linking
# against stage 0's runtime.h. The tail-call rewrite (`tcrec_*`) lives
# here too: it is a C-emitter pre-pass (it mints `__kai_tcrec|<c_sym>|…`
# goto strings and calls `emit_expr` / `c_sym`), not a `[Decl]→[Decl]`
# peer of monomorph/unbox/perceus — see
# docs/lane-infer-cross-section-analysis.md §3.
#
# Relationship to the other backend: the symbol-minting, free-variable,
# alias-rewrite, FFI-classification and protocol-dispatch plumbing this
# emitter shares with the LLVM backend was sunk to compiler.emit_shared
# in this same lane (133 fns + 13 types), so both `emit_program` (here)
# and `emit_program_llvm` (compiler.emit_llvm) import them once instead
# of duplicating. emit_c imports emit_shared; it does not import
# emit_llvm.
#
# Public surface: 17 fns + 1 type. Entry points the driver calls:
# `emit_program` (the C emitter), `tcrec_rewrite_decls` (the TCO
# pre-pass), the `--dump-mono` / `--dump-types` queries, the pre-emit
# alias-expansion / index- and interp-desugar passes
# (`expand_aliases_in_decls`, `expand_ta_decls`, `desugar_index_decls`,
# `desugar_interp_decls`, `resolve_alias_cands`, the `collect_*` alias
# scanners), the ambiguous-EFn reporter (`find_ambig_efns` /
# `report_ambig_efns`), `report_unused_in_decls`, and
# `mangle_prelude_segments`. `BuildMode` (build/test/bench/check wrapper
# selection) moves here `pub` — `emit_program` matches on it and the
# driver constructs it; it travels with its primary consumer.
#
# Downward glue (cmt_ prefix, mirrored not imported, per the phase-1m
# discipline — each has a single consumer here): `cmt_type_expr_display`,
# `cmt_unit_expr_display`, `cmt_row_effects_without_default_handler`.
# Their originals stay in main's head/driver region; the driver lane
# reconciles the three copies.
#
# Bundle order: ... monomorph, emit_shared, emit_llvm, **emit_c**, main.
# Imports compiler.ast, compiler.chars, compiler.diag, compiler.util,
# compiler.parse, compiler.resolve, compiler.refinements, compiler.infer,
# compiler.fnreg, compiler.modules, compiler.unbox, compiler.perceus,
# compiler.protos, and compiler.emit_shared (the backend-shared layer).

import compiler.ast
import compiler.chars
import compiler.diag
import compiler.util
import compiler.parse
import compiler.resolve
import compiler.refinements
import compiler.infer
import compiler.fnreg
import compiler.modules
import compiler.unbox
import compiler.perceus
import compiler.protos
import compiler.emit_shared
import compiler.region

# ====================================================================

# ---- BuildMode (build-wrapper selection, consumed by emit_program) ----

# Build-time wrapper selection passed to the emitters. Collapses the
# previous test_mode/bench_mode/check_mode Bool triple (audit proposal
# 5 in docs/lane-experience-compiler-idioms-audit.md). `BMBuild` is the
# ordinary `main` path; the other three each emit a distinct wrapper.
#[doc("Build-time wrapper selection (build/test/bench/check) passed to the emitters; the driver consumes it from here.")]
pub type BuildMode = BMBuild | BMTest | BMBench | BMCheck

# Lane linus-a (Lane A of docs/stage2-quality-km-audit-2026-05-29.md):
# the emit walker used to thread five companion arguments through every
# recursive call — `lcs` (lexical-scope names), `fns` (the EFn registry),
# `variants` (the EVar registry), `lams` (collected lambdas) and `cls`
# (collected clause-infos). That data clump appeared in ~74 signatures
# and ~250 call-sites; adding any sixth piece of emit context meant
# touching all of them. `EmitCtx` bundles the five into one record so the
# walker passes a single `cx`. The only field that varies as the walker
# descends is `lcs` (each body/arm/clause extends the lexical scope); the
# other four are invariant for a whole `emit_program` run, so they are
# built once at entry. `emit_ctx_with_lcs` rebuilds the record with a new
# `lcs` for those descent points — semantically identical to the old
# `..., new_lcs, fns, variants, lams, cls` argument shuffle.
type EmitCtx = { lcs: [String], fns: [EFn], variants: [EVar], lams: [LamInfo], cls: [ClauseInfo],
                 regions: [RegionMark], in_region: Bool }

fn emit_ctx_with_lcs(cx: EmitCtx, l: [String]) : EmitCtx =
  EmitCtx { lcs: l, fns: cx.fns, variants: cx.variants, lams: cx.lams, cls: cx.cls,
            regions: cx.regions, in_region: cx.in_region }

# issue #120 — opt-in Perceus regions (Phase P1): set/clear in_region.
fn emit_ctx_with_in_region(cx: EmitCtx, b: Bool) : EmitCtx =
  EmitCtx { lcs: cx.lcs, fns: cx.fns, variants: cx.variants, lams: cx.lams, cls: cx.cls,
            regions: cx.regions, in_region: b }

# True when a block at (line, col) is a recorded `region { }`.
fn emit_block_is_region(cx: EmitCtx, line: Int, col: Int) : Bool =
  emit_region_marks_has(cx.regions, line, col)

fn emit_region_marks_has(ms: [RegionMark], line: Int, col: Int) : Bool {
  match ms {
    [] -> false
    [m, ...rest] ->
      if rmark_line(m) == line and rmark_col(m) == col { true }
      else { emit_region_marks_has(rest, line, col) }
  }
}

# The C cons constructor a region-lexical site emits: arena-bump inside
# a region body, ordinary RC otherwise.
fn emit_cons_ctor(cx: EmitCtx) : String = if cx.in_region { "kai_arena_cons(" } else { "kai_cons(" }

# issue #120 (P1): record literal constructor — bump-arena `kai_arena_record`
# in-region, else RC-heap `kai_record`. Both take `(int n, KaiValue **fields,
# const char **names)`; the C array-literal args decay to those pointer types
# identically, so the swap is behaviour-identical outside a region.
fn emit_record_ctor(cx: EmitCtx) : String = if cx.in_region { "kai_arena_record(" } else { "kai_record(" }

# issue #120 (P1): n-ary variant constructor — bump-arena `kai_arena_variant`
# in-region, else RC-heap `kai_variant_u`. Both take `(tag, name, n, mask,
# slots)` in the same order. NULLARY variants are shared singletons and are
# NOT routed (they must stay on the RC heap, never the arena — the arena
# free would dangle the shared singleton).
fn emit_variant_ctor(cx: EmitCtx) : String = if cx.in_region { "kai_arena_variant(" } else { "kai_variant_u(" }

# Issue #452 Phase A.0 step 3: `prelude_caches` is parallel to
# `preludes`. Each slot is either "" (no cache, force re-parse from
# source) or a path to a .kab file produced by --emit-prelude-cache.
# `--prelude <src>` appends "" to keep the arrays aligned;
# `--prelude-cache <src> <cache>` appends <cache>. Length is always
# equal to length of `preludes`.
# `cache_sha` carries the optional sha256 hex (64 chars) used when
# emitting a cache via --emit-prelude-cache; empty string means write
# the all-zero placeholder.

# ====================================================================

fn efn_find(fns: [EFn], target: String) : Option[EFn] {
  match fns {
    [] -> None
    [h, ...rest] -> match h {
      EFn(n, _, _, _) -> if n == target { Some(h) } else { efn_find(rest, target) }
    }
  }
}

fn efn_find_arity(fns: [EFn], target: String) : Option[Int] = match efn_resolve(fns, target) {
  Some(EFn(_, ar, _, _)) -> Some(ar)
  None                   -> None
}

pub fn evar_payload_tys(vs: [EVar], target: String) : Option[[TypeExpr]] {
  match vs {
    [] -> None
    [h, ...rest] -> match h {
      EV(n, _, tys, _) -> if n == target { Some(tys) } else { evar_payload_tys(rest, target) }
    }
  }
}

#[doc("An ambiguous EFn-resolution entry: the callee name plus the candidate module origins that conflict.")]
pub type AmbigEntry = AmbE(String, [String])

# m6.2 v2: return one AmbigEntry per name N that is exported by two
# or more modules and has no root-file definition. Only such names
# are ambiguous at a bare-name call site — when a root entry exists,
# the locals-shadow-imports rule (efn_pick_root) picks the root
# silently; when only one module exports the name, the resolution
# is unique. Iteration is O(|fns|^2) — fine, |fns| stays in the
# low thousands even with the full prelude chain loaded.

# m6.2 v2: return one AmbigEntry per name N that is exported by two
# or more modules and has no root-file definition. Only such names
# are ambiguous at a bare-name call site — when a root entry exists,
# the locals-shadow-imports rule (efn_pick_root) picks the root
# silently; when only one module exports the name, the resolution
# is unique. Iteration is O(|fns|^2) — fine, |fns| stays in the
# low thousands even with the full prelude chain loaded.
#[doc("return one AmbigEntry per name N that is exported by two or more modules and has no root-file definition. Only such names are ambiguous at a bare-name call site — when a root…")]
pub fn find_ambig_efns(fns: [EFn], target_origin: Option[String]) : [AmbigEntry] =
  find_ambig_loop(fns, target_origin, [], [])

fn find_ambig_loop(fns: [EFn], target_origin: Option[String], seen: [String], acc: [AmbigEntry]) : [AmbigEntry] {
  match fns {
    [] -> list_reverse(acc)
    [h, ...rest] -> match h {
      EFn(n, _, _, _) ->
        if list_has(seen, n) { find_ambig_loop(rest, target_origin, seen, acc) }
        else {
          let cands = efn_collect_matching(fns, n, [])
          let count = list_length(cands)
          if count <= 1 { find_ambig_loop(rest, target_origin, [n, ...seen], acc) }
          else {
            match efn_pick_root(cands) {
              Some(_) -> find_ambig_loop(rest, target_origin, [n, ...seen], acc)
              None    -> {
                let mods = ambig_mods_of(cands, [])
                # Issue #335: if the calling file (the target) exports
                # this name itself, the file-local rule resolves the
                # ambiguity inside that file's bodies — no warning.
                if mods_contain_target(mods, target_origin) {
                  find_ambig_loop(rest, target_origin, [n, ...seen], acc)
                } else {
                  let entry = AmbE(n, mods)
                  find_ambig_loop(rest, target_origin, [n, ...seen], [entry, ...acc])
                }
              }
            }
          }
        }
    }
  }
}

fn mods_contain_target(mods: [String], target_origin: Option[String]) : Bool =
  match target_origin {
    None    -> false
    Some(m) -> list_has(mods, m)
  }

fn ambig_mods_of(cands: [EFn], acc: [String]) : [String] {
  match cands {
    [] -> list_reverse(acc)
    [h, ...rest] -> match h {
      EFn(_, _, None, _)    -> ambig_mods_of(rest, acc)
      EFn(_, _, Some(m), _) ->
        if list_has(acc, m) { ambig_mods_of(rest, acc) }
        else                { ambig_mods_of(rest, [m, ...acc]) }
    }
  }
}

# issue #243: emit a stderr warning for each ambiguous bare-name
# that the user's root file ACTUALLY calls without a qualifier. The
# m6.2 v2 design fired one warning per ambiguous export regardless
# of usage; that produced 9 spurious warnings on hello-world after
# the prelude grew to two modules exporting `map`/`repeat`/etc.
# (PR #241 retired the colliding aliases, but two-module overlaps
# remain by design — `option.map` and `result.map` are intentionally
# both exported). The body walk we now perform is bounded by the
# root file's AST, not the prelude, so it stays cheap.

# issue #243: emit a stderr warning for each ambiguous bare-name
# that the user's root file ACTUALLY calls without a qualifier. The
# m6.2 v2 design fired one warning per ambiguous export regardless
# of usage; that produced 9 spurious warnings on hello-world after
# the prelude grew to two modules exporting `map`/`repeat`/etc.
# (PR #241 retired the colliding aliases, but two-module overlaps
# remain by design — `option.map` and `result.map` are intentionally
# both exported). The body walk we now perform is bounded by the
# root file's AST, not the prelude, so it stays cheap.
#[doc("issue #243: emit a stderr warning for each ambiguous bare-name that the user's root file ACTUALLY calls without a qualifier. The m6.2 v2 design fired one warning per ambiguous…")]
pub fn report_ambig_efns(amb: [AmbigEntry], used: [String]) : Unit / Console = match amb {
  [] -> ()
  [a, ...rest] -> match a {
    AmbE(name, mods) -> {
      if list_has(used, name) {
        eprint(concat_all([
          "warning: bare name '", name,
          "' is exported by multiple modules with no root-file shadow: ",
          join_with(mods, ", "),
          "; use a qualified call (e.g. ", list_head_or(mods, "<mod>"),
          ".", name, "(...)) to disambiguate"
        ]))
      } else { () }
      report_ambig_efns(rest, used)
    }
  }
}

# issue #243: collect the set of bare-name callees used in the root
# file's decls. A "bare-name callee" is `ECall(callee, _)` where the
# callee node is `EVar(name)` — i.e. an unqualified function call.
# Qualified calls (`m.f(...)`) parse as `ECall(EField(EVar(m), f), _)`
# or are rewritten to `EModCall` post-resolution; both are skipped.
# Module-origin filtering happens at the caller (only root decls are
# walked), so this returns the nameset for the active root file alone.

# issue #243: collect the set of bare-name callees used in the root
# file's decls. A "bare-name callee" is `ECall(callee, _)` where the
# callee node is `EVar(name)` — i.e. an unqualified function call.
# Qualified calls (`m.f(...)`) parse as `ECall(EField(EVar(m), f), _)`
# or are rewritten to `EModCall` post-resolution; both are skipped.
# Module-origin filtering happens at the caller (only root decls are
# walked), so this returns the nameset for the active root file alone.
#[doc("issue #243: collect the set of bare-name callees used in the root file's decls. A 'bare-name callee' is `ECall(callee, _)` where the callee node is `EVar(name)` — i.e. an…")]
# issue #118 layer 3 — collect the constructor names that the Perceus
# recogniser turned into reuse targets, i.e. every `ctor` appearing as
# the second argument of a synthesised `__perceus_reuse_variant(_scr,
# ctor(args...))`. The emitter maps these names to tags and stamps the
# runtime reusable-tag bitset so `kai_variant_u` stops immortalising
# them (which would saturate their rc and block reuse-in-place). Runs
# over the post-Perceus AST inside `emit_program`.
pub fn collect_reuse_ctors(decls: [Decl], acc: [String]) : [String] = match decls {
  []           -> acc
  [d, ...rest] -> collect_reuse_ctors(rest, collect_reuse_ctors_decl(d, acc))
}

fn collect_reuse_ctors_decl(d: Decl, acc: [String]) : [String] = match d {
  DFn(_, _, _, _, _, _, body, _, _, _) -> walk_reuse_ctors(body, acc)
  DTest(_, body, _, _)     -> walk_reuse_ctors(body, acc)
  DBench(_, body, _, _)    -> walk_reuse_ctors(body, acc)
  DCheck(_, _, body, _, _) -> walk_reuse_ctors(body, acc)
  _ -> acc
}

# Pull the ctor name out of a `__perceus_reuse_variant`'s second arg,
# which is `ECall(EVar(ctor) | EModCall(_, ctor), _)`. None for any
# other shape.
fn reuse_ctor_name(ctor: Expr) : Option[String] = match ctor.kind {
  ECall(cf, _) -> match cf.kind {
    EVar(cname)        -> Some(cname)
    EModCall(_, cname) -> Some(cname)
    _                  -> None
  }
  _ -> None
}

fn walk_reuse_ctors(e: Expr, acc: [String]) : [String] = {
  # Detect the reuse-variant call shape at this node, then recurse via
  # the shared `walk_bare_callees` traversal for the sub-expressions.
  # We reuse the existing full ExprKind walker to descend; it already
  # visits every child, and the only node we care about adds a name.
  let acc1 = match e.kind {
    ECall(callee, args_) -> match callee.kind {
      EVar(nm) ->
        if nm == "__perceus_reuse_variant" {
          match args_ {
            [_scr, ctor] -> match reuse_ctor_name(ctor) {
              Some(cn) -> if list_has(acc, cn) { acc } else { [cn, ...acc] }
              None     -> acc
            }
            _ -> acc
          }
        } else { acc }
      _ -> acc
    }
    _ -> acc
  }
  walk_reuse_ctors_children(e.kind, acc1)
}

# Descend into every child expression. Mirrors `walk_bare_callees`'s
# structural recursion but invokes `walk_reuse_ctors` so the reuse-call
# detection fires at every level.
fn walk_reuse_ctors_children(k: ExprKind, acc: [String]) : [String] = match k {
  ECall(callee, args_) -> walk_reuse_ctors_list(args_, walk_reuse_ctors(callee, acc))
  EIntrinsic(_, args_)  -> walk_reuse_ctors_list(args_, acc)
  EField(base, _)       -> walk_reuse_ctors(base, acc)
  EIndex(a, b)          -> walk_reuse_ctors(b, walk_reuse_ctors(a, acc))
  EBinop(_, a, b)       -> walk_reuse_ctors(b, walk_reuse_ctors(a, acc))
  EUnop(_, x)           -> walk_reuse_ctors(x, acc)
  EIf(c, t, eo)         -> {
    let a1 = walk_reuse_ctors(t, walk_reuse_ctors(c, acc))
    match eo { Some(b) -> walk_reuse_ctors(b, a1) None -> a1 }
  }
  EMatch(scr, arms)     -> walk_reuse_ctors_arms(arms, walk_reuse_ctors(scr, acc))
  ELambda(_, body)      -> walk_reuse_ctors(body, acc)
  ERecordLit(_, fs)     -> walk_reuse_ctors_fields(fs, acc)
  EList(els)            -> walk_reuse_ctors_elems(els, acc)
  ERange(a, b, opt)     -> {
    let a1 = walk_reuse_ctors(b, walk_reuse_ctors(a, acc))
    match opt { Some(s) -> walk_reuse_ctors(s, a1) None -> a1 }
  }
  EBlock(stmts, tail)   -> {
    let a1 = walk_reuse_ctors_stmts(stmts, acc)
    match tail { Some(t) -> walk_reuse_ctors(t, a1) None -> a1 }
  }
  EPipe(a, b)           -> walk_reuse_ctors(b, walk_reuse_ctors(a, acc))
  EMapPipe(a, b)        -> walk_reuse_ctors(b, walk_reuse_ctors(a, acc))
  EFlatMapPipe(a, b)    -> walk_reuse_ctors(b, walk_reuse_ctors(a, acc))
  EFilterPipe(a, b)     -> walk_reuse_ctors(b, walk_reuse_ctors(a, acc))
  EBang(inner)          -> walk_reuse_ctors(inner, acc)
  ELitUnit(inner, _)    -> walk_reuse_ctors(inner, acc)
  EHandle(body, _, _, init_opt, _, clauses, ret_opt) -> {
    let a1 = walk_reuse_ctors(body, acc)
    let a2 = match init_opt { Some(i) -> walk_reuse_ctors(i, a1) None -> a1 }
    let a3 = walk_reuse_ctors_clauses(clauses, a2)
    match ret_opt {
      Some(r) -> match r { HR(_, b, _, _) -> walk_reuse_ctors(b, a3) }
      None    -> a3
    }
  }
  _ -> acc
}

fn walk_reuse_ctors_list(es: [Expr], acc: [String]) : [String] = match es {
  []           -> acc
  [h, ...rest] -> walk_reuse_ctors_list(rest, walk_reuse_ctors(h, acc))
}

fn walk_reuse_ctors_arms(arms: [Arm], acc: [String]) : [String] = match arms {
  []           -> acc
  [a, ...rest] -> match a {
    Arm(_, opt_guard, body) -> {
      let a1 = match opt_guard { Some(g) -> walk_reuse_ctors(g, acc) None -> acc }
      walk_reuse_ctors_arms(rest, walk_reuse_ctors(body, a1))
    }
  }
}

fn walk_reuse_ctors_fields(fs: [FieldInit], acc: [String]) : [String] = match fs {
  []           -> acc
  [f, ...rest] -> match f {
    FI(_, e) -> walk_reuse_ctors_fields(rest, walk_reuse_ctors(e, acc))
  }
}

fn walk_reuse_ctors_elems(els: [ListElem], acc: [String]) : [String] = match els {
  []           -> acc
  [el, ...rest] -> match el {
    ElPlain(e)  -> walk_reuse_ctors_elems(rest, walk_reuse_ctors(e, acc))
    ElSpread(e) -> walk_reuse_ctors_elems(rest, walk_reuse_ctors(e, acc))
  }
}

fn walk_reuse_ctors_stmts(ss: [Stmt], acc: [String]) : [String] = match ss {
  []           -> acc
  [s, ...rest] -> match s {
    SLet(_, _, e)        -> walk_reuse_ctors_stmts(rest, walk_reuse_ctors(e, acc))
    SVar(_, _, e, _, _)  -> walk_reuse_ctors_stmts(rest, walk_reuse_ctors(e, acc))
    SAssert(e, og)       -> {
      let a1 = walk_reuse_ctors(e, acc)
      let a2 = match og { Some(g) -> walk_reuse_ctors(g, a1) None -> a1 }
      walk_reuse_ctors_stmts(rest, a2)
    }
    SExprStmt(e)         -> walk_reuse_ctors_stmts(rest, walk_reuse_ctors(e, acc))
    SIndexAssign(a, b, c, _, _) -> {
      let a1 = walk_reuse_ctors(c, walk_reuse_ctors(b, walk_reuse_ctors(a, acc)))
      walk_reuse_ctors_stmts(rest, a1)
    }
    SUse(_, _, _)        -> walk_reuse_ctors_stmts(rest, acc)
  }
}

fn walk_reuse_ctors_clauses(cs: [HClause], acc: [String]) : [String] = match cs {
  []           -> acc
  [c, ...rest] -> match c {
    HC(_, _, body, _, _) -> walk_reuse_ctors_clauses(rest, walk_reuse_ctors(body, acc))
  }
}

pub fn collect_root_bare_callees(decls: [Decl], acc: [String]) : [String] = match decls {
  []           -> acc
  [d, ...rest] -> collect_root_bare_callees(rest, collect_root_bare_callees_decl(d, acc))
}

fn collect_root_bare_callees_decl(d: Decl, acc: [String]) : [String] = match d {
  DFn(_, _, _, _, _, _, body, _, _, mo) -> match mo {
    None    -> walk_bare_callees(body, acc)
    Some(_) -> acc
  }
  DTest(_, body, _, _)        -> walk_bare_callees(body, acc)
  DBench(_, body, _, _)       -> walk_bare_callees(body, acc)
  DCheck(_, _, body, _, _)    -> walk_bare_callees(body, acc)
  _ -> acc
}

fn walk_bare_callees(e: Expr, acc: [String]) : [String] = match e.kind {
  EInt(_)             -> acc
  EReal(_)            -> acc
  EBool(_)            -> acc
  EChar(_)            -> acc
  EStr(_, _)          -> acc
  EUnit               -> acc
  EVar(_)             -> acc
  EUnder              -> acc
  EPlaceholder        -> acc
  EHole(_)            -> acc
  ETodo(_)            -> acc
  EVariantsOf(_, _)   -> acc
  EModCall(_, _)      -> acc
  EIntrinsic(_, args_) -> walk_bare_callees_list(args_, acc)
  ECall(callee, args_) -> {
    let acc1 = match callee.kind {
      EVar(name) -> if list_has(acc, name) { acc } else { [name, ...acc] }
      _          -> walk_bare_callees(callee, acc)
    }
    walk_bare_callees_list(args_, acc1)
  }
  EField(base, _)     -> walk_bare_callees(base, acc)
  EIndex(a, b)        -> walk_bare_callees(b, walk_bare_callees(a, acc))
  EBinop(_, a, b)     -> walk_bare_callees(b, walk_bare_callees(a, acc))
  EUnop(_, x)         -> walk_bare_callees(x, acc)
  EIf(c, t, eo)       -> {
    let a1 = walk_bare_callees(t, walk_bare_callees(c, acc))
    match eo { Some(b) -> walk_bare_callees(b, a1) None -> a1 }
  }
  EMatch(scr, arms)   -> walk_bare_callees_arms(arms, walk_bare_callees(scr, acc))
  ELambda(_, body)    -> walk_bare_callees(body, acc)
  ERecordLit(_, fs)   -> walk_bare_callees_fields(fs, acc)
  EList(els)          -> walk_bare_callees_elems(els, acc)
  ERange(a, b, opt)   -> {
    let a1 = walk_bare_callees(b, walk_bare_callees(a, acc))
    match opt { Some(s) -> walk_bare_callees(s, a1) None -> a1 }
  }
  EBlock(stmts, tail) -> {
    let a1 = walk_bare_callees_stmts(stmts, acc)
    match tail { Some(t) -> walk_bare_callees(t, a1) None -> a1 }
  }
  EPipe(a, b)         -> walk_bare_callees(b, walk_bare_callees(a, acc))
  EMapPipe(a, b)      -> walk_bare_callees(b, walk_bare_callees(a, acc))
  EFlatMapPipe(a, b)  -> walk_bare_callees(b, walk_bare_callees(a, acc))
  EFilterPipe(a, b)   -> walk_bare_callees(b, walk_bare_callees(a, acc))
  EBang(inner)        -> walk_bare_callees(inner, acc)
  ELitUnit(inner, _)  -> walk_bare_callees(inner, acc)
  EHandle(body, _, _, init_opt, _, clauses, ret_opt) -> {
    let a1 = walk_bare_callees(body, acc)
    let a2 = match init_opt { Some(i) -> walk_bare_callees(i, a1) None -> a1 }
    let a3 = walk_bare_callees_clauses(clauses, a2)
    match ret_opt {
      Some(r) -> match r { HR(_, b, _, _) -> walk_bare_callees(b, a3) }
      None    -> a3
    }
  }
}

fn walk_bare_callees_list(es: [Expr], acc: [String]) : [String] = match es {
  []           -> acc
  [h, ...rest] -> walk_bare_callees_list(rest, walk_bare_callees(h, acc))
}

fn walk_bare_callees_arms(arms: [Arm], acc: [String]) : [String] = match arms {
  []           -> acc
  [a, ...rest] -> match a {
    Arm(_, opt_guard, body) -> {
      let a1 = match opt_guard { Some(g) -> walk_bare_callees(g, acc) None -> acc }
      walk_bare_callees_arms(rest, walk_bare_callees(body, a1))
    }
  }
}

fn walk_bare_callees_fields(fs: [FieldInit], acc: [String]) : [String] = match fs {
  []           -> acc
  [f, ...rest] -> match f {
    FI(_, e) -> walk_bare_callees_fields(rest, walk_bare_callees(e, acc))
  }
}

fn walk_bare_callees_elems(els: [ListElem], acc: [String]) : [String] = match els {
  []           -> acc
  [el, ...rest] -> match el {
    ElPlain(e)  -> walk_bare_callees_elems(rest, walk_bare_callees(e, acc))
    ElSpread(e) -> walk_bare_callees_elems(rest, walk_bare_callees(e, acc))
  }
}

fn walk_bare_callees_stmts(ss: [Stmt], acc: [String]) : [String] = match ss {
  []           -> acc
  [s, ...rest] -> match s {
    SLet(_, _, e)        -> walk_bare_callees_stmts(rest, walk_bare_callees(e, acc))
    SVar(_, _, e, _, _)  -> walk_bare_callees_stmts(rest, walk_bare_callees(e, acc))
    SAssert(e, og)       -> {
      let a1 = walk_bare_callees(e, acc)
      let a2 = match og { Some(g) -> walk_bare_callees(g, a1) None -> a1 }
      walk_bare_callees_stmts(rest, a2)
    }
    SExprStmt(e)         -> walk_bare_callees_stmts(rest, walk_bare_callees(e, acc))
    SIndexAssign(a, b, c, _, _) -> {
      let a1 = walk_bare_callees(c, walk_bare_callees(b, walk_bare_callees(a, acc)))
      walk_bare_callees_stmts(rest, a1)
    }
    SUse(_, _, _)        -> walk_bare_callees_stmts(rest, acc)
  }
}

fn walk_bare_callees_clauses(cs: [HClause], acc: [String]) : [String] = match cs {
  []           -> acc
  [c, ...rest] -> match c {
    HC(_, _, body, _, _) -> walk_bare_callees_clauses(rest, walk_bare_callees(body, acc))
  }
}

# issue #381: warn on unused local `let` and pattern bindings.
#
# Policy (validated in the issue body):
#   - Local `let name = …` whose `name` is never referenced inside its
#     lexical scope: warn.
#   - Pattern binding (e.g. `Some(v) -> body` without `v` in body): warn.
#   - Function parameter unused: never warn (interface / protocol /
#     contract with caller).
#   - Any binder whose name starts with `_` (including `__`-prefixed
#     compiler-internal names like `__cv_*`, `__pcs_ret`): never warn.
#     `name_is_unused` already encodes the user-facing convention; we
#     extend the silence to `__`-prefixed names here because every
#     desugar that synthesises locals uses that namespace.
#
# The walker runs post-typer / pre-monomorphise (alongside
# `report_ambig_efns`). Running pre-mono avoids duplicate diagnostics
# from per-spec body copies; running post-typer means the AST has
# already been resolved (no spurious "use" via alias names).
#
# Reference detection uses `fv_expr` with empty `own` and `globals`,
# which yields the set of every free `EVar(name)` reachable from the
# sub-AST modulo scope rules already encoded in `fv_stmts_scoped`
# (so a re-binding of `name` inside the rest correctly shadows our
# binder for refs after the shadow). This is over-approximating in
# the conservative direction — when in doubt we mark the binding
# *used*, not unused.

fn diag_warning(file: String, line: Int, col: Int, msg: String) : Unit / Console + File {

  eprint("warning: #{msg}")
  eprint("  --> #{file}:#{int_to_string(line)}:#{int_to_string(col)}")
  emit_source_caret(file, line, col)
}

fn name_is_silenced(name: String) : Bool {
  # `_`-prefixed (including `__`-prefixed compiler-internal names) =
  # intentionally unused. `name_is_unused` only matches `_x` (not
  # `__x`); for diagnostics we silence the broader `_*` family.
  match char_at(name, 0) {
    Some(c0) -> c0 == '_'
    None -> false
  }
}

# Collect (name, line, col) triples for every binder a pattern
# introduces. Uses the pattern's own line/col — for destructuring
# patterns (`(x, y)`, `Some(v)`) all sub-binders share the outer
# pattern's location, which is the closest stable anchor stage 1
# preserves.

# Collect (name, line, col) triples for every binder a pattern
# introduces. Uses the pattern's own line/col — for destructuring
# patterns (`(x, y)`, `Some(v)`) all sub-binders share the outer
# pattern's location, which is the closest stable anchor stage 1
# preserves.
type UBind = UB(String, Int, Int)

fn pat_ubinds(pat: Pattern, acc: [UBind]) : [UBind] {
  let line = pat.line
  let col = pat.col
  match pat.pkind {
    PWild -> acc
    PLit(_) -> acc
    PBind(name) -> [UB(name, line, col), ...acc]
    PList(pats, opt_rest) -> {
      let acc1 = pat_ubinds_loop(pats, acc)
      match opt_rest {
        Some(rname) -> [UB(rname, line, col), ...acc1]
        None -> acc1
      }
    }
    PVariant(_, subs) -> pat_ubinds_loop(subs, acc)
    PVariantRecord(_, fields) -> pfield_ubinds_loop(fields, acc)
    PRecord(fields) -> pfield_ubinds_loop(fields, acc)
    PHole(_) -> acc
    PAs(name, sub) -> pat_ubinds(sub, [UB(name, line, col), ...acc])
    PNarrow(name, _) -> [UB(name, line, col), ...acc]
  }
}

fn pat_ubinds_loop(ps: [Pattern], acc: [UBind]) : [UBind] {
  match ps {
    [] -> acc
    [p, ...rest] -> pat_ubinds_loop(rest, pat_ubinds(p, acc))
  }
}

fn pfield_ubinds_loop(fs: [PField], acc: [UBind]) : [UBind] {
  match fs {
    [] -> acc
    [f, ...rest] -> match f {
      PField(_, sub, _) -> pfield_ubinds_loop(rest, pat_ubinds(sub, acc))
    }
  }
}

fn report_unused_ubinds(file: String, ubs: [UBind], refs: [String]) : Unit / Console + File {

  match ubs {
    [] -> ()
    [u, ...rest] -> match u {
      UB(name, line, col) -> {
        if name_is_silenced(name) { () }
        else if list_has(refs, name) { () }
        else {
          diag_warning(file, line, col,
            concat_all(["unused binding `", name, "`"]))
          diag_help("prefix with `_` to mark as intentionally unused")
        }
        report_unused_ubinds(file, rest, refs)
      }
    }
  }
}

# Walk a decl looking for unused local bindings. Skips parameter
# names entirely — interface compliance, protocol dispatch, and
# axiom signatures all justify silent unused params.

# Walk a decl looking for unused local bindings. Skips parameter
# names entirely — interface compliance, protocol dispatch, and
# axiom signatures all justify silent unused params.
#[doc("Walk a decl looking for unused local bindings. Skips parameter names entirely — interface compliance, protocol dispatch, and axiom signatures all justify silent unused params.")]
pub fn report_unused_in_decls(file: String, decls: [Decl]) : Unit / Console + File {

  match decls {
    [] -> ()
    [d, ...rest] -> {
      report_unused_in_decl(file, d)
      report_unused_in_decls(file, rest)
    }
  }
}

fn report_unused_in_decl(file: String, d: Decl) : Unit / Console + File {

  match d {
    DFn(_, _, _, _, _, _, body, _, _, mo) -> match mo {
      None    -> report_unused_in_expr(file, body)
      Some(_) -> ()
    }
    DTest(_, body, _, _)        -> report_unused_in_expr(file, body)
    DBench(_, body, _, _)       -> report_unused_in_expr(file, body)
    DCheck(_, _, body, _, _)    -> report_unused_in_expr(file, body)
    _ -> ()
  }
}

fn report_unused_in_expr(file: String, e: Expr) : Unit / Console + File {

  match e.kind {
    EInt(_) -> ()
    EReal(_) -> ()
    EBool(_) -> ()
    EChar(_) -> ()
    EStr(_, _) -> ()
    EUnit -> ()
    EVar(_) -> ()
    EUnder -> ()
    EPlaceholder -> ()
    EHole(_) -> ()
    ETodo(_) -> ()
    EVariantsOf(_, _) -> ()
    EModCall(_, _) -> ()
    EIntrinsic(_, args_) -> report_unused_in_exprs(file, args_)
    ECall(f, xs) -> {
      report_unused_in_expr(file, f)
      report_unused_in_exprs(file, xs)
    }
    EField(base, _) -> report_unused_in_expr(file, base)
    EIndex(a, b) -> {
      report_unused_in_expr(file, a)
      report_unused_in_expr(file, b)
    }
    EBinop(_, a, b) -> {
      report_unused_in_expr(file, a)
      report_unused_in_expr(file, b)
    }
    EUnop(_, x) -> report_unused_in_expr(file, x)
    EIf(c, t, eo) -> {
      report_unused_in_expr(file, c)
      report_unused_in_expr(file, t)
      match eo { Some(b) -> report_unused_in_expr(file, b) None -> () }
    }
    EMatch(scr, arms) -> {
      report_unused_in_expr(file, scr)
      report_unused_in_arms(file, arms)
    }
    ELambda(_, body) -> report_unused_in_expr(file, body)
    ERecordLit(_, fs) -> report_unused_in_field_inits(file, fs)
    EList(els) -> report_unused_in_list_elems(file, els)
    ERange(a, b, opt) -> {
      report_unused_in_expr(file, a)
      report_unused_in_expr(file, b)
      match opt { Some(s) -> report_unused_in_expr(file, s) None -> () }
    }
    EBlock(stmts, tail) -> report_unused_in_block(file, stmts, tail)
    EPipe(a, b) -> {
      report_unused_in_expr(file, a)
      report_unused_in_expr(file, b)
    }
    EMapPipe(a, b) -> {
      report_unused_in_expr(file, a)
      report_unused_in_expr(file, b)
    }
    EFlatMapPipe(a, b) -> {
      report_unused_in_expr(file, a)
      report_unused_in_expr(file, b)
    }
    EFilterPipe(a, b) -> {
      report_unused_in_expr(file, a)
      report_unused_in_expr(file, b)
    }
    EBang(inner) -> report_unused_in_expr(file, inner)
    ELitUnit(inner, _) -> report_unused_in_expr(file, inner)
    EHandle(body, _, _, init_opt, _, clauses, ret_opt) -> {
      report_unused_in_expr(file, body)
      match init_opt { Some(i) -> report_unused_in_expr(file, i) None -> () }
      report_unused_in_hclauses(file, clauses)
      match ret_opt {
        Some(r) -> match r { HR(_, b, _, _) -> report_unused_in_expr(file, b) }
        None -> ()
      }
    }
  }
}

fn report_unused_in_exprs(file: String, es: [Expr]) : Unit / Console + File {

  match es {
    [] -> ()
    [h, ...rest] -> {
      report_unused_in_expr(file, h)
      report_unused_in_exprs(file, rest)
    }
  }
}

fn report_unused_in_arms(file: String, arms: [Arm]) : Unit / Console + File {

  match arms {
    [] -> ()
    [a, ...rest] -> match a {
      Arm(pat, opt_g, body) -> {
        # An arm's pattern binders are visible in the (optional)
        # guard and the body. Collect references from both, then
        # warn on any binder absent from the union.
        let ubs = pat_ubinds(pat, [])
        let refs0 = match opt_g {
          Some(g) -> fv_expr(g, [], [], [])
          None    -> []
        }
        let refs = fv_expr(body, [], [], refs0)
        report_unused_ubinds(file, ubs, refs)
        match opt_g { Some(g) -> report_unused_in_expr(file, g) None -> () }
        report_unused_in_expr(file, body)
        report_unused_in_arms(file, rest)
      }
    }
  }
}

fn report_unused_in_field_inits(file: String, fs: [FieldInit]) : Unit / Console + File {

  match fs {
    [] -> ()
    [f, ...rest] -> match f {
      FI(_, e) -> {
        report_unused_in_expr(file, e)
        report_unused_in_field_inits(file, rest)
      }
    }
  }
}

fn report_unused_in_list_elems(file: String, els: [ListElem]) : Unit / Console + File {

  match els {
    [] -> ()
    [el, ...rest] -> {
      match el {
        ElPlain(e)  -> report_unused_in_expr(file, e)
        ElSpread(e) -> report_unused_in_expr(file, e)
      }
      report_unused_in_list_elems(file, rest)
    }
  }
}

fn report_unused_in_hclauses(file: String, cs: [HClause]) : Unit / Console + File {

  match cs {
    [] -> ()
    [c, ...rest] -> match c {
      HC(_, _, body, _, _) -> {
        report_unused_in_expr(file, body)
        report_unused_in_hclauses(file, rest)
      }
    }
  }
}

# Walk a block in source order. For each `SLet(pat, _, rhs)`:
#   1. Recurse into `rhs` (its body cannot reference the pattern's
#      binders — they aren't in scope yet).
#   2. Compute the set of free names referenced in the rest of the
#      block (subsequent stmts + optional tail). `fv_stmts_scoped`
#      respects shadowing — a later `SLet` of the same name kicks
#      that name out of `acc` for refs after the shadow point.
#   3. Warn on any pat-binder absent from that ref set.

# Walk a block in source order. For each `SLet(pat, _, rhs)`:
#   1. Recurse into `rhs` (its body cannot reference the pattern's
#      binders — they aren't in scope yet).
#   2. Compute the set of free names referenced in the rest of the
#      block (subsequent stmts + optional tail). `fv_stmts_scoped`
#      respects shadowing — a later `SLet` of the same name kicks
#      that name out of `acc` for refs after the shadow point.
#   3. Warn on any pat-binder absent from that ref set.
fn report_unused_in_block(file: String, stmts: [Stmt], tail: Option[Expr]) : Unit / Console + File {

  match stmts {
    [] -> match tail {
      Some(t) -> report_unused_in_expr(file, t)
      None    -> ()
    }
    [s, ...rest] -> {
      match s {
        SLet(pat, _, rhs) -> {
          report_unused_in_expr(file, rhs)
          let ubs = pat_ubinds(pat, [])
          let rest_refs = fv_stmts(rest, [], [], [])
          let refs = match tail {
            Some(t) -> fv_expr(t, [], [], rest_refs)
            None    -> rest_refs
          }
          report_unused_ubinds(file, ubs, refs)
        }
        SVar(_, _, rhs, _, _) -> report_unused_in_expr(file, rhs)
        SAssert(c, opt_m) -> {
          report_unused_in_expr(file, c)
          match opt_m { Some(m) -> report_unused_in_expr(file, m) None -> () }
        }
        SExprStmt(x) -> report_unused_in_expr(file, x)
        SIndexAssign(b, i, v, _, _) -> {
          report_unused_in_expr(file, b)
          report_unused_in_expr(file, i)
          report_unused_in_expr(file, v)
        }
        SUse(_, _, _) -> ()
      }
      report_unused_in_block(file, rest, tail)
    }
  }
}

fn list_head_or(xs: [String], fallback: String) : String = match xs {
  [] -> fallback
  [h, ..._rest] -> h
}

fn vs_to_evars(vs: [Variant], next_tag: Int, acc: [EVar]) : [EVar] = match vs_to_evars_count(vs, next_tag, acc) {
  CUVStep(_, a) -> a
}

type EPrelude = EP(String, String, Int)     # kai name, c name, arity

fn prelude_table() : [EPrelude] {
  [
    EP("print",            "kai_prelude_print",            1),
    EP("eprint",           "kai_prelude_eprint",           1),
    EP("write_stdout",     "kai_prelude_write_stdout",     1),
    EP("panic",            "kai_prelude_panic",            1),
    EP("exit",             "kai_prelude_exit",             1),
    EP("int_to_string",    "kai_prelude_int_to_string",    1),
    EP("real_to_string",   "kai_prelude_real_to_string",   1),
    EP("int_to_real",      "kai_prelude_int_to_real",      1),
    EP("real_to_int",      "kai_prelude_real_to_int",      1),
    # libm bindings (issue #343) — pass-through NaN/Inf semantics.
    EP("real_sqrt",        "kai_prelude_real_sqrt",        1),
    EP("real_cbrt",        "kai_prelude_real_cbrt",        1),
    EP("real_exp",         "kai_prelude_real_exp",         1),
    EP("real_log",         "kai_prelude_real_log",         1),
    EP("real_log2",        "kai_prelude_real_log2",        1),
    EP("real_log10",       "kai_prelude_real_log10",       1),
    EP("real_sin",         "kai_prelude_real_sin",         1),
    EP("real_cos",         "kai_prelude_real_cos",         1),
    EP("real_tan",         "kai_prelude_real_tan",         1),
    EP("real_asin",        "kai_prelude_real_asin",        1),
    EP("real_acos",        "kai_prelude_real_acos",        1),
    EP("real_atan",        "kai_prelude_real_atan",        1),
    EP("real_sinh",        "kai_prelude_real_sinh",        1),
    EP("real_cosh",        "kai_prelude_real_cosh",        1),
    EP("real_tanh",        "kai_prelude_real_tanh",        1),
    EP("real_signum",      "kai_prelude_real_signum",      1),
    EP("real_is_nan",      "kai_prelude_real_is_nan",      1),
    EP("real_is_inf",      "kai_prelude_real_is_inf",      1),
    EP("real_pow",         "kai_prelude_real_pow",         2),
    EP("real_atan2",       "kai_prelude_real_atan2",       2),
    EP("real_rem",         "kai_prelude_real_rem",         2),
    EP("string_length",    "kai_prelude_string_length",    1),
    EP("string_concat",    "kai_prelude_string_concat",    2),
    EP("string_concat_all","kai_prelude_string_concat_all",1),
    EP("string_join",      "kai_prelude_string_join",      2),
    EP("list_length",      "kai_prelude_list_length",      1),
    EP("list_append",      "kai_prelude_list_append",      2),
    EP("list_reverse",     "kai_prelude_list_reverse",     1),
    EP("map",              "kai_prelude_map",              2),
    # issue #201: paired runtime entry for the `||` flat-map pipe.
    # Same shape as `map`; head-type-to-module dispatch in
    # `synth_flat_map_pipe` resolves to `<module>.flat_map`, and the
    # module bound to head-type `List` is `list` whose `flat_map` lands
    # on this prelude symbol so `[T]` works without an explicit import.
    EP("flat_map",         "kai_prelude_flat_map",         2),
    EP("filter",           "kai_prelude_filter",           2),
    EP("reduce",           "kai_prelude_reduce",           3),
    EP("each",             "kai_prelude_each",             2),
    EP("args",             "kai_prelude_args",             0),
    # Issue #127: argv[0] as a flat prelude (path (a) in the issue
    # body, mirroring how `args()` is also a prelude even though
    # `Env.args()` exists as an op). `stdlib/os/args.kai` re-exports
    # this as `program_name()` so the dotted-call surface stays
    # uniform with the rest of `os.args`.
    EP("program_name",     "kai_prelude_program_name",     0),
    # Hanga Roa: compile-time hard-coded path to `stdlib/`. Used by
    # the core loader to find core/*.kai without --prelude flags.
    EP("stdlib_path",      "kai_prelude_stdlib_path",      0),
    # Canonicalise a filesystem path via realpath(3). Used by the
    # import resolver to dedup module loads when --prelude paths
    # are absolute (core auto-load) but user --path arguments are
    # relative — without this the same file loads twice.
    EP("abspath",          "kai_prelude_abspath",          1),
    EP("read_file",        "kai_prelude_read_file",        1),
    EP("write_file",       "kai_prelude_write_file",       2),
    # Issue #345: fs/file expansion (exists/delete/rename).
    EP("file_exists",      "kai_prelude_file_exists",      1),
    EP("file_delete",      "kai_prelude_file_delete",      1),
    EP("file_rename",      "kai_prelude_file_rename",      2),
    # Issue #482: binary file IO (deferred from #345).
    EP("file_read_bytes",  "kai_prelude_file_read_bytes",  1),
    EP("file_write_bytes", "kai_prelude_file_write_bytes", 2),
    # Issue #344: fs/dir surface (list/create/remove/walk).
    EP("dir_list_dir",     "kai_prelude_dir_list_dir",     1),
    EP("dir_create_dir",   "kai_prelude_dir_create_dir",   1),
    EP("dir_remove_dir",   "kai_prelude_dir_remove_dir",   1),
    EP("dir_walk",         "kai_prelude_dir_walk",         1),
    EP("read_line",        "kai_prelude_read_line",        0),
    # Issue #453: byte-oriented stdin (LSP framing precursor).
    EP("read_bytes",       "kai_prelude_read_bytes",       1),
    EP("string_to_int",    "kai_prelude_string_to_int",    1),
    EP("string_to_real",   "kai_prelude_string_to_real",   1),
    EP("char_at",          "kai_prelude_char_at",          2),
    EP("string_split",     "kai_prelude_string_split",     2),
    EP("string_contains",  "kai_prelude_string_contains",  2),
    EP("string_slice",     "kai_prelude_string_slice",     3),
    EP("char_to_int",      "kai_prelude_char_to_int",      1),
    EP("int_to_char",      "kai_prelude_int_to_char",      1),
    # Issue #592 KAB2 cache: build a 1-byte String from the low 8 bits
    # of `n`. Bypasses `kai_to_string(KAI_CHAR)` + `Show for Char`'s
    # `\xNN` escape rendering so every byte value 0..255 round-trips
    # byte-exact; the cache codec needs this for raw binary payloads.
    EP("int_to_byte_string","kai_prelude_int_to_byte_string", 1),
    # Issue #592 KAB2 cache: read one byte from String as Int 0..255,
    # or -1 on OOB. Bypasses Option allocation of `char_at`; reduces
    # cache deserialize wall by ~80% on warm loads.
    EP("string_byte_at_int","kai_prelude_string_byte_at_int", 2),
    # Issue #373: Hash protocol backends — full-width FNV-1a over a
    # String's bytes, and IEEE-754 bit reinterpret for Real.
    EP("string_hash",       "kai_prelude_string_hash",        1),
    EP("real_bits",         "kai_prelude_real_bits",          1),
    # Lane 4 (#473): Byte nominal primitive. See add_prelude_sigs above
    # for the type-level surface; C bodies live in stage0/runtime.h.
    EP("int_to_byte",        "kai_prelude_int_to_byte",        1),
    EP("byte_to_int",        "kai_prelude_byte_to_int",        1),
    EP("byte_add",           "kai_prelude_byte_add",           2),
    EP("byte_sub",           "kai_prelude_byte_sub",           2),
    EP("byte_eq",            "kai_prelude_byte_eq",            2),
    EP("byte_lt",            "kai_prelude_byte_lt",            2),
    EP("byte_to_string",     "kai_prelude_byte_to_string",     1),
    EP("array_make",       "kai_prelude_array_make",       2),
    EP("array_length",     "kai_prelude_array_length",     1),
    EP("array_get",        "kai_prelude_array_get",        2),
    EP("array_set",        "kai_prelude_array_set",        3),
    EP("array_grow",       "kai_prelude_array_grow",       3),
    # m8 #7: mailbox runtime
    EP("mailbox_alloc",         "kai_prelude_mailbox_alloc",         0),
    EP("mailbox_alloc_bounded", "kai_prelude_mailbox_alloc_bounded", 2),
    EP("mailbox_send",          "kai_prelude_mailbox_send",          2),
    EP("mailbox_recv",          "kai_prelude_mailbox_recv",          1),
    EP("mailbox_free",          "kai_prelude_mailbox_free",          1),
    # Tier 2 spawn_actor — alloc-without-stamp + reassign owner to a
    # spawned fiber. Used by stdlib/actor.kai's `spawn_actor`.
    EP("mailbox_alloc_unowned",  "kai_prelude_mailbox_alloc_unowned",  0),
    EP("mailbox_assign_owner",   "kai_prelude_mailbox_assign_owner",   2)
  ]
}

fn prelude_find(target: String) : Option[EPrelude] {
  prelude_find_loop(prelude_table(), target)
}

fn prelude_find_loop(table: [EPrelude], target: String) : Option[EPrelude] {
  match table {
    [] -> None
    [ep, ...rest] -> match ep {
      EP(name, _, _) -> if name == target { Some(ep) } else { prelude_find_loop(rest, target) }
    }
  }
}

# ---- expression emission ----

fn emit_ident_callee(name: String) : String {
  match prelude_find(name) {
    Some(ep) -> match ep { EP(_, cname, _) -> cname }
    None -> cat2("kai_", name)
  }
}

# Emit an ident used as a value (not a call target).
#
# `lcs` is the lexical scope at this site — the list of local
# names currently bound by an enclosing fn param, lambda param,
# `let` / `var`, match-arm pattern, `use` desugar, or handle
# alias. Locals always win over a same-named top-level fn or
# prelude builtin: the user wrote `let drop = 5; drop` and the
# typer accepted it as a local read, so emit `kai_drop` (the C
# variable holding the local) rather than the top-level `drop`
# fn's closure thunk. Without this guard, `efn_find` matches the
# top-level fn and the local read silently hands back the wrong
# value (a closure pointer where the user expected an Int). The
# LLVM backend has had this guard since m3d (`llvm_local_find`
# in `llvm_emit_expr`); the C backend was missing it until m14
# v1.x.

# Emit an ident used as a value (not a call target).
#
# `lcs` is the lexical scope at this site — the list of local
# names currently bound by an enclosing fn param, lambda param,
# `let` / `var`, match-arm pattern, `use` desugar, or handle
# alias. Locals always win over a same-named top-level fn or
# prelude builtin: the user wrote `let drop = 5; drop` and the
# typer accepted it as a local read, so emit `kai_drop` (the C
# variable holding the local) rather than the top-level `drop`
# fn's closure thunk. Without this guard, `efn_find` matches the
# top-level fn and the local read silently hands back the wrong
# value (a closure pointer where the user expected an Int). The
# LLVM backend has had this guard since m3d (`llvm_local_find`
# in `llvm_emit_expr`); the C backend was missing it until m14
# v1.x.
fn emit_ident_value(name: String, lcs: [String], fns: [EFn], variants: [EVar]) : String {
  if list_has(lcs, name) { cat2("kai_", name) }
  else { match evar_find(variants, name) {
    Some(_) -> concat_all([
      "kai_variant_u(", int_to_string(evar_find_tag(variants, name)),
      ", \"", name, "\", 0, 0, NULL)"
    ])
    None -> match prelude_find(name) {
      Some(ep) -> match ep {
        EP(_, cname, ar) ->
          cat5("kai_closure(&_", cname, "_thunk, ", int_to_string(ar), ", 0, NULL)")
      }
      None -> match efn_resolve(fns, name) {
        Some(EFn(_, ar, mo, _)) ->
          cat5("kai_closure(&_kai_", c_sym(name, mo), "_thunk, ", int_to_string(ar), ", 0, NULL)")
        None -> cat2("kai_", name)
      }
    }
  } }
}

# Emit a raw string literal's *body* as a C string literal. For now this
# only handles hello-style cases: no #{...} interpolation, no \u{HHHH},
# the escapes that kaikai and C share are passed through unchanged.
# Later milestones extend this to full interpolation.

# Emit a raw string literal's *body* as a C string literal. For now this
# only handles hello-style cases: no #{...} interpolation, no \u{HHHH},
# the escapes that kaikai and C share are passed through unchanged.
# Later milestones extend this to full interpolation.
fn emit_string_lit_body(span: String) : String {
  # span includes opening and closing quotes; C literal syntax matches.
  span
}

# m7d §23: pick the runtime helper a `++` lowers to. The typer
# pins the binop's result type to `String` or `[T]`; anything else
# means we lost the annotation somewhere upstream.

# m7d §23: pick the runtime helper a `++` lowers to. The typer
# pins the binop's result type to `String` or `[T]`; anything else
# means we lost the annotation somewhere upstream.
fn concat_helper_of(opt_ty: Option[Ty]) : String {
  match opt_ty {
    Some(t) -> match t {
      TyString    -> "kai_prelude_string_concat"
      TyListT(_)  -> "kai_prelude_list_append"
      _           -> "kai_prelude_string_concat /* m7d §23: unexpected type */"
    }
    None -> "kai_prelude_string_concat /* m7d §23: missing type */"
  }
}

fn binop_cname(op: String) : Option[String] {
  if op == "+" { Some("kai_op_add") }
  else if op == "-" { Some("kai_op_sub") }
  else if op == "*" { Some("kai_op_mul") }
  else if op == "/" { Some("kai_op_div") }
  else if op == "%" { Some("kai_op_mod") }
  else if op == "^" { Some("kai_op_pow_int") }
  else if op == "<" { Some("kai_op_lt") }
  else if op == ">" { Some("kai_op_gt") }
  else if op == "<=" { Some("kai_op_le") }
  else if op == ">=" { Some("kai_op_ge") }
  else if op == "==" { Some("kai_op_eq_v") }
  else if op == "!=" { Some("kai_op_ne_v") }
  else { None }
}

fn unop_cname(op: String) : Option[String] {
  if op == "-" { Some("kai_op_neg") }
  else if op == "not" { Some("kai_op_boolnot") }
  else { None }
}

fn emit_call_args(src: String, args_e: [Expr], cx: EmitCtx) : String / Console =

  join_with(map(args_e, (a) => emit_expr(src, a, cx)), ", ")

# Phase 3 unboxing — emit each call argument as a raw C scalar
# matching the UFn signature's slot ty. `emit_expr_raw` falls back
# to the boxed-then-unbox boundary form if the arg is MBoxed; for
# raw children (literal / EVar to a raw param / nested UFn call /
# raw arith) it emits the native scalar directly. The result is
# the comma-joined argument list ready for the call site.

# Phase 3 unboxing — emit each call argument as a raw C scalar
# matching the UFn signature's slot ty. `emit_expr_raw` falls back
# to the boxed-then-unbox boundary form if the arg is MBoxed; for
# raw children (literal / EVar to a raw param / nested UFn call /
# raw arith) it emits the native scalar directly. The result is
# the comma-joined argument list ready for the call site.
fn emit_call_args_raw(src: String, args_e: [Expr], cx: EmitCtx) : String / Console =

  join_with(map(args_e, (a) => emit_expr_raw(src, a, cx)), ", ")

# m8.x bug #12: emit `KaiValue *_op_arg_<i> = <expr>; ` for each
# arg of an op call. The args are evaluated *before* the
# `in_dispatch` flag is set, so any inner op call to the same
# handler still finds the live node.

# m8.x bug #12: emit `KaiValue *_op_arg_<i> = <expr>; ` for each
# arg of an op call. The args are evaluated *before* the
# `in_dispatch` flag is set, so any inner op call to the same
# handler still finds the live node.
fn emit_op_arg_bindings(src: String, args_e: [Expr], i: Int,
                          cx: EmitCtx) : String / Console {

  match args_e {
    [] -> ""
    [a, ...rest] -> {
      let expr_c = emit_expr(src, a, cx)
      let head = concat_all(["KaiValue *_op_arg_", int_to_string(i), " = ", expr_c, "; "])
      let tail = emit_op_arg_bindings(src, rest, i + 1, cx)
      string_concat(head, tail)
    }
  }
}

# Comma-separated list `_op_arg_0, _op_arg_1, ...` that gets
# spliced into the dispatch call site after `_ev_op`.

# Comma-separated list `_op_arg_0, _op_arg_1, ...` that gets
# spliced into the dispatch call site after `_ev_op`.
fn emit_op_arg_pass_list(args_e: [Expr], i: Int) : String {
  match args_e {
    [] -> ""
    [_, ...rest] -> {
      let head = concat_all(["_op_arg_", int_to_string(i)])
      match rest {
        [] -> head
        _  -> concat_all([head, ", ", emit_op_arg_pass_list(rest, i + 1)])
      }
    }
  }
}

# Build the `{.ptr = X0}, {.ptr = X1}, ...` slot-list string from a
# list of arg expressions. Used by the boxed (non-Phase 2) variant
# constructor path where every slot is a pointer.

# Build the `{.ptr = X0}, {.ptr = X1}, ...` slot-list string from a
# list of arg expressions. Used by the boxed (non-Phase 2) variant
# constructor path where every slot is a pointer.
fn emit_call_args_slots(src: String, args_e: [Expr], cx: EmitCtx) : String / Console =
  join_with(map(args_e, (a) => string_concat("{.ptr = ", string_concat(emit_expr(src, a, cx), "}"))), ", ")

# Wrap an already-rendered argument expression as a single boxed slot
# literal. Used by pipe lowering where the LHS expression is
# pre-rendered before being concatenated with the rest.

# Wrap an already-rendered argument expression as a single boxed slot
# literal. Used by pipe lowering where the LHS expression is
# pre-rendered before being concatenated with the rest.
fn arg_str_as_slot(arg_str: String) : String =
  string_concat("{.ptr = ", string_concat(arg_str, "}"))

fn emit_variant_call(name: String, n_args: Int, slot_out: String, cx: EmitCtx) : String {
  let tag_str = int_to_string(evar_find_tag(cx.variants, name))
  if n_args == 0 {
    concat_all(["kai_variant_u(", tag_str, ", \"", name, "\", 0, 0, NULL)"])
  } else {
    concat_all([
      emit_variant_ctor(cx), tag_str, ", \"", name, "\", ", int_to_string(n_args),
      ", 0, (KaiVarSlot[]){", slot_out, "})"
    ])
  }
}

# Issue #440 Phase 2 — classify a payload TypeExpr against the inline
# slot kinds Phase 2 supports. Returns:
#   0 = pointer (default — emit boxed slot)
#   1 = Int (i64, unboxed)
#   2 = Real (double, unboxed)
# Anything else (List, Fn, dimensioned, refined, user types) returns 0
# so the slot stays boxed. The classifier inspects the surface
# `TyKind` only — it does not consult resolved types — so polymorphic
# variants (`Some(a)`) fall through to the pointer path even when the
# call site has a concrete Int instantiation. That conservative
# choice keeps Phase 2 self-contained: only sum types whose
# declaration spells `Int` / `Real` literally get unboxed slots.

# Issue #440 Phase 2 — classify a payload TypeExpr against the inline
# slot kinds Phase 2 supports. Returns:
#   0 = pointer (default — emit boxed slot)
#   1 = Int (i64, unboxed)
#   2 = Real (double, unboxed)
# Anything else (List, Fn, dimensioned, refined, user types) returns 0
# so the slot stays boxed. The classifier inspects the surface
# `TyKind` only — it does not consult resolved types — so polymorphic
# variants (`Some(a)`) fall through to the pointer path even when the
# call site has a concrete Int instantiation. That conservative
# choice keeps Phase 2 self-contained: only sum types whose
# declaration spells `Int` / `Real` literally get unboxed slots.
fn variant_slot_kind(te: TypeExpr) : Int = match te.tkind {
  TyName(n, args) ->
    if list_length(args) == 0 {
      if n == "Int" { 1 }
      else if n == "Real" { 2 }
      else { 0 }
    } else { 0 }
  _ -> 0
}

# Build the `slot_mask` value for a payload type list. 2 bits per
# slot, LSB-first. Returns 0 for any list with > 16 slots (mask
# exhausts the 32-bit field — falls back to all-pointer layout).
# Phase 2 — slot position scaler. kinds are 0/1/2 and slot fields
# are disjoint 2-bit windows, so addition is the same as bitwise OR
# (no carry-in). We avoid `bit_or` / `<<` because the stage 1
# compiler does not parse the bit-intrinsic surface; stage 2 builds
# the mask with plain arithmetic so the bootstrap chain works.

# Build the `slot_mask` value for a payload type list. 2 bits per
# slot, LSB-first. Returns 0 for any list with > 16 slots (mask
# exhausts the 32-bit field — falls back to all-pointer layout).
# Phase 2 — slot position scaler. kinds are 0/1/2 and slot fields
# are disjoint 2-bit windows, so addition is the same as bitwise OR
# (no carry-in). We avoid `bit_or` / `<<` because the stage 1
# compiler does not parse the bit-intrinsic surface; stage 2 builds
# the mask with plain arithmetic so the bootstrap chain works.
fn variant_slot_pos(i: Int) : Int =
  if i <= 0 { 1 } else { 4 * variant_slot_pos(i - 1) }

fn variant_slot_mask_loop(tys: [TypeExpr], i: Int, acc: Int) : Int = match tys {
  [] -> acc
  [t, ...rest] ->
    if i >= 16 { 0 }
    else {
      let k = variant_slot_kind(t)
      variant_slot_mask_loop(rest, i + 1, acc + (k * variant_slot_pos(i)))
    }
}

fn variant_slot_mask(tys: [TypeExpr]) : Int = variant_slot_mask_loop(tys, 0, 0)

# True iff any slot of `tys` is a primitive (Int or Real) — i.e. the
# typed construction path is worth taking. Empty list / all-pointer
# tys return false, so the legacy `kai_variant` boxed path is used.

# True iff any slot of `tys` is a primitive (Int or Real) — i.e. the
# typed construction path is worth taking. Empty list / all-pointer
# tys return false, so the legacy `kai_variant` boxed path is used.
pub fn variant_has_primitive_slot(tys: [TypeExpr]) : Bool = match tys {
  [] -> false
  [t, ...rest] ->
    if variant_slot_kind(t) != 0 { true }
    else { variant_has_primitive_slot(rest) }
}

# Emit a single `KaiVarSlot` initialiser for arg `e` against payload
# type `te`. For pointer slots: `{.ptr = <boxed>}`. For Int/Real: pass
# the boxed value through `kai_take_int` / `kai_take_real` so the
# ephemeral box (e.g. a freshly-allocated `kai_int(7)`) gets
# released, and the raw scalar lands in the typed slot. Singleton
# Ints survive the decref because their rc is pinned at INT32_MAX.

# Emit a single `KaiVarSlot` initialiser for arg `e` against payload
# type `te`. For pointer slots: `{.ptr = <boxed>}`. For Int/Real: pass
# the boxed value through `kai_take_int` / `kai_take_real` so the
# ephemeral box (e.g. a freshly-allocated `kai_int(7)`) gets
# released, and the raw scalar lands in the typed slot. Singleton
# Ints survive the decref because their rc is pinned at INT32_MAX.
fn emit_variant_slot_init(src: String, e: Expr, te: TypeExpr,
                          cx: EmitCtx) : String / Console {
  let k = variant_slot_kind(te)
  let boxed = emit_expr(src, e, cx)
  if k == 1 {
    concat_all(["{.i64 = kai_take_int(", boxed, ")}"])
  } else if k == 2 {
    concat_all(["{.r = kai_take_real(", boxed, ")}"])
  } else {
    concat_all(["{.ptr = ", boxed, "}"])
  }
}

fn emit_variant_slot_init_list(src: String, args_e: [Expr], tys: [TypeExpr],
                               cx: EmitCtx) : String / Console {
  match args_e {
    [] -> ""
    [e, ...rest_e] -> match tys {
      [] -> {
        # Defensive: arity mismatch between call site and decl; fall
        # back to pointer slot to keep the C compilable. The typer
        # would have rejected this earlier.
        let head = concat_all(["{.ptr = ",
          emit_expr(src, e, cx), "}"])
        match rest_e {
          [] -> head
          _  -> concat_all([head, ", ",
            emit_variant_slot_init_list(src, rest_e, [], cx)])
        }
      }
      [t, ...rest_t] -> {
        let head = emit_variant_slot_init(src, e, t, cx)
        match rest_e {
          [] -> head
          _  -> concat_all([head, ", ",
            emit_variant_slot_init_list(src, rest_e, rest_t, cx)])
        }
      }
    }
  }
}

# Phase 2 entry point for variant construction. When the variant has
# at least one primitive payload slot, emit `kai_variant_u` with a
# typed slot literal and a populated mask. Otherwise return None so
# the caller falls back to the legacy `kai_variant` path.

# Phase 2 entry point for variant construction. When the variant has
# at least one primitive payload slot, emit `kai_variant_u` with a
# typed slot literal and a populated mask. Otherwise return None so
# the caller falls back to the legacy `kai_variant` path.
fn emit_variant_call_typed(name: String, args_e: [Expr], tys: [TypeExpr],
                           src: String, cx: EmitCtx) : Option[String] / Console {
  if variant_has_primitive_slot(tys) {
    let n = list_length(args_e)
    let mask = variant_slot_mask(tys)
    let slot_inits = emit_variant_slot_init_list(src, args_e, tys, cx)
    let tag_str = int_to_string(evar_find_tag(cx.variants, name))
    Some(concat_all([
      emit_variant_ctor(cx), tag_str, ", \"", name, "\", ", int_to_string(n),
      ", ", int_to_string(mask),
      ", (KaiVarSlot[]){", slot_inits, "})"
    ]))
  } else {
    None
  }
}

# issue #118 — lower a `__perceus_reuse_variant` rebuild given the
# constructor name + arg expressions. Shared by the `EVar` and
# `EModCall` callee shapes (the resolver qualifies user ctors to the
# latter). Typed-payload ctors (issue #440) still route to the
# alloc-fresh `kai_variant_u`: `kai_reuse_or_alloc_variant` writes
# `slots[i].ptr` and assumes `slot_mask == 0`, which would mismatch
# the typed extract (`slots[i].i64`). Reuse-for-typed-cells is a
# follow-up lane.
fn emit_reuse_variant_body(src: String, cname: String, cargs: [Expr],
                           cx: EmitCtx) : String / Console {
  let n = list_length(cargs)
  let tys_opt = evar_payload_tys(cx.variants, cname)
  let has_prim = match tys_opt {
    Some(ts) -> variant_has_primitive_slot(ts)
    None     -> false
  }
  if has_prim {
    match tys_opt {
      Some(ts) -> {
        let mask = variant_slot_mask(ts)
        let slot_inits = emit_variant_slot_init_list(src, cargs, ts, cx)
        let tag_str = int_to_string(evar_find_tag(cx.variants, cname))
        concat_all([
          "kai_variant_u(", tag_str, ", \"", cname, "\", ", int_to_string(n),
          ", ", int_to_string(mask),
          ", (KaiVarSlot[]){", slot_inits, "})"
        ])
      }
      None -> "kai_unit() /* __perceus_reuse_variant: typed lookup vanished */"
    }
  } else if n == 0 {
    let tag_str = int_to_string(evar_find_tag(cx.variants, cname))
    concat_all([
      "kai_reuse_or_alloc_variant(_scr, ", tag_str, ", \"", cname,
      "\", 0, 0, NULL)"
    ])
  } else {
    let slot_strs = emit_call_args_slots(src, cargs, cx)
    let tag_str = int_to_string(evar_find_tag(cx.variants, cname))
    concat_all([
      "kai_reuse_or_alloc_variant(_scr, ", tag_str, ", \"", cname,
      "\", ", int_to_string(n),
      ", 0, (KaiVarSlot[]){", slot_strs, "})"
    ])
  }
}

fn emit_call_expr(src: String, f: Expr, args_e: [Expr], cx: EmitCtx) : String / Console {

  # Phase 3 unboxing — when the callee resolves to a UFn (raw C
  # signature), emit the call against raw args and wrap the
  # result with `kai_int` / `kai_bool` / `kai_char` / `kai_real`
  # so the boxed-context caller still sees a `KaiValue *`. This
  # short-circuits the regular dispatch chain (variant / prelude /
  # closure-thunk fallback) because UFns are exclusively
  # user-declared top-level fns and cannot be overridden by an
  # `lcs` shadow with the same name (a let-bound closure shadowing
  # a UFn keeps the boxed call site — `lcs.has(name)` test wins).
  match emit_ufn_boxed_call(src, f, args_e, cx) {
    Some(s) -> s
    None    -> emit_call_expr_default(src, f, args_e, cx)
  }
}

# Phase 3 unboxing — try to emit the call as a raw-call boxed
# (`kai_<T>(callee(raw_args))`). Returns None when the callee
# does not resolve to a UFn; the caller falls back to the
# original boxed-only dispatch.

# Phase 3 unboxing — try to emit the call as a raw-call boxed
# (`kai_<T>(callee(raw_args))`). Returns None when the callee
# does not resolve to a UFn; the caller falls back to the
# original boxed-only dispatch.
fn emit_ufn_boxed_call(src: String, f: Expr, args_e: [Expr], cx: EmitCtx) : Option[String] / Console {

  match f.kind {
    EVar(callee) ->
      if list_has(cx.lcs, callee) { None }
      else { match efn_resolve(cx.fns, callee) {
        Some(EFn(_, _, mo, Some(US(_, rt)))) -> {
          let raw_args = emit_call_args_raw(src, args_e, cx)
          let raw_call = cat5("kai_", c_sym(callee, mo), "(", raw_args, ")")
          Some(box_wrap(Some(rt), raw_call))
        }
        _ -> None
      } }
    EModCall(mod, fname) -> match lookup_ufn_sig(cx.fns, fname, Some(mod)) {
      Some(US(_, rt)) -> {
        let raw_args = emit_call_args_raw(src, args_e, cx)
        let raw_call = cat5("kai_", c_sym(fname, Some(mod)), "(", raw_args, ")")
        Some(box_wrap(Some(rt), raw_call))
      }
      None -> None
    }
    _ -> None
  }
}

fn emit_call_expr_default(src: String, f: Expr, args_e: [Expr], cx: EmitCtx) : String / Console {

  let call_args = emit_call_args(src, args_e, cx)
  match f.kind {
    EVar(callee) -> {
      # m7a #6d: `resume(v)` lowers to a runtime call that performs
      # the one-shot status check, flips the status, and tail-calls
      # the continuation's `fn` (currently kai_cont_identity, until
      # the full CPS transform reifies the rest of the caller's
      # body). Doc C §*resume representation*.
      if tcrec_is_sentinel(callee) {
        # Issue #37: self-tail-call site, planted by `tcrec_rewrite_decl`.
        # The callee carries `__kai_tcrec|<c_sym>|<dropmask>|<p0>|<p1>|...`;
        # split, parse, and emit the rebind+goto block. The label
        # `_kai_<c_sym>_entry` is planted by `emit_fn_body`.
        let parts = tcrec_split_pipe(callee)
        match parts {
          [_, sym, dropmask_str, ...pnames] -> {
            let dropmask = tcrec_parse_decimal(dropmask_str)
            tcrec_emit_goto(src, sym, dropmask, pnames, args_e,
                            cx)
          }
          _ -> "kai_unit() /* tcrec: malformed sentinel */"
        }
      } else if callee == "resume" {
        match args_e {
          [a] -> concat_all([
            "kai_cont_resume(k, ", emit_expr(src, a, cx), ")"
          ])
          # m7b #11: 2-arg resume `resume(v, new_state)` — used in
          # parameterised handler clauses (`State[T]` / `Writer[W]`).
          # Writes the new state into the enclosing Ev's `state` slot
          # before resuming. `self` is the clause's first argument.
          [a, ns] -> concat_all([
            "({ self->state = ",
            emit_expr(src, ns, cx),
            "; kai_cont_resume(k, ",
            emit_expr(src, a, cx),
            "); })"
          ])
          _   -> "kai_unit() /* resume: arity mismatch (expected 1 or 2 args) */"
        }
      } else if callee == "__perceus_dup" {
        # m5 #4 — AST-level dup, lowered to runtime `kai_incref`.
        # Inserted by `perceus_pass` around every non-last EVar read of
        # a binding that lives long enough to need an extra reference.
        match args_e {
          [a] -> concat_all([
            "kai_internal_dup(", emit_expr(src, a, cx), ")"
          ])
          _   -> "kai_unit() /* __perceus_dup: arity mismatch */"
        }
      } else if callee == "__strip_unit" {
        # m12.8 phase 2: typer-internal erasure of the unit annotation
        # on `Real<u>`. At runtime it is identity — units carry no
        # representation, so the lowered call is exactly the inner
        # expression. Inherits the original `unitless` emit shape
        # (Bug 8 retired the user-visible name; the parametric Show
        # impl in stdlib/protocols.kai now uses this intrinsic to feed
        # `Real<u>` into `real_to_string : Real -> String`).
        match args_e {
          [a] -> emit_expr(src, a, cx)
          _   -> "kai_unit() /* __strip_unit: expected 1 arg */"
        }
      } else if callee == "unit_name" {
        # m12.8.x phase 2 (Gap 1, partial): compile-time reflection
        # on the dimensioned argument. Inlines the canonical unit
        # symbol as a String literal. Reads the arg's `.ty` (which
        # the typed-AST finalisation pass populated with the fully
        # substituted type). When the unit is still a UVar (e.g.
        # the protocol-impl-generic case) or the arg type is bare
        # `Real` with no dimension, an empty string literal is
        # emitted instead of failing — keeps user code that calls
        # `unit_name` defensively well-defined.
        match args_e {
          [a] -> {
            let nm = unit_name_of_ty(a.ty)
            concat_all(["kai_str(\"", nm, "\")"])
          }
          _ -> "kai_unit() /* unit_name: expected 1 arg */"
        }
      } else if callee == "__perceus_drop" {
        # m5 #4 — AST-level drop, lowered to runtime `kai_decref`
        # (returns Unit so the call site type-checks as KaiValue *).
        match args_e {
          [a] -> concat_all([
            "kai_internal_drop(", emit_expr(src, a, cx), ")"
          ])
          _   -> "kai_unit() /* __perceus_drop: arity mismatch */"
        }
      } else if callee == "__perceus_reuse_cons" {
        # issue #118 — reuse-in-place for cons cells. The recogniser
        # synthesises calls of the form
        #   `__perceus_reuse_cons(__pcs_scr, head, tail)`
        # inside a `match SCRUT { [h, ...t] -> ... }` arm body.
        # `__pcs_scr` is a synthetic identifier that lowers to the
        # match emitter's local `_scr` — sidestepping the need to
        # teach `emit_match_default` about reuse-aware decref. The
        # runtime helper reads `_scr->rc`: when unique, it rewrites
        # the cell in place + `kai_incref`s the cell so it survives
        # the `kai_decref(_scr)` at match exit; otherwise it falls
        # back to `kai_cons` and leaves `_scr` intact for the match
        # exit to reclaim.
        match args_e {
          [_scr, h, t] -> concat_all([
            "kai_reuse_or_alloc_cons(_scr, ",
            emit_expr(src, h, cx), ", ",
            emit_expr(src, t, cx), ")"
          ])
          _ -> "kai_unit() /* __perceus_reuse_cons: arity mismatch (expected 3 args) */"
        }
      } else if callee == "__perceus_reuse_record" {
        # issue #118 — reuse-in-place for record cells. The recogniser
        # synthesises `__perceus_reuse_record(__pcs_scr, {field: val, ...})`
        # where the literal record arg is a same-arity rebuild. We
        # extract its field exprs + names from the ERecordLit and
        # forward them in the same shape `kai_record` expects.
        match args_e {
          [_scr, lit] -> match lit.kind {
            ERecordLit(_rec_name, fis) -> {
              let n = list_length(fis)
              let vals  = join_with(map(fis, (fi) => emit_field_init_val(src, fi, cx)), ", ")
              let names = join_with(map(fis, emit_field_init_name), ", ")
              concat_all([
                "kai_reuse_or_alloc_record(_scr, ",
                int_to_string(n),
                ", (KaiValue *[]){", vals, "}, (const char *[]){", names, "})"
              ])
            }
            _ -> "kai_unit() /* __perceus_reuse_record: 2nd arg must be a record literal */"
          }
          _ -> "kai_unit() /* __perceus_reuse_record: arity mismatch (expected 2 args) */"
        }
      } else if callee == "__perceus_reuse_variant" {
        # issue #118 — reuse-in-place for variant cells. Recogniser
        # synthesises `__perceus_reuse_variant(__pcs_scr, Ctor(args...))`
        # where the second arg is a variant constructor call of the
        # same arity. We unpack the constructor's name + args and
        # lower to `kai_reuse_or_alloc_variant`.
        #
        # Issue #440 Phase 2 — when the ctor has primitive payload
        # slots (typed), the reuse-in-place fast path is disabled:
        # `kai_reuse_or_alloc_variant` writes its replacement args
        # into `slots[i].ptr` and assumes `slot_mask == 0`, which
        # would mismatch the emit-side typed extract (`slots[i].i64`).
        # Routing the rebuild through `kai_variant_u` keeps the
        # cell coherent with the match read; the reuse-for-typed-
        # cells extension is a follow-up lane.
        match args_e {
          [_scr, ctor] -> match ctor.kind {
            # The recogniser may hand the ctor either as a bare
            # `EVar(cname)` (pre-resolution shape) or — the common
            # case after the resolver qualifies user constructors —
            # as `EModCall(tycon, cname)`. Both lower identically;
            # `emit_reuse_variant_body` shares the slot logic.
            ECall(cf, cargs) -> match cf.kind {
              EVar(cname) ->
                emit_reuse_variant_body(src, cname, cargs, cx)
              EModCall(_mod, cname) ->
                emit_reuse_variant_body(src, cname, cargs, cx)
              _ -> "kai_unit() /* __perceus_reuse_variant: 2nd arg must be a variant constructor call */"
            }
            _ -> "kai_unit() /* __perceus_reuse_variant: 2nd arg must be a variant constructor call */"
          }
          _ -> "kai_unit() /* __perceus_reuse_variant: arity mismatch (expected 2 args) */"
        }
      } else if callee == "bit_and" {
        # m13: bit ops are compiler intrinsics — each lowers inline to
        # the matching C operator. The shape is consistent across the
        # binary ops: read both KaiInts, apply the operator on `as.i`,
        # box the result, decref the inputs. Refcounting matches
        # `kai_op_add` in stage0/runtime.h: caller hands us values we own
        # and must release exactly once.
        match args_e {
          [a, b] -> concat_all([
            "({ KaiValue *_a = ", emit_expr(src, a, cx),
            "; KaiValue *_b = ", emit_expr(src, b, cx),
            "; KaiValue *_r = kai_int(_a->as.i & _b->as.i); ",
            "kai_decref(_a); kai_decref(_b); _r; })"
          ])
          _ -> "kai_unit() /* bit_and: expected 2 args */"
        }
      } else if callee == "bit_or" {
        match args_e {
          [a, b] -> concat_all([
            "({ KaiValue *_a = ", emit_expr(src, a, cx),
            "; KaiValue *_b = ", emit_expr(src, b, cx),
            "; KaiValue *_r = kai_int(_a->as.i | _b->as.i); ",
            "kai_decref(_a); kai_decref(_b); _r; })"
          ])
          _ -> "kai_unit() /* bit_or: expected 2 args */"
        }
      } else if callee == "bit_xor" {
        match args_e {
          [a, b] -> concat_all([
            "({ KaiValue *_a = ", emit_expr(src, a, cx),
            "; KaiValue *_b = ", emit_expr(src, b, cx),
            "; KaiValue *_r = kai_int(_a->as.i ^ _b->as.i); ",
            "kai_decref(_a); kai_decref(_b); _r; })"
          ])
          _ -> "kai_unit() /* bit_xor: expected 2 args */"
        }
      } else if callee == "bit_not" {
        # Unary: a single `~`. Refcount matches `bit_count`.
        match args_e {
          [a] -> concat_all([
            "({ KaiValue *_a = ", emit_expr(src, a, cx),
            "; KaiValue *_r = kai_int(~ _a->as.i); ",
            "kai_decref(_a); _r; })"
          ])
          _ -> "kai_unit() /* bit_not: expected 1 arg */"
        }
      } else if callee == "bit_shl" {
        match args_e {
          [a, b] -> concat_all([
            "({ KaiValue *_a = ", emit_expr(src, a, cx),
            "; KaiValue *_b = ", emit_expr(src, b, cx),
            "; KaiValue *_r = kai_int(_a->as.i << _b->as.i); ",
            "kai_decref(_a); kai_decref(_b); _r; })"
          ])
          _ -> "kai_unit() /* bit_shl: expected 2 args */"
        }
      } else if callee == "bit_shr" {
        # Arithmetic shift: signed `>>` preserves the sign bit. The
        # spec'd contrast with `bit_ushr` rests on `_a->as.i` staying
        # `int64_t`.
        match args_e {
          [a, b] -> concat_all([
            "({ KaiValue *_a = ", emit_expr(src, a, cx),
            "; KaiValue *_b = ", emit_expr(src, b, cx),
            "; KaiValue *_r = kai_int(_a->as.i >> _b->as.i); ",
            "kai_decref(_a); kai_decref(_b); _r; })"
          ])
          _ -> "kai_unit() /* bit_shr: expected 2 args */"
        }
      } else if callee == "bit_ushr" {
        # Logical shift: cast through `uint64_t` to zero-fill, then
        # back to `int64_t` so the result fits the KaiInt slot.
        match args_e {
          [a, b] -> concat_all([
            "({ KaiValue *_a = ", emit_expr(src, a, cx),
            "; KaiValue *_b = ", emit_expr(src, b, cx),
            "; KaiValue *_r = kai_int((int64_t)(((uint64_t) _a->as.i) >> _b->as.i)); ",
            "kai_decref(_a); kai_decref(_b); _r; })"
          ])
          _ -> "kai_unit() /* bit_ushr: expected 2 args */"
        }
      } else if callee == "bit_count" {
        # `__builtin_popcountll` is GCC/Clang. Cast through `uint64_t`
        # so the count semantics don't depend on signed-bit handling.
        match args_e {
          [a] -> concat_all([
            "({ KaiValue *_a = ", emit_expr(src, a, cx),
            "; KaiValue *_r = kai_int((int64_t) __builtin_popcountll((uint64_t) _a->as.i)); ",
            "kai_decref(_a); _r; })"
          ])
          _ -> "kai_unit() /* bit_count: expected 1 arg */"
        }
      } else if callee == "bit_test" {
        # Returns Bool — boxed via `kai_bool`.
        match args_e {
          [a, b] -> concat_all([
            "({ KaiValue *_a = ", emit_expr(src, a, cx),
            "; KaiValue *_b = ", emit_expr(src, b, cx),
            "; KaiValue *_r = kai_bool(((_a->as.i >> _b->as.i) & 1) != 0); ",
            "kai_decref(_a); kai_decref(_b); _r; })"
          ])
          _ -> "kai_unit() /* bit_test: expected 2 args */"
        }
      } else if callee == "bit_set" {
        match args_e {
          [a, b] -> concat_all([
            "({ KaiValue *_a = ", emit_expr(src, a, cx),
            "; KaiValue *_b = ", emit_expr(src, b, cx),
            "; KaiValue *_r = kai_int(_a->as.i | ((int64_t)1 << _b->as.i)); ",
            "kai_decref(_a); kai_decref(_b); _r; })"
          ])
          _ -> "kai_unit() /* bit_set: expected 2 args */"
        }
      } else if callee == "bit_clear" {
        match args_e {
          [a, b] -> concat_all([
            "({ KaiValue *_a = ", emit_expr(src, a, cx),
            "; KaiValue *_b = ", emit_expr(src, b, cx),
            "; KaiValue *_r = kai_int(_a->as.i & ~((int64_t)1 << _b->as.i)); ",
            "kai_decref(_a); kai_decref(_b); _r; })"
          ])
          _ -> "kai_unit() /* bit_clear: expected 2 args */"
        }
      } else if callee == "bit_toggle" {
        match args_e {
          [a, b] -> concat_all([
            "({ KaiValue *_a = ", emit_expr(src, a, cx),
            "; KaiValue *_b = ", emit_expr(src, b, cx),
            "; KaiValue *_r = kai_int(_a->as.i ^ ((int64_t)1 << _b->as.i)); ",
            "kai_decref(_a); kai_decref(_b); _r; })"
          ])
          _ -> "kai_unit() /* bit_toggle: expected 2 args */"
        }
      } else if string_contains_dot(callee) {
        # m7a #6c/#6d/#6e: op call `Eff.op(args)`. Look up the
        # innermost EvEff node, allocate a KaiCont on the stack
        # (identity continuation for one-shot resume), and indirect-
        # call the op fn ptr. After the clause returns, if it never
        # called resume (status stays UNRESUMED), pop the evidence
        # and longjmp to the enclosing handle's setjmp landing pad
        # — Doc A §*Discarding the continuation*. The default
        # handlers (m7a #7) always resume, so the longjmp branch is
        # a no-op for them; the node's handle_jmp is NULL there.
        let eff_n = dotted_prefix(callee)
        let op_n_tagged = dotted_suffix(callee)
        # m7b #15 (compiler integration, scope-limited): the alias
        # rewrite tags op names with `@<alias>` when the original
        # callee was an `as`-bound capability. Split here: when
        # tagged, dispatch via the handle's local
        # `kai_alias_<alias>_id` (kai_evidence_lookup_node_by_id);
        # otherwise the standard innermost-by-name lookup.
        let at_pos = string_index_of_at(op_n_tagged)
        let op_n = if at_pos >= 0 { string_slice(op_n_tagged, 0, at_pos) } else { op_n_tagged }
        let alias_n = if at_pos >= 0 { string_slice(op_n_tagged, at_pos + 1, string_length(op_n_tagged)) } else { "" }
        let lookup_c =
          if at_pos >= 0 {
            concat_all(["kai_evidence_lookup_node_by_id(kai_alias_", alias_n, "_id)"])
          } else {
            concat_all(["kai_evidence_lookup_node(\"", eff_n, "\")"])
          }
        # m8.x bug #12: mark the handler's evidence node as
        # in-dispatch across the clause invocation. The
        # `kai_evidence_lookup_node` walk skips flagged nodes, so
        # a recursive `Eff.op(...)` inside the clause resolves to
        # the *outer* handler and not back into ourselves.
        #
        # Args MUST be evaluated *before* the flag is set — they
        # may themselves invoke the same op (e.g.
        # `State.set(State.get() + 1)` evaluates `State.get()`
        # while constructing `set`'s argument). Setting the flag
        # before the args would make the inner `lookup_node` walk
        # past the live handler and crash. Bind each arg to a
        # `_op_arg_<i>` C local first; then flip the flag right
        # before invoking the clause.
        let arg_bindings = emit_op_arg_bindings(src, args_e, 0, cx)
        let arg_passes   = emit_op_arg_pass_list(args_e, 0)
        let pass_str     = match args_e {
          [] -> ""
          _  -> cat2(", ", arg_passes)
        }
        concat_all([
          "({ KaiEvidence *_node_op = ", lookup_c, "; ",
          "Ev", eff_n, " *_ev_op = (Ev", eff_n, " *) _node_op->handler; ",
          "KaiCont _k; kai_cont_init_identity(&_k, _ev_op->handler_id); ",
          arg_bindings,
          "KaiFiber *_disp_fib = kai_current_fiber(); ",
          "KaiEvidence *_saved_disp = _disp_fib->in_dispatch_node; ",
          "_disp_fib->in_dispatch_node = _node_op; ",
          "KaiValue *_op_r = _ev_op->", op_n, "(_ev_op", pass_str, ", &_k); ",
          "_disp_fib->in_dispatch_node = _saved_disp; ",
          "if (_k.status == KAI_CONT_UNRESUMED && _node_op->handle_jmp != NULL) { ",
            "*_node_op->discard_slot = _op_r; ",
            "kai_evidence_pop(); ",
            "longjmp(*_node_op->handle_jmp, 1); ",
          "} ",
          "_op_r; })"
        ])
      } else {
        # Issue #440 Phase 2 — when the callee is a variant ctor with
        # at least one primitive payload slot, emit the typed
        # `kai_variant_u` path. Falls back to the legacy boxed
        # `emit_named_call_lookup` shape otherwise.
        match evar_payload_tys(cx.variants, callee) {
          Some(tys) -> match emit_variant_call_typed(callee, args_e, tys, src, cx) {
            Some(s) -> s
            None    -> emit_named_call_lookup(src, callee, args_e, call_args, cx)
          }
          None -> emit_named_call_lookup(src, callee, args_e, call_args, cx)
        }
      }
    }
    # m6.2 Phase 3 / v2: qualified call `mod.fname(args)`. v2 mints
    # `kai_<mod>__<fname>` directly from the EModCall payload — the
    # resolver already verified `fname` is exported by `mod`, so we
    # do not need to round-trip through emit_named_call_lookup (which
    # would lose the qualified context and pick the wrong entry when
    # two modules export the same bare name).
    #
    # Issue #644 — Plan B: the typer rewrites `Response.Ok(x)` (or a
    # bare `Ok(x)` disambiguated to `Response.Ok` by annotation) to
    # `EModCall("Response", "Ok")`. The emitter must lower it as a
    # variant ctor (`kai_variant(0, "Ok", ...)`), not as a module fn
    # call, because variant tag matching keys on the bare ctor name
    # at runtime. Detect by membership in `variants`; fall through to
    # the module-fn path otherwise.
    #
    # Phase 2 unboxing parity: if the variant has typed payload slots
    # (`emit_variant_call_typed` returns Some), use that path so the
    # ctor emits `kai_variant_u` matching what the bare EVar ctor
    # path uses elsewhere — otherwise nested unboxed sub-ctors and
    # the outer boxed ctor would disagree on slot layout and reads
    # like `slots[0].i64` would return garbage from a boxed pointer.
    EModCall(mod, fname) -> match evar_find(cx.variants, fname) {
      Some(_) -> match evar_payload_tys(cx.variants, fname) {
        Some(tys) -> match emit_variant_call_typed(fname, args_e, tys, src, cx) {
          Some(s) -> s
          None    -> emit_variant_call(fname, list_length(args_e), emit_call_args_slots(src, args_e, cx), cx)
        }
        None -> emit_variant_call(fname, list_length(args_e), emit_call_args_slots(src, args_e, cx), cx)
      }
      None    -> cat5("kai_", c_sym(fname, Some(mod)), "(", call_args, ")")
    }
    _ -> {
      let fc = emit_expr(src, f, cx)
      concat_all([
        "kai_apply(", fc, ", ", int_to_string(list_length(args_e)),
        ", (KaiValue *[]){", call_args, "})"
      ])
    }
  }
}

# Shared by emit_pipe_expr's EVar / EModCall branches. Same lookup
# chain as emit_named_call_lookup but parameterised on a pre-built
# args string (the pipe LHS is already the first argument).
#
# `lcs` makes a local closure shadow a same-named top-level fn: the
# user wrote `let take = ...` and pipe-called `xs |> take(1)`, the
# local has to win. When `callee` is in lcs we drop straight to the
# kai_apply branch over the local C variable; the variant / prelude
# / efn lookups only fire for genuinely-global names.
# Phase 3 unboxing — when `callee` resolves to a UFn entry in the
# EFn table, the call site swaps to the raw calling convention.
# `emit_pipe_named_lookup` (and its sibling `emit_named_call_lookup`)
# stay the gateway for both raw and boxed paths so the lookup
# discipline (lcs shadowing, variant dispatch, prelude inlining) is
# centralised. The raw arg string is built lazily inside the UFn
# arm via `emit_call_args_raw_pipe` (LHS already raw + the rest).
# The result of the raw call is itself a raw scalar; the parent
# emit_expr already wraps it via `box_wrap` when it sees the ECall
# node tagged MUnboxed (set in `ufn_promote_calls`). We re-wrap
# here as a defensive identity-on-raw boundary because the pipe
# path may inline through emit_pipe_expr's match without first
# going through `emit_expr`.

# Shared by emit_pipe_expr's EVar / EModCall branches. Same lookup
# chain as emit_named_call_lookup but parameterised on a pre-built
# args string (the pipe LHS is already the first argument).
#
# `lcs` makes a local closure shadow a same-named top-level fn: the
# user wrote `let take = ...` and pipe-called `xs |> take(1)`, the
# local has to win. When `callee` is in lcs we drop straight to the
# kai_apply branch over the local C variable; the variant / prelude
# / efn lookups only fire for genuinely-global names.
# Phase 3 unboxing — when `callee` resolves to a UFn entry in the
# EFn table, the call site swaps to the raw calling convention.
# `emit_pipe_named_lookup` (and its sibling `emit_named_call_lookup`)
# stay the gateway for both raw and boxed paths so the lookup
# discipline (lcs shadowing, variant dispatch, prelude inlining) is
# centralised. The raw arg string is built lazily inside the UFn
# arm via `emit_call_args_raw_pipe` (LHS already raw + the rest).
# The result of the raw call is itself a raw scalar; the parent
# emit_expr already wraps it via `box_wrap` when it sees the ECall
# node tagged MUnboxed (set in `ufn_promote_calls`). We re-wrap
# here as a defensive identity-on-raw boundary because the pipe
# path may inline through emit_pipe_expr's match without first
# going through `emit_expr`.
fn emit_pipe_named_lookup(src: String, callee: String, arity: Int, lhs_c: String, args_e: [Expr], args_all: String, cx: EmitCtx) : String / Console =
  if list_has(cx.lcs, callee) {
    concat_all([
      "kai_apply(kai_", callee, ", ", int_to_string(arity),
      ", (KaiValue *[]){", args_all, "})"
    ])
  } else { match evar_find(cx.variants, callee) {
    Some(_) -> {
      let rest_slots = emit_call_args_slots(src, args_e, cx)
      let lhs_slot = arg_str_as_slot(lhs_c)
      let slots_all = if list_length(args_e) == 0 { lhs_slot } else { cat3(lhs_slot, ", ", rest_slots) }
      emit_variant_call(callee, arity, slots_all, cx)
    }
    None -> match prelude_find(callee) {
      Some(ep) -> match ep {
        EP(_, cname, _) -> cat4(cname, "(", args_all, ")")
      }
      None -> match efn_resolve(cx.fns, callee) {
        Some(EFn(_, _, mo, _)) -> cat5("kai_", c_sym(callee, mo), "(", args_all, ")")
        None -> concat_all([
          "kai_apply(kai_", callee, ", ", int_to_string(arity),
          ", (KaiValue *[]){", args_all, "})"
        ])
      }
    }
  } }

# Shared by emit_call_expr's EVar non-special branch and its
# EModCall (m6.2) branch. Picks variant / prelude / user-fn /
# closure-thunk emission from the same lookup chain. `lcs` lets a
# local closure shadow a same-named top-level fn (see
# emit_pipe_named_lookup).

# Shared by emit_call_expr's EVar non-special branch and its
# EModCall (m6.2) branch. Picks variant / prelude / user-fn /
# closure-thunk emission from the same lookup chain. `lcs` lets a
# local closure shadow a same-named top-level fn (see
# emit_pipe_named_lookup).
fn emit_named_call_lookup(src: String, callee: String, args_e: [Expr], call_args: String, cx: EmitCtx) : String / Console =
  if list_has(cx.lcs, callee) {
    concat_all([
      "kai_apply(kai_", callee, ", ", int_to_string(list_length(args_e)),
      ", (KaiValue *[]){", call_args, "})"
    ])
  } else { match evar_find(cx.variants, callee) {
    # Issue #440 Phase 2 — variant ctor. The typed emit path is
    # wired through `emit_call_expr_default` (which has access to
    # `src` + `lams` + `cls`); this lookup-only helper keeps the
    # boxed-args shape via emit_call_args_slots so the runtime sees a
    # uniform `kai_variant_u` call (issue #688 dropped the legacy
    # `kai_variant`).
    Some(_) -> emit_variant_call(callee, list_length(args_e),
                                 emit_call_args_slots(src, args_e, cx),
                                 cx.variants)
    None -> match prelude_find(callee) {
      Some(ep) -> match ep {
        EP(_, cname, _) -> cat4(cname, "(", call_args, ")")
      }
      None -> match efn_resolve(cx.fns, callee) {
        Some(EFn(_, _, mo, _)) -> cat5("kai_", c_sym(callee, mo), "(", call_args, ")")
        None -> concat_all([
          "kai_apply(kai_", callee, ", ", int_to_string(list_length(args_e)),
          ", (KaiValue *[]){", call_args, "})"
        ])
      }
    }
  } }

fn emit_pipe_expr(src: String, lhs: Expr, rhs: Expr, cx: EmitCtx) : String / Console {

  match rhs.kind {
    ECall(f, args_e) -> match f.kind {
      # Phase 3 unboxing — pipe into a UFn callee. The piped LHS
      # becomes the first arg; both LHS and the trailing args are
      # emitted raw via `emit_expr_raw`. Without this branch the
      # default `emit_call_args` produces boxed args and the
      # `kai_<sym>` call site (which has the raw signature post-
      # Phase-3) takes `KaiValue *` — a hard C type error caught
      # by tier1 on `m7d_21_pipe_placeholder_basic`.
      EVar(callee) -> {
        if list_has(cx.lcs, callee) {
          let lhs_c = emit_expr(src, lhs, cx)
          let rest_args = emit_call_args(src, args_e, cx)
          let args_all = if list_length(args_e) == 0 { lhs_c } else { cat3(lhs_c, ", ", rest_args) }
          emit_pipe_named_lookup(src, callee, list_length(args_e) + 1, lhs_c, args_e, args_all, cx)
        } else { match efn_resolve(cx.fns, callee) {
          Some(EFn(_, _, mo, Some(US(_, rt)))) -> {
            let lhs_raw = emit_expr_raw(src, lhs, cx)
            let rest_raw = emit_call_args_raw(src, args_e, cx)
            let args_all = if list_length(args_e) == 0 { lhs_raw } else { cat3(lhs_raw, ", ", rest_raw) }
            let raw_call = cat5("kai_", c_sym(callee, mo), "(", args_all, ")")
            box_wrap(Some(rt), raw_call)
          }
          _ -> {
            let lhs_c = emit_expr(src, lhs, cx)
            let rest_args = emit_call_args(src, args_e, cx)
            let args_all = if list_length(args_e) == 0 { lhs_c } else { cat3(lhs_c, ", ", rest_args) }
            emit_pipe_named_lookup(src, callee, list_length(args_e) + 1, lhs_c, args_e, args_all, cx)
          }
        } }
      }
      # m6.2 Phase 3 / v2: piped qualified call `x |> mod.f(args)`.
      # Mint the prefixed symbol directly — same logic as the
      # non-piped EModCall branch in emit_call_expr. Phase 3
      # routes UFn-classified targets through the raw shape too.
      EModCall(mod, fname) -> match lookup_ufn_sig(cx.fns, fname, Some(mod)) {
        Some(US(_, rt)) -> {
          let lhs_raw = emit_expr_raw(src, lhs, cx)
          let rest_raw = emit_call_args_raw(src, args_e, cx)
          let args_all = if list_length(args_e) == 0 { lhs_raw } else { cat3(lhs_raw, ", ", rest_raw) }
          let raw_call = cat5("kai_", c_sym(fname, Some(mod)), "(", args_all, ")")
          box_wrap(Some(rt), raw_call)
        }
        None -> {
          let lhs_c = emit_expr(src, lhs, cx)
          let rest_args = emit_call_args(src, args_e, cx)
          let args_all = if list_length(args_e) == 0 { lhs_c } else { cat3(lhs_c, ", ", rest_args) }
          cat5("kai_", c_sym(fname, Some(mod)), "(", args_all, ")")
        }
      }
      _ -> {
        let lhs_c = emit_expr(src, lhs, cx)
        let fc = emit_expr(src, f, cx)
        let rest_args = emit_call_args(src, args_e, cx)
        let args_all = if list_length(args_e) == 0 { lhs_c } else { cat3(lhs_c, ", ", rest_args) }
        concat_all([
          "kai_apply(", fc, ", ", int_to_string(list_length(args_e) + 1),
          ", (KaiValue *[]){", args_all, "})"
        ])
      }
    }
    EVar(callee) -> {
      if list_has(cx.lcs, callee) {
        let lhs_c = emit_expr(src, lhs, cx)
        emit_pipe_named_lookup(src, callee, 1, lhs_c, [], lhs_c, cx)
      } else { match efn_resolve(cx.fns, callee) {
        Some(EFn(_, _, mo, Some(US(_, rt)))) -> {
          let lhs_raw = emit_expr_raw(src, lhs, cx)
          let raw_call = cat5("kai_", c_sym(callee, mo), "(", lhs_raw, ")")
          box_wrap(Some(rt), raw_call)
        }
        _ -> {
          let lhs_c = emit_expr(src, lhs, cx)
          emit_pipe_named_lookup(src, callee, 1, lhs_c, [], lhs_c, cx)
        }
      } }
    }
    # m6.2 Phase 3 / v2: piped qualified-call shorthand `x |> mod.f`
    # (no parens) — same direct mint as the parens form.
    EModCall(mod, fname) -> match lookup_ufn_sig(cx.fns, fname, Some(mod)) {
      Some(US(_, rt)) -> {
        let lhs_raw = emit_expr_raw(src, lhs, cx)
        let raw_call = cat5("kai_", c_sym(fname, Some(mod)), "(", lhs_raw, ")")
        box_wrap(Some(rt), raw_call)
      }
      None -> {
        let lhs_c = emit_expr(src, lhs, cx)
        cat5("kai_", c_sym(fname, Some(mod)), "(", lhs_c, ")")
      }
    }
    _ -> {
      let lhs_c = emit_expr(src, lhs, cx)
      concat_all([
        "kai_apply(", emit_expr(src, rhs, cx),
        ", 1, (KaiValue *[]){", lhs_c, "})"
      ])
    }
  }
}

fn emit_range_expr(src: String, from: Expr, to: Expr, opt_step: Option[Expr],
                   cx: EmitCtx) : String / Console {

  let a = emit_expr(src, from, cx)
  let b = emit_expr(src, to, cx)
  match opt_step {
    None -> cat5("kai_range(", a, ", ", b, ")")
    Some(s) -> {
      let sc = emit_expr(src, s, cx)
      concat_all(["kai_range_step(", a, ", ", b, ", ", sc, ")"])
    }
  }
}

# ---- list literal emission ----

# issue #212 — when the spread argument is already wrapped in a
# `__perceus_dup` (e.g. on a non-last-use read of a list-typed
# parameter), the dup already incref'd the value. Wrapping that in
# the structural `kai_incref` of the tail-spread emit double-incref's
# the cell, blocking `kai_check_unique` on the recursive accumulator
# spine and leaking +1 reference per iteration.

# issue #212 — when the spread argument is already wrapped in a
# `__perceus_dup` (e.g. on a non-last-use read of a list-typed
# parameter), the dup already incref'd the value. Wrapping that in
# the structural `kai_incref` of the tail-spread emit double-incref's
# the cell, blocking `kai_check_unique` on the recursive accumulator
# spine and leaking +1 reference per iteration.
fn is_perceus_dup_call(e: Expr) : Bool = match e.kind {
  ECall(callee, _) -> match callee.kind {
    EVar(nm) -> nm == "__perceus_dup"
    _ -> false
  }
  _ -> false
}

fn emit_list_tail(src: String, elems: [ListElem], cx: EmitCtx) : String / Console {
  # issue #120 (P1): cons cells built lexically inside a `region { }`
  # bump-allocate into the arena; outside, ordinary RC `kai_cons`.
  let cons_c = emit_cons_ctor(cx)
  match elems {
    [] -> "kai_nil()"
    # Tail spread `[..., ...xs]`: `kai_incref(xs)` gives the caller
    # a result whose RC is 1 and leaves xs untouched, matching the
    # ownership contract list_append used to provide via spine copy
    # — but in O(1) instead of O(|xs|). This collapses the O(n²)
    # blowup of the `[x, ...acc]` parser prepend pattern.
    [el] -> match el {
      ElPlain(x) -> concat_all([cons_c, emit_expr(src,x, cx), ", kai_nil())"])
      ElSpread(x) ->
        # issue #212: if `x` is `__perceus_dup(...)`, the dup already
        # produces an owned reference; an outer `kai_incref` would
        # double-bump. Emit the dup's lowering on its own.
        if is_perceus_dup_call(x) {
          emit_expr(src, x, cx)
        } else {
          concat_all(["kai_incref(", emit_expr(src, x, cx), ")"])
        }
    }
    [el, ...rest] -> match el {
      ElPlain(x) -> concat_all([
        cons_c, emit_expr(src,x, cx), ", ",
        emit_list_tail(src, rest, cx), ")"
      ])
      ElSpread(x) -> concat_all([
        "kai_prelude_list_append(", emit_expr(src,x, cx), ", ",
        emit_list_tail(src, rest, cx), ")"
      ])
    }
  }
}

fn emit_list_expr(src: String, elems: [ListElem], cx: EmitCtx) : String / Console =

  emit_list_tail(src, elems, cx)

# ---- record literal emission ----

fn emit_field_init_val(src: String, fi: FieldInit, cx: EmitCtx) : String / Console {

  match fi { FI(_, val) -> emit_expr(src,val, cx) }
}

fn emit_field_init_name(fi: FieldInit) : String {
  match fi { FI(name, _) -> cat3("\"", name, "\"") }
}

fn emit_record_lit(src: String, fields: [FieldInit], cx: EmitCtx) : String / Console {

  let n = list_length(fields)
  let vals = join_with(map(fields, (fi) => emit_field_init_val(src, fi, cx)), ", ")
  let names = join_with(map(fields, emit_field_init_name), ", ")
  concat_all([
    emit_record_ctor(cx), int_to_string(n),
    ", (KaiValue *[]){", vals, "}, (const char *[]){", names, "})"
  ])
}

# ---- match: pattern test + bind emission ----

fn emit_pat_test(src: String, pat: Pattern, scr: String, cx: EmitCtx) : String / Console {

  match pat.pkind {
    PWild -> "1"
    PBind(_) -> "1"
    PLit(e) -> concat_all(["kai_op_eq(", scr, ", ", emit_expr(src,e, cx), ")"])
    PList(pats, opt_rest) -> emit_pat_test_list(src, pats, opt_rest, scr, cx)
    PVariant(name, subs) -> emit_pat_test_variant(src, name, subs, scr, cx)
    PVariantRecord(name, fields) -> emit_pat_test_variant_record(src, name, fields, scr, cx)
    PRecord(fields) -> emit_pat_test_record(src, fields, scr, cx)
    PHole(_) -> "1"
    # m7d §14: `name @ sub` matches iff `sub` matches; the binding
    # is performed by emit_pat_binds.
    PAs(_, sub) -> emit_pat_test(src, sub, scr, cx)
    # issue #187 phase 3: PNarrow is rewritten to PAs+PVariant in
    # synth_match before codegen runs; this arm only fires if a
    # `match` outside the typer's scope reaches codegen with a raw
    # narrowing pattern. Treat as unconditional match (no test).
    PNarrow(_, _) -> "1"
  }
}

fn emit_pat_test_list(src: String, pats: [Pattern], opt_rest: Option[String],
                      scr: String, cx: EmitCtx) : String / Console {

  let n_fixed = list_length(pats)
  let has_rest = match opt_rest { Some(_) -> true None -> false }
  if n_fixed == 0 and not has_rest {
    concat_all(["(", scr, " && ", scr, "->tag == KAI_NIL)"])
  } else {
    cat3("(", emit_pat_test_list_loop(src, pats, has_rest, scr, 0, n_fixed, cx), ")")
  }
}

fn emit_pat_test_list_loop(src: String, pats: [Pattern], has_rest: Bool,
                            cur: String, i: Int, n_fixed: Int,
                            cx: EmitCtx) : String / Console {

  if i >= n_fixed {
    if has_rest { "1" }
    else { concat_all([cur, " && ", cur, "->tag == KAI_NIL"]) }
  } else {
    let head = cat2(cur, "->as.cons.head")
    let tail = cat2(cur, "->as.cons.tail")
    let pi = list_nth(pats, i)
    let head_test = emit_pat_test(src, pi, head, cx)
    let cons_guard = concat_all([cur, " && ", cur, "->tag == KAI_CONS"])
    concat_all([
      cons_guard, " && ", head_test, " && ",
      emit_pat_test_list_loop(src, pats, has_rest, tail, i + 1, n_fixed, cx)
    ])
  }
}

fn list_nth(xs: [Pattern], i: Int) : Pattern {
  match xs {
    [] -> mk_pat(PWild, 0, 0)
    [h, ...rest] -> if i == 0 { h } else { list_nth(rest, i - 1) }
  }
}

# Issue #688 — emit the variant-name dispatch as either
# `scr->as.var.variant_tag == N` (when the constructor is registered
# under the atom-style global convention, docs/variant-tags.md) or
# `strcmp(scr->as.var.variant_name, "Name") == 0` (synthetic fallback).
# Used by emit_pat_test_variant, emit_pat_test_variant_record, and
# emit_bang to keep the three sites in sync.

# Issue #688 — emit the variant-name dispatch as either
# `scr->as.var.variant_tag == N` (when the constructor is registered
# under the atom-style global convention, docs/variant-tags.md) or
# `strcmp(scr->as.var.variant_name, "Name") == 0` (synthetic fallback).
# Used by emit_pat_test_variant, emit_pat_test_variant_record, and
# emit_bang to keep the three sites in sync.
fn emit_variant_tag_test(scr: String, name: String, variants: [EVar]) : String {
  match evar_find_tag_opt(variants, name) {
    Some(t) -> concat_all([
      scr, "->tag == KAI_VARIANT && ",
      scr, "->as.var.variant_tag == ", int_to_string(t)
    ])
    None -> concat_all([
      scr, "->tag == KAI_VARIANT && strcmp(",
      scr, "->as.var.variant_name, \"", name, "\") == 0"
    ])
  }
}

fn emit_pat_test_variant(src: String, name: String, subs: [Pattern],
                         scr: String, cx: EmitCtx) : String / Console {

  let base = concat_all(["(", scr, " && ", emit_variant_tag_test(scr, name, cx.variants)])
  # Issue #440 Phase 2 — look up the variant's payload Types so the
  # sub-pattern test reads each slot with the right kind. Unknown
  # ctor (e.g. nullary builtin / non-sum match) falls back to all
  # pointer slots.
  let tys = match evar_payload_tys(cx.variants, name) {
    Some(ts) -> ts
    None     -> []
  }
  cat3(base, emit_pat_test_variant_subs(src, subs, tys, scr, 0, cx), ")")
}

# Pull a borrowed boxed view of slot `i` against the typed shape. For
# pointer slots returns the alias expression — no RC bump. For Int /
# Real slots wraps in `kai_int`/`kai_real`, which allocates a fresh
# boxed temporary the caller owns. Phase 2 test paths must release
# any temporary they create.

# Pull a borrowed boxed view of slot `i` against the typed shape. For
# pointer slots returns the alias expression — no RC bump. For Int /
# Real slots wraps in `kai_int`/`kai_real`, which allocates a fresh
# boxed temporary the caller owns. Phase 2 test paths must release
# any temporary they create.
fn slot_read_for_test(scr: String, i: Int, tys: [TypeExpr]) : String {
  let k = match list_nth_ty(tys, i) { Some(t) -> variant_slot_kind(t) None -> 0 }
  if k == 1 {
    concat_all(["kai_int(", scr, "->as.var.slots[", int_to_string(i), "].i64)"])
  } else if k == 2 {
    concat_all(["kai_real(", scr, "->as.var.slots[", int_to_string(i), "].r)"])
  } else {
    concat_all([scr, "->as.var.slots[", int_to_string(i), "].ptr"])
  }
}

# Borrowed read for pattern tests on primitive slots. Returns a
# raw-scalar-aware test expression that does NOT allocate when the
# pattern only checks equality against a literal — but since
# `emit_pat_test` operates on boxed `KaiValue *`, we go through the
# boxed read above. The freshly boxed temp leaks unless the caller
# wraps the test in a statement-expression that decrefs it; for the
# Phase 2 MVP we only emit unboxed slots when the variant's typed
# arms use PBind / PWild (not PLit), which means the test side
# stays boxed only on pointer slots — primitive slots cannot occur
# in PLit's emit because the literal slot pattern is reached only
# for PVariant args, which we route through PBind below. The
# `slot_read_for_test` helper therefore stays simple. The
# emit_pat_test arm itself does not introduce allocations for the
# inline literal cases on primitive slots (#440 follow-up): Phase 2
# routes them through a `slots[i].i64 == LITERAL` check via the
# specialised PLit path.

# Borrowed read for pattern tests on primitive slots. Returns a
# raw-scalar-aware test expression that does NOT allocate when the
# pattern only checks equality against a literal — but since
# `emit_pat_test` operates on boxed `KaiValue *`, we go through the
# boxed read above. The freshly boxed temp leaks unless the caller
# wraps the test in a statement-expression that decrefs it; for the
# Phase 2 MVP we only emit unboxed slots when the variant's typed
# arms use PBind / PWild (not PLit), which means the test side
# stays boxed only on pointer slots — primitive slots cannot occur
# in PLit's emit because the literal slot pattern is reached only
# for PVariant args, which we route through PBind below. The
# `slot_read_for_test` helper therefore stays simple. The
# emit_pat_test arm itself does not introduce allocations for the
# inline literal cases on primitive slots (#440 follow-up): Phase 2
# routes them through a `slots[i].i64 == LITERAL` check via the
# specialised PLit path.
fn list_nth_ty(xs: [TypeExpr], i: Int) : Option[TypeExpr] = match xs {
  [] -> None
  [h, ...rest] -> if i == 0 { Some(h) } else { list_nth_ty(rest, i - 1) }
}

fn emit_pat_test_variant_subs(src: String, subs: [Pattern], tys: [TypeExpr], scr: String, i: Int,
                              cx: EmitCtx) : String / Console {

  match subs {
    [] -> ""
    [sp, ...rest] -> {
      # Issue #440 Phase 2 — primitive slots are stored as raw
      # scalars. For sub-pattern testing we emit a typed slot read
      # that the underlying boxed pat-test machinery can consume.
      # PWild / PBind / PAs do not touch the value so the read is
      # never evaluated for them; PLit reads the slot (and the
      # boxed temp is decref'd inline by the comparator chain).
      let k = match list_nth_ty(tys, i) { Some(t) -> variant_slot_kind(t) None -> 0 }
      let sub_scr =
        if k == 0 {
          concat_all([scr, "->as.var.slots[", int_to_string(i), "].ptr"])
        } else {
          slot_read_for_test(scr, i, tys)
        }
      let t = emit_pat_test(src, sp, sub_scr, cx)
      concat_all([" && ", t, emit_pat_test_variant_subs(src, rest, tys, scr, i + 1, cx)])
    }
  }
}

fn emit_pat_test_record(src: String, fields: [PField], scr: String,
                        cx: EmitCtx) : String / Console {

  let base = concat_all(["(", scr, " && ", scr, "->tag == KAI_RECORD"])
  cat3(base, emit_pat_test_record_fields(src, fields, scr, cx), ")")
}

fn emit_pat_test_record_fields(src: String, fields: [PField], scr: String,
                               cx: EmitCtx) : String / Console {

  match fields {
    [] -> ""
    [pf, ...rest] -> match pf {
      PField(name, sub, _) -> {
        # m5.x §4b: pat_test only reads the field's tag / value — use
        # the borrowing variant so a failing arm doesn't leak one ref
        # per field tested. emit_pat_binds (below, line 8334) still
        # uses kai_op_field; matched arms keep owned bindings.
        let tmp = concat_all(["kai_op_field_borrow(", scr, ", \"", name, "\")"])
        let t = emit_pat_test(src, sub, tmp, cx)
        concat_all([" && (", t, ")", emit_pat_test_record_fields(src, rest, scr, cx)])
      }
    }
  }
}

fn emit_pat_test_variant_record(src: String, name: String, fields: [PField], scr: String,
                                 cx: EmitCtx) : String / Console {

  # Variant with record destructuring: first check the variant tag,
  # then read record fields via kai_op_field on the scrutinee itself
  # because the emit side stores records directly in variants.
  # Issue #688 — atom-style global tag dispatch via emit_variant_tag_test.
  let base = concat_all(["(", scr, " && ", emit_variant_tag_test(scr, name, cx.variants)])
  cat3(base, emit_pat_test_record_fields(src, fields, scr, cx), ")")
}

# `is_alias` = the scrutinee shares storage with its producer (variant args,
# cons head/tail). PBind/PAs emit `kai_incref(scr)` so the binding has its
# own owned reference. When false, scr is already owned (top-level _scr /
# _letv from a transferred RHS, or `kai_op_field` which already increfs its
# return) and the binding takes the ref directly. The producer-side incref
# is the prerequisite for runtime-flip exit drops: a multi-use param
# decref'd at exit must not free a value still pointed at by the original
# scrutinee's variant slot — landed in the m5.x runtime flip
# (atomic A+B+C+D, 2026-04-28); see `git log` if archaeology is needed.

# `is_alias` = the scrutinee shares storage with its producer (variant args,
# cons head/tail). PBind/PAs emit `kai_incref(scr)` so the binding has its
# own owned reference. When false, scr is already owned (top-level _scr /
# _letv from a transferred RHS, or `kai_op_field` which already increfs its
# return) and the binding takes the ref directly. The producer-side incref
# is the prerequisite for runtime-flip exit drops: a multi-use param
# decref'd at exit must not free a value still pointed at by the original
# scrutinee's variant slot — landed in the m5.x runtime flip
# (atomic A+B+C+D, 2026-04-28); see `git log` if archaeology is needed.
fn emit_pat_binds(src: String, pat: Pattern, scr: String, is_alias: Bool,
                  cx: EmitCtx) : String {
  match pat.pkind {
    PWild ->
      # #293 Phase 2.3/2.4: when scr is an owned (non-alias) ref the
      # value would otherwise leak. Drop it. For alias paths the
      # parent's decref reclaims it.
      if is_alias { "" }
      else { concat_all(["kai_decref(", scr, "); "]) }
    PLit(_) -> ""
    PBind(name) ->
      # #293 Phase 2.3/2.4: `_`-prefixed names are unused-by-convention.
      # Treat them as wildcards so cons head / variant arg / record
      # field allocations balance.
      if name_is_unused(name) {
        if is_alias { "" }
        else { concat_all(["kai_decref(", scr, "); "]) }
      } else if is_alias {
        concat_all(["KaiValue *kai_", name, " = kai_incref(", scr, "); "])
      } else {
        concat_all(["KaiValue *kai_", name, " = ", scr, "; "])
      }
    PList(pats, opt_rest) -> emit_pat_binds_list(src, pats, opt_rest, scr, 0, cx)
    # Issue #440 Phase 2 — pipe the ctor name through so the variant
    # bind helper can read each slot with the right kind.
    PVariant(vname, subs) -> {
      let tys = match evar_payload_tys(cx.variants, vname) {
        Some(ts) -> ts
        None     -> []
      }
      emit_pat_binds_variant(src, subs, tys, scr, 0, cx)
    }
    PVariantRecord(_, fields) -> emit_pat_binds_record(src, fields, scr, cx)
    PRecord(fields) -> emit_pat_binds_record(src, fields, scr, cx)
    PHole(_) -> ""
    # m7d §14: bind the as-name to the whole scrutinee, then descend
    # into the inner pattern's bindings on the same scrutinee. The
    # bound name follows the outer is_alias; the sub-pattern always
    # treats scr as alias because the as-bound name is now sharing
    # storage with the sub-bindings even when scr was originally owned.
    PAs(name, sub) -> {
      let head_bind = if is_alias {
        concat_all(["KaiValue *kai_", name, " = kai_incref(", scr, "); "])
      } else {
        concat_all(["KaiValue *kai_", name, " = ", scr, "; "])
      }
      cat2(head_bind, emit_pat_binds(src, sub, scr, true, cx))
    }
    # issue #187 phase 3: defensive arm; PNarrow is rewritten to
    # PAs+PVariant before codegen. If reached, bind the name like
    # PBind so the body sees the scrutinee under its narrow name.
    PNarrow(name, _) ->
      if is_alias {
        concat_all(["KaiValue *kai_", name, " = kai_incref(", scr, "); "])
      } else {
        concat_all(["KaiValue *kai_", name, " = ", scr, "; "])
      }
  }
}

fn emit_pat_binds_list(src: String, pats: [Pattern], opt_rest: Option[String],
                       cur: String, i: Int, cx: EmitCtx) : String {
  match pats {
    [] -> match opt_rest {
      Some(name) -> concat_all(["KaiValue *kai_", name, " = kai_incref(", cur, "); "])
      None -> ""
    }
    [p, ...rest] -> {
      let head = cat2(cur, "->as.cons.head")
      let tail = cat2(cur, "->as.cons.tail")
      # cons.head / cons.tail are aliases of cur's storage.
      cat2(emit_pat_binds(src, p, head, true, cx),
           emit_pat_binds_list(src, rest, opt_rest, tail, i + 1, cx))
    }
  }
}

fn emit_pat_binds_variant(src: String, subs: [Pattern], tys: [TypeExpr], scr: String, i: Int,
                          cx: EmitCtx) : String {
  match subs {
    [] -> ""
    [sp, ...rest] -> {
      # Issue #440 Phase 2 — read each slot in the shape its kind
      # dictates. Pointer slots stay aliased to the cell's storage
      # (no RC bump on the read; the binding decides whether to
      # incref). Primitive slots (Int / Real) emit a freshly-boxed
      # owning temporary so the bind machinery can treat them
      # uniformly. The owning shape (is_alias=false) lets the bind
      # consume the temp without leaking — kai_incref skipped, no
      # decref needed at arm exit because no extra ref was taken.
      let k = match list_nth_ty(tys, i) { Some(t) -> variant_slot_kind(t) None -> 0 }
      if k == 0 {
        let sub_scr = concat_all([scr, "->as.var.slots[", int_to_string(i), "].ptr"])
        # variant arg slot is alias of scr's storage.
        cat2(emit_pat_binds(src, sp, sub_scr, true, cx),
             emit_pat_binds_variant(src, rest, tys, scr, i + 1, cx))
      } else {
        let sub_scr =
          if k == 1 {
            concat_all(["kai_int(", scr, "->as.var.slots[", int_to_string(i), "].i64)"])
          } else {
            concat_all(["kai_real(", scr, "->as.var.slots[", int_to_string(i), "].r)"])
          }
        # The primitive slot read allocates a fresh boxed temp; the
        # bind owns it (is_alias=false) so PBind takes the ref
        # directly without an incref, PWild releases it, etc.
        cat2(emit_pat_binds(src, sp, sub_scr, false, cx),
             emit_pat_binds_variant(src, rest, tys, scr, i + 1, cx))
      }
    }
  }
}

fn emit_pat_binds_record(src: String, fields: [PField], scr: String,
                          cx: EmitCtx) : String {
  match fields {
    [] -> ""
    [pf, ...rest] -> match pf {
      PField(name, sub, _) -> {
        # #293 Phase 1.3 — nested destructuring needs a temp drop on
        # the intermediate field. See the matching comment in
        # stage1/compiler.kai's emit_pat_binds_record for the rationale.
        if pat_is_destructuring(sub) {
          let tname = concat_all(["_pf_", int_to_string(sub.line), "_",
                                    int_to_string(sub.col)])
          let inner = emit_pat_binds(src, sub, tname, true, cx)
          cat2(
            concat_all([
              "KaiValue *", tname, " = kai_op_field(", scr, ", \"", name, "\"); ",
              inner, "kai_decref(", tname, "); "
            ]),
            emit_pat_binds_record(src, rest, scr, cx)
          )
        } else {
          let tmp = concat_all(["kai_op_field(", scr, ", \"", name, "\")"])
          # kai_op_field returns an incref'd value; child is owned.
          cat2(emit_pat_binds(src, sub, tmp, false, cx),
               emit_pat_binds_record(src, rest, scr, cx))
        }
      }
    }
  }
}

fn name_is_unused(name: String) : Bool {
  # `_`-prefixed user-facing names signal "unused" by convention.
  # Excludes `__`-prefixed compiler-internal names (e.g. `__cv_*` from
  # m12.6 const-pattern desugar, `__pcs_ret` / `__perceus_*` from
  # perceus_pass) which the body still references.
  match char_at(name, 0) {
    Some(c0) -> c0 == '_' and match char_at(name, 1) {
      Some(c1) -> c1 != '_'
      None -> true
    }
    None -> false
  }
}

fn pat_is_destructuring(p: Pattern) : Bool {
  match p.pkind {
    PBind(_) -> false
    PWild -> false
    PLit(_) -> false
    PRecord(_) -> true
    PVariant(_, _) -> true
    PVariantRecord(_, _) -> true
    PList(_, _) -> true
    PNarrow(_, _) -> false
    PAs(_, sub) -> pat_is_destructuring(sub)
    PHole(_) -> false
  }
}

fn emit_match_arms(src: String, arms: [Arm], cx: EmitCtx) : String / Console =

  concat_all(map(arms, (a) => emit_match_arm(src, a, cx)))

# Issue #209 — detect a cons reuse-arm whose body is the synthetic
# `__perceus_reuse_cons(__pcs_scr, h_new, t_new)` produced by
# `pcs_recognise_reuse_*`. When detected, the arm is emitted via the
# dual-path layout in `emit_match_arm_reuse_cons` instead of the
# default incref-the-binds layout: the unique branch borrows head/tail
# (no incref) so the recursive consumer sees the children at their
# actual RC, enabling spine-deep reuse instead of one-cell-only.

# Issue #209 — detect a cons reuse-arm whose body is the synthetic
# `__perceus_reuse_cons(__pcs_scr, h_new, t_new)` produced by
# `pcs_recognise_reuse_*`. When detected, the arm is emitted via the
# dual-path layout in `emit_match_arm_reuse_cons` instead of the
# default incref-the-binds layout: the unique branch borrows head/tail
# (no incref) so the recursive consumer sees the children at their
# actual RC, enabling spine-deep reuse instead of one-cell-only.
fn try_reuse_cons_arm(pat: Pattern, body: Expr) : Option[ReuseConsArm] {
  match pat.pkind {
    PList(pats, opt_rest) -> match opt_rest {
      Some(rest_name) -> match pats {
        [head_pat] -> match body.kind {
          ECall(callee, call_args) -> match callee.kind {
            EVar(callee_name) ->
              if callee_name == "__perceus_reuse_cons" {
                match call_args {
                  [_scr_arg, h_new, t_new] -> Some(ReuseConsArm(head_pat, rest_name, h_new, t_new))
                  _ -> None
                }
              } else { None }
            _ -> None
          }
          _ -> None
        }
        _ -> None
      }
      None -> None
    }
    _ -> None
  }
}

type ReuseConsArm = ReuseConsArm(Pattern, String, Expr, Expr)

# Emit a single reuse-arm with the dual-path layout. Pre-condition: the
# scrutinee value is in the C local `_scr`, and the test
# `_scr->tag == KAI_CONS` already passed (encoded by `emit_pat_test`).
#
# Unique branch (kai_check_unique(_scr) == 1):
#   - bind head/tail by *borrow* (no incref). The body's consumer of
#     each binding (e.g. `f(h)`, `recur(t)`) sees the child at its
#     real RC — typically 1 for a fresh spine — so the recursive call
#     also enters its own unique branch. This is what amplifies the
#     reuse from "outermost cell only" to L-per-call.
#   - evaluate `h_new` / `t_new` (which consume the borrowed binds).
#     After this point the slots `_scr->cons.{head,tail}` point at
#     freed memory, so the path is committed.
#   - overwrite the slots in place, incref `_scr` so it survives the
#     match-exit `kai_decref(_scr)`, return `_scr`.
#
# Fallback branch (cell shared, not unique):
#   - bind head/tail by `kai_incref` (the standard pat-binds path).
#   - evaluate `h_new` / `t_new` and allocate a fresh cell via
#     `kai_cons`. The original `_scr` and its children remain intact;
#     match exit's `kai_decref(_scr)` reclaims them normally.
#
# The body's `h_new` / `t_new` are emitted under bindings keyed on the
# pattern names (head_pat's PBind, rest_name); each branch issues its
# own bindings before the same body emit, so the body code is
# duplicated textually but evaluated exactly once at runtime.

# Emit a single reuse-arm with the dual-path layout. Pre-condition: the
# scrutinee value is in the C local `_scr`, and the test
# `_scr->tag == KAI_CONS` already passed (encoded by `emit_pat_test`).
#
# Unique branch (kai_check_unique(_scr) == 1):
#   - bind head/tail by *borrow* (no incref). The body's consumer of
#     each binding (e.g. `f(h)`, `recur(t)`) sees the child at its
#     real RC — typically 1 for a fresh spine — so the recursive call
#     also enters its own unique branch. This is what amplifies the
#     reuse from "outermost cell only" to L-per-call.
#   - evaluate `h_new` / `t_new` (which consume the borrowed binds).
#     After this point the slots `_scr->cons.{head,tail}` point at
#     freed memory, so the path is committed.
#   - overwrite the slots in place, incref `_scr` so it survives the
#     match-exit `kai_decref(_scr)`, return `_scr`.
#
# Fallback branch (cell shared, not unique):
#   - bind head/tail by `kai_incref` (the standard pat-binds path).
#   - evaluate `h_new` / `t_new` and allocate a fresh cell via
#     `kai_cons`. The original `_scr` and its children remain intact;
#     match exit's `kai_decref(_scr)` reclaims them normally.
#
# The body's `h_new` / `t_new` are emitted under bindings keyed on the
# pattern names (head_pat's PBind, rest_name); each branch issues its
# own bindings before the same body emit, so the body code is
# duplicated textually but evaluated exactly once at runtime.
fn emit_match_arm_reuse_cons(src: String, arm_lcs: [String], rca: ReuseConsArm,
                             cx: EmitCtx) : String / Console {

  let arm_cx = emit_ctx_with_lcs(cx, arm_lcs)
  match rca {
    ReuseConsArm(head_pat, rest_name, h_new, t_new) -> {
      # Borrowed-binds path: emit pat_binds with raw cons child slots
      # and *no* incref wrappers.
      let head_borrow = match head_pat.pkind {
        PBind(hn) -> concat_all(["KaiValue *kai_", hn, " = _scr->as.cons.head; "])
        PWild     -> ""
        _         -> emit_pat_binds(src, head_pat, "_scr->as.cons.head", true, cx)
      }
      let tail_borrow = concat_all(["KaiValue *kai_", rest_name, " = _scr->as.cons.tail; "])
      # Owned-binds path (fallback / shared): same shape as the
      # default `emit_pat_binds_list` produces.
      let head_owned = match head_pat.pkind {
        PBind(hn) -> concat_all(["KaiValue *kai_", hn, " = kai_incref(_scr->as.cons.head); "])
        PWild     -> ""
        _         -> emit_pat_binds(src, head_pat, "_scr->as.cons.head", true, cx)
      }
      let tail_owned = concat_all(["KaiValue *kai_", rest_name, " = kai_incref(_scr->as.cons.tail); "])
      let h_new_c = emit_expr(src, h_new, arm_cx)
      let t_new_c = emit_expr(src, t_new, arm_cx)
      concat_all([
        "if (kai_check_unique(_scr)) { ",
        head_borrow, tail_borrow,
        "KaiValue *_h_new = ", h_new_c, "; ",
        "KaiValue *_t_new = ", t_new_c, "; ",
        "_scr->as.cons.head = _h_new; _scr->as.cons.tail = _t_new; ",
        "kai_rc_reuse_total++; ",
        "_r = kai_incref(_scr); ",
        "} else { ",
        head_owned, tail_owned,
        "KaiValue *_h_new2 = ", h_new_c, "; ",
        "KaiValue *_t_new2 = ", t_new_c, "; ",
        "_r = kai_cons(_h_new2, _t_new2); ",
        "}"
      ])
    }
  }
}

fn emit_match_arm(src: String, a: Arm, cx: EmitCtx) : String / Console {

  match a {
    Arm(pat, opt_guard, body) -> {
      let pt = emit_pat_test(src, pat, "_scr", cx)
      # The arm's guard and body see this pattern's bound names as
      # locals, so an `EVar(p)` with `p` matching a pattern binder
      # (e.g. `match xs { [drop, ...rest] -> drop }` where `drop` is
      # also a top-level fn name) emits a local read instead of a
      # closure-thunk reference.
      let arm_lcs = list_append(cx.lcs, pat_binders(pat, []))
      let arm_cx = emit_ctx_with_lcs(cx, arm_lcs)
      # Issue #209 — reuse-arm dual-path emit. Only viable when there
      # is no guard (a guard might reject the unique branch after we
      # already committed to overwriting `_scr`'s slots).
      match opt_guard {
        None -> match try_reuse_cons_arm(pat, body) {
          Some(rca) -> {
            let arm_body = emit_match_arm_reuse_cons(src, arm_lcs, rca, cx)
            concat_all(["    if (", pt, ") { ", arm_body, " break; }\n"])
          }
          None -> {
            # _scr is shared across all match arms — subsequent arms re-read
            # it after this one's pat_test/guard rejects, and a guard inside
            # this arm may consume the binding (e.g. const-pattern desugar's
            # `__cv_NAME == NAME()`). Treat as alias so PBind increfs.
            let binds = emit_pat_binds(src, pat, "_scr", true, cx)
            let body_c = emit_expr(src, body, arm_cx)
            # Issue #309 — when every tail leaf of `body` is a tcrec
            # sentinel call, the goto leaves the enclosing
            # statement-expression and the post-do-while
            # `kai_decref(_scr)` is unreachable. Pre-inject the drop
            # inside the body's statement-expression so it executes
            # before the goto fires. Safe because the predicate
            # guarantees control NEVER reaches the post-do-while
            # decref via this arm — no double-decref is possible.
            if tcrec_tail_always_sentinel(body) {
              concat_all([
                "    if (", pt, ") { ", binds,
                "_r = ({ kai_decref(_scr); ", body_c, "; }); break; }\n"
              ])
            } else {
              concat_all(["    if (", pt, ") { ", binds, "_r = ", body_c, "; break; }\n"])
            }
          }
        }
        Some(g) -> {
          let binds = emit_pat_binds(src, pat, "_scr", true, cx)
          let body_c = emit_expr(src, body, arm_cx)
          let gc = emit_expr(src, g, arm_cx)
          concat_all([
            "    if (", pt, ") { ", binds,
            "if (kai_op_truthy(", gc, ")) { _r = ", body_c, "; break; } }\n"
          ])
        }
      }
    }
  }
}

fn pat_lit_raw(p: Pattern) : String {
  match p.pkind {
    PLit(lit) -> match lit.kind {
      EInt(n)  -> cat2(int_to_string(n), "LL")
      EBool(b) -> if b { "1" } else { "0" }
      EChar(c) -> int_to_string(char_to_int(c))
      _ -> "0LL /* pat_lit_raw: unexpected lit */"
    }
    _ -> "0LL /* pat_lit_raw: not a literal pattern */"
  }
}

# Lower a `match` whose scrutinee is `MUnboxed` and whose arms
# are all literal-or-wild into a C `switch`. The wildcard /
# bind arm becomes the `default:` clause; if no wildcard is
# present, `default:` panics with "non-exhaustive match".

# Lower a `match` whose scrutinee is `MUnboxed` and whose arms
# are all literal-or-wild into a C `switch`. The wildcard /
# bind arm becomes the `default:` clause; if no wildcard is
# present, `default:` panics with "non-exhaustive match".
fn emit_match_switch(src: String, scrut: Expr, arms: [Arm], cx: EmitCtx) : String / Console {

  let raw = emit_expr_raw(src, scrut, cx)
  let cty = raw_c_type(scrut.ty)
  concat_all([
    "({ ", cty, " _scr = ", raw, "; KaiValue *_r = kai_unit(); switch (_scr) {\n",
    emit_switch_arms(src, arms, cty, cx, false),
    "} _r; })"
  ])
}

fn emit_switch_arms(src: String, arms: [Arm], scr_cty: String, cx: EmitCtx, saw_default: Bool) : String / Console {

  match arms {
    [] -> if saw_default { "" }
          else { "    default: kai_prelude_panic(kai_str(\"non-exhaustive match\")); break;\n" }
    [a, ...rest] -> match a {
      Arm(p, _, body) -> {
        # Each arm's body sees the scrutinee binding as a local
        # name when the pattern is `PBind(name)`.
        let arm_lcs = list_append(cx.lcs, pat_binders(p, []))
        let body_c = emit_expr(src, body, emit_ctx_with_lcs(cx, arm_lcs))
        match p.pkind {
          PWild -> {
            let head = concat_all(["    default: _r = ", body_c, "; break;\n"])
            cat2(head, emit_switch_arms(src, rest, scr_cty, cx, true))
          }
          # Issue #91 — `PBind(name)` catch-all binds the raw
          # scalar `_scr` as `kair_<name>` for the body. Body
          # EVar reads of `name` resolve raw via the env extension
          # in `unbox_arm_with_scr`.
          PBind(name) -> {
            let head = concat_all([
              "    default: { ", scr_cty, " kair_", name, " = _scr; _r = ",
              body_c, "; } break;\n"
            ])
            cat2(head, emit_switch_arms(src, rest, scr_cty, cx, true))
          }
          _ -> {
            # PLit literal arm.
            let head = concat_all(["    case ", pat_lit_raw(p), ": _r = ", body_c, "; break;\n"])
            cat2(head, emit_switch_arms(src, rest, scr_cty, cx, saw_default))
          }
        }
      }
    }
  }
}

fn cty_for_bind(opt_ty: Option[Ty]) : String = raw_c_type(opt_ty)

fn emit_match_expr(src: String, scrut: Expr, arms: [Arm], cx: EmitCtx) : String / Console {

  # Tier 2.5 M5 — match scrutinee fast path. When the scrutinee is
  # `MUnboxed` (raw int / char) and every arm is a literal-or-wild
  # pattern of the same unboxable type with no guard, lower the
  # match to a C `switch` on the raw scalar. Avoids the `_scr`
  # boxed alias + per-arm `kai_op_eq(...)` chain. The Real-unboxing
  # extension restricts this fast path to integral scrutinee types
  # — `double` is not a valid `switch` operand in C, so a raw Real
  # scrutinee routes through the boxed path (re-boxing once at the
  # boundary).
  match scrut.mode {
    MUnboxed -> {
      if ty_is_integral_raw(scrut.ty) and arms_all_literal_or_wild(arms) and arms_pbind_safe_for_fast_path(arms) {
        emit_match_switch(src, scrut, arms, cx)
      } else {
        emit_match_default(src, scrut, arms, cx)
      }
    }
    _ -> emit_match_default(src, scrut, arms, cx)
  }
}

fn emit_match_default(src: String, scrut: Expr, arms: [Arm], cx: EmitCtx) : String / Console {

  let sc = emit_expr(src,scrut, cx)
  # m5.x flip Phase 3 closeout (original 9fe6f6d shape, restored after
  # §4b landed): consume the scrutinee linearly. `_scr` takes the value
  # `sc` returns and is decrefed on exit. Multi-read let-bound names
  # arrive pre-wrapped in `__perceus_dup` from the perceus_pass EStr +
  # AST rewrite, so a bare read of the binding is single-use by the
  # time the match sees it; the match decref consumes the ref it owns
  # without touching the producer's slot.
  concat_all([
    "({ KaiValue *_scr = ", sc, "; KaiValue *_r = kai_unit(); do {\n",
    emit_match_arms(src, arms, cx),
    "    kai_prelude_panic(kai_str(\"non-exhaustive match\"));\n",
    "} while (0); kai_decref(_scr); _r; })"
  ])
}

# ---- string interpolation ----
#
# The raw span includes quotes: either 1 quote on each side for single-
# or 3 quotes for triple. We walk the body (between the quotes) and
# split into literal / expression parts at each `#{...}` boundary, then
# chain them via kai_string_concat wrapping each expression in
# kai_to_string.

fn interp_is_triple(span: String) : Bool {
  let n = string_length(span)
  if n < 6 { false }
  else {
    match char_at(span, 0) {
      Some(c) -> c == '"' and match char_at(span, 1) {
        Some(c2) -> c2 == '"' and match char_at(span, 2) {
          Some(c3) -> c3 == '"'
          None -> false
        }
        None -> false
      }
      None -> false
    }
  }
}

fn emit_interp_parts(src: String, parts: [IPart], cx: EmitCtx) : String / Console {

  match parts {
    [] -> "kai_str(\"\")"
    [p] -> emit_interp_part(src, p, cx)
    [p, ...rest] -> concat_all([
      "kai_string_concat(",
      emit_interp_part(src, p, cx),
      ", ",
      emit_interp_parts(src, rest, cx),
      ")"
    ])
  }
}

fn emit_interp_part(src: String, p: IPart, cx: EmitCtx) : String / Console {

  match p {
    IpLit(_, raw) -> cat3("kai_str(", raw, ")")
    IpExp(expr_src) -> {
      match parse_interp_expr(expr_src) {
        Some(e) -> cat3("kai_to_string(", emit_expr(src,e, cx), ")")
        None -> "kai_str(\"\")"
      }
    }
  }
}

# escape_str_body_for_c / esc_body_loop moved to compiler/util.kai
# (issue #677 phase 1h H1a). Per issue #311, triple-quote string spans
# carry unescaped chars (newline, tab, `"`) the C preprocessor can't
# handle; the helper walks the body once emitting a C-escape per
# problem char.

fn emit_string_expr(src: String, span: String, is_triple: Bool, cx: EmitCtx) : String / Console {

  let n = string_length(span)
  let body_start = if is_triple { 3 } else { 1 }
  let body_end = if is_triple { n - 3 } else { n - 1 }
  # Fast path: if no `#{` appears, emit as a plain C literal.
  if not has_interp(span, body_start, body_end) {
    if is_triple {
      let body = string_slice(span, body_start, body_end - body_start)
      cat3("kai_str(\"", escape_str_body_for_c(body), "\")")
    } else {
      cat3("kai_str(", span, ")")
    }
  } else {
    let parts = iscan_collect(span, body_end, IScan { parts: [], lit_start: body_start, i: body_start })
    emit_interp_parts(src, parts, cx)
  }
}

# has_interp moved to compiler/util.kai (issue #677 phase 1h H2 pre-move).

# ---- lambda collection + emission ----
#
# We pre-walk the program building a list of LamInfo entries; each entry
# gets a unique id and records the lambda's params, its free variables
# (its closure captures), and its body. At emit time the lambda
# expression is replaced with `kai_closure(&_kai_lam_<id>, arity,
# n_caps, captures)`; the body is emitted as a separate function later.

fn pat_bindings_skip_raw(pat: Pattern, rhs: Expr, acc: [String]) : [String] {
  match pat.pkind {
    PBind(name) -> match rhs.mode {
      MUnboxed -> acc
      _        -> [name, ...acc]
    }
    _ -> pat_bindings(pat, acc)
  }
}

fn fv_stmts(ss: [Stmt], own: [String], globals: [String], acc: [String]) : [String] / Console {

  let r = fv_stmts_scoped(ss, own, globals, acc)
  r.acc
}

fn handle_captures_at(cls: [ClauseInfo], hline: Int, hcol: Int) : [String] {
  match cls {
    [] -> []
    [c, ...rest] -> match c {
      CI(line, col, _, _, _, _, _, _, caps) ->
        if line == hline and col == hcol {
          merge_string_set(caps, handle_captures_at(rest, hline, hcol))
        } else {
          handle_captures_at(rest, hline, hcol)
        }
    }
  }
}

# Stable-order union of two string lists. Order matters because the
# install side (`emit_handle_env_assigns`) and the read side
# (`emit_clause_env_prologue`) must walk the same struct fields in
# the same sequence; we lean on the C struct's field order to align
# both.

# Stable-order union of two string lists. Order matters because the
# install side (`emit_handle_env_assigns`) and the read side
# (`emit_clause_env_prologue`) must walk the same struct fields in
# the same sequence; we lean on the C struct's field order to align
# both.
fn merge_string_set(a: [String], b: [String]) : [String] {
  match a {
    [] -> b
    [h, ...rest] -> {
      if list_has(b, h) { merge_string_set(rest, b) }
      else { [h, ...merge_string_set(rest, b)] }
    }
  }
}

# R9: stable C symbol for a handle's env struct. Built from the same
# (enc_fn, line, col) triple as the clause-fn names; both ends mint
# matching identifiers off the matching `ClauseInfo` so the cast in
# the clause prologue resolves to the same type the install site
# allocated. `enc_fn` is the post-monomorph fn / lambda symbol.

# R9: stable C symbol for a handle's env struct. Built from the same
# (enc_fn, line, col) triple as the clause-fn names; both ends mint
# matching identifiers off the matching `ClauseInfo` so the cast in
# the clause prologue resolves to the same type the install site
# allocated. `enc_fn` is the post-monomorph fn / lambda symbol.
fn handle_env_struct_name(enc_fn: String, line: Int, col: Int) : String =
  concat_all([
    "_kai_", enc_fn, "__env_",
    int_to_string(line), "_", int_to_string(col)
  ])

# Lookup the enc_fn stamped on any clause of this handle (all clauses
# of one handle share the same enc_fn). Returns "" when no matching
# clause is in the table — the same defensive fallback used by
# `lookup_clause_enc_fn`.

# Lookup the enc_fn stamped on any clause of this handle (all clauses
# of one handle share the same enc_fn). Returns "" when no matching
# clause is in the table — the same defensive fallback used by
# `lookup_clause_enc_fn`.
fn handle_enc_fn_at(cls: [ClauseInfo], hline: Int, hcol: Int) : String {
  match cls {
    [] -> ""
    [c, ...rest] -> match c {
      CI(line, col, _, _, _, _, _, enc_fn, _) ->
        if line == hline and col == hcol { enc_fn }
        else { handle_enc_fn_at(rest, hline, hcol) }
    }
  }
}

fn collect_op_to_eff(decls: [Decl]) : [OpToEff] {
  match decls {
    [] -> []
    [d, ...rest] -> match d {
      DEffect(_, eff_name, _, ops, _, _, _) ->
        list_append(ops_to_eff_pairs(eff_name, ops),
                    collect_op_to_eff(rest))
      _ -> collect_op_to_eff(rest)
    }
  }
}

fn ops_to_eff_pairs(eff_name: String, ops: [EffectOp]) : [OpToEff] {
  match ops {
    [] -> []
    [op, ...rest] -> match op {
      EOp(op_name, _, _, _, _, _) ->
        [OEFP(op_name, eff_name), ...ops_to_eff_pairs(eff_name, rest)]
    }
  }
}

# Returns Some(eff_name) if some component of the alias provides op_name.
# When multiple components share an op_name (currently impossible in
# the catalog — Stdout.print, Stderr.eprint, Stdin.read_line, etc., are
# disjoint), the leftmost component wins. The check is case-sensitive.

# Returns Some(eff_name) if some component of the alias provides op_name.
# When multiple components share an op_name (currently impossible in
# the catalog — Stdout.print, Stderr.eprint, Stdin.read_line, etc., are
# disjoint), the leftmost component wins. The check is case-sensitive.
fn find_eff_for_alias_op(components: [String], op_to_eff: [OpToEff], op_name: String) : Option[String] {
  match components {
    [] -> None
    [c, ...rest] ->
      if eff_has_op(c, op_name, op_to_eff) { Some(c) }
      else { find_eff_for_alias_op(rest, op_to_eff, op_name) }
  }
}

fn eff_has_op(eff_name: String, op_name: String, op_to_eff: [OpToEff]) : Bool {
  match op_to_eff {
    [] -> false
    [oe, ...rest] -> match oe {
      OEFP(o, e) ->
        if o == op_name and e == eff_name { true }
        else { eff_has_op(eff_name, op_name, rest) }
    }
  }
}

# m12.8 Phase 4b: alias-aware op-call resolution lives inside
# `try_op_call` (typer) and `desugar_op_calls_callee` (emit) instead
# of as a standalone walker — a separate pre-pass blew the selfhost
# stack when traversing compiler.kai's deep AST. The helpers
# `find_alias` / `find_eff_for_alias_op` / `eff_has_op` (defined
# above) are consulted at each call site.

fn emit_lam_arg_reads(params: [Param], i: Int) : String {
  match params {
    [] -> ""
    [p, ...rest] -> concat_all([
      "    KaiValue *kai_", p.pname, " = args[", int_to_string(i), "];\n",
      emit_lam_arg_reads(rest, i + 1)
    ])
  }
}

fn emit_lam_cap_reads(caps: [String], i: Int) : String {
  match caps {
    [] -> ""
    [c, ...rest] -> {
      let prefix = "__alias_id__"
      let read_line = if string_starts_with_q(c, prefix) {
        # Handler-id sentinel: unpack the kai_int back to a
        # KaiHandlerId so the existing tagged-op emit
        # (`kai_evidence_lookup_node_by_id(kai_alias_<a>_id)`)
        # finds the local in scope.
        let alias = string_slice(c, string_length(prefix), string_length(c))
        concat_all([
          "    KaiHandlerId kai_alias_", alias,
          "_id = (KaiHandlerId) self->as.clo.captures[",
          int_to_string(i),
          "]->as.i;\n"
        ])
      } else {
        concat_all([
          "    KaiValue *kai_", c, " = self->as.clo.captures[", int_to_string(i), "];\n"
        ])
      }
      concat_all([read_line, emit_lam_cap_reads(rest, i + 1)])
    }
  }
}

fn emit_lam_helper(src: String, l: LamInfo, cx: EmitCtx) : String / Console {

  match l {
    LamInfo(id, _, _, params, caps, body) -> {
      let arg_reads = emit_lam_arg_reads(params, 0)
      let cap_reads = emit_lam_cap_reads(caps, 0)
      # Lambda body sees its params + captures as locals — same
      # contract as `emit_fn_body` for top-level fn params.
      let body_lcs = list_append(list_append(cx.lcs, fn_param_names(params)), caps)
      let body_c = emit_expr(src,body, emit_ctx_with_lcs(cx, body_lcs))
      concat_all([
        "static KaiValue *_kai_lam_", int_to_string(id),
        "(KaiValue *self, KaiValue **args, int n) {\n",
        "    (void) self; (void) n;\n",
        arg_reads, cap_reads,
        "    return ", body_c, ";\n}\n\n"
      ])
    }
  }
}

fn emit_lam_helpers(src: String, lams: [LamInfo], fns: [EFn], variants: [EVar], cls: [ClauseInfo]) : String / Console =

  concat_all(map(lams, (l) => emit_lam_helper(src, l, EmitCtx { lcs: [], fns: fns, variants: variants, lams: lams, cls: cls,
                                                                regions: [], in_region: false })))

fn emit_one_lam_forward(l: LamInfo) : String =
  match l {
    LamInfo(id, _, _, _, _, _) ->
      concat_all(["static KaiValue *_kai_lam_", int_to_string(id), "(KaiValue *, KaiValue **, int);\n"])
  }

fn emit_lam_forward_decls(lams: [LamInfo]) : String =
  concat_all(map(lams, emit_one_lam_forward))

# m7a #6c — clause body emission. Each HClause becomes a top-level
# C function whose name encodes the EHandle's source position plus
# the op name (collisions are impossible since two distinct HCs
# either belong to different handles or carry different op names).
# The signature matches the EvE field type pinned in #6a:
#   `static KaiValue *_kai_clause_<line>_<col>_<op>(EvE *self, args..., KaiCont *k)`.
# `resume` is the surface convention for the trailing param and is
# never part of the C signature — the body uses `resume(v)` as
# direct-style identity (m7a #6c only). m7a #6d will replace this
# with a reified continuation closure.

fn emit_clause_sig(c: ClauseInfo) : String {
  match c {
    CI(line, col, eff, op_name, params, _, _, enc_fn, _) -> {
      let op_args = op_args_only(params)
      let arg_str = match op_args {
        [] -> ""
        _  -> cat2(", ", join_with(map(op_args, (pm) => cat2("KaiValue *kai_", pm.pname)), ", "))
      }
      concat_all([
        "static KaiValue *", clause_fn_name(enc_fn, line, col, op_name),
        "(Ev", eff, " *self", arg_str, ", KaiCont *k)"
      ])
    }
  }
}

fn emit_clause_forward(c: ClauseInfo) : String =
  cat2(emit_clause_sig(c), ";\n")

fn emit_clause_forwards(cs: [ClauseInfo]) : String =
  concat_all(map(cs, emit_clause_forward))

# R9: per-handle env typedefs. One typedef per (line, col, enc_fn)
# triple, covering the union of every clause's captures. Emitted at
# top level (ahead of the clause forwards) so the install-site
# allocation in `emit_handle` and the read-side cast in
# `emit_clause_env_prologue` both resolve to the same struct type.
# Uses a "first occurrence wins" walk: the first ClauseInfo we meet
# for a (line, col) pair owns the typedef, later ones for the same
# handle skip emission. Captures are unioned across all clauses of
# the matching handle so the struct layout covers every clause body.

# R9: per-handle env typedefs. One typedef per (line, col, enc_fn)
# triple, covering the union of every clause's captures. Emitted at
# top level (ahead of the clause forwards) so the install-site
# allocation in `emit_handle` and the read-side cast in
# `emit_clause_env_prologue` both resolve to the same struct type.
# Uses a "first occurrence wins" walk: the first ClauseInfo we meet
# for a (line, col) pair owns the typedef, later ones for the same
# handle skip emission. Captures are unioned across all clauses of
# the matching handle so the struct layout covers every clause body.
fn emit_handle_env_typedefs(cs: [ClauseInfo]) : String =
  emit_handle_env_typedefs_loop(cs, [])

fn emit_handle_env_typedefs_loop(cs: [ClauseInfo], seen: [String]) : String {
  match cs {
    [] -> ""
    [c, ...rest] -> match c {
      CI(line, col, _, _, _, _, _, enc_fn, _) -> {
        let key = handle_env_struct_name(enc_fn, line, col)
        if list_has(seen, key) {
          emit_handle_env_typedefs_loop(rest, seen)
        } else {
          let caps = handle_captures_at(cs, line, col)
          let decl = match caps {
            [] -> ""
            _ -> emit_handle_env_typedef(key, caps)
          }
          concat_all([decl, emit_handle_env_typedefs_loop(rest, [key, ...seen])])
        }
      }
    }
  }
}

fn emit_handle_env_typedef(env_name: String, caps: [String]) : String =
  concat_all([
    "typedef struct ", env_name, " ", env_name, ";\n",
    "struct ", env_name, " {\n",
    emit_handle_env_typedef_fields(caps),
    "};\n\n"
  ])

fn emit_handle_env_typedef_fields(caps: [String]) : String {
  match caps {
    [] -> ""
    [c, ...rest] -> concat_all([
      "    KaiValue *kai_", c, ";\n",
      emit_handle_env_typedef_fields(rest)
    ])
  }
}

# m7b #11: stateful-clause prologue. `state` and `log` are aliases of
# `self->state`. Both names are bound (the two are aliases of the same
# slot — the spec uses `state` for `State[T]` and `log` for `Writer[W]`,
# but at this layer they read the same field). The clause body is then
# emitted unchanged: any `state` / `log` reference falls through the
# normal ident lookup and resolves to the local C alias.

# m7b #11: stateful-clause prologue. `state` and `log` are aliases of
# `self->state`. Both names are bound (the two are aliases of the same
# slot — the spec uses `state` for `State[T]` and `log` for `Writer[W]`,
# but at this layer they read the same field). The clause body is then
# emitted unchanged: any `state` / `log` reference falls through the
# normal ident lookup and resolves to the local C alias.
fn clause_state_prologue(stateful: Bool) : String {
  if stateful {
    "    KaiValue *kai_state = self->state; KaiValue *kai_log = self->state;\n"
  } else { "" }
}

fn emit_clause_body(src: String, c: ClauseInfo, cx: EmitCtx) : String / Console {

  match c {
    CI(line, col, _, _, _, body, stateful, enc_fn, caps) -> {
      # Clause body sees `self` and `k` (always), `kai_state` /
      # `kai_log` (when stateful), the clause's params (params
      # come into scope through the surrounding handle's lcs),
      # and — R9 — every capture that travels through `self->env`.
      # `state` / `log` are spelled with `kai_` prefix in the
      # generated C, but the kaikai-side names are `state` / `log`.
      let stateful_locals = if stateful { ["state", "log"] } else { [] }
      let body_lcs = list_append(list_append(list_append(cx.lcs, ["self", "k"]), stateful_locals), caps)
      let body_c = emit_expr_in_clause(src, body, emit_ctx_with_lcs(cx, body_lcs), stateful)
      let env_prologue = emit_clause_env_prologue(cx.cls, line, col, enc_fn, caps)
      concat_all([
        emit_clause_sig(c), " {\n",
        "    (void) self; (void) k;\n",
        clause_state_prologue(stateful),
        env_prologue,
        "    return ", body_c, ";\n",
        "}\n\n"
      ])
    }
  }
}

# R9: rebind each captured `kai_<name>` from the handle's env struct
# into a clause-local C variable, so the body can reference enclosing
# bindings the same way it would inside the surrounding fn. The cast
# target is the per-handle env typedef minted by
# `emit_handle_env_typedefs`; field names match exactly the surface
# names listed in `caps`. Empty when the clause captures nothing —
# the env slot stays NULL and is never dereferenced.
#
# Each read goes through `kai_internal_dup` because perceus analyses
# every clause body in isolation and assumes its `kai_<name>` locals
# arrive with a private reference it may consume (e.g. by passing
# the value to `kai_prelude_string_concat`). The env struct itself
# holds a borrow scoped to the handle stmt-expression — the caller's
# `kai_<name>` outlives the handle's body and is dropped after the
# stmt-expr unwinds, which is the same scope the spec assigns to
# `EvE.env`. Without the dup, a single-use capture would be freed
# after the first clause invocation and the second would read a
# dangling pointer (the manifestation of "Perceus needs to incref
# captures at install / decref at pop" — solved here at clause
# entry, where it composes with perceus's per-clause analysis).

# R9: rebind each captured `kai_<name>` from the handle's env struct
# into a clause-local C variable, so the body can reference enclosing
# bindings the same way it would inside the surrounding fn. The cast
# target is the per-handle env typedef minted by
# `emit_handle_env_typedefs`; field names match exactly the surface
# names listed in `caps`. Empty when the clause captures nothing —
# the env slot stays NULL and is never dereferenced.
#
# Each read goes through `kai_internal_dup` because perceus analyses
# every clause body in isolation and assumes its `kai_<name>` locals
# arrive with a private reference it may consume (e.g. by passing
# the value to `kai_prelude_string_concat`). The env struct itself
# holds a borrow scoped to the handle stmt-expression — the caller's
# `kai_<name>` outlives the handle's body and is dropped after the
# stmt-expr unwinds, which is the same scope the spec assigns to
# `EvE.env`. Without the dup, a single-use capture would be freed
# after the first clause invocation and the second would read a
# dangling pointer (the manifestation of "Perceus needs to incref
# captures at install / decref at pop" — solved here at clause
# entry, where it composes with perceus's per-clause analysis).
fn emit_clause_env_prologue(cls: [ClauseInfo], line: Int, col: Int,
                             enc_fn: String, caps: [String]) : String {
  match caps {
    [] -> ""
    _ -> {
      let env_name = handle_env_struct_name(enc_fn, line, col)
      concat_all([
        "    ", env_name, " *_env = (", env_name, " *) self->env;\n",
        emit_clause_env_reads(caps)
      ])
    }
  }
}

fn emit_clause_env_reads(caps: [String]) : String {
  match caps {
    [] -> ""
    [c, ...rest] -> concat_all([
      "    KaiValue *kai_", c, " = kai_internal_dup(_env->kai_", c, ");\n",
      emit_clause_env_reads(rest)
    ])
  }
}

# Wrapper around `emit_expr` that flips the in-clause flag, so that
# `resume(v, ns)` lowers to a state-write before the resume call.
# Defined further below near emit_expr.

# Wrapper around `emit_expr` that flips the in-clause flag, so that
# `resume(v, ns)` lowers to a state-write before the resume call.
# Defined further below near emit_expr.
fn emit_expr_in_clause(src: String, e: Expr, cx: EmitCtx, stateful: Bool) : String / Console =

  emit_expr(src, e, cx)

fn emit_clause_bodies(src: String, cs: [ClauseInfo], cx: EmitCtx) : String / Console =

  concat_all(map(cs, (c) => emit_clause_body(src, c, cx)))

# m7c-d — emit each clause as a top-level LLVM function. Mirrors
# `emit_clause_body`/`emit_clause_sig` from the C backend. The
# function takes `(EvX *self, %KaiValue* %arg1, ..., i8* %k)`
# and returns `%KaiValue*`. Inside, `self` and `k` are bound as
# locals (literal register names `%self` / `%k` so the resume
# handler in `llvm_emit_call` can reference `%k` directly). For
# stateful clauses we load `self->state` once into a local
# `%kai_state` (also bound as `%kai_log`) so the body can
# reference `state`/`log` like any other ident.

# m7c-d — emit each clause as a top-level LLVM function. Mirrors
# `emit_clause_body`/`emit_clause_sig` from the C backend. The
# function takes `(EvX *self, %KaiValue* %arg1, ..., i8* %k)`
# and returns `%KaiValue*`. Inside, `self` and `k` are bound as
# locals (literal register names `%self` / `%k` so the resume
# handler in `llvm_emit_call` can reference `%k` directly). For
# stateful clauses we load `self->state` once into a local
# `%kai_state` (also bound as `%kai_log`) so the body can
# reference `state`/`log` like any other ident.
fn emit_one_closure_cap(c: String) : String {
  let prefix = "__alias_id__"
  if string_starts_with_q(c, prefix) {
    let alias = string_slice(c, string_length(prefix), string_length(c))
    concat_all(["kai_int((int64_t) kai_alias_", alias, "_id)"])
  } else {
    cat2("kai_", c)
  }
}

fn emit_closure_caps(caps: [String]) : String =
  join_with(map(caps, emit_one_closure_cap), ", ")

fn emit_lambda_ref(x: Expr, cx: EmitCtx) : String {
  match find_lam(cx.lams, x.line, x.col) {
    None -> "kai_unit() /* lambda: missing info */"
    Some(l) -> match l {
      LamInfo(id, _, _, params, caps, _) -> {
        let arity = list_length(params)
        let n_caps = list_length(caps)
        if n_caps == 0 {
          concat_all([
            "kai_closure(&_kai_lam_", int_to_string(id),
            ", ", int_to_string(arity), ", 0, NULL)"
          ])
        } else {
          concat_all([
            "kai_closure(&_kai_lam_", int_to_string(id),
            ", ", int_to_string(arity), ", ", int_to_string(n_caps),
            ", (KaiValue *[]){", emit_closure_caps(caps), "})"
          ])
        }
      }
    }
  }
}

# ---- full emit_expr (with lambda support) ----

# C type used for a raw local of an unboxable type. Matches the
# `as.*` field widths in `KaiValue` (see runtime.h).

# C type used for a raw local of an unboxable type. Matches the
# `as.*` field widths in `KaiValue` (see runtime.h).
fn raw_c_type(opt_ty: Option[Ty]) : String {
  match opt_ty {
    Some(t) -> match t {
      TyInt  -> "int64_t"
      TyReal -> "double"
      TyBool -> "int"
      TyChar -> "uint32_t"
      TyDimT(inner, _)    -> raw_c_type(Some(inner))
      TyRefineT(inner, _) -> raw_c_type(Some(inner))
      _ -> "int64_t /* raw_c_type: unexpected ty */"
    }
    None -> "int64_t /* raw_c_type: missing ty */"
  }
}

# Wrap a raw C scalar into its boxed `KaiValue *` form. Picks the
# constructor by `ty`. `kai_int` / `kai_bool` / `kai_char` are the
# Phase 1 cache-aware constructors so small ints and chars stay
# allocation-free at the boundary.

# Wrap a raw C scalar into its boxed `KaiValue *` form. Picks the
# constructor by `ty`. `kai_int` / `kai_bool` / `kai_char` are the
# Phase 1 cache-aware constructors so small ints and chars stay
# allocation-free at the boundary.
fn box_wrap(opt_ty: Option[Ty], raw: String) : String {
  match opt_ty {
    Some(t) -> match t {
      TyInt  -> cat3("kai_int(",  raw, ")")
      TyReal -> cat3("kai_real(", raw, ")")
      TyBool -> cat3("kai_bool(", raw, ")")
      TyChar -> cat3("kai_char(", raw, ")")
      TyDimT(inner, _)    -> box_wrap(Some(inner), raw)
      TyRefineT(inner, _) -> box_wrap(Some(inner), raw)
      _ -> cat3("kai_int(", raw, ") /* box_wrap: unexpected ty */")
    }
    None -> cat3("kai_int(", raw, ") /* box_wrap: missing ty */")
  }
}

# Unbox a boxed `KaiValue *` into its raw C scalar. Used at the
# `MBoxed → MUnboxed` boundary inside arithmetic operands.

# Unbox a boxed `KaiValue *` into its raw C scalar. Used at the
# `MBoxed → MUnboxed` boundary inside arithmetic operands.
# True when a raw EBinop is Int `+`/`-`/`*` and must therefore wrap in
# two's complement (kaikai's documented Int semantics). The emitter
# renders these via a uint64_t round-trip so the wrap is well-defined
# C; `/` and `%` are excluded (their overflow is not contractually a
# wrap, and div-by-INT64_MIN is a separate concern) and Real `+`/`-`/`*`
# are excluded by the TyInt gate. See the EBinop arm in emit_kind_raw.
fn raw_arith_is_wrapping_int(op: String, opt_ty: Option[Ty]) : Bool {
  let is_wrap_op = op == "+" or op == "-" or op == "*"
  let is_int = match opt_ty {
    Some(t) -> match t {
      TyInt -> true
      TyDimT(inner, _)    -> match inner { TyInt -> true _ -> false }
      TyRefineT(inner, _) -> match inner { TyInt -> true _ -> false }
      _ -> false
    }
    None -> false
  }
  is_wrap_op and is_int
}

fn unbox_field_for(opt_ty: Option[Ty]) : String {
  match opt_ty {
    Some(t) -> match t {
      TyInt  -> "->as.i"
      TyReal -> "->as.r"
      TyBool -> "->as.b"
      TyChar -> "->as.c"
      TyDimT(inner, _)    -> unbox_field_for(Some(inner))
      TyRefineT(inner, _) -> unbox_field_for(Some(inner))
      _ -> "->as.i /* unbox: unexpected ty */"
    }
    None -> "->as.i /* unbox: missing ty */"
  }
}

# Emit the raw C scalar form of `x`. Caller has already established
# that `x.ty` is unboxable; the result is `int64_t` / `int` /
# `uint32_t` (depending on ty), no `KaiValue *` wrapper.
#
# When `x.mode` is `MUnboxed` the kind is one of the natively-raw
# forms (literal, raw EVar, raw arith). When `x.mode` is `MBoxed`
# we fall back to emitting boxed and tacking on the unbox field —
# the boundary tactic from `docs/unboxing-phase2-design.md` §3.

# Emit the raw C scalar form of `x`. Caller has already established
# that `x.ty` is unboxable; the result is `int64_t` / `int` /
# `uint32_t` (depending on ty), no `KaiValue *` wrapper.
#
# When `x.mode` is `MUnboxed` the kind is one of the natively-raw
# forms (literal, raw EVar, raw arith). When `x.mode` is `MBoxed`
# we fall back to emitting boxed and tacking on the unbox field —
# the boundary tactic from `docs/unboxing-phase2-design.md` §3.
fn emit_expr_raw(src: String, x: Expr, cx: EmitCtx) : String / Console {

  match x.mode {
    MUnboxed -> emit_kind_raw(src, x, cx)
    _ -> {
      let boxed = emit_expr_boxed(src, x, cx)
      cat3("(", boxed, cat2(")", unbox_field_for(x.ty)))
    }
  }
}

# Issue #90 — unroll `b ^ n` into `n` repeated multiplications.
# Caller has already gated `n` to `[0, 64]` and `base_c` is a pure
# raw C expression (literal / EVar / pure raw arith). For `n == 0`
# the result is `1` (matches `kai_op_pow_int`). For `n == 1`,
# emit just `(base_c)`. For `n >= 2`, emit `((base_c)*(base_c)*…)`
# with `n` factors. Squaring would emit fewer factors but produces
# the same constant-folded code under any optimizer; the linear
# form keeps the emitted IR easy to grep for in regression tests.

# Issue #90 — unroll `b ^ n` into `n` repeated multiplications.
# Caller has already gated `n` to `[0, 64]` and `base_c` is a pure
# raw C expression (literal / EVar / pure raw arith). For `n == 0`
# the result is `1` (matches `kai_op_pow_int`). For `n == 1`,
# emit just `(base_c)`. For `n >= 2`, emit `((base_c)*(base_c)*…)`
# with `n` factors. Squaring would emit fewer factors but produces
# the same constant-folded code under any optimizer; the linear
# form keeps the emitted IR easy to grep for in regression tests.
fn emit_pow_unroll(base_c: String, n: Int) : String {
  match n {
    0 -> "1LL"
    1 -> cat3("(", base_c, ")")
    _ -> cat3("(", emit_pow_unroll_loop(base_c, n, ""), ")")
  }
}

fn emit_pow_unroll_loop(base_c: String, k: Int, acc: String) : String {
  match k {
    0 -> acc
    1 -> {
      if acc == "" { cat3("(", base_c, ")") }
      else { concat_all([acc, " * (", base_c, ")"]) }
    }
    _ -> {
      let next = if acc == "" { cat3("(", base_c, ")") }
                 else { concat_all([acc, " * (", base_c, ")"]) }
      emit_pow_unroll_loop(base_c, k - 1, next)
    }
  }
}

fn emit_kind_raw(src: String, x: Expr, cx: EmitCtx) : String / Console {

  match x.kind {
    EInt(n)  -> cat2(int_to_string(n), "LL")
    EReal(r) -> real_c_lit(real_to_string(r))
    EBool(b) -> if b { "1" } else { "0" }
    EChar(c) -> int_to_string(char_to_int(c))
    EVar(name) -> cat2("kair_", name)
    EBinop(op, a, b) ->
      if raw_arith_is_wrapping_int(op, x.ty) {
        # Int +/-/* wrap in two's complement by design (matches the
        # boxed `kai_op_*` path). Compute in uint64_t and cast back so
        # the wrap is well-defined C (6.3.1.3) rather than signed-
        # overflow UB that `-fsanitize=undefined` flags — reachable
        # the moment a hash mix (`acc * 31`) overflows. Real `*`/`+`
        # and Int `/`/`%` keep the plain form (handled below).
        concat_all(["((int64_t)((uint64_t)(",
                    emit_expr_raw(src, a, cx),
                    ") ", raw_op_str(op), " (uint64_t)(",
                    emit_expr_raw(src, b, cx),
                    ")))"])
      } else if op_is_raw_arith(op) or op_is_raw_cmp(op) or op_is_raw_logical(op) {
        concat_all(["(",
                    emit_expr_raw(src, a, cx),
                    " ", raw_op_str(op), " ",
                    emit_expr_raw(src, b, cx),
                    ")"])
      } else if op == "^" {
        # Issue #90 — integer power, exponent is a compile-time
        # literal in `[0, 64]` (gated by `pow_exp_is_inlinable`).
        # Unroll into repeated multiplications. Base is pure raw
        # (no calls) so duplication is safe.
        let n = match try_eval_int(b) { Some(v) -> v None -> 0 }
        let base_c = emit_expr_raw(src, a, cx)
        emit_pow_unroll(base_c, n)
      } else {
        # Conservative fallback: boxed expression then unbox.
        let boxed = emit_expr_boxed(src, x, cx)
        cat3("(", boxed, cat2(")", unbox_field_for(x.ty)))
      }
    EUnop(op, inner) ->
      if op == "-" {
        cat3("(-", emit_expr_raw(src, inner, cx), ")")
      } else if op == "not" {
        cat3("(!", emit_expr_raw(src, inner, cx), ")")
      } else {
        let boxed = emit_expr_boxed(src, x, cx)
        cat3("(", boxed, cat2(")", unbox_field_for(x.ty)))
      }
    # Phase 3 unboxing — when the callee resolves to a UFn, emit
    # the raw call inline (`<callee>(<raw args>)`) so the result
    # stays a raw scalar without a kai_int wrap-and-unwrap. The
    # tcrec sentinel callee is special — it always lowers to the
    # `goto`-block which `tcrec_emit_goto` already produces in raw
    # form when the surrounding fn is UFn. Other callees fall back
    # to the boxed-then-unbox boundary form.
    ECall(callee_e, args_e) -> match callee_e.kind {
      EVar(callee) ->
        if tcrec_is_sentinel(callee) {
          let parts = tcrec_split_pipe(callee)
          match parts {
            [_, sym, dropmask_str, ...pnames] -> {
              let dropmask = tcrec_parse_decimal(dropmask_str)
              tcrec_emit_goto(src, sym, dropmask, pnames, args_e,
                              cx)
            }
            _ -> "0 /* tcrec: malformed sentinel */"
          }
        } else { match emit_ufn_raw_call(src, callee_e, args_e, cx) {
          Some(s) -> s
          None    -> {
            let boxed = emit_expr_boxed(src, x, cx)
            cat3("(", boxed, cat2(")", unbox_field_for(x.ty)))
          }
        } }
      _ -> match emit_ufn_raw_call(src, callee_e, args_e, cx) {
        Some(s) -> s
        None    -> {
          let boxed = emit_expr_boxed(src, x, cx)
          cat3("(", boxed, cat2(")", unbox_field_for(x.ty)))
        }
      }
    }
    # Phase 3 unboxing — `if cond { a } else { b }` where every
    # branch is itself emit-raw-able lowers to the C ternary
    # `(cond ? a : b)`. Caller has already gated `x.mode = MUnboxed`
    # via `decide_mode`'s EIf clause (not yet enabled — kept boxed
    # for now). Defensive: when present, both arms must agree on
    # type and the cond must be raw-bool.
    EIf(cnd, ath, opt_eth) -> match opt_eth {
      Some(eth) -> {
        let cnd_c = emit_expr_raw(src, cnd, cx)
        let a_c = emit_expr_raw(src, ath, cx)
        let b_c = emit_expr_raw(src, eth, cx)
        concat_all(["(", cnd_c, " ? ", a_c, " : ", b_c, ")"])
      }
      None -> {
        let boxed = emit_expr_boxed(src, x, cx)
        cat3("(", boxed, cat2(")", unbox_field_for(x.ty)))
      }
    }
    # Phase 3 unboxing — single-tail EBlock with no preceding
    # statements simply wraps a raw tail expression. Emit the
    # tail directly without the surrounding `({ ... })`.
    EBlock(stmts, opt_tail) -> match stmts {
      [] -> match opt_tail {
        Some(t) -> emit_expr_raw(src, t, cx)
        None -> {
          let boxed = emit_expr_boxed(src, x, cx)
          cat3("(", boxed, cat2(")", unbox_field_for(x.ty)))
        }
      }
      _ -> {
        let boxed = emit_expr_boxed(src, x, cx)
        cat3("(", boxed, cat2(")", unbox_field_for(x.ty)))
      }
    }
    _ -> {
      # Anything else: emit boxed and unwrap. The unbox_pass should
      # not have marked these MUnboxed in the first place — defensive.
      let boxed = emit_expr_boxed(src, x, cx)
      cat3("(", boxed, cat2(")", unbox_field_for(x.ty)))
    }
  }
}

# Phase 3 unboxing — when the callee `f` resolves to a UFn entry
# in the EFn table, emit the call against raw args without any
# `kai_<T>` wrap. Returns None when the callee is not a UFn. The
# caller (emit_kind_raw ECall arm) falls back to the boxed-then-
# unbox boundary form.

# Phase 3 unboxing — when the callee `f` resolves to a UFn entry
# in the EFn table, emit the call against raw args without any
# `kai_<T>` wrap. Returns None when the callee is not a UFn. The
# caller (emit_kind_raw ECall arm) falls back to the boxed-then-
# unbox boundary form.
fn emit_ufn_raw_call(src: String, f: Expr, args_e: [Expr], cx: EmitCtx) : Option[String] / Console {

  match f.kind {
    EVar(callee) ->
      if list_has(cx.lcs, callee) { None }
      else { match efn_resolve(cx.fns, callee) {
        Some(EFn(_, _, mo, Some(_))) -> {
          let raw_args = emit_call_args_raw(src, args_e, cx)
          Some(cat5("kai_", c_sym(callee, mo), "(", raw_args, ")"))
        }
        _ -> None
      } }
    EModCall(mod, fname) -> match lookup_ufn_sig(cx.fns, fname, Some(mod)) {
      Some(_) -> {
        let raw_args = emit_call_args_raw(src, args_e, cx)
        Some(cat5("kai_", c_sym(fname, Some(mod)), "(", raw_args, ")"))
      }
      None -> None
    }
    _ -> None
  }
}

fn emit_expr(src: String, x: Expr, cx: EmitCtx) : String / Console {

  match x.mode {
    MUnboxed -> {
      # MUnboxed → MBoxed boundary: emit raw and wrap.
      let raw = emit_expr_raw(src, x, cx)
      box_wrap(x.ty, raw)
    }
    _ -> emit_expr_boxed(src, x, cx)
  }
}

fn emit_expr_boxed(src: String, x: Expr, cx: EmitCtx) : String / Console {

  match x.kind {
    # Fix B (bidirectional list literals): when an Int literal is
    # checked against a Byte-context (e.g. inside `let bs: [Byte] = [65, 66]`),
    # the typer rewrites the node's ty to TyByte. Emit a Byte
    # constructor directly rather than `kai_int`. The 0..255 range
    # check has already happened at type-check time.
    EInt(n)      -> match x.ty {
      Some(TyByte) -> cat3("kai_byte((uint8_t)", int_to_string(n), ")")
      _            -> cat3("kai_int(", int_to_string(n), "LL)")
    }
    EReal(r)     -> cat3("kai_real(", real_to_string(r), ")")
    EBool(b)     -> if b { "kai_bool(1)" } else { "kai_bool(0)" }
    EChar(c)     -> cat3("kai_char(", int_to_string(char_to_int(c)), ")")
    EStr(span, is_triple) -> emit_string_expr(src, span, is_triple, cx)
    EUnit        -> "kai_unit()"
    EVar(name)   -> emit_ident_value(name, cx.lcs, cx.fns, cx.variants)
    EUnder       -> "kai_unit() /* _ */"
    EPlaceholder -> "kai_unit() /* placeholder */"
    ECall(f, args_e) -> emit_call_expr(src, f, args_e, cx)
    EField(base, fname) -> {
      # #293 Phase 1.2 — record field access RC discipline.
      # `base` is owned by the time it lands here: perceus_pass wraps
      # non-last reads of in-scope EVar in __perceus_dup, single-use
      # reads transfer their ref, and ctor/call expressions return
      # rc=1. `kai_op_field` increfs the field on read, so the base
      # is no longer reachable through the result. Drop it to balance.
      let b = emit_expr(src, base, cx)
      concat_all([
        "({ KaiValue *_b = ", b,
        "; KaiValue *_f = kai_op_field(_b, \"", fname, "\"); kai_decref(_b); _f; })"
      ])
    }
    EIndex(_, _) -> "kai_unit() /* index: not used by bootstrap examples */"
    EBinop(op, a, b) -> {
      if op == "and" {
        # m5.x flip Phase 3 closeout: `_a` is freshly allocated in
        # most call sites; under the runtime flip it would otherwise
        # leak — `kai_op_truthy` is non-consuming (the LLVM short-
        # circuit phi needs the value alive on the skip path) and
        # the C ternary returns either `<RHS>` or `kai_bool(0)`,
        # both fresh, so `_a` is never reused. Drop it via the
        # comma operator inside each branch.
        concat_all([
          "({ KaiValue *_a = ", emit_expr(src, a, cx),
          "; KaiValue *_r = kai_op_truthy(_a) ? ", emit_expr(src, b, cx),
          " : kai_bool(0); kai_decref(_a); _r; })"
        ])
      } else if op == "or" {
        concat_all([
          "({ KaiValue *_a = ", emit_expr(src, a, cx),
          "; KaiValue *_r = kai_op_truthy(_a) ? kai_bool(1) : ", emit_expr(src, b, cx), "; kai_decref(_a); _r; })"
        ])
      } else if op == "++" {
        # m7d §23: lower `a ++ b` to either `string_concat(a, b)` or
        # `list_append(a, b)` depending on the binop's typed result.
        # The typer pins `x.ty` to `String` or `[T]` before we get
        # here; an untyped `++` is a typer bug we surface as a panic
        # stub so it shows up in fixtures.
        let helper = concat_helper_of(x.ty)
        concat_all([
          helper, "(",
          emit_expr(src, a, cx), ", ",
          emit_expr(src, b, cx), ")"
        ])
      } else {
        match binop_cname(op) {
          Some(cn) -> concat_all([
            cn, "(",
            emit_expr(src, a, cx), ", ",
            emit_expr(src, b, cx), ")"
          ])
          None -> cat3("kai_unit() /* unknown binop: ", op, " */")
        }
      }
    }
    EUnop(op, inner) -> {
      match unop_cname(op) {
        Some(cn) -> concat_all([cn, "(", emit_expr(src, inner, cx), ")"])
        None -> cat3("kai_unit() /* unknown unop: ", op, " */")
      }
    }
    EIf(c, a, opt_b) -> {
      # Tier 2.5 M4 — if the condition is already raw bool, skip
      # the `kai_op_truthy` wrapper and use the C ternary directly.
      # Issue #82: when the cond is boxed, capture it in a local and
      # decref after the ternary. `kai_op_truthy` is non-consuming
      # (the LLVM short-circuit phi keeps lhs alive on the skip path,
      # so the runtime predicate cannot blindly consume), and the
      # branches return either the then- or else-arm fresh value —
      # never `_c` itself — so dropping `_c` after the ternary is
      # safe and balances the fresh allocation that fed it.
      match c.mode {
        MUnboxed -> {
          let cc = emit_expr_raw(src, c, cx)
          let tc = emit_expr(src, a, cx)
          let ec = match opt_b {
            Some(eb) -> emit_expr(src, eb, cx)
            None -> "kai_unit()"
          }
          concat_all(["(", cc, " ? ", tc, " : ", ec, ")"])
        }
        _ -> {
          let cb = emit_expr(src, c, cx)
          let tc = emit_expr(src, a, cx)
          let ec = match opt_b {
            Some(eb) -> emit_expr(src, eb, cx)
            None -> "kai_unit()"
          }
          concat_all([
            "({ KaiValue *_c = ", cb,
            "; KaiValue *_r = kai_op_truthy(_c) ? ", tc, " : ", ec,
            "; kai_decref(_c); _r; })"
          ])
        }
      }
    }
    EMatch(scr, arms) -> emit_match_expr(src, scr, arms, cx)
    ELambda(_, _) -> emit_lambda_ref(x, cx)
    ERecordLit(_, fields) -> emit_record_lit(src, fields, cx)
    EList(elems) -> emit_list_expr(src, elems, cx)
    ERange(a, b, opt_step) -> emit_range_expr(src, a, b, opt_step, cx)
    EBlock(stmts, opt_final) -> {
      # issue #120 (P1): a block recorded as a `region { }` lowers to a
      # bump-arena scope. `bcx` carries in_region = true so constructors
      # lexically inside the body bump-allocate into the arena; the
      # block's value is deep-copied OUT of the arena (rc=1) BEFORE the
      # arena is freed (copy-before-pop is load-bearing), so it survives.
      # A non-region block emits the ordinary statement-expression.
      let is_region = emit_block_is_region(cx, x.line, x.col)
      let bcx = if is_region { emit_ctx_with_in_region(cx, true) } else { cx }
      match stmts {
        [] -> match opt_final {
          Some(fe) ->
            if is_region {
              concat_all(["({ kai_arena_push(); KaiValue *__rout = kai_deep_copy_out(",
                          emit_expr(src, fe, bcx), "); kai_arena_pop(); __rout; })"])
            } else { emit_expr(src, fe, cx) }
          None ->
            if is_region { "({ kai_arena_push(); kai_arena_pop(); kai_unit(); })" }
            else { "kai_unit()" }
        }
        _ -> {
          # m5 #3 — drops for unused let-bindings whose RHS is a
          # fresh allocation. See `block_unused_lets`. The set is
          # computed once per block so each let-binding's drop
          # decision considers all subsequent stmts and the trailing
          # final expression.
          let drops = block_unused_lets(stmts, opt_final)
          # m14 v1.x — fold over stmts threading the local-name
          # scope: each `SLet(pat, _, _)` extends `lcs` with `pat`'s
          # binders so a later stmt or the final expression resolves
          # `EVar(name)` to the local read instead of a same-named
          # top-level fn.
          let stmt_acc = emit_block_stmts(src, stmts, drops, bcx)
          let stmt_out = match stmt_acc { EBSA(_, t) -> t }
          let block_lcs = match stmt_acc { EBSA(l, _) -> l }
          if is_region {
            let final_in = match opt_final {
              Some(fe) -> emit_expr(src, fe, emit_ctx_with_in_region(emit_ctx_with_lcs(cx, block_lcs), true))
              None -> "kai_unit()"
            }
            concat_all(["({ kai_arena_push(); ", stmt_out,
                        " KaiValue *__rout = kai_deep_copy_out(", final_in, ");",
                        " kai_arena_pop(); __rout; })"])
          } else {
            let final_out = match opt_final {
              Some(fe) -> cat2(emit_expr(src, fe, emit_ctx_with_lcs(cx, block_lcs)), "; ")
              None -> "kai_unit(); "
            }
            cat4("({ ", stmt_out, final_out, "})")
          }
        }
      }
    }
    EPipe(a, b) -> emit_pipe_expr(src, a, b, cx)
    # issue #201: `|` and `||` are rewritten by the typer (synth_map_pipe /
    # synth_flat_map_pipe) into a `<module>.<op>(lhs, f)` ECall before
    # codegen runs, so these arms are unreachable in practice. They exist
    # to keep the exhaustive match valid; a fall-through here is a typer
    # bug — emit a panic so the regression is loud at runtime.
    EMapPipe(_, _)     -> "kai_prelude_panic(kai_str(\"unreachable: EMapPipe survived typer\"))"
    EFlatMapPipe(_, _) -> "kai_prelude_panic(kai_str(\"unreachable: EFlatMapPipe survived typer\"))"
    EFilterPipe(_, _)  -> "kai_prelude_panic(kai_str(\"unreachable: EFilterPipe survived typer\"))"
    EHole(nm_opt) -> {
      # Unfilled holes are runtime-panicky but syntactically valid:
      # the checker reports them and emission leaves a panic stub,
      # so a binary with holes is runnable — it just aborts loudly
      # on first reach.
      #
      # The panic message bundles location + inferred type + label
      # so the user (or an LLM driving the codebase) sees *what*
      # they have to fill in, not just "?":
      #
      #   unfilled hole: ?name at line 12 col 34, expected (Int) -> String
      #
      # When the hole is anonymous, we omit the `?<name>` segment.
      # When the typer never pinned a type (rare), we omit the type
      # segment. Location is always available because EHole carries
      # the parser-recorded line/col. The message stays ASCII so it
      # rides safely through the C `"..."` literal we emit below
      # (kaikai has no C-string escaper today).
      let label = match nm_opt { Some(nm) -> cat2("?", nm)  None -> "?" }
      let ty_seg = match x.ty {
        None    -> ""
        Some(t) -> cat2(", expected ", ty_to_string(t))
      }
      let loc = concat_all([" at line ", int_to_string(x.line), " col ", int_to_string(x.col)])
      let msg = concat_all(["unfilled hole: ", label, loc, ty_seg])
      concat_all(["kai_prelude_panic(kai_str(\"", msg, "\"))"])
    }
    ETodo(msg) -> {
      # m7d §1: `todo!(msg)` lowers to the same panic path as a hole
      # but with the user-supplied message, prefixed `todo: ` so the
      # binary's abort tag matches the source-form intent.
      let full = cat2("todo: ", msg)
      concat_all(["kai_prelude_panic(kai_str(\"", full, "\"))"])
    }
    EBang(inner) -> emit_bang(src, inner, cx)
    EHandle(body, eff_name, _eff_tyargs, init_opt, alias_opt, clauses, ret_opt) ->
      emit_handle(src, body, eff_name, init_opt, alias_opt, clauses, ret_opt, x.line, x.col, cx)
    # m12.5: codegen erasure — `1.0<USD>` emits the same C as `1.0`.
    # Units are typer-only; the generated value carries no unit tag.
    ELitUnit(inner, _) -> emit_expr(src, inner, cx)
    # m7e §11: `variants[T]()`. The typer baked the resolved variant
    # names into the AST node (synth_variants_of); here we materialise
    # them as a kai_cons spine of nullary constructors. Each variant
    # was validated as nullary at typing time, so emit_variant_call
    # with arity 0 / empty arg array is correct.
    EVariantsOf(_, names) -> emit_variants_of_list(names, cx.variants)
    # m6.2 Phase 3 / v2: qualified call as an expression value
    # (callee of an ECall is handled in emit_call_expr; this branch
    # covers `let f = list.map`-style first-class references). Mint
    # the prefixed thunk symbol directly from the EModCall payload.
    # `emit_ident_value(fname, ...)` would lose the qualified context
    # and pick the wrong entry in the ambiguous-name case.
    # Issue #644 — Plan B: when the qualified name is actually a
    # variant ctor, emit the variant value directly (nullary only;
    # non-nullary as a value is not supported, mirroring the EVar
    # value-position constraint).
    EModCall(mod, fname) -> match evar_find(cx.variants, fname) {
      Some(ar) -> if ar == 0 {
        emit_variant_call(fname, 0, "", cx)
      } else {
        cat3("kai_unit() /* non-nullary ctor as value not supported: ", string_concat(mod, string_concat(".", fname)), " */")
      }
      None -> match efn_resolve(cx.fns, fname) {
        Some(EFn(_, ar, _, _)) ->
          cat5("kai_closure(&_kai_", c_sym(fname, Some(mod)), "_thunk, ", int_to_string(ar), ", 0, NULL)")
        None -> cat2("kai_", fname)
      }
    }
    # Issue #556: intrinsic calls in value position should never reach
    # emit_expr_boxed — the typer rejects them outside the clause-body
    # context where Stage 4 codegen recognises them and emits a bridge.
    # If we get here, that constraint was violated upstream.
    EIntrinsic(name, _) -> cat3("kai_unit() /* unreachable: intrinsic $", name, " in value position */")
  }
}

# m7e §11: emit a `[V0, V1, ..., Vn]` C list of nullary variant
# constructors. Mirrors emit_list_tail's cons-spine shape; uses the
# same kai_variant signature emit_ident_value uses for a bare
# nullary constructor reference.

# m7e §11: emit a `[V0, V1, ..., Vn]` C list of nullary variant
# constructors. Mirrors emit_list_tail's cons-spine shape; uses the
# same kai_variant signature emit_ident_value uses for a bare
# nullary constructor reference.
fn emit_variants_of_list(names: [String], variants: [EVar]) : String {
  match names {
    [] -> "kai_nil()"
    [n, ...rest] -> concat_all([
      "kai_cons(kai_variant_u(", int_to_string(evar_find_tag(variants, n)),
      ", \"", n, "\", 0, 0, NULL), ",
      emit_variants_of_list(rest, variants), ")"
    ])
  }
}

# m7e §13 — lower `expr!` to a statement-expression that evaluates
# `inner`, returns the success payload, or short-circuits the
# enclosing C function with an early `return`. The discriminator
# (`Some` vs `Ok`) is chosen from `inner.ty`, which the typer
# stamped to `Option[_]` or `Result[_, _]` after substitution. Any
# other shape here is a typer bug — we fall back to a panic stub
# rather than emit silently-wrong C.

# m7e §13 — lower `expr!` to a statement-expression that evaluates
# `inner`, returns the success payload, or short-circuits the
# enclosing C function with an early `return`. The discriminator
# (`Some` vs `Ok`) is chosen from `inner.ty`, which the typer
# stamped to `Option[_]` or `Result[_, _]` after substitution. Any
# other shape here is a typer bug — we fall back to a panic stub
# rather than emit silently-wrong C.
fn emit_bang(src: String, inner: Expr, cx: EmitCtx) : String / Console {

  let inner_c = emit_expr(src, inner, cx)
  let success = bang_success_variant(inner.ty)
  match success {
    Some(name) -> concat_all([
      "({ KaiValue *_b = ", inner_c, "; ",
      "if (!(_b && ", emit_variant_tag_test("_b", name, cx.variants), ")) return _b; ",
      "_b->as.var.slots[0].ptr; })"
    ])
    None -> concat_all([
      "kai_prelude_panic(kai_str(\"internal: `!` on non-Option/Result reached emitter\"))"
    ])
  }
}

fn emit_handle(src: String, body: Expr, eff_name: String, init_opt: Option[Expr],
               alias_opt: Option[String],
               clauses: [HClause],
               ret_opt: Option[HReturn], hline: Int, hcol: Int,
               cx: EmitCtx) : String / Console {

  let body_c = emit_expr(src, body, cx)
  let assigns = emit_clause_assignments(eff_name, clauses, hline, hcol, cx.cls)
  # R9: gather every name any clause body of this handle captures
  # from the surrounding scope. Filtered against `lcs` so a name that
  # is *not* in scope at the install site (e.g. a top-level fn that
  # `fv_expr` already excluded via `globals` — defensive) does not
  # produce an undefined assign.
  let env_caps = list_filter_in(handle_captures_at(cx.cls, hline, hcol), cx.lcs)
  let env_enc_fn = handle_enc_fn_at(cx.cls, hline, hcol)
  let env_alloc = emit_handle_env_alloc(env_caps, env_enc_fn, hline, hcol)
  let env_assign = emit_handle_env_ev_assign(env_caps)
  # m7b #15 (compiler integration): expose the handle's
  # `handler_id` as a local C variable named `kai_alias_<a>_id`
  # whenever the handle declared an `as`-bound capability. The
  # op-call dispatch (emit_call_expr) emits a
  # `kai_evidence_lookup_node_by_id(kai_alias_<a>_id)` call
  # whenever the alias rewrite tagged the op name with
  # `@<a>`. The local lives in the same statement-expression
  # as the rest of the handle prologue, so it is in scope for
  # every op-call site inside `body_c`.
  let alias_id_c = match alias_opt {
    Some(a) -> concat_all([
      "KaiHandlerId kai_alias_", a, "_id = _ev.handler_id; "
    ])
    None -> ""
  }
  let init_c = match init_opt {
    Some(ie) -> concat_all(["_ev.state = ", emit_expr(src, ie, cx), "; "])
    None     -> ""
  }
  let ret_c = match ret_opt {
    Some(r) -> match r {
      HR(pname, rexpr, _, _) -> {
        # m7b #11: when the handler is stateful, the return clause
        # also sees `state` / `log` (so `return(x) -> (x, state)` works).
        let stateful = match init_opt { Some(_) -> true None -> false }
        let prologue = if stateful {
          # _node is a KaiEvidence; its `handler` field is `&_ev`.
          "KaiValue *kai_state = _ev.state; KaiValue *kai_log = _ev.state; "
        } else { "" }
        concat_all([
          "KaiValue *kai_", pname, " = _body_result; ",
          prologue,
          emit_expr(src, rexpr, cx), ";"
        ])
      }
    }
    None -> "_body_result;"
  }
  # m7a #6e: handle owns a jmp_buf and a discard-value slot. If a
  # clause discards `resume`, the op-call site pops the evidence
  # and longjmps here; the setjmp-else branch picks the discarded
  # value as `_body_result` and the return clause runs as usual.
  # Push uses the *_with_jmp variant so the op site can find the
  # jmp via the looked-up KaiEvidence node.
  # issue #501: `_discard` is volatile-qualified because it is a local
  # automatic written between `setjmp` and `longjmp` (the op-call
  # discard branch stores the clause's return value into
  # `*_node->discard_slot`, which aliases `&_discard`). Per C99
  # §7.13.2.1 such a local has indeterminate value after `longjmp`
  # unless it has volatile-qualified type — under `-O2` the else
  # branch otherwise reads a stale NULL and the consumer segfaults.
  concat_all([
    "({ Ev", eff_name, " _ev = {0}; ",
    "_ev.handler_id = kai_fresh_handler_id(); ",
    assigns,
    init_c,
    env_alloc,
    env_assign,
    "KaiEvidence _node; ",
    "jmp_buf _jmp; ",
    "KaiValue * volatile _discard = NULL; ",
    "KaiValue *_body_result; ",
    alias_id_c,
    "if (setjmp(_jmp) == 0) { ",
      "kai_evidence_push_with_jmp(&_node, \"", eff_name, "\", &_ev, &_jmp, (KaiValue **) &_discard); ",
      "_body_result = ", body_c, "; ",
      "kai_evidence_pop(); ",
    "} else { ",
      "_body_result = _discard; ",
    "} ",
    ret_c,
    " })"
  ])
}

# R9: keep only the names that are actually in scope at the install
# site. `handle_captures_at` returns the union of every clause's
# `fv_expr` result; `lcs` is the list of locals visible to
# `emit_handle`. The install code reads each capture as a local
# `kai_<name>` to populate the env struct, so a name not in `lcs`
# would expand to an undeclared identifier.

# R9: keep only the names that are actually in scope at the install
# site. `handle_captures_at` returns the union of every clause's
# `fv_expr` result; `lcs` is the list of locals visible to
# `emit_handle`. The install code reads each capture as a local
# `kai_<name>` to populate the env struct, so a name not in `lcs`
# would expand to an undeclared identifier.
fn list_filter_in(names: [String], lcs: [String]) : [String] {
  match names {
    [] -> []
    [h, ...rest] ->
      if list_has(lcs, h) { [h, ...list_filter_in(rest, lcs)] }
      else { list_filter_in(rest, lcs) }
  }
}

# R9 install side: allocate one env struct per handle (zero-init,
# stack-allocated inside the handle's stmt-expression), populate one
# field per capture, and stash a `void *` pointer in `_ev.env`. Empty
# when the handle has no captures — the EvE's `env` slot stays NULL
# and clause prologues never read it. The emitted env-struct typedef
# is minted once per (line, col) pair by `emit_handle_env_typedefs`
# at top level, and lives ahead of every clause forward in the
# generated C.

# R9 install side: allocate one env struct per handle (zero-init,
# stack-allocated inside the handle's stmt-expression), populate one
# field per capture, and stash a `void *` pointer in `_ev.env`. Empty
# when the handle has no captures — the EvE's `env` slot stays NULL
# and clause prologues never read it. The emitted env-struct typedef
# is minted once per (line, col) pair by `emit_handle_env_typedefs`
# at top level, and lives ahead of every clause forward in the
# generated C.
fn emit_handle_env_alloc(caps: [String], enc_fn: String,
                          hline: Int, hcol: Int) : String {
  match caps {
    [] -> ""
    _ -> {
      let env_name = handle_env_struct_name(enc_fn, hline, hcol)
      concat_all([
        env_name, " _env = {0}; ",
        emit_handle_env_field_assigns(caps)
      ])
    }
  }
}

fn emit_handle_env_field_assigns(caps: [String]) : String {
  match caps {
    [] -> ""
    [c, ...rest] -> concat_all([
      "_env.kai_", c, " = kai_", c, "; ",
      emit_handle_env_field_assigns(rest)
    ])
  }
}

fn emit_handle_env_ev_assign(caps: [String]) : String {
  match caps {
    [] -> ""
    _  -> "_ev.env = (void *) &_env; "
  }
}

# m4c #4: install code mints `_ev.<op> = &<clause_sym>;` where
# `<clause_sym>` must match the C function emitted for the clause
# body. Both ends now mint via `clause_fn_name(enc_fn, ...)`. The
# enc_fn lives in the matching `ClauseInfo` (stamped at collect time
# — see `lc_record_clauses`); we look it up by (hline, hcol, op_name).
# The lookup returns "" when the matching CI is missing, which is a
# defensive fallback — collect always records one CI per HClause.

# m4c #4: install code mints `_ev.<op> = &<clause_sym>;` where
# `<clause_sym>` must match the C function emitted for the clause
# body. Both ends now mint via `clause_fn_name(enc_fn, ...)`. The
# enc_fn lives in the matching `ClauseInfo` (stamped at collect time
# — see `lc_record_clauses`); we look it up by (hline, hcol, op_name).
# The lookup returns "" when the matching CI is missing, which is a
# defensive fallback — collect always records one CI per HClause.
fn emit_clause_assignments(eff_name: String, cs: [HClause],
                           hline: Int, hcol: Int,
                           cls: [ClauseInfo]) : String {
  match cs {
    [] -> ""
    [c, ...rest] -> match c {
      HC(op_name, _, _, _, _) -> {
        let enc_fn = lookup_clause_enc_fn(cls, hline, hcol, op_name)
        concat_all([
          "_ev.", op_name, " = &", clause_fn_name(enc_fn, hline, hcol, op_name), "; ",
          emit_clause_assignments(eff_name, rest, hline, hcol, cls)
        ])
      }
    }
  }
}

fn expr_is_perceus_drop_call(x: Expr) : Bool {
  match x.kind {
    ECall(callee, _) -> match callee.kind {
      EVar(nm) -> nm == "__perceus_drop"
      _ -> false
    }
    _ -> false
  }
}

fn emit_stmt(src: String, s: Stmt, cx: EmitCtx) : String / Console {

  match s {
    SLet(pat, _, rhs) -> emit_let_stmt(src, pat, rhs, cx)
    SAssert(cond, opt_msg) -> emit_assert_stmt(src, cond, opt_msg, cx)
    # Issue #403: when the SExprStmt is `__perceus_drop(name)`,
    # `kai_internal_drop` already decrements the value's rc and
    # returns the unit singleton (rc == INT32_MAX). The general
    # path's trailing `kai_decref(_)` short-circuits on that
    # singleton, but the call + branch still cost on every
    # invocation — and the issue-#350 arm-drop pass emits ~18 M
    # of these on the RB-tree workload. Mirrors the `(void) _;`
    # pattern the tcrec rule-3 emission already uses.
    SExprStmt(x) ->
      if expr_is_perceus_drop_call(x) {
        cat3("{ KaiValue *_ = ", emit_expr(src, x, cx), "; (void) _; } ")
      } else {
        cat3("{ KaiValue *_ = ", emit_expr(src, x, cx), "; kai_decref(_); } ")
      }
    # m7b #6: index-assign desugars away pre-resolve; this arm is dead
    # code in normal compilation but keeps the match exhaustive.
    SIndexAssign(_, _, _, _, _) -> "/* SIndexAssign: should have been desugared */ "
    # m7b #5: `var name = init` desugars away pre-resolve; this arm
    # is dead code in normal compilation but keeps the match exhaustive.
    SVar(_, _, _, _, _) -> "/* SVar: should have been desugared */ "
    # m7e §25: `use Effect` stmt desugars away pre-resolve. Dead code
    # in normal compilation; emit a comment for debug visibility.
    SUse(_, _, _) -> "/* SUse: should have been desugared */ "
  }
}

# m14 v1.x — fold over a block's stmts threading the local-name
# scope. After each `SLet(pat, _, _)`, the pattern's binders are
# appended to `lcs` so subsequent stmts (and the trailing final
# expression) see them as locals. Other stmt forms (`SAssert`,
# `SExprStmt`, dead `SVar` / `SUse` / `SIndexAssign`) are scope-
# neutral. The accumulated `lcs` is returned alongside the
# concatenated C output so the caller can pass it to the final
# expression.

# m14 v1.x — fold over a block's stmts threading the local-name
# scope. After each `SLet(pat, _, _)`, the pattern's binders are
# appended to `lcs` so subsequent stmts (and the trailing final
# expression) see them as locals. Other stmt forms (`SAssert`,
# `SExprStmt`, dead `SVar` / `SUse` / `SIndexAssign`) are scope-
# neutral. The accumulated `lcs` is returned alongside the
# concatenated C output so the caller can pass it to the final
# expression.
type EmitBlockStmtsAcc = EBSA([String], String)

fn emit_block_stmts(src: String, stmts: [Stmt], drops: [String],
                    cx: EmitCtx) : EmitBlockStmtsAcc / Console =
  emit_block_stmts_loop(src, stmts, drops, cx, "")

fn emit_block_stmts_loop(src: String, stmts: [Stmt], drops: [String],
                          cx: EmitCtx,
                          acc: String) : EmitBlockStmtsAcc / Console = match stmts {

  [] -> EBSA(cx.lcs, acc)
  [s, ...rest] -> {
    let out = emit_stmt_with_drops(src, s, drops, cx)
    let lcs1 = match s {
      SLet(pat, _, _) -> list_append(cx.lcs, pat_binders(pat, []))
      _ -> cx.lcs
    }
    emit_block_stmts_loop(src, rest, drops, emit_ctx_with_lcs(cx, lcs1),
                          string_concat(acc, out))
  }
}

# m5 #3 — emit_stmt variant that consults the per-block drop set.
# Only `SLet` is augmented; the other stmt forms route through the
# original `emit_stmt` path. The set is the result of
# `block_unused_lets`, so a name only appears here when it is safe
# to decref immediately after the let.

# m5 #3 — emit_stmt variant that consults the per-block drop set.
# Only `SLet` is augmented; the other stmt forms route through the
# original `emit_stmt` path. The set is the result of
# `block_unused_lets`, so a name only appears here when it is safe
# to decref immediately after the let.
fn emit_stmt_with_drops(src: String, s: Stmt, drops: [String],
                        cx: EmitCtx) : String / Console {

  match s {
    SLet(pat, _, rhs) ->
      emit_let_stmt_with_drops(src, pat, rhs, drops, cx)
    _ -> emit_stmt(src, s, cx)
  }
}

fn emit_let_stmt_with_drops(src: String, pat: Pattern, rhs: Expr,
                             drops: [String],
                             cx: EmitCtx) : String / Console {

  match pat.pkind {
    # Tier 2.5 — raw scalar binding. The unbox pass marked the
    # rhs `MUnboxed`, which means this binding is stored as a raw
    # C scalar (no `KaiValue *`). RC bookkeeping does not apply
    # — the local lives on the C stack and dies at block exit.
    PBind(name) -> match rhs.mode {
      MUnboxed -> {
        let raw = emit_expr_raw(src, rhs, cx)
        let cty = raw_c_type(rhs.ty)
        concat_all([cty, " kair_", name, " = ", raw, "; "])
      }
      _ -> {
        let rhs_c = emit_expr(src, rhs, cx)
        let bind = concat_all(["KaiValue *kai_", name, " = ", rhs_c, "; "])
        if list_has(drops, name) {
          cat2(bind, concat_all(["kai_decref(kai_", name, "); "]))
        } else {
          bind
        }
      }
    }
    # `let _ = expr` discards the value. #293 Phase 2.1: emit_expr
    # always returns an owned reference (perceus_pass dups non-last
    # reads), so the discard site can unconditionally decref.
    PWild -> {
      let rhs_c = emit_expr(src, rhs, cx)
      cat3("{ KaiValue *_w = ", rhs_c, "; kai_decref(_w); } ")
    }
    _ -> {
      # m7d §28: same shape as emit_let_stmt's destructuring path —
      # bind a unique temp and emit pattern binds INTO the enclosing
      # block so the destructured names stay in scope for the rest
      # of the block. Drops do not apply to destructured names; the
      # `drops` argument here is for PBind only.
      # #293 Phase 1.3: same RC discipline as the no-drops path —
      # alias=true so each binder increfs, then drop the composite.
      let rhs_c = emit_expr(src, rhs, cx)
      let tmp = concat_all(["_letv_", int_to_string(pat.line), "_",
                              int_to_string(pat.col)])
      let binds = emit_pat_binds(src, pat, tmp, true, cx)
      concat_all(["KaiValue *", tmp, " = ", rhs_c, "; ", binds, "kai_decref(", tmp, "); "])
    }
  }
}

fn emit_let_stmt(src: String, pat: Pattern, rhs: Expr, cx: EmitCtx) : String / Console {

  match pat.pkind {
    PBind(name) -> match rhs.mode {
      MUnboxed -> {
        let raw = emit_expr_raw(src, rhs, cx)
        let cty = raw_c_type(rhs.ty)
        concat_all([cty, " kair_", name, " = ", raw, "; "])
      }
      _ -> {
        let rhs_c = emit_expr(src, rhs, cx)
        concat_all(["KaiValue *kai_", name, " = ", rhs_c, "; "])
      }
    }
    PWild -> {
      let rhs_c = emit_expr(src, rhs, cx)
      cat3("{ KaiValue *_w = ", rhs_c, "; kai_decref(_w); } ")
    }
    _ -> {
      # m7d §28: destructuring let. Bind a unique temp and emit the
      # pattern's binds INTO THE ENCLOSING BLOCK (no `{...}`
      # wrapping) so the destructured names stay in scope for the
      # rest of the block. The temp name carries the source location
      # to avoid shadowing across nested let-destructurings.
      let rhs_c = emit_expr(src, rhs, cx)
      let tmp = concat_all(["_letv_", int_to_string(pat.line), "_",
                              int_to_string(pat.col)])
      # #293 Phase 1.3 — destructuring let RC discipline. Treat children
      # as alias storage (is_alias=true) so each PBind increfs, then
      # drop `tmp` so the composite alloc balances. Field-typed children
      # already incref via `kai_op_field`; the alias flip only changes
      # cons.head/tail and var.args[i] sites which previously aliased
      # without bumping the rc. The `kai_decref(tmp)` at the end of the
      # binds releases the ownership transferred from the RHS.
      let binds = emit_pat_binds(src, pat, tmp, true, cx)
      concat_all(["KaiValue *", tmp, " = ", rhs_c, "; ", binds, "kai_decref(", tmp, "); "])
    }
  }
}

fn emit_assert_stmt(src: String, cond: Expr, opt_msg: Option[Expr],
                    cx: EmitCtx) : String / Console {

  # kai_assert_check consults kai_test_in_progress at runtime and either
  # aborts (outside a test) or longjmps to the test harness (inside one),
  # so the emitter doesn't need to know whether it's in test mode.
  # m12.6.x #8: when opt_msg is a literal string (e.g. the contract-
  # desugar's "requires violated at line N"), embed its span as a C
  # literal so the panic shows the contract context instead of the
  # generic "assertion failed". Non-literal msgs fall back to the
  # generic — runtime evaluation of an arbitrary Expr to a C string
  # would need a kai_to_cstring helper that doesn't exist.
  # cond is emitted EXACTLY once; `cc` is reused for both the plain and
  # the value-carrying call. Never re-emit a sub-expression (a second
  # emit_expr would double-evaluate side effects and double-decref under
  # Perceus).
  let cc = emit_expr(src, cond, cx)
  let msg_lit = match opt_msg {
    Some(m) -> match m.kind {
      EStr(span, false) -> span
      _ -> "\"assertion failed\""
    }
    None -> "\"assertion failed\""
  }
  # Issue #86 (piece 2): when this is a `requires` contract violation
  # whose predicate has the simple `<ident> <cmp> <literal>` shape, append
  # the offending binding's runtime value. Restricted to `requires` (not
  # `ensures`): a requires-assert runs before the body consumes any
  # param, so the binding's local is guaranteed live; an ensures-assert
  # runs after `let result = body`, where the referenced param may have
  # already been consumed (its local freed), so referencing it would be a
  # use-after-free. The ensures case keeps the value-less form (piece 1
  # context only) — documented as a follow-up.
  match opt_msg {
    Some(m) -> match m.kind {
      EStr(span, false) ->
        if assert_span_is_requires(span) {
          match contract_single_ident_node(cond) {
            Some(ci) -> match ci {
              CtrId(ident, idnode, lit) -> {
                let valarg = emit_contract_value_arg(ident, idnode, lit)
                let idlit = concat_all(["\"", escape_str_body_for_c(ident), "\""])
                # Capture the value arg into a temp that is evaluated
                # BEFORE the condition. The condition consumes the
                # offending binding's local (the comparison helpers
                # `kai_op_*_v` decref both operands), so a `kai_incref`
                # of that same local must run first — otherwise C's
                # unspecified argument-evaluation order can incref a
                # freed object (boxed repr) → crash. The statement-
                # expression pins the order: `_av` first, then `cc`.
                concat_all(["({ KaiValue *_av = ", valarg, "; ",
                            "kai_assert_check_with_value(", cc, ", ", span,
                            ", ", idlit, ", _av); }); "])
              }
            }
            None -> concat_all(["kai_assert_check(", cc, ", ", msg_lit, "); "])
          }
        } else { concat_all(["kai_assert_check(", cc, ", ", msg_lit, "); "]) }
      _ -> concat_all(["kai_assert_check(", cc, ", ", msg_lit, "); "])
    }
    None -> concat_all(["kai_assert_check(", cc, ", ", msg_lit, "); "])
  }
}

# Issue #86 (piece 2): build the owned `KaiValue*` value argument for
# `kai_assert_check_with_value`. The helper CONSUMES `val`, so:
#   - boxed local  → `kai_incref(kai_<ident>)` transfers a fresh ref the
#     helper consumes, leaving the local's own ref (and any Perceus drop)
#     untouched.
#   - raw-unboxed local → `box_wrap` mints a fresh `kai_real`/`kai_int`
#     box from the raw scalar `kair_<ident>`.
# The *repr* (which local name exists) comes from the ident node's own
# `mode` — the exact value `emit_expr` consults for this same node, so
# the two agree on `kair_` vs `kai_`. The literal's `ty` is the box-type
# oracle for the raw case (a dup-wrapped ident node's `ty` may be blank,
# the literal's never is). A boxed local in a raw comparison (e.g. a
# `Char` param compared via a raw `!=`) still reads from `kai_<ident>`
# because the binding's storage is boxed regardless of the comparison's
# lowering.
fn emit_contract_value_arg(ident: String, idnode: Expr, lit: Expr) : String {
  match idnode.mode {
    MUnboxed -> box_wrap(lit.ty, cat2("kair_", ident))
    _        -> cat3("kai_incref(kai_", ident, ")")
  }
}

# ---- declaration emission ----

# m7a #6a: emit the `Ev<Eff>` struct per `effect Eff { ops }` decl,
# per docs/effects-impl.md §*Surface-to-runtime mapping*. Each op
# becomes a plain function-pointer field with `*Self` as the implicit
# first argument, the surface op args next, and a trailing `KaiCont
# *k` (the reified continuation). m7a #6a only emits the type; m7a
# #6b populates an EvE at handle entry, m7a #6c calls through it.

# m7a #6a: emit the `Ev<Eff>` struct per `effect Eff { ops }` decl,
# per docs/effects-impl.md §*Surface-to-runtime mapping*. Each op
# becomes a plain function-pointer field with `*Self` as the implicit
# first argument, the surface op args next, and a trailing `KaiCont
# *k` (the reified continuation). m7a #6a only emits the type; m7a
# #6b populates an EvE at handle entry, m7a #6c calls through it.
fn emit_op_fn_ptr_args(params: [Param]) : String {
  match params {
    [] -> ""
    _  -> cat2(", ", join_with(map(params, (pm) => cat2("KaiValue *kai_", pm.pname)), ", "))
  }
}

fn emit_op_fn_ptr(eff_name: String, op: EffectOp) : String {
  match op {
    EOp(op_name, _, params, _, _, _) ->
      concat_all([
        "    KaiValue *(*", op_name, ")(Ev", eff_name, " *self",
        emit_op_fn_ptr_args(params),
        ", KaiCont *k);\n"
      ])
  }
}

fn emit_effect_struct(d: Decl) : String {
  match d {
    DEffect(_, name, _tparams, ops, _, _, _) -> {
      let fields = concat_all(map(ops, (op) => emit_op_fn_ptr(name, op)))
      concat_all([
        "typedef struct Ev", name, " Ev", name, ";\n",
        "struct Ev", name, " {\n",
        "    KaiHandlerId handler_id;\n",
        "    void *env;\n",
        # m7b #11: every Ev struct carries a `state` slot for parameter-
        # ised handlers (`with State[T](init)` / `with Writer[W]([])`).
        # Stateless handlers leave it NULL — cost is one pointer per
        # handler instance; benefit is a uniform clause-body shape.
        "    KaiValue *state;\n",
        fields,
        "};\n\n"
      ])
    }
    _ -> ""
  }
}

fn effect_struct_decls(decls: [Decl]) : String =
  concat_all(map(decls, emit_effect_struct))

# m7c-a — LLVM equivalent of `emit_effect_struct`. Emits an
# `%EvX = type { i64, i8*, %KaiValue*, fn-ptrs... }` where the
# leading three fields mirror the C layout (handler_id, env,
# state slot) and each op contributes one function pointer.
# Doc C §m7c assumes the LLVM backend uses the same on-the-heap
# layout as the C backend so the runtime helpers can see both
# without translation.

# m7c-a — LLVM equivalent of `emit_effect_struct`. Emits an
# `%EvX = type { i64, i8*, %KaiValue*, fn-ptrs... }` where the
# leading three fields mirror the C layout (handler_id, env,
# state slot) and each op contributes one function pointer.
# Doc C §m7c assumes the LLVM backend uses the same on-the-heap
# layout as the C backend so the runtime helpers can see both
# without translation.
fn emit_param_list(params: [Param]) : String {
  match params {
    [] -> "void"
    _ -> join_with(map(params, (pm) => cat2("KaiValue *kai_", pm.pname)), ", ")
  }
}

# Phase 3 unboxing — emit the raw parameter list for a UFn.
# Each parameter is a raw C scalar named `kair_<pname>`; the
# emitter's MUnboxed EVar reads of `pname` resolve via
# `emit_ident_value` to that name.

# Phase 3 unboxing — emit the raw parameter list for a UFn.
# Each parameter is a raw C scalar named `kair_<pname>`; the
# emitter's MUnboxed EVar reads of `pname` resolve via
# `emit_ident_value` to that name.
fn emit_param_list_unboxed(params: [Param], param_tys: [Ty]) : String {
  match params {
    [] -> "void"
    _ -> join_with(emit_param_list_unboxed_each(params, param_tys, []), ", ")
  }
}

fn emit_param_list_unboxed_each(params: [Param], tys: [Ty], acc: [String]) : [String] {
  match params {
    [] -> list_reverse(acc)
    [p, ...rest] -> {
      let pty = match tys {
        [t, ...trest] -> t
        []            -> param_ty(p)
      }
      let trest = match tys {
        [_, ...r] -> r
        []        -> []
      }
      let entry = concat_all([raw_c_type(Some(pty)), " kair_", p.pname])
      emit_param_list_unboxed_each(rest, trest, [entry, ...acc])
    }
  }
}

fn emit_fn_signature(name: String, params: [Param]) : String =
  cat5("static KaiValue *kai_", name, "(", emit_param_list(params), ")")

# Phase 3 unboxing — raw signature for a UFn. Return type is the
# raw C scalar matching `ret_ty`; param list mints `kair_<name>`
# locals typed to each `param_ty`.

# Phase 3 unboxing — raw signature for a UFn. Return type is the
# raw C scalar matching `ret_ty`; param list mints `kair_<name>`
# locals typed to each `param_ty`.
fn emit_fn_signature_unboxed(name: String, params: [Param], sig: UFnSig) : String =
  match sig {
    US(pts, rt) -> concat_all([
      "static ", raw_c_type(Some(rt)),
      " kai_", name, "(", emit_param_list_unboxed(params, pts), ")"
    ])
  }

fn is_ufn_decl(fns: [EFn], name: String, mo: Option[String]) : Bool {
  match lookup_ufn_sig(fns, name, mo) {
    Some(_) -> true
    None    -> false
  }
}

# Phase 3 unboxing — find a UFn entry by its emitted C symbol
# (e.g. `numeric__real_pow_int_loop`). Iterates the EFn registry
# and compares `c_sym(name, mo)` against the target string.

# Phase 3 unboxing — find a UFn entry by its emitted C symbol
# (e.g. `numeric__real_pow_int_loop`). Iterates the EFn registry
# and compares `c_sym(name, mo)` against the target string.
fn lookup_ufn_by_csym(fns: [EFn], csym: String) : Option[UFnSig] {
  match fns {
    [] -> None
    [h, ...rest] -> match h {
      EFn(n, _, mo, Some(us)) ->
        if c_sym(n, mo) == csym { Some(us) }
        else { lookup_ufn_by_csym(rest, csym) }
      _ -> lookup_ufn_by_csym(rest, csym)
    }
  }
}

fn emit_fn_forward(d: Decl, fns: [EFn]) : String {
  match d {
    DFn(_, name, _, params, _, _, _, _, _, mo) -> {
      let sig = match lookup_ufn_sig(fns, name, mo) {
        Some(us) -> emit_fn_signature_unboxed(c_sym(name, mo), params, us)
        None     -> emit_fn_signature(c_sym(name, mo), params)
      }
      cat2(sig, ";\n")
    }
    _ -> ""
  }
}

fn emit_thunk_forward(d: Decl) : String {
  match d {
    DFn(_, name, _, _, _, _, _, _, _, mo) ->
      cat3("static KaiValue *_kai_", c_sym(name, mo), "_thunk(KaiValue *, KaiValue **, int);\n")
    _ -> ""
  }
}

fn emit_fn_body(src: String, d: Decl, cx: EmitCtx) : String / Console {

  match d {
    DFn(_, name, _, params, ret_ty_opt, _, body, _, _, mo) -> {
      let opt_sig = lookup_ufn_sig(cx.fns, name, mo)
      let sig = match opt_sig {
        Some(us) -> emit_fn_signature_unboxed(c_sym(name, mo), params, us)
        None     -> emit_fn_signature(c_sym(name, mo), params)
      }
      # m12.7.x FFI v1: a `[<extern_c>]` axiom lowered into a DFn
      # whose body is the magic ETodo tag. Emit the FFI shim instead
      # of the standard body — the shim unboxes each parameter to
      # the matching C scalar, calls the extern symbol, and re-boxes
      # the return value. The shim does its own `extern` forward decl
      # inline so callers don't need a separate header pass.
      if body_is_ffi_extern(body) {
        # Issue #261: the C-side symbol is either the override
        # baked into the body's tag or the kaikai identifier.
        emit_ffi_shim_body(sig, ffi_extern_symbol_of(body, name), params, ret_ty_opt)
      } else if body_is_proto_dispatch(body) {
        # Option C: runtime dispatch shim. Look up the matching
        # `__pimpl_*` in the impl-table and tail-call it. See
        # `make_dispatcher_body` and docs/protocols.md §Codegen sketch.
        emit_proto_dispatch_shim_c(sig, proto_dispatch_parts(body), params, ret_ty_opt)
      } else {
        # Seed the local-name scope with the fn's parameters so an
        # `EVar(pname)` reference inside the body emits the local C
        # variable read (`kai_<pname>`) rather than a closure-thunk
        # over a same-named top-level fn.
        let body_lcs = list_append(cx.lcs, fn_param_names(params))
        # Same-module preference: when this DFn lives in a module,
        # rotate the EFn table so entries from that same module come
        # first. `efn_resolve`'s ambiguous-fallback returns the first
        # match, so a recursive call inside `loop.repeat` resolves
        # to `loop.repeat` even when `list.repeat` is also in scope.
        let body_fns = fns_prefer_module(cx.fns, mo)
        # Body sees the extended lexical scope and the module-rotated
        # EFn table; the other three context fields are unchanged.
        let body_cx = EmitCtx { lcs: body_lcs, fns: body_fns, variants: cx.variants, lams: cx.lams, cls: cx.cls,
                                regions: cx.regions, in_region: cx.in_region }
        # Phase 3 unboxing — UFn body emits a raw return expression
        # whose value is the raw scalar matching `ret_ty`. The
        # body's `mode` is set by `unbox_pass`/`ufn_promote_calls`;
        # `emit_expr_raw` handles the MBoxed→raw boundary if the
        # body somehow stayed boxed (defensive for partial
        # promotions). The TCO sentinel goto path stays compatible:
        # `tcrec_emit_goto` writes `goto _kai_<sym>_entry;` which
        # ignores the surrounding return-expression shape.
        match opt_sig {
          Some(_) -> {
            let body_c = emit_expr_raw(src, body, body_cx)
            let label = if tcrec_body_has_sentinel(body) {
              concat_all(["_kai_", c_sym(name, mo), "_entry:;\n    "])
            } else { "" }
            concat_all([sig, " {\n    ", label, "return ", body_c, ";\n}\n\n"])
          }
          None -> {
            let body_c = emit_expr(src, body, body_cx)
            # Issue #37: when `tcrec_rewrite_decl` planted at least one
            # `__kai_tcrec|...` self-tail-call sentinel inside `body`,
            # plant the matching `_kai_<c_sym>_entry:;` label *before*
            # the `return ({ ... });` so the goto inside the
            # statement-expression has a target.
            let label = if tcrec_body_has_sentinel(body) {
              concat_all(["_kai_", c_sym(name, mo), "_entry:;\n    "])
            } else { "" }
            concat_all([sig, " {\n    ", label, "return ", body_c, ";\n}\n\n"])
          }
        }
      }
    }
    _ -> ""
  }
}

# m12.7.x FFI v1: the C body of an `[<extern_c>]` axiom. The shim
# - forward-declares the extern symbol with the matching C signature,
# - unboxes each kaikai parameter into its C-side equivalent,
# - calls the extern, releases the input args, and
# - boxes the return value back into a `KaiValue *` (or `kai_unit()`
#   for a `void`-returning extern).
#
# Type translation v1 (per `docs/m12.7-ffi.md` §*Type table*):
#   Int    ↔ int64_t        Real   ↔ double
#   Bool   ↔ int             String ↔ const char *
#   Unit   ↔ void   (return only)
# Anything else surfaces as an `#error` so the C compiler flags it
# at build time — silently emitting a wrong shim would be worse than
# refusing the cast.

# m12.7.x FFI v1: the C body of an `[<extern_c>]` axiom. The shim
# - forward-declares the extern symbol with the matching C signature,
# - unboxes each kaikai parameter into its C-side equivalent,
# - calls the extern, releases the input args, and
# - boxes the return value back into a `KaiValue *` (or `kai_unit()`
#   for a `void`-returning extern).
#
# Type translation v1 (per `docs/m12.7-ffi.md` §*Type table*):
#   Int    ↔ int64_t        Real   ↔ double
#   Bool   ↔ int             String ↔ const char *
#   Unit   ↔ void   (return only)
# Anything else surfaces as an `#error` so the C compiler flags it
# at build time — silently emitting a wrong shim would be worse than
# refusing the cast.
fn emit_ffi_shim_body(sig: String, name: String, params: [Param],
                      ret_ty_opt: Option[TypeExpr]) : String {
  let ret_kind = ffi_ret_kind_of(ret_ty_opt)
  # FFI v1 deliberately does NOT mint a fresh `extern` declaration
  # for the named symbol. The user is expected to either rely on a
  # libc symbol already declared by `<stdio.h>` / `<stdlib.h>` /
  # `<string.h>` / `<unistd.h>` / `<time.h>` (all pulled in by
  # `runtime.h`), or to feed an `#include` for their FFI library
  # via the user-supplied wrapper.c that the build links in. A
  # local extern declaration here would conflict with libc's
  # canonical signature whenever the kaikai-side type mapping does
  # not match the C-side native (e.g. kaikai `Int` → `int64_t` vs
  # libc `puts`'s `int` return).
  let arg_setup = ffi_emit_arg_setup(params, 0)
  let arg_list = ffi_emit_arg_list(params, 0)
  let call_expr = concat_all([name, "(", arg_list, ")"])
  let arg_decrefs = ffi_emit_arg_decrefs(params, 0)
  let body = match ret_kind {
    FfiRetUnit -> concat_all([
      arg_setup,
      "    ", call_expr, ";\n",
      arg_decrefs,
      "    return kai_unit();\n"
    ])
    FfiRetInt -> concat_all([
      arg_setup,
      "    int64_t _kai_ffi_ret = (int64_t) ", call_expr, ";\n",
      arg_decrefs,
      "    return kai_int(_kai_ffi_ret);\n"
    ])
    FfiRetReal -> concat_all([
      arg_setup,
      "    double _kai_ffi_ret = (double) ", call_expr, ";\n",
      arg_decrefs,
      "    return kai_real(_kai_ffi_ret);\n"
    ])
    FfiRetBool -> concat_all([
      arg_setup,
      "    int _kai_ffi_ret = (int) ", call_expr, ";\n",
      arg_decrefs,
      "    return kai_bool(_kai_ffi_ret != 0);\n"
    ])
    FfiRetString -> concat_all([
      arg_setup,
      "    const char *_kai_ffi_ret = ", call_expr, ";\n",
      arg_decrefs,
      "    return kai_str(_kai_ffi_ret == NULL ? \"\" : _kai_ffi_ret);\n"
    ])
    FfiRetUnknown(t) -> concat_all([
      "#error \"FFI return type `", t,
      "` is not supported in m12.7.x — use Int / Real / Bool / String / Unit\"\n"
    ])
  }
  concat_all([sig, " {\n", body, "}\n\n"])
}

# Option C: runtime-dispatch shim body for `__proto_<op>`. Looks up
# the matching `__pimpl_*` in the impl-table by `(proto_id,
# head_tag(self))` and tail-calls it.
#
# The shim signature must match the dispatcher's kaikai signature
# byte-for-byte — `sig` already encodes that. The first parameter is
# always `Self`-shaped (the receiver carries the dispatch tag); we
# read its head tag and look up.
#
# If the lookup misses (no impl registered for the receiver's runtime
# head), panic with a useful message. The validator pass
# (`validate_resolved_protocols`) catches the static cases at compile
# time; reaching the panic at runtime means either (a) a user wrote a
# polymorphic helper without the required `T : P` bound and the bound
# was not enforced at instantiation, or (b) impl-table corruption.

# Option C: runtime-dispatch shim body for `__proto_<op>`. Looks up
# the matching `__pimpl_*` in the impl-table by `(proto_id,
# head_tag(self))` and tail-calls it.
#
# The shim signature must match the dispatcher's kaikai signature
# byte-for-byte — `sig` already encodes that. The first parameter is
# always `Self`-shaped (the receiver carries the dispatch tag); we
# read its head tag and look up.
#
# If the lookup misses (no impl registered for the receiver's runtime
# head), panic with a useful message. The validator pass
# (`validate_resolved_protocols`) catches the static cases at compile
# time; reaching the panic at runtime means either (a) a user wrote a
# polymorphic helper without the required `T : P` bound and the bound
# was not enforced at instantiation, or (b) impl-table corruption.
fn emit_proto_dispatch_shim_c(sig: String, parts: ProtoDispatchParts,
                                params: [Param],
                                ret_ty_opt: Option[TypeExpr]) : String {
  match parts {
    PDP(pname, opname) -> {
      let proto_id_c = stdlib_proto_id_c(pname)
      let arity = list_length(params)
      let miss_msg = concat_all(["no impl of ", pname, ".", opname,
                                  " for runtime head (arity 0 op: caller must annotate Self)"])
      if arity == 0 {
        # Arity-0 ops (`Default.default() : Self`) cannot be runtime-
        # dispatched: there is no value to derive the head tag from,
        # and Self is meant to be pinned by the caller's annotation
        # so the monomorphiser resolves the impl statically. Reaching
        # this body means the validator missed an unresolved call —
        # panic with the diagnostic and never call back into the
        # impl-table.
        concat_all([
          sig, " {\n",
          "    fprintf(stderr, \"panic: ", miss_msg, "\\n\");\n",
          "    exit(1);\n",
          "}\n\n"
        ])
      } else {
        let cast = proto_dispatch_cast(arity)
        let arg_list = proto_dispatch_arg_list(params, 0)
        let head_param = match params {
          [p, ..._] -> p.pname
          []        -> "self"
        }
        concat_all([
          sig, " {\n",
          "    int32_t _kai_head = kai_head_tag(kai_", head_param, ");\n",
          "    void *_kai_fn_p = kai_lookup_impl(", proto_id_c, ", _kai_head);\n",
          "    if (_kai_fn_p == NULL) {\n",
          "        fprintf(stderr, \"panic: no impl of ", pname, ".", opname,
                  " for runtime head %d\\n\", (int) _kai_head);\n",
          "        exit(1);\n",
          "    }\n",
          "    return ", cast, "_kai_fn_p)(", arg_list, ");\n",
          "}\n\n"
        ])
      }
    }
  }
}

# Map a stdlib protocol name to its KAI_PROTO_* C constant.
# Returns `-1` (cast to int32_t below in the emitted call) and emits
# an #error comment for unknown protocols so the C compile fails
# loudly. v1 supports the 12 stdlib protocols pinned in
# docs/variant-tags.md.

# Map a stdlib protocol name to its KAI_PROTO_* C constant.
# Returns `-1` (cast to int32_t below in the emitted call) and emits
# an #error comment for unknown protocols so the C compile fails
# loudly. v1 supports the 12 stdlib protocols pinned in
# docs/variant-tags.md.
fn stdlib_proto_id_c(pname: String) : String {
  if pname == "Show"         { "KAI_PROTO_SHOW" }
  else if pname == "Eq"      { "KAI_PROTO_EQ" }
  else if pname == "Ord"     { "KAI_PROTO_ORD" }
  else if pname == "Hash"    { "KAI_PROTO_HASH" }
  else if pname == "Serialize"     { "KAI_PROTO_SERIALIZE" }
  else if pname == "BinSerialize"  { "KAI_PROTO_BIN_SERIALIZE" }
  else if pname == "Default" { "KAI_PROTO_DEFAULT" }
  else if pname == "Add"     { "KAI_PROTO_ADD" }
  else if pname == "Sub"     { "KAI_PROTO_SUB" }
  else if pname == "Mul"     { "KAI_PROTO_MUL" }
  else if pname == "Div"     { "KAI_PROTO_DIV" }
  else if pname == "Rem"     { "KAI_PROTO_REM" }
  else { concat_all(["-1 /* unknown protocol ", pname,
                      " — user protocols not supported in v1 */"]) }
}

# Build the C cast prefix for indirect call of a dispatcher of N
# params. All params and the return are `KaiValue *`. The caller emits
# the closing `)` after the cast and the arg list:
# `return ((KaiValue *(*)(KaiValue *)) _kai_fn_p)(kai_a);`

# Build the C cast prefix for indirect call of a dispatcher of N
# params. All params and the return are `KaiValue *`. The caller emits
# the closing `)` after the cast and the arg list:
# `return ((KaiValue *(*)(KaiValue *)) _kai_fn_p)(kai_a);`
fn proto_dispatch_cast(arity: Int) : String {
  let args = proto_dispatch_kaivalueptr_list(arity, 0)
  concat_all(["((KaiValue *(*)(", args, ")) "])
}

fn proto_dispatch_kaivalueptr_list(arity: Int, i: Int) : String {
  if i >= arity { "" }
  else if i == 0 { concat_all(["KaiValue *", proto_dispatch_kaivalueptr_list(arity, i + 1)]) }
  else { concat_all([", KaiValue *", proto_dispatch_kaivalueptr_list(arity, i + 1)]) }
}

# Emit the kaikai params as a C call-arg list `kai_p0, kai_p1, ...`.

# Emit the kaikai params as a C call-arg list `kai_p0, kai_p1, ...`.
fn proto_dispatch_arg_list(params: [Param], i: Int) : String {
  match params {
    [] -> ""
    [p, ...rest] -> {
      let head = if i == 0 { concat_all(["kai_", p.pname]) }
                 else { concat_all([", kai_", p.pname]) }
      concat_all([head, proto_dispatch_arg_list(rest, i + 1)])
    }
  }
}

fn ffi_c_ret_type_str(k: FfiRetKind) : String {
  match k {
    FfiRetUnit -> "void"
    FfiRetInt -> "int64_t"
    FfiRetReal -> "double"
    FfiRetBool -> "int"
    FfiRetString -> "const char *"
    FfiRetUnknown(_) -> "void"  # body is `#error`, never compiled
  }
}

fn ffi_c_param_type_str(p: Param) : String {
  match p.ptype {
    None -> "/* missing type */ void *"
    Some(t) -> match ffi_kind_of_ty(t) {
      FfiRetInt -> "int64_t"
      FfiRetReal -> "double"
      FfiRetBool -> "int"
      FfiRetString -> "const char *"
      FfiRetUnit -> "/* Unit param not supported */ void *"
      FfiRetUnknown(_) -> "/* unsupported FFI param */ void *"
    }
  }
}

fn ffi_c_param_list(params: [Param]) : String {
  match params {
    [] -> "void"
    _ -> join_with(map(params, ffi_c_param_type_str), ", ")
  }
}

# Emit a sequence of local C bindings that unbox each kaikai
# parameter into the matching C scalar. The shim stores the inputs
# in `_kai_ffi_argN` so they survive across the extern call long
# enough for the caller to release the boxed inputs after the call.

# Emit a sequence of local C bindings that unbox each kaikai
# parameter into the matching C scalar. The shim stores the inputs
# in `_kai_ffi_argN` so they survive across the extern call long
# enough for the caller to release the boxed inputs after the call.
fn ffi_emit_arg_setup(params: [Param], i: Int) : String {
  match params {
    [] -> ""
    [p, ...rest] -> {
      let kind = match p.ptype {
        None -> FfiRetUnknown("missing")
        Some(t) -> ffi_kind_of_ty(t)
      }
      let arg_name = concat_all(["_kai_ffi_arg", int_to_string(i)])
      let stmt = match kind {
        FfiRetInt -> concat_all([
          "    int64_t ", arg_name, " = kai_", p.pname, "->as.i;\n"
        ])
        FfiRetReal -> concat_all([
          "    double ", arg_name, " = kai_", p.pname, "->as.r;\n"
        ])
        FfiRetBool -> concat_all([
          "    int ", arg_name, " = kai_", p.pname, "->as.b ? 1 : 0;\n"
        ])
        FfiRetString -> concat_all([
          "    const char *", arg_name, " = kai_", p.pname, "->as.s.bytes;\n"
        ])
        FfiRetUnit -> concat_all([
          "    /* Unit FFI arg #", int_to_string(i), " elided */\n"
        ])
        FfiRetUnknown(t) -> concat_all([
          "#error \"FFI arg type `", t, "` is not supported\"\n"
        ])
      }
      cat2(stmt, ffi_emit_arg_setup(rest, i + 1))
    }
  }
}

fn ffi_emit_arg_list(params: [Param], i: Int) : String {
  match params {
    [] -> ""
    [_, ...rest] -> {
      let head = concat_all(["_kai_ffi_arg", int_to_string(i)])
      match rest {
        [] -> head
        _ -> concat_all([head, ", ", ffi_emit_arg_list(rest, i + 1)])
      }
    }
  }
}

# After the extern returns we must release the boxed kaikai inputs;
# the calling convention hands ownership to the callee.

# After the extern returns we must release the boxed kaikai inputs;
# the calling convention hands ownership to the callee.
fn ffi_emit_arg_decrefs(params: [Param], i: Int) : String {
  match params {
    [] -> ""
    [p, ...rest] -> cat2(
      concat_all(["    kai_decref(kai_", p.pname, ");\n"]),
      ffi_emit_arg_decrefs(rest, i + 1)
    )
  }
}

fn emit_param_args(params: [Param]) : String =
  join_with(map(params, (pm) => cat2("kai_", pm.pname)), ", ")

fn emit_param_reads(params: [Param], start: Int) : String {
  match params {
    [] -> ""
    [p, ...rest] ->
      cat2(
        concat_all(["    KaiValue *kai_", p.pname, " = args[", int_to_string(start), "];\n"]),
        emit_param_reads(rest, start + 1))
  }
}

fn emit_fn_thunk(d: Decl, fns: [EFn]) : String {
  match d {
    DFn(_, name, _, params, _, _, _, _, _, mo) -> {
      let sym = c_sym(name, mo)
      let hdr = concat_all([
        "static KaiValue *_kai_", sym,
        "_thunk(KaiValue *self, KaiValue **args, int n) {\n    (void) self; (void) n;\n"
      ])
      # Phase 3 unboxing — when the named fn is a UFn, the thunk
      # marshals each boxed `args[i]` into the matching raw scalar
      # via `->as.X` and wraps the raw return in `kai_<T>` so the
      # closure-call indirection (`kai_apply` / `kai_closure`)
      # still hands back a `KaiValue *`. This is the dispatch
      # bridge between the boxed first-class-fn world and the
      # raw direct-call world.
      match lookup_ufn_sig(fns, name, mo) {
        Some(US(pts, rt)) -> {
          let arg_unbox = emit_thunk_unbox_args(params, pts, 0)
          let arg_list = emit_thunk_raw_arg_list(params, 0)
          let call_raw = concat_all(["kai_", sym, "(", arg_list, ")"])
          let body = concat_all([
            arg_unbox,
            "    return ", box_wrap(Some(rt), call_raw), ";\n}\n\n"
          ])
          concat_all([hdr, body])
        }
        None -> {
          let param_reads = emit_param_reads(params, 0)
          let named_args = emit_param_args(params)
          let call = concat_all(["    return kai_", sym, "(", named_args, ");\n}\n\n"])
          concat_all([hdr, param_reads, call])
        }
      }
    }
    _ -> ""
  }
}

# Phase 3 unboxing — emit per-param `<raw_ty> kair_<name> = args[i]->as.X;`
# bindings inside a UFn thunk. The boxed arg slot is dropped as soon
# as the raw scalar is read; the caller (`kai_apply`) owns its
# argument array's references but the thunk takes ownership of each
# slot as it consumes it (matching the boxed thunk's
# `KaiValue *kai_<n> = args[i]; ...; kai_decref(...)` discipline).

# Phase 3 unboxing — emit per-param `<raw_ty> kair_<name> = args[i]->as.X;`
# bindings inside a UFn thunk. The boxed arg slot is dropped as soon
# as the raw scalar is read; the caller (`kai_apply`) owns its
# argument array's references but the thunk takes ownership of each
# slot as it consumes it (matching the boxed thunk's
# `KaiValue *kai_<n> = args[i]; ...; kai_decref(...)` discipline).
fn emit_thunk_unbox_args(params: [Param], tys: [Ty], i: Int) : String {
  match params {
    [] -> ""
    [p, ...rest] -> {
      let pty = match tys {
        [t, ...trest] -> t
        []            -> param_ty(p)
      }
      let trest = match tys {
        [_, ...r] -> r
        []        -> []
      }
      let ix = int_to_string(i)
      let line = concat_all([
        "    ", raw_c_type(Some(pty)), " kair_", p.pname,
        " = args[", ix, "]", unbox_field_for(Some(pty)), ";\n",
        "    kai_decref(args[", ix, "]);\n"
      ])
      cat2(line, emit_thunk_unbox_args(rest, trest, i + 1))
    }
  }
}

fn emit_thunk_raw_arg_list(params: [Param], i: Int) : String {
  match params {
    [] -> ""
    [p, ...rest] -> {
      let head = concat_all(["kair_", p.pname])
      match rest {
        [] -> head
        _  -> concat_all([head, ", ", emit_thunk_raw_arg_list(rest, i + 1)])
      }
    }
  }
}

# ---- top-level passes ----

fn fn_forward_decls(decls: [Decl], fns: [EFn]) : String =
  concat_all(map(decls, (d) => emit_fn_forward(d, fns)))

fn thunk_forward_decls(decls: [Decl]) : String =
  concat_all(map(decls, emit_thunk_forward))

fn fn_bodies(src: String, decls: [Decl], cx: EmitCtx) : String / Console =

  concat_all(map(decls, (d) => {
    match d {
      DFn(_, _, _, _, _, _, _, _, _, _) -> cat2(emit_fn_body(src, d, cx), emit_fn_thunk(d, cx.fns))
      _ -> ""
    }
  }))

# ---- test function emission (always emitted; only called from int main
#      when test_mode is on) ----

fn emit_test_fn(src: String, id: Int, desc_span: String, body: Expr,
                cx: EmitCtx,
                target_origin: Option[String]) : String / Console {

  # desc_span is the raw source of the description including its quotes,
  # so it's already a valid C string literal. We wrap the body in
  # setjmp/longjmp: kai_assert_check inside the body can longjmp us out
  # on failure, and the test still counts as a tried test.
  # Issue #335: rotate the EFn table so the target file's own module
  # entries come first. `efn_resolve`'s ambiguous fallback then
  # resolves a bare name (e.g. `concat([])`) to the same-module entry
  # rather than a sibling prelude's clashing export. Mirrors the rotate
  # `emit_fn_body` already does for DFn bodies.
  let body_fns = fns_prefer_module(cx.fns, target_origin)
  let body_cx = EmitCtx { lcs: cx.lcs, fns: body_fns, variants: cx.variants, lams: cx.lams, cls: cx.cls,
                          regions: cx.regions, in_region: cx.in_region }
  let body_c = emit_expr(src, body, body_cx)
  concat_all([
    "static void _kai_test_", int_to_string(id), "(void) {\n",
    "    kai_test_begin(", desc_span, ");\n",
    "    if (setjmp(kai_test_jmp) == 0) {\n",
    "        kai_test_in_progress = 1;\n",
    "        KaiValue *_body = ", body_c, ";\n",
    "        kai_decref(_body);\n",
    "        kai_test_in_progress = 0;\n",
    "        kai_test_pass();\n",
    "    } else {\n",
    "        kai_test_in_progress = 0;\n",
    "    }\n",
    "}\n\n"
  ])
}

fn test_decls(decls: [Decl]) : [Decl] =
  filter(decls, (d) => match d { DTest(_, _, _, _) -> true _ -> false })

fn emit_one_test(src: String, cx: EmitCtx,
                 target_origin: Option[String], id_d: DeclWithId) : String / Console {

  match id_d {
    DWI(id, d) -> match d {
      DTest(desc_span, body, _, _) -> emit_test_fn(src, id, desc_span, body, cx, target_origin)
      _ -> ""
    }
  }
}

# Helper pair to zip index with decl for clean iteration.

# Helper pair to zip index with decl for clean iteration.
type DeclWithId = DWI(Int, Decl)

fn number_tests_loop(decls: [Decl], id: Int, acc: [DeclWithId]) : [DeclWithId] {
  match decls {
    [] -> list_reverse(acc)
    [d, ...rest] -> match d {
      DTest(_, _, _, _) -> number_tests_loop(rest, id + 1, [DWI(id, d), ...acc])
      _ -> number_tests_loop(rest, id, acc)
    }
  }
}

fn number_tests(decls: [Decl]) : [DeclWithId] =
  number_tests_loop(decls, 0, [])

fn emit_all_tests(src: String, decls: [Decl], cx: EmitCtx,
                  target_origin: Option[String]) : String / Console {

  let numbered = number_tests(decls)
  concat_all(map(numbered, (dwi) => emit_one_test(src, cx, target_origin, dwi)))
}

fn test_count(decls: [Decl]) : Int = list_length(test_decls(decls))

fn test_call_list(n: Int, i: Int) : String {
  if i >= n { "" }
  else {
    concat_all(["    _kai_test_", int_to_string(i), "();\n", test_call_list(n, i + 1)])
  }
}

# ---- bench function emission (always emitted; only called from int main
#      when bench_mode is on) ----
#
# bench v1.x (issue #437): each bench body runs in two phases —
# KAI_BENCH_WARMUP untimed iterations to reduce JIT/cache effects on
# the timed window, then KAI_BENCH_ITERS timed iterations whose
# per-iteration nanoseconds are recorded into the runtime sample
# buffer. Both knobs are env vars (read once via kai_bench_iters() /
# kai_bench_warmup() in runtime.h) so users can override at runtime
# without recompiling. On exit kai_bench_finalize sorts the samples
# and prints median + MAD + mean + range. Like test, we do NOT install
# a setjmp landing pad — an assertion failure inside a bench should
# panic the process, since timing aborted code is meaningless.

fn emit_bench_fn(src: String, id: Int, desc_span: String, body: Expr,
                 cx: EmitCtx,
                 target_origin: Option[String]) : String / Console {

  # Issue #335: same file-local rotate as emit_test_fn.
  let body_fns = fns_prefer_module(cx.fns, target_origin)
  let body_cx = EmitCtx { lcs: cx.lcs, fns: body_fns, variants: cx.variants, lams: cx.lams, cls: cx.cls,
                          regions: cx.regions, in_region: cx.in_region }
  let body_c = emit_expr(src, body, body_cx)
  concat_all([
    "static void _kai_bench_", int_to_string(id), "(void) {\n",
    "    int _kai_bench_iters = kai_bench_iters();\n",
    "    int _kai_bench_warmup = kai_bench_warmup();\n",
    "    int _kai_bench_w;\n",
    "    int _kai_bench_i;\n",
    "    long long _kai_bench_a;\n",
    "    long long _kai_bench_b;\n",
    "    kai_bench_ensure_capacity(_kai_bench_iters);\n",
    "    for (_kai_bench_w = 0; _kai_bench_w < _kai_bench_warmup; _kai_bench_w++) {\n",
    "        KaiValue *_body = ", body_c, ";\n",
    "        kai_decref(_body);\n",
    "    }\n",
    "    for (_kai_bench_i = 0; _kai_bench_i < _kai_bench_iters; _kai_bench_i++) {\n",
    "        _kai_bench_a = kai_bench_now_ns();\n",
    "        KaiValue *_body = ", body_c, ";\n",
    "        _kai_bench_b = kai_bench_now_ns();\n",
    "        kai_decref(_body);\n",
    "        kai_bench_record(_kai_bench_i, _kai_bench_b - _kai_bench_a);\n",
    "    }\n",
    "    kai_bench_finalize(", desc_span, ", _kai_bench_iters);\n",
    "}\n\n"
  ])
}

fn bench_decls(decls: [Decl]) : [Decl] =
  filter(decls, (d) => match d { DBench(_, _, _, _) -> true _ -> false })

fn emit_one_bench(src: String, cx: EmitCtx,
                  target_origin: Option[String], id_d: DeclWithId) : String / Console {

  match id_d {
    DWI(id, d) -> match d {
      DBench(desc_span, body, _, _) -> emit_bench_fn(src, id, desc_span, body, cx, target_origin)
      _ -> ""
    }
  }
}

fn number_benches_loop(decls: [Decl], id: Int, acc: [DeclWithId]) : [DeclWithId] {
  match decls {
    [] -> list_reverse(acc)
    [d, ...rest] -> match d {
      DBench(_, _, _, _) -> number_benches_loop(rest, id + 1, [DWI(id, d), ...acc])
      _ -> number_benches_loop(rest, id, acc)
    }
  }
}

fn number_benches(decls: [Decl]) : [DeclWithId] =
  number_benches_loop(decls, 0, [])

fn emit_all_benches(src: String, decls: [Decl], cx: EmitCtx,
                    target_origin: Option[String]) : String / Console {

  let numbered = number_benches(decls)
  concat_all(map(numbered, (dwi) => emit_one_bench(src, cx, target_origin, dwi)))
}

fn bench_count(decls: [Decl]) : Int = list_length(bench_decls(decls))

fn bench_call_list(n: Int, i: Int) : String {
  if i >= n { "" }
  else {
    concat_all(["    _kai_bench_", int_to_string(i), "();\n", bench_call_list(n, i + 1)])
  }
}

# ---- check function emission (always emitted; only called from int main
#      when check_mode is on) ----
#
# check v1 (issue #44): mirrors the test/bench pipelines above. Each
# check body is wrapped in a fixed-N (=KAI_CHECK_ITERS, 100) loop.
# Each iteration:
#
#   1. Records the description in the runtime via kai_check_begin
#      (only on iter 0).
#   2. Resets the counterexample buffer.
#   3. Generates a fresh value for every with-clause param via
#      kai_arbitrary_<T>() and records it for the counterexample.
#   4. Evaluates the body. The body must produce a Bool. true keeps
#      the loop running; false records a counterexample at the
#      current iter index and breaks early.
#
# After the loop, kai_check_pass / kai_check_fail prints the
# per-block result.
#
# The C-level local for each param is `kai_<name>` so the body's
# `EVar(name)` resolves to it through emit_ident_value's lcs lookup.
# The lcs argument passed to emit_expr therefore lists every
# with-clause param name.

# Picks the runtime arbitrary-helper name for a parameter type. v1
# supports primitives (Int / Bool / Char / String) and lists of those
# primitives. Anything else collapses to a panic stub so the failure
# is loud rather than silent — protocol-based / structural derivation
# lands in v1.x and v2.

# Picks the runtime arbitrary-helper name for a parameter type. v1
# supports primitives (Int / Bool / Char / String) and lists of those
# primitives. Anything else collapses to a panic stub so the failure
# is loud rather than silent — protocol-based / structural derivation
# lands in v1.x and v2.
fn check_arbitrary_for_ty(ty: TypeExpr) : String {
  match ty.tkind {
    TyName(name, _args) -> {
      if name == "Int" { "kai_arbitrary_int()" }
      else if name == "Bool" { "kai_arbitrary_bool()" }
      else if name == "Char" { "kai_arbitrary_char()" }
      else if name == "String" { "kai_arbitrary_string()" }
      else { check_arbitrary_panic(name) }
    }
    TyList(inner) -> match inner.tkind {
      TyName(iname, _) -> {
        if iname == "Int" { "kai_arbitrary_list_int()" }
        else if iname == "Bool" { "kai_arbitrary_list_bool()" }
        else if iname == "Char" { "kai_arbitrary_list_char()" }
        else if iname == "String" { "kai_arbitrary_list_string()" }
        else { check_arbitrary_panic(concat_all(["[", iname, "]"])) }
      }
      _ -> check_arbitrary_panic("[<complex>]")
    }
    _ -> check_arbitrary_panic("<complex>")
  }
}

fn check_arbitrary_panic(label: String) : String =
  concat_all([
    "kai_prelude_panic(kai_str(\"check v1: no generator for type ",
    label,
    " — supported types are Int, Bool, Char, String, and lists of those\"))"
  ])

# Picks the runtime shrink-helper names for a parameter type. Returns
# a list of strategy names. Lists have two strategies (drop-head, then
# shrink-head); scalars have one. Empty list means no shrink for this
# type — the runner will skip the param. Issue #438.

# Picks the runtime shrink-helper names for a parameter type. Returns
# a list of strategy names. Lists have two strategies (drop-head, then
# shrink-head); scalars have one. Empty list means no shrink for this
# type — the runner will skip the param. Issue #438.
fn check_shrink_for_ty(ty: TypeExpr) : [String] {
  match ty.tkind {
    TyName(name, _args) -> {
      if name == "Int" { ["kai_shrink_int"] }
      else if name == "Bool" { ["kai_shrink_bool"] }
      else if name == "Char" { ["kai_shrink_char"] }
      else if name == "String" { ["kai_shrink_string"] }
      else { [] }
    }
    TyList(inner) -> match inner.tkind {
      TyName(iname, _) -> {
        if iname == "Int"    { ["kai_shrink_list_int",    "kai_shrink_list_int_head"] }
        else if iname == "Bool"   { ["kai_shrink_list_bool",   "kai_shrink_list_bool_head"] }
        else if iname == "Char"   { ["kai_shrink_list_char",   "kai_shrink_list_char_head"] }
        else if iname == "String" { ["kai_shrink_list_string", "kai_shrink_list_string_head"] }
        else { [] }
      }
      _ -> []
    }
    _ -> []
  }
}

fn emit_check_param_drops(params: [Param]) : String {
  match params {
    [] -> ""
    [p, ...rest] -> concat_all([
      "        kai_decref(kai_", p.pname, ");\n",
      emit_check_param_drops(rest)
    ])
  }
}

# After a counterexample is detected, the failing param values are
# captured in C locals named kai_<name> and we want to keep them alive
# beyond the per-iter loop's scope. The original loop already drops on
# every successful iter and breaks BEFORE dropping on failure, so the
# captured values still hold rc=1 — we just stop treating them as
# loop-scoped. Issue #438.
#
# Re-evaluating the body for shrinking is done by inlining body_c
# again — this is the cleanest way to keep `EVar(name)` resolving via
# the same lcs/locals path the typer already produced. Cost is one
# extra body emission per param-strategy at compile time and zero at
# steady-state runtime (the inlined re-eval only fires when a check
# actually fails, so passing checks pay nothing).

# Emits one strategy attempt: try kai_shrink_<helper>(kai_<param>); if
# it produces a non-NULL candidate AND the body still fails with that
# candidate swapped in, accept it (decref the previous value, keep the
# candidate as the new param), set _progressed=1, and break out of the
# strategy chain. Otherwise restore and decref the candidate.

# Emits one strategy attempt: try kai_shrink_<helper>(kai_<param>); if
# it produces a non-NULL candidate AND the body still fails with that
# candidate swapped in, accept it (decref the previous value, keep the
# candidate as the new param), set _progressed=1, and break out of the
# strategy chain. Otherwise restore and decref the candidate.
fn emit_shrink_attempt(pname: String, helper: String, body_c: String) : String =
  concat_all([
    "        if (!_progressed) {\n",
    "            KaiValue *_cand = ", helper, "(kai_", pname, ");\n",
    "            if (_cand != NULL) {\n",
    "                KaiValue *_save = kai_", pname, ";\n",
    "                kai_", pname, " = _cand;\n",
    "                KaiValue *_body = ", body_c, ";\n",
    "                int _ok = kai_op_truthy(_body);\n",
    "                kai_decref(_body);\n",
    "                if (!_ok) {\n",
    "                    kai_decref(_save);\n",
    "                    _progressed = 1;\n",
    "                } else {\n",
    "                    kai_", pname, " = _save;\n",
    "                    kai_decref(_cand);\n",
    "                }\n",
    "            }\n",
    "        }\n"
  ])

# All strategies for one param, in order.

# All strategies for one param, in order.
fn emit_shrink_attempts_for_param(pname: String, helpers: [String], body_c: String) : String {
  match helpers {
    [] -> ""
    [h, ...rest] -> concat_all([
      emit_shrink_attempt(pname, h, body_c),
      emit_shrink_attempts_for_param(pname, rest, body_c)
    ])
  }
}

# All shrink attempts across every param in the with-clause. The
# enclosing round flag (_progressed) short-circuits subsequent attempts
# once any candidate sticks, so we always greedily restart from the
# first param after each accepted shrink — that matches QuickCheck's
# greedy strategy and keeps the iter budget focused on the most-
# productive prefix of params.

# All shrink attempts across every param in the with-clause. The
# enclosing round flag (_progressed) short-circuits subsequent attempts
# once any candidate sticks, so we always greedily restart from the
# first param after each accepted shrink — that matches QuickCheck's
# greedy strategy and keeps the iter budget focused on the most-
# productive prefix of params.
fn emit_shrink_attempts(params: [Param], body_c: String) : String {
  match params {
    [] -> ""
    [p, ...rest] -> {
      let helpers = match p.ptype {
        Some(t) -> check_shrink_for_ty(t)
        None -> []
      }
      concat_all([
        emit_shrink_attempts_for_param(p.pname, helpers, body_c),
        emit_shrink_attempts(rest, body_c)
      ])
    }
  }
}

fn check_param_names(params: [Param]) : [String] = match params {
  [] -> []
  [p, ...rest] -> [p.pname, ...check_param_names(rest)]
}

# Re-records every param into the cx buffer (used after shrinking to
# rebuild the buffer with shrunk values).

# Re-records every param into the cx buffer (used after shrinking to
# rebuild the buffer with shrunk values).
fn emit_check_param_rerecord(params: [Param]) : String {
  match params {
    [] -> ""
    [p, ...rest] -> concat_all([
      "    kai_check_record_param(\"", p.pname, "\", kai_", p.pname, ");\n",
      emit_check_param_rerecord(rest)
    ])
  }
}

# Drops every param at function-tail scope (no leading indent variant
# of emit_check_param_drops).

# Drops every param at function-tail scope (no leading indent variant
# of emit_check_param_drops).
fn emit_check_param_drops_tail(params: [Param]) : String {
  match params {
    [] -> ""
    [p, ...rest] -> concat_all([
      "    kai_decref(kai_", p.pname, ");\n",
      emit_check_param_drops_tail(rest)
    ])
  }
}

# Forward declares each param at function scope so the per-iter loop
# assigns into them and the post-loop shrink section can reference
# the surviving values. Initialised to NULL so the no-failure path
# leaves nothing to drop.

# Forward declares each param at function scope so the per-iter loop
# assigns into them and the post-loop shrink section can reference
# the surviving values. Initialised to NULL so the no-failure path
# leaves nothing to drop.
fn emit_check_param_decls(params: [Param]) : String {
  match params {
    [] -> ""
    [p, ...rest] -> concat_all([
      "    KaiValue *kai_", p.pname, " = NULL;\n",
      emit_check_param_decls(rest)
    ])
  }
}

# Emits the per-iter param init that ASSIGNS (not declares) into the
# function-scope locals so the post-loop shrink section can see them.

# Emits the per-iter param init that ASSIGNS (not declares) into the
# function-scope locals so the post-loop shrink section can see them.
fn emit_check_param_inits_assign(params: [Param]) : String {
  match params {
    [] -> ""
    [p, ...rest] -> {
      let tyc = match p.ptype {
        Some(t) -> check_arbitrary_for_ty(t)
        None -> check_arbitrary_panic("<missing>")
      }
      concat_all([
        "        kai_", p.pname, " = ", tyc, ";\n",
        "        kai_check_record_param(\"", p.pname, "\", kai_", p.pname, ");\n",
        emit_check_param_inits_assign(rest)
      ])
    }
  }
}

fn emit_check_fn(src: String, id: Int, desc_span: String, params: [Param], body: Expr,
                 cx: EmitCtx,
                 target_origin: Option[String]) : String / Console {

  let lcs2 = list_append(check_param_names(params), cx.lcs)
  # Issue #335: same file-local rotate as emit_test_fn.
  let body_fns = fns_prefer_module(cx.fns, target_origin)
  let body_cx = EmitCtx { lcs: lcs2, fns: body_fns, variants: cx.variants, lams: cx.lams, cls: cx.cls,
                          regions: cx.regions, in_region: cx.in_region }
  let body_c = emit_expr(src, body, body_cx)
  # Issue #438: hoist param locals to function scope so the post-loop
  # shrink section can keep mutating them. The per-iter loop now
  # assigns into them (not redeclares) and only drops on the OK path —
  # on failure the values survive so the shrinker can use them as the
  # starting point.
  let decls = emit_check_param_decls(params)
  let inits = emit_check_param_inits_assign(params)
  let iter_drops = emit_check_param_drops(params)
  let tail_drops = emit_check_param_drops_tail(params)
  let attempts = emit_shrink_attempts(params, body_c)
  let rerecord = emit_check_param_rerecord(params)
  concat_all([
    "static void _kai_check_", int_to_string(id), "(void) {\n",
    "    kai_check_begin(", desc_span, ");\n",
    "    int _kai_check_i;\n",
    "    int _kai_check_failed_at = -1;\n",
    decls,
    "    for (_kai_check_i = 0; _kai_check_i < KAI_CHECK_ITERS; _kai_check_i++) {\n",
    "        kai_check_cx_reset();\n",
    inits,
    "        KaiValue *_body = ", body_c, ";\n",
    "        int _ok = kai_op_truthy(_body);\n",
    "        kai_decref(_body);\n",
    "        if (!_ok) { _kai_check_failed_at = _kai_check_i; break; }\n",
    iter_drops,
    "    }\n",
    "    if (_kai_check_failed_at >= 0) {\n",
    "        kai_check_cx_save_orig();\n",
    "        int _kai_shrink_budget = kai_check_shrink_iters_limit();\n",
    "        int _kai_shrink_i;\n",
    "        for (_kai_shrink_i = 0; _kai_shrink_i < _kai_shrink_budget; _kai_shrink_i++) {\n",
    "            int _progressed = 0;\n",
    attempts,
    "            if (!_progressed) break;\n",
    "        }\n",
    "        kai_check_cx_reset();\n",
    rerecord,
    "        kai_check_fail_shrunk(_kai_check_failed_at);\n",
    tail_drops,
    "    }\n",
    "    else { kai_check_pass(KAI_CHECK_ITERS); }\n",
    "}\n\n"
  ])
}

fn check_decls(decls: [Decl]) : [Decl] =
  filter(decls, (d) => match d { DCheck(_, _, _, _, _) -> true _ -> false })

fn emit_one_check(src: String, cx: EmitCtx,
                  target_origin: Option[String], id_d: DeclWithId) : String / Console {

  match id_d {
    DWI(id, d) -> match d {
      DCheck(desc_span, ps, body, _, _) -> emit_check_fn(src, id, desc_span, ps, body, cx, target_origin)
      _ -> ""
    }
  }
}

fn number_checks_loop(decls: [Decl], id: Int, acc: [DeclWithId]) : [DeclWithId] {
  match decls {
    [] -> list_reverse(acc)
    [d, ...rest] -> match d {
      DCheck(_, _, _, _, _) -> number_checks_loop(rest, id + 1, [DWI(id, d), ...acc])
      _ -> number_checks_loop(rest, id, acc)
    }
  }
}

fn number_checks(decls: [Decl]) : [DeclWithId] =
  number_checks_loop(decls, 0, [])

fn emit_all_checks(src: String, decls: [Decl], cx: EmitCtx,
                   target_origin: Option[String]) : String / Console {

  let numbered = number_checks(decls)
  concat_all(map(numbered, (dwi) => emit_one_check(src, cx, target_origin, dwi)))
}

fn check_count(decls: [Decl]) : Int = list_length(check_decls(decls))

fn check_call_list(n: Int, i: Int) : String {
  if i >= n { "" }
  else {
    concat_all(["    _kai_check_", int_to_string(i), "();\n", check_call_list(n, i + 1)])
  }
}

fn has_main_decl(decls: [Decl]) : Bool {
  match decls {
    [] -> false
    [d, ...rest] -> match d {
      DFn(_, n, _, _, _, _, _, _, _, _) -> if n == "main" { true } else { has_main_decl(rest) }
      _ -> has_main_decl(rest)
    }
  }
}

# Option C runtime infrastructure — emit the impl-table + variant->head
# tables and a registration call before user main.
#
# Walks every DFn whose name starts with `__pimpl_` and synthesises a
# `KaiImplEntry { .proto_id = …, .head_tag = …, .fn = &kai_<sym> }`
# row. The protocol name and target type name are parsed back out of
# the mangled symbol (`__pimpl_<P>_<T>_<op>` and the heterogeneous
# variant `__pimpl_<P>_<T>_<op>__a_<args>`). User protocols / user types
# emit an `-1` slot that the runtime hashmap ignores; v1 supports the
# stdlib heads/protos pinned in `docs/variant-tags.md`.
#
# `kai_variant_to_head` is rebuilt the same way: every entry in
# `variants` (the global EVar table) gets its head tag derived from
# the constructor->sum mapping in the user's declarations.

# Option C runtime infrastructure — emit the impl-table + variant->head
# tables and a registration call before user main.
#
# Walks every DFn whose name starts with `__pimpl_` and synthesises a
# `KaiImplEntry { .proto_id = …, .head_tag = …, .fn = &kai_<sym> }`
# row. The protocol name and target type name are parsed back out of
# the mangled symbol (`__pimpl_<P>_<T>_<op>` and the heterogeneous
# variant `__pimpl_<P>_<T>_<op>__a_<args>`). User protocols / user types
# emit an `-1` slot that the runtime hashmap ignores; v1 supports the
# stdlib heads/protos pinned in `docs/variant-tags.md`.
#
# `kai_variant_to_head` is rebuilt the same way: every entry in
# `variants` (the global EVar table) gets its head tag derived from
# the constructor->sum mapping in the user's declarations.
fn emit_proto_runtime_tables(decls: [Decl], variants: [EVar], fns: [EFn]) : String {
  let impl_rows = collect_pimpl_rows(decls, fns, [])
  let v2h       = collect_variant_to_head(variants, decls)
  let n_impl    = list_length(impl_rows)
  let n_v2h     = list_length(v2h)
  let impl_arr  = emit_impl_table_array(impl_rows, decls)
  let v2h_arr   = emit_variant_to_head_array(v2h)
  # Boxed shims for the unboxed builtin impls registered in the table,
  # emitted before the table so `&kai_<csym>__boxed` resolves. The raw
  # pimpls they call are forward-declared with the other fn bodies.
  let shim_defs = emit_impl_shim_defs(impl_rows, [])
  let fwds      = concat_all([emit_pimpl_forwards(impl_rows, []), shim_defs])
  # issue #118 layer 3 — reusable-tag registry. Collect ctor names the
  # Perceus recogniser marked as reuse targets, map them to tags, and
  # stamp the runtime bitset so `kai_variant_u` skips immortalising
  # those cells (immortalisation saturates rc and blocks reuse).
  let reuse_ctors = collect_reuse_ctors(decls, [])
  let reuse_tags  = reuse_ctor_tags(reuse_ctors, variants, [])
  let n_reuse     = list_length(reuse_tags)
  let reuse_arr   = emit_reuse_tag_array(reuse_tags)
  concat_all([
    fwds,
    "static const int32_t _kai_variant_to_head_tbl[] = {",
    v2h_arr,
    "};\n",
    "static const KaiImplEntry _kai_impl_table_entries[] = {",
    impl_arr,
    "};\n",
    "static const int32_t _kai_reusable_tags_tbl[] = {",
    reuse_arr,
    "};\n",
    "static void _kai_register_proto_tables(void) {\n",
    "    kai_register_variant_heads(_kai_variant_to_head_tbl, ",
    int_to_string(n_v2h), ");\n",
    "    kai_register_impls(_kai_impl_table_entries, ",
    int_to_string(n_impl), ");\n",
    "    kai_register_reusable_tags(_kai_reusable_tags_tbl, ",
    int_to_string(n_reuse), ");\n",
    "}\n\n"
  ])
}

# Map reuse-target ctor names to their integer tags via the global
# EVar table. Names with no tag (defensive — should not happen for a
# recognised ctor) are dropped. Pub so the LLVM backend reuses the
# same name→tag mapping (backend parity — issue #118 layer 3).
pub fn reuse_ctor_tags(names: [String], variants: [EVar], acc: [Int]) : [Int] = match names {
  []           -> acc
  [n, ...rest] -> match evar_find_tag_opt(variants, n) {
    Some(t) -> reuse_ctor_tags(rest, variants, [t, ...acc])
    None    -> reuse_ctor_tags(rest, variants, acc)
  }
}

# A zero-length array initialiser is illegal in C99, so emit a single
# `-1` sentinel when no reuse ctors exist. `kai_register_reusable_tags`
# is then called with n=0 and never reads the slot; and even if it did,
# `-1` is out of range and ignored.
fn emit_reuse_tag_array(tags: [Int]) : String = match tags {
  []           -> "-1"
  [t, ...rest] -> concat_all([int_to_string(t), ", ", emit_reuse_tag_array_loop(rest)])
}

fn emit_reuse_tag_array_loop(tags: [Int]) : String = match tags {
  []           -> ""
  [t, ...rest] -> concat_all([int_to_string(t), ", ", emit_reuse_tag_array_loop(rest)])
}

fn emit_impl_table_array(rows: [PimplRow], decls: [Decl]) : String =
  emit_impl_table_array_loop(rows, decls, "")

fn emit_impl_table_array_loop(rows: [PimplRow], decls: [Decl], acc: String) : String {
  match rows {
    [] -> acc
    [pr, ...rest] -> match pr {
      PR(csym, p, t, _, _) -> {
        # Unboxed builtin impls (`Eq_Int_eq(int64_t,int64_t)`, …) cannot
        # be cast to the dispatch shape `KaiValue*(KaiValue*,KaiValue*)`
        # the runtime expects: the runtime would reinterpret boxed
        # pointers as raw scalars and the raw return as a `KaiValue*`,
        # dereferencing a small integer (SIGSEGV — issue fix-proto-eq-abi).
        # Register the boxed shim instead; boxed impls register directly.
        let fn_sym = if pimpl_row_is_unboxed(pr) {
          concat_all(["kai_", csym, "__boxed"])
        } else {
          concat_all(["kai_", csym])
        }
        let line = concat_all(["\n    { .proto_id = ", stdlib_proto_id_c(p),
                                ", .head_tag = ", stdlib_head_tag_c(t, decls),
                                ", .fn = (void *) &", fn_sym, " },"])
        emit_impl_table_array_loop(rest, decls, concat_all([acc, line]))
      }
    }
  }
}

# Map a kaikai type-name (mangled form like `Int`, `String`, `Option`,
# `Result`, or a user type) to the runtime head-tag C constant.

# Map a kaikai type-name (mangled form like `Int`, `String`, `Option`,
# `Result`, or a user type) to the runtime head-tag C constant.
fn stdlib_head_tag_c(tname: String, decls: [Decl]) : String {
  if tname == "Int"          { "KAI_HEAD_INT" }
  else if tname == "Real"    { "KAI_HEAD_REAL" }
  else if tname == "Bool"    { "KAI_HEAD_BOOL" }
  else if tname == "Char"    { "KAI_HEAD_CHAR" }
  else if tname == "String"  { "KAI_HEAD_STRING" }
  else if tname == "Unit"    { "KAI_HEAD_UNIT" }
  else if tname == "Byte"    { "KAI_HEAD_BYTE" }
  else if tname == "List"    { "KAI_HEAD_LIST" }
  else if tname == "Array"   { "KAI_HEAD_ARRAY" }
  else if tname == "Option"  { "KAI_HEAD_OPTION" }
  else if tname == "Result"  { "KAI_HEAD_RESULT" }
  else if tname == "Signal"  { "KAI_HEAD_SIGNAL" }
  else if tname == "ProcessExit" { "KAI_HEAD_PROCESS_EXIT" }
  else {
    # User-declared record/sum type: dense head tag (>= 20). -1 only when
    # the name names no record/sum decl (truly unknown).
    let ut = user_type_head_tag(tname, decls)
    if ut >= 0 { concat_all([int_to_string(ut), " /* user type: ", tname, " */"]) }
    else { concat_all(["-1 /* unknown type: ", tname, " */"]) }
  }
}

fn emit_variant_to_head_array(xs: [Int]) : String =
  emit_v2h_loop(xs, "")

fn emit_v2h_loop(xs: [Int], acc: String) : String {
  match xs {
    [] -> acc
    [v, ...rest] -> emit_v2h_loop(rest, concat_all([acc, " ", int_to_string(v), ","]))
  }
}

# Forward declarations for every `__pimpl_*` whose address we take in
# the impl table. These names are static fns in the same translation
# unit; the regular fwd block already declares them, but the impl
# table is emitted before user main and must be sure the names are
# in scope. Re-emitting the forwards is cheap and idempotent.

# Forward declarations for every `__pimpl_*` whose address we take in
# the impl table. These names are static fns in the same translation
# unit; the regular fwd block already declares them, but the impl
# table is emitted before user main and must be sure the names are
# in scope. Re-emitting the forwards is cheap and idempotent.
fn emit_pimpl_forwards(rows: [PimplRow], _seen: [String]) : String =
  emit_pimpl_forwards_loop(rows, [])

fn emit_pimpl_forwards_loop(rows: [PimplRow], seen: [String]) : String {
  match rows {
    [] -> ""
    [PR(csym, _, _, _, _), ...rest] ->
      if list_has(seen, csym) {
        emit_pimpl_forwards_loop(rest, seen)
      } else {
        concat_all(["/* impl-table address-of for &kai_", csym, " */\n",
                     emit_pimpl_forwards_loop(rest, [csym, ...seen])])
      }
  }
}

# Emit one boxed shim per unboxed builtin pimpl row registered in the
# impl table. The shim has the dispatch shape
# `KaiValue *kai_<csym>__boxed(KaiValue *a, KaiValue *b)` (or one arg for
# arity-1 impls like Hash). It unpacks each boxed arg to its raw scalar,
# decrefs it (consuming ownership exactly like the runtime's
# `__pimpl_*_thunk` does — the dispatch sites incref a/b before calling
# and require the impl to consume both), calls the raw pimpl, and boxes
# the raw return: `kai_bool` for an Int-returning op (Eq), and the
# return type's constructor (`kai_int` for cmp, `kai_real`/`kai_char`
# for min/max) via `box_wrap`. Boxed pimpls have `None` here and emit
# nothing — they are registered directly.
fn emit_impl_shim_defs(rows: [PimplRow], seen: [String]) : String {
  match rows {
    [] -> ""
    [pr, ...rest] -> match pr {
      PR(csym, _, _, _, sig) ->
        if list_has(seen, csym) or not pimpl_row_is_unboxed(pr) {
          emit_impl_shim_defs(rest, seen)
        } else {
          match sig {
            Some(US(pts, rt)) -> concat_all([
              emit_one_impl_shim(csym, pts, rt),
              emit_impl_shim_defs(rest, [csym, ...seen])
            ])
            None -> emit_impl_shim_defs(rest, [csym, ...seen])
          }
        }
    }
  }
}

# Emit a single boxed shim. `pts` are the raw param tys, `rt` the raw
# return ty. The shim reads `a->as.X` / `b->as.X` per param ty, decrefs
# each boxed arg (consume), calls the raw pimpl, and boxes the return.
fn emit_one_impl_shim(csym: String, pts: [Ty], rt: Ty) : String {
  let unbox  = emit_shim_unbox_args(pts, 0)
  let args   = emit_shim_raw_arg_list(pts, 0)
  let call   = concat_all(["kai_", csym, "(", args, ")"])
  concat_all([
    "static KaiValue *kai_", csym, "__boxed(", emit_shim_param_list(pts, 0), ") {\n",
    unbox,
    "    return ", box_wrap(Some(rt), call), ";\n",
    "}\n\n"
  ])
}

# `KaiValue *a0, KaiValue *a1, …` — one boxed param per impl arg.
# An empty list at the top (arity-0 impls like `Default`) emits `void`
# so the shim's prototype is `KaiValue *kai_<csym>__boxed(void)`, which
# matches the `KaiValue*(*)(void)` shape the dispatcher casts the slot
# to. An empty `()` would be a K&R unspecified-args prototype, not a
# zero-arg one. issue fix-default-shim.
fn emit_shim_param_list(pts: [Ty], i: Int) : String {
  match pts {
    [] -> if i == 0 { "void" } else { "" }
    [_, ...rest] -> {
      let head = concat_all(["KaiValue *a", int_to_string(i)])
      match rest {
        [] -> head
        _  -> concat_all([head, ", ", emit_shim_param_list(rest, i + 1)])
      }
    }
  }
}

# `<raw_ty> r0 = a0->as.X; kai_decref(a0); …` per param. Decref consumes
# the boxed arg, matching the runtime dispatch contract (caller increfs
# a/b; impl owns + drops both).
fn emit_shim_unbox_args(pts: [Ty], i: Int) : String {
  match pts {
    [] -> ""
    [t, ...rest] -> {
      let ix = int_to_string(i)
      let line = concat_all([
        "    ", raw_c_type(Some(t)), " r", ix,
        " = a", ix, unbox_field_for(Some(t)), ";\n",
        "    kai_decref(a", ix, ");\n"
      ])
      concat_all([line, emit_shim_unbox_args(rest, i + 1)])
    }
  }
}

# `r0, r1, …` — the raw scalar locals passed to the raw pimpl.
fn emit_shim_raw_arg_list(pts: [Ty], i: Int) : String {
  match pts {
    [] -> ""
    [_, ...rest] -> {
      let head = concat_all(["r", int_to_string(i)])
      match rest {
        [] -> head
        _  -> concat_all([head, ", ", emit_shim_raw_arg_list(rest, i + 1)])
      }
    }
  }
}

fn emit_main_wrapper(decls: [Decl], bmode: BuildMode, variants: [EVar], fns: [EFn]) : String {
  let proto_tables = emit_proto_runtime_tables(decls, variants, fns)
  let proto_init   = "    _kai_register_proto_tables();\n"
  match bmode {
    BMTest -> {
      let n = test_count(decls)
      concat_all([
        proto_tables,
        "int main(int argc, char **argv) {\n",
        "    kai_set_args(argc, argv);\n",
        proto_init,
        test_call_list(n, 0),
        "    return kai_test_summary();\n",
        "}\n"
      ])
    }
    BMBench -> {
      let n = bench_count(decls)
      concat_all([
        proto_tables,
        "int main(int argc, char **argv) {\n",
        "    kai_set_args(argc, argv);\n",
        proto_init,
        bench_call_list(n, 0),
        "    return kai_bench_summary();\n",
        "}\n"
      ])
    }
    BMCheck -> {
      let n = check_count(decls)
      concat_all([
        proto_tables,
        "int main(int argc, char **argv) {\n",
        "    kai_set_args(argc, argv);\n",
        proto_init,
        check_call_list(n, 0),
        "    return kai_check_summary();\n",
        "}\n"
      ])
    }
    BMBuild -> {
      if has_main_decl(decls) {
        # m7a #7: install default handlers around `kai_main` only for
        # the builtin effects that appear in `main`'s row. The push/pop
        # pair is syntactically balanced (Doc C §*Per-fiber isolation*);
        # pop runs even if `kai_main` returns. Pops are emitted in
        # reverse-push order so the evidence stack stays LIFO-balanced.
        #
        # Issue #115: the shim block below is emitted at file scope,
        # before `int main()`. Each shim has the typed signature
        # matching the EvX struct field and forwards to the runtime
        # void-self function. Setup assigns shim addresses without a
        # cast, so UBSan's `-fsanitize=function` (Linux clang's
        # `-fsanitize=undefined`, absent from Apple clang's default)
        # sees matching types at every dispatch through `_ev_op->op`.
        # Issue #308: drop any effect name whose decl is user-supplied
        # (line/col != 0). The default-handler emit assumes the builtin
        # EvX layout — emitting it for a user `effect Log { ... }` shape
        # produces invalid C against the user's struct.
        let main_row = cmt_row_effects_without_default_handler(main_row_labels(decls), decls)
        let shims    = default_shims_for(main_row, decls)
        let setup    = default_setups_for(main_row, decls)
        let teardown = default_pops_for(main_row)
        concat_all([
          shims,
          proto_tables,
          "int main(int argc, char **argv) {\n",
          "    kai_set_args(argc, argv);\n",
          proto_init,
          setup,
          "    KaiValue *_result = kai_main();\n",
          teardown,
          "    kai_decref(_result);\n",
          "    return 0;\n",
          "}\n"
        ])
      } else {
        ""
      }
    }
  }
}

fn default_shims_from_block(eff_name: String, decls: [Decl]) : String =
  match find_effect_default_block(eff_name, decls) {
    None         -> ""
    Some(defblk) -> match defblk {
      DBlk(clauses, _, _, _) ->
        concat_all(map(clauses, (c) => default_shim_from_clause(eff_name, c)))
    }
  }

fn default_setups_from_block(eff_name: String, decls: [Decl]) : String =
  match find_effect_default_block(eff_name, decls) {
    None         -> ""
    Some(defblk) -> match defblk {
      DBlk(clauses, _, _, _) -> {
        let eff_lc = string_to_lower_ascii(eff_name)
        concat_all([
          "    static Ev", eff_name, " _kai_default_ev_", eff_lc, ";\n",
          "    static KaiEvidence _kai_default_node_", eff_lc, ";\n",
          "    _kai_default_ev_", eff_lc, ".handler_id = kai_fresh_handler_id();\n",
          concat_all(map(clauses, (c) => default_setup_assign_from_clause(eff_name, c))),
          "    kai_evidence_push(&_kai_default_node_", eff_lc,
            ", \"", eff_name, "\", &_kai_default_ev_", eff_lc, ");\n"
        ])
      }
    }
  }

fn effect_has_default_block(eff_name: String, decls: [Decl]) : Bool =
  match find_effect_default_block(eff_name, decls) {
    None    -> false
    Some(_) -> true
  }

fn default_shim_from_clause(eff_name: String, c: HClause) : String =
  match c {
    HC(op_name, params, body, _, _) -> {
      let csym_opt = extern_handler_c_symbol(body)
      match csym_opt {
        None        -> ""
        Some(csym_name) -> {
          let visible = op_args_only(params)
          let arg_decls = concat_all(map(visible, (p) => concat_all([", KaiValue *kai_", p.pname])))
          let arg_pass  = concat_all(map(visible, (p) => concat_all([", kai_", p.pname])))
          concat_all([
            "static KaiValue *_kai_default_", string_to_lower_ascii(eff_name),
              "_", op_name, "_shim(Ev", eff_name, " *self",
              arg_decls, ", KaiCont *k) {\n",
            "    return ", csym_name, "(self", arg_pass, ", k);\n",
            "}\n"
          ])
        }
      }
    }
  }

# Build the per-clause field assignment line for the setup block:
#     _kai_default_ev_<eff_lc>.<op> = &_kai_default_<eff_lc>_<op>_shim;
# Returns "" when the clause is not an extern_handler bridge.

# Build the per-clause field assignment line for the setup block:
#     _kai_default_ev_<eff_lc>.<op> = &_kai_default_<eff_lc>_<op>_shim;
# Returns "" when the clause is not an extern_handler bridge.
fn default_setup_assign_from_clause(eff_name: String, c: HClause) : String =
  match c {
    HC(op_name, _, body, _, _) -> match extern_handler_c_symbol(body) {
      None    -> ""
      Some(_) -> {
        let eff_lc = string_to_lower_ascii(eff_name)
        concat_all([
          "    _kai_default_ev_", eff_lc, ".", op_name,
          " = &_kai_default_", eff_lc, "_", op_name, "_shim;\n"
        ])
      }
    }
  }

fn default_setups_for(main_row: [String], decls: [Decl]) : String = {
  # Issue #558: every builtin (and any user-declared effect) whose
  # decl carries a `default { }` block bridged via `$extern_handler`
  # rides the AST-derived `default_setups_from_block`. The hardcoded
  # `default_<eff>_setup()` family was deleted alongside this
  # migration — the source-level `default { }` is the only path.
  # The list below preserves the historic push order for the builtins
  # so the corresponding pop order in `default_pops_for` stays
  # consistent; any user-declared effects in `main_row` push after
  # the builtins in their declaration order.
  let order = list_append(builtin_default_install_order(),
                            user_effects_in_row(main_row))
  emit_default_setups_in_order(order, main_row, decls)
}

fn emit_default_setups_in_order(order: [String], main_row: [String],
                                 decls: [Decl]) : String {
  match order {
    [] -> ""
    [eff, ...rest] ->
      if list_has(main_row, eff) {
        let derived = default_setups_from_block(eff, decls)
        concat_all([derived, emit_default_setups_in_order(rest, main_row, decls)])
      } else {
        emit_default_setups_in_order(rest, main_row, decls)
      }
  }
}

# Push order for default handlers — mirrors the historic hardcoded
# arrangement so push/pop stays balanced and selfhost stays
# byte-identical. Pops in `default_pops_for` walk this list in
# reverse.

# Push order for default handlers — mirrors the historic hardcoded
# arrangement so push/pop stays balanced and selfhost stays
# byte-identical. Pops in `default_pops_for` walk this list in
# reverse.
fn builtin_default_install_order() : [String] =
  ["Stdout", "Stderr", "Fail", "Stdin", "Env", "File", "Clock",
   "Random", "SecureRandom", "NetTcp", "Signal", "Process", "Log",
   "Mutable", "Cancel", "Link", "Monitor", "Spawn"]

# Labels in `main_row` that are NOT canonical builtin defaults. They
# go at the end of the install order, after the builtins, so the pop
# order can mirror reverse-declaration.

# Labels in `main_row` that are NOT canonical builtin defaults. They
# go at the end of the install order, after the builtins, so the pop
# order can mirror reverse-declaration.
fn user_effects_in_row(main_row: [String]) : [String] {
  let builtins = builtin_default_install_order()
  match main_row {
    [] -> []
    [x, ...rest] ->
      if list_has(builtins, x) {
        user_effects_in_row(rest)
      } else {
        [x, ...user_effects_in_row(rest)]
      }
  }
}

# Issue #115: aggregate the typed shim definitions for every
# default handler that `default_setups_for` will install. Emitted
# at file scope before `int main()` so the shim addresses are in
# scope when the setup block assigns them. The pair-wise
# correspondence with `default_setups_for` is load-bearing — the
# setup expects `_kai_default_<eff>_<op>_shim` to be defined for
# every effect in `main_row`, and a missing shim shows up as a
# C compile error before the binary is produced (and well before
# UBSan would otherwise catch the type mismatch at runtime).

# Issue #115: aggregate the typed shim definitions for every
# default handler that `default_setups_for` will install. Emitted
# at file scope before `int main()` so the shim addresses are in
# scope when the setup block assigns them. The pair-wise
# correspondence with `default_setups_for` is load-bearing — the
# setup expects `_kai_default_<eff>_<op>_shim` to be defined for
# every effect in `main_row`, and a missing shim shows up as a
# C compile error before the binary is produced (and well before
# UBSan would otherwise catch the type mismatch at runtime).
fn default_shims_for(main_row: [String], decls: [Decl]) : String = {
  # Issue #558: every shim is derived from the effect's `default { }`
  # block; the hardcoded `default_<eff>_shims()` family was deleted
  # alongside this migration. Iteration order matches
  # `default_setups_for` (push order) so the shim definitions appear
  # ahead of the setup block that references them. User-declared
  # effects with `default { }` blocks emit their shims after the
  # builtin shims.
  let order = list_append(builtin_default_install_order(),
                            user_effects_in_row(main_row))
  emit_default_shims_in_order(order, main_row, decls)
}

fn emit_default_shims_in_order(order: [String], main_row: [String],
                                decls: [Decl]) : String {
  match order {
    [] -> ""
    [eff, ...rest] ->
      if list_has(main_row, eff) {
        let derived = default_shims_from_block(eff, decls)
        concat_all([derived, emit_default_shims_in_order(rest, main_row, decls)])
      } else {
        emit_default_shims_in_order(rest, main_row, decls)
      }
  }
}

# Pops in reverse-push order so the evidence stack drains LIFO.
# Push order: builtins first (in `builtin_default_install_order`),
# then user-declared effects (in declaration order). Pops therefore
# walk user-declared effects first (reverse declaration order), then
# builtins (reverse pinned order).

# Pops in reverse-push order so the evidence stack drains LIFO.
# Push order: builtins first (in `builtin_default_install_order`),
# then user-declared effects (in declaration order). Pops therefore
# walk user-declared effects first (reverse declaration order), then
# builtins (reverse pinned order).
fn default_pops_for(main_row: [String]) : String = {
  let order = list_append(builtin_default_install_order(),
                            user_effects_in_row(main_row))
  emit_default_pops_in_order(list_reverse(order), main_row)
}

fn emit_default_pops_in_order(order_rev: [String], main_row: [String]) : String {
  match order_rev {
    [] -> ""
    [eff, ...rest] ->
      if list_has(main_row, eff) {
        concat_all(["    kai_evidence_pop();\n",
                    emit_default_pops_in_order(rest, main_row)])
      } else {
        emit_default_pops_in_order(rest, main_row)
      }
  }
}

fn desugar_op_calls_decls(ds: [Decl], effs: [String]) : [Decl] =
  map(ds, (d) => desugar_op_calls_decl(d, effs))

fn desugar_op_calls_decl(d: Decl, effs: [String]) : Decl {
  match d {
    DFn(pub_, n, tps, ps, ret, row, body, l, c, mo) ->
      DFn(pub_, n, tps, ps, ret, row, desugar_op_calls_expr(body, effs), l, c, mo)
    DTest(desc, body, l, c) ->
      DTest(desc, desugar_op_calls_expr(body, effs), l, c)
    DBench(desc, body, l, c) ->
      DBench(desc, desugar_op_calls_expr(body, effs), l, c)
    DCheck(desc, params, body, l, c) ->
      DCheck(desc, params, desugar_op_calls_expr(body, effs), l, c)
    _ -> d
  }
}

fn desugar_op_calls_expr(e: Expr, effs: [String]) : Expr =
  Expr { kind: desugar_op_calls_kind(e.kind, effs),
         line: e.line, col: e.col, ty: e.ty, mode: e.mode }

fn desugar_op_calls_callee(callee: Expr, effs: [String]) : Expr {
  match callee.kind {
    EField(base, op_name) -> match base.kind {
      EVar(name) ->
        if list_has(effs, name) {
          mk_expr(EVar(string_concat(name, string_concat(".", op_name))),
                  callee.line, callee.col)
        } else { desugar_op_calls_expr(callee, effs) }
      _ -> desugar_op_calls_expr(callee, effs)
    }
    _ -> desugar_op_calls_expr(callee, effs)
  }
}

fn desugar_op_calls_kind(k: ExprKind, effs: [String]) : ExprKind {
  match k {
    # The only kind that needs special handling: rewrite a
    # `EField(EVar(eff), op)` callee into the flat `EVar("eff.op")`
    # form so emit_call_expr can dispatch through kai_evidence_lookup.
    # All sub-expressions (args + non-EField callee) recurse via the
    # shared visitor.
    ECall(callee, args_) ->
      ECall(desugar_op_calls_callee(callee, effs),
            map(args_, (a) => desugar_op_calls_expr(a, effs)))
    _ -> map_expr_kind(k, (sub) => desugar_op_calls_expr(sub, effs))
  }
}

# Pre-typer recursion over `EIndex` and `SIndexAssign`. The pass no
# longer rewrites either form (issue #128 moved the dispatch to the
# typer so `Map[K, V]` and `Array[T]` can pick different lowerings).
# What the pass *does* do is walk every body so any sugar layered
# above this one — `EBlock` rewrites, var-cell desugar — sees the
# stmts in their original shape; an unmodified visitor would miss
# the `SIndexAssign` arm because it survives the typer too.

# Pre-typer recursion over `EIndex` and `SIndexAssign`. The pass no
# longer rewrites either form (issue #128 moved the dispatch to the
# typer so `Map[K, V]` and `Array[T]` can pick different lowerings).
# What the pass *does* do is walk every body so any sugar layered
# above this one — `EBlock` rewrites, var-cell desugar — sees the
# stmts in their original shape; an unmodified visitor would miss
# the `SIndexAssign` arm because it survives the typer too.
#[doc("Pre-typer recursion over `EIndex` and `SIndexAssign`. The pass no longer rewrites either form (issue #128 moved the dispatch to the typer so `Map[K, V]` and `Array[T]` can pick…")]
pub fn desugar_index_decls(ds: [Decl]) : [Decl] = map(ds, desugar_index_decl)

fn desugar_index_decl(d: Decl) : Decl {
  match d {
    DFn(pub_, n, tps, ps, ret, row, body, l, c, mo) ->
      DFn(pub_, n, tps, ps, ret, row, desugar_index_expr(body), l, c, mo)
    DTest(desc, body, l, c) -> DTest(desc, desugar_index_expr(body), l, c)
    DBench(desc, body, l, c) -> DBench(desc, desugar_index_expr(body), l, c)
    DCheck(desc, params, body, l, c) -> DCheck(desc, params, desugar_index_expr(body), l, c)
    _ -> d
  }
}

fn desugar_index_expr(e: Expr) : Expr =
  Expr { kind: desugar_index_kind(e.kind, e.line, e.col),
         line: e.line, col: e.col, ty: e.ty, mode: e.mode }

fn desugar_index_opt(opt: Option[Expr]) : Option[Expr] {
  match opt {
    Some(e) -> Some(desugar_index_expr(e))
    None    -> None
  }
}

fn desugar_index_stmts(ss: [Stmt]) : [Stmt] = map(ss, desugar_index_stmt)

fn desugar_index_stmt(s: Stmt) : Stmt {
  match s {
    SLet(pat, ann, rhs) -> SLet(pat, ann, desugar_index_expr(rhs))
    SAssert(c, m) -> SAssert(desugar_index_expr(c), desugar_index_opt(m))
    SExprStmt(x) -> SExprStmt(desugar_index_expr(x))
    # issue #128: SIndexAssign now flows through to the typer, which
    # dispatches on the container's inferred type (Array → array_set
    # call; Map → typed error). Sub-exprs still recurse so any nested
    # sugars below this layer are picked up.
    SIndexAssign(b, i, v, line, col) ->
      SIndexAssign(desugar_index_expr(b), desugar_index_expr(i),
                   desugar_index_expr(v), line, col)
    # m7b #5: pass through; the var-desugar pass below transforms SVar
    # into a `handle ... with State[T](init)` form. Until that pass runs
    # we still need to recurse into `init` so any nested `a[i]` inside
    # the initialiser is rewritten.
    SVar(n, ty, rhs, l, c) -> SVar(n, ty, desugar_index_expr(rhs), l, c)
    # m7e §25: SUse pass through.
    SUse(n, l, c) -> SUse(n, l, c)
  }
}

fn desugar_index_kind(k: ExprKind, line: Int, col: Int) : ExprKind {
  match k {
    # issue #128: EIndex now flows through to the typer, which
    # dispatches by the container's inferred type (Array → array_get
    # call; Map → map_get call returning Option[V]). The pass still
    # walks sub-expressions because EBlock stmt-bodies carry the
    # SIndexAssign variant we now also leave intact.
    EBlock(stmts, tail) -> EBlock(desugar_index_stmts(stmts),
                                   desugar_index_opt(tail))
    _ -> map_expr_kind(k, desugar_index_expr)
  }
}

fn proto_dispatch_tag() : String = "__kai_proto_dispatch__"

fn mk_proto_dispatch_body(pname: String, opname: String, line: Int, col: Int) : Expr =
  mk_expr(ETodo(concat_all([proto_dispatch_tag_prefix(), pname, ":", opname])), line, col)

#[doc("Emit-layer entry point desugar_interp_decls")]
pub fn desugar_interp_decls(ds: [Decl], op_names: [String], op_arities: [OpAr], mt: [ModuleEntry], file: String) : [Decl] / Console + File {

  if not list_has(op_names, "show") { ds }
  else { map(ds, (d) => desugar_interp_decl(d, op_names, op_arities, mt, file)) }
}

fn desugar_interp_decl(d: Decl, op_names: [String], op_arities: [OpAr], mt: [ModuleEntry], file: String) : Decl / Console + File {

  match d {
    DFn(p, n, tps, ps, ret, row, body, l, c, mo) ->
      DFn(p, n, tps, ps, ret, row, desugar_interp_expr(body, op_names, op_arities, mt, file), l, c, mo)
    DTest(desc, body, l, c) ->
      DTest(desc, desugar_interp_expr(body, op_names, op_arities, mt, file), l, c)
    DBench(desc, body, l, c) ->
      DBench(desc, desugar_interp_expr(body, op_names, op_arities, mt, file), l, c)
    DCheck(desc, ps, body, l, c) ->
      DCheck(desc, ps, desugar_interp_expr(body, op_names, op_arities, mt, file), l, c)
    _ -> d
  }
}

fn desugar_interp_expr(e: Expr, op_names: [String], op_arities: [OpAr], mt: [ModuleEntry], file: String) : Expr / Console + File =

  Expr { kind: desugar_interp_kind(e.kind, op_names, op_arities, mt, file, e.line, e.col),
         line: e.line, col: e.col, ty: e.ty, mode: e.mode }

fn desugar_interp_kind(k: ExprKind, op_names: [String], op_arities: [OpAr],
                        mt: [ModuleEntry], file: String,
                        line: Int, col: Int) : ExprKind / Console + File {

  match k {
    # The two kinds the pass actually transforms:
    #   * EStr with `#{...}` interpolation lifts into a
    #     `string_concat_all([...])` call so the typer sees the
    #     interp body's typed expressions and protocol ops route
    #     through the user's `impl Show for T`.
    #   * ECall whose callee is `EField(receiver, op_name)` for an
    #     op_name in `op_names` (a declared protocol op) rewrites
    #     to `__proto_<op>(receiver, ...args)` so the post-inference
    #     rewrite can route the call to the matching impl. Records
    #     that happen to carry a field with the same name as a
    #     protocol op shadow this rule.
    EStr(span, is_triple) -> {
      let n = string_length(span)
      let body_start = if is_triple { 3 } else { 1 }
      let body_end = if is_triple { n - 3 } else { n - 1 }
      if has_interp(span, body_start, body_end) {
        lift_interp_string(span, body_start, body_end, op_names, op_arities, mt, file, line, col)
      } else { k }
    }
    ECall(c, args_) -> match c.kind {
      EField(receiver, op_name) ->
        if list_has(op_names, op_name) {
          let new_callee = mk_expr(EVar(proto_dispatcher_name(op_name)),
                                    c.line, c.col)
          let new_recv   = desugar_interp_expr(receiver, op_names, op_arities, mt, file)
          let new_args   = map(args_, (a) => desugar_interp_expr(a, op_names, op_arities, mt, file))
          ECall(new_callee, [new_recv, ...new_args])
        } else {
          ECall(desugar_interp_expr(c, op_names, op_arities, mt, file),
                map(args_, (a) => desugar_interp_expr(a, op_names, op_arities, mt, file)))
        }
      _ -> ECall(desugar_interp_expr(c, op_names, op_arities, mt, file),
                  map(args_, (a) => desugar_interp_expr(a, op_names, op_arities, mt, file)))
    }
    # Inlined from `map_expr_kind` for issue #528 (effect-row propagation
    # blocked by stage 1's lack of row polymorphism on function-param types).
    EInt(_)        -> k
    EReal(_)       -> k
    EBool(_)       -> k
    EChar(_)       -> k
    EUnit          -> k
    EVar(_)        -> k
    EUnder         -> k
    EPlaceholder   -> k
    EHole(_)       -> k
    ETodo(_)       -> k
    EVariantsOf(_, _) -> k
    EModCall(_, _) -> k
    EIntrinsic(name, args_) ->
      EIntrinsic(name, map(args_, (a) => desugar_interp_expr(a, op_names, op_arities, mt, file)))
    EField(base, name)   -> EField(desugar_interp_expr(base, op_names, op_arities, mt, file), name)
    EIndex(a, b)         -> EIndex(desugar_interp_expr(a, op_names, op_arities, mt, file),
                                    desugar_interp_expr(b, op_names, op_arities, mt, file))
    EBinop(op, a, b)     -> EBinop(op, desugar_interp_expr(a, op_names, op_arities, mt, file),
                                        desugar_interp_expr(b, op_names, op_arities, mt, file))
    EUnop(op, x)         -> EUnop(op, desugar_interp_expr(x, op_names, op_arities, mt, file))
    EIf(c, t_, eo)       -> EIf(desugar_interp_expr(c, op_names, op_arities, mt, file),
                                  desugar_interp_expr(t_, op_names, op_arities, mt, file),
                                  desugar_interp_expr_opt(eo, op_names, op_arities, mt, file))
    EMatch(scr, arms)    -> EMatch(desugar_interp_expr(scr, op_names, op_arities, mt, file),
                                     desugar_interp_arms(arms, op_names, op_arities, mt, file))
    ELambda(ps, b)       -> ELambda(ps, desugar_interp_expr(b, op_names, op_arities, mt, file))
    ERecordLit(name, fs) -> ERecordLit(name, desugar_interp_fields_init(fs, op_names, op_arities, mt, file))
    EList(els)           -> EList(desugar_interp_list_elems(els, op_names, op_arities, mt, file))
    ERange(a, b, opt_step) -> ERange(desugar_interp_expr(a, op_names, op_arities, mt, file),
                                       desugar_interp_expr(b, op_names, op_arities, mt, file),
                                       desugar_interp_expr_opt(opt_step, op_names, op_arities, mt, file))
    EBlock(stmts, tail)  -> EBlock(desugar_interp_stmts(stmts, op_names, op_arities, mt, file),
                                     desugar_interp_expr_opt(tail, op_names, op_arities, mt, file))
    EPipe(a, b)          -> EPipe(desugar_interp_expr(a, op_names, op_arities, mt, file),
                                    desugar_interp_expr(b, op_names, op_arities, mt, file))
    EMapPipe(a, b)       -> EMapPipe(desugar_interp_expr(a, op_names, op_arities, mt, file),
                                       desugar_interp_expr(b, op_names, op_arities, mt, file))
    EFlatMapPipe(a, b)   -> EFlatMapPipe(desugar_interp_expr(a, op_names, op_arities, mt, file),
                                            desugar_interp_expr(b, op_names, op_arities, mt, file))
    EFilterPipe(a, b)    -> EFilterPipe(desugar_interp_expr(a, op_names, op_arities, mt, file),
                                           desugar_interp_expr(b, op_names, op_arities, mt, file))
    EHandle(body, eff_name, eff_tyargs, init_opt, alias_opt, clauses, ret_opt) ->
      EHandle(desugar_interp_expr(body, op_names, op_arities, mt, file), eff_name, eff_tyargs,
              desugar_interp_expr_opt(init_opt, op_names, op_arities, mt, file), alias_opt,
              desugar_interp_hclauses(clauses, op_names, op_arities, mt, file),
              desugar_interp_hreturn_opt(ret_opt, op_names, op_arities, mt, file))
    ELitUnit(inner, u)   -> ELitUnit(desugar_interp_expr(inner, op_names, op_arities, mt, file), u)
    EBang(inner)         -> EBang(desugar_interp_expr(inner, op_names, op_arities, mt, file))
  }
}

# Issue #528 helpers for `desugar_interp_kind` — direct walkers that
# replace the `map_expr_kind` HOF call. Stage 1 cannot parse row
# polymorphism on function-param types.

# Issue #528 helpers for `desugar_interp_kind` — direct walkers that
# replace the `map_expr_kind` HOF call. Stage 1 cannot parse row
# polymorphism on function-param types.
fn desugar_interp_expr_opt(opt: Option[Expr], op_names: [String], op_arities: [OpAr], mt: [ModuleEntry], file: String) : Option[Expr] / Console + File = match opt {
  None    -> None
  Some(x) -> Some(desugar_interp_expr(x, op_names, op_arities, mt, file))
}

fn desugar_interp_arms(arms: [Arm], op_names: [String], op_arities: [OpAr], mt: [ModuleEntry], file: String) : [Arm] / Console + File = match arms {
  []           -> []
  [h, ...rest] -> [desugar_interp_arm(h, op_names, op_arities, mt, file),
                   ...desugar_interp_arms(rest, op_names, op_arities, mt, file)]
}

fn desugar_interp_arm(a: Arm, op_names: [String], op_arities: [OpAr], mt: [ModuleEntry], file: String) : Arm / Console + File = match a {
  Arm(pat, guard_opt, body) ->
    Arm(pat,
        desugar_interp_expr_opt(guard_opt, op_names, op_arities, mt, file),
        desugar_interp_expr(body, op_names, op_arities, mt, file))
}

fn desugar_interp_fields_init(fs: [FieldInit], op_names: [String], op_arities: [OpAr], mt: [ModuleEntry], file: String) : [FieldInit] / Console + File = match fs {
  []           -> []
  [h, ...rest] -> [desugar_interp_field_init(h, op_names, op_arities, mt, file),
                   ...desugar_interp_fields_init(rest, op_names, op_arities, mt, file)]
}

fn desugar_interp_field_init(fi: FieldInit, op_names: [String], op_arities: [OpAr], mt: [ModuleEntry], file: String) : FieldInit / Console + File = match fi {
  FI(name, e) -> FI(name, desugar_interp_expr(e, op_names, op_arities, mt, file))
}

fn desugar_interp_list_elems(els: [ListElem], op_names: [String], op_arities: [OpAr], mt: [ModuleEntry], file: String) : [ListElem] / Console + File = match els {
  []           -> []
  [h, ...rest] -> [desugar_interp_list_elem(h, op_names, op_arities, mt, file),
                   ...desugar_interp_list_elems(rest, op_names, op_arities, mt, file)]
}

fn desugar_interp_list_elem(el: ListElem, op_names: [String], op_arities: [OpAr], mt: [ModuleEntry], file: String) : ListElem / Console + File = match el {
  ElPlain(e)  -> ElPlain(desugar_interp_expr(e, op_names, op_arities, mt, file))
  ElSpread(e) -> ElSpread(desugar_interp_expr(e, op_names, op_arities, mt, file))
}

fn desugar_interp_stmts(ss: [Stmt], op_names: [String], op_arities: [OpAr], mt: [ModuleEntry], file: String) : [Stmt] / Console + File = match ss {
  []           -> []
  [h, ...rest] -> [desugar_interp_stmt(h, op_names, op_arities, mt, file),
                   ...desugar_interp_stmts(rest, op_names, op_arities, mt, file)]
}

fn desugar_interp_stmt(s: Stmt, op_names: [String], op_arities: [OpAr], mt: [ModuleEntry], file: String) : Stmt / Console + File = match s {
  SLet(p, ann, rhs) -> SLet(p, ann, desugar_interp_expr(rhs, op_names, op_arities, mt, file))
  SAssert(e, msg_opt) -> SAssert(desugar_interp_expr(e, op_names, op_arities, mt, file),
                                  desugar_interp_expr_opt(msg_opt, op_names, op_arities, mt, file))
  SExprStmt(e) -> SExprStmt(desugar_interp_expr(e, op_names, op_arities, mt, file))
  SIndexAssign(arr, idx, rhs, ln, cl) ->
    SIndexAssign(desugar_interp_expr(arr, op_names, op_arities, mt, file),
                  desugar_interp_expr(idx, op_names, op_arities, mt, file),
                  desugar_interp_expr(rhs, op_names, op_arities, mt, file), ln, cl)
  SVar(name, ann, rhs, ln, cl) -> SVar(name, ann, desugar_interp_expr(rhs, op_names, op_arities, mt, file), ln, cl)
  SUse(_, _, _) -> s
}

fn desugar_interp_hclauses(cs: [HClause], op_names: [String], op_arities: [OpAr], mt: [ModuleEntry], file: String) : [HClause] / Console + File = match cs {
  []           -> []
  [h, ...rest] -> [desugar_interp_hclause(h, op_names, op_arities, mt, file),
                   ...desugar_interp_hclauses(rest, op_names, op_arities, mt, file)]
}

fn desugar_interp_hclause(c: HClause, op_names: [String], op_arities: [OpAr], mt: [ModuleEntry], file: String) : HClause / Console + File = match c {
  HC(op_name, ps, body, ln, cl) ->
    HC(op_name, ps, desugar_interp_expr(body, op_names, op_arities, mt, file), ln, cl)
}

fn desugar_interp_hreturn_opt(opt: Option[HReturn], op_names: [String], op_arities: [OpAr], mt: [ModuleEntry], file: String) : Option[HReturn] / Console + File = match opt {
  None    -> None
  Some(r) -> Some(desugar_interp_hreturn(r, op_names, op_arities, mt, file))
}

fn desugar_interp_hreturn(r: HReturn, op_names: [String], op_arities: [OpAr], mt: [ModuleEntry], file: String) : HReturn / Console + File = match r {
  HR(name, body, ln, cl) -> HR(name, desugar_interp_expr(body, op_names, op_arities, mt, file), ln, cl)
}

fn lift_interp_string(span: String, body_start: Int, body_end: Int,
                       op_names: [String], op_arities: [OpAr], mt: [ModuleEntry], file: String,
                       line: Int, col: Int) : ExprKind / Console + File {

  let parts = iscan_collect(span, body_end,
                             IScan { parts: [], lit_start: body_start, i: body_start })
  let part_exprs = map(parts, (p: IPart) => interp_part_to_expr(p, op_names, op_arities, mt, file, line, col))
  ECall(mk_expr(EVar("string_concat_all"), line, col),
        [mk_expr(EList(map(part_exprs, (e: Expr) => ElPlain(e))), line, col)])
}

fn interp_part_to_expr(p: IPart, op_names: [String], op_arities: [OpAr],
                        mt: [ModuleEntry], file: String,
                        line: Int, col: Int) : Expr / Console + File {

  match p {
    IpLit(_, raw_quoted) -> mk_expr(EStr(raw_quoted, false), line, col)
    IpExp(expr_src) -> {
      let inner = match parse_interp_expr(expr_src) {
        # Issue #217: run the qualified-call resolver on the
        # freshly-parsed sub-expression before recursing into the
        # interp desugar. Without this step `list.sum(xs)` and other
        # `mod.fn(args)` shapes inside `#{...}` skip the rewrite the
        # rest of the program goes through and surface to the typer
        # as an unresolved EField on a module-name EVar.
        #
        # Issue #443: the protocol-call rewriter that turns
        # `EVar("eq")` into `EVar("__proto_eq")` runs inside
        # `lower_protocols`, but the freshly-parsed sub-expression
        # we surface here was still locked inside a string span at
        # that point. The driver re-runs `rename_proto_calls_decls`
        # on the post-interp-desugar decl stream so the surfaced
        # references go through the same arity-aware, scope-aware
        # rewrite the rest of the program got.
        Some(e) -> desugar_interp_expr(rqc_expr(e, [], mt, file),
                                         op_names, op_arities, mt, file)
        None    -> mk_expr(EStr("\"\"", false), line, col)
      }
      # The post-rename dispatcher name (`__proto_show`) bypasses the
      # rename pass that already ran inside lower_protocols. The
      # post-inference rewrite recognises this prefixed form.
      mk_expr(ECall(mk_expr(EVar(proto_dispatcher_name("show")), line, col),
                     [inner]),
              line, col)
    }
  }
}

#[doc("Emit-layer entry point emit_program")]
pub fn emit_program(file: String, src: String, raw_decls: [Decl], bmode: BuildMode, target_origin: Option[String], regions: [RegionMark]) : String / Console {

  # m7a #6c: rewrite `Eff.op(args)` callees from `EField(EVar(Eff), op)`
  # to `EVar("Eff.op")` before code emission. The typer (synth_op_call_with_scheme)
  # produces this form internally, but check_infer is a diagnostic-only
  # pass — it does not propagate the rewritten AST back to all_decls.
  # This standalone walker closes the gap; the next pipeline iteration
  # (Doc C §*Pipeline order and desugaring*) will fold it into a proper
  # post-resolve desugar pass.
  let alias_resolved = rewrite_alias_decls(raw_decls)
  let eff_names = collect_effect_names(alias_resolved)
  let decls = desugar_op_calls_decls(alias_resolved, eff_names)
  let fns = register_fn_decls(decls)
  let variants = register_variants(decls)
  let op_quals = collect_op_qualified_names(decls)
  let globals = build_globals(fns, variants, eff_names, op_quals)
  let st0 = lc_new(globals)
  let st = collect_decls(decls, st0)
  let lams = st.lams
  let clauses_info = st.clauses
  let header = "/* generated by kaikai stage 2 */\n#include \"runtime.h\"\n\n"
  let eff_structs = effect_struct_decls(decls)
  # R9: env typedefs come after the EvE structs (no dependency between
  # them — env structs are pure plain-old-data, EvE has the void *env)
  # but before the clause forwards (whose bodies cast `self->env` to
  # the env type) and before the install-site stmt-expressions emitted
  # inside fn bodies.
  let env_structs = emit_handle_env_typedefs(clauses_info)
  let clause_fwd = emit_clause_forwards(clauses_info)
  let fwd = fn_forward_decls(decls, fns)
  let thunk_fwd = thunk_forward_decls(decls)
  let lam_fwd = emit_lam_forward_decls(lams)
  # Top-level emission runs with an empty lexical scope; each fn /
  # lambda / clause / test body seeds its own scope from the params
  # (and captures, where applicable) before recursing into the body.
  # m4c #4: `clauses_info` (built above) is the side table threaded
  # through the emit walker so install code (`emit_clause_assignments`)
  # can look up the enclosing fn name stamped at collect time on each
  # `ClauseInfo` and mint matching prefixed C symbols.
  let cls = clauses_info
  # Lane linus-a: the four invariant context fields are built once here
  # and bundled with an empty top-level lexical scope. Each fn / lambda /
  # clause / test body seeds its own scope from its params before
  # recursing, so the entry `lcs` is `[]`.
  let cx = EmitCtx { lcs: [], fns: fns, variants: variants, lams: lams, cls: cls,
                     regions: regions, in_region: false }
  let bodies = fn_bodies(src, decls, cx)
  let lam_bodies = emit_lam_helpers(src, lams, fns, variants, cls)
  let clause_bodies = emit_clause_bodies(src, clauses_info, cx)
  let tests = emit_all_tests(src, decls, cx, target_origin)
  let benches = emit_all_benches(src, decls, cx, target_origin)
  let checks = emit_all_checks(src, decls, cx, target_origin)
  let main_wr = emit_main_wrapper(decls, bmode, variants, fns)
  concat_all([header, eff_structs, env_structs, clause_fwd, fwd, "\n", thunk_fwd, "\n", lam_fwd, "\n", bodies, lam_bodies, clause_bodies, tests, benches, checks, main_wr])
}

# ====================================================================
# semantic types (M2a)
# ====================================================================
#
# The checker uses `Ty` for semantic (resolved) types. This is distinct
# from the syntactic `TypeExpr` carried on AST nodes. M2a introduces
# the representation plus a resolver from TypeExpr to Ty and a
# signature extractor for top-level decls; actual type inference lands
# in M2b+.

fn row_labels_of_rls_with_tparams(ls: [RowLabel], binds: [TPBind]) : [Label] {
  match ls {
    [] -> []
    [rl, ...rest] -> match rl {
      RL(name, ts) -> [
        Label { eff: name, ty_args: map(ts, (te) => resolve_ty_with_tparams(te, binds)) },
        ...row_labels_of_rls_with_tparams(rest, binds)
      ]
    }
  }
}

fn row_of_expr_with_tparams(re: RowExpr, binds: [TPBind]) : Row {
  match re {
    REmpty -> row_empty()
    RClosed(labels) -> Row {
      labels: row_labels_of_rls_with_tparams(labels, binds),
      tail: None,
      display_alias: None
    }
    # m7b #12: row variables in user-written signatures resolve to
    # a row-variable id via `mk_rvbinds`; this helper takes only a
    # tparam binding context and is currently unused (defined for
    # the parametric-effect op-decl path). Pre-fill with a
    # placeholder tail to satisfy the exhaustiveness checker; if
    # this branch is ever hit, callers should switch to
    # `row_of_expr_with_rbinds` instead.
    ROpen(_, labels) -> Row {
      labels: row_labels_of_rls_with_tparams(labels, binds),
      tail: Some(-1),
      display_alias: None
    }
  }
}

# m7b #1b — closed effect aliases (Doc A §*Open questions* #5).
# An effect alias `type Io = Console + Stdin + Env + File` is a name
# that expands to a fixed label set in row position. The resolver
# performs a DFS expansion before any RowExpr is consumed; cycles and
# non-effect labels in alias bodies are rejected here. After
# rewriting, RowExpr.RClosed labels reference only declared effects.
#
# AliasCand: candidate alias decl harvested from the AST.
#   name     — the type-decl name
#   raw      — the labels as written (effects or other alias names)
#   explicit — true for `TBEffectAlias` (explicit `+` form); false for
#              `TBAlias(TyName(n, []))` (single-name form). Implicit
#              candidates whose label is not an effect/alias are
#              silently treated as regular type aliases instead of
#              effect aliases. Cycles are still rejected for both.
#   line/col — source position for diagnostics.

# m7b #1b — closed effect aliases (Doc A §*Open questions* #5).
# An effect alias `type Io = Console + Stdin + Env + File` is a name
# that expands to a fixed label set in row position. The resolver
# performs a DFS expansion before any RowExpr is consumed; cycles and
# non-effect labels in alias bodies are rejected here. After
# rewriting, RowExpr.RClosed labels reference only declared effects.
#
# AliasCand: candidate alias decl harvested from the AST.
#   name     — the type-decl name
#   raw      — the labels as written (effects or other alias names)
#   explicit — true for `TBEffectAlias` (explicit `+` form); false for
#              `TBAlias(TyName(n, []))` (single-name form). Implicit
#              candidates whose label is not an effect/alias are
#              silently treated as regular type aliases instead of
#              effect aliases. Cycles are still rejected for both.
#   line/col — source position for diagnostics.
#[doc("b #1b — closed effect aliases (Doc A §*Open questions* #5). An effect alias `type Io = Console + Stdin + Env + File` is a name that expands to a fixed label set in row…")]
pub fn collect_alias_cands(decls: [Decl]) : [AliasCand] {
  match decls {
    [] -> []
    [d, ...rest] -> {
      let here = match d {
        DType(_, name, _, body, line, col, _) -> match body {
          TBEffectAlias(labels) -> [AC(name, labels, true, line, col)]
          TBAlias(ty) -> match ty.tkind {
            TyName(n, targs) ->
              if targs == [] { [AC(name, [n], false, line, col)] }
              else { [] }
            _ -> []
          }
          _ -> []
        }
        _ -> []
      }
      list_append(here, collect_alias_cands(rest))
    }
  }
}

fn cand_names_of(cands: [AliasCand]) : [String] {
  match cands {
    [] -> []
    [c, ...rest] -> match c {
      AC(n, _, _, _, _) -> [n, ...cand_names_of(rest)]
    }
  }
}

fn find_alias_cand(cands: [AliasCand], name: String) : Option[AliasCand] {
  match cands {
    [] -> None
    [c, ...rest] -> match c {
      AC(n, _, _, _, _) -> if n == name { Some(c) } else { find_alias_cand(rest, name) }
    }
  }
}

fn alias_status(entries: [AEntry], name: String) : AStatus {
  match entries {
    [] -> AsTodo
    [e, ...rest] -> match e {
      AEnt(en, es) -> if en == name { es } else { alias_status(rest, name) }
    }
  }
}

fn alias_set_status(entries: [AEntry], name: String, status: AStatus) : [AEntry] {
  match entries {
    [] -> [AEnt(name, status)]
    [e, ...rest] -> match e {
      AEnt(en, es) ->
        if en == name { [AEnt(en, status), ...rest] }
        else { [AEnt(en, es), ...alias_set_status(rest, name, status)] }
    }
  }
}

fn prepend_rev_strs(xs: [String], acc: [String]) : [String] {
  match xs {
    [] -> acc
    [x, ...rest] -> prepend_rev_strs(rest, [x, ...acc])
  }
}

fn dedup_strs(xs: [String]) : [String] = dedup_strs_loop(xs, [])

fn dedup_strs_loop(xs: [String], acc: [String]) : [String] {
  match xs {
    [] -> list_reverse(acc)
    [x, ...rest] ->
      if list_has(acc, x) { dedup_strs_loop(rest, acc) }
      else { dedup_strs_loop(rest, [x, ...acc]) }
  }
}

fn cand_pos(cands: [AliasCand], name: String) : AliasPos {
  match find_alias_cand(cands, name) {
    None -> AliasPos { line: 0, col: 0 }
    Some(c) -> match c {
      AC(_, _, _, ln, co) -> AliasPos { line: ln, col: co }
    }
  }
}

fn resolve_alias(name: String, cands: [AliasCand], cand_ns: [String],
                 eff_names: [String], file: String, st: AliasResolveState) : AliasResolveOne / Console + File {


  match alias_status(st.entries, name) {
    AsDone(labels) -> AliasResolveOne { st: st, r: Some(labels) }
    AsFail -> AliasResolveOne { st: st, r: None }
    AsActive -> {
      let pos = cand_pos(cands, name)
      diag_error(file, pos.line, pos.col,
        string_concat("cyclic effect alias: ", name))
      diag_note("an alias can only expand to declared effects, not back to itself")
      diag_help("break the cycle: list each effect explicitly in the body of `type #{name} = ...`")
      let st2 = AliasResolveState {
        entries: alias_set_status(st.entries, name, AsFail),
        errs:    st.errs + 1
      }
      AliasResolveOne { st: st2, r: None }
    }
    AsTodo -> {
      match find_alias_cand(cands, name) {
        None -> AliasResolveOne { st: st, r: None }
        Some(c) -> match c {
          AC(_, raw, explicit, line, col) -> {
            let entries1 = alias_set_status(st.entries, name, AsActive)
            let st1 = AliasResolveState { entries: entries1, errs: st.errs }
            let r = resolve_alias_labels(raw, cands, cand_ns, eff_names, file,
                                         name, explicit, line, col, st1, [])
            match r.r {
              None -> {
                let entries2 = alias_set_status(r.st.entries, name, AsFail)
                AliasResolveOne { st: AliasResolveState { entries: entries2, errs: r.st.errs }, r: None }
              }
              Some(labels) -> {
                let unique = dedup_strs(labels)
                let entries2 = alias_set_status(r.st.entries, name, AsDone(unique))
                AliasResolveOne { st: AliasResolveState { entries: entries2, errs: r.st.errs }, r: Some(unique) }
              }
            }
          }
        }
      }
    }
  }
}

fn resolve_alias_labels(raw: [String], cands: [AliasCand], cand_ns: [String],
                        eff_names: [String], file: String,
                        parent: String, explicit: Bool, pline: Int, pcol: Int,
                        st: AliasResolveState, acc: [String]) : AliasResolveOne / Console + File {


  match raw {
    [] -> AliasResolveOne { st: st, r: Some(list_reverse(acc)) }
    [label, ...rest] -> {
      if list_has(eff_names, label) {
        resolve_alias_labels(rest, cands, cand_ns, eff_names, file, parent,
                             explicit, pline, pcol, st, [label, ...acc])
      } else if list_has(cand_ns, label) {
        let r = resolve_alias(label, cands, cand_ns, eff_names, file, st)
        match r.r {
          None -> AliasResolveOne { st: r.st, r: None }
          Some(sub) ->
            resolve_alias_labels(rest, cands, cand_ns, eff_names, file, parent,
                                 explicit, pline, pcol, r.st,
                                 prepend_rev_strs(sub, acc))
        }
      } else {
        if explicit {
          diag_error(file, pline, pcol,
            concat_all(["unknown effect in alias body: ", label,
                        " (declared as part of `", parent, "`)"]))
          let st1 = AliasResolveState { entries: st.entries, errs: st.errs + 1 }
          AliasResolveOne { st: st1, r: None }
        } else {
          AliasResolveOne { st: st, r: None }
        }
      }
    }
  }
}

#[doc("Emit-layer entry point resolve_alias_cands")]
pub fn resolve_alias_cands(cands: [AliasCand], eff_names: [String], file: String) : AliasResolution / Console + File {


  let cand_ns = cand_names_of(cands)
  resolve_alias_cands_loop(cands, cand_ns, eff_names, file,
                           AliasResolveState { entries: [], errs: 0 }, cands, [])
}

fn resolve_alias_cands_loop(all_cands: [AliasCand], cand_ns: [String],
                            eff_names: [String], file: String,
                            st: AliasResolveState, todo: [AliasCand],
                            acc: [AliasResult]) : AliasResolution / Console + File {


  match todo {
    [] -> AliasResolution { aliases: list_reverse(acc), errs: st.errs }
    [c, ...rest] -> match c {
      AC(name, _, _, _, _) -> {
        let r = resolve_alias(name, all_cands, cand_ns, eff_names, file, st)
        let acc1 = match r.r {
          Some(labels) -> [AR(name, labels), ...acc]
          None -> acc
        }
        resolve_alias_cands_loop(all_cands, cand_ns, eff_names, file, r.st, rest, acc1)
      }
    }
  }
}

fn find_alias(aliases: [AliasResult], name: String) : Option[AliasResult] {
  match aliases {
    [] -> None
    [a, ...rest] -> match a {
      AR(n, _) -> if n == name { Some(a) } else { find_alias(rest, name) }
    }
  }
}

# Substitute every alias name in `labels` with its expanded form.
# Effect names pass through unchanged. Duplicates introduced by
# expansion are removed by the caller.

# Substitute every alias name in `labels` with its expanded form.
# Effect names pass through unchanged. Duplicates introduced by
# expansion are removed by the caller.
fn expand_label_list(labels: [String], aliases: [AliasResult]) : [String] {
  match labels {
    [] -> []
    [l, ...rest] -> {
      let here = match find_alias(aliases, l) {
        Some(AR(_, expanded)) -> expanded
        None -> [l]
      }
      list_append(here, expand_label_list(rest, aliases))
    }
  }
}

fn expand_aliases_in_row(re: RowExpr, aliases: [AliasResult]) : RowExpr {
  match re {
    REmpty -> REmpty
    RClosed(labels) -> RClosed(dedup_row_labels(expand_row_labels(labels, aliases)))
    ROpen(rv, labels) -> ROpen(rv, dedup_row_labels(expand_row_labels(labels, aliases)))
  }
}

# m7b #1 — alias expansion. Aliases (`type Io = Console + Stdin + ...`)
# only resolve plain non-parametric names; if the user wrote
# `Reader[Int]` we leave the label alone since aliases over
# parameterised effects (`type DbReader = Reader[DbConfig]`) are
# out of scope for m7b #11. Bare names that match an alias expand
# into a list of bare-name labels.

# m7b #1 — alias expansion. Aliases (`type Io = Console + Stdin + ...`)
# only resolve plain non-parametric names; if the user wrote
# `Reader[Int]` we leave the label alone since aliases over
# parameterised effects (`type DbReader = Reader[DbConfig]`) are
# out of scope for m7b #11. Bare names that match an alias expand
# into a list of bare-name labels.
fn expand_row_labels(ls: [RowLabel], aliases: [AliasResult]) : [RowLabel] {
  match ls {
    [] -> []
    [l, ...rest] -> match l {
      RL(name, []) -> {
        let here = match find_alias(aliases, name) {
          Some(AR(_, expanded)) -> map(expanded, (n) => RL(n, []))
          None -> [l]
        }
        list_append(here, expand_row_labels(rest, aliases))
      }
      # Parameterised label: pass through unchanged (no alias is
      # registered with type args today).
      _ -> [l, ...expand_row_labels(rest, aliases)]
    }
  }
}

fn row_label_eq(a: RowLabel, b: RowLabel) : Bool {
  match a {
    RL(an, _) -> match b {
      RL(bn, _) -> an == bn
    }
  }
}

fn dedup_row_labels(ls: [RowLabel]) : [RowLabel] {
  dedup_row_labels_loop(ls, [], [])
}

fn dedup_row_labels_loop(ls: [RowLabel], seen: [String], acc: [RowLabel]) : [RowLabel] {
  match ls {
    [] -> list_reverse(acc)
    [h, ...rest] -> match h {
      RL(n, targs) -> {
        # Issue #472 — parametric effects (e.g. `Actor[Request]` vs
        # `Actor[Reply]`) must NOT collapse to a single label. Key by
        # name+rendered-args so each instantiation survives dedup; bare
        # labels (no args) keep using the name alone.
        # NOTE: the field is named `targs` not `args` because `args` is a
        # prelude builtin (cli argv) and stage 1 wrongly resolves the
        # local binding to that — see project_kaikai_param_args_shadow
        # memo.
        let key = match targs {
          [] -> n
          _  -> concat_all([n, "[", join_with(map(targs, cmt_type_expr_display), ","), "]"])
        }
        if list_has(seen, key) {
          dedup_row_labels_loop(rest, seen, acc)
        } else {
          dedup_row_labels_loop(rest, [key, ...seen], [h, ...acc])
        }
      }
    }
  }
}

fn expand_aliases_in_decl(d: Decl, aliases: [AliasResult]) : Decl {
  match d {
    DFn(p, n, tps, params, ret, rexpr, body, l, c, mo) ->
      DFn(p, n, tps, params, ret, expand_aliases_in_row(rexpr, aliases), body, l, c, mo)
    _ -> d
  }
}

#[doc("Emit-layer entry point expand_aliases_in_decls")]
pub fn expand_aliases_in_decls(decls: [Decl], aliases: [AliasResult]) : [Decl] {
  match decls {
    [] -> []
    [d, ...rest] -> [expand_aliases_in_decl(d, aliases),
                     ...expand_aliases_in_decls(rest, aliases)]
  }
}

# === issue #376: transparent type aliases for `type Foo = T` ===
#
# Restores the alias contract from `docs/kaikai-minimal.md`: when the
# RHS of a `type Foo = T` declaration is a single TypeExpr (no `|`),
# `Foo` is interchangeable with `T` in every type position. The
# regression introduced by issue #187 (sum/union unification) treated
# these as nominal one-component unions, breaking
# `type Age = Int`, `type Env = [(String, Real)]`, etc.
#
# Rule: single-component (`TBAlias`) bodies that are NOT effect aliases
# are expanded structurally.
#   - Effect aliases: `type Console = Stdout + Stderr` (`TBEffectAlias`)
#     plus the single-name form `type Foo = SomeEffect` already
#     resolved as effect by `resolve_alias_cands`. Filtered by name.
#   - Refinement aliases (`type Pos = Int where p`) expand to the
#     inline `TyRefine(Int, p)` form at every use site (closes #449
#     and #505). The `__ref_pred_X` synth fn and the pattern-narrow
#     lowering run on the raw decl stream before the expansion
#     fires, so they still bind against the alias name; expansion
#     only rewrites the `TyName("X", [])` uses that survive in
#     signatures and bindings.
# Multi-component `type X = A | B` (`TBSum`) keeps #187 semantics.
#
# The expansion is iterative: each pass walks every TypeExpr in the
# decl stream and rewrites a `TyName(name, args)` whose `name` is a
# transparent alias into the alias body, substituting the alias's
# tparams. Aliases that mention other aliases on their RHS resolve
# transitively via repeated passes until a fixpoint or a cycle bound
# is hit. A simple iteration cap (length of the alias table) bounds
# work under cycles; cycle errors are reported by the caller via the
# `infer_program` cascade if any TyCon survives.

# `TAEntry` records one transparent alias.
#   name     — the alias type name (e.g. "Age")
#   tparams  — declared type parameter names (e.g. ["T"] for
#              `type Predicate[T] = (T) -> Bool`); empty for
#              `type Age = Int`
#   body     — the right-hand TypeExpr

# `TAEntry` records one transparent alias.
#   name     — the alias type name (e.g. "Age")
#   tparams  — declared type parameter names (e.g. ["T"] for
#              `type Predicate[T] = (T) -> Bool`); empty for
#              `type Age = Int`
#   body     — the right-hand TypeExpr
#[doc("A transparent type-alias entry: alias name, type params, and the right-hand TypeExpr it expands to.")]
pub type TAEntry = TAE(String, [String], TypeExpr)

#[doc("Emit-layer entry point collect_transparent_aliases")]
pub fn collect_transparent_aliases(decls: [Decl], eff_names: [String]) : [TAEntry] =
  collect_transparent_aliases_loop(decls, eff_names, [])

fn collect_transparent_aliases_loop(decls: [Decl], eff_names: [String],
                                     acc: [TAEntry]) : [TAEntry] {
  match decls {
    [] -> list_reverse(acc)
    [d, ...rest] -> {
      let here = transparent_alias_of_decl(d, eff_names)
      let acc1 = match here {
        Some(e) -> [e, ...acc]
        None -> acc
      }
      collect_transparent_aliases_loop(rest, eff_names, acc1)
    }
  }
}

fn transparent_alias_of_decl(d: Decl, eff_names: [String]) : Option[TAEntry] {
  match d {
    DType(_, name, tparams, body, _, _, _) -> match body {
      TBAlias(t) -> match t.tkind {
        # Single-name body that resolves to an effect: skip. Effect
        # aliasing is the legacy semantics of TBAlias single-name
        # form, threaded by `resolve_alias_cands` + the row pass.
        TyName(n, []) -> if list_has(eff_names, n) { None }
                         else { Some(TAE(name, tparams, t)) }
        # Refinement aliases (`type Pos = Int where p`) expand to
        # their inline form `TyRefine(Int, p)` at every use site.
        # `synthesize_refine_pred_fns` + `lower_pattern_narrow_decls`
        # have already run by the time expansion fires, so the
        # synthesised `__ref_pred_X` fn survives and the per-pattern
        # narrow lowering has resolved the alias name against the
        # raw decl list. Closes #449 and #505.
        _ -> Some(TAE(name, tparams, t))
      }
      _ -> None
    }
    _ -> None
  }
}

fn ta_lookup(table: [TAEntry], name: String) : Option[TAEntry] {
  match table {
    [] -> None
    [e, ...rest] -> match e {
      TAE(n, _, _) -> if n == name { Some(e) } else { ta_lookup(rest, name) }
    }
  }
}

# Substitute tparams in a body TypeExpr with the supplied args. The
# tparam map associates each declared tparam name with the
# instantiation TypeExpr at the use site.

# Substitute tparams in a body TypeExpr with the supplied args. The
# tparam map associates each declared tparam name with the
# instantiation TypeExpr at the use site.
type TPSubst = TPS(String, TypeExpr)

fn build_tp_subst(tparams: [String], args: [TypeExpr]) : [TPSubst] {
  match tparams {
    [] -> []
    [p, ...prest] -> match args {
      [] -> []
      [a, ...arest] -> [TPS(p, a), ...build_tp_subst(prest, arest)]
    }
  }
}

fn tp_subst_lookup(subst: [TPSubst], name: String) : Option[TypeExpr] {
  match subst {
    [] -> None
    [s, ...rest] -> match s {
      TPS(n, te) -> if n == name { Some(te) } else { tp_subst_lookup(rest, name) }
    }
  }
}

fn apply_tp_subst_te(te: TypeExpr, subst: [TPSubst]) : TypeExpr {
  match te.tkind {
    TyName(name, targs) -> {
      let targs1 = apply_tp_subst_te_list(targs, subst)
      match tp_subst_lookup(subst, name) {
        Some(rep) -> if targs1 == [] { rep }
                     else {
                       # `Predicate[T] = (T) -> Bool` instantiated with
                       # `Predicate[Int]` plain-name lookup substitutes
                       # `T` itself, not a TyName-with-args. Higher-kinded
                       # aliases are out of scope; the type-args-on-tparam
                       # case is not supported and falls through.
                       TypeExpr { tkind: TyName(name, targs1), line: te.line, col: te.col }
                     }
        None -> TypeExpr { tkind: TyName(name, targs1), line: te.line, col: te.col }
      }
    }
    TyList(inner) ->
      TypeExpr { tkind: TyList(apply_tp_subst_te(inner, subst)),
                  line: te.line, col: te.col }
    TyFn(ps, ret, row) ->
      TypeExpr { tkind: TyFn(apply_tp_subst_te_list(ps, subst),
                              apply_tp_subst_te(ret, subst),
                              apply_tp_subst_row(row, subst)),
                  line: te.line, col: te.col }
    TyDim(base, u) ->
      TypeExpr { tkind: TyDim(apply_tp_subst_te(base, subst), u),
                  line: te.line, col: te.col }
    TyRefine(base, p) ->
      TypeExpr { tkind: TyRefine(apply_tp_subst_te(base, subst), p),
                  line: te.line, col: te.col }
  }
}

fn apply_tp_subst_te_list(tes: [TypeExpr], subst: [TPSubst]) : [TypeExpr] {
  match tes {
    [] -> []
    [t, ...rest] -> [apply_tp_subst_te(t, subst), ...apply_tp_subst_te_list(rest, subst)]
  }
}

# Apply a tparam substitution to a RowExpr. When a tparam name appears
# as the row variable (`ROpen("e", labels)`), replace the tail with the
# substituted TypeExpr, treating an uppercase `TyName(NN, [])` argument
# as a single effect label (`labels + [RL(NN, [])]`, closed). Lowercase
# `TyName(nm, [])` is treated as another row variable name. Any more
# complex replacement (e.g. `TyName("Foo", [Int])`) leaves the row
# unchanged — that case is rejected by `resolve_ty_with_binds` later
# with a normal "unknown row variable" diagnostic instead of a panic.
#
# Closes #624 (alias with row variable + concrete row annotation): the
# alias body `() -> Option[t] / e` instantiated at `Foo[Int, Console]`
# now rewrites the row to `RClosed([Console])`, where before the
# substitution skipped the row entirely and downstream resolve produced
# a row tail of `Some(-1)` that paniced in `subst_row_lookup`.

# Apply a tparam substitution to a RowExpr. When a tparam name appears
# as the row variable (`ROpen("e", labels)`), replace the tail with the
# substituted TypeExpr, treating an uppercase `TyName(NN, [])` argument
# as a single effect label (`labels + [RL(NN, [])]`, closed). Lowercase
# `TyName(nm, [])` is treated as another row variable name. Any more
# complex replacement (e.g. `TyName("Foo", [Int])`) leaves the row
# unchanged — that case is rejected by `resolve_ty_with_binds` later
# with a normal "unknown row variable" diagnostic instead of a panic.
#
# Closes #624 (alias with row variable + concrete row annotation): the
# alias body `() -> Option[t] / e` instantiated at `Foo[Int, Console]`
# now rewrites the row to `RClosed([Console])`, where before the
# substitution skipped the row entirely and downstream resolve produced
# a row tail of `Some(-1)` that paniced in `subst_row_lookup`.
fn apply_tp_subst_row(r: RowExpr, subst: [TPSubst]) : RowExpr {
  match r {
    REmpty -> REmpty
    RClosed(labels) -> RClosed(apply_tp_subst_rls(labels, subst))
    ROpen(rv, labels) -> {
      let labels1 = apply_tp_subst_rls(labels, subst)
      match tp_subst_lookup(subst, rv) {
        None -> ROpen(rv, labels1)
        Some(rep) -> match rep.tkind {
          TyName(nm, []) -> {
            if name_first_is_upper(nm) {
              RClosed(label_concat_rls(labels1, [RL(nm, [])]))
            } else {
              ROpen(nm, labels1)
            }
          }
          _ -> ROpen(rv, labels1)
        }
      }
    }
  }
}

fn apply_tp_subst_rls(ls: [RowLabel], subst: [TPSubst]) : [RowLabel] {
  match ls {
    [] -> []
    [rl, ...rest] -> match rl {
      RL(name, ts) -> [
        RL(name, apply_tp_subst_te_list(ts, subst)),
        ...apply_tp_subst_rls(rest, subst)
      ]
    }
  }
}

fn label_concat_rls(a: [RowLabel], b: [RowLabel]) : [RowLabel] {
  match a {
    [] -> b
    [h, ...rest] -> [h, ...label_concat_rls(rest, b)]
  }
}

fn name_first_is_upper(s: String) : Bool {
  match char_at(s, 0) {
    Some(c) -> c >= 'A' and c <= 'Z'
    None -> false
  }
}

# Single-step expansion of a TypeExpr against the alias table. Returns
# the rewritten TypeExpr. Recursion bound by `fuel` caps cycles.

# Single-step expansion of a TypeExpr against the alias table. Returns
# the rewritten TypeExpr. Recursion bound by `fuel` caps cycles.
fn expand_ta_te(te: TypeExpr, table: [TAEntry], fuel: Int) : TypeExpr {
  if fuel <= 0 { te }
  else { match te.tkind {
    TyName(name, targs) -> {
      let targs1 = expand_ta_te_list(targs, table, fuel)
      match ta_lookup(table, name) {
        Some(TAE(_, tparams, body)) -> {
          let subst = build_tp_subst(tparams, targs1)
          let inst = apply_tp_subst_te(body, subst)
          # Re-walk the instantiated body so a chain `type A = B; type B = Int`
          # collapses to Int. Decrement fuel on each unfold.
          expand_ta_te(inst, table, fuel - 1)
        }
        None -> TypeExpr { tkind: TyName(name, targs1), line: te.line, col: te.col }
      }
    }
    TyList(inner) ->
      TypeExpr { tkind: TyList(expand_ta_te(inner, table, fuel)),
                  line: te.line, col: te.col }
    TyFn(ps, ret, row) ->
      TypeExpr { tkind: TyFn(expand_ta_te_list(ps, table, fuel),
                              expand_ta_te(ret, table, fuel),
                              expand_ta_row(row, table, fuel)),
                  line: te.line, col: te.col }
    TyDim(base, u) ->
      TypeExpr { tkind: TyDim(expand_ta_te(base, table, fuel), u),
                  line: te.line, col: te.col }
    TyRefine(base, p) ->
      TypeExpr { tkind: TyRefine(expand_ta_te(base, table, fuel), p),
                  line: te.line, col: te.col }
  } }
}

fn expand_ta_te_list(tes: [TypeExpr], table: [TAEntry], fuel: Int) : [TypeExpr] {
  match tes {
    [] -> []
    [t, ...rest] -> [expand_ta_te(t, table, fuel),
                     ...expand_ta_te_list(rest, table, fuel)]
  }
}

# Walk a RowExpr looking for TypeExprs (inside label ty_args) to expand.
# The row tail is a name — not a TypeExpr — so no alias substitution
# happens there. Label ty_args (`Reader[Int]`) carry TypeExprs that
# may mention aliases.

# Walk a RowExpr looking for TypeExprs (inside label ty_args) to expand.
# The row tail is a name — not a TypeExpr — so no alias substitution
# happens there. Label ty_args (`Reader[Int]`) carry TypeExprs that
# may mention aliases.
fn expand_ta_row(r: RowExpr, table: [TAEntry], fuel: Int) : RowExpr {
  match r {
    REmpty -> REmpty
    RClosed(labels) -> RClosed(expand_ta_rls(labels, table, fuel))
    ROpen(rv, labels) -> ROpen(rv, expand_ta_rls(labels, table, fuel))
  }
}

fn expand_ta_rls(ls: [RowLabel], table: [TAEntry], fuel: Int) : [RowLabel] {
  match ls {
    [] -> []
    [rl, ...rest] -> match rl {
      RL(name, ts) -> [
        RL(name, expand_ta_te_list(ts, table, fuel)),
        ...expand_ta_rls(rest, table, fuel)
      ]
    }
  }
}

# Walk every Decl, expanding transparent aliases in every TypeExpr.
# Mirrors qualtype_decl shape but rewrites TypeExprs only — no Console
# diagnostics (all errors deferred to downstream typer cascade).

# Walk every Decl, expanding transparent aliases in every TypeExpr.
# Mirrors qualtype_decl shape but rewrites TypeExprs only — no Console
# diagnostics (all errors deferred to downstream typer cascade).
#[doc("Walk every Decl, expanding transparent aliases in every TypeExpr. Mirrors qualtype_decl shape but rewrites TypeExprs only — no Console diagnostics (all errors deferred to…")]
pub fn expand_ta_decls(decls: [Decl], table: [TAEntry]) : [Decl] {
  let fuel = list_length(table) + 1
  expand_ta_decls_loop(decls, table, fuel)
}

fn expand_ta_decls_loop(decls: [Decl], table: [TAEntry], fuel: Int) : [Decl] {
  match decls {
    [] -> []
    [d, ...rest] -> [expand_ta_decl(d, table, fuel),
                     ...expand_ta_decls_loop(rest, table, fuel)]
  }
}

fn expand_ta_decl(d: Decl, table: [TAEntry], fuel: Int) : Decl {
  match d {
    DFn(p, n, tps, ps, ret_opt, row, body, l, c, mo) ->
      DFn(p, n, tps, expand_ta_params(ps, table, fuel),
          match ret_opt { None -> None Some(te) -> Some(expand_ta_te(te, table, fuel)) },
          row,
          expand_ta_expr(body, table, fuel), l, c, mo)
    DType(p, n, tps, body, l, c, mo) ->
      # Skip rewriting the alias's own DType body: keeping the original
      # decl preserves the alias name in `--ast` output and lets later
      # passes that consult it (refinement synth, dump) see the surface
      # form. Nominal record/sum bodies still get their field/variant
      # TypeExprs walked so a record field typed with an alias resolves.
      match body {
        TBAlias(_) -> d
        TBEffectAlias(_) -> d
        TBRecord(fs) ->
          DType(p, n, tps, TBRecord(expand_ta_fields(fs, table, fuel)), l, c, mo)
        TBSum(vs) ->
          DType(p, n, tps, TBSum(expand_ta_variants(vs, table, fuel)), l, c, mo)
      }
    DEffect(p, n, tps, ops, defblk, l, c) ->
      DEffect(p, n, tps, expand_ta_eops(ops, table, fuel), defblk, l, c)
    DProtocol(p, n, tps, ops, l, c) ->
      DProtocol(p, n, tps, expand_ta_pops(ops, table, fuel), l, c)
    DImpl(name, proto_args, ty, sub_decls, l, c) ->
      DImpl(name, expand_ta_te_list(proto_args, table, fuel),
            expand_ta_te(ty, table, fuel),
            expand_ta_decls_loop(sub_decls, table, fuel), l, c)
    DDerive(ps, inner, l, c) ->
      DDerive(ps, expand_ta_decl(inner, table, fuel), l, c)
    DUnstable(inner, l, c) ->
      DUnstable(expand_ta_decl(inner, table, fuel), l, c)
    DAttribPure(inner, l, c) ->
      DAttribPure(expand_ta_decl(inner, table, fuel), l, c)
    DAxiom(p, sm, n, cso, tps, ps, ret, row, l, c) ->
      DAxiom(p, sm, n, cso, tps, expand_ta_params(ps, table, fuel),
             expand_ta_te(ret, table, fuel), row, l, c)
    DConst(p, n, ty, body, l, c) ->
      DConst(p, n, expand_ta_te(ty, table, fuel),
              expand_ta_expr(body, table, fuel), l, c)
    DTest(n, body, l, c) -> DTest(n, expand_ta_expr(body, table, fuel), l, c)
    DBench(n, body, l, c) -> DBench(n, expand_ta_expr(body, table, fuel), l, c)
    DCheck(n, ps, body, l, c) ->
      DCheck(n, expand_ta_params(ps, table, fuel),
              expand_ta_expr(body, table, fuel), l, c)
    DImport(_, _, _) -> d
    DUnit(_, _, _, _, _) -> d
    DUse(_, _, _) -> d
    # DProtoImpl shape, registry-only nodes, etc. fall through if any
    # exist; the resolver is conservative about leaving unknown decl
    # shapes untouched.
  }
}

fn expand_ta_params(ps: [Param], table: [TAEntry], fuel: Int) : [Param] {
  match ps {
    [] -> []
    [p, ...rest] -> [expand_ta_param(p, table, fuel),
                     ...expand_ta_params(rest, table, fuel)]
  }
}

fn expand_ta_param(pm: Param, table: [TAEntry], fuel: Int) : Param =
  Param { pname: pm.pname,
          ptype: match pm.ptype {
            None -> None
            Some(te) -> Some(expand_ta_te(te, table, fuel))
          },
          pline: pm.pline, pcol: pm.pcol }

fn expand_ta_fields(fs: [FieldDecl], table: [TAEntry], fuel: Int) : [FieldDecl] {
  match fs {
    [] -> []
    [f, ...rest] -> match f {
      FD(is_pub, name, te) -> [FD(is_pub, name, expand_ta_te(te, table, fuel)),
                       ...expand_ta_fields(rest, table, fuel)]
    }
  }
}

fn expand_ta_variants(vs: [Variant], table: [TAEntry], fuel: Int) : [Variant] {
  match vs {
    [] -> []
    [v, ...rest] -> match v {
      Var(cname, vargs) -> [Var(cname, expand_ta_te_list(vargs, table, fuel)),
                             ...expand_ta_variants(rest, table, fuel)]
    }
  }
}

fn expand_ta_eops(ops: [EffectOp], table: [TAEntry], fuel: Int) : [EffectOp] {
  match ops {
    [] -> []
    [op, ...rest] -> match op {
      EOp(name, tps, ps, ret, l, c) ->
        [EOp(name, tps, expand_ta_params(ps, table, fuel),
              expand_ta_te(ret, table, fuel), l, c),
         ...expand_ta_eops(rest, table, fuel)]
    }
  }
}

fn expand_ta_pops(ops: [ProtoOp], table: [TAEntry], fuel: Int) : [ProtoOp] {
  match ops {
    [] -> []
    [op, ...rest] -> match op {
      POp(name, tps, ps, ret, l, c) ->
        [POp(name, tps, expand_ta_params(ps, table, fuel),
              expand_ta_te(ret, table, fuel), l, c),
         ...expand_ta_pops(rest, table, fuel)]
    }
  }
}

fn expand_ta_expr(e: Expr, table: [TAEntry], fuel: Int) : Expr =
  Expr { kind: expand_ta_expr_kind(e.kind, table, fuel),
         line: e.line, col: e.col, ty: e.ty, mode: e.mode }

fn expand_ta_expr_kind(k: ExprKind, table: [TAEntry], fuel: Int) : ExprKind {
  match k {
    EBlock(stmts, opt_final) ->
      EBlock(expand_ta_stmts(stmts, table, fuel),
             match opt_final {
               None -> None
               Some(fe) -> Some(expand_ta_expr(fe, table, fuel))
             })
    EMatch(scrut, arms) ->
      EMatch(expand_ta_expr(scrut, table, fuel),
             expand_ta_arms(arms, table, fuel))
    EVariantsOf(te, ns) ->
      EVariantsOf(expand_ta_te(te, table, fuel), ns)
    ELambda(ps, body) ->
      ELambda(expand_ta_params(ps, table, fuel),
              expand_ta_expr(body, table, fuel))
    EHandle(body, eff, ty_args, init_opt, alias_opt, clauses, ret_opt) ->
      EHandle(expand_ta_expr(body, table, fuel), eff,
              expand_ta_te_list(ty_args, table, fuel),
              match init_opt { None -> None Some(ie) -> Some(expand_ta_expr(ie, table, fuel)) },
              alias_opt,
              expand_ta_hclauses(clauses, table, fuel),
              match ret_opt {
                None -> None
                Some(r) -> Some(expand_ta_hreturn(r, table, fuel))
              })
    _ -> map_expr_kind(k, (sub) => expand_ta_expr(sub, table, fuel))
  }
}

fn expand_ta_arms(arms: [Arm], table: [TAEntry], fuel: Int) : [Arm] {
  match arms {
    [] -> []
    [a, ...rest] -> [expand_ta_arm(a, table, fuel),
                     ...expand_ta_arms(rest, table, fuel)]
  }
}

fn expand_ta_arm(a: Arm, table: [TAEntry], fuel: Int) : Arm {
  match a {
    Arm(pat, opt_guard, body) ->
      Arm(expand_ta_pat(pat, table, fuel),
          match opt_guard {
            None -> None
            Some(g) -> Some(expand_ta_expr(g, table, fuel))
          },
          expand_ta_expr(body, table, fuel))
  }
}

fn expand_ta_pat(pat: Pattern, table: [TAEntry], fuel: Int) : Pattern {
  match pat.pkind {
    PNarrow(name, te) ->
      Pattern { pkind: PNarrow(name, expand_ta_te(te, table, fuel)),
                 line: pat.line, col: pat.col }
    PVariant(name, subs) ->
      Pattern { pkind: PVariant(name, expand_ta_pat_list(subs, table, fuel)),
                 line: pat.line, col: pat.col }
    PVariantRecord(name, fs) ->
      Pattern { pkind: PVariantRecord(name, expand_ta_pfields(fs, table, fuel)),
                 line: pat.line, col: pat.col }
    PRecord(fs) ->
      Pattern { pkind: PRecord(expand_ta_pfields(fs, table, fuel)),
                 line: pat.line, col: pat.col }
    PList(subs, rest) ->
      Pattern { pkind: PList(expand_ta_pat_list(subs, table, fuel), rest),
                 line: pat.line, col: pat.col }
    PAs(name, inner) ->
      Pattern { pkind: PAs(name, expand_ta_pat(inner, table, fuel)),
                 line: pat.line, col: pat.col }
    _ -> pat
  }
}

fn expand_ta_pat_list(ps: [Pattern], table: [TAEntry], fuel: Int) : [Pattern] {
  match ps {
    [] -> []
    [p, ...rest] -> [expand_ta_pat(p, table, fuel),
                     ...expand_ta_pat_list(rest, table, fuel)]
  }
}

fn expand_ta_pfields(fs: [PField], table: [TAEntry], fuel: Int) : [PField] {
  match fs {
    [] -> []
    [f, ...rest] -> match f {
      PField(name, sub, sh) -> [PField(name, expand_ta_pat(sub, table, fuel), sh),
                                 ...expand_ta_pfields(rest, table, fuel)]
    }
  }
}

fn expand_ta_stmts(ss: [Stmt], table: [TAEntry], fuel: Int) : [Stmt] {
  match ss {
    [] -> []
    [s, ...rest] -> [expand_ta_stmt(s, table, fuel),
                     ...expand_ta_stmts(rest, table, fuel)]
  }
}

fn expand_ta_stmt(s: Stmt, table: [TAEntry], fuel: Int) : Stmt {
  match s {
    SLet(pat, ty_opt, e) ->
      SLet(expand_ta_pat(pat, table, fuel),
           match ty_opt {
             None -> None
             Some(te) -> Some(expand_ta_te(te, table, fuel))
           },
           expand_ta_expr(e, table, fuel))
    SVar(name, ty_opt, init, l, c) ->
      SVar(name,
           match ty_opt {
             None -> None
             Some(te) -> Some(expand_ta_te(te, table, fuel))
           },
           expand_ta_expr(init, table, fuel), l, c)
    SAssert(e, om) ->
      SAssert(expand_ta_expr(e, table, fuel),
              match om { None -> None Some(m) -> Some(expand_ta_expr(m, table, fuel)) })
    SExprStmt(e) -> SExprStmt(expand_ta_expr(e, table, fuel))
    SIndexAssign(t, ix, v, l, c) ->
      SIndexAssign(expand_ta_expr(t, table, fuel),
                    expand_ta_expr(ix, table, fuel),
                    expand_ta_expr(v, table, fuel), l, c)
    SUse(eff, l, c) -> SUse(eff, l, c)
  }
}

fn expand_ta_hclauses(cs: [HClause], table: [TAEntry], fuel: Int) : [HClause] {
  match cs {
    [] -> []
    [c, ...rest] -> match c {
      HC(name, ps, body, l, col) ->
        [HC(name, expand_ta_params(ps, table, fuel),
             expand_ta_expr(body, table, fuel), l, col),
         ...expand_ta_hclauses(rest, table, fuel)]
    }
  }
}

fn expand_ta_hreturn(r: HReturn, table: [TAEntry], fuel: Int) : HReturn {
  match r {
    HR(name, body, l, c) -> HR(name, expand_ta_expr(body, table, fuel), l, c)
  }
}

# === issue #647: mangle private prelude types so same-arity
# collisions with user-side redeclarations no longer leak into
# the prelude's own exhaustiveness checks. =====================
#
# Setup. Issue #643 / PR #646 made the variant table arity-aware
# (`Tree[k, v]` vs. `Tree`). That fix is sufficient when arities
# differ. When two same-arity sum types share a name across
# modules — concretely `stdlib/crypto/hash.kai`'s private
# `type SplitN = SplitOk | SplitShort` and a user redeclaration
# `type SplitN = LocalA | LocalB` — the arity discriminator no
# longer separates them. Pre-#647, the user's match was clean
# (sentinel marker) but the prelude code (`sha_take_n_loop`'s
# match on `SplitOk` / `SplitShort`) saw the user's `LocalA` /
# `LocalB` and failed exhaustiveness.
#
# Fix (issue #647, Option 1 — mangle in the declaring module).
# Every non-`pub` `DType T` whose home module is NOT the root
# file is renamed to `<module>::T` at the AST level, and every
# `TyName(T, args)` inside a decl whose home module is the SAME
# module is rewritten to `TyName(<module>::T, args)`. Decls of
# other modules and the root file never reference `T` (private
# types are not exported), so they remain untouched. The variant
# table lookup, the union summary, and the codegen ctor path all
# see the mangled return tycon for prelude variants and the bare
# name for user variants — distinct buckets, no leak in either
# direction.
#
# Why "Option 1" of the issue body and not Option 2 (per-module
# name scopes) — Option 2 would touch every TyEnv builder + every
# lookup site; Option 1 reuses the same TypeExpr-rewriter shape
# as `expand_ta_decls` and confines the change to a single
# pre-typer pass. The audit script's two skip-list entries
# (`SplitN`, `NB_FragR`) come off; future same-arity collisions
# between any two non-`pub` prelude types are also handled by
# construction (different modules → different mangled names).
#
# Pipeline placement. Runs AFTER `expand_ta_decls` (so transparent
# aliases have already been substituted; the mangler doesn't need
# to recurse into alias bodies) and BEFORE `infer_program` (so
# the typer sees the mangled names directly). Module home is
# recovered via the same `decl_home_hint_reset` algorithm
# `synth_refine_loop` uses, since `DType` carries no
# `module_origin` field of its own.

type PrivTyEntry = PTE(String, String, String)   # mod, bare, mangled

fn mangled_private_type_name(mod_name: String, bare: String) : String =
  concat_all([mod_name, "::", bare])

# Walk one prelude segment (a contiguous block of decls all
# belonging to module `mod_name`) and collect every non-`pub`
# DType into a PTE entry. Refinement aliases (TBAlias with
# TyRefine) are skipped because they cannot collide on the
# variant-table path (they expand to a `__ref_pred_X` fn and a
# scalar base type) — including them would risk renaming the
# synth fn target. Effect-alias bodies (TBEffectAlias) are
# similarly skipped: their names live in the effect namespace,
# not the type namespace the variant walker consumes.

# Walk one prelude segment (a contiguous block of decls all
# belonging to module `mod_name`) and collect every non-`pub`
# DType into a PTE entry. Refinement aliases (TBAlias with
# TyRefine) are skipped because they cannot collide on the
# variant-table path (they expand to a `__ref_pred_X` fn and a
# scalar base type) — including them would risk renaming the
# synth fn target. Effect-alias bodies (TBEffectAlias) are
# similarly skipped: their names live in the effect namespace,
# not the type namespace the variant walker consumes.
fn collect_private_segment_types(decls: [Decl], mod_name: String,
                                    acc: [PrivTyEntry]) : [PrivTyEntry] {
  match decls {
    [] -> acc
    [d, ...rest] -> {
      let acc1 = private_type_entry_of(d, mod_name, acc)
      collect_private_segment_types(rest, mod_name, acc1)
    }
  }
}

fn private_type_entry_of(d: Decl, home_mod: String,
                            acc: [PrivTyEntry]) : [PrivTyEntry] {
  match d {
    DType(is_pub, name, _, body, _, _, _) ->
      if is_pub { acc }
      else { match body {
        # Only sum types are mangled today. Records ride the
        # `rec_find` path which is bare-name-keyed and would need
        # a parallel rewrite — issue #643 retro item 2 already
        # tracks the record-side leak as a separate lane.
        # Mangling TBRecord here would rename the record's
        # nominal handle (e.g. `RxRangeParse`) without touching
        # the `rec_find` lookup, breaking field projection
        # (`res_first.st`) inside the same module.
        TBSum(_)    -> [PTE(home_mod, name,
                            mangled_private_type_name(home_mod, name)),
                        ...acc]
        _ -> acc
      } }
    _ -> acc
  }
}

fn priv_ty_lookup(entries: [PrivTyEntry], mod_name: String,
                     bare: String) : Option[String] {
  match entries {
    [] -> None
    [e, ...rest] -> match e {
      PTE(m, b, mangled) ->
        if m == mod_name and b == bare { Some(mangled) }
        else { priv_ty_lookup(rest, mod_name, bare) }
    }
  }
}

# Process the prelude as a per-segment list. Each segment is a
# `(mod_name, decls)` pair coming from `load_preludes`'s
# `PreludeSegment` accumulator, so the home module of every decl
# in the segment is unambiguous (no `decl_home_hint_reset`
# heuristic needed — that one fails to reset for a DType at the
# head of the root file because DType carries no `mo`).
#
# Per segment: collect the private-type entries, then rewrite
# every TypeExpr in every decl of THAT segment so internal
# references resolve to the mangled name. Decls of OTHER prelude
# segments stay intact (they cannot reference each other's
# private types — non-`pub` types are not exported). The root
# file's decls are not touched: they cannot reference a mangled
# prelude private type (those names are not exported), and the
# user is free to redeclare the same bare name as their own type
# without conflict.

# Process the prelude as a per-segment list. Each segment is a
# `(mod_name, decls)` pair coming from `load_preludes`'s
# `PreludeSegment` accumulator, so the home module of every decl
# in the segment is unambiguous (no `decl_home_hint_reset`
# heuristic needed — that one fails to reset for a DType at the
# head of the root file because DType carries no `mo`).
#
# Per segment: collect the private-type entries, then rewrite
# every TypeExpr in every decl of THAT segment so internal
# references resolve to the mangled name. Decls of OTHER prelude
# segments stay intact (they cannot reference each other's
# private types — non-`pub` types are not exported). The root
# file's decls are not touched: they cannot reference a mangled
# prelude private type (those names are not exported), and the
# user is free to redeclare the same bare name as their own type
# without conflict.
#[doc("Process the prelude as a per-segment list. Each segment is a `(mod_name, decls)` pair coming from `load_preludes`'s `PreludeSegment` accumulator, so the home module of every…")]
pub fn mangle_prelude_segments(decls: [Decl], segs: [PreludeSegment],
                              n_prelude: Int) : [Decl] {
  let prelude_part = pae_take(decls, n_prelude)
  let root_part = pae_drop(decls, n_prelude)
  let mangled_prelude = mangle_prelude_segments_loop(prelude_part, segs, [])
  list_append(mangled_prelude, root_part)
}

fn mangle_prelude_segments_loop(prelude_decls: [Decl],
                                   segs: [PreludeSegment],
                                   acc: [Decl]) : [Decl] {
  match segs {
    [] -> list_append(acc, prelude_decls)   # safety: leftover untouched
    [s, ...rest] -> match s {
      PSeg(mod_name, seg_template) -> {
        let n_seg = list_length(seg_template)
        let this_seg = pae_take(prelude_decls, n_seg)
        let remaining = pae_drop(prelude_decls, n_seg)
        let seg_entries = collect_private_segment_types(this_seg, mod_name, [])
        let mangled_seg =
          if seg_entries == [] { this_seg }
          else { mangle_one_segment(this_seg, seg_entries, mod_name, []) }
        mangle_prelude_segments_loop(remaining, rest,
                                        list_append(acc, mangled_seg))
      }
    }
  }
}

fn mangle_one_segment(decls: [Decl], entries: [PrivTyEntry],
                        mod_name: String, acc: [Decl]) : [Decl] {
  match decls {
    [] -> list_reverse(acc)
    [d, ...rest] -> {
      let d1 = mangle_one_decl(d, entries, mod_name)
      mangle_one_segment(rest, entries, mod_name, [d1, ...acc])
    }
  }
}

fn mangle_one_decl(d: Decl, entries: [PrivTyEntry], home_mod: String) : Decl {
  match d {
    DType(is_pub, name, tps, body, l, c, _) -> {
      let name1 = match priv_ty_lookup(entries, home_mod, name) {
        Some(m) -> m
        None    -> name
      }
      DType(is_pub, name1, tps,
            mangle_typebody(body, entries, home_mod), l, c, None)
    }
    DFn(p, n, tps, ps, ret_opt, row, body, l, c, mo) ->
      DFn(p, n, tps, mangle_params(ps, entries, home_mod),
          match ret_opt { None -> None
                          Some(te) -> Some(mangle_te(te, entries, home_mod)) },
          row,
          mangle_expr(body, entries, home_mod), l, c, mo)
    DAxiom(p, sm, n, cso, tps, ps, ret, row, l, c) ->
      DAxiom(p, sm, n, cso, tps, mangle_params(ps, entries, home_mod),
             mangle_te(ret, entries, home_mod), row, l, c)
    DConst(p, n, ty, body, l, c) ->
      DConst(p, n, mangle_te(ty, entries, home_mod),
              mangle_expr(body, entries, home_mod), l, c)
    DEffect(p, n, tps, ops, defblk, l, c) ->
      DEffect(p, n, tps, mangle_eops(ops, entries, home_mod), defblk, l, c)
    DProtocol(p, n, tps, ops, l, c) ->
      DProtocol(p, n, tps, mangle_pops(ops, entries, home_mod), l, c)
    DImpl(name, proto_args, ty, sub_decls, l, c) ->
      DImpl(name, mangle_te_list(proto_args, entries, home_mod),
            mangle_te(ty, entries, home_mod),
            mangle_one_segment(sub_decls, entries, home_mod, []),
            l, c)
    DDerive(ps, inner, l, c) ->
      DDerive(ps, mangle_one_decl(inner, entries, home_mod), l, c)
    DUnstable(inner, l, c) ->
      DUnstable(mangle_one_decl(inner, entries, home_mod), l, c)
    DAttribPure(inner, l, c) ->
      DAttribPure(mangle_one_decl(inner, entries, home_mod), l, c)
    DTest(n, body, l, c) ->
      DTest(n, mangle_expr(body, entries, home_mod), l, c)
    DBench(n, body, l, c) ->
      DBench(n, mangle_expr(body, entries, home_mod), l, c)
    DCheck(n, ps, body, l, c) ->
      DCheck(n, mangle_params(ps, entries, home_mod),
              mangle_expr(body, entries, home_mod), l, c)
    _ -> d
  }
}

fn mangle_te(te: TypeExpr, entries: [PrivTyEntry], home_mod: String) : TypeExpr {
  match te.tkind {
    TyName(name, targs) -> {
      let targs1 = mangle_te_list(targs, entries, home_mod)
      let name1 = match priv_ty_lookup(entries, home_mod, name) {
        Some(m) -> m
        None    -> name
      }
      TypeExpr { tkind: TyName(name1, targs1), line: te.line, col: te.col }
    }
    TyList(inner) ->
      TypeExpr { tkind: TyList(mangle_te(inner, entries, home_mod)),
                  line: te.line, col: te.col }
    TyFn(ps, ret, row) ->
      TypeExpr { tkind: TyFn(mangle_te_list(ps, entries, home_mod),
                              mangle_te(ret, entries, home_mod),
                              mangle_row(row, entries, home_mod)),
                  line: te.line, col: te.col }
    TyDim(base, u) ->
      TypeExpr { tkind: TyDim(mangle_te(base, entries, home_mod), u),
                  line: te.line, col: te.col }
    TyRefine(base, p) ->
      TypeExpr { tkind: TyRefine(mangle_te(base, entries, home_mod), p),
                  line: te.line, col: te.col }
  }
}

fn mangle_te_list(tes: [TypeExpr], entries: [PrivTyEntry],
                    home_mod: String) : [TypeExpr] {
  match tes {
    [] -> []
    [t, ...rest] -> [mangle_te(t, entries, home_mod),
                     ...mangle_te_list(rest, entries, home_mod)]
  }
}

fn mangle_row(r: RowExpr, entries: [PrivTyEntry],
                home_mod: String) : RowExpr {
  match r {
    REmpty -> REmpty
    RClosed(labels) -> RClosed(mangle_rls(labels, entries, home_mod))
    ROpen(rv, labels) -> ROpen(rv, mangle_rls(labels, entries, home_mod))
  }
}

fn mangle_rls(ls: [RowLabel], entries: [PrivTyEntry],
                home_mod: String) : [RowLabel] {
  match ls {
    [] -> []
    [rl, ...rest] -> match rl {
      RL(name, ts) -> [RL(name, mangle_te_list(ts, entries, home_mod)),
                        ...mangle_rls(rest, entries, home_mod)]
    }
  }
}

fn mangle_params(ps: [Param], entries: [PrivTyEntry],
                   home_mod: String) : [Param] {
  match ps {
    [] -> []
    [p, ...rest] -> [mangle_param(p, entries, home_mod),
                     ...mangle_params(rest, entries, home_mod)]
  }
}

fn mangle_param(pm: Param, entries: [PrivTyEntry],
                  home_mod: String) : Param =
  Param { pname: pm.pname,
          ptype: match pm.ptype {
            None -> None
            Some(te) -> Some(mangle_te(te, entries, home_mod))
          },
          pline: pm.pline, pcol: pm.pcol }

fn mangle_typebody(b: TypeBody, entries: [PrivTyEntry],
                     home_mod: String) : TypeBody {
  match b {
    TBAlias(t) -> TBAlias(mangle_te(t, entries, home_mod))
    TBRecord(fs) -> TBRecord(mangle_fields(fs, entries, home_mod))
    TBSum(vs) -> TBSum(mangle_variants(vs, entries, home_mod))
    TBEffectAlias(_) -> b
  }
}

fn mangle_fields(fs: [FieldDecl], entries: [PrivTyEntry],
                   home_mod: String) : [FieldDecl] {
  match fs {
    [] -> []
    [f, ...rest] -> match f {
      FD(is_pub, name, te) -> [FD(is_pub, name, mangle_te(te, entries, home_mod)),
                        ...mangle_fields(rest, entries, home_mod)]
    }
  }
}

fn mangle_variants(vs: [Variant], entries: [PrivTyEntry],
                     home_mod: String) : [Variant] {
  match vs {
    [] -> []
    [v, ...rest] -> match v {
      Var(cname, vargs) -> [Var(cname, mangle_te_list(vargs, entries, home_mod)),
                             ...mangle_variants(rest, entries, home_mod)]
    }
  }
}

fn mangle_eops(ops: [EffectOp], entries: [PrivTyEntry],
                 home_mod: String) : [EffectOp] {
  match ops {
    [] -> []
    [op, ...rest] -> match op {
      EOp(name, tps, ps, ret, l, c) ->
        [EOp(name, tps, mangle_params(ps, entries, home_mod),
              mangle_te(ret, entries, home_mod), l, c),
         ...mangle_eops(rest, entries, home_mod)]
    }
  }
}

fn mangle_pops(ops: [ProtoOp], entries: [PrivTyEntry],
                 home_mod: String) : [ProtoOp] {
  match ops {
    [] -> []
    [op, ...rest] -> match op {
      POp(name, tps, ps, ret, l, c) ->
        [POp(name, tps, mangle_params(ps, entries, home_mod),
              mangle_te(ret, entries, home_mod), l, c),
         ...mangle_pops(rest, entries, home_mod)]
    }
  }
}

fn mangle_expr(e: Expr, entries: [PrivTyEntry], home_mod: String) : Expr =
  Expr { kind: mangle_expr_kind(e.kind, entries, home_mod),
         line: e.line, col: e.col, ty: e.ty, mode: e.mode }

fn mangle_expr_kind(k: ExprKind, entries: [PrivTyEntry],
                       home_mod: String) : ExprKind {
  match k {
    EBlock(stmts, opt_final) ->
      EBlock(mangle_stmts(stmts, entries, home_mod),
             match opt_final {
               None -> None
               Some(fe) -> Some(mangle_expr(fe, entries, home_mod))
             })
    EMatch(scrut, arms) ->
      EMatch(mangle_expr(scrut, entries, home_mod),
             mangle_arms(arms, entries, home_mod))
    EVariantsOf(te, ns) ->
      EVariantsOf(mangle_te(te, entries, home_mod), ns)
    ELambda(ps, body) ->
      ELambda(mangle_params(ps, entries, home_mod),
              mangle_expr(body, entries, home_mod))
    EHandle(body, eff, ty_args, init_opt, alias_opt, clauses, ret_opt) ->
      EHandle(mangle_expr(body, entries, home_mod), eff,
              mangle_te_list(ty_args, entries, home_mod),
              match init_opt {
                None -> None
                Some(ie) -> Some(mangle_expr(ie, entries, home_mod))
              },
              alias_opt,
              mangle_hclauses(clauses, entries, home_mod),
              match ret_opt {
                None -> None
                Some(r) -> Some(mangle_hreturn(r, entries, home_mod))
              })
    _ -> map_expr_kind(k, (sub) => mangle_expr(sub, entries, home_mod))
  }
}

fn mangle_arms(arms: [Arm], entries: [PrivTyEntry],
                 home_mod: String) : [Arm] {
  match arms {
    [] -> []
    [a, ...rest] -> [mangle_arm(a, entries, home_mod),
                     ...mangle_arms(rest, entries, home_mod)]
  }
}

fn mangle_arm(a: Arm, entries: [PrivTyEntry], home_mod: String) : Arm {
  match a {
    Arm(pat, opt_guard, body) ->
      Arm(mangle_pat(pat, entries, home_mod),
          match opt_guard {
            None -> None
            Some(g) -> Some(mangle_expr(g, entries, home_mod))
          },
          mangle_expr(body, entries, home_mod))
  }
}

fn mangle_pat(pat: Pattern, entries: [PrivTyEntry],
                home_mod: String) : Pattern {
  match pat.pkind {
    PNarrow(name, te) ->
      Pattern { pkind: PNarrow(name, mangle_te(te, entries, home_mod)),
                 line: pat.line, col: pat.col }
    PVariant(name, subs) ->
      Pattern { pkind: PVariant(name, mangle_pat_list(subs, entries, home_mod)),
                 line: pat.line, col: pat.col }
    PVariantRecord(name, fs) ->
      Pattern { pkind: PVariantRecord(name, mangle_pfields(fs, entries, home_mod)),
                 line: pat.line, col: pat.col }
    PRecord(fs) ->
      Pattern { pkind: PRecord(mangle_pfields(fs, entries, home_mod)),
                 line: pat.line, col: pat.col }
    PList(subs, rest) ->
      Pattern { pkind: PList(mangle_pat_list(subs, entries, home_mod), rest),
                 line: pat.line, col: pat.col }
    PAs(name, inner) ->
      Pattern { pkind: PAs(name, mangle_pat(inner, entries, home_mod)),
                 line: pat.line, col: pat.col }
    _ -> pat
  }
}

fn mangle_pat_list(ps: [Pattern], entries: [PrivTyEntry],
                     home_mod: String) : [Pattern] {
  match ps {
    [] -> []
    [p, ...rest] -> [mangle_pat(p, entries, home_mod),
                     ...mangle_pat_list(rest, entries, home_mod)]
  }
}

fn mangle_pfields(fs: [PField], entries: [PrivTyEntry],
                    home_mod: String) : [PField] {
  match fs {
    [] -> []
    [f, ...rest] -> match f {
      PField(name, sub, sh) -> [PField(name, mangle_pat(sub, entries, home_mod), sh),
                                 ...mangle_pfields(rest, entries, home_mod)]
    }
  }
}

fn mangle_stmts(ss: [Stmt], entries: [PrivTyEntry],
                  home_mod: String) : [Stmt] {
  match ss {
    [] -> []
    [s, ...rest] -> [mangle_stmt(s, entries, home_mod),
                     ...mangle_stmts(rest, entries, home_mod)]
  }
}

fn mangle_stmt(s: Stmt, entries: [PrivTyEntry], home_mod: String) : Stmt {
  match s {
    SLet(pat, ty_opt, e) ->
      SLet(mangle_pat(pat, entries, home_mod),
           match ty_opt {
             None -> None
             Some(te) -> Some(mangle_te(te, entries, home_mod))
           },
           mangle_expr(e, entries, home_mod))
    SVar(name, ty_opt, init, l, c) ->
      SVar(name,
           match ty_opt {
             None -> None
             Some(te) -> Some(mangle_te(te, entries, home_mod))
           },
           mangle_expr(init, entries, home_mod), l, c)
    SAssert(e, om) ->
      SAssert(mangle_expr(e, entries, home_mod),
              match om {
                None -> None
                Some(m) -> Some(mangle_expr(m, entries, home_mod))
              })
    SExprStmt(e) -> SExprStmt(mangle_expr(e, entries, home_mod))
    SIndexAssign(t, ix, v, l, c) ->
      SIndexAssign(mangle_expr(t, entries, home_mod),
                    mangle_expr(ix, entries, home_mod),
                    mangle_expr(v, entries, home_mod), l, c)
    SUse(eff, l, c) -> SUse(eff, l, c)
  }
}

fn mangle_hclauses(cs: [HClause], entries: [PrivTyEntry],
                     home_mod: String) : [HClause] {
  match cs {
    [] -> []
    [c, ...rest] -> match c {
      HC(name, ps, body, l, col) ->
        [HC(name, mangle_params(ps, entries, home_mod),
             mangle_expr(body, entries, home_mod), l, col),
         ...mangle_hclauses(rest, entries, home_mod)]
    }
  }
}

fn mangle_hreturn(r: HReturn, entries: [PrivTyEntry],
                    home_mod: String) : HReturn {
  match r {
    HR(name, body, l, c) -> HR(name, mangle_expr(body, entries, home_mod), l, c)
  }
}

# m7b #1d — display-time alias preservation (Doc A §*Open questions*
# #5). Render a label set using the largest alias that fully covers
# it; remaining labels (those outside the alias) are appended with
# `+`. The alias rewrite at resolve time is value-preserving, so the
# choice is purely cosmetic — diagnostics keep the user's `Io`
# spelling when it still describes the row, and fall back to the
# expanded labels on partial coverage. Currently no diagnostic prints
# whole rows; this helper is the building block when row-mismatch
# rendering lands.

# m7b #1d — display-time alias preservation (Doc A §*Open questions*
# #5). Render a label set using the largest alias that fully covers
# it; remaining labels (those outside the alias) are appended with
# `+`. The alias rewrite at resolve time is value-preserving, so the
# choice is purely cosmetic — diagnostics keep the user's `Io`
# spelling when it still describes the row, and fall back to the
# expanded labels on partial coverage. Currently no diagnostic prints
# whole rows; this helper is the building block when row-mismatch
# rendering lands.
fn row_to_diag_string(labels: [String], aliases: [AliasResult]) : String {
  if labels == [] { "(empty)" }
  else {
    match best_alias_cover(aliases, labels, None) {
      None -> join_with(labels, " + ")
      Some(AR(alias_name, alias_labels)) -> {
        let leftover = subtract_strings(labels, alias_labels)
        if leftover == [] { alias_name }
        else { string_concat(alias_name, string_concat(" + ", join_with(leftover, " + "))) }
      }
    }
  }
}

# Return the alias whose label set is a subset of `labels` and that
# covers the largest number of labels. Ties prefer the alias seen
# first (lexically earlier in source).

# Return the alias whose label set is a subset of `labels` and that
# covers the largest number of labels. Ties prefer the alias seen
# first (lexically earlier in source).
fn best_alias_cover(aliases: [AliasResult], labels: [String],
                    best: Option[AliasResult]) : Option[AliasResult] {
  match aliases {
    [] -> best
    [a, ...rest] -> match a {
      AR(_, alabels) -> {
        let covers = labels_subset(alabels, labels)
        let new_best =
          if covers and better_cover(best, alabels) { Some(a) }
          else { best }
        best_alias_cover(rest, labels, new_best)
      }
    }
  }
}

fn better_cover(prev: Option[AliasResult], candidate_labels: [String]) : Bool {
  match prev {
    None -> true
    Some(AR(_, p)) -> list_length(candidate_labels) > list_length(p)
  }
}

fn labels_subset(small: [String], big: [String]) : Bool {
  match small {
    [] -> true
    [x, ...rest] ->
      if list_has(big, x) { labels_subset(rest, big) }
      else { false }
  }
}

fn subtract_strings(xs: [String], ys: [String]) : [String] {
  match xs {
    [] -> []
    [x, ...rest] ->
      if list_has(ys, x) { subtract_strings(rest, ys) }
      else { [x, ...subtract_strings(rest, ys)] }
  }
}

fn sig_of_decl(d: Decl) : Option[Ty] {
  match d {
    DFn(_, _, _, params, opt_ret, rexpr, _, _, _, _) -> {
      let pts = map(params, param_ty)
      let ret = match opt_ret {
        Some(rty) -> resolve_ty(rty)
        None -> TyUnit
      }
      Some(TyFnT(pts, ret, row_of_expr(rexpr)))
    }
    # m12.7: axiom signature has the same shape as a fn — params,
    # return type, row. The body's row is replaced by the declared
    # row directly (no body to read row_of_expr from).
    DAxiom(_, _, _, _, _, params, ret_ty, row, _, _) -> {
      let pts = map(params, param_ty)
      let ret = resolve_ty(ret_ty)
      Some(TyFnT(pts, ret, row_of_expr(row)))
    }
    _ -> None
  }
}

fn mangle_ty(t: Ty) : String {
  match t {
    TyInt    -> "Int"
    TyReal   -> "Real"
    TyBool   -> "Bool"
    TyString -> "String"
    TyChar   -> "Char"
    TyUnit   -> "Unit"
    TyByte     -> "Byte"
    TyListT(inner) -> concat_all(["L_", mangle_ty(inner), "_E"])
    TyFnT(ps, ret, _) -> concat_all([
      "F_", join_with(map(ps, mangle_ty), "_"),
      "_R_", mangle_ty(ret), "_E"
    ])
    TyCon(_, cname, tas) -> {
      match tas {
        [] -> cname
        [_h, ..._rest] -> concat_all([cname, "_O_",
                                    join_with(map(tas, mangle_ty), "_"),
                                    "_C"])
      }
    }
    TyVarT(_) -> "TVAR"
    TyAny     -> "Any"
    # m12.5: units are erased at codegen time. The mangled name for a
    # dimensioned type is the same as its base type's mangle — so a
    # call like `f(1.0<USD>)` and a call `f(1.0)` mangle into the same
    # specialisation. This is the codegen-erasure invariant manifest
    # at the mangler level.
    TyDimT(base, _) -> mangle_ty(base)
    # m12.6.x #1: refinements erase like units. `Int where >= 0` and
    # `Int` mangle the same — they share monomorphisations and
    # protocol-impl dispatch entries.
    TyRefineT(base, _) -> mangle_ty(base)
    # issue #187 phase 1: mangle a union as `U_<part1>_<part2>_..._E`
    # using the canonical component order. The leading `U_` and
    # trailing `_E` bracket the spec the same way `L_..._E` brackets
    # a list, so distinct unions never collide with each other or
    # with primitive mangles even when their component manglings
    # rearrange. Phase 1 never invokes the mangler on a `TyUnion` in
    # selfhost (no resolver path constructs one) so this arm is dead
    # until Phase 2 wires it up; the implementation is provided now
    # to keep the walker exhaustive without `_` fallbacks that would
    # mask future bugs.
    TyUnion(parts) -> concat_all(["U_",
                                  join_with(map(parts, mangle_ty), "_"),
                                  "_E"])
  }
}

fn mangle_name(name: String, tys: [Ty], units: [UnitExprT]) : String {
  let ty_part = match tys {
    [] -> ""
    [_h, ..._rest] -> concat_all(["__mono__", join_with(map(tys, mangle_ty), "__")])
  }
  # m4c Phase 3: encode the unit-tparam tuple after the type-tparam
  # tuple. Empty units means no per-unit specialisation (the common
  # case). For `impl[u: Measure] Show for Real<u>` and friends, two
  # specs binding `u` to USD and EUR mangle distinctly via
  # `__umono__USD` / `__umono__EUR`. The rendering uses the same
  # canonical-unit display as `unit_name(x)` so emit and rewrite
  # agree on the suffix string.
  let u_part = match units {
    [] -> ""
    [_h, ..._rest] -> concat_all(["__umono__", join_with(map(units, mangle_unit), "__")])
  }
  if string_length(ty_part) == 0 and string_length(u_part) == 0 {
    name
  } else {
    concat_all([name, ty_part, u_part])
  }
}

# Render a unit canonically for mangling. `unit_one` (i.e. no unit)
# emits "1" so a `Real<1>` spec sits in its own slot. Bare unit-vars
# only appear in pre-monomorphisation insts and would not key a
# real spec; we still emit a stable "TUVAR" sentinel so any such
# slip-through is observable rather than silently colliding with a
# concrete unit.

# Render a unit canonically for mangling. `unit_one` (i.e. no unit)
# emits "1" so a `Real<1>` spec sits in its own slot. Bare unit-vars
# only appear in pre-monomorphisation insts and would not key a
# real spec; we still emit a stable "TUVAR" sentinel so any such
# slip-through is observable rather than silently colliding with a
# concrete unit.
fn mangle_unit(u: UnitExprT) : String {
  let cu = unit_canon(u)
  match cu {
    UVar(_) -> "TUVAR"
    UOne    -> "1"
    _       -> mangle_unit_ident(cmt_unit_expr_display(cu))
  }
}

# Replace mangle-unsafe characters in the canonical unit display with
# C-identifier-safe sentinels. `*` -> `_x_`, `/` -> `_d_`, `^` ->
# `_p_`, `(`/`)` -> `_l_` / `_r_`. Spaces, if any, become `_s_`.

# Replace mangle-unsafe characters in the canonical unit display with
# C-identifier-safe sentinels. `*` -> `_x_`, `/` -> `_d_`, `^` ->
# `_p_`, `(`/`)` -> `_l_` / `_r_`. Spaces, if any, become `_s_`.
fn mangle_unit_ident(s: String) : String =
  mangle_unit_ident_loop(s, 0, string_length(s), [])

fn mangle_unit_ident_loop(s: String, i: Int, n: Int, acc: [String]) : String {
  if i >= n { concat_all(list_reverse(acc)) }
  else {
    let c = match char_at(s, i) {
      Some(ch) -> ch
      None     -> ' '
    }
    let piece = match c {
      '*' -> "_x_"
      '/' -> "_d_"
      '^' -> "_p_"
      '(' -> "_l_"
      ')' -> "_r_"
      ' ' -> "_s_"
      _   -> string_slice(s, i, 1)
    }
    mangle_unit_ident_loop(s, i + 1, n, [piece, ...acc])
  }
}

fn dump_decl_type(d: Decl) : Unit / Console {
  match d {
    DFn(is_pub, name, _, _, _, _, _, line, col, _) -> {
      let pub_s = if is_pub { "pub " } else { "" }
      match sig_of_decl(d) {
        Some(ty) -> print("#{pub_s}fn #{name} : #{ty_to_string(ty)} @#{int_to_string(line)}:#{int_to_string(col)}")
        None -> ()
      }
    }
    DType(is_pub, name, tparams, _, line, col, _) -> {
      let pub_s = if is_pub { "pub " } else { "" }
      let tps = match tparams {
        [] -> ""
        _ -> concat_all(["[", join_with(tparams, ", "), "]"])
      }
      print("#{pub_s}type #{name}#{tps} @#{int_to_string(line)}:#{int_to_string(col)}")
    }
    DTest(desc, _, line, col) ->
      print("test #{desc} @#{int_to_string(line)}:#{int_to_string(col)}")
    DBench(desc, _, line, col) ->
      print("bench #{desc} @#{int_to_string(line)}:#{int_to_string(col)}")
    DCheck(desc, _, _, line, col) ->
      print("check #{desc} @#{int_to_string(line)}:#{int_to_string(col)}")
    DImport(ik, line, col) -> {
      match ik {
        IkPath(p) -> print("import #{p} @#{int_to_string(line)}:#{int_to_string(col)}")
        IkAlias(p, a) -> print("import #{p} as #{a} @#{int_to_string(line)}:#{int_to_string(col)}")
        IkSelective(p, _) -> print("import #{p} @#{int_to_string(line)}:#{int_to_string(col)}")
        IkHole(name) -> print("import ?#{name} @#{int_to_string(line)}:#{int_to_string(col)}")
      }
    }
    DEffect(is_pub, name, _, _, _, line, col) -> {
      let pub_s = if is_pub { "pub " } else { "" }
      print("#{pub_s}effect #{name} @#{int_to_string(line)}:#{int_to_string(col)}")
    }
    DProtocol(is_pub, name, _, _, line, col) -> {
      let pub_s = if is_pub { "pub " } else { "" }
      print("#{pub_s}protocol #{name} @#{int_to_string(line)}:#{int_to_string(col)}")
    }
    DImpl(pname, _, _, _, line, col) ->
      print("impl #{pname} @#{int_to_string(line)}:#{int_to_string(col)}")
    DDerive(_, inner, _, _) -> dump_decl_type(inner)
    DUnstable(inner, _, _) -> dump_decl_type(inner)
    DUnit(is_pub, name, alias_opt, line, col) -> {
      let pub_s = if is_pub { "pub " } else { "" }
      let body_s = match alias_opt {
        None -> ""
        Some(u) -> string_concat(" = ", unit_canon_display(u))
      }
      print("#{pub_s}unit #{name}#{body_s} @#{int_to_string(line)}:#{int_to_string(col)}")
    }
    DUse(name, line, col) ->
      print("use #{name} @#{int_to_string(line)}:#{int_to_string(col)}")
    DAxiom(is_pub, _, name, _, _, _, _, _, line, col) -> {
      let pub_s = if is_pub { "pub " } else { "" }
      match sig_of_decl(d) {
        Some(ty) -> print("#{pub_s}axiom #{name} : #{ty_to_string(ty)} @#{int_to_string(line)}:#{int_to_string(col)}")
        None -> print("#{pub_s}axiom #{name} @#{int_to_string(line)}:#{int_to_string(col)}")
      }
    }
    DAttribPure(inner, _, _) -> dump_decl_type(inner)  # m12.6.x #5(a)
    DConst(is_pub, name, ty, _, line, col) -> {        # issue #269
      let pub_s = if is_pub { "pub " } else { "" }
      print("#{pub_s}const #{name} : #{ty_to_string(resolve_ty(ty))} @#{int_to_string(line)}:#{int_to_string(col)}")
    }
  }
}

#[doc("Emit-layer entry point dump_types")]
pub fn dump_types(decls: [Decl]) : Unit / Console = dump_types_loop(decls)

fn dump_types_loop(ds: [Decl]) : Unit / Console {
  match ds {
    [] -> ()
    [d, ...rest] -> { dump_decl_type(d) dump_types_loop(rest) }
  }
}

# ====================================================================
# ---- `--dump-mono`: call-site instantiations ----
#
# Every EVar reference that instantiates a polymorphic scheme
# registers a CallSite; inference then resolves each CallSite's
# fresh TyVarT ids through the final substitution to get concrete
# type arguments. This flag prints one line per call-site showing
# the name, location, and the resolved type tuple.
#
# Monomorphisation (M4c) will de-duplicate these tuples per callee
# and emit one specialised function body per unique instantiation.

fn dump_mono_line(cs: ResolvedCS) : Unit / Console {
  match cs {
    RCS(nm, line, col, tys, _, _) -> {
      let tys_str = join_with(ty_string_list(tys), ", ")
      print("#{nm}@#{int_to_string(line)}:#{int_to_string(col)}  [#{tys_str}]")
    }
  }
}

# Drop every instance whose enclosing decl was authored outside the
# root file (i.e. came in through core or an imported module). Used
# by --dump-mono / --dump-mono-out so the diagnostic surface only
# reflects what the user's program contributes, mirroring the legacy
# behaviour before core became implicit.

# Drop every instance whose enclosing decl was authored outside the
# root file (i.e. came in through core or an imported module). Used
# by --dump-mono / --dump-mono-out so the diagnostic surface only
# reflects what the user's program contributes, mirroring the legacy
# behaviour before core became implicit.
fn root_only_insts(insts: [ResolvedCS]) : [ResolvedCS] = match insts {
  [] -> []
  [cs, ...rest] -> match cs {
    RCS(_, _, _, _, _, mo) -> match mo {
      None    -> [cs, ...root_only_insts(rest)]
      Some(_) -> root_only_insts(rest)
    }
  }
}

#[doc("Emit-layer entry point dump_mono")]
pub fn dump_mono(file: String, decls: [Decl]) : Int / Console + File {


  let r = infer_program(file, decls, false)
  root_only_insts(r.insts) |> each(dump_mono_line)
  r.errs
}

# ---- `--dump-mono-out`: planned mangled names per call site ----
#
# Same input as `--dump-mono` (the resolved-call-site list); output
# adds the mangled name `mangle_name` would produce for each tuple.
# Diagnostic for m4c #2; m4c #3 will use these names to mint the
# specialised decls. Lines look like:
#   foo@line:col  [Int, Bool]  ->  foo__mono__Int__Bool

fn dump_mono_out_line(cs: ResolvedCS) : Unit / Console {
  match cs {
    RCS(nm, line, col, tys, units, _) -> {
      let tys_str = join_with(ty_string_list(tys), ", ")
      let mname = mangle_name(nm, tys, units)
      print("#{nm}@#{int_to_string(line)}:#{int_to_string(col)}  [#{tys_str}]  ->  #{mname}")
    }
  }
}

#[doc("Emit-layer entry point dump_mono_out")]
pub fn dump_mono_out(file: String, decls: [Decl]) : Int / Console + File {


  let r = infer_program(file, decls, false)
  root_only_insts(r.insts) |> each(dump_mono_out_line)
  r.errs
}


# ---- m37 / TCO — self-tail-call detection (M1) ---------------------
#
# Issue #37: the Perceus exit-drop wrap places `kai_internal_drop(...)`
# calls *after* the body's tail expression, so neither gcc nor clang
# can fold a self-recursive call into `jmp` at the C level. The
# compiler-side fix rewrites self-tail-calls into a `goto`-loop with
# parameter rebinding; this walker is the recognition half.
#
# `tcrec_has_tail_self_call(body, nm, arity)` returns true if `body`
# contains at least one self-recursive call to a fn named `nm` with
# `arity` arguments in *tail position*. Tail position propagates
# through:
#   - EBlock(_, Some(tail))      — `tail` is tail
#   - EIf(_, then, opt_else)     — both branches are tail
#   - EMatch(_, arms)            — each arm body is tail
# It does NOT propagate through:
#   - ECall args / EBinop / EUnop / ERange / records / lists
#   - EBlock stmts (only the trailing expression is tail)
#   - EMatch scrutinee / EIf condition / match guards
#   - ELambda body (different fn — never tail of the enclosing fn)
#   - EPipe / EHandle (conservative; could be relaxed later)
#
# A locally-bound `let`/`var` shadowing `nm` disables the match
# inside its scope.
#
# M1 lands the walker only; no caller wires it into the pipeline,
# so selfhost stays byte-identical until M3 flips emission.

# ---- m37 / TCO — self-tail-call detection (M1) ---------------------
#
# Issue #37: the Perceus exit-drop wrap places `kai_internal_drop(...)`
# calls *after* the body's tail expression, so neither gcc nor clang
# can fold a self-recursive call into `jmp` at the C level. The
# compiler-side fix rewrites self-tail-calls into a `goto`-loop with
# parameter rebinding; this walker is the recognition half.
#
# `tcrec_has_tail_self_call(body, nm, arity)` returns true if `body`
# contains at least one self-recursive call to a fn named `nm` with
# `arity` arguments in *tail position*. Tail position propagates
# through:
#   - EBlock(_, Some(tail))      — `tail` is tail
#   - EIf(_, then, opt_else)     — both branches are tail
#   - EMatch(_, arms)            — each arm body is tail
# It does NOT propagate through:
#   - ECall args / EBinop / EUnop / ERange / records / lists
#   - EBlock stmts (only the trailing expression is tail)
#   - EMatch scrutinee / EIf condition / match guards
#   - ELambda body (different fn — never tail of the enclosing fn)
#   - EPipe / EHandle (conservative; could be relaxed later)
#
# A locally-bound `let`/`var` shadowing `nm` disables the match
# inside its scope.
#
# M1 lands the walker only; no caller wires it into the pipeline,
# so selfhost stays byte-identical until M3 flips emission.
fn tcrec_has_tail_self_call(body: Expr, nm: String, arity: Int) : Bool =
  tcrec_walk_tail(body.kind, nm, arity, [])

fn tcrec_walk_tail(k: ExprKind, nm: String, arity: Int, scope: [String]) : Bool {
  match k {
    ECall(f, xs) -> match f.kind {
      EVar(callee) ->
        if callee == nm and not list_has(scope, nm) and list_length(xs) == arity {
          true
        } else { false }
      _ -> false
    }
    EIf(_, t, opt_e) -> {
      if tcrec_walk_tail(t.kind, nm, arity, scope) { true }
      else { match opt_e {
        None -> false
        Some(e2) -> tcrec_walk_tail(e2.kind, nm, arity, scope)
      } }
    }
    EMatch(_, arms) -> tcrec_walk_arms(arms, nm, arity, scope)
    EBlock(stmts, opt_tail) -> {
      let scope1 = tcrec_block_scope(stmts, scope)
      match opt_tail {
        None -> false
        Some(e) -> tcrec_walk_tail(e.kind, nm, arity, scope1)
      }
    }
    _ -> false
  }
}

fn tcrec_walk_arms(arms: [Arm], nm: String, arity: Int, scope: [String]) : Bool {
  match arms {
    [] -> false
    [a, ...rest] -> match a {
      Arm(pat, _, body) -> {
        let scope1 = pat_bindings(pat, scope)
        if tcrec_walk_tail(body.kind, nm, arity, scope1) { true }
        else { tcrec_walk_arms(rest, nm, arity, scope) }
      }
    }
  }
}

fn tcrec_block_scope(stmts: [Stmt], scope: [String]) : [String] {
  match stmts {
    [] -> scope
    [s, ...rest] -> {
      let scope1 = match s {
        SLet(pat, _, _) -> pat_bindings(pat, scope)
        SVar(name, _, _, _, _) -> [name, ...scope]
        _ -> scope
      }
      tcrec_block_scope(rest, scope1)
    }
  }
}

# ---- m37 / TCO — self-tail-call rewrite (M2) ----------------------
#
# Runs after `perceus_pass`. For every fn whose body contains at least
# one self-tail-call (per M1), the callee `EVar(name)` of each such
# tail call is replaced with `EVar(sentinel)` where `sentinel` is a
# pipe-encoded string carrying everything `emit_call_expr` needs:
#
#     __kai_tcrec|<c_sym>|<dropmask>|<p0>|<p1>|...
#
# - `c_sym`     — the linker symbol of the enclosing fn (used to mint
#                 the goto label `_kai_<c_sym>_entry`).
# - `dropmask`  — bit `i` set iff parameter `i` should be dropped
#                 before the rebind in the goto block. The criterion
#                 mirrors `pcs_collect_exit_drops`: a param gets a
#                 drop in the goto block iff `last_use_for` is
#                 `LUBlocked` or `LUAt` with multi-use. This makes
#                 the goto-path's drops byte-for-byte equivalent to
#                 the wrap's exit drops, which the goto skips by
#                 jumping out of the enclosing statement-expression.
# - `p0..pN`    — parameter names, in declaration order, used to
#                 emit `kai_<pname> = _t<i>;` in the goto block.
#
# `emit_fn_body` walks the rewritten body once and plants the goto
# label `_kai_<c_sym>_entry:;` before `return ({ ... });` whenever a
# sentinel call is present.
#
# Pipe was chosen as the separator because it cannot appear in kaikai
# identifiers and so cannot collide with parameter names.
#
# M2 lands the rewrite + sentinel scanner only; no caller wires
# `tcrec_rewrite_decls` into the pipeline yet, so selfhost stays
# byte-identical until M3 connects the pieces.

# ---- m37 / TCO — self-tail-call rewrite (M2) ----------------------
#
# Runs after `perceus_pass`. For every fn whose body contains at least
# one self-tail-call (per M1), the callee `EVar(name)` of each such
# tail call is replaced with `EVar(sentinel)` where `sentinel` is a
# pipe-encoded string carrying everything `emit_call_expr` needs:
#
#     __kai_tcrec|<c_sym>|<dropmask>|<p0>|<p1>|...
#
# - `c_sym`     — the linker symbol of the enclosing fn (used to mint
#                 the goto label `_kai_<c_sym>_entry`).
# - `dropmask`  — bit `i` set iff parameter `i` should be dropped
#                 before the rebind in the goto block. The criterion
#                 mirrors `pcs_collect_exit_drops`: a param gets a
#                 drop in the goto block iff `last_use_for` is
#                 `LUBlocked` or `LUAt` with multi-use. This makes
#                 the goto-path's drops byte-for-byte equivalent to
#                 the wrap's exit drops, which the goto skips by
#                 jumping out of the enclosing statement-expression.
# - `p0..pN`    — parameter names, in declaration order, used to
#                 emit `kai_<pname> = _t<i>;` in the goto block.
#
# `emit_fn_body` walks the rewritten body once and plants the goto
# label `_kai_<c_sym>_entry:;` before `return ({ ... });` whenever a
# sentinel call is present.
#
# Pipe was chosen as the separator because it cannot appear in kaikai
# identifiers and so cannot collide with parameter names.
#
# M2 lands the rewrite + sentinel scanner only; no caller wires
# `tcrec_rewrite_decls` into the pipeline yet, so selfhost stays
# byte-identical until M3 connects the pieces.
#[doc("---- m37 / TCO — self-tail-call rewrite (M2) ---------------------- Runs after `perceus_pass`. For every fn whose body contains at least one self-tail-call (per M1), the callee…")]
pub fn tcrec_rewrite_decls(decls: [Decl]) : [Decl] / Console = map(decls, tcrec_rewrite_decl)

# Pipeline reorder (Eric review 2026-05-06):
# tcrec runs AFTER perceus_pass, so the body it receives may be
# wrapped in `EBlock([...entry_drops, SLet(__pcs_ret, INNER),
# ...exit_drops], Some(EVar(__pcs_ret)))` (`pcs_wrap_with_exit`).
# `tcrec_is_pcs_ret_wrap` recognises the shape; when present,
# `tcrec_rewrite_pcs_ret_wrap` rebuilds the wrap around a rewritten
# inner body. Self-tail-calls in the wrap-less case (no exit drops,
# body unchanged or `EBlock(entry, Some(body))` with entry-only
# drops) work without any unwrap because the structural walker
# already descends through `EBlock(_, Some(tail))`. Only the exit-
# drops shape needs special handling because its tail is
# `EVar(__pcs_ret)` instead of the original body.

# Pipeline reorder (Eric review 2026-05-06):
# tcrec runs AFTER perceus_pass, so the body it receives may be
# wrapped in `EBlock([...entry_drops, SLet(__pcs_ret, INNER),
# ...exit_drops], Some(EVar(__pcs_ret)))` (`pcs_wrap_with_exit`).
# `tcrec_is_pcs_ret_wrap` recognises the shape; when present,
# `tcrec_rewrite_pcs_ret_wrap` rebuilds the wrap around a rewritten
# inner body. Self-tail-calls in the wrap-less case (no exit drops,
# body unchanged or `EBlock(entry, Some(body))` with entry-only
# drops) work without any unwrap because the structural walker
# already descends through `EBlock(_, Some(tail))`. Only the exit-
# drops shape needs special handling because its tail is
# `EVar(__pcs_ret)` instead of the original body.
fn tcrec_rewrite_decl(d: Decl) : Decl / Console {

  match d {
    DFn(is_pub, name, tparams, params, opt_ret, row, body, ln, cl, mo) -> {
      let arity = list_length(params)
      if tcrec_is_pcs_ret_wrap(body) {
        match body.kind {
          EBlock(stmts, _) ->
            tcrec_rewrite_pcs_ret_wrap(d, is_pub, name, tparams, params,
                                        opt_ret, row, body, stmts, ln, cl, mo,
                                        arity)
          _ -> d
        }
      } else {
        if not tcrec_has_tail_self_call(body, name, arity) { d }
        else {
          let pnames = map(params, (p) => p.pname)
          let uses = pcs_collect_uses_expr(body, pnames, false, [])
          if tcrec_any_unused(params, uses) { d }
          else {
            let c_sym_str = c_sym(name, mo)
            # Issue #92: precompute the rule-3 dropmask side table BEFORE
            # entering the rewrite. The pre-pass walks `body` once,
            # inspects each call site's args via `tcrec_args_have_evar`,
            # and produces `[TcrDm]` (a list of int triples). The rewrite
            # then threads only `[TcrDm]` and never touches `[Expr]` during
            # the per-site dropmask compute.
            #
            # The `borrow_flags` are the per-param "is single use a
            # borrow position" predicate (see `tcrec_use_is_borrow`). They
            # gate rule-3 firing so the goto's extra drop is only planted
            # at borrow uses, never at consume uses. Without this, rule 3
            # double-decrefs values whose single use already consumed
            # them (e.g. direct call args like `lex_next(l)`).
            let borrow_flags = tcrec_compute_borrow_flags(params, body, [])
            let dm_table = tcrec_collect_dm_table(body, name, arity, params,
                                                   pnames, uses, borrow_flags, [], [])
            # Issue #599 — recompute the branch-aware skip-set so the
            # TCO-site dropmask aligns with pcs_pass's wrap-skip
            # decisions. Without this, params in skip_set get the
            # TCO drop planted while the rewriter omitted the
            # matching dup, double-freeing the original ref.
            let skip_set = pcs_branch_aware_skip_params(pnames, body)
            let new_body = tcrec_rewrite_body(body, name, arity, c_sym_str,
                                              params, pnames, uses, dm_table, skip_set, [])
            DFn(is_pub, name, tparams, params, opt_ret, row, new_body, ln, cl, mo)
          }
        }
      }
    }
    _ -> d
  }
}

# Recognise the perceus exit-drop wrap shape:
# `EBlock(stmts, Some(EVar("__pcs_ret")))`. Cheap structural test —
# only allocates if the shape matches, in which case the caller
# proceeds to extract the SLet and rebuild.

# Recognise the perceus exit-drop wrap shape:
# `EBlock(stmts, Some(EVar("__pcs_ret")))`. Cheap structural test —
# only allocates if the shape matches, in which case the caller
# proceeds to extract the SLet and rebuild.
fn tcrec_is_pcs_ret_wrap(body: Expr) : Bool {
  match body.kind {
    EBlock(_, opt_tail) -> match opt_tail {
      Some(t) -> match t.kind {
        EVar(nm) -> nm == "__pcs_ret"
        _ -> false
      }
      None -> false
    }
    _ -> false
  }
}

fn tcrec_rewrite_pcs_ret_wrap(d: Decl, is_pub: Bool, name: String,
                              tparams: [String], params: [Param],
                              opt_ret: Option[TypeExpr], row: RowExpr,
                              body: Expr, stmts: [Stmt],
                              ln: Int, cl: Int, mo: Option[String],
                              arity: Int) : Decl / Console {

  match tcrec_find_pcs_ret_let(stmts, []) {
    None -> d
    Some(triple) -> match triple {
      TcrecPcsTriple(before, inner, after) ->
        if not tcrec_has_tail_self_call(inner, name, arity) { d }
        else {
          let pnames = map(params, (p) => p.pname)
          let uses = pcs_collect_uses_expr(inner, pnames, false, [])
          if tcrec_any_unused(params, uses) { d }
          else {
            let c_sym_str = c_sym(name, mo)
            # Issue #92: same precomputation as the non-pcs-ret-wrap branch.
            let borrow_flags = tcrec_compute_borrow_flags(params, inner, [])
            let dm_table = tcrec_collect_dm_table(inner, name, arity, params,
                                                   pnames, uses, borrow_flags, [], [])
            # Issue #599 — branch-aware skip-set for TCO drop alignment.
            let skip_set = pcs_branch_aware_skip_params(pnames, inner)
            let new_inner = tcrec_rewrite_body(inner, name, arity, c_sym_str,
                                                params, pnames, uses, dm_table, skip_set, [])
            let new_body = tcrec_rebuild_pcs_ret_wrap(body, before, new_inner, after)
            DFn(is_pub, name, tparams, params, opt_ret, row, new_body, ln, cl, mo)
          }
        }
    }
  }
}

# Decomposition of `EBlock(stmts, Some(EVar("__pcs_ret")))` into the
# entry stmts before the SLet, the SLet's RHS (the original body),
# and the exit stmts after the SLet. Returns None if no
# `SLet(PBind("__pcs_ret"), _, _)` is found in stmts.

# Decomposition of `EBlock(stmts, Some(EVar("__pcs_ret")))` into the
# entry stmts before the SLet, the SLet's RHS (the original body),
# and the exit stmts after the SLet. Returns None if no
# `SLet(PBind("__pcs_ret"), _, _)` is found in stmts.
type TcrecPcsTriple = TcrecPcsTriple([Stmt], Expr, [Stmt])

fn tcrec_find_pcs_ret_let(stmts: [Stmt], before_acc: [Stmt]) : Option[TcrecPcsTriple] {
  match stmts {
    [] -> None
    [s, ...rest] -> match s {
      SLet(pat, _, rhs) -> match pat.pkind {
        PBind(nm) ->
          if nm == "__pcs_ret" {
            Some(TcrecPcsTriple(list_reverse(before_acc), rhs, rest))
          } else {
            tcrec_find_pcs_ret_let(rest, [s, ...before_acc])
          }
        _ -> tcrec_find_pcs_ret_let(rest, [s, ...before_acc])
      }
      _ -> tcrec_find_pcs_ret_let(rest, [s, ...before_acc])
    }
  }
}

fn tcrec_rebuild_pcs_ret_wrap(orig: Expr, before: [Stmt], new_inner: Expr,
                              after: [Stmt]) : Expr {
  let ret_let = SLet(
    Pattern { pkind: PBind("__pcs_ret"), line: new_inner.line, col: new_inner.col },
    None,
    new_inner
  )
  let stmts = list_append(before, [ret_let, ...after])
  let tail = Expr { kind: EVar("__pcs_ret"), line: new_inner.line, col: new_inner.col,
                    ty: new_inner.ty, mode: new_inner.mode }
  Expr { kind: EBlock(stmts, Some(tail)),
         line: orig.line, col: orig.col, ty: orig.ty, mode: orig.mode }
}

fn tcrec_any_unused(params: [Param], uses: [Use]) : Bool {
  match params {
    [] -> false
    [p, ...rest] -> match last_use_for(p.pname, uses) {
      LUUnused(_) -> true
      _ -> tcrec_any_unused(rest, uses)
    }
  }
}

# Conservative per-call-site dropmask. The criterion for each
# parameter p mirrors `pcs_collect_exit_drops` exactly:
#
#   - LUBlocked              → drop.
#   - LUAt + count(p) >= 2   → drop (every read is `__perceus_dup`-
#                               wrapped, so the original ref is
#                               unconsumed at the wrap's exit, which
#                               the goto skips).
#   - LUAt + count(p) == 1   → no drop. The single read transfers
#                               ownership to its consumer; if the
#                               consumer happens to live inside the
#                               args, evaluating them already
#                               releases p (so a goto-block drop
#                               would double-free). If the consumer
#                               lives *outside* the args (e.g. p
#                               was the scrutinee of an enclosing
#                               match — `nth`'s
#                               `match xs { … nth(t, i-1) … }`),
#                               the goto skips that match's exit
#                               `kai_decref(_scr)` and we leak the
#                               cons cell once per iteration. The
#                               leak is bounded and tracked as
#                               issue #43 / issue #92 (R6, re-land
#                               blocked — three
#                               structurally different attempts
#                               in PR #41 + PR #48 all tripped a
#                               glibc tcache-integrity abort during
#                               stage 2's selfhost on Linux). The
#                               canonical leak shape is the fixture
#                               `examples/tco/list_nth_shape.kai`.
#   - LUUnused               → unreachable (`tcrec_any_unused` made
#                               us bail out before getting here).

# Conservative per-call-site dropmask. The criterion for each
# parameter p mirrors `pcs_collect_exit_drops` exactly:
#
#   - LUBlocked              → drop.
#   - LUAt + count(p) >= 2   → drop (every read is `__perceus_dup`-
#                               wrapped, so the original ref is
#                               unconsumed at the wrap's exit, which
#                               the goto skips).
#   - LUAt + count(p) == 1   → no drop. The single read transfers
#                               ownership to its consumer; if the
#                               consumer happens to live inside the
#                               args, evaluating them already
#                               releases p (so a goto-block drop
#                               would double-free). If the consumer
#                               lives *outside* the args (e.g. p
#                               was the scrutinee of an enclosing
#                               match — `nth`'s
#                               `match xs { … nth(t, i-1) … }`),
#                               the goto skips that match's exit
#                               `kai_decref(_scr)` and we leak the
#                               cons cell once per iteration. The
#                               leak is bounded and tracked as
#                               issue #43 / issue #92 (R6, re-land
#                               blocked — three
#                               structurally different attempts
#                               in PR #41 + PR #48 all tripped a
#                               glibc tcache-integrity abort during
#                               stage 2's selfhost on Linux). The
#                               canonical leak shape is the fixture
#                               `examples/tco/list_nth_shape.kai`.
#   - LUUnused               → unreachable (`tcrec_any_unused` made
#                               us bail out before getting here).
fn tcrec_compute_site_dropmask(params: [Param], uses: [Use], skip_set: [String],
                                i: Int, acc: Int) : Int {
  match params {
    [] -> acc
    [p, ...rest] -> {
      let drop = match last_use_for(p.pname, uses) {
        LUBlocked(_) -> true
        LUAt(_, _, _) -> {
          # Issue #599 — branch-aware alignment: if the param is in
          # `skip_set`, the pcs_rewrite pass did NOT wrap reads and
          # `pcs_collect_exit_drops` suppressed the exit drop. The
          # TCO setup must NOT plant a drop either; the single read
          # transfers the ref raw to the recursive call's matching
          # arg, balanced.
          if list_has(skip_set, p.pname) { false }
          else { pcs_count_non_lam_uses(p.pname, uses, 0) >= 2 }
        }
        LUUnused(_) -> false
      }
      let acc1 = if drop { acc + tcrec_pow2(i) } else { acc }
      tcrec_compute_site_dropmask(rest, uses, skip_set, i + 1, acc1)
    }
  }
}

fn tcrec_pow2(n: Int) : Int =
  if n <= 0 { 1 } else { 2 * tcrec_pow2(n - 1) }

# ---- m37 / TCO — rule-3 side table (issue #92) ---------------------
#
# Rule 3 drops a parameter `p` at a recursive self-tail-call site
# when:
#
#   - last_use_for(p) == LUAt with count == 1 (single non-lambda
#     read), AND
#   - p does NOT appear anywhere in that call site's args.
#
# That combination means p's single use lives OUTSIDE the args (e.g.
# the scrutinee of an enclosing `match`); the goto skips that match's
# exit `kai_decref` so without an explicit drop in the goto block we
# leak one cell per iteration. The canonical shape is `nth_loop` in
# `examples/tco/list_nth_shape.kai`.
#
# Three previous attempts at re-landing this rule (PR #41, PR #48
# commits 522b9df + bd54356) hit the same Linux glibc tcache abort.
# The common factor was threading `[Expr]` (the call's args) into,
# through, or near `tcrec_compute_site_dropmask` — even when wrapped
# in a closure. A refcount imbalance in stage 1's perceus emit fires
# on that shape on Linux but not macOS.
#
# This implementation avoids the bug class entirely: a pre-pass walks
# the body once at the start of `tcrec_rewrite_decl`, computes the
# rule-3 mask for every recursive call site, and stores the result as
# a list of plain int triples (`TcrDm(line, col, mask)`). The rewrite
# then looks up the mask by `(line, col)` and OR-combines it with the
# rules-1+2 base mask. No `[Expr]` value flows through the dropmask
# computation; the side table is the same shape as `[Use]` (a list of
# small int-tuple records), already known to thread safely through
# the rewrite.

# ---- m37 / TCO — rule-3 side table (issue #92) ---------------------
#
# Rule 3 drops a parameter `p` at a recursive self-tail-call site
# when:
#
#   - last_use_for(p) == LUAt with count == 1 (single non-lambda
#     read), AND
#   - p does NOT appear anywhere in that call site's args.
#
# That combination means p's single use lives OUTSIDE the args (e.g.
# the scrutinee of an enclosing `match`); the goto skips that match's
# exit `kai_decref` so without an explicit drop in the goto block we
# leak one cell per iteration. The canonical shape is `nth_loop` in
# `examples/tco/list_nth_shape.kai`.
#
# Three previous attempts at re-landing this rule (PR #41, PR #48
# commits 522b9df + bd54356) hit the same Linux glibc tcache abort.
# The common factor was threading `[Expr]` (the call's args) into,
# through, or near `tcrec_compute_site_dropmask` — even when wrapped
# in a closure. A refcount imbalance in stage 1's perceus emit fires
# on that shape on Linux but not macOS.
#
# This implementation avoids the bug class entirely: a pre-pass walks
# the body once at the start of `tcrec_rewrite_decl`, computes the
# rule-3 mask for every recursive call site, and stores the result as
# a list of plain int triples (`TcrDm(line, col, mask)`). The rewrite
# then looks up the mask by `(line, col)` and OR-combines it with the
# rules-1+2 base mask. No `[Expr]` value flows through the dropmask
# computation; the side table is the same shape as `[Use]` (a list of
# small int-tuple records), already known to thread safely through
# the rewrite.
type TcrDm = TcrDm(Int, Int, Int)   # call-site line, col, rule-3 mask

# Pre-pass entry: walks `body` in tail position the same way
# `tcrec_rewrite_kind` does. At every recursive self-tail-call site
# it records TcrDm(f.line, f.col, rule3_mask) where `f` is the EVar
# callee. Args are inspected once (via `tcrec_args_have_evar`) to
# build the int mask, then discarded.

# Pre-pass entry: walks `body` in tail position the same way
# `tcrec_rewrite_kind` does. At every recursive self-tail-call site
# it records TcrDm(f.line, f.col, rule3_mask) where `f` is the EVar
# callee. Args are inspected once (via `tcrec_args_have_evar`) to
# build the int mask, then discarded.
fn tcrec_collect_dm_table(body: Expr, nm: String, arity: Int,
                          params: [Param], pnames: [String],
                          uses: [Use], borrow_flags: [Bool],
                          scope: [String], acc: [TcrDm]) : [TcrDm] =
  tcrec_collect_dm_kind(body.kind, nm, arity, params, pnames, uses, borrow_flags, scope, acc)

fn tcrec_collect_dm_kind(k: ExprKind, nm: String, arity: Int,
                         params: [Param], pnames: [String], uses: [Use],
                         borrow_flags: [Bool], scope: [String],
                         acc: [TcrDm]) : [TcrDm] {
  match k {
    ECall(f, xs) -> match f.kind {
      EVar(callee) ->
        if callee == nm and not list_has(scope, nm) and list_length(xs) == arity {
          let mask = tcrec_rule3_mask(params, uses, xs, borrow_flags, 0, 0)
          [TcrDm(f.line, f.col, mask), ...acc]
        } else { acc }
      _ -> acc
    }
    EIf(_, t, opt_e) -> {
      let a1 = tcrec_collect_dm_table(t, nm, arity, params, pnames, uses, borrow_flags, scope, acc)
      match opt_e {
        None -> a1
        Some(e2) -> tcrec_collect_dm_table(e2, nm, arity, params, pnames, uses, borrow_flags, scope, a1)
      }
    }
    EMatch(_, arms) -> tcrec_collect_dm_arms(arms, nm, arity, params, pnames, uses, borrow_flags, scope, acc)
    EBlock(stmts, opt_tail) -> {
      let scope1 = tcrec_block_scope(stmts, scope)
      match opt_tail {
        None -> acc
        Some(e) -> tcrec_collect_dm_table(e, nm, arity, params, pnames, uses, borrow_flags, scope1, acc)
      }
    }
    _ -> acc
  }
}

fn tcrec_collect_dm_arms(arms: [Arm], nm: String, arity: Int, params: [Param],
                         pnames: [String], uses: [Use], borrow_flags: [Bool],
                         scope: [String], acc: [TcrDm]) : [TcrDm] {
  match arms {
    [] -> acc
    [a, ...rest] -> match a {
      Arm(pat, _, body) -> {
        let scope1 = pat_bindings(pat, scope)
        let a1 = tcrec_collect_dm_table(body, nm, arity, params, pnames, uses, borrow_flags, scope1, acc)
        tcrec_collect_dm_arms(rest, nm, arity, params, pnames, uses, borrow_flags, scope, a1)
      }
    }
  }
}

# For each param i: bit i set iff rule 3 fires at this call site
# (LUAt + count==1 + param does not appear in args + single use is
# in a borrow position).
#
# Issue #92 fix: the borrow-position check is the load-bearing
# addition. Rule 3 plants `kai_internal_drop(kai_p)` in the goto
# block to reinstate a decref the goto skips. That is correct when
# the single use is in a borrow position (e.g. match scrutinee:
# `_scr = kai_p; ...; kai_decref(_scr);` — goto skips the post-do-
# while decref, so we re-add it. Or list tail spread: `kai_incref(p)`
# leaves the original ref alive, exit drops the goto skips would
# free it). The drop is WRONG when the single use is a consume
# (e.g. direct call arg `f(p)`: callee consumes p inline; nothing is
# skipped by the goto; an extra drop is a double-decref). The
# `borrow_flags[i]` bit gates the firing on this distinction.

# For each param i: bit i set iff rule 3 fires at this call site
# (LUAt + count==1 + param does not appear in args + single use is
# in a borrow position).
#
# Issue #92 fix: the borrow-position check is the load-bearing
# addition. Rule 3 plants `kai_internal_drop(kai_p)` in the goto
# block to reinstate a decref the goto skips. That is correct when
# the single use is in a borrow position (e.g. match scrutinee:
# `_scr = kai_p; ...; kai_decref(_scr);` — goto skips the post-do-
# while decref, so we re-add it. Or list tail spread: `kai_incref(p)`
# leaves the original ref alive, exit drops the goto skips would
# free it). The drop is WRONG when the single use is a consume
# (e.g. direct call arg `f(p)`: callee consumes p inline; nothing is
# skipped by the goto; an extra drop is a double-decref). The
# `borrow_flags[i]` bit gates the firing on this distinction.
fn tcrec_rule3_mask(params: [Param], uses: [Use], args: [Expr],
                    borrow_flags: [Bool], i: Int, acc: Int) : Int {
  match params {
    [] -> acc
    [p, ...rest] -> {
      let fire = match last_use_for(p.pname, uses) {
        LUAt(_, _, _) ->
          if pcs_count_non_lam_uses(p.pname, uses, 0) == 1 {
            if tcrec_args_have_evar(args, p.pname) { false }
            else { tcrec_nth_bool(borrow_flags, i, false) }
          } else { false }
        _ -> false
      }
      let acc1 = if fire { acc + tcrec_pow2(i) } else { acc }
      let rest_flags = match borrow_flags {
        [] -> []
        [_, ...t] -> t
      }
      tcrec_rule3_mask(rest, uses, args, rest_flags, i + 1, acc1)
    }
  }
}

# List index helper for `[Bool]`. Returns `dflt` if `i` is out of bounds.

# List index helper for `[Bool]`. Returns `dflt` if `i` is out of bounds.
fn tcrec_nth_bool(xs: [Bool], i: Int, dflt: Bool) : Bool {
  match xs {
    [] -> dflt
    [h, ...rest] -> if i <= 0 { h } else { tcrec_nth_bool(rest, i - 1, dflt) }
  }
}

# Issue #92 — single-use borrow predicate. CONSERVATIVE: returns true
# only when the (presumed unique by caller's count==1 precondition)
# `EVar(p)` occurrence is a list-tail-spread `[..., ...p]`. That is
# the one position whose decref the goto path is GUARANTEED to skip,
# regardless of perceus's downstream choices, because
# `kai_incref(p)` for the cons cell leaves the original ref alive
# and only the goto-skipped exit-drops would release it.
#
# Match scrutinees (`match p { ... }`) are deliberately NOT treated as
# borrow here even though they superficially look like one. Whether
# the post-do-while `kai_decref(_scr)` is reachable from the recursive
# call depends on perceus's "tail-always-sentinel" arm-shape decision
# (issue #309): if every tail leaf of the arm body is a self-tail-
# call, perceus injects an early `kai_decref(_scr)` BEFORE the goto,
# and rule 3's extra drop becomes a double-decref. The
# scrutinee-borrow case requires per-call-site reasoning over the
# enclosing arm body, which is out of scope for this fix; the leak
# the canonical `nth_loop` fixture exhibits remains bounded
# (one cons cell per iteration) and falls under the existing
# rules-1+2 conservative dropmask.
#
# Every other position (call args, binop operands, field/index that
# internally dup-and-decref, etc.) consumes `p` inline; rule 3 there
# would double-decref.

# Issue #92 — single-use borrow predicate. CONSERVATIVE: returns true
# only when the (presumed unique by caller's count==1 precondition)
# `EVar(p)` occurrence is a list-tail-spread `[..., ...p]`. That is
# the one position whose decref the goto path is GUARANTEED to skip,
# regardless of perceus's downstream choices, because
# `kai_incref(p)` for the cons cell leaves the original ref alive
# and only the goto-skipped exit-drops would release it.
#
# Match scrutinees (`match p { ... }`) are deliberately NOT treated as
# borrow here even though they superficially look like one. Whether
# the post-do-while `kai_decref(_scr)` is reachable from the recursive
# call depends on perceus's "tail-always-sentinel" arm-shape decision
# (issue #309): if every tail leaf of the arm body is a self-tail-
# call, perceus injects an early `kai_decref(_scr)` BEFORE the goto,
# and rule 3's extra drop becomes a double-decref. The
# scrutinee-borrow case requires per-call-site reasoning over the
# enclosing arm body, which is out of scope for this fix; the leak
# the canonical `nth_loop` fixture exhibits remains bounded
# (one cons cell per iteration) and falls under the existing
# rules-1+2 conservative dropmask.
#
# Every other position (call args, binop operands, field/index that
# internally dup-and-decref, etc.) consumes `p` inline; rule 3 there
# would double-decref.
fn tcrec_use_is_borrow(body: Expr, p: String) : Bool =
  tcrec_use_borrow_kind(body.kind, p)

fn tcrec_use_borrow_kind(k: ExprKind, p: String) : Bool {
  match k {
    EList(elems) -> tcrec_elems_use_borrow(elems, p)
    EMatch(s, arms) ->
      if tcrec_use_borrow_kind(s.kind, p) { true }
      else { tcrec_arms_use_borrow(arms, p) }
    ECall(f, xs) ->
      if tcrec_use_borrow_kind(f.kind, p) { true }
      else { tcrec_args_use_borrow(xs, p) }
    EBinop(_, l, r) ->
      if tcrec_use_borrow_kind(l.kind, p) { true }
      else { tcrec_use_borrow_kind(r.kind, p) }
    EUnop(_, x) -> tcrec_use_borrow_kind(x.kind, p)
    EField(x, _) -> tcrec_use_borrow_kind(x.kind, p)
    EIndex(x, i) ->
      if tcrec_use_borrow_kind(x.kind, p) { true }
      else { tcrec_use_borrow_kind(i.kind, p) }
    EIf(c, t, opt_e) ->
      if tcrec_use_borrow_kind(c.kind, p) { true }
      else if tcrec_use_borrow_kind(t.kind, p) { true }
      else { match opt_e {
        None -> false
        Some(e2) -> tcrec_use_borrow_kind(e2.kind, p)
      } }
    EBlock(stmts, opt_tail) ->
      if tcrec_stmts_use_borrow(stmts, p) { true }
      else { match opt_tail {
        None -> false
        Some(e) -> tcrec_use_borrow_kind(e.kind, p)
      } }
    ERange(lo, hi, opt_by) ->
      if tcrec_use_borrow_kind(lo.kind, p) { true }
      else if tcrec_use_borrow_kind(hi.kind, p) { true }
      else { match opt_by {
        None -> false
        Some(e) -> tcrec_use_borrow_kind(e.kind, p)
      } }
    ERecordLit(_, fis) -> tcrec_fis_use_borrow(fis, p)
    EPipe(l, r) ->
      if tcrec_use_borrow_kind(l.kind, p) { true }
      else { tcrec_use_borrow_kind(r.kind, p) }
    EMapPipe(l, r) ->
      if tcrec_use_borrow_kind(l.kind, p) { true }
      else { tcrec_use_borrow_kind(r.kind, p) }
    EFlatMapPipe(l, r) ->
      if tcrec_use_borrow_kind(l.kind, p) { true }
      else { tcrec_use_borrow_kind(r.kind, p) }
    EFilterPipe(l, r) ->
      if tcrec_use_borrow_kind(l.kind, p) { true }
      else { tcrec_use_borrow_kind(r.kind, p) }
    EBang(inner) -> tcrec_use_borrow_kind(inner.kind, p)
    # Lambda bodies are excluded from the count by
    # `pcs_count_non_lam_uses`, so they cannot be the unique use.
    ELambda(_, _) -> false
    _ -> false
  }
}

fn tcrec_args_use_borrow(args: [Expr], p: String) : Bool {
  match args {
    [] -> false
    [h, ...rest] ->
      if tcrec_use_borrow_kind(h.kind, p) { true }
      else { tcrec_args_use_borrow(rest, p) }
  }
}

fn tcrec_arms_use_borrow(arms: [Arm], p: String) : Bool {
  match arms {
    [] -> false
    [a, ...rest] -> match a {
      Arm(_, opt_g, body) -> {
        let g_hit = match opt_g {
          None -> false
          Some(g) -> tcrec_use_borrow_kind(g.kind, p)
        }
        if g_hit { true }
        else if tcrec_use_borrow_kind(body.kind, p) { true }
        else { tcrec_arms_use_borrow(rest, p) }
      }
    }
  }
}

fn tcrec_stmts_use_borrow(stmts: [Stmt], p: String) : Bool {
  match stmts {
    [] -> false
    [s, ...rest] -> {
      let here = match s {
        SLet(_, _, e) -> tcrec_use_borrow_kind(e.kind, p)
        SVar(_, _, e, _, _) -> tcrec_use_borrow_kind(e.kind, p)
        SAssert(c, opt_m) ->
          if tcrec_use_borrow_kind(c.kind, p) { true }
          else { match opt_m {
            None -> false
            Some(m) -> tcrec_use_borrow_kind(m.kind, p)
          } }
        SExprStmt(e) -> tcrec_use_borrow_kind(e.kind, p)
        SIndexAssign(b, i, v, _, _) ->
          if tcrec_use_borrow_kind(b.kind, p) { true }
          else if tcrec_use_borrow_kind(i.kind, p) { true }
          else { tcrec_use_borrow_kind(v.kind, p) }
        SUse(_, _, _) -> false
      }
      if here { true } else { tcrec_stmts_use_borrow(rest, p) }
    }
  }
}

fn tcrec_elems_use_borrow(elems: [ListElem], p: String) : Bool {
  match elems {
    [] -> false
    [e, ...rest] -> {
      let here = match e {
        ElSpread(x) -> match x.kind {
          EVar(nm) -> nm == p
          _ -> tcrec_use_borrow_kind(x.kind, p)
        }
        ElPlain(x) -> tcrec_use_borrow_kind(x.kind, p)
      }
      if here { true } else { tcrec_elems_use_borrow(rest, p) }
    }
  }
}

fn tcrec_fis_use_borrow(fis: [FieldInit], p: String) : Bool {
  match fis {
    [] -> false
    [h, ...rest] -> match h {
      FI(_, e) ->
        if tcrec_use_borrow_kind(e.kind, p) { true }
        else { tcrec_fis_use_borrow(rest, p) }
    }
  }
}

# Per-param borrow flag, computed once at fn entry. Bit i (== flag at
# index i in the returned [Bool]) is true iff param i's single
# non-lambda use is in a borrow position. Only meaningful when
# `pcs_count_non_lam_uses(p) == 1`; the rule-3 mask gates on count
# before consulting this flag.

# Per-param borrow flag, computed once at fn entry. Bit i (== flag at
# index i in the returned [Bool]) is true iff param i's single
# non-lambda use is in a borrow position. Only meaningful when
# `pcs_count_non_lam_uses(p) == 1`; the rule-3 mask gates on count
# before consulting this flag.
fn tcrec_compute_borrow_flags(params: [Param], body: Expr, acc: [Bool]) : [Bool] {
  match params {
    [] -> list_reverse(acc)
    [p, ...rest] -> {
      let flag = tcrec_use_is_borrow(body, p.pname)
      tcrec_compute_borrow_flags(rest, body, [flag, ...acc])
    }
  }
}

# True iff EVar(p) appears anywhere inside `args` (recursively). Only
# called from the pre-pass walker; never threaded through the rewrite.

# True iff EVar(p) appears anywhere inside `args` (recursively). Only
# called from the pre-pass walker; never threaded through the rewrite.
fn tcrec_args_have_evar(args: [Expr], p: String) : Bool {
  match args {
    [] -> false
    [h, ...rest] ->
      if tcrec_expr_has_evar(h, p) { true }
      else { tcrec_args_have_evar(rest, p) }
  }
}

fn tcrec_expr_has_evar(e: Expr, p: String) : Bool =
  tcrec_kind_has_evar(e.kind, p)

fn tcrec_kind_has_evar(k: ExprKind, p: String) : Bool {
  match k {
    EVar(nm) -> nm == p
    ECall(f, xs) ->
      if tcrec_expr_has_evar(f, p) { true } else { tcrec_args_have_evar(xs, p) }
    EBinop(_, l, r) ->
      if tcrec_expr_has_evar(l, p) { true } else { tcrec_expr_has_evar(r, p) }
    EUnop(_, x) -> tcrec_expr_has_evar(x, p)
    EField(x, _) -> tcrec_expr_has_evar(x, p)
    EIndex(x, i) ->
      if tcrec_expr_has_evar(x, p) { true } else { tcrec_expr_has_evar(i, p) }
    EIf(c, t, opt_e) ->
      if tcrec_expr_has_evar(c, p) { true }
      else if tcrec_expr_has_evar(t, p) { true }
      else { match opt_e {
        None -> false
        Some(e2) -> tcrec_expr_has_evar(e2, p)
      } }
    EMatch(s, arms) ->
      if tcrec_expr_has_evar(s, p) { true }
      else { tcrec_arms_have_evar(arms, p) }
    EBlock(stmts, opt_tail) ->
      if tcrec_stmts_have_evar(stmts, p) { true }
      else { match opt_tail {
        None -> false
        Some(e) -> tcrec_expr_has_evar(e, p)
      } }
    EList(elems) -> tcrec_list_elems_have_evar(elems, p)
    ERange(lo, hi, opt_by) ->
      if tcrec_expr_has_evar(lo, p) { true }
      else if tcrec_expr_has_evar(hi, p) { true }
      else { match opt_by {
        None -> false
        Some(e) -> tcrec_expr_has_evar(e, p)
      } }
    ERecordLit(_, fis) -> tcrec_field_inits_have_evar(fis, p)
    EPipe(l, r) ->
      if tcrec_expr_has_evar(l, p) { true } else { tcrec_expr_has_evar(r, p) }
    EMapPipe(l, r) ->
      if tcrec_expr_has_evar(l, p) { true } else { tcrec_expr_has_evar(r, p) }
    EFlatMapPipe(l, r) ->
      if tcrec_expr_has_evar(l, p) { true } else { tcrec_expr_has_evar(r, p) }
    EFilterPipe(l, r) ->
      if tcrec_expr_has_evar(l, p) { true } else { tcrec_expr_has_evar(r, p) }
    EBang(inner) -> tcrec_expr_has_evar(inner, p)
    EStr(span, is_triple) -> tcrec_str_has_evar(span, is_triple, p)
    ELambda(_, body) -> tcrec_expr_has_evar(body, p)
    _ -> false
  }
}

fn tcrec_arms_have_evar(arms: [Arm], p: String) : Bool {
  match arms {
    [] -> false
    [a, ...rest] -> match a {
      Arm(_, opt_g, body) -> {
        let g_hit = match opt_g {
          None -> false
          Some(g) -> tcrec_expr_has_evar(g, p)
        }
        if g_hit { true }
        else if tcrec_expr_has_evar(body, p) { true }
        else { tcrec_arms_have_evar(rest, p) }
      }
    }
  }
}

fn tcrec_stmts_have_evar(stmts: [Stmt], p: String) : Bool {
  match stmts {
    [] -> false
    [s, ...rest] -> {
      let here = match s {
        SLet(_, _, e) -> tcrec_expr_has_evar(e, p)
        SVar(_, _, e, _, _) -> tcrec_expr_has_evar(e, p)
        SAssert(c, opt_m) ->
          if tcrec_expr_has_evar(c, p) { true }
          else { match opt_m {
            None -> false
            Some(m) -> tcrec_expr_has_evar(m, p)
          } }
        SExprStmt(e) -> tcrec_expr_has_evar(e, p)
        SIndexAssign(b, i, v, _, _) ->
          if tcrec_expr_has_evar(b, p) { true }
          else if tcrec_expr_has_evar(i, p) { true }
          else { tcrec_expr_has_evar(v, p) }
        SUse(_, _, _) -> false
      }
      if here { true } else { tcrec_stmts_have_evar(rest, p) }
    }
  }
}

fn tcrec_list_elems_have_evar(elems: [ListElem], p: String) : Bool {
  match elems {
    [] -> false
    [e, ...rest] -> {
      let here = match e {
        ElPlain(x) -> tcrec_expr_has_evar(x, p)
        ElSpread(x) -> tcrec_expr_has_evar(x, p)
      }
      if here { true } else { tcrec_list_elems_have_evar(rest, p) }
    }
  }
}

fn tcrec_field_inits_have_evar(fis: [FieldInit], p: String) : Bool {
  match fis {
    [] -> false
    [h, ...rest] -> match h {
      FI(_, e) ->
        if tcrec_expr_has_evar(e, p) { true }
        else { tcrec_field_inits_have_evar(rest, p) }
    }
  }
}

# Conservative fallback for interpolated strings: assume any interp
# segment (`#{...}`) might reference `p`. The exact-decode path
# (`scan_uses_interp_parts` + friends) requires re-lexing and is
# overkill — rule 3 erring on the safe side just means we skip a
# drop opportunity (revert to the current conservative dropmask),
# never that we double-free. A bare-string literal with no `#{`
# clearly cannot reference any binding, so we short-circuit it.

# Conservative fallback for interpolated strings: assume any interp
# segment (`#{...}`) might reference `p`. The exact-decode path
# (`scan_uses_interp_parts` + friends) requires re-lexing and is
# overkill — rule 3 erring on the safe side just means we skip a
# drop opportunity (revert to the current conservative dropmask),
# never that we double-free. A bare-string literal with no `#{`
# clearly cannot reference any binding, so we short-circuit it.
fn tcrec_str_has_evar(span: String, _is_triple: Bool, _p: String) : Bool =
  tcrec_span_has_interp(span, 0, string_length(span))

fn tcrec_span_has_interp(s: String, i: Int, n: Int) : Bool {
  if i + 1 >= n { false }
  else { match char_at(s, i) {
    None -> false
    Some(c) ->
      if c == '#' {
        match char_at(s, i + 1) {
          Some(d) -> if d == '{' { true } else { tcrec_span_has_interp(s, i + 1, n) }
          None -> false
        }
      } else { tcrec_span_has_interp(s, i + 1, n) }
  } }
}

# Lookup the rule-3 mask for the call site at (line, col). Returns 0
# if the call site is not in the table (e.g. shadowed by a local
# binding the rewriter walks into separately).

# Lookup the rule-3 mask for the call site at (line, col). Returns 0
# if the call site is not in the table (e.g. shadowed by a local
# binding the rewriter walks into separately).
fn tcrec_lookup_dm(table: [TcrDm], line: Int, col: Int) : Int {
  match table {
    [] -> 0
    [h, ...rest] -> match h {
      TcrDm(l, c, m) ->
        if l == line and c == col { m }
        else { tcrec_lookup_dm(rest, line, col) }
    }
  }
}

# Issue #102: omit the trailing `|` when pnames is empty (zero-arg
# self-tail-call). The decoder `tcrec_split_pipe` then yields exactly
# 3 parts and `[_, sym, mask, ...pnames]` matches with `pnames = []`,
# so `tcrec_emit_rebinds` correctly emits nothing — instead of the
# malformed `kai_ = _t0;` produced when an empty trailing element
# leaked into the pnames list.

# Issue #102: omit the trailing `|` when pnames is empty (zero-arg
# self-tail-call). The decoder `tcrec_split_pipe` then yields exactly
# 3 parts and `[_, sym, mask, ...pnames]` matches with `pnames = []`,
# so `tcrec_emit_rebinds` correctly emits nothing — instead of the
# malformed `kai_ = _t0;` produced when an empty trailing element
# leaked into the pnames list.
fn tcrec_make_sentinel(sym: String, dropmask: Int, pnames: [String]) : String =
  match pnames {
    [] -> concat_all(["__kai_tcrec|", sym, "|", int_to_string(dropmask)])
    _  -> concat_all(["__kai_tcrec|", sym, "|", int_to_string(dropmask),
                      "|", string_join(pnames, "|")])
  }

# Issue #706: the sentinel wire-format helpers now live in
# `emit_shared.kai` (`es_tcrec_*`) so both the C and LLVM emitters
# decode the same format. These thin wrappers preserve the local call
# sites unchanged.
fn tcrec_is_sentinel(callee: String) : Bool = es_tcrec_is_sentinel(callee)

fn tcrec_split_pipe(s: String) : [String] = es_tcrec_split_pipe(s)

# Tail-position rewrite. Mirrors the M1 walker but produces a fresh
# `Expr` tree where each tail-self-call's callee has been swapped
# for a freshly-built sentinel `EVar` whose dropmask is computed
# *per call site* by inspecting that site's args. Args are not
# recursed into — they are non-tail and `emit_expr` evaluates
# them normally on emit.

# Tail-position rewrite. Mirrors the M1 walker but produces a fresh
# `Expr` tree where each tail-self-call's callee has been swapped
# for a freshly-built sentinel `EVar` whose dropmask is computed
# *per call site* by inspecting that site's args. Args are not
# recursed into — they are non-tail and `emit_expr` evaluates
# them normally on emit.
fn tcrec_rewrite_body(body: Expr, nm: String, arity: Int, c_sym_str: String,
                      params: [Param], pnames: [String], uses: [Use],
                      dm_table: [TcrDm], skip_set: [String], scope: [String]) : Expr =
  Expr { kind: tcrec_rewrite_kind(body.kind, body.line, body.col, nm, arity,
                                   c_sym_str, params, pnames, uses, dm_table, skip_set, scope),
         line: body.line, col: body.col, ty: body.ty, mode: body.mode }

fn tcrec_rewrite_kind(k: ExprKind, line: Int, col: Int, nm: String, arity: Int,
                      c_sym_str: String, params: [Param], pnames: [String],
                      uses: [Use], dm_table: [TcrDm], skip_set: [String], scope: [String]) : ExprKind {
  match k {
    ECall(f, xs) -> match f.kind {
      EVar(callee) ->
        if callee == nm and not list_has(scope, nm) and list_length(xs) == arity {
          # Rules 1+2 (LUBlocked / LUAt count >= 2) are per-fn — same
          # at every site. Rule 3 (LUAt count == 1 + p not in args)
          # is per-site and looked up by (line, col) in the side table
          # built once at `tcrec_rewrite_decl` entry. The two masks are
          # disjoint by construction (rule 1+2 fires on count==0 or
          # count>=2; rule 3 fires only on count==1) so OR == ADD.
          let base_mask = tcrec_compute_site_dropmask(params, uses, skip_set, 0, 0)
          let rule3_mask = tcrec_lookup_dm(dm_table, f.line, f.col)
          let dropmask = base_mask + rule3_mask
          let sentinel = tcrec_make_sentinel(c_sym_str, dropmask, pnames)
          ECall(
            Expr { kind: EVar(sentinel), line: f.line, col: f.col,
                   ty: f.ty, mode: f.mode },
            xs)
        } else { k }
      _ -> k
    }
    EIf(c, t, opt_e) -> {
      let t1 = tcrec_rewrite_body(t, nm, arity, c_sym_str, params, pnames, uses, dm_table, skip_set, scope)
      let opt_e1 = match opt_e {
        None -> None
        Some(e2) -> Some(tcrec_rewrite_body(e2, nm, arity, c_sym_str, params,
                                            pnames, uses, dm_table, skip_set, scope))
      }
      EIf(c, t1, opt_e1)
    }
    EMatch(s, arms) ->
      EMatch(s, tcrec_rewrite_arms(arms, nm, arity, c_sym_str, params, pnames,
                                    uses, dm_table, skip_set, scope, []))
    EBlock(stmts, opt_tail) -> {
      let scope1 = tcrec_block_scope(stmts, scope)
      match opt_tail {
        None -> k
        Some(e) ->
          EBlock(stmts, Some(tcrec_rewrite_body(e, nm, arity, c_sym_str, params,
                                                 pnames, uses, dm_table, skip_set, scope1)))
      }
    }
    _ -> k
  }
}

fn tcrec_rewrite_arms(arms: [Arm], nm: String, arity: Int, c_sym_str: String,
                      params: [Param], pnames: [String], uses: [Use],
                      dm_table: [TcrDm], skip_set: [String], scope: [String], acc: [Arm]) : [Arm] {
  match arms {
    [] -> list_reverse(acc)
    [a, ...rest] -> match a {
      Arm(pat, opt_g, body) -> {
        let scope1 = pat_bindings(pat, scope)
        let new_body = tcrec_rewrite_body(body, nm, arity, c_sym_str, params,
                                          pnames, uses, dm_table, skip_set, scope1)
        tcrec_rewrite_arms(rest, nm, arity, c_sym_str, params, pnames, uses,
                           dm_table, skip_set, scope, [Arm(pat, opt_g, new_body), ...acc])
      }
    }
  }
}

# Recognition predicate used by `emit_fn_body` to decide whether to
# plant the goto label. Recurses into every sub-expression, not just
# tail position, because a sentinel can sit anywhere the rewrite
# placed one (currently always tail; future relaxations may place
# them elsewhere).

# Recognition predicate used by `emit_fn_body` to decide whether to
# plant the goto label. Recurses into every sub-expression, not just
# tail position, because a sentinel can sit anywhere the rewrite
# placed one (currently always tail; future relaxations may place
# them elsewhere).
fn tcrec_body_has_sentinel(body: Expr) : Bool =
  tcrec_scan_kind(body.kind)

# Issue #309 — recognise expressions whose every tail position is a
# tcrec sentinel call. Stricter than `tcrec_body_has_sentinel`: only
# returns true when control-flow guarantees the goto fires (i.e. no
# tail leaf evaluates to a normal value). Used by `emit_match_arm`
# to decide whether it is safe to inject a `kai_decref(_scr)` before
# evaluating the arm body — when the goto is guaranteed, the arm's
# normal post-do-while `kai_decref(_scr)` is unreachable and the
# pre-injected drop closes the leak without risking a double-decref.
# Conservative: ECall checks only the head EVar; recurses through
# EIf / EMatch / EBlock tail. Anything else returns false.

# Issue #309 — recognise expressions whose every tail position is a
# tcrec sentinel call. Stricter than `tcrec_body_has_sentinel`: only
# returns true when control-flow guarantees the goto fires (i.e. no
# tail leaf evaluates to a normal value). Used by `emit_match_arm`
# to decide whether it is safe to inject a `kai_decref(_scr)` before
# evaluating the arm body — when the goto is guaranteed, the arm's
# normal post-do-while `kai_decref(_scr)` is unreachable and the
# pre-injected drop closes the leak without risking a double-decref.
# Conservative: ECall checks only the head EVar; recurses through
# EIf / EMatch / EBlock tail. Anything else returns false.
fn tcrec_tail_always_sentinel(body: Expr) : Bool =
  tcrec_tail_is_sentinel_kind(body.kind)

fn tcrec_tail_is_sentinel_kind(k: ExprKind) : Bool {
  match k {
    ECall(f, _) -> match f.kind {
      EVar(callee) -> tcrec_is_sentinel(callee)
      _ -> false
    }
    EIf(_, t, opt_e) -> match opt_e {
      None -> false
      Some(e2) -> if tcrec_tail_always_sentinel(t) {
        tcrec_tail_always_sentinel(e2)
      } else { false }
    }
    EMatch(_, arms) -> tcrec_tail_arms_always_sentinel(arms)
    EBlock(_, opt_tail) -> match opt_tail {
      None -> false
      Some(e) -> tcrec_tail_always_sentinel(e)
    }
    _ -> false
  }
}

fn tcrec_tail_arms_always_sentinel(arms: [Arm]) : Bool {
  match arms {
    [] -> false
    [a, ...rest] -> match a {
      Arm(_, _, body) ->
        if tcrec_tail_always_sentinel(body) {
          match rest {
            [] -> true
            _  -> tcrec_tail_arms_always_sentinel(rest)
          }
        } else { false }
    }
  }
}

fn tcrec_scan_kind(k: ExprKind) : Bool {
  match k {
    ECall(f, xs) -> match f.kind {
      EVar(callee) ->
        if tcrec_is_sentinel(callee) { true }
        else { tcrec_scan_exprs(xs) }
      _ -> if tcrec_body_has_sentinel(f) { true } else { tcrec_scan_exprs(xs) }
    }
    EIf(c, t, opt_e) ->
      if tcrec_body_has_sentinel(c) { true }
      else if tcrec_body_has_sentinel(t) { true }
      else { match opt_e {
        None -> false
        Some(e2) -> tcrec_body_has_sentinel(e2)
      } }
    EMatch(s, arms) ->
      if tcrec_body_has_sentinel(s) { true } else { tcrec_scan_arms(arms) }
    EBlock(stmts, opt_tail) ->
      if tcrec_scan_stmts(stmts) { true }
      else { match opt_tail {
        None -> false
        Some(e) -> tcrec_body_has_sentinel(e)
      } }
    EBinop(_, l, r) ->
      if tcrec_body_has_sentinel(l) { true } else { tcrec_body_has_sentinel(r) }
    EUnop(_, x) -> tcrec_body_has_sentinel(x)
    EField(x, _) -> tcrec_body_has_sentinel(x)
    EIndex(x, i) ->
      if tcrec_body_has_sentinel(x) { true } else { tcrec_body_has_sentinel(i) }
    EPipe(l, r) ->
      if tcrec_body_has_sentinel(l) { true } else { tcrec_body_has_sentinel(r) }
    EMapPipe(l, r) ->
      if tcrec_body_has_sentinel(l) { true } else { tcrec_body_has_sentinel(r) }
    EFlatMapPipe(l, r) ->
      if tcrec_body_has_sentinel(l) { true } else { tcrec_body_has_sentinel(r) }
    EFilterPipe(l, r) ->
      if tcrec_body_has_sentinel(l) { true } else { tcrec_body_has_sentinel(r) }
    _ -> false
  }
}

fn tcrec_scan_exprs(es: [Expr]) : Bool {
  match es {
    [] -> false
    [h, ...rest] ->
      if tcrec_body_has_sentinel(h) { true } else { tcrec_scan_exprs(rest) }
  }
}

fn tcrec_scan_arms(arms: [Arm]) : Bool {
  match arms {
    [] -> false
    [a, ...rest] -> match a {
      Arm(_, _, body) ->
        if tcrec_body_has_sentinel(body) { true } else { tcrec_scan_arms(rest) }
    }
  }
}

fn tcrec_scan_stmts(stmts: [Stmt]) : Bool {
  match stmts {
    [] -> false
    [s, ...rest] -> {
      let here = match s {
        SLet(_, _, e) -> tcrec_body_has_sentinel(e)
        SVar(_, _, e, _, _) -> tcrec_body_has_sentinel(e)
        SAssert(c, opt_m) ->
          if tcrec_body_has_sentinel(c) { true }
          else { match opt_m {
            None -> false
            Some(m) -> tcrec_body_has_sentinel(m)
          } }
        SExprStmt(e) -> tcrec_body_has_sentinel(e)
        SIndexAssign(b, i, v, _, _) ->
          if tcrec_body_has_sentinel(b) { true }
          else if tcrec_body_has_sentinel(i) { true }
          else { tcrec_body_has_sentinel(v) }
        SUse(_, _, _) -> false
      }
      if here { true } else { tcrec_scan_stmts(rest) }
    }
  }
}

# Decimal parser used by the emit-side sentinel decoder. Stops at
# the first non-digit; returns 0 on an empty / malformed input. The
# encoder emits via `int_to_string` so only `[0-9]+` ever reaches us.

# Decimal parser used by the emit-side sentinel decoder. Stops at
# the first non-digit; returns 0 on an empty / malformed input. The
# encoder emits via `int_to_string` so only `[0-9]+` ever reaches us.
fn tcrec_parse_decimal(s: String) : Int = es_tcrec_parse_decimal(s)

# ---- m37 / TCO — goto-block emission ------------------------------
#
# Called from `emit_call_expr` when the callee's `EVar` carries a
# `__kai_tcrec|...` sentinel. Emits the rebind-and-goto block
# documented in `tcrec_rewrite_decl`. Refcount discipline:
#
# 1. Evaluate every arg into a fresh `_t<i>` local (each with rc=1
#    per the Perceus contract — args may share storage with a
#    parameter only via `kai_internal_dup`, which already bumped rc).
# 2. Drop the params whose bit is set in the dropmask. Those are
#    exactly the params that would have been dropped by the wrap's
#    exit drops, which the goto skips by jumping out of the
#    enclosing statement-expression.
# 3. Rebind `kai_<pname> = _t<i>`, in declaration order. Each
#    rebound variable now holds rc=1, the same invariant the wrap
#    relies on at fn entry.
# 4. Goto the entry label planted by `emit_fn_body`.
# 5. Trailing `(KaiValue *)0;` so the statement-expression is a
#    well-typed lvalue; the value is unreachable past the goto.

# ---- m37 / TCO — goto-block emission ------------------------------
#
# Called from `emit_call_expr` when the callee's `EVar` carries a
# `__kai_tcrec|...` sentinel. Emits the rebind-and-goto block
# documented in `tcrec_rewrite_decl`. Refcount discipline:
#
# 1. Evaluate every arg into a fresh `_t<i>` local (each with rc=1
#    per the Perceus contract — args may share storage with a
#    parameter only via `kai_internal_dup`, which already bumped rc).
# 2. Drop the params whose bit is set in the dropmask. Those are
#    exactly the params that would have been dropped by the wrap's
#    exit drops, which the goto skips by jumping out of the
#    enclosing statement-expression.
# 3. Rebind `kai_<pname> = _t<i>`, in declaration order. Each
#    rebound variable now holds rc=1, the same invariant the wrap
#    relies on at fn entry.
# 4. Goto the entry label planted by `emit_fn_body`.
# 5. Trailing `(KaiValue *)0;` so the statement-expression is a
#    well-typed lvalue; the value is unreachable past the goto.
fn tcrec_emit_goto(src: String, sym: String, dropmask: Int, pnames: [String],
                   args_e: [Expr], cx: EmitCtx) : String / Console {

  # Phase 3 unboxing — when the recursive callee is a UFn, the
  # rebound parameters are raw scalars (`kair_<name>`) and the
  # arg values are evaluated as raw expressions. Drops collapse
  # to no-ops since raw scalars carry no reference count.
  match lookup_ufn_by_csym(cx.fns, sym) {
    Some(US(pts, _)) -> {
      let arg_lets = tcrec_emit_arg_lets_raw(src, args_e, pts, 0, cx)
      let rebinds  = tcrec_emit_rebinds_raw(pnames, 0)
      concat_all([
        "({ ", arg_lets, rebinds,
        "goto _kai_", sym, "_entry; 0; })"
      ])
    }
    None -> {
      let arg_lets = tcrec_emit_arg_lets(src, args_e, 0, cx)
      let drops    = tcrec_emit_drops(pnames, dropmask, 0)
      let rebinds  = tcrec_emit_rebinds(pnames, 0)
      concat_all([
        "({ ", arg_lets, drops, rebinds,
        "goto _kai_", sym, "_entry; (KaiValue *)0; })"
      ])
    }
  }
}

fn tcrec_emit_arg_lets(src: String, args_e: [Expr], i: Int, cx: EmitCtx) : String / Console {

  match args_e {
    [] -> ""
    [a, ...rest] -> {
      let arg_c = emit_expr(src, a, cx)
      let head = concat_all([
        "KaiValue *_t", int_to_string(i), " = ", arg_c, "; "
      ])
      string_concat(head,
        tcrec_emit_arg_lets(src, rest, i + 1, cx))
    }
  }
}

# Phase 3 unboxing — same shape as `tcrec_emit_arg_lets` but each
# `_tN` is a raw scalar matching the corresponding UFn param ty,
# and the rhs is built by `emit_expr_raw`. The decoupling between
# arg evaluation (into temporaries) and rebind (back to param
# locals) preserves the original sequencing — the prior args may
# have referenced the old param values, so all temporaries are
# computed before any rebind fires.

# Phase 3 unboxing — same shape as `tcrec_emit_arg_lets` but each
# `_tN` is a raw scalar matching the corresponding UFn param ty,
# and the rhs is built by `emit_expr_raw`. The decoupling between
# arg evaluation (into temporaries) and rebind (back to param
# locals) preserves the original sequencing — the prior args may
# have referenced the old param values, so all temporaries are
# computed before any rebind fires.
fn tcrec_emit_arg_lets_raw(src: String, args_e: [Expr], pts: [Ty], i: Int, cx: EmitCtx) : String / Console {

  match args_e {
    [] -> ""
    [a, ...rest] -> {
      let pty = match pts {
        [t, ...trest] -> t
        []            -> match a.ty { Some(t) -> t None -> TyInt }
      }
      let trest = match pts {
        [_, ...r] -> r
        []        -> []
      }
      let arg_c = emit_expr_raw(src, a, cx)
      let head = concat_all([
        raw_c_type(Some(pty)), " _t", int_to_string(i), " = ", arg_c, "; "
      ])
      string_concat(head,
        tcrec_emit_arg_lets_raw(src, rest, trest, i + 1, cx))
    }
  }
}

fn tcrec_emit_drops(pnames: [String], dropmask: Int, i: Int) : String {
  match pnames {
    [] -> ""
    [p, ...rest] -> {
      let bit = tcrec_pow2(i)
      let head =
        if (dropmask / bit) % 2 == 1 {
          concat_all([
            "{ KaiValue *_ = kai_internal_drop(kai_", p, "); (void) _; } "
          ])
        } else { "" }
      string_concat(head, tcrec_emit_drops(rest, dropmask, i + 1))
    }
  }
}

fn tcrec_emit_rebinds(pnames: [String], i: Int) : String {
  match pnames {
    [] -> ""
    [p, ...rest] -> {
      let head = concat_all([
        "kai_", p, " = _t", int_to_string(i), "; "
      ])
      string_concat(head, tcrec_emit_rebinds(rest, i + 1))
    }
  }
}

# Phase 3 unboxing — rebind raw param locals (`kair_<name>`) from
# the temporaries computed by `tcrec_emit_arg_lets_raw`.

# Phase 3 unboxing — rebind raw param locals (`kair_<name>`) from
# the temporaries computed by `tcrec_emit_arg_lets_raw`.
fn tcrec_emit_rebinds_raw(pnames: [String], i: Int) : String {
  match pnames {
    [] -> ""
    [p, ...rest] -> {
      let head = concat_all([
        "kair_", p, " = _t", int_to_string(i), "; "
      ])
      string_concat(head, tcrec_emit_rebinds_raw(rest, i + 1))
    }
  }
}

# ---- `--dump-last-use`: per-fn-param last-use diagnostic ----

# ====================================================================

# ====================================================================
#                     ^name  ^exports  ^origin ^unstable_exports
#
# Issue #602: `unstable_exports` is the subset of `exports` that the
# module file wrapped in `DUnstable(...)`. The import-rewrite pass
# checks this list when threading an `EField(EVar(mod), fn)` into an
# `EModCall(mod, fn)` so it can emit the #602 warning before any
# code generation runs.

# `in_progress` (issue #538 shape 1) is the stack of module paths
# currently mid-resolution. It is distinct from `visited`: `visited`
# means "finished loading, do not reload" (legitimate diamond
# imports hit this path), `in_progress` means "actively resolving;
# seeing this path again is an import cycle". Push on entry to
# `resolve_module`, pop on exit, then mark visited. Order matters —
# the head of the list is the most recently entered module, so the
# chain in the diagnostic walks head→tail.

# ====================================================================
# downward glue mirrors (cmt_ prefix) — see header

#[doc("Mirror of main head's type_expr_display (downward glue, phase 1r); reconcile in the driver lane.")]
fn cmt_type_expr_display(t: TypeExpr) : String {
  match t.tkind {
    TyName(name, []) -> name
    TyName(name, ts) -> concat_all([name, "[", join_with(map(ts, cmt_type_expr_display), ", "), "]"])
    TyList(inner) -> concat_all(["[", cmt_type_expr_display(inner), "]"])
    TyFn(ps, ret, _) -> concat_all([
      "(", join_with(map(ps, cmt_type_expr_display), ", "), ") -> ", cmt_type_expr_display(ret)
    ])
    TyDim(base, u) -> concat_all([cmt_type_expr_display(base), "<", cmt_unit_expr_display(u), ">"])
    TyRefine(base, _) -> concat_all([cmt_type_expr_display(base), " where <pred>"])
  }
}

# m12.5: render a UnitExprT as user-readable text. The display is *not*
# the canonical form (which lives as Map[Sym,Int]); it's the tree shape
# the parser produced, with light cleanup. Use unit_canon_display for
# canonical output.
#
# Style: scientific notation. Multiplication renders as a single space
# (`kg m`), division renders with `/` and no surrounding spaces
# (`m/s`, `kg m/s^2`). Powers use `^` with the integer literal
# (`m^2`, `s^-1`). `UOne` factors are dropped.

#[doc("Mirror of main head's unit_expr_display (downward glue, phase 1r); reconcile in the driver lane.")]
fn cmt_unit_expr_display(u: UnitExprT) : String {
  match u {
    UOne -> "1"
    USym(s) -> s
    UMul(a, b) -> match b {
      UInv(b_inner) -> match a {
        UOne -> concat_all(["1/", cmt_unit_expr_display(b_inner)])
        _    -> concat_all([cmt_unit_expr_display(a), "/", cmt_unit_expr_display(b_inner)])
      }
      UOne -> cmt_unit_expr_display(a)
      _ -> match a {
        UOne -> cmt_unit_expr_display(b)
        UInv(a_inner) -> concat_all([cmt_unit_expr_display(b), "/", cmt_unit_expr_display(a_inner)])
        _ -> concat_all([cmt_unit_expr_display(a), " ", cmt_unit_expr_display(b)])
      }
    }
    UInv(a) -> concat_all(["1/", cmt_unit_expr_display(a)])
    UPow(a, n) -> concat_all([cmt_unit_expr_display(a), "^", int_to_string(n)])
    UVar(n) -> cat2("?u", int_to_string(n))
  }
}

# Extract just the eff names from a row's labels — useful for the
# many string-based passes in the resolver that don't need the type
# args. Parametric effects are projected to their bare name (so
# `Reader[Int]` and `Reader[String]` both yield `Reader`); callers
# that need to distinguish instantiations work on the full label list.

#[doc("Mirror of main head's row_effects_without_default_handler (downward glue, phase 1r); reconcile in the driver lane.")]
fn cmt_row_effects_without_default_handler(main_row: [String],
                                        decls: [Decl]) : [String] {
  match main_row {
    [] -> []
    [x, ...rest] ->
      if effect_default_block_all_extern(x, decls) {
        [x, ...cmt_row_effects_without_default_handler(rest, decls)]
      } else {
        cmt_row_effects_without_default_handler(rest, decls)
      }
  }
}

# net-tcp-v1: walk the declared types so the NetTcp / Conn / Listener
# / Byte builtin injection in `inject_builtin_effects` can defer to
# any user-supplied decl with the same name. Mirrors
# `collect_effect_names` for DType.
