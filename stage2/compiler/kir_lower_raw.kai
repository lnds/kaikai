# compiler/kir_lower_raw.kai â€” raw (unboxed) Real lowering helpers.
#
# The KIR is all-boxed by default (`slot_of_ty` â†’ SBoxed). The UNBOX pass
# (`unbox.kai`) marks an `Expr` `MUnboxed` when it is a raw C scalar and
# every operand is raw; the C-direct oracle reads that `.mode` and emits
# `double kair_x` raw arithmetic, boxing only at borders. Perceus, seeing a
# raw binding, SKIPS its RC (`prc_pat_bindings_skip_raw`): a raw `double`
# has no refcount. If the KIR ignores `.mode` and re-boxes, it inherits
# perceus's RC-plan (which omitted the dup/drop of the raw vars) over BOXED
# values â€” a use-after-free on any multi-use Real operand (the
# `9.88131e-324` corruption). The fix (asu, Camino A): the KIR is
# MODE-SLAVE, exactly like the C emitter â€” a `MUnboxed` Real lowers to a
# raw `f64` register + native `fadd`/`fmul`/`fcmp`, boxing only at the
# rawâ†”boxed border. This module owns the PURE classification half (no
# recursion into `lower_expr`); `lower_expr_raw` lives in the Expr-SCC
# `kir_lower_walk.kai`.
#
# SCOPE: REAL + INT + BYTE arith/cmp, CHAR literal/var. A node is
# raw-promoted iff it is `MUnboxed` AND a natively-raw FORM in one of four
# scalar families:
#   - REAL (asu, Camino A â€” the native-parity "Real box/unbox" family): a
#     Real literal/var, Real arith (`+ - * /`), unary `-`, a Real comparison,
#     or a logical over raw-Real comparisons.
#   - INT (P1, native Int unboxing): an Int literal/var, Int arith
#     (`+ - * / %`), or an Int comparison (`< > <= >= == !=` over Int
#     operands). `+`/`-`/`*` yield a raw `i64` (native `add`/`sub`/`mul`,
#     wrapping, NO nsw/nuw â€” kaikai Int wraps); an Int comparison yields a raw
#     i1 (signed `icmp`), boxed only at a rawâ†’boxed border. `/` and `%` are
#     raw too, but route through the checked helper `kai_idiv_chk`/
#     `kai_imod_chk` (not a bare `sdiv`/`srem`) so a zero divisor or
#     INT64_MIN/-1 traps clean instead of running hardware UB. Bit-ops
#     (`<<`, `&`, â€¦) stay boxed (no raw `i`-prim lowering for them in v1).
#   - CHAR (the under-ref fix): a Char literal or var, at the literal/var
#     FORMS only. A `MUnboxed` Char read lowers to a raw `SChar` (i32
#     codepoint) register and boxes a FRESH `kaix_char` at each boxed use â€”
#     never a shared boxed cell whose ref the consuming prims
#     (`kai_core_char_to_int`, `kai_op_eq_v`) eat N times against 1 ref.
#     Only chars <= 0x7F are interned immortal; a heap Char (any byte >=
#     0x80 out of `char_at`) freed by the first extra consumption leaves
#     later uses reading recycled memory. Char comparisons and other forms
#     stay boxed (each operand crosses the border as its own fresh box).
#   - BYTE (`u8` op family): a Byte literal/var, Byte arith (`+ - * / %`),
#     or a Byte comparison. The register invariant is value 0..255: `+ - *`
#     mask at 8 bits AFTER each op, `/`/`%` widen into the checked i64
#     helper (zero divisor traps) and truncate, cmp is a plain `icmp` over
#     the masked values. Boxed borders box fresh (`kaix_byte`) â€” a Byte box
#     is heap-RC'd (no interning), so the Char under-ref hazard applies.
# Bool nodes that are MUnboxed for OTHER reasons (a UFn call returning
# Bool) stay on the boxed path: boxed Bool rides the singleton cache
# (immortal, no double-free), and the scalar machinery
# (`real.unbox`/`int.box`, `f==`/`i==`) is wrong for a Bool operand.
# The gate is the OPERAND type for a comparison/logical node, never just the
# result type â€” `kir_kind_is_raw` inspects the children, so a `bool or bool`
# from two UFn calls never enters, and a comparison routes to the f-family
# (Real operands) or the i-family (Int operands) by operand type.

import compiler.ast
import compiler.cell_promote
import compiler.kir

# True when an optional type is `Real` (stripping Dim/Refinement wrappers) â€”
# the one scalar this module raw-promotes.
pub fn kir_ty_is_real(opt_t: Option[Ty]) : Bool = match opt_t {
  Some(t) -> kir_ty_is_real_t(t)
  None    -> false
}

fn kir_ty_is_real_t(t: Ty) : Bool = match t {
  TyReal              -> true
  TyDimT(inner, _)    -> kir_ty_is_real_t(inner)
  TyRefineT(inner, _) -> kir_ty_is_real_t(inner)
  _                   -> false
}

# True when an optional type is `Int` (stripping Refinement wrappers). The
# second scalar this module raw-promotes â€” but ONLY for a `let`-binder's
# RHS / its EVar reads (a literal or a var), NEVER Int arith / bit-ops. A
# boxed Int that escapes `let`-scope (a fn param) already rides perceus's
# RC correctly; the gap is the `let` binding, which perceus skip-raws
# (`prc_pat_bindings_skip_raw` sees `MUnboxed`) yet the all-boxed KIR
# re-boxed with a SHARED cell â€” a use-after-free on any out-of-cache Int
# (|n| > 65535) used twice by a consuming prim (`kaix_add` / `kaix_bit_*`
# decref their args). Lowering the binder RAW (`SInt64`) + boxing a FRESH
# `kaix_int` at each read (`nemit_load_reg_boxed`) matches the C-direct
# oracle's `int64_t kair_x` + `kai_int(kair_x)` per use â€” no shared cell,
# no RC, no double-free. Mirror of the Real raw path (the np-real lane),
# extended to the Int `let`-binder FORM only.
pub fn kir_ty_is_int(opt_t: Option[Ty]) : Bool = match opt_t {
  Some(t) -> kir_ty_is_int_t(t)
  None    -> false
}

fn kir_ty_is_int_t(t: Ty) : Bool = match t {
  TyInt               -> true
  TyRefineT(inner, _) -> kir_ty_is_int_t(inner)
  _                   -> false
}

# True iff an optional type is `Bool`. Used by the boxâ†’raw border to route a
# Bool scalar through `bool.unbox` (â†’ `kaix_bool_field`, slot `SBool`) rather
# than the Int / Real prims â€” a Bool fed to `real.unbox` reads `as.r` off a
# boxed Bool (a silent miscompile + an LLVM type mismatch the verifier
# rejects). A raw-Bool call arg (a `neg: Bool` param the callee unboxes) is
# the case that needs it.
pub fn kir_ty_is_bool(opt_t: Option[Ty]) : Bool = match opt_t {
  Some(t) -> kir_ty_is_bool_t(t)
  None    -> false
}

fn kir_ty_is_bool_t(t: Ty) : Bool = match t {
  TyBool              -> true
  TyRefineT(inner, _) -> kir_ty_is_bool_t(inner)
  _                   -> false
}

# True iff an optional type is `Char`. Routes the boxâ†’raw border through
# `char.unbox` (â†’ `kaix_char_field`, slot `SChar`) and gates the raw
# literal/var forms â€” a Char fed to the Int/Real prims would read the wrong
# union member.
pub fn kir_ty_is_char(opt_t: Option[Ty]) : Bool = match opt_t {
  Some(t) -> kir_ty_is_char_t(t)
  None    -> false
}

fn kir_ty_is_char_t(t: Ty) : Bool = match t {
  TyChar              -> true
  TyRefineT(inner, _) -> kir_ty_is_char_t(inner)
  _                   -> false
}

# True iff an optional type is `Byte`. Routes the boxâ†’raw border through
# `byte.unbox` (â†’ `kaix_byte_field`, slot `SByte`) and gates the raw
# literal/var/arith forms â€” the `u8` op family masks at 8 bits where the
# Int prims would compute at i64 width.
pub fn kir_ty_is_byte(opt_t: Option[Ty]) : Bool = match opt_t {
  Some(t) -> kir_ty_is_byte_t(t)
  None    -> false
}

fn kir_ty_is_byte_t(t: Ty) : Bool = match t {
  TyByte              -> true
  TyRefineT(inner, _) -> kir_ty_is_byte_t(inner)
  _                   -> false
}

# True iff an optional type is one of the raw fixed widths Int32/UInt32/
# UInt64 (Byte has its own `kir_ty_is_byte`; Int128 is not raw yet). Gates
# the raw literal/var/arith forms and routes the boxâ†’raw border through the
# per-type `<width>.unbox` prim. The op family carries signedness by name
# (`i32/` signed, `u32/`/`u64/` unsigned).
pub fn kir_ty_is_fixed_raw(opt_t: Option[Ty]) : Bool = match opt_t {
  Some(t) -> not is_none_ty(kir_fixed_raw_slot_t(t))
  None    -> false
}

# The KSlot for a raw fixed-width type, or SBoxed for anything else (peels
# refinements). `SBoxed` doubles as the "not a raw fixed width" sentinel â€”
# `kir_ty_is_fixed_raw` tests against it.
fn kir_fixed_raw_slot_t(t: Ty) : KSlot = match t {
  TyInt32             -> SInt32T
  TyUInt32            -> SUInt32
  TyUInt64            -> SUInt64
  TyRefineT(inner, _) -> kir_fixed_raw_slot_t(inner)
  _                   -> SBoxed
}

fn is_none_ty(s: KSlot) : Bool = match s { SBoxed -> true _ -> false }

# The raw KSlot for a raw fixed-width optional type (caller has already
# gated with `kir_ty_is_fixed_raw`).
pub fn kir_fixed_raw_slot(opt_t: Option[Ty]) : KSlot = match opt_t {
  Some(t) -> kir_fixed_raw_slot_t(t)
  None    -> SBoxed
}

# The op-family / border-prim prefix for a raw fixed-width type: `i32`,
# `u32`, or `u64`. The arith/cmp prims are `<pfx>+`â€¦`<pfx>%`, `<pfx><`â€¦; the
# box/unbox borders are `<box>.box`/`<box>.unbox` via `kir_fixed_box_name`.
fn kir_fixed_prim_prefix_t(t: Ty) : String = match t {
  TyInt32             -> "i32"
  TyUInt32            -> "u32"
  TyUInt64            -> "u64"
  TyRefineT(inner, _) -> kir_fixed_prim_prefix_t(inner)
  _                   -> "i32"
}

pub fn kir_fixed_prim_prefix(opt_t: Option[Ty]) : String = match opt_t {
  Some(t) -> kir_fixed_prim_prefix_t(t)
  None    -> "i32"
}

# The box/unbox border-prim base name for a raw fixed-width type
# (`int32`/`uint32`/`uint64`) â€” `<name>.box` â†’ `kaix_<name>`.
fn kir_fixed_box_name_t(t: Ty) : String = match t {
  TyInt32             -> "int32"
  TyUInt32            -> "uint32"
  TyUInt64            -> "uint64"
  TyRefineT(inner, _) -> kir_fixed_box_name_t(inner)
  _                   -> "int32"
}

pub fn kir_fixed_box_name(opt_t: Option[Ty]) : String = match opt_t {
  Some(t) -> kir_fixed_box_name_t(t)
  None    -> "int32"
}

# An Expr the KIR raw path handles. ONLY the natively-raw FORMS â€” a Real
# literal, a Real var, Real arith (`+ - * /`), unary `-`, a Real comparison,
# or a logical / `not` over raw-Real comparisons. A Real-typed `MUnboxed`
# node of ANOTHER form (an `if`, a call, a field read) is NOT raw-promoted:
# lowering it boxed (its natural shape) and then unboxâ†’rebox at the border
# would just add a redundant `real.unbox`/`real.box` round-trip. The guard
# gates on the FORM, so such nodes stay on the plain boxed path. The operand
# type gates a comparison/logical (not the Bool result): a `bool or bool`
# from two UFn calls is NOT raw, even though `or` is logical.
pub fn kir_node_is_raw(x: Expr) : Bool =
  match x.mode { MUnboxed -> kir_kind_is_raw(x) _ -> false }

# The natively-raw FORMS, by `.kind`. A literal / var is raw when its type
# is Real or Int. Arithmetic is raw when typed Real (`f+ f- f* f/`) or Int
# (`i+ i- i*` â€” `/`/`%` excluded, P1 guard #2). A comparison routes by
# OPERAND type: Real operands â†’ the f-family (yields a raw i1), Int operands
# â†’ the i-family (signed `icmp`). A logical (`and`/`or`/`not`) is raw when
# its operands are raw (a comparison over either scalar). The gate inspects
# children so a boxed-Char / boxed-Bool node never enters the scalar path.
fn kir_kind_is_raw(x: Expr) : Bool = match x.kind {
  EReal(_, _) -> kir_ty_is_real(x.ty)
  EIntLit(_) -> kir_ty_is_real(x.ty)
  EDecimalLit(_) -> kir_ty_is_real(x.ty)
  EInt(_)     -> kir_ty_is_int(x.ty) or kir_ty_is_byte(x.ty) or kir_ty_is_fixed_raw(x.ty)
  EFixed(_, _) -> kir_ty_is_byte(x.ty) or kir_ty_is_fixed_raw(x.ty)
  EChar(_)    -> kir_ty_is_char(x.ty)
  EVar(_)     -> kir_ty_is_real(x.ty) or kir_ty_is_int(x.ty) or kir_ty_is_char(x.ty) or kir_ty_is_byte(x.ty) or kir_ty_is_fixed_raw(x.ty)
  ELitUnit(inner, _) -> kir_node_is_raw(inner)
  # Arith routes by RESULT type, not op string: `+ - *` overlap the Real
  # (`f`) and Int (`i`) families, so a type-blind `if op_is_freal { real }`
  # would reject every Int `+`/`-`/`*` (its result is Int, not Real) before
  # the Int branch ran. Gate on the type first: a Real-typed freal-arith is
  # raw, an Int-typed iint-arith is raw (`/` excluded from the Int set).
  EBinop(op, a, b) ->
    if kir_ty_is_real(x.ty) { kir_op_is_raw_freal_arith(op) }
    else if kir_ty_is_int(x.ty) { kir_op_is_raw_iint_arith(op) }
    else if kir_ty_is_byte(x.ty) { kir_op_is_raw_iint_arith(op) }
    else if kir_ty_is_fixed_raw(x.ty) { kir_op_is_raw_iint_arith(op) }
    else if kir_op_is_raw_cmp(op) {
      (kir_ty_is_real(a.ty) and kir_ty_is_real(b.ty)) or
      (kir_ty_is_int(a.ty) and kir_ty_is_int(b.ty)) or
      (kir_ty_is_byte(a.ty) and kir_ty_is_byte(b.ty)) or
      (kir_ty_is_fixed_raw(a.ty) and kir_ty_is_fixed_raw(b.ty))
    }
    else if kir_op_is_raw_logical(op) { kir_node_is_raw(a) and kir_node_is_raw(b) }
    else { false }
  EUnop(op, a) ->
    if op == "-" { kir_ty_is_real(x.ty) }
    else if op == "not" { kir_node_is_raw(a) }
    else { false }
  # A promoted var cell (`cell_promote`): the init is a raw literal and a
  # read is a raw register load, both at the cell's scalar slot.
  EIntrinsic(inm, _) -> inm == "__cell_init" or is_cell_get(inm)
  _ -> false
}

# The boxing prim a raw value crosses to boxed through, by RESULT type:
# `real.box` (â†’ `kaix_real`) for a Real, `bool.box` (â†’ `kaix_bool`) for the
# raw-Bool result of a Real comparison / logical. Mirror of `box_wrap`.
pub fn kir_raw_box_prim(opt_t: Option[Ty]) : String =
  if kir_ty_is_real(opt_t) { "real.box" }
  else if kir_ty_is_int(opt_t) { "int.box" }
  else if kir_ty_is_char(opt_t) { "char.box" }
  else if kir_ty_is_byte(opt_t) { "byte.box" }
  else if kir_ty_is_fixed_raw(opt_t) { cat2(kir_fixed_box_name(opt_t), ".box") }
  else { "bool.box" }

# The `fbinop` opcode for a raw-Real arithmetic operator (matches the
# runtime `kai_llvm_build_fbinop` switch: 0=fadd 1=fsub 2=fmul 3=fdiv).
# `%` has no `double` form (the unbox pass keeps Real `%` boxed), so it
# never reaches here.
pub fn kir_fbinop_op(op: String) : Int =
  if op == "+" { 0 }
  else if op == "-" { 1 }
  else if op == "*" { 2 }
  else { 3 }

# Is `op` a raw-Real arithmetic operator (one `fbinop` lowers)? `/` is
# included (native `fdiv`); `%` is excluded (boxed `kaix_mod`).
pub fn kir_op_is_raw_freal_arith(op: String) : Bool =
  op == "+" or op == "-" or op == "*" or op == "/"

# The `ibinop` opcode for a raw-Int arithmetic operator: 0=add 1=sub 2=mul
# (all WRAPPING, no nsw/nuw), 3=div 4=mod. The native emitter turns opcodes
# 3/4 into a call to the checked helper (`kai_idiv_chk`/`kai_imod_chk`), not a
# bare `sdiv`/`srem`, so div-by-zero and INT64_MIN/-1 trap.
pub fn kir_ibinop_op(op: String) : Int =
  if op == "+" { 0 }
  else if op == "-" { 1 }
  else if op == "*" { 2 }
  else if op == "/" { 3 }
  else { 4 }

# Is `op` a raw-Int arithmetic operator (one `ibinop` lowers)? `+ - * / %`.
# `/` and `%` lower to the checked helper on both backends (C emits
# `kai_idiv_chk`/`kai_imod_chk`, native calls the shim), so div-by-zero and
# INT64_MIN/-1 trap identically instead of diverging. Bit-ops stay boxed.
pub fn kir_op_is_raw_iint_arith(op: String) : Bool =
  op == "+" or op == "-" or op == "*" or op == "/" or op == "%"

# The `fcmp` predicate code for a raw-Real comparison (matches the runtime
# `kai_llvm_build_fcmp` switch: 0=< 1=> 2=<= 3=>= 4=== 5=!=, all ordered).
pub fn kir_fcmp_pred(op: String) : Int =
  if op == "<" { 0 }
  else if op == ">" { 1 }
  else if op == "<=" { 2 }
  else if op == ">=" { 3 }
  else if op == "==" { 4 }
  else { 5 }

# The `icmp` predicate code for a raw-Int comparison (matches the runtime
# `kai_llvm_build_icmp` switch: 0=< 1=> 2=<= 3=>= 4=== 5=!=, all SIGNED).
pub fn kir_icmp_pred(op: String) : Int =
  if op == "<" { 0 }
  else if op == ">" { 1 }
  else if op == "<=" { 2 }
  else if op == ">=" { 3 }
  else if op == "==" { 4 }
  else { 5 }

# Is `op` a comparison (one `fcmp`/`icmp`+widen lowers)? The SAME operator
# set for Real and Int operands; `kir_kind_is_raw` routes to the f- or
# i-family by operand type.
pub fn kir_op_is_raw_cmp(op: String) : Bool =
  op == "<" or op == ">" or op == "<=" or op == ">=" or op == "==" or op == "!="

# Is `op` a short-circuit boolean (`and`/`or` over two raw i1 bools)? The
# unbox pass already evaluated both operands (it marks the whole node
# MUnboxed only when both children are raw), so a strict raw `and`/`or` is
# sound â€” same as the C oracle's `&&`/`||` on two raw `int` operands.
pub fn kir_op_is_raw_logical(op: String) : Bool = op == "and" or op == "or"

# The native i1 boolean opcode for `and`/`or` (1=and, 0=or; the emitter
# maps to `LLVMBuildAnd`/`LLVMBuildOr`).
pub fn kir_logical_op(op: String) : Int = if op == "and" { 1 } else { 0 }

# The KIR prim NAME carrying a raw binary op. The native emitter
# (`nemit_prim`) dispatches these to `llvm_build_fbinop` / `llvm_build_fcmp`
# / `llvm_build_ibinop` / `llvm_build_icmp` / the i1 logical builder rather
# than the boxed `kaix_*` helpers. The `f` prefix marks the raw-Real family,
# `i` the raw-Int family; both keep them distinct from the boxed `+`/`<`
# strings so a translator never confuses the two; logical `and`/`or` get a
# `b` prefix (i1 domain).
pub fn kir_raw_arith_prim(op: String) : String = cat2("f", op)
pub fn kir_raw_cmp_prim(op: String) : String = cat2("f", op)
pub fn kir_raw_logical_prim(op: String) : String = cat2("b", op)
pub fn kir_raw_iarith_prim(op: String) : String = cat2("i", op)
pub fn kir_raw_icmp_prim(op: String) : String = cat2("i", op)
# The `u8` family: same operator set as the i-family, per-op 8-bit
# masking (`+ - *` mask after the op; `/`/`%` widen into the checked i64
# helper and truncate; cmp is an i32 `icmp` over the masked values).
pub fn kir_raw_u8arith_prim(op: String) : String = cat2("u8", op)
pub fn kir_raw_u8cmp_prim(op: String) : String = cat2("u8", op)
# The fixed-width families (`i32`/`u32`/`u64`): the same operator set as
# the i-family with the prefix carrying the type. `+ - *` are one wrapping
# `ibinop` at the register width (no mask â€” the width IS the register);
# `/`/`%` widen into the checked helper (signed `kai_idiv_chk`, unsigned
# `kai_udiv_chk`) and truncate; cmp is a signed/unsigned `icmp` per prefix.
pub fn kir_raw_fixed_arith_prim(opt_t: Option[Ty], op: String) : String = cat2(kir_fixed_prim_prefix(opt_t), op)
pub fn kir_raw_fixed_cmp_prim(opt_t: Option[Ty], op: String) : String = cat2(kir_fixed_prim_prefix(opt_t), op)
