# compiler/perceus.kai — Perceus reference-counting pass (m5).
#
# Extracted from main.kai under issue #677 Phase 1n4 (the analysis in
# docs/lane-infer-cross-section-analysis.md §"Lane N4"). Walks the
# post-monomorphise, post-unbox `[Decl]` and inserts `__perceus_dup`
# calls at non-last in-scope reads plus entry drops for unused
# parameters, following the Koka Perceus discipline (docs/perceus-basic.md).
#
# Pipeline position: monomorphise -> unbox_pass -> **perceus_pass** ->
# tco -> emit. It is a pure `[Decl] -> [Decl]` structural transform with
# zero dependency on the typer's inference state (InferState / Subst /
# TyScheme / TypedProgram / ProtocolReg: 0 uses across the whole pass).
# Its last-use analysis is structural over `Expr` + the `.mode` the
# unbox pass embedded and the `.ty` infer embedded — never the typer.
#
# What this module owns
#
#   - `perceus_pass` — the entry point: build the `[EFn]` registry via
#     compiler.fnreg, then rewrite every decl (`perceus_decl` /
#     `pcs_collect_uses_expr` / `pcs_rewrite_expr` /
#     `pcs_prepend_unused_drops`) so each binding transfers at its last
#     use, earlier reads bump the refcount via `__perceus_dup`, and
#     unused params drop at body entry.
#   - The use-collection + last-use machinery (`pcs_collect_uses_expr`,
#     `last_use_for`, `pcs_count_non_lam_uses`,
#     `pcs_branch_aware_skip_params`) is `pub` because the tco pre-pass
#     (`tcrec_*`, still resident in main pending the emit_c lane)
#     consults it directly to align its goto-loop drops with the wrap's
#     exit drops — the same emit-adjacent-consumer shape unbox (N3) hit.
#
# Public surface (5 fns, 0 pub types): perceus_pass + the 4 tco-shared
# use/last-use helpers above. The internal types `PcsBlockState` /
# `PcsRwBlock` / `PcsRwStmt` / `DupMark` stay private (no external sig).
#
# Bundle order: ... infer, fnreg, unbox, perceus, main. Imports
# compiler.ast for the AST nodes, compiler.diag for diagnostics,
# compiler.util for `concat_all` / `has_interp` / `list_has`,
# compiler.fnreg for the EFn registry (`register_fn_decls` /
# `is_ufn_decl` via `lookup_ufn_sig`) + the interp scanner
# (`iscan_collect` / `body_is_ffi_extern`), compiler.infer for the
# `Use` / `LU` / `IPart` / `IScan` types, compiler.lex for `tokenize`,
# and compiler.parse for `parse_interp_expr`. The AST-functor family
# (`prc_map_expr_kind`), the type mangler (`prc_mangle_ty`), the
# pattern-binding walkers (`prc_pat_bindings` /
# `prc_pat_bindings_skip_raw` / `prc_pat_binders`) and the UFn
# predicate (`prc_is_ufn_decl`) are mirrored downward glue with the
# `prc_` prefix, per the phase-1m `dsg_` discipline (consumers = 1 each
# from this module ⇒ mirror, not sink).

import compiler.ast
import compiler.diag
import compiler.util
import compiler.lex
import compiler.parse
import compiler.infer
import compiler.fnreg

# ==================================================================
# Downward glue mirrors (prc_ prefix) — copied verbatim from the
# canonical definitions still resident in main / infer / modules.
# Mirrored rather than sunk because each has a single consumer here.
# ==================================================================

fn prc_join_with(xs: [String], sep: String) : String = string_join(xs, sep)

fn prc_mangle_ty(t: Ty) : String {
  match t {
    TyInt    -> "Int"
    TyReal   -> "Real"
    TyBool   -> "Bool"
    TyString -> "String"
    TyChar   -> "Char"
    TyUnit   -> "Unit"
    TyByte     -> "Byte"
    TyListT(inner) -> concat_all(["L_", prc_mangle_ty(inner), "_E"])
    TyFnT(ps, ret, _) -> concat_all([
      "F_", prc_join_with(map(ps, prc_mangle_ty), "_"),
      "_R_", prc_mangle_ty(ret), "_E"
    ])
    TyCon(_, cname, tas) -> {
      match tas {
        [] -> cname
        [_h, ..._rest] -> concat_all([cname, "_O_",
                                    prc_join_with(map(tas, prc_mangle_ty), "_"),
                                    "_C"])
      }
    }
    TyVarT(_) -> "TVAR"
    TyAny     -> "Any"
    # m12.5: units are erased at codegen time. The mangled name for a
    # dimensioned type is the same as its base type's mangle — so a
    # call like `f(1.0<USD>)` and a call `f(1.0)` mangle into the same
    # specialisation. This is the codegen-erasure invariant manifest
    # at the mangler level.
    TyDimT(base, _) -> prc_mangle_ty(base)
    # m12.6.x #1: refinements erase like units. `Int where >= 0` and
    # `Int` mangle the same — they share monomorphisations and
    # protocol-impl dispatch entries.
    TyRefineT(base, _) -> prc_mangle_ty(base)
    # issue #187 phase 1: mangle a union as `U_<part1>_<part2>_..._E`
    # using the canonical component order. The leading `U_` and
    # trailing `_E` bracket the spec the same way `L_..._E` brackets
    # a list, so distinct unions never collide with each other or
    # with primitive mangles even when their component manglings
    # rearrange. Phase 1 never invokes the mangler on a `TyUnion` in
    # selfhost (no resolver path constructs one) so this arm is dead
    # until Phase 2 wires it up; the implementation is provided now
    # to keep the walker exhaustive without `_` fallbacks that would
    # mask future bugs.
    TyUnion(parts) -> concat_all(["U_",
                                  prc_join_with(map(parts, prc_mangle_ty), "_"),
                                  "_E"])
  }
}


fn prc_map_arm_exprs(a: Arm, f: (Expr) -> Expr) : Arm {
  match a {
    Arm(p, g, b) -> Arm(p, prc_map_opt_expr(g, f), f(b))
  }
}


fn prc_map_clause_exprs(c: HClause, f: (Expr) -> Expr) : HClause {
  match c {
    HC(n, ps, b, l, co) -> HC(n, ps, f(b), l, co)
  }
}


fn prc_map_elem_exprs(el: ListElem, f: (Expr) -> Expr) : ListElem {
  match el {
    ElPlain(x)  -> ElPlain(f(x))
    ElSpread(x) -> ElSpread(f(x))
  }
}


fn prc_map_expr_kind(k: ExprKind, f: (Expr) -> Expr) : ExprKind {
  match k {
    # Leaves: no sub-Expr to recurse into.
    EInt(_)        -> k
    EReal(_)       -> k
    EBool(_)       -> k
    EChar(_)       -> k
    EStr(_, _)     -> k
    EUnit          -> k
    EVar(_)        -> k
    EUnder         -> k
    EPlaceholder   -> k
    EHole(_)       -> k
    ETodo(_)       -> k
    # `EVariantsOf(TypeExpr, [String])` carries no sub-Expr (only a
    # TypeExpr and a resolved-names list, neither of which the
    # visitor traverses). Same shape as EHole/ETodo for the
    # purposes of the structural recursion.
    EVariantsOf(_, _) -> k
    # m6.2 Phase 2.1: qualified module call carries no sub-Exprs
    # (both fields are plain Strings), so `f` has nothing to apply.
    EModCall(_, _) -> k
    # Issue #556: intrinsic args ARE sub-Exprs, so the visitor recurs.
    EIntrinsic(name, args_) -> EIntrinsic(name, map(args_, f))
    # Composites: apply f to every direct sub-Expr.
    ECall(callee, args_) -> ECall(f(callee), map(args_, f))
    EField(base, name)   -> EField(f(base), name)
    EIndex(a, b)         -> EIndex(f(a), f(b))
    EBinop(op, a, b)     -> EBinop(op, f(a), f(b))
    EUnop(op, x)         -> EUnop(op, f(x))
    EIf(c, t_, eo)       -> EIf(f(c), f(t_), prc_map_opt_expr(eo, f))
    EMatch(scr, arms)    -> EMatch(f(scr), map(arms, (a) => prc_map_arm_exprs(a, f)))
    ELambda(ps, b)       -> ELambda(ps, f(b))
    ERecordLit(name, fs) -> ERecordLit(name, map(fs, (fi) => prc_map_field_exprs(fi, f)))
    EList(els)           -> EList(map(els, (el) => prc_map_elem_exprs(el, f)))
    ERange(a, b, opt_step) -> ERange(f(a), f(b), prc_map_opt_expr(opt_step, f))
    EBlock(stmts, tail)  -> EBlock(map(stmts, (s) => prc_map_stmt_exprs(s, f)),
                                    prc_map_opt_expr(tail, f))
    EPipe(a, b)          -> EPipe(f(a), f(b))
    EMapPipe(a, b)       -> EMapPipe(f(a), f(b))
    EFlatMapPipe(a, b)   -> EFlatMapPipe(f(a), f(b))
    EFilterPipe(a, b)    -> EFilterPipe(f(a), f(b))
    EHandle(body, eff_name, eff_tyargs, init_opt, alias_opt, clauses, ret_opt) ->
      EHandle(f(body), eff_name, eff_tyargs,
              prc_map_opt_expr(init_opt, f), alias_opt,
              map(clauses, (c) => prc_map_clause_exprs(c, f)),
              prc_map_opt_return_exprs(ret_opt, f))
    ELitUnit(inner, u)   -> ELitUnit(f(inner), u)
    EBang(inner)         -> EBang(f(inner))
  }
}


fn prc_map_field_exprs(fi: FieldInit, f: (Expr) -> Expr) : FieldInit {
  match fi {
    FI(n, v) -> FI(n, f(v))
  }
}


fn prc_map_opt_expr(opt: Option[Expr], f: (Expr) -> Expr) : Option[Expr] {
  match opt {
    Some(e) -> Some(f(e))
    None    -> None
  }
}


fn prc_map_opt_return_exprs(opt: Option[HReturn], f: (Expr) -> Expr) : Option[HReturn] {
  match opt {
    Some(r) -> Some(prc_map_return_exprs(r, f))
    None    -> None
  }
}


fn prc_map_return_exprs(r: HReturn, f: (Expr) -> Expr) : HReturn {
  match r {
    HR(p, b, l, c) -> HR(p, f(b), l, c)
  }
}


fn prc_map_stmt_exprs(s: Stmt, f: (Expr) -> Expr) : Stmt {
  match s {
    SLet(p, ann, rhs)           -> SLet(p, ann, f(rhs))
    SAssert(c, m)               -> SAssert(f(c), prc_map_opt_expr(m, f))
    SExprStmt(x)                -> SExprStmt(f(x))
    SIndexAssign(b, i, v, l, c) -> SIndexAssign(f(b), f(i), f(v), l, c)
    SVar(n, ty, rhs, l, c)      -> SVar(n, ty, f(rhs), l, c)
    # m7e §25: SUse has no sub-expression — pass through unchanged.
    SUse(n, l, c)               -> SUse(n, l, c)
  }
}

fn prc_pat_bindings(pat: Pattern, acc: [String]) : [String] {
  match pat.pkind {
    PWild -> acc
    PLit(_) -> acc
    PBind(name) -> [name, ...acc]
    PList(pats, opt_rest) -> {
      let acc1 = prc_pat_bindings_loop(pats, acc)
      match opt_rest {
        Some(rname) -> [rname, ...acc1]
        None -> acc1
      }
    }
    PVariant(_, subs) -> prc_pat_bindings_loop(subs, acc)
    PVariantRecord(_, fields) -> prc_pfield_bindings_loop(fields, acc)
    PRecord(fields) -> prc_pfield_bindings_loop(fields, acc)
    PHole(_) -> acc
    PAs(name, sub) -> prc_pat_bindings(sub, [name, ...acc])
    PNarrow(name, _) -> [name, ...acc]
  }
}

# Like `prc_pat_bindings`, but if the pattern is a single `PBind` and
# the let's RHS is `MUnboxed`, the binding is a raw C scalar and
# must NOT enter the Perceus tracking scope. All other shapes —
# destructured lets, wildcards, literals — defer to the standard
# `prc_pat_bindings` walker. See `docs/unboxing-phase2-design.md` §3
# (boundary tactic) for the coordination contract.
fn prc_pat_bindings_skip_raw(pat: Pattern, rhs: Expr, acc: [String]) : [String] {
  match pat.pkind {
    PBind(name) -> match rhs.mode {
      MUnboxed -> acc
      _        -> [name, ...acc]
    }
    _ -> prc_pat_bindings(pat, acc)
  }
}

fn prc_pat_bindings_loop(ps: [Pattern], acc: [String]) : [String] {
  match ps {
    [] -> acc
    [p, ...rest] -> prc_pat_bindings_loop(rest, prc_pat_bindings(p, acc))
  }
}

fn prc_pfield_bindings_loop(fs: [PField], acc: [String]) : [String] {
  match fs {
    [] -> acc
    [f, ...rest] -> match f {
      PField(_, sub, _) -> prc_pfield_bindings_loop(rest, prc_pat_bindings(sub, acc))
    }
  }
}

fn prc_pat_binders(pat: Pattern, acc: [String]) : [String] = match pat.pkind {
  PWild           -> acc
  PLit(_)         -> acc
  PBind(name)     -> [name, ...acc]
  PList(subs, opt_rest) -> {
    let acc1 = prc_pat_binders_list(subs, acc)
    match opt_rest { Some(n) -> [n, ...acc1] None -> acc1 }
  }
  PVariant(_, subs)        -> prc_pat_binders_list(subs, acc)
  PVariantRecord(_, fs)    -> prc_pat_binders_pfields(fs, acc)
  PRecord(fs)              -> prc_pat_binders_pfields(fs, acc)
  PHole(_)                 -> acc
  PAs(name, inner)         -> prc_pat_binders(inner, [name, ...acc])
  PNarrow(name, _)         -> [name, ...acc]
}

fn prc_pat_binders_list(ps: [Pattern], acc: [String]) : [String] = match ps {
  [] -> acc
  [p, ...rest] -> prc_pat_binders_list(rest, prc_pat_binders(p, acc))
}

fn prc_pat_binders_pfields(fs: [PField], acc: [String]) : [String] = match fs {
  [] -> acc
  [f, ...rest] -> match f {
    PField(_, sub, _) -> prc_pat_binders_pfields(rest, prc_pat_binders(sub, acc))
  }
}

fn prc_is_ufn_decl(fns: [EFn], name: String, mo: Option[String]) : Bool {
  match lookup_ufn_sig(fns, name, mo) {
    Some(_) -> true
    None    -> false
  }
}

# ==================================================================
# Perceus pass (extracted body — issue #677 phase 1n4)
# ==================================================================

# ---- m5 — basic Perceus (m5 #1, walker scaffold) ----
#
# Walks the post-mono `[Decl]` and (eventually) inserts `kai_dup` /
# `kai_decref` calls at non-last / last-use positions per the Koka
# Perceus paper. m5 #1 wires the slot; the body is identity. m5 #2
# computes per-binding last-use positions; m5 #3 emits drops at
# end-of-scope; m5 #4 emits dups at non-last uses; m5 #5 measures.
#
# Operates on values, not types. Under uniform boxing every
# `KaiValue *` has the same RC shape, so a single drop/dup discipline
# applies across instantiations — the m4c retrofit blocking real
# monomorphisation does not block this pass.
#
# Reads the source AST as the IR. The emitter consumes whatever this
# function returns; selfhost convergence remains the gate.

# m5 #4 step 2/4 — scope-aware Perceus pass.
#
# For each `DFn`, walks the body twice:
#   1. `pcs_collect_uses_expr` — accumulates `[Use]` for every EVar
#      whose name is currently in scope (params + lets + match
#      pattern bindings + handler-clause params + lambda params).
#      Mirrors `fv_expr` (5478) modulo polarity: we want IN-scope
#      reads, fv wants free vars.
#   2. `pcs_rewrite_expr` — reconstructs the body, wrapping every
#      non-last in-scope EVar in `ECall(EVar("__perceus_dup"), [...])`.
#      Last-use-per-name is computed via `pcs_last_use_for` (same as
#      m5 #2 but consumed for rewriting, not just reporting).
#
# Then `pcs_prepend_unused_drops` wraps the body in `EBlock` to drop
# every parameter whose `pcs_last_use_for` is `LUUnused`. Drops emit
# at body START — safe because the param was never read after entry.
#
# Together with the runtime primitive consumption (step 3/4 —
# blocked on stage 1 needing its own perceus pass; see
# `docs/perceus-basic.md` §"What unblocks step 3+"), this
# would produce a coherent linear discipline: every binding
# transferred at exactly one position (last use); earlier reads
# bump the refcount via dup; unused params dropped at entry.
# Inert until step 3 lands.


#[doc("Entry point: scope-aware Perceus RC pass over the post-mono [Decl] (dup at non-last uses, drop unused params at entry). Pipeline position monomorphise -> unbox -> perceus_pass -> tco -> emit.")]
pub fn perceus_pass(decls: [Decl]) : [Decl] / Console {

  let fns = register_fn_decls(decls)
  # Borrow inference pre-pass (Koka pre-Parc): per-fn borrowed param
  # positions, consumed by BOTH sides of the flip (callee wraps the
  # borrowed scrutinee in __perceus_borrow so emit_match skips its exit
  # decref; caller strips the __perceus_dup on args in borrowed slots).
  let bmap = pcs_build_borrow_map(decls, [])
  # Consume-map (Koka Borrowed dual): per-fn CONSUMED param positions. A caller
  # may MOVE a binder into a consuming slot; a non-consuming slot (field-read
  # callee like regexp nb_add_transition) must keep the caller's ref.
  let cmap = pcs_build_consume_map(decls, [])
  map(decls, (d) => perceus_decl_b(d, fns, bmap, cmap))
}

pub type BorrowEntry = BE(String, [Int])

fn pcs_build_borrow_map(decls: [Decl], acc: [BorrowEntry]) : [BorrowEntry] = match decls {
  []           -> acc
  [d, ...rest] -> pcs_build_borrow_map(rest, pcs_borrow_entry_of(d, acc))
}

fn pcs_borrow_entry_of(d: Decl, acc: [BorrowEntry]) : [BorrowEntry] = match d {
  DFn(_, name, _, params, _, _, body, _, _, mo) -> {
    let pnames = map(params, (p) => p.pname)
    let bset = pcs_borrow_params(pnames, body)
    match bset {
      [] -> acc
      _  -> {
        let positions = pcs_borrow_positions(pnames, bset, 0)
        # Register under BOTH the qualified key and the bare name, so a
        # caller referencing the fn either way (EModCall(mod,name) or a
        # bare EVar(name)) finds it.
        let qual = [BE(pcs_borrow_key(name, mo), positions), ...acc]
        match mo {
          None    -> qual
          Some(_) -> [BE(name, positions), ...qual]
        }
      }
    }
  }
  _ -> acc
}

fn pcs_borrow_key(name: String, mo: Option[String]) : String = match mo {
  None    -> name
  Some(m) -> concat_all([m, ".", name])
}

fn pcs_borrow_positions(pnames: [String], bset: [String], i: Int) : [Int] = match pnames {
  []           -> []
  [p, ...rest] ->
    if list_has(bset, p) { [i, ...pcs_borrow_positions(rest, bset, i + 1)] }
    else { pcs_borrow_positions(rest, bset, i + 1) }
}

fn pcs_borrow_lookup(bmap: [BorrowEntry], key: String) : [Int] = match bmap {
  []           -> []
  [e, ...rest] -> match e {
    BE(k, ps) -> if k == key { ps } else { pcs_borrow_lookup(rest, key) }
  }
}

# Back-compat: tests call the 2-arg form with no borrow map.
fn perceus_decl(d: Decl, fns: [EFn]) : Decl / Console =
  perceus_decl_b(d, fns, [], [])

# Callee side: wrap `match p { ... }` as `match __perceus_borrow(p) {...}`
# for each borrowed param `p` whose scrutinee is the bare param —
# emit_match then skips the exit decref (the value is borrowed, owned up
# the stack). Walks the whole body.
fn pcs_wrap_borrow_scrutinees(e: Expr, borrowed: [String]) : Expr =
  Expr { kind: pcs_wrap_borrow_kind(e.kind, borrowed),
         line: e.line, col: e.col, ty: e.ty, mode: e.mode }

fn pcs_wrap_borrow_kind(k: ExprKind, borrowed: [String]) : ExprKind = match k {
  EMatch(scr, arms) -> {
    let scr2 = match scr.kind {
      EVar(nm) ->
        if list_has(borrowed, nm) {
          Expr { kind: ECall(
                   Expr { kind: EVar("__perceus_borrow"), line: scr.line, col: scr.col,
                          ty: None, mode: MUnknown },
                   [scr]),
                 line: scr.line, col: scr.col, ty: scr.ty, mode: scr.mode }
        } else { pcs_wrap_borrow_scrutinees(scr, borrowed) }
      _ -> pcs_wrap_borrow_scrutinees(scr, borrowed)
    }
    EMatch(scr2, pcs_wrap_borrow_arms(arms, borrowed))
  }
  _ -> prc_map_expr_kind(k, (sub) => pcs_wrap_borrow_scrutinees(sub, borrowed))
}

fn pcs_wrap_borrow_arms(arms: [Arm], borrowed: [String]) : [Arm] = match arms {
  []           -> []
  [a, ...rest] -> match a {
    Arm(p, g, b) -> [Arm(p, g, pcs_wrap_borrow_scrutinees(b, borrowed)),
                     ...pcs_wrap_borrow_arms(rest, borrowed)]
  }
}

# Caller side: strip the __perceus_dup the rewrite put on an argument
# that lands in a borrowed parameter slot of the callee. The callee
# borrows (does not consume) so the caller need not dup → the incref is
# removed. Uses the global borrow map keyed by callee name.
fn pcs_strip_borrow_args(e: Expr, bmap: [BorrowEntry]) : Expr =
  Expr { kind: pcs_strip_borrow_kind(e.kind, bmap),
         line: e.line, col: e.col, ty: e.ty, mode: e.mode }

fn pcs_strip_borrow_kind(k: ExprKind, bmap: [BorrowEntry]) : ExprKind = match k {
  ECall(callee, args_) -> {
    let key = pcs_callee_key(callee)
    let positions = pcs_borrow_lookup(bmap, key)
    let args2 = pcs_strip_args_at(args_, positions, 0, bmap)
    ECall(pcs_strip_borrow_args(callee, bmap), args2)
  }
  _ -> prc_map_expr_kind(k, (sub) => pcs_strip_borrow_args(sub, bmap))
}

# The call key for a callee expr — bare EVar or resolved EModCall.
fn pcs_callee_key(callee: Expr) : String = match callee.kind {
  EVar(nm)          -> nm
  EModCall(m, nm)   -> concat_all([m, ".", nm])
  _                 -> ""
}

# For each arg: if its index is in `positions` (borrowed slot) and it is
# `__perceus_dup(x)`, strip to `x`. Recurse into every arg either way.
fn pcs_strip_args_at(args_: [Expr], positions: [Int], i: Int, bmap: [BorrowEntry]) : [Expr] = match args_ {
  []           -> []
  [a, ...rest] -> {
    let a1 = pcs_strip_borrow_args(a, bmap)
    let a2 = if pcs_has_int(positions, i) { pcs_strip_dup_wrap(a1) } else { a1 }
    [a2, ...pcs_strip_args_at(rest, positions, i + 1, bmap)]
  }
}

fn pcs_has_int(xs: [Int], t: Int) : Bool = match xs {
  []           -> false
  [x, ...rest] -> if x == t { true } else { pcs_has_int(rest, t) }
}

fn pcs_list_union(xs: [String], ys: [String]) : [String] = match ys {
  []           -> xs
  [y, ...rest] -> if list_has(xs, y) { pcs_list_union(xs, rest) }
                  else { pcs_list_union([y, ...xs], rest) }
}

fn pcs_params_minus(params: [Param], borrowed: [String]) : [Param] = match params {
  []           -> []
  [p, ...rest] ->
    if list_has(borrowed, p.pname) { pcs_params_minus(rest, borrowed) }
    else { [p, ...pcs_params_minus(rest, borrowed)] }
}

# ---------- Borrow inference (Koka kk_borrow_t, B1) ----------
#
# A parameter is BORROWED when the body only INSPECTS it: every read of
# the param is the scrutinee of a `match` whose arms never use any
# binder of the matched pattern (the children never escape). `is_red`
# is the canonical case:
#
#   fn is_red(t) = match t { RBNode(Red,_,_,_,_) -> true; _ -> false }
#
# `t` is read once, as a match scrutinee, and the arms bind nothing —
# so no component of `t` escapes the call. A borrowed param is the dual
# of the #599 skip-set: the callee does NOT consume it (no scrutinee
# decref, no exit drop), and the caller does NOT dup it. This removes
# the `kai_internal_dup` the caller would otherwise emit on a multi-use
# argument — the 37%-of-wall RC traffic the rb-tree spends on
# inspection calls (is_red, comparisons).
#
# Soundness (asu trap #1): the danger is escape of a CHILD of the
# param, not the param itself. The rule is conservative toward owned —
# it only fires when the arms bind NOTHING that is later read, so there
# is provably no escape. Anything more (a binder used anywhere in the
# arm body) marks the param owned and falls back to the dup discipline.

pub fn pcs_borrow_params(pnames: [String], body: Expr) : [String] = match pnames {
  []           -> []
  [h, ...rest] -> {
    let rest_b = pcs_borrow_params(rest, body)
    if pcs_name_only_inspected(h, body) { [h, ...rest_b] } else { rest_b }
  }
}

# ---------- Consume-map (Koka Borrowed dual: which params a fn CONSUMES) ---
#
# A param is CONSUMED by its fn iff the fn deconstructs it (match scrutinee
# whose arm binds children) or stores it (ctor/record/list slot) — i.e. the fn
# takes ownership and the cell is reclaimed/reused inside. A param that is
# only FIELD-READ (`b.states`, `b.next_id`) or passed to another fn that does
# not consume it (the stdlib/regexp `nb_add_transition`/`nb_set_transitions`
# field-read chain) is NOT consumed — the caller keeps the obligation. This is
# the bit a caller needs to decide whether MOVING a binder into `f(binder)` is
# sound: move only into CONSUMING slots; a non-consuming slot must keep the
# caller's ref (dup), else the value's life after the call reads freed memory
# (the regexp UAF). Keyed per fn (qualified + bare, like the borrow map).
pub type ConsumeEntry = CE(String, [Int])

fn pcs_build_consume_map(decls: [Decl], acc: [ConsumeEntry]) : [ConsumeEntry] = match decls {
  []           -> acc
  [d, ...rest] -> pcs_build_consume_map(rest, pcs_consume_entry_of(d, acc))
}

fn pcs_consume_entry_of(d: Decl, acc: [ConsumeEntry]) : [ConsumeEntry] = match d {
  DFn(_, name, _, params, _, _, body, _, _, mo) -> {
    let pnames = map(params, (p) => p.pname)
    let positions = pcs_consumed_positions(pnames, body, 0)
    let qual = [CE(pcs_borrow_key(name, mo), positions), ...acc]
    match mo {
      None    -> qual
      Some(_) -> [CE(name, positions), ...qual]
    }
  }
  _ -> acc
}

fn pcs_consumed_positions(pnames: [String], body: Expr, i: Int) : [Int] = match pnames {
  []           -> []
  [p, ...rest] ->
    if pcs_param_consumes(p, body) { [i, ...pcs_consumed_positions(rest, body, i + 1)] }
    else { pcs_consumed_positions(rest, body, i + 1) }
}

# A param p is CONSUMED iff it appears as a deconstructing match scrutinee
# (arm binds a child = ownership taken) OR in a ctor/record/list slot (stored).
# A field-read-only param (regexp nb_*) is NOT consumed.
fn pcs_param_consumes(p: String, body: Expr) : Bool = pcs_consumes_kind(p, body.kind)

fn pcs_consumes_kind(p: String, k: ExprKind) : Bool = match k {
  EMatch(s, arms) -> {
    let scr_consumes = match s.kind {
      EVar(nm) -> nm == p and pcs_arms_bind_children(arms)
      _        -> pcs_consumes_kind(p, s.kind)
    }
    scr_consumes or pcs_consumes_arms(p, arms)
  }
  ECall(f, xs) -> match f.kind {
    EVar(c)        -> if pcs_name_is_ctor(c) { pcs_any_bare_var(p, xs) or pcs_consumes_seq(p, xs) }
                      else { pcs_consumes_kind(p, f.kind) or pcs_consumes_seq(p, xs) }
    EModCall(_, c) -> if pcs_name_is_ctor(c) { pcs_any_bare_var(p, xs) or pcs_consumes_seq(p, xs) }
                      else { pcs_consumes_seq(p, xs) }
    _              -> pcs_consumes_kind(p, f.kind) or pcs_consumes_seq(p, xs)
  }
  ERecordLit(_, fis) -> pcs_consumes_fields(p, fis)
  EList(els)         -> pcs_consumes_elems(p, els)
  EIf(c, t, opt_e)   -> pcs_consumes_kind(p, c.kind) or pcs_consumes_kind(p, t.kind) or
                         (match opt_e { None -> false Some(e2) -> pcs_consumes_kind(p, e2.kind) })
  EBlock(stmts, tail)-> pcs_consumes_stmts(p, stmts) or
                         (match tail { None -> false Some(e) -> pcs_consumes_kind(p, e.kind) })
  EBinop(_, a, b)    -> pcs_consumes_kind(p, a.kind) or pcs_consumes_kind(p, b.kind)
  EUnop(_, x)        -> pcs_consumes_kind(p, x.kind)
  EField(x, _)       -> match x.kind { EVar(_) -> false _ -> pcs_consumes_kind(p, x.kind) }
  EIndex(a, b)       -> (match a.kind { EVar(_) -> false _ -> pcs_consumes_kind(p, a.kind) }) or
                         pcs_consumes_kind(p, b.kind)
  EPipe(a, b)        -> pcs_consumes_kind(p, a.kind) or pcs_consumes_kind(p, b.kind)
  EBang(x)           -> pcs_consumes_kind(p, x.kind)
  _ -> false
}

fn pcs_arms_bind_children(arms: [Arm]) : Bool = match arms {
  []           -> false
  [a, ...rest] -> match a {
    Arm(pat, _, _) -> match prc_pat_binders(pat, []) { [] -> pcs_arms_bind_children(rest) _ -> true }
  }
}

fn pcs_consumes_arms(p: String, arms: [Arm]) : Bool = match arms {
  []           -> false
  [a, ...rest] -> match a {
    Arm(_, opt_g, b) ->
      (match opt_g { None -> false Some(g) -> pcs_consumes_kind(p, g.kind) }) or
      pcs_consumes_kind(p, b.kind) or pcs_consumes_arms(p, rest)
  }
}

fn pcs_consumes_seq(p: String, xs: [Expr]) : Bool = match xs {
  []           -> false
  [h, ...rest] -> pcs_consumes_kind(p, h.kind) or pcs_consumes_seq(p, rest)
}

fn pcs_any_bare_var(p: String, xs: [Expr]) : Bool = match xs {
  []           -> false
  [h, ...rest] -> (match h.kind { EVar(nm) -> nm == p _ -> false }) or pcs_any_bare_var(p, rest)
}

fn pcs_consumes_fields(p: String, fis: [FieldInit]) : Bool = match fis {
  []           -> false
  [h, ...rest] -> match h {
    FI(_, e) -> (match e.kind { EVar(nm) -> nm == p _ -> pcs_consumes_kind(p, e.kind) }) or
                pcs_consumes_fields(p, rest)
  }
}

fn pcs_consumes_elems(p: String, els: [ListElem]) : Bool = match els {
  []           -> false
  [h, ...rest] -> {
    let here = match h {
      ElPlain(e)  -> match e.kind { EVar(nm) -> nm == p _ -> pcs_consumes_kind(p, e.kind) }
      ElSpread(e) -> pcs_consumes_kind(p, e.kind)
    }
    here or pcs_consumes_elems(p, rest)
  }
}

fn pcs_consumes_stmts(p: String, stmts: [Stmt]) : Bool = match stmts {
  []           -> false
  [s, ...rest] -> {
    let here = match s {
      SLet(_, _, e)       -> pcs_consumes_kind(p, e.kind)
      SVar(_, _, e, _, _) -> pcs_consumes_kind(p, e.kind)
      SExprStmt(e)        -> pcs_consumes_kind(p, e.kind)
      _                   -> false
    }
    here or pcs_consumes_stmts(p, rest)
  }
}

fn pcs_consume_lookup(cmap: [ConsumeEntry], key: String) : [Int] = match cmap {
  []           -> []
  [e, ...rest] -> match e { CE(k, ps) -> if k == key { ps } else { pcs_consume_lookup(rest, key) } }
}

# True iff every arg-slot use of `nm` in `e` lands in a CONSUMING param slot
# of the callee (per cmap). ctor slots / match scrutinees / returns consume by
# construction. A user-fn call whose slot for nm is NOT in the callee's
# consume set → false (the callee borrows nm; moving it is unsound).
fn pcs_uses_only_consuming_slots(nm: String, e: Expr, cmap: [ConsumeEntry]) : Bool =
  pcs_consuming_slots_kind(nm, e.kind, cmap)

fn pcs_any_arg_is_lambda(xs: [Expr]) : Bool = match xs {
  []           -> false
  [h, ...rest] -> match h.kind { ELambda(_, _) -> true _ -> pcs_any_arg_is_lambda(rest) }
}

fn pcs_name_in_expr(nm: String, e: Expr) : Bool = pcs_max_paths_in_expr(nm, e) > 0

fn pcs_name_in_exprs(nm: String, xs: [Expr]) : Bool = match xs {
  []           -> false
  [h, ...rest] -> pcs_name_in_expr(nm, h) or pcs_name_in_exprs(nm, rest)
}

fn pcs_consuming_slots_kind(nm: String, k: ExprKind, cmap: [ConsumeEntry]) : Bool = match k {
  ECall(f, xs) -> {
    # Higher-order conservatism: if ANY arg is a lambda, the call is a
    # higher-order combinator (map/filter/fold). The lambda may FIELD-READ
    # nm's elements (e.g. `map(args, (a) => desugar_interp_expr(a))` field-
    # reads each a), which the per-callee consume-map does not model — the
    # consume bit is about the LIST param, not its elements. Moving nm into
    # such a call corrupts the AST (the desugar_interp self-host infinite
    # recursion). Treat nm as non-consuming-safe whenever the call carries a
    # lambda arg, OR nm itself appears inside a lambda.
    if pcs_any_arg_is_lambda(xs) and (pcs_name_in_exprs(nm, xs) or pcs_name_in_expr(nm, f)) {
      false
    } else {
      let key = pcs_callee_key(f)
      let consumed = pcs_consume_lookup(cmap, key)
      let is_ctor = match f.kind {
        EVar(c)        -> pcs_name_is_ctor(c)
        EModCall(_, c) -> pcs_name_is_ctor(c)
        _              -> false
      }
      pcs_consuming_slots_kind(nm, f.kind, cmap) and
        pcs_consuming_args(nm, xs, consumed, is_ctor, 0, cmap)
    }
  }
  ELambda(_, _) -> false   # nm captured under a lambda = not move-safe
  EMatch(s, arms) -> {
    let s_ok = match s.kind { EVar(_) -> true _ -> pcs_uses_only_consuming_slots(nm, s, cmap) }
    s_ok and pcs_consuming_arms(nm, arms, cmap)
  }
  EIf(c, t, opt_e) -> pcs_uses_only_consuming_slots(nm, c, cmap) and
                       pcs_uses_only_consuming_slots(nm, t, cmap) and
                       (match opt_e { None -> true Some(e2) -> pcs_uses_only_consuming_slots(nm, e2, cmap) })
  EBlock(stmts, tail) -> pcs_consuming_stmts(nm, stmts, cmap) and
                          (match tail { None -> true Some(e) -> pcs_uses_only_consuming_slots(nm, e, cmap) })
  EBinop(_, a, b) -> pcs_uses_only_consuming_slots(nm, a, cmap) and pcs_uses_only_consuming_slots(nm, b, cmap)
  EUnop(_, x)     -> pcs_uses_only_consuming_slots(nm, x, cmap)
  EField(x, _)    -> match x.kind { EVar(uname) -> uname != nm _ -> pcs_uses_only_consuming_slots(nm, x, cmap) }
  EIndex(a, b)    -> (match a.kind { EVar(uname) -> uname != nm _ -> pcs_uses_only_consuming_slots(nm, a, cmap) }) and
                      pcs_uses_only_consuming_slots(nm, b, cmap)
  ERecordLit(_, fis) -> pcs_consuming_fields(nm, fis, cmap)
  EList(els)      -> pcs_consuming_elems(nm, els, cmap)
  EPipe(a, b)     -> pcs_uses_only_consuming_slots(nm, a, cmap) and pcs_uses_only_consuming_slots(nm, b, cmap)
  EBang(x)        -> pcs_uses_only_consuming_slots(nm, x, cmap)
  _ -> true
}

fn pcs_consuming_args(nm: String, xs: [Expr], consumed: [Int], is_ctor: Bool, i: Int, cmap: [ConsumeEntry]) : Bool = match xs {
  []           -> true
  [h, ...rest] -> {
    let here = match h.kind {
      EVar(uname) -> if uname == nm { is_ctor or pcs_has_int(consumed, i) } else { true }
      _ -> pcs_uses_only_consuming_slots(nm, h, cmap)
    }
    here and pcs_consuming_args(nm, rest, consumed, is_ctor, i + 1, cmap)
  }
}

fn pcs_consuming_arms(nm: String, arms: [Arm], cmap: [ConsumeEntry]) : Bool = match arms {
  []           -> true
  [a, ...rest] -> match a {
    Arm(_, opt_g, b) ->
      (match opt_g { None -> true Some(g) -> pcs_uses_only_consuming_slots(nm, g, cmap) }) and
      pcs_uses_only_consuming_slots(nm, b, cmap) and pcs_consuming_arms(nm, rest, cmap)
  }
}

fn pcs_consuming_stmts(nm: String, stmts: [Stmt], cmap: [ConsumeEntry]) : Bool = match stmts {
  []           -> true
  [s, ...rest] -> {
    let here = match s {
      SLet(_, _, e)       -> pcs_uses_only_consuming_slots(nm, e, cmap)
      SVar(_, _, e, _, _) -> pcs_uses_only_consuming_slots(nm, e, cmap)
      SExprStmt(e)        -> pcs_uses_only_consuming_slots(nm, e, cmap)
      _                   -> true
    }
    here and pcs_consuming_stmts(nm, rest, cmap)
  }
}

fn pcs_consuming_fields(nm: String, fis: [FieldInit], cmap: [ConsumeEntry]) : Bool = match fis {
  []           -> true
  [h, ...rest] -> match h {
    FI(_, e) -> pcs_uses_only_consuming_slots(nm, e, cmap) and pcs_consuming_fields(nm, rest, cmap)
  }
}

fn pcs_consuming_elems(nm: String, els: [ListElem], cmap: [ConsumeEntry]) : Bool = match els {
  []           -> true
  [h, ...rest] -> {
    let inner = match h { ElPlain(e) -> e ElSpread(e) -> e }
    pcs_uses_only_consuming_slots(nm, inner, cmap) and pcs_consuming_elems(nm, rest, cmap)
  }
}

# True iff every read of `nm` in `e` is an inspect-only position: the
# bare scrutinee of a match whose arms escape nothing. A use anywhere
# else (arg to a call, ctor slot, field, return, etc.) is NOT
# inspect-only → the param is owned. Conservative: returns false the
# moment it sees `nm` outside an inspecting match.
fn pcs_name_only_inspected(nm: String, e: Expr) : Bool =
  pcs_inspected_kind(nm, e.kind)

fn pcs_inspected_kind(nm: String, k: ExprKind) : Bool = match k {
  EMatch(s, arms) -> {
    # `nm` as the bare scrutinee is an inspect, IF the arms escape
    # nothing. `nm` appearing inside a non-bare scrutinee expression,
    # or inside any arm body, must itself be inspect-only.
    let scr_inspect = match s.kind {
      EVar(uname) -> if uname == nm { pcs_arms_escape_nothing(arms) } else { true }
      _           -> pcs_name_only_inspected(nm, s)
    }
    scr_inspect and pcs_inspected_arms(nm, arms)
  }
  EVar(uname)         -> uname != nm   # a bare read NOT as scrutinee = owned use
  ECall(f, xs)        -> pcs_inspected(nm, f) and pcs_inspected_list(nm, xs)
  EIntrinsic(_, xs)   -> pcs_inspected_list(nm, xs)
  EField(x, _)        -> pcs_name_absent(nm, x)   # field read of nm = owned
  EIndex(a, b)        -> pcs_name_absent(nm, a) and pcs_name_only_inspected(nm, b)
  EBinop(_, a, b)     -> pcs_name_only_inspected(nm, a) and pcs_name_only_inspected(nm, b)
  EUnop(_, x)         -> pcs_name_only_inspected(nm, x)
  EIf(c, t, oe)       -> pcs_name_only_inspected(nm, c) and
                          pcs_name_only_inspected(nm, t) and
                          pcs_inspected_opt(nm, oe)
  EBlock(stmts, tail) -> pcs_inspected_block(nm, stmts, tail)
  ELambda(_, b)       -> pcs_name_absent(nm, b)   # capture = owned
  ERecordLit(_, fis)  -> pcs_inspected_fields(nm, fis)
  EList(els)          -> pcs_inspected_elems(nm, els)
  ERange(a, b, oe)    -> pcs_name_only_inspected(nm, a) and
                          pcs_name_only_inspected(nm, b) and pcs_inspected_opt(nm, oe)
  EPipe(a, b)         -> pcs_name_only_inspected(nm, a) and pcs_name_only_inspected(nm, b)
  EMapPipe(a, b)      -> pcs_name_only_inspected(nm, a) and pcs_name_only_inspected(nm, b)
  EFlatMapPipe(a, b)  -> pcs_name_only_inspected(nm, a) and pcs_name_only_inspected(nm, b)
  EFilterPipe(a, b)   -> pcs_name_only_inspected(nm, a) and pcs_name_only_inspected(nm, b)
  EBang(x)            -> pcs_name_only_inspected(nm, x)
  ELitUnit(x, _)      -> pcs_name_only_inspected(nm, x)
  EStr(_, _)          -> false   # interpolation reads are owned (conservative)
  EHandle(_, _, _, _, _, _, _) -> false   # conservative: handlers are owned
  _                   -> true    # leaves never reference nm
}

# An arm escapes nothing iff none of its pattern's binders are read in
# the arm body. Conservative: a guard counts as the body too.
fn pcs_arms_escape_nothing(arms: [Arm]) : Bool = match arms {
  []           -> true
  [a, ...rest] -> match a {
    Arm(pat, opt_g, abody) -> {
      let binders = prc_pat_binders(pat, [])
      let body_clean = pcs_no_binder_used(binders, abody)
      let guard_clean = match opt_g {
        None    -> true
        Some(g) -> pcs_no_binder_used(binders, g)
      }
      if body_clean and guard_clean { pcs_arms_escape_nothing(rest) } else { false }
    }
  }
}

# None of `binders` is read anywhere in `e`.
fn pcs_no_binder_used(binders: [String], e: Expr) : Bool = match binders {
  []           -> true
  [b, ...rest] -> if pcs_name_absent(b, e) { pcs_no_binder_used(rest, e) } else { false }
}

# `nm` does not appear as a read anywhere in `e`. Pure structural walk
# (no effects) — must stay effect-free so the borrow analysis carries
# no Console row (the use-collector pcs_collect_uses_expr does, and
# threading that row through the inference would be both heavy and
# wrong: inference is a pure query). Reuses the existing
# pcs_max_paths_in_expr, which counts reads of `nm` purely.
fn pcs_name_absent(nm: String, e: Expr) : Bool =
  pcs_max_paths_in_expr(nm, e) == 0

fn pcs_inspected(nm: String, e: Expr) : Bool = pcs_name_only_inspected(nm, e)

fn pcs_inspected_list(nm: String, es: [Expr]) : Bool = match es {
  []           -> true
  [e, ...rest] -> if pcs_name_only_inspected(nm, e) { pcs_inspected_list(nm, rest) } else { false }
}

fn pcs_inspected_opt(nm: String, oe: Option[Expr]) : Bool = match oe {
  None    -> true
  Some(e) -> pcs_name_only_inspected(nm, e)
}

fn pcs_inspected_arms(nm: String, arms: [Arm]) : Bool = match arms {
  []           -> true
  [a, ...rest] -> match a {
    Arm(_, opt_g, abody) -> {
      let g_ok = match opt_g { None -> true Some(g) -> pcs_name_only_inspected(nm, g) }
      if g_ok and pcs_name_only_inspected(nm, abody) { pcs_inspected_arms(nm, rest) } else { false }
    }
  }
}

fn pcs_inspected_block(nm: String, stmts: [Stmt], tail: Option[Expr]) : Bool = {
  let s_ok = pcs_inspected_stmts(nm, stmts)
  s_ok and pcs_inspected_opt(nm, tail)
}

fn pcs_inspected_stmts(nm: String, stmts: [Stmt]) : Bool = match stmts {
  []           -> true
  [s, ...rest] -> if pcs_inspected_stmt(nm, s) { pcs_inspected_stmts(nm, rest) } else { false }
}

fn pcs_inspected_stmt(nm: String, s: Stmt) : Bool = match s {
  SLet(_, _, rhs)         -> pcs_name_only_inspected(nm, rhs)
  SExprStmt(e)            -> pcs_name_only_inspected(nm, e)
  _                       -> pcs_name_absent_stmt(nm, s)
}

fn pcs_name_absent_stmt(nm: String, s: Stmt) : Bool = match s {
  SLet(_, _, rhs) -> pcs_name_absent(nm, rhs)
  SExprStmt(e)    -> pcs_name_absent(nm, e)
  _               -> true
}

fn pcs_inspected_fields(nm: String, fis: [FieldInit]) : Bool = match fis {
  []           -> true
  [f, ...rest] -> match f {
    FI(_, v) -> if pcs_name_only_inspected(nm, v) { pcs_inspected_fields(nm, rest) } else { false }
  }
}

fn pcs_inspected_elems(nm: String, els: [ListElem]) : Bool = match els {
  []           -> true
  [el, ...rest] -> {
    let ok = match el {
      ElPlain(e)  -> pcs_name_only_inspected(nm, e)
      ElSpread(e) -> pcs_name_absent(nm, e)   # spread tail owns the value
    }
    if ok { pcs_inspected_elems(nm, rest) } else { false }
  }
}

fn perceus_decl_b(d: Decl, fns: [EFn], bmap: [BorrowEntry], cmap: [ConsumeEntry]) : Decl / Console {

  match d {
    DFn(is_pub, name, tparams, params, opt_ret, row, body, ln, cl, mo) -> {
      # m12.7.x FFI v1: an `[<extern_c>]` axiom's body is the magic
      # ETodo tag that signals the C / LLVM emitters to inline an
      # FFI shim. Skip Perceus rewriting — the shim handles its own
      # arg-decref discipline (it `kai_decref`s every boxed input
      # after the extern returns), so prepending unused-param drops
      # would double-free.
      if body_is_ffi_extern(body) { d }
      # Phase 3 unboxing — UFn params are raw C scalars (`int64_t`
      # etc.) with no reference count, so they carry NO dup/drop
      # obligation: they must stay out of the Perceus scope (a dup
      # against `kai_<pname>` would name a non-existent boxed alias)
      # and never receive an unused-param drop.
      #
      # Issue #703 — but the *body* of a UFn can still bind boxed
      # locals (`let v = A([..])`), and the match emitter consumes
      # (`kai_decref(_scr)`) its scrutinee on every match exit. A
      # boxed local read by ≥ 2 matches therefore needs the same
      # dup-at-non-last-read + exit-drop discipline as any other
      # block-local. The previous code skipped Perceus for the
      # *entire* UFn body, so the second `match v` dispatched on a
      # freed chunk → "non-exhaustive match" (C honored the missing
      # dup; LLVM happened not to). The fix runs the body rewrite
      # with an EMPTY param scope (mirroring DTest below): in-body
      # SLet bindings enter the scope during the walk and get their
      # dups + exit drops, while the raw params stay untouched and
      # `pcs_prepend_unused_drops` is skipped (no boxed params to
      # reclaim).
      else if prc_is_ufn_decl(fns, name, mo) {
        let uses = pcs_collect_uses_expr(body, [], false, [])
        let new_body = pcs_rewrite_expr(body, [], uses, false, [], [], bmap)
        let arm_dropped = pcs_arm_drop_pass(new_body, name, [], uses)
        let reused_body = pcs_recognise_reuse_expr(arm_dropped)
        DFn(is_pub, name, tparams, params, opt_ret, row, reused_body, ln, cl, mo)
      }
      else {
        let pnames = map(params, (p) => p.pname)
        let uses = pcs_collect_uses_expr(body, pnames, false, [])
        # Borrow inference (Koka). A borrowed param is inspect-only:
        # the body reads it WITHOUT dup (so it must be in the skip-set,
        # never dup'd) and its match scrutinee is wrapped in
        # __perceus_borrow so emit_match skips the exit decref → the
        # callee never touches the param's RC. The caller side
        # (pcs_strip_borrow_args) strips the __perceus_dup on the matching
        # argument → no incref is paid either. Net: zero RC on the
        # inspected param, which is exactly the 37%-of-wall traffic the
        # rb-tree spends on is_red / comparisons.
        let borrowed = pcs_borrow_params(pnames, body)
        # Issue #599 — branch-aware skip-set: params read <= 1 time per
        # path transfer ownership raw (no dup). Borrowed params join the
        # skip-set too (they are never dup'd) — union the two.
        # Plus the arm-binder per-path move set (Koka Parc per-branch
        # ownership): pattern binders of SELF-RECURSIVE MODULO-CONS arms whose
        # max-path count (borrow-aware, discounting is_red(l)) is <= 1,
        # consumed-on-every-path, all-consumers-linear. Restricted to
        # self-rec-modulo-cons arms because emit disposes only those via the
        # borrow-model (arm-top reuse); a non-self-rec arm keeps the legacy
        # emit and moving its binders would double-free (the regexp UAF). This
        # is the half that lets insert_loop's Black arm move l/r instead of
        # spuriously dup'ing them — the ~8.8-nodes-per-insert spine leak.
        let arm_moves = pcs_collect_arm_skip_binders(name, true, body, bmap, cmap)
        let skip_set = pcs_list_union(
          pcs_list_union(pcs_branch_aware_skip_params(pnames, body), borrowed),
          arm_moves)
        let new_body = pcs_rewrite_expr(body, pnames, uses, false, skip_set, [], bmap)
        let arm_dropped = pcs_arm_drop_pass(new_body, name, pnames, uses)
        let reused_body = pcs_recognise_reuse_expr(arm_dropped)
        # Borrowed params carry no exit obligation — exclude from the
        # unused-param drop.
        let drop_params = pcs_params_minus(params, borrowed)
        let body_with_drops = pcs_prepend_unused_drops(reused_body, drop_params, uses, skip_set)
        # Callee flip: wrap borrowed scrutinees so emit_match skips the
        # decref. Caller flip: strip __perceus_dup on borrowed-slot args.
        let body_borrow_scr = pcs_wrap_borrow_scrutinees(body_with_drops, borrowed)
        let body_borrow = pcs_strip_borrow_args(body_borrow_scr, bmap)
        DFn(is_pub, name, tparams, params, opt_ret, row, body_borrow, ln, cl, mo)
      }
    }
    # Test bodies are emitted as their own thunk fns; without rewriting
    # them here, multi-use let-bindings inside test bodies (especially
    # ones captured by closures) skip the dup pass and the closure body
    # double-consumes its captures under the linear runtime. No params
    # to drop, but the dup walker is still needed for in-body multi-use
    # bindings.
    DTest(desc, body, ln, cl) -> {
      let uses = pcs_collect_uses_expr(body, [], false, [])
      let new_body = pcs_rewrite_expr(body, [], uses, false, [], [], bmap)
      let reused_body = pcs_recognise_reuse_expr(new_body)
      DTest(desc, reused_body, ln, cl)
    }
    DBench(desc, body, ln, cl) -> {
      let uses = pcs_collect_uses_expr(body, [], false, [])
      let new_body = pcs_rewrite_expr(body, [], uses, false, [], [], bmap)
      let reused_body = pcs_recognise_reuse_expr(new_body)
      DBench(desc, reused_body, ln, cl)
    }
    # check v1 (issue #44): with-clause params behave like fn params
    # for Perceus — collected as known external bindings so dup/drop
    # discipline accounts for them. The emitter wraps each iter in a
    # function that defines the param locals and drops them at iter
    # boundary.
    #
    # Issue #697: unlike a fn param, a check-param is NOT owned by the
    # body — the generated check loop owns it. The loop drops it in
    # iter_drops/tail_drops, and the shrinker re-evaluates the same
    # body against the SAME param value across iterations. So the body
    # must BORROW its params: every read dups, last-use included, and
    # the body never consumes/drops them. Passing `pnames` as the
    # `force_set` makes `pcs_is_non_last` always-dup them — the same
    # treatment `state`/`log` get, and for the same alias-not-owned
    # reason. Without it, a single-use param (`string_length(s)`)
    # transfers raw to a decref-aware consumer that frees it, then the
    # loop's own drop double-frees (heap-use-after-free → SIGTRAP).
    DCheck(desc, ps, body, ln, cl) -> {
      let pnames = map(ps, (p) => p.pname)
      let uses = pcs_collect_uses_expr(body, pnames, false, [])
      let skip_set = pcs_branch_aware_skip_params(pnames, body)
      let new_body = pcs_rewrite_expr(body, pnames, uses, false, skip_set, pnames, bmap)
      let reused_body = pcs_recognise_reuse_expr(new_body)
      DCheck(desc, ps, reused_body, ln, cl)
    }
    _ -> d
  }
}

# ---- issue #118 — Perceus reuse-in-place recogniser ----
#
# Walks the post-`pcs_rewrite_expr` AST looking for match arms whose
# body rebuilds a constructor of the same shape as the arm's pattern.
# When found, the rebuild is rewritten to call one of the magic
# `__perceus_reuse_*` helpers; the emitter (`emit_call_expr`) lowers
# those to runtime hooks that branch on the consumed cell's RC at
# each invocation: rewrite-in-place when unique, fall back to
# `kai_<shape>` when shared.
#
# The synthetic identifier `__pcs_scr` is the recogniser's hand-off
# to the emitter — it lowers to the literal C local `_scr` that
# `emit_match_default` introduces for every match. The match exit
# always `kai_decref(_scr)`s; the runtime helpers `kai_incref` the
# reused cell so it survives the decref, leaving the caller with a
# unique-RC result.
#
# v1 patterns (audit §1):
#   - cons:    Arm(PList([_], Some(t)), None, EList([ElPlain(_), ElSpread(_)]))
#   - variant: Arm(PVariant(_, ps), None, ECall(EVar(C), args))
#                where length(args) == length(ps)
#   - record:  Arm(PRecord(_), None, ERecordLit(_, fis))
#                where the literal has the same field count
#
# Out of v1 scope: PVariantRecord (named-field variants), guards,
# blocks before the rebuild, multi-cons rebuilds (e.g. `[a, b, ...c]
# -> [a', b', ...c']` rewrites only the outermost cons), arms whose
# body recurses through a let-binding (those would need a follow-up
# pass). The runtime `rc == 1` guard makes every fall-through case
# safe — a missed recognition is a missed optimisation, not a bug.

fn pcs_recognise_reuse_expr(e: Expr) : Expr =
  Expr { kind: pcs_recognise_reuse_kind(e.kind, e.line, e.col),
         line: e.line, col: e.col, ty: e.ty, mode: e.mode }

fn pcs_recognise_reuse_kind(k: ExprKind, line: Int, col: Int) : ExprKind {
  match k {
    EMatch(scr, arms) -> {
      # The scrutinee's resolved type is the typer-aware shape
      # predicate's anchor for variant + record arms (issue #210):
      # a same-shape rebuild must produce a value whose
      # `mangle_ty` matches the scrutinee's. `scr.ty` is populated
      # by the typer + monomorphiser before perceus runs.
      let new_scr = pcs_recognise_reuse_expr(scr)
      EMatch(new_scr, pcs_recognise_reuse_arms(new_scr.ty, arms))
    }
    _ -> prc_map_expr_kind(k, pcs_recognise_reuse_expr)
  }
}

fn pcs_recognise_reuse_arms(scr_ty: Option[Ty], arms: [Arm]) : [Arm] {
  match arms {
    [] -> []
    [a, ...rest] -> match a {
      Arm(pat, opt_g, body) -> {
        # Recurse into the body first so nested matches also get
        # rewritten, then attempt the same-shape recognition on the
        # outermost form. Guards disable recognition (the body might
        # not run) — keep the conservative path.
        let body1 = pcs_recognise_reuse_expr(body)
        let body2 = match opt_g {
          None    -> pcs_try_reuse_arm(scr_ty, pat, body1)
          Some(_) -> body1
        }
        [Arm(pat, opt_g, body2),
         ...pcs_recognise_reuse_arms(scr_ty, rest)]
      }
    }
  }
}

# Build the synthetic `__pcs_scr` placeholder at a given source
# position. The emitter recognises the name inside
# `__perceus_reuse_*` first-arg slots and lowers it to `_scr`.
fn pcs_mk_scr(line: Int, col: Int) : Expr =
  Expr { kind: EVar("__pcs_scr"), line: line, col: col,
         ty: None, mode: MUnknown }

fn pcs_mk_call(name: String, args: [Expr], line: Int, col: Int) : Expr =
  Expr { kind: ECall(
            Expr { kind: EVar(name), line: line, col: col,
                   ty: None, mode: MUnknown },
            args),
         line: line, col: col, ty: None, mode: MUnknown }

fn pcs_try_reuse_arm(scr_ty: Option[Ty], pat: Pattern, body: Expr) : Expr {
  match pat.pkind {
    # Cons rebuild — `[h, ...t] -> [g(h), ...recur(t)]`. Only the
    # single-head shape (one fixed sub-pattern + a rest binder) is
    # in v1 scope; multi-head spines fall through to the normal
    # `kai_cons` allocator.
    PList(pats, opt_rest) -> {
      match opt_rest {
        Some(_) -> match pats {
          [_] -> pcs_try_reuse_cons(body)
          _   -> body
        }
        None -> body
      }
    }
    # Variant rebuild — `Some(d) -> Some(g(d))`. Issue #210: the
    # shape predicate compares the resolved scrutinee type to the
    # rebuild expression's resolved type. Both must be `TyCon`s
    # with the same head name and tparams (equal `mangle_ty`); a
    # rebuild like `Some(d) -> Some(false)` over `Maybe[Int]`
    # produces `Maybe[Bool]` and is rejected.
    # The 1:1 reuse lowering (emit_match_arm_reuse_variant) only binds
    # FLAT slot sub-patterns (PBind / PWild). A nested variant/list/
    # record sub-pattern binds inner vars the reuse emit never declares,
    # producing C that references undeclared `kai_<inner>` identifiers.
    # Restrict reuse to arms whose slots are all flat; nested-pattern
    # arms fall through to the fresh `kai_variant_u` allocator (a missed
    # optimisation, not a miscompile).
    # The reuse must also be DIAGONAL: each boxed slot of the rebuild
    # must be exactly the binder of the same slot in the pattern. A
    # rebuild that puts a fresh node, or another slot's binder, into a
    # pointer slot orphans the old child (memory leak) — the 1:1 lowering
    # transfers slots without dropping the old pointer. Unboxed slots
    # (Int/Real/Bool) are copy-by-value with no RC, so any derived
    # expression (`k + 1`) is safe. Non-diagonal arms fall through to the
    # fresh allocator, which drops the old children correctly.
    PVariant(_cname, ps) -> {
      let flat_ok = pcs_all_flat_subs(ps)
      let shape_ok = pcs_shape_matches(scr_ty, body.ty)
      # The diagonal gate was only needed for the old eager-1:1-decref
      # embryo (kai_reuse_or_alloc_variant), which orphaned children on
      # a non-diagonal rebuild. The reuse lowering now uses
      # kai_variant_reuse_at (Koka move semantics: donate the unique
      # cell, write the new slots, do NOT decref the donor's old
      # children — the arm already extracted/owns them). A non-diagonal
      # rebuild is therefore sound, so the diagonal gate is dropped.
      # `flat_ok` stays: nested sub-patterns bind inner vars the reuse
      # emit never declares, producing undeclared-identifier C.
      if flat_ok and shape_ok {
        pcs_try_reuse_variant(body, list_length(ps))
      } else { body }
    }
    # Record rebuild — `{ a, b } -> Rec { a: f(a), b }`. Same shape
    # predicate as variants; field count must also match (already
    # enforced inside `pcs_try_reuse_record`).
    PRecord(pfs) ->
      if pcs_shape_matches(scr_ty, body.ty) {
        pcs_try_reuse_record(body, list_length(pfs))
      } else { body }
    _ -> body
  }
}

# Issue #210 typer-aware shape predicate. Both the scrutinee and the
# rebuild expression must have a resolved type, and the canonical
# `mangle_ty` must match (head TyCon name + tparams). This blocks
# the original lexical-predicate failure mode (`Some(d) -> Some(false)`
# over `Maybe[Int]` rebuilds a `Maybe[Bool]` cell) without depending
# on lexer-level heuristics. Conservative on `None` / unresolved
# types (`TyAny`, `TyVarT`): no reuse fires when the typer didn't
# pin a concrete shape.
fn pcs_shape_matches(t1: Option[Ty], t2: Option[Ty]) : Bool {
  match t1 {
    None -> false
    Some(a) -> match t2 {
      None -> false
      Some(b) -> {
        if pcs_ty_concrete(a) and pcs_ty_concrete(b) {
          prc_mangle_ty(a) == prc_mangle_ty(b)
        } else { false }
      }
    }
  }
}

fn pcs_ty_concrete(t: Ty) : Bool {
  match t {
    TyVarT(_) -> false
    TyAny     -> false
    _         -> true
  }
}

fn pcs_try_reuse_cons(body: Expr) : Expr {
  match body.kind {
    EList(elems) -> match elems {
      [e1, e2] -> match e1 {
        ElPlain(h_new) -> match e2 {
          ElSpread(t_new) ->
            pcs_mk_call("__perceus_reuse_cons",
                        [pcs_mk_scr(body.line, body.col), h_new, t_new],
                        body.line, body.col)
          _ -> body
        }
        _ -> body
      }
      _ -> body
    }
    _ -> body
  }
}

fn pcs_try_reuse_variant(body: Expr, expected_arity: Int) : Expr {
  match body.kind {
    ECall(callee, cargs) -> match callee.kind {
      EVar(cname) ->
        # The shape predicate (mangle_ty match) confirms the rebuild
        # produces the same TyCon as the scrutinee, but it does not
        # distinguish a variant constructor from a function call that
        # returns the same type (e.g. `fn make_some(x: Int) : Maybe[Int]`).
        # The lexical uppercase check filters out non-ctor callees;
        # combined with the typer-aware shape match it is sound.
        if list_length(cargs) == expected_arity and pcs_name_is_ctor(cname) {
          pcs_mk_call("__perceus_reuse_variant",
                      [pcs_mk_scr(body.line, body.col), body],
                      body.line, body.col)
        } else { body }
      # The resolver qualifies a user constructor to its declaring
      # tycon module: `TNode(...)` becomes `ECall(EModCall("Tree",
      # "TNode"), ...)`. The recogniser must accept this resolved form
      # — without it, every variant rebuild after resolution looks
      # like a plain call and reuse-in-place never fires (the bare
      # `EVar` shape only survives for cons / record). The ctor-name
      # check still guards against a same-typed function call.
      EModCall(_mod, cname) ->
        if list_length(cargs) == expected_arity and pcs_name_is_ctor(cname) {
          pcs_mk_call("__perceus_reuse_variant",
                      [pcs_mk_scr(body.line, body.col), body],
                      body.line, body.col)
        } else { body }
      _ -> body
    }
    _ -> body
  }
}

fn pcs_name_is_ctor(nm: String) : Bool {
  match char_at(nm, 0) {
    Some(c) -> c >= 'A' and c <= 'Z'
    None    -> false
  }
}

# A slot sub-pattern is "flat" if the reuse-in-place emit can bind it
# without descending: a bare binder or a wildcard. Anything else
# (nested variant / list / record / literal) binds inner names the
# 1:1 reuse lowering does not declare, so such arms must not be
# recognised as reusable.
fn pcs_sub_is_flat(p: Pattern) : Bool =
  match p.pkind {
    PBind(_) -> true
    PWild    -> true
    # Nested sub-patterns (variant/list/record) bind inner names that
    # the reuse-in-place lowering does not descend to declare — a
    # nested-variant arm like balance_left's
    # `RBNode(_, RBNode(Red, lx, ..), ..)` would emit C referencing an
    # undeclared `kai_lx`. Capturing these (donate the inner cell as a
    # second pool token, declare the inner binders in the reuse path) is
    # the nested-subpattern token-POOL lever, still pending. Until then
    # they fall through to the fresh allocator (a missed optimisation,
    # not a miscompile).
    _        -> false
  }

fn pcs_all_flat_subs(ps: [Pattern]) : Bool =
  match ps {
    []          -> true
    [p, ...rest] -> if pcs_sub_is_flat(p) { pcs_all_flat_subs(rest) } else { false }
  }

# A variant slot is "unboxed" (copy-by-value, no RC) only for the kinds
# the emitter inlines into the slot word: Int (.i64) and Real (.r). Bool,
# Char, String, Byte are stored as BOXED pointers in the variant cell
# (variant_slot_kind in emit_c.kai returns 0 for them), so overwriting
# such a slot non-diagonally would orphan the old pointer. Keep this in
# lockstep with `variant_slot_kind`.
fn pcs_ty_is_unboxed(t: Option[Ty]) : Bool =
  match t {
    None -> false
    Some(ty) -> match ty {
      TyInt  -> true
      TyReal -> true
      _      -> false
    }
  }

# Diagonal-reuse predicate. The arm rebuilds `C(e0, ..., en)` over the
# pattern `C(p0, ..., pn)`. Reuse-in-place is leak-safe ONLY when, for
# every slot i:
#   - the slot is unboxed (copy-by-value, any `ei` is fine), OR
#   - `ei` is exactly the binder of `pi` (strict identity — the same
#     child stays in the same slot; no pointer is orphaned and the
#     borrowed alias is not consumed, avoiding both leak and UAF).
# A boxed slot whose rebuild expression is a fresh ctor, another slot's
# binder, or a consuming call `g(pi)` is NON-diagonal and must fall
# through to the fresh allocator.
fn pcs_reuse_is_diagonal(ps: [Pattern], body: Expr) : Bool =
  match pcs_ctor_args(body) {
    None       -> false
    Some(cargs) ->
      if list_length(cargs) == list_length(ps) {
        pcs_diag_slots(ps, cargs)
      } else { false }
  }

# Pull the constructor argument list out of a rebuild body, accepting
# both the bare `EVar(C)` and resolved `EModCall(mod, C)` callee shapes.
# NB: the binder must NOT be named `args` — that shadows against the
# prelude `args()` fn and silently resolves to an empty list (stage1
# shadow bug). Use `cargs`.
fn pcs_ctor_args(body: Expr) : Option[[Expr]] =
  match body.kind {
    ECall(callee, cargs) -> match callee.kind {
      EVar(_)        -> Some(cargs)
      EModCall(_, _) -> Some(cargs)
      _              -> None
    }
    _ -> None
  }

fn pcs_diag_slots(ps: [Pattern], cargs: [Expr]) : Bool =
  match ps {
    [] -> true
    [p, ...prest] -> match cargs {
      [] -> true
      [a, ...arest] ->
        if pcs_slot_is_diagonal(p, a) { pcs_diag_slots(prest, arest) }
        else { false }
    }
  }

# One slot is diagonal if its rebuild value is unboxed (copy-by-value),
# or it is exactly the binder of the slot pattern.
fn pcs_slot_is_diagonal(p: Pattern, a: Expr) : Bool =
  if pcs_ty_is_unboxed(a.ty) { true }
  else {
    match p.pkind {
      PBind(bn) -> match a.kind {
        EVar(an) -> an == bn
        _        -> false
      }
      _ -> false
    }
  }

fn pcs_try_reuse_record(body: Expr, expected_n: Int) : Expr {
  match body.kind {
    ERecordLit(_rec_name, fis) ->
      if list_length(fis) == expected_n {
        pcs_mk_call("__perceus_reuse_record",
                    [pcs_mk_scr(body.line, body.col), body],
                    body.line, body.col)
      } else { body }
    _ -> body
  }
}

# ---- pcs_collect_uses: scope-tracking EVar collection ----

#[doc("Accumulate a [Use] for every in-scope EVar read in an expression, tracking lambda-capture polarity. Pub because the tco pre-pass reuses the same use set for drop alignment.")]
pub fn pcs_collect_uses_expr(e: Expr, scope: [String], in_lam: Bool, acc: [Use]) : [Use] / Console =

  pcs_collect_uses_kind(e.kind, e.line, e.col, scope, in_lam, acc)

fn pcs_collect_uses_kind(k: ExprKind, line: Int, col: Int, scope: [String],
                         in_lam: Bool, acc: [Use]) : [Use] / Console {

  match k {
    EVar(nm) -> if list_has(scope, nm) { [U(nm, line, col, in_lam), ...acc] } else { acc }
    EStr(span, is_triple) -> pcs_collect_uses_in_interp(span, is_triple, scope, in_lam, acc)
    ECall(f, xs) -> pcs_collect_uses_in_exprs(xs, scope, in_lam,
                       pcs_collect_uses_expr(f, scope, in_lam, acc))
    EField(x, _) -> pcs_collect_uses_expr(x, scope, in_lam, acc)
    EIndex(x, i) -> pcs_collect_uses_expr(i, scope, in_lam,
                       pcs_collect_uses_expr(x, scope, in_lam, acc))
    EBinop(_, l, r) -> pcs_collect_uses_expr(r, scope, in_lam,
                          pcs_collect_uses_expr(l, scope, in_lam, acc))
    EUnop(_, x) -> pcs_collect_uses_expr(x, scope, in_lam, acc)
    EIf(c, t, opt_e) -> {
      let a1 = pcs_collect_uses_expr(c, scope, in_lam, acc)
      let a2 = pcs_collect_uses_expr(t, scope, in_lam, a1)
      match opt_e {
        None -> a2
        Some(e2) -> pcs_collect_uses_expr(e2, scope, in_lam, a2)
      }
    }
    EMatch(s, arms) -> pcs_collect_uses_in_arms(arms, scope, in_lam,
                          pcs_collect_uses_expr(s, scope, in_lam, acc))
    ELambda(ps, body) -> {
      let pn = map(ps, (p) => p.pname)
      pcs_collect_uses_expr(body, list_append(scope, pn), true, acc)
    }
    ERecordLit(_, fis) -> pcs_collect_uses_in_field_inits(fis, scope, in_lam, acc)
    EList(elems) -> pcs_collect_uses_in_list_elems(elems, scope, in_lam, acc)
    ERange(lo, hi, opt_by) -> {
      let a1 = pcs_collect_uses_expr(lo, scope, in_lam, acc)
      let a2 = pcs_collect_uses_expr(hi, scope, in_lam, a1)
      match opt_by {
        None -> a2
        Some(e2) -> pcs_collect_uses_expr(e2, scope, in_lam, a2)
      }
    }
    EBlock(stmts, opt_tail) -> pcs_collect_uses_in_block(stmts, opt_tail, scope, in_lam, acc)
    EPipe(l, r) -> pcs_collect_uses_expr(r, scope, in_lam,
                      pcs_collect_uses_expr(l, scope, in_lam, acc))
    EMapPipe(l, r) -> pcs_collect_uses_expr(r, scope, in_lam,
                         pcs_collect_uses_expr(l, scope, in_lam, acc))
    EFlatMapPipe(l, r) -> pcs_collect_uses_expr(r, scope, in_lam,
                            pcs_collect_uses_expr(l, scope, in_lam, acc))
    EFilterPipe(l, r) -> pcs_collect_uses_expr(r, scope, in_lam,
                           pcs_collect_uses_expr(l, scope, in_lam, acc))
    EHandle(body, _, _, init_opt, _, clauses, ret_opt) -> {
      let a1 = pcs_collect_uses_expr(body, scope, in_lam, acc)
      let a2 = match init_opt {
        None -> a1
        Some(e2) -> pcs_collect_uses_expr(e2, scope, in_lam, a1)
      }
      let a3 = pcs_collect_uses_in_clauses(clauses, scope, in_lam, a2)
      match ret_opt {
        None -> a3
        Some(hr) -> match hr {
          HR(pname, body2, _, _) ->
            pcs_collect_uses_expr(body2, [pname, ...scope], in_lam, a3)
        }
      }
    }
    EBang(inner) -> pcs_collect_uses_expr(inner, scope, in_lam, acc)
    _ -> acc
  }
}

fn pcs_collect_uses_in_exprs(es: [Expr], scope: [String], in_lam: Bool, acc: [Use]) : [Use] / Console {

  match es {
    [] -> acc
    [h, ...rest] -> pcs_collect_uses_in_exprs(rest, scope, in_lam,
                       pcs_collect_uses_expr(h, scope, in_lam, acc))
  }
}

fn pcs_collect_uses_in_arms(arms: [Arm], scope: [String], in_lam: Bool, acc: [Use]) : [Use] / Console {

  match arms {
    [] -> acc
    [a, ...rest] -> match a {
      Arm(pat, opt_g, body) -> {
        let scope1 = prc_pat_bindings(pat, scope)
        let a1 = match opt_g {
          None -> acc
          Some(g) -> pcs_collect_uses_expr(g, scope1, in_lam, acc)
        }
        let a2 = pcs_collect_uses_expr(body, scope1, in_lam, a1)
        pcs_collect_uses_in_arms(rest, scope, in_lam, a2)
      }
    }
  }
}

fn pcs_collect_uses_in_field_inits(fis: [FieldInit], scope: [String],
                                    in_lam: Bool, acc: [Use]) : [Use] / Console {

  match fis {
    [] -> acc
    [h, ...rest] -> match h {
      FI(_, e) -> pcs_collect_uses_in_field_inits(rest, scope, in_lam,
                     pcs_collect_uses_expr(e, scope, in_lam, acc))
    }
  }
}

fn pcs_collect_uses_in_list_elems(es: [ListElem], scope: [String],
                                   in_lam: Bool, acc: [Use]) : [Use] / Console {

  match es {
    [] -> acc
    [h, ...rest] -> {
      let inner = match h { ElPlain(e) -> e ElSpread(e) -> e }
      pcs_collect_uses_in_list_elems(rest, scope, in_lam,
        pcs_collect_uses_expr(inner, scope, in_lam, acc))
    }
  }
}

fn pcs_collect_uses_in_block(stmts: [Stmt], opt_tail: Option[Expr],
                              scope: [String], in_lam: Bool, acc: [Use]) : [Use] / Console {

  let r = pcs_block_loop(stmts, scope, in_lam, acc)
  match opt_tail {
    None -> r.acc
    Some(e) -> pcs_collect_uses_expr(e, r.scope, in_lam, r.acc)
  }
}

type PcsBlockState = { scope: [String], acc: [Use] }

fn pcs_block_loop(stmts: [Stmt], scope: [String], in_lam: Bool,
                   acc: [Use]) : PcsBlockState / Console {

  match stmts {
    [] -> PcsBlockState { scope: scope, acc: acc }
    [s, ...rest] -> {
      let nxt = match s {
        SLet(pat, _, rhs) -> {
          let acc1 = pcs_collect_uses_expr(rhs, scope, in_lam, acc)
          # Raw locals (Tier 2.5) are not tracked by Perceus —
          # `int64_t` lives on the C stack and dies at block exit,
          # there is no refcount to dup/drop. Skip them from scope.
          PcsBlockState { scope: prc_pat_bindings_skip_raw(pat, rhs, scope), acc: acc1 }
        }
        SVar(name, _, rhs, _, _) -> {
          let acc1 = pcs_collect_uses_expr(rhs, scope, in_lam, acc)
          PcsBlockState { scope: [name, ...scope], acc: acc1 }
        }
        SAssert(c, opt_m) -> {
          let a1 = pcs_collect_uses_expr(c, scope, in_lam, acc)
          let a2 = match opt_m {
            None -> a1
            Some(m) -> pcs_collect_uses_expr(m, scope, in_lam, a1)
          }
          PcsBlockState { scope: scope, acc: a2 }
        }
        SExprStmt(e) ->
          PcsBlockState { scope: scope, acc: pcs_collect_uses_expr(e, scope, in_lam, acc) }
        SIndexAssign(b, i, v, _, _) -> {
          let a1 = pcs_collect_uses_expr(b, scope, in_lam, acc)
          let a2 = pcs_collect_uses_expr(i, scope, in_lam, a1)
          let a3 = pcs_collect_uses_expr(v, scope, in_lam, a2)
          PcsBlockState { scope: scope, acc: a3 }
        }
        # m7e §25: SUse has no expression and binds nothing.
        SUse(_, _, _) -> PcsBlockState { scope: scope, acc: acc }
      }
      pcs_block_loop(rest, nxt.scope, in_lam, nxt.acc)
    }
  }
}

fn pcs_collect_uses_in_clauses(cs: [HClause], scope: [String], in_lam: Bool,
                                acc: [Use]) : [Use] / Console {

  match cs {
    [] -> acc
    [h, ...rest] -> match h {
      HC(_, params, body, _, _) -> {
        # Filter out the trailing `resume` param. `resume(v)` is
        # emitted via a special case in emit_call_expr (and
        # llvm_emit_call) and has no runtime KaiValue representation,
        # so wrapping `EVar("resume")` in `__perceus_dup` would route
        # the inner `resume` through `emit_ident_value`'s `kai_resume`
        # fallback, which is undeclared.
        let pn = pcs_filter_non_resume(map(params, (p) => p.pname), [])
        let scope1 = list_append(scope, ["state", "log", ...pn])
        pcs_collect_uses_in_clauses(rest, scope, in_lam,
          pcs_collect_uses_expr(body, scope1, in_lam, acc))
      }
    }
  }
}

fn pcs_filter_non_resume(names: [String], acc: [String]) : [String] {
  match names {
    [] -> list_reverse(acc)
    [h, ...rest] ->
      if h == "resume" { pcs_filter_non_resume(rest, acc) }
      else { pcs_filter_non_resume(rest, [h, ...acc]) }
  }
}

fn pcs_collect_uses_in_interp(span: String, is_triple: Bool, scope: [String],
                               in_lam: Bool, acc: [Use]) : [Use] / Console {

  let n = string_length(span)
  let body_start = if is_triple { 3 } else { 1 }
  let body_end = if is_triple { n - 3 } else { n - 1 }
  let parts = iscan_collect(span, body_end,
                            IScan { parts: [], lit_start: body_start, i: body_start })
  pcs_collect_uses_interp_parts(parts, scope, in_lam, acc)
}

fn pcs_collect_uses_interp_parts(parts: [IPart], scope: [String], in_lam: Bool,
                                   acc: [Use]) : [Use] / Console {

  match parts {
    [] -> acc
    [p, ...rest] -> match p {
      IpLit(_, _) -> pcs_collect_uses_interp_parts(rest, scope, in_lam, acc)
      IpExp(esrc) -> {
        let acc1 = match parse_interp_expr(esrc) {
          Some(e) -> pcs_collect_uses_expr(e, scope, in_lam, acc)
          None -> acc
        }
        pcs_collect_uses_interp_parts(rest, scope, in_lam, acc1)
      }
    }
  }
}

# ---- pcs_rewrite: wrap non-last in-scope EVar reads in __perceus_dup ----

fn pcs_rewrite_expr(e: Expr, scope: [String], uses: [Use], in_lam: Bool, skip_set: [String], force_set: [String], bmap: [BorrowEntry]) : Expr / Console =

  Expr { kind: pcs_rewrite_kind(e.kind, e.line, e.col, scope, uses, in_lam, skip_set, force_set, bmap),
         line: e.line, col: e.col, ty: e.ty, mode: e.mode }

fn pcs_rewrite_kind(k: ExprKind, line: Int, col: Int, scope: [String],
                    uses: [Use], in_lam: Bool, skip_set: [String], force_set: [String], bmap: [BorrowEntry]) : ExprKind / Console {

  match k {
    # The actual rewrite: wrap a non-last `EVar` use in `__perceus_dup`.
    EVar(nm) -> {
      if list_has(scope, nm) and pcs_is_non_last(nm, line, col, uses, in_lam, skip_set, force_set, bmap) {
        ECall(
          Expr { kind: EVar("__perceus_dup"), line: line, col: col,
                 ty: None, mode: MUnknown },
          [Expr { kind: EVar(nm), line: line, col: col,
                  ty: None, mode: MUnknown }]
        )
      } else { EVar(nm) }
    }
    # §4b — interpolated strings carry their interp expressions as raw
    # source spans; the structural visitor cannot reach the inner reads.
    # Re-tokenise + re-parse each `#{...}` body, run pcs_rewrite_expr on
    # the parsed Expr, then surgically rewrite the source by replacing
    # the wrapped ident tokens with `__perceus_dup(NAME)`. Result rounds
    # back through the parser at emit time as a normal ECall(__perceus_dup).
    EStr(span, is_triple) -> EStr(pcs_rewrite_estr_span(span, is_triple, scope, uses, in_lam, skip_set, force_set, bmap), is_triple)
    # Scope-aware kinds: ELambda extends scope with params and flips
    # in_lam; EBlock threads scope through SLet/SVar bindings; EMatch
    # delegates to pcs_rewrite_arms which adds pattern bindings to the
    # arm's scope; EHandle's HReturn binder shadows; clauses get the
    # state/log/op-param scope.
    ELambda(ps, body) -> {
      let pn = map(ps, (p) => p.pname)
      ELambda(ps, pcs_rewrite_expr(body, list_append(scope, pn), uses, true, skip_set, force_set, bmap))
    }
    EBlock(stmts, opt_tail) -> {
      let r = pcs_rewrite_block(stmts, scope, uses, in_lam, [], skip_set, force_set, bmap)
      let new_tail = match opt_tail {
        None -> None
        Some(e) -> Some(pcs_rewrite_expr(e, r.scope, uses, in_lam, skip_set, force_set, bmap))
      }
      # Issue #297 (partial) — block-scope exit drops for SLet PBind
      # bindings that took a `__perceus_dup` per non-last read above.
      # Symmetric with `pcs_collect_exit_drops` for fn params: an
      # SLet whose binder has ≥ 2 non-lam uses (or LUBlocked) carries
      # an unbalanced original ref at block exit; without an explicit
      # `__perceus_drop` the chunk leaks.
      #
      # Conservative scope: only emit a drop when the binding does
      # NOT appear in the block's tail expression. Tail-position
      # readings would force the drop AFTER the tail (via a
      # `__pcs_block_ret` wrap) which hides any self-tail-call from
      # `tcrec_rewrite_decls` and breaks TCO; the demo-side regression
      # was a stack overflow on `search` (#issue-294-style). Skipping
      # the drop in those cases preserves TCO and leaves the leak
      # intact — acceptable for this partial scope; the issue stays
      # open for the broader audit.
      #
      # LUAt-with-count==1 stays raw (lexically-last consumer
      # transfers the ref). LUUnused is handled by `block_unused_lets`
      # via inline decref.
      let exit_drops = pcs_collect_block_let_exit_drops(stmts, scope, uses,
                                                         opt_tail, [])
      EBlock(pcs_append_drops(r.stmts, exit_drops), new_tail)
    }
    EMatch(s, arms) -> EMatch(pcs_rewrite_expr(s, scope, uses, in_lam, skip_set, force_set, bmap),
                              pcs_rewrite_arms(arms, scope, uses, in_lam, skip_set, force_set, bmap))
    EHandle(body, eff, eff_tas, init_opt, alias, clauses, ret_opt) -> {
      let body1 = pcs_rewrite_expr(body, scope, uses, in_lam, skip_set, force_set, bmap)
      let init1 = match init_opt {
        None -> None
        Some(e2) -> Some(pcs_rewrite_expr(e2, scope, uses, in_lam, skip_set, force_set, bmap))
      }
      let cls1 = pcs_rewrite_clauses(clauses, scope, uses, in_lam, skip_set, force_set, bmap)
      let ret1 = match ret_opt {
        None -> None
        Some(hr) -> match hr {
          HR(pname, body2, hl, hc) ->
            Some(HR(pname,
                    pcs_rewrite_expr(body2, [pname, ...scope], uses, in_lam, skip_set, force_set, bmap),
                    hl, hc))
        }
      }
      EHandle(body1, eff, eff_tas, init1, alias, cls1, ret1)
    }
    # Remaining kinds inlined for issue #528 (stage 1 has no row
    # polymorphism on function-param types, so the HOF `map_expr_kind`
    # cannot accept an effectful callback). The structural recursion
    # is replicated here with direct calls to `pcs_rewrite_expr`.
    EInt(_)        -> k
    EReal(_)       -> k
    EBool(_)       -> k
    EChar(_)       -> k
    EUnit          -> k
    EUnder         -> k
    EPlaceholder   -> k
    EHole(_)       -> k
    ETodo(_)       -> k
    EVariantsOf(_, _) -> k
    EModCall(_, _) -> k
    EIntrinsic(name, args_) ->
      EIntrinsic(name, pcs_rewrite_expr_list(args_, scope, uses, in_lam, skip_set, force_set, bmap))
    ECall(callee, args_) ->
      ECall(pcs_rewrite_expr(callee, scope, uses, in_lam, skip_set, force_set, bmap),
            pcs_rewrite_expr_list(args_, scope, uses, in_lam, skip_set, force_set, bmap))
    EField(base, nm)     -> EField(pcs_rewrite_expr(base, scope, uses, in_lam, skip_set, force_set, bmap), nm)
    EIndex(a, b)         -> EIndex(pcs_rewrite_expr(a, scope, uses, in_lam, skip_set, force_set, bmap),
                                    pcs_rewrite_expr(b, scope, uses, in_lam, skip_set, force_set, bmap))
    EBinop(op, a, b)     -> EBinop(op, pcs_rewrite_expr(a, scope, uses, in_lam, skip_set, force_set, bmap),
                                        pcs_rewrite_expr(b, scope, uses, in_lam, skip_set, force_set, bmap))
    EUnop(op, x)         -> EUnop(op, pcs_rewrite_expr(x, scope, uses, in_lam, skip_set, force_set, bmap))
    EIf(c, t_, eo)       -> EIf(pcs_rewrite_expr(c, scope, uses, in_lam, skip_set, force_set, bmap),
                                  pcs_rewrite_expr(t_, scope, uses, in_lam, skip_set, force_set, bmap),
                                  pcs_rewrite_expr_opt(eo, scope, uses, in_lam, skip_set, force_set, bmap))
    ERecordLit(name, fs) -> ERecordLit(name, pcs_rewrite_fields_init(fs, scope, uses, in_lam, skip_set, force_set, bmap))
    EList(els)           -> EList(pcs_rewrite_list_elems(els, scope, uses, in_lam, skip_set, force_set, bmap))
    ERange(a, b, opt_step) -> ERange(pcs_rewrite_expr(a, scope, uses, in_lam, skip_set, force_set, bmap),
                                       pcs_rewrite_expr(b, scope, uses, in_lam, skip_set, force_set, bmap),
                                       pcs_rewrite_expr_opt(opt_step, scope, uses, in_lam, skip_set, force_set, bmap))
    EPipe(a, b)          -> EPipe(pcs_rewrite_expr(a, scope, uses, in_lam, skip_set, force_set, bmap),
                                    pcs_rewrite_expr(b, scope, uses, in_lam, skip_set, force_set, bmap))
    EMapPipe(a, b)       -> EMapPipe(pcs_rewrite_expr(a, scope, uses, in_lam, skip_set, force_set, bmap),
                                       pcs_rewrite_expr(b, scope, uses, in_lam, skip_set, force_set, bmap))
    EFlatMapPipe(a, b)   -> EFlatMapPipe(pcs_rewrite_expr(a, scope, uses, in_lam, skip_set, force_set, bmap),
                                            pcs_rewrite_expr(b, scope, uses, in_lam, skip_set, force_set, bmap))
    EFilterPipe(a, b)    -> EFilterPipe(pcs_rewrite_expr(a, scope, uses, in_lam, skip_set, force_set, bmap),
                                           pcs_rewrite_expr(b, scope, uses, in_lam, skip_set, force_set, bmap))
    ELitUnit(inner, u)   -> ELitUnit(pcs_rewrite_expr(inner, scope, uses, in_lam, skip_set, force_set, bmap), u)
    EBang(inner)         -> EBang(pcs_rewrite_expr(inner, scope, uses, in_lam, skip_set, force_set, bmap))
  }
}

fn pcs_rewrite_expr_opt(opt: Option[Expr], scope: [String], uses: [Use], in_lam: Bool, skip_set: [String], force_set: [String], bmap: [BorrowEntry]) : Option[Expr] / Console = match opt {
  None    -> None
  Some(x) -> Some(pcs_rewrite_expr(x, scope, uses, in_lam, skip_set, force_set, bmap))
}

fn pcs_rewrite_expr_list(es: [Expr], scope: [String], uses: [Use], in_lam: Bool, skip_set: [String], force_set: [String], bmap: [BorrowEntry]) : [Expr] / Console = match es {
  []           -> []
  [h, ...rest] -> [pcs_rewrite_expr(h, scope, uses, in_lam, skip_set, force_set, bmap),
                   ...pcs_rewrite_expr_list(rest, scope, uses, in_lam, skip_set, force_set, bmap)]
}

fn pcs_rewrite_fields_init(fs: [FieldInit], scope: [String], uses: [Use], in_lam: Bool, skip_set: [String], force_set: [String], bmap: [BorrowEntry]) : [FieldInit] / Console = match fs {
  []           -> []
  [h, ...rest] -> [pcs_rewrite_field_init(h, scope, uses, in_lam, skip_set, force_set, bmap),
                   ...pcs_rewrite_fields_init(rest, scope, uses, in_lam, skip_set, force_set, bmap)]
}

fn pcs_rewrite_field_init(fi: FieldInit, scope: [String], uses: [Use], in_lam: Bool, skip_set: [String], force_set: [String], bmap: [BorrowEntry]) : FieldInit / Console = match fi {
  FI(name, e) -> FI(name, pcs_rewrite_expr(e, scope, uses, in_lam, skip_set, force_set, bmap))
}

fn pcs_rewrite_list_elems(els: [ListElem], scope: [String], uses: [Use], in_lam: Bool, skip_set: [String], force_set: [String], bmap: [BorrowEntry]) : [ListElem] / Console = match els {
  []           -> []
  [h, ...rest] -> [pcs_rewrite_list_elem(h, scope, uses, in_lam, skip_set, force_set, bmap),
                   ...pcs_rewrite_list_elems(rest, scope, uses, in_lam, skip_set, force_set, bmap)]
}

fn pcs_rewrite_list_elem(el: ListElem, scope: [String], uses: [Use], in_lam: Bool, skip_set: [String], force_set: [String], bmap: [BorrowEntry]) : ListElem / Console = match el {
  ElPlain(e)  -> ElPlain(pcs_rewrite_expr(e, scope, uses, in_lam, skip_set, force_set, bmap))
  ElSpread(e) -> ElSpread(pcs_rewrite_expr(e, scope, uses, in_lam, skip_set, force_set, bmap))
}

fn pcs_rewrite_arms(arms: [Arm], scope: [String], uses: [Use], in_lam: Bool, skip_set: [String], force_set: [String], bmap: [BorrowEntry]) : [Arm] / Console {

  match arms {
    [] -> []
    [a, ...rest] -> match a {
      Arm(pat, opt_g, body) -> {
        let scope1 = prc_pat_bindings(pat, scope)
        # The arm-binder per-path move set is precomputed once in
        # perceus_decl_b (pcs_collect_trmc_arm_moves) — restricted to arms
        # that are self-recursive modulo-cons (the shape emit turns into a
        # TRMC step and disposes via the borrow-model). It is already unioned
        # into the incoming skip_set, so no per-arm recompute here.
        let body_skip = skip_set
        let g1 = match opt_g {
          None -> None
          Some(g) -> Some(pcs_rewrite_expr(g, scope1, uses, in_lam, skip_set, force_set, bmap))
        }
        let body1 = pcs_rewrite_expr(body, scope1, uses, in_lam, body_skip, force_set, bmap)
        [Arm(pat, g1, body1), ...pcs_rewrite_arms(rest, scope, uses, in_lam, skip_set, force_set, bmap)]
      }
    }
  }
}

type PcsRwBlock = { stmts: [Stmt], scope: [String] }

fn pcs_rewrite_block(stmts: [Stmt], scope: [String], uses: [Use], in_lam: Bool,
                     acc: [Stmt], skip_set: [String], force_set: [String], bmap: [BorrowEntry]) : PcsRwBlock / Console {

  match stmts {
    [] -> PcsRwBlock { stmts: list_reverse(acc), scope: scope }
    [s, ...rest] -> {
      let r = pcs_rewrite_stmt(s, scope, uses, in_lam, skip_set, force_set, bmap)
      pcs_rewrite_block(rest, r.scope, uses, in_lam, [r.stmt, ...acc], skip_set, force_set, bmap)
    }
  }
}

type PcsRwStmt = { stmt: Stmt, scope: [String] }

fn pcs_rewrite_stmt(s: Stmt, scope: [String], uses: [Use], in_lam: Bool, skip_set: [String], force_set: [String], bmap: [BorrowEntry]) : PcsRwStmt / Console {

  match s {
    SLet(pat, ty_opt, rhs) -> {
      let rhs1 = pcs_rewrite_expr(rhs, scope, uses, in_lam, skip_set, force_set, bmap)
      # See `pcs_collect_uses_in_block` SLet — raw locals stay
      # outside the Perceus scope so EVar reads of them are not
      # rewritten into `__perceus_dup` calls (which expect boxed
      # arguments).
      PcsRwStmt { stmt: SLet(pat, ty_opt, rhs1),
                  scope: prc_pat_bindings_skip_raw(pat, rhs, scope) }
    }
    SVar(name, ty_opt, rhs, ln, cl) -> {
      let rhs1 = pcs_rewrite_expr(rhs, scope, uses, in_lam, skip_set, force_set, bmap)
      PcsRwStmt { stmt: SVar(name, ty_opt, rhs1, ln, cl), scope: [name, ...scope] }
    }
    SAssert(c, opt_m) -> {
      let c1 = pcs_rewrite_expr(c, scope, uses, in_lam, skip_set, force_set, bmap)
      let m1 = match opt_m {
        None -> None
        Some(m) -> Some(pcs_rewrite_expr(m, scope, uses, in_lam, skip_set, force_set, bmap))
      }
      PcsRwStmt { stmt: SAssert(c1, m1), scope: scope }
    }
    SExprStmt(e) -> {
      let e1 = pcs_rewrite_expr(e, scope, uses, in_lam, skip_set, force_set, bmap)
      PcsRwStmt { stmt: SExprStmt(e1), scope: scope }
    }
    SIndexAssign(b, i, v, ln, cl) -> {
      let b1 = pcs_rewrite_expr(b, scope, uses, in_lam, skip_set, force_set, bmap)
      let i1 = pcs_rewrite_expr(i, scope, uses, in_lam, skip_set, force_set, bmap)
      let v1 = pcs_rewrite_expr(v, scope, uses, in_lam, skip_set, force_set, bmap)
      PcsRwStmt { stmt: SIndexAssign(b1, i1, v1, ln, cl), scope: scope }
    }
    # m7e §25: SUse has no expression and binds nothing.
    SUse(n, ln, cl) -> PcsRwStmt { stmt: SUse(n, ln, cl), scope: scope }
  }
}

fn pcs_rewrite_clauses(cs: [HClause], scope: [String], uses: [Use],
                        in_lam: Bool, skip_set: [String], force_set: [String], bmap: [BorrowEntry]) : [HClause] / Console {

  match cs {
    [] -> []
    [h, ...rest] -> match h {
      HC(op, params, body, ln, cl) -> {
        let pn = pcs_filter_non_resume(map(params, (p) => p.pname), [])
        let scope1 = list_append(scope, ["state", "log", ...pn])
        let body1 = pcs_rewrite_expr(body, scope1, uses, in_lam, skip_set, force_set, bmap)
        [HC(op, params, body1, ln, cl), ...pcs_rewrite_clauses(rest, scope, uses, in_lam, skip_set, force_set, bmap)]
      }
    }
  }
}

# Dup predicate (m5.x-flip Phase 1, "dup all ≥2 uses" variant). A name
# is wrapped in `__perceus_dup` whenever:
#   (a) it appears inside a closure body (`in_lam_here == true`); the
#       lambda may outlive the construction site, so every capture-side
#       read pays a dup and the closure's incref-on-construction holds
#       the original;
#   (b) it has any in-lam use elsewhere (LUBlocked) — the closure owns
#       the original, so non-lam reads must dup;
#   (c) it has ≥ 2 non-lam uses (LUAt with count ≥ 2) — every read pays
#       a dup. Under the loose runtime the original ref leaks (no exit
#       drop yet); the exit-drop pass that reclaims it landed together
#       with the runtime flip (m5.x atomic A+B+C+D, 2026-04-28).
# The previous "lexically-last → raw transfer" rule was unsafe because
# C does not specify the evaluation order of function-call arguments;
# the lexically-last raw read could fire before earlier dup-wrapped
# reads, freeing the local before the dups executed (lane experience
# 2026-04-26). The all-dup variant is order-independent: every read
# bumps rc before the primitive consumes it. The single-use case stays
# raw — no dup, no drop, transferring the binding's existing reference.
# LUUnused names cannot reach this predicate (they have no uses).
#
# Carve-out for the magic clause-body names `state` and `log`
# (`pcs_rewrite_clauses` injects them into the local scope so this
# predicate fires for them): both are *aliases* of `self->state` /
# `self->log`, not bindings the clause owns. The clause prologue
# (`clause_state_prologue`, `emit_clause_body`) emits
# `KaiValue *kai_state = self->state;` — a raw aliased pointer
# whose storage's lifetime is the *handler's*, not the clause's.
# Treating either name as "last use" and emitting a raw transfer
# hands the EvE slot's only outstanding ref to a downstream
# decref-aware sink (`kai_prelude_string_concat`,
# `kai_prelude_string_length`, `kai_prelude_string_join`); the sink
# decrefs it, the storage is freed, and the next op call into the
# same parameterised handler reads the freed slot. The fix forces
# every read of `state` / `log` to emit `__perceus_dup`, balancing
# the consumer's burn-off with one extra `kai_internal_dup` per
# read. Cost: one `kai_incref` per state/log read (well within the
# loose runtime's tolerance); this is the smallest correct change
# until the Perceus exit-pass closes the broader RC story (see
# `docs/lane-diagnostic-r10-r11.md` for the full analysis;
# broader Perceus follow-ups tracked under the `perceus` label
# (issues #77–#82). Closed R10 and R11 (issue #61).

fn pcs_is_non_last(nm: String, line: Int, col: Int, uses: [Use],
                   in_lam_here: Bool, skip_set: [String], force_set: [String], bmap: [BorrowEntry]) : Bool {
  # Issue #697 — `force_set` carries the names that must dup on EVERY
  # read, last-use included, because the body does not own them: it
  # borrows them. The sole populator is the `DCheck` branch, whose
  # `with`-clause params are owned by the generated check loop (it
  # drops them in iter_drops/tail_drops) and re-read by the shrinker
  # across iterations. Treating a check-param as last-use → raw
  # transfer hands the loop's only ref to a decref-aware consumer
  # (`kai_prelude_string_length`, `kai_op_ne_v`, …), which frees it;
  # the loop's own drop then double-frees. Same alias-not-owned shape
  # as `state`/`log` below — forced to always-dup for the same reason.
  if nm == "state" or nm == "log" or list_has(force_set, nm) { true }
  else if in_lam_here { true }
  else {
    match last_use_for(nm, uses) {
      LUAt(_, _, _) -> {
        # Issue #599 — branch-aware dup elimination. If the binding
        # appears in `skip_set` (built once from the body via
        # `pcs_max_paths_*`, populated only for top-level fn params
        # whose max non-lam reads across any execution path is <= 1),
        # skip the dup wrap entirely: the single read on the executed
        # path can transfer ownership raw. Otherwise fall back to the
        # conservative "≥ 2 non-lam uses" check.
        if list_has(skip_set, nm) { false }
        else { pcs_count_non_lam_uses(nm, uses, 0) >= 2 }
      }
      LUBlocked(_) -> true
      LUUnused(_) -> false
    }
  }
}

# Count the non-in-lambda uses of `nm` in `uses`. Lambda uses are
# excluded because they are accounted for by the LUBlocked branch and
# the closure-capture incref; non-lam reads at the fn body's own scope
# are what determine whether the binding is multi-use under the Phase 1
# rule.
#[doc("Count non-lambda reads of a name in a [Use] list (closure-capture increfs excluded). Pub: the tco pre-pass uses the multi-use predicate to decide goto-loop drop placement.")]
pub fn pcs_count_non_lam_uses(nm: String, uses: [Use], acc: Int) : Int {
  match uses {
    [] -> acc
    [h, ...rest] -> match h {
      U(uname, _, _, in_lam) -> {
        if uname == nm and not in_lam {
          pcs_count_non_lam_uses(nm, rest, acc + 1)
        } else {
          pcs_count_non_lam_uses(nm, rest, acc)
        }
      }
    }
  }
}

# Issue #599 — branch-aware max-path count for a single name in a
# function body. Returns the maximum number of non-lambda reads of
# `nm` on ANY linear execution path through the body, taking the max
# over `EMatch` arms and `EIf` branches (mutually-exclusive sites)
# and the sum over sequential composition (`EBlock`, `ECall` args,
# `EBinop`, …).
#
# When the result is <= 1 the binding is read at most once on every
# path, so the conservative-dup wrap can be skipped: the last (and
# only) read on the executed path can transfer ownership raw.
#
# Lambdas contribute 0 because closure captures are RC'd separately
# via `kai_closure`'s incref; this matches the in_lam-skip convention
# of `pcs_count_non_lam_uses` and keeps the rule sound for
# LUBlocked bindings.
#
# This function is read-only and pure (no Console effect needed) so
# it can be called from any rewrite site without threading a new
# parameter through every `pcs_rewrite_*` helper. It is invoked
# lazily from `pcs_is_non_last` only for top-level fn params; per-fn
# bodies are small enough that the O(body-size) walk per param is
# cheap compared with the rest of the perceus pass.
# Back-compat wrapper: the borrow-unaware count (used by the params path
# and other call sites that have no borrow map in scope).
fn pcs_max_paths_in_expr(nm: String, e: Expr) : Int =
  pcs_max_paths_b_expr(nm, e, [])

# Borrow-aware path count (Koka Parc: a use of `nm` that lands in a
# BORROWED parameter slot of the callee does NOT consume `nm`, so it must
# NOT count toward the dup decision — the canonical case is `is_red(l)`,
# which inspects `l` without taking ownership. Without this, `l`'s use in
# `is_red(l)` plus its use in `insert_loop(l)` sum to 2 on the same path →
# the binder fails the `mp <= 1` skip check → a spurious dup keeps the
# descent tree shared → the rb-tree spine leaks. `bmap` is the borrow map
# built by pcs_build_borrow_map. The arg-position filter mirrors
# pcs_strip_borrow_args exactly.)
fn pcs_max_paths_b_expr(nm: String, e: Expr, bmap: [BorrowEntry]) : Int =
  pcs_max_paths_b_kind(nm, e.kind, bmap)

fn pcs_max_paths_b_kind(nm: String, k: ExprKind, bmap: [BorrowEntry]) : Int = match k {
  EVar(uname)         -> if uname == nm { 1 } else { 0 }
  EStr(_, _)          -> 0
  ECall(f, xs)        -> {
    # Discount args that land in a borrowed slot of the callee: those uses
    # of `nm` are borrows, not consumers, and do not count.
    let key = pcs_callee_key(f)
    let positions = pcs_borrow_lookup(bmap, key)
    pcs_max_paths_b_expr(nm, f, bmap) + pcs_max_paths_b_args(nm, xs, positions, 0, bmap)
  }
  EIntrinsic(_, xs)   -> pcs_max_paths_b_seq(nm, xs, bmap)
  EField(x, _)        -> pcs_max_paths_b_expr(nm, x, bmap)
  EIndex(a, b)        -> pcs_max_paths_b_expr(nm, a, bmap) + pcs_max_paths_b_expr(nm, b, bmap)
  EBinop(_, a, b)     -> pcs_max_paths_b_expr(nm, a, bmap) + pcs_max_paths_b_expr(nm, b, bmap)
  EUnop(_, x)         -> pcs_max_paths_b_expr(nm, x, bmap)
  EIf(c, t, opt_e)    -> pcs_max_paths_b_expr(nm, c, bmap) +
                          pcs_max_paths_b_alt2(nm, t, opt_e, bmap)
  EMatch(s, arms)     -> pcs_max_paths_b_expr(nm, s, bmap) +
                          pcs_max_paths_b_arms(nm, arms, 0, bmap)
  ELambda(_, _)       -> 0
  ERecordLit(_, fis)  -> pcs_max_paths_b_field_inits(nm, fis, bmap)
  EList(els)          -> pcs_max_paths_b_list_elems(nm, els, bmap)
  ERange(a, b, opt)   -> pcs_max_paths_b_expr(nm, a, bmap) +
                          pcs_max_paths_b_expr(nm, b, bmap) +
                          pcs_max_paths_b_opt(nm, opt, bmap)
  EBlock(stmts, tail) -> pcs_max_paths_b_block(nm, stmts, tail, bmap)
  EPipe(a, b)         -> pcs_max_paths_b_expr(nm, a, bmap) + pcs_max_paths_b_expr(nm, b, bmap)
  EMapPipe(a, b)      -> pcs_max_paths_b_expr(nm, a, bmap) + pcs_max_paths_b_expr(nm, b, bmap)
  EFlatMapPipe(a, b)  -> pcs_max_paths_b_expr(nm, a, bmap) + pcs_max_paths_b_expr(nm, b, bmap)
  EFilterPipe(a, b)   -> pcs_max_paths_b_expr(nm, a, bmap) + pcs_max_paths_b_expr(nm, b, bmap)
  EHandle(body, _, _, init_opt, _, clauses, ret_opt) -> {
    let bp = pcs_max_paths_b_expr(nm, body, bmap)
    let ip = pcs_max_paths_b_opt(nm, init_opt, bmap)
    let cp = pcs_max_paths_b_clauses(nm, clauses, bmap)
    let rp = pcs_max_paths_b_ret_opt(nm, ret_opt, bmap)
    bp + ip + cp + rp
  }
  EBang(inner)        -> pcs_max_paths_b_expr(nm, inner, bmap)
  ELitUnit(inner, _)  -> pcs_max_paths_b_expr(nm, inner, bmap)
  _                   -> 0
}

# Walk args, charging 0 for any arg whose index is a borrowed slot of the
# callee (the use is a borrow, not a consume).
fn pcs_max_paths_b_args(nm: String, es: [Expr], positions: [Int], i: Int, bmap: [BorrowEntry]) : Int = match es {
  []           -> 0
  [h, ...rest] -> {
    let here = if pcs_has_int(positions, i) { 0 } else { pcs_max_paths_b_expr(nm, h, bmap) }
    here + pcs_max_paths_b_args(nm, rest, positions, i + 1, bmap)
  }
}

fn pcs_max_paths_b_seq(nm: String, es: [Expr], bmap: [BorrowEntry]) : Int = match es {
  []           -> 0
  [h, ...rest] -> pcs_max_paths_b_expr(nm, h, bmap) + pcs_max_paths_b_seq(nm, rest, bmap)
}

fn pcs_max_paths_b_alt2(nm: String, t: Expr, opt_e: Option[Expr], bmap: [BorrowEntry]) : Int = {
  let tp = pcs_max_paths_b_expr(nm, t, bmap)
  let ep = match opt_e { None -> 0 Some(e) -> pcs_max_paths_b_expr(nm, e, bmap) }
  if tp > ep { tp } else { ep }
}

fn pcs_max_paths_b_arms(nm: String, arms: [Arm], best: Int, bmap: [BorrowEntry]) : Int = match arms {
  [] -> best
  [a, ...rest] -> match a {
    Arm(_, opt_g, body) -> {
      let gp = match opt_g { None -> 0 Some(g) -> pcs_max_paths_b_expr(nm, g, bmap) }
      let bp = pcs_max_paths_b_expr(nm, body, bmap)
      let armp = gp + bp
      let nb = if armp > best { armp } else { best }
      pcs_max_paths_b_arms(nm, rest, nb, bmap)
    }
  }
}

fn pcs_max_paths_b_field_inits(nm: String, fis: [FieldInit], bmap: [BorrowEntry]) : Int = match fis {
  []           -> 0
  [h, ...rest] -> match h {
    FI(_, e) -> pcs_max_paths_b_expr(nm, e, bmap) + pcs_max_paths_b_field_inits(nm, rest, bmap)
  }
}

fn pcs_max_paths_b_list_elems(nm: String, els: [ListElem], bmap: [BorrowEntry]) : Int = match els {
  []           -> 0
  [h, ...rest] -> {
    let inner = match h { ElPlain(e) -> e ElSpread(e) -> e }
    pcs_max_paths_b_expr(nm, inner, bmap) + pcs_max_paths_b_list_elems(nm, rest, bmap)
  }
}

fn pcs_max_paths_b_opt(nm: String, opt: Option[Expr], bmap: [BorrowEntry]) : Int = match opt {
  None    -> 0
  Some(e) -> pcs_max_paths_b_expr(nm, e, bmap)
}

fn pcs_max_paths_b_block(nm: String, stmts: [Stmt], tail: Option[Expr], bmap: [BorrowEntry]) : Int =
  pcs_max_paths_b_stmts(nm, stmts, bmap) + pcs_max_paths_b_opt(nm, tail, bmap)

fn pcs_max_paths_b_stmts(nm: String, stmts: [Stmt], bmap: [BorrowEntry]) : Int = match stmts {
  []           -> 0
  [h, ...rest] -> pcs_max_paths_b_stmt(nm, h, bmap) + pcs_max_paths_b_stmts(nm, rest, bmap)
}

fn pcs_max_paths_b_stmt(nm: String, s: Stmt, bmap: [BorrowEntry]) : Int = match s {
  SLet(_, _, e)                  -> pcs_max_paths_b_expr(nm, e, bmap)
  SVar(_, _, e, _, _)            -> pcs_max_paths_b_expr(nm, e, bmap)
  SAssert(e, opt_m)              -> pcs_max_paths_b_expr(nm, e, bmap) +
                                     pcs_max_paths_b_opt(nm, opt_m, bmap)
  SExprStmt(e)                   -> pcs_max_paths_b_expr(nm, e, bmap)
  SIndexAssign(a, b, c, _, _)    -> pcs_max_paths_b_expr(nm, a, bmap) +
                                     pcs_max_paths_b_expr(nm, b, bmap) +
                                     pcs_max_paths_b_expr(nm, c, bmap)
  SUse(_, _, _)                  -> 0
}

fn pcs_max_paths_b_clauses(nm: String, cs: [HClause], bmap: [BorrowEntry]) : Int = match cs {
  []           -> 0
  [h, ...rest] -> match h {
    HC(_, _, body, _, _) ->
      pcs_max_paths_b_expr(nm, body, bmap) + pcs_max_paths_b_clauses(nm, rest, bmap)
  }
}

fn pcs_max_paths_b_ret_opt(nm: String, opt: Option[HReturn], bmap: [BorrowEntry]) : Int = match opt {
  None    -> 0
  Some(hr) -> match hr { HR(_, body, _, _) -> pcs_max_paths_b_expr(nm, body, bmap) }
}

fn pcs_max_paths_in_kind_UNUSED(nm: String, e: Expr) : Int =
  pcs_max_paths_in_kind(nm, e.kind)

fn pcs_max_paths_in_kind(nm: String, k: ExprKind) : Int = match k {
  EVar(uname)         -> if uname == nm { 1 } else { 0 }
  EStr(_, _)          -> 0   # interpolated reads handled by §4b path;
                              # branch-aware analysis applies to non-
                              # interpolation reads only.
  ECall(f, xs)        -> pcs_max_paths_in_expr(nm, f) + pcs_max_paths_seq(nm, xs)
  EIntrinsic(_, xs)   -> pcs_max_paths_seq(nm, xs)
  EField(x, _)        -> pcs_max_paths_in_expr(nm, x)
  EIndex(a, b)        -> pcs_max_paths_in_expr(nm, a) + pcs_max_paths_in_expr(nm, b)
  EBinop(_, a, b)     -> pcs_max_paths_in_expr(nm, a) + pcs_max_paths_in_expr(nm, b)
  EUnop(_, x)         -> pcs_max_paths_in_expr(nm, x)
  EIf(c, t, opt_e)    -> pcs_max_paths_in_expr(nm, c) +
                          pcs_max_paths_alt2(nm, t, opt_e)
  EMatch(s, arms)     -> pcs_max_paths_in_expr(nm, s) +
                          pcs_max_paths_in_arms(nm, arms, 0)
  ELambda(_, _)       -> 0
  ERecordLit(_, fis)  -> pcs_max_paths_in_field_inits(nm, fis)
  EList(els)          -> pcs_max_paths_in_list_elems(nm, els)
  ERange(a, b, opt)   -> pcs_max_paths_in_expr(nm, a) +
                          pcs_max_paths_in_expr(nm, b) +
                          pcs_max_paths_opt(nm, opt)
  EBlock(stmts, tail) -> pcs_max_paths_in_block(nm, stmts, tail)
  EPipe(a, b)         -> pcs_max_paths_in_expr(nm, a) + pcs_max_paths_in_expr(nm, b)
  EMapPipe(a, b)      -> pcs_max_paths_in_expr(nm, a) + pcs_max_paths_in_expr(nm, b)
  EFlatMapPipe(a, b)  -> pcs_max_paths_in_expr(nm, a) + pcs_max_paths_in_expr(nm, b)
  EFilterPipe(a, b)   -> pcs_max_paths_in_expr(nm, a) + pcs_max_paths_in_expr(nm, b)
  EHandle(body, _, _, init_opt, _, clauses, ret_opt) -> {
    # Handler clauses are alternatives — only one clause fires per op
    # invocation — but a single body can fire multiple ops, so the
    # body-vs-clauses relationship is sum, not alt. Conservative
    # fallback: treat as sum.
    let bp = pcs_max_paths_in_expr(nm, body)
    let ip = pcs_max_paths_opt(nm, init_opt)
    let cp = pcs_max_paths_in_clauses(nm, clauses)
    let rp = pcs_max_paths_in_ret_opt(nm, ret_opt)
    bp + ip + cp + rp
  }
  EBang(inner)        -> pcs_max_paths_in_expr(nm, inner)
  ELitUnit(inner, _)  -> pcs_max_paths_in_expr(nm, inner)
  _                   -> 0
}

fn pcs_max_paths_seq(nm: String, es: [Expr]) : Int = match es {
  []           -> 0
  [h, ...rest] -> pcs_max_paths_in_expr(nm, h) + pcs_max_paths_seq(nm, rest)
}

fn pcs_max_paths_alt2(nm: String, t: Expr, opt_e: Option[Expr]) : Int = {
  let tp = pcs_max_paths_in_expr(nm, t)
  let ep = match opt_e {
    None    -> 0
    Some(e) -> pcs_max_paths_in_expr(nm, e)
  }
  if tp > ep { tp } else { ep }
}

fn pcs_max_paths_in_arms(nm: String, arms: [Arm], best: Int) : Int = match arms {
  [] -> best
  [a, ...rest] -> match a {
    Arm(pat, opt_g, body) -> {
      let gp = match opt_g {
        None    -> 0
        Some(g) -> pcs_max_paths_in_expr(nm, g)
      }
      let bp = pcs_max_paths_in_expr(nm, body)
      let armp = gp + bp
      let nb = if armp > best { armp } else { best }
      pcs_max_paths_in_arms(nm, rest, nb)
    }
  }
}

fn pcs_max_paths_in_field_inits(nm: String, fis: [FieldInit]) : Int = match fis {
  []           -> 0
  [h, ...rest] -> match h {
    FI(_, e) -> pcs_max_paths_in_expr(nm, e) + pcs_max_paths_in_field_inits(nm, rest)
  }
}

fn pcs_max_paths_in_list_elems(nm: String, els: [ListElem]) : Int = match els {
  []           -> 0
  [h, ...rest] -> {
    let inner = match h { ElPlain(e) -> e ElSpread(e) -> e }
    pcs_max_paths_in_expr(nm, inner) + pcs_max_paths_in_list_elems(nm, rest)
  }
}

fn pcs_max_paths_opt(nm: String, opt: Option[Expr]) : Int = match opt {
  None    -> 0
  Some(e) -> pcs_max_paths_in_expr(nm, e)
}

fn pcs_max_paths_in_block(nm: String, stmts: [Stmt], tail: Option[Expr]) : Int =
  pcs_max_paths_in_stmts(nm, stmts) + pcs_max_paths_opt(nm, tail)

fn pcs_max_paths_in_stmts(nm: String, stmts: [Stmt]) : Int = match stmts {
  []           -> 0
  [h, ...rest] -> pcs_max_paths_in_stmt(nm, h) + pcs_max_paths_in_stmts(nm, rest)
}

fn pcs_max_paths_in_stmt(nm: String, s: Stmt) : Int = match s {
  SLet(_, _, e)                  -> pcs_max_paths_in_expr(nm, e)
  SVar(_, _, e, _, _)            -> pcs_max_paths_in_expr(nm, e)
  SAssert(e, opt_m)              -> pcs_max_paths_in_expr(nm, e) +
                                     pcs_max_paths_opt(nm, opt_m)
  SExprStmt(e)                   -> pcs_max_paths_in_expr(nm, e)
  SIndexAssign(a, b, c, _, _)    -> pcs_max_paths_in_expr(nm, a) +
                                     pcs_max_paths_in_expr(nm, b) +
                                     pcs_max_paths_in_expr(nm, c)
  SUse(_, _, _)                  -> 0
}

fn pcs_max_paths_in_clauses(nm: String, cs: [HClause]) : Int = match cs {
  []           -> 0
  [h, ...rest] -> match h {
    HC(_, _, body, _, _) ->
      pcs_max_paths_in_expr(nm, body) + pcs_max_paths_in_clauses(nm, rest)
  }
}

fn pcs_max_paths_in_ret_opt(nm: String, opt: Option[HReturn]) : Int = match opt {
  None    -> 0
  Some(hr) -> match hr {
    HR(_, body, _, _) -> pcs_max_paths_in_expr(nm, body)
  }
}

# Compute the branch-aware skip-set for a fn body: every top-level
# fn param whose reads can safely transfer ownership raw on every
# execution path. The three conditions for safety:
#
#   1. `pcs_max_paths_in_expr <= 1` — the binding is read at most
#      once on any single execution path (no path doubles a wrap).
#   2. `pcs_consumed_on_every_path` — every path through the body
#      actually consumes the binding (no exit-drop needed; the
#      single read on the executed path transfers ownership).
#   3. `pcs_all_consumers_linear` — every consumer of the binding
#      is a linear consumer: a call to a user-defined fn (which
#      pcs_pass made linear by construction) or a variant/record
#      that owns the slot. Non-linear consumers (intrinsics,
#      capability ops, raw field access on a borrowed record,
#      list-spread tails `[..., ...nm]`) internally incref their
#      arg, and a raw transfer would leak or double-free.
#[doc("Params whose transfer must be skipped because some branch reads them through an incref-ing op (capability ops, borrowed field access, spread tails). Pub: tco consults it.")]
pub fn pcs_branch_aware_skip_params(pnames: [String], body: Expr) : [String] = match pnames {
  []           -> []
  [h, ...rest] -> {
    let mp = pcs_max_paths_in_expr(h, body)
    let cv = pcs_consumed_on_every_path(h, body)
    let ln = pcs_all_consumers_linear(h, body)
    let rest_skip = pcs_branch_aware_skip_params(rest, body)
    if mp <= 1 and cv and ln { [h, ...rest_skip] } else { rest_skip }
  }
}

# Issue #599 extended to LOCALS (arm-level pattern binders). A match-arm
# binder `l` whose body reads it at most once on any path (branch-aware
# max-path <= 1), consumes it on every path, and only in linear positions
# can transfer ownership RAW — exactly the params rule, scoped to the arm
# body. This is the half that makes reuse fire in insert_loop: without it,
# `l`/`r` fall to the flat `count_non_lam_uses >= 2` fallback (they appear
# in several mutually-exclusive if-branches, so the flat count is >= 2) and
# get a redundant dup that keeps the descent tree shared (rc >= 2 -> never
# unique -> reuse inert). The three conditions operate on the arm `body`
# expr, so they are naturally scoped to the binder's lifetime (a pattern
# binder is local to its arm). Same soundness contract as the params path.
# Pre-TRMC mirror of emit_c's `arm_all_tails_consume_token`: every tail leaf
# of the arm body is a CONSTRUCTOR rebuild (ECall to an uppercase ctor name,
# bare EVar or resolved EModCall). That is the arm shape whose every branch
# rebuilds the donated cell — so moving the arm's binders is sound (each
# branch consumes them building the node). An arm with a tail call to an
# EXTERNAL fn (balance_left, …) fails: that branch would drop `_scr` (arm-top)
# and read moved children → the OOM/panic. Keeping this aligned with the
# emit predicate is what makes the perceus-move / emit-dup pair balance.
fn pcs_arm_all_tails_ctor(e: Expr) : Bool = pcs_arm_tail_ctor_kind(e.kind)

fn pcs_arm_tail_ctor_kind(k: ExprKind) : Bool = match k {
  EIf(_, t, opt_e) ->
    pcs_arm_all_tails_ctor(t) and
    (match opt_e { None -> false Some(e2) -> pcs_arm_all_tails_ctor(e2) })
  EBlock(_, opt_tail) -> match opt_tail { None -> false Some(e) -> pcs_arm_all_tails_ctor(e) }
  EMatch(_, arms) -> pcs_arm_tail_ctor_arms(arms)
  ECall(f, _) -> match f.kind {
    EVar(c)        -> pcs_name_is_ctor(c)
    EModCall(_, c) -> pcs_name_is_ctor(c)
    _              -> false
  }
  _ -> false
}

fn pcs_arm_tail_ctor_arms(arms: [Arm]) : Bool = match arms {
  []           -> true
  [a, ...rest] -> match a { Arm(_, _, b) -> pcs_arm_all_tails_ctor(b) and pcs_arm_tail_ctor_arms(rest) }
}

#[doc("Arm-level pattern binders that pass the branch-aware safety check over the arm body (max-path<=1, consumed-on-every-path, all-consumers-linear). Pub: emit_c's arm-top reuse consults it so the shared-branch dup set matches exactly the binders perceus moves — the two must agree or RC double-counts.")]
pub fn pcs_branch_aware_skip_locals(binders: [String], body: Expr) : [String] =
  pcs_branch_aware_skip_locals_b(binders, body, [], [])

# Borrow-aware variant: the max-path count discounts uses of a binder that
# land in a borrowed callee slot (is_red(l) does not consume l). This is
# what lets the rb-tree Black arm's l/r pass `mp <= 1` — without it, the
# is_red(l) + insert_loop(l) uses sum to 2 on the descent path. `bmap` is
# the global borrow map; pass [] for the borrow-unaware behaviour.
pub fn pcs_branch_aware_skip_locals_b(binders: [String], body: Expr, bmap: [BorrowEntry], cmap: [ConsumeEntry]) : [String] = match binders {
  []           -> []
  [h, ...rest] -> {
    let mp = pcs_max_paths_b_expr(h, body, bmap)
    let cv = pcs_consumed_on_every_path(h, body)
    let ln = pcs_all_consumers_linear(h, body)
    # Consume-aware (Koka Borrowed dual): every arg-slot use of h must land in
    # a CONSUMING callee slot. A use in a NON-consuming slot (field-read callee
    # — regexp nb_add_transition(b)) means the callee borrows h; moving h there
    # frees it under the callee → UAF. ctor slots / match scrutinees / returns
    # consume by construction.
    let cons_ok = pcs_uses_only_consuming_slots(h, body, cmap)
    let rest_skip = pcs_branch_aware_skip_locals_b(rest, body, bmap, cmap)
    if mp <= 1 and cv and ln and cons_ok { [h, ...rest_skip] } else { rest_skip }
  }
}

# Walk a fn body, collecting EVERY guard-less match arm's pattern binders
# that pass the borrow-aware branch-aware safety check over THAT arm's body.
# Precomputed once in perceus_decl_b (where the borrow map is in scope) and
# unioned into the global skip-set, so pcs_rewrite_arms need not thread the
# borrow map through all 59 rewrite call sites. A binder is added only when
# it passes the check in its own arm body (max-path<=1 borrow-aware,
# consumed-on-every-path, all-consumers-linear); the three conditions ARE
# Koka's per-branch ownership reconcile and are sound on their own.
pub fn pcs_collect_arm_skip_binders(self_name: String, tl: Bool, e: Expr, bmap: [BorrowEntry], cmap: [ConsumeEntry]) : [String] =
  pcs_collect_arm_skip_kind(self_name, tl, e.kind, bmap, cmap)

fn pcs_collect_arm_skip_kind(self_name: String, tl: Bool, k: ExprKind, bmap: [BorrowEntry], cmap: [ConsumeEntry]) : [String] = match k {
  EMatch(s, arms) ->
    # The scrutinee descends as NON-toplevel (its own matches are nested).
    # The arms keep `tl`: arms of the fn-body's first match are toplevel; arms
    # reached after descending through a nested match are not.
    pcs_list_union(pcs_collect_arm_skip_binders(self_name, false, s, bmap, cmap),
                   pcs_collect_arm_skip_arms(self_name, tl, arms, bmap, cmap))
  ECall(f, xs) ->
    pcs_list_union(pcs_collect_arm_skip_binders(self_name, tl, f, bmap, cmap),
                   pcs_collect_arm_skip_seq(self_name, tl, xs, bmap, cmap))
  EIf(c, t, opt_e) ->
    pcs_list_union(pcs_collect_arm_skip_binders(self_name, tl, c, bmap, cmap),
      pcs_list_union(pcs_collect_arm_skip_binders(self_name, tl, t, bmap, cmap),
                     match opt_e { None -> [] Some(e2) -> pcs_collect_arm_skip_binders(self_name, tl, e2, bmap, cmap) }))
  EBlock(stmts, tail) ->
    pcs_list_union(pcs_collect_arm_skip_stmts(self_name, tl, stmts, bmap, cmap),
                   match tail { None -> [] Some(e) -> pcs_collect_arm_skip_binders(self_name, tl, e, bmap, cmap) })
  EBinop(_, a, b)    -> pcs_list_union(pcs_collect_arm_skip_binders(self_name, tl, a, bmap, cmap), pcs_collect_arm_skip_binders(self_name, tl, b, bmap, cmap))
  EUnop(_, x)        -> pcs_collect_arm_skip_binders(self_name, tl, x, bmap, cmap)
  EField(x, _)       -> pcs_collect_arm_skip_binders(self_name, tl, x, bmap, cmap)
  EIndex(a, b)       -> pcs_list_union(pcs_collect_arm_skip_binders(self_name, tl, a, bmap, cmap), pcs_collect_arm_skip_binders(self_name, tl, b, bmap, cmap))
  ELambda(_, body)   -> pcs_collect_arm_skip_binders(self_name, tl, body, bmap, cmap)
  ERecordLit(_, fis) -> pcs_collect_arm_skip_field_inits(self_name, tl, fis, bmap, cmap)
  EList(els)         -> pcs_collect_arm_skip_list_elems(self_name, tl, els, bmap, cmap)
  ERange(a, b, opt)  -> pcs_list_union(pcs_collect_arm_skip_binders(self_name, tl, a, bmap, cmap),
                          pcs_list_union(pcs_collect_arm_skip_binders(self_name, tl, b, bmap, cmap),
                            match opt { None -> [] Some(e) -> pcs_collect_arm_skip_binders(self_name, tl, e, bmap, cmap) }))
  EPipe(a, b)        -> pcs_list_union(pcs_collect_arm_skip_binders(self_name, tl, a, bmap, cmap), pcs_collect_arm_skip_binders(self_name, tl, b, bmap, cmap))
  EMapPipe(a, b)     -> pcs_list_union(pcs_collect_arm_skip_binders(self_name, tl, a, bmap, cmap), pcs_collect_arm_skip_binders(self_name, tl, b, bmap, cmap))
  EFlatMapPipe(a, b) -> pcs_list_union(pcs_collect_arm_skip_binders(self_name, tl, a, bmap, cmap), pcs_collect_arm_skip_binders(self_name, tl, b, bmap, cmap))
  EFilterPipe(a, b)  -> pcs_list_union(pcs_collect_arm_skip_binders(self_name, tl, a, bmap, cmap), pcs_collect_arm_skip_binders(self_name, tl, b, bmap, cmap))
  EBang(x)           -> pcs_collect_arm_skip_binders(self_name, tl, x, bmap, cmap)
  ELitUnit(x, _)     -> pcs_collect_arm_skip_binders(self_name, tl, x, bmap, cmap)
  _ -> []
}

fn pcs_collect_arm_skip_seq(self_name: String, tl: Bool, es: [Expr], bmap: [BorrowEntry], cmap: [ConsumeEntry]) : [String] = match es {
  []           -> []
  [h, ...rest] -> pcs_list_union(pcs_collect_arm_skip_binders(self_name, tl, h, bmap, cmap),
                                 pcs_collect_arm_skip_seq(self_name, tl, rest, bmap, cmap))
}

fn pcs_collect_arm_skip_stmts(self_name: String, tl: Bool, stmts: [Stmt], bmap: [BorrowEntry], cmap: [ConsumeEntry]) : [String] = match stmts {
  []           -> []
  [s, ...rest] -> {
    let here = match s {
      SLet(_, _, e)               -> pcs_collect_arm_skip_binders(self_name, tl, e, bmap, cmap)
      SVar(_, _, e, _, _)         -> pcs_collect_arm_skip_binders(self_name, tl, e, bmap, cmap)
      SExprStmt(e)                -> pcs_collect_arm_skip_binders(self_name, tl, e, bmap, cmap)
      SAssert(e, opt_m)           -> pcs_list_union(pcs_collect_arm_skip_binders(self_name, tl, e, bmap, cmap),
                                       match opt_m { None -> [] Some(m) -> pcs_collect_arm_skip_binders(self_name, tl, m, bmap, cmap) })
      SIndexAssign(a, b, c, _, _) -> pcs_list_union(pcs_collect_arm_skip_binders(self_name, tl, a, bmap, cmap),
                                       pcs_list_union(pcs_collect_arm_skip_binders(self_name, tl, b, bmap, cmap),
                                                      pcs_collect_arm_skip_binders(self_name, tl, c, bmap, cmap)))
      _                           -> []
    }
    pcs_list_union(here, pcs_collect_arm_skip_stmts(self_name, tl, rest, bmap, cmap))
  }
}

fn pcs_collect_arm_skip_field_inits(self_name: String, tl: Bool, fis: [FieldInit], bmap: [BorrowEntry], cmap: [ConsumeEntry]) : [String] = match fis {
  []           -> []
  [h, ...rest] -> match h {
    FI(_, e) -> pcs_list_union(pcs_collect_arm_skip_binders(self_name, tl, e, bmap, cmap),
                               pcs_collect_arm_skip_field_inits(self_name, tl, rest, bmap, cmap))
  }
}

fn pcs_collect_arm_skip_list_elems(self_name: String, tl: Bool, els: [ListElem], bmap: [BorrowEntry], cmap: [ConsumeEntry]) : [String] = match els {
  []           -> []
  [h, ...rest] -> {
    let inner = match h { ElPlain(e) -> e ElSpread(e) -> e }
    pcs_list_union(pcs_collect_arm_skip_binders(self_name, tl, inner, bmap, cmap),
                   pcs_collect_arm_skip_list_elems(self_name, tl, rest, bmap, cmap))
  }
}

fn pcs_collect_arm_skip_arms(self_name: String, tl: Bool, arms: [Arm], bmap: [BorrowEntry], cmap: [ConsumeEntry]) : [String] = match arms {
  []           -> []
  [a, ...rest] -> match a {
    Arm(pat, opt_g, body) -> {
      # Descend into the body for NESTED matches — those are never toplevel.
      let nested = pcs_collect_arm_skip_binders(self_name, false, body, bmap, cmap)
      # Move this arm's binders when emit disposes the scrutinee via a reuse-
      # model that does NOT cascade into the moved child:
      #  (1) self-rec modulo-cons (`self(...)` in a ctor slot) → TRMC arm-top
      #      reuse (insert_loop). Sound at ANY depth: the arm-top steals the
      #      matched cell, which IS the cell the TRMC step rebuilds.
      #  (2) cons-overwrite — reconstructs the SAME ctor it matched in tail
      #      position → emit's try_reuse_variant_arm overwrites _scr in place.
      #      Sound ONLY at the fn-body's TOP-LEVEL match (`tl`): there the
      #      reused cell IS the cell the result replaces. In a NESTED match over
      #      a binder (gap3's `match l { Node(ll,..) -> match ll { ... } }`) the
      #      reused cell is the INNER scrutinee (ll) but the result replaces the
      #      OUTER node (l) — the in-place overwrite builds a self-referential
      #      cycle (gap3 stack-overflows in `size`). Hence the `tl` gate.
      let reuse_shape = pcs_arm_self_modulo_cons(self_name, body) or
                        (tl and pcs_arm_cons_overwrite(pat, body))
      let here = match opt_g {
        None    ->
          if reuse_shape {
            pcs_branch_aware_skip_locals_b(prc_pat_binders(pat, []), body, bmap, cmap)
          } else { [] }
        Some(_) -> []
      }
      pcs_list_union(pcs_list_union(here, nested),
                     pcs_collect_arm_skip_arms(self_name, tl, rest, bmap, cmap))
    }
  }
}

# True iff `body` contains a self-recursive call `self_name(...)` sitting in a
# constructor-rebuild slot OR a tail-recursive position — i.e. the Okasaki
# modulo-cons shape (`RBNode(Red, self(l,...), ...)`) that tcrec lowers to a
# TRMC step. This is the arm shape for which emit applies the borrow-model
# shell dispose; only there is moving a deconstructed child sound.
fn pcs_arm_self_modulo_cons(self_name: String, e: Expr) : Bool =
  pcs_smc_kind(self_name, e.kind)

# True iff the arm matched `PVariant(C, ...)` and reconstructs the SAME ctor C
# in every tail position — the cons-overwrite reuse shape emit's
# try_reuse_variant_arm fires on (overwrites _scr in place via kai_check_unique,
# which does NOT cascade into moved children). This is balance_left/right: it
# matches `RBNode(...)` and rebuilds `RBNode(...)` in each tail. Moving the
# arm's binders is sound because emit reuses the matched cell rather than
# decref-ing it recursively. A tail that rebuilds a DIFFERENT ctor (or calls a
# non-reuse fn) fails, keeping regexp's NB_Frag arms out.
fn pcs_arm_cons_overwrite(pat: Pattern, body: Expr) : Bool = match pat.pkind {
  PVariant(cname, _) -> pcs_arm_tails_rebuild_ctor(cname, body)
  _                  -> false
}

# Every tail leaf of `body` is an ECall to ctor `cname` (bare or resolved).
fn pcs_arm_tails_rebuild_ctor(cname: String, e: Expr) : Bool = pcs_tails_ctor_kind(cname, e.kind)

fn pcs_tails_ctor_kind(cname: String, k: ExprKind) : Bool = match k {
  EIf(_, t, opt_e) ->
    pcs_arm_tails_rebuild_ctor(cname, t) and
    (match opt_e { None -> false Some(e2) -> pcs_arm_tails_rebuild_ctor(cname, e2) })
  EBlock(_, opt_tail) -> match opt_tail { None -> false Some(e) -> pcs_arm_tails_rebuild_ctor(cname, e) }
  EMatch(_, arms) -> pcs_tails_ctor_arms(cname, arms)
  ECall(f, xs) -> match f.kind {
    # Rebuild of the same ctor AND every slot is "simple" — a bare binder, a
    # scalar, or a NESTED ctor of simples — NEVER a fn call that derives a slot
    # from a binder (`desugar_interp_expr(c)`). emit's try_reuse_variant_arm
    # overwrites _scr's slots IN PLACE; if a new slot is computed FROM an old
    # slot (the desugar shape), the overwrite corrupts the binder before the
    # call reads it → a self-referential cycle (the desugar_interp self-host
    # infinite recursion). balance's slots are direct ctors of binders, so they
    # are safe. Restricting to simple slots keeps cons-overwrite to the
    # balance-shaped arms only.
    EVar(c)        -> c == cname and pcs_all_slots_simple(xs)
    EModCall(_, c) -> c == cname and pcs_all_slots_simple(xs)
    _              -> false
  }
  _ -> false
}

# A slot is "simple" if writing it in place cannot read a binder that an
# earlier in-place write already clobbered: bare EVar, scalar literal, dup of a
# binder, or a ctor whose own slots are all simple. A non-ctor fn call is NOT
# simple (it may read a binder that derives the donor's slots).
fn pcs_all_slots_simple(xs: [Expr]) : Bool = match xs {
  []           -> true
  [h, ...rest] -> pcs_slot_simple(h) and pcs_all_slots_simple(rest)
}

# A slot of a cons-overwrite rebuild is "simple" iff it is a bare binder, a
# scalar, or a dup of a binder — NOT a NESTED ctor that embeds a pointer
# binder. A nested ctor (`Node(Node(lll,...), lk, Node(lr,...))`) makes the
# rebuild NON-BIJECTIVE: the in-place overwrite (kai_check_unique) writes the
# donor's slot 0 to a NEW node that borrows the donor's OLD children, and emit
# does not dup those borrowed children → over-decref → a corrupted (cyclic)
# tree (gap3_balance_minimal stack-overflows in `size`). The rb-tree's balance
# rotations have exactly this nested shape and CORRECTLY fall to fresh-alloc
# (emit emits no kai_check_unique there); the RSS win comes from the FLAT
# rebuilds (recolor / the 3-arm `kai_check_unique` case) + the TRMC arm-top
# reuse of insert_loop, not the rotations. Restricting cons-overwrite to flat
# rebuilds keeps gap3 correct and loses nothing the rotations gave.
fn pcs_slot_simple(e: Expr) : Bool = match e.kind {
  EVar(_)        -> true
  EInt(_)        -> true
  EReal(_)       -> true
  EBool(_)       -> true
  EChar(_)       -> true
  EUnit          -> true
  EStr(_, _)     -> true
  ECall(f, xs)   -> match f.kind {
    # A dup of a binder is flat. A NULLARY ctor (Red/Black/Leaf, no slots) is
    # flat. A ctor WITH slots embeds children → non-bijective → NOT simple.
    EVar(c)        -> if c == "__perceus_dup" { true } else { pcs_name_is_ctor(c) and pcs_all_slots_simple(xs) }
    EModCall(_, c) -> pcs_name_is_ctor(c) and pcs_all_slots_simple(xs)
    _              -> false
  }
  _ -> false
}

fn pcs_is_empty_list(xs: [Expr]) : Bool = match xs { [] -> true _ -> false }

fn pcs_tails_ctor_arms(cname: String, arms: [Arm]) : Bool = match arms {
  []           -> true
  [a, ...rest] -> match a { Arm(_, _, b) -> pcs_arm_tails_rebuild_ctor(cname, b) and pcs_tails_ctor_arms(cname, rest) }
}

fn pcs_smc_kind(self_name: String, k: ExprKind) : Bool = match k {
  # ONLY the modulo-cons shape: a CONSTRUCTOR rebuild one of whose slots is a
  # self-call `self_name(...)`. A bare self tail-call (`r = self(...)` bound to
  # a let, then matched — as in stdlib/regexp compile_repeat_optional) is
  # plain recursion, NOT modulo-cons, and tcrec does NOT lower it to a TRMC
  # step in a constructor slot; moving binders there is unsound (it keeps the
  # legacy emit). So we require the self-call to sit in a ctor slot.
  ECall(f, xs) -> match f.kind {
    EVar(c)        -> if pcs_name_is_ctor(c) { pcs_smc_any_arg_is_self(self_name, xs) }
                      else { pcs_smc_seq(self_name, xs) }
    EModCall(_, c) -> if pcs_name_is_ctor(c) { pcs_smc_any_arg_is_self(self_name, xs) }
                      else { pcs_smc_seq(self_name, xs) }
    _              -> pcs_smc_seq(self_name, xs)
  }
  EIf(c, t, opt_e) ->
    pcs_smc_kind(self_name, c.kind) or pcs_smc_kind(self_name, t.kind) or
    (match opt_e { None -> false Some(e2) -> pcs_smc_kind(self_name, e2.kind) })
  EBlock(stmts, tail) ->
    pcs_smc_stmts(self_name, stmts) or
    (match tail { None -> false Some(e) -> pcs_smc_kind(self_name, e.kind) })
  EMatch(s, arms) ->
    pcs_smc_kind(self_name, s.kind) or pcs_smc_arms(self_name, arms)
  _ -> false
}

# True iff any direct arg of a ctor call is a self-call (the modulo-cons hole)
# or recursively contains the modulo-cons shape.
fn pcs_smc_any_arg_is_self(self_name: String, xs: [Expr]) : Bool = match xs {
  []           -> false
  [h, ...rest] -> {
    let here = match h.kind {
      ECall(f, _) -> match f.kind {
        EVar(c)        -> c == self_name
        EModCall(_, c) -> c == self_name
        _              -> false
      }
      _ -> pcs_smc_kind(self_name, h.kind)
    }
    here or pcs_smc_any_arg_is_self(self_name, rest)
  }
}

fn pcs_smc_seq(self_name: String, xs: [Expr]) : Bool = match xs {
  []           -> false
  [h, ...rest] -> pcs_smc_kind(self_name, h.kind) or pcs_smc_seq(self_name, rest)
}

fn pcs_smc_stmts(self_name: String, stmts: [Stmt]) : Bool = match stmts {
  []           -> false
  [s, ...rest] -> {
    let here = match s {
      SLet(_, _, e)       -> pcs_smc_kind(self_name, e.kind)
      SVar(_, _, e, _, _) -> pcs_smc_kind(self_name, e.kind)
      SExprStmt(e)        -> pcs_smc_kind(self_name, e.kind)
      _                   -> false
    }
    here or pcs_smc_stmts(self_name, rest)
  }
}

fn pcs_smc_arms(self_name: String, arms: [Arm]) : Bool = match arms {
  []           -> false
  [a, ...rest] -> match a { Arm(_, _, b) -> pcs_smc_kind(self_name, b.kind) or pcs_smc_arms(self_name, rest) }
}

# Returns `true` if every read of `nm` in `e` is a linear consumer
# context — either:
#   - direct arg to `ECall(EVar(<user_fn>), ...)` — call to a
#     user-defined fn (pcs_pass makes those linear by construction);
#   - direct slot of `EVariantsOf` / variant-constructor `ECall` /
#     `ERecordLit` field init — the constructor takes ownership of
#     the slot.
# Any other context (intrinsic, capability op like `EField(EVar(eff),
# op)` invoked, raw `EField` read of `nm` for record projection,
# `EIndex`, binop, unop on non-numeric types) is non-linear and
# requires the conservative dup wrap.
fn pcs_all_consumers_linear(nm: String, e: Expr) : Bool =
  pcs_consumers_linear_kind(nm, e.kind)

fn pcs_consumers_linear_kind(nm: String, k: ExprKind) : Bool = match k {
  EVar(_)             -> true   # a bare EVar is "in linear position"
                                 # — it's either the body's tail (return
                                 # transfer, linear), or recursed into
                                 # from an arg/field that already classified
                                 # the call/ctor as linear or not.
  EStr(_, _)          -> true   # interpolated reads handled by §4b
  ECall(f, xs)        -> pcs_call_consumers_linear(nm, f, xs)
  EIntrinsic(_, xs)   -> {
    # Intrinsics are runtime primitives — non-linear if `nm` appears
    # as an arg.
    if pcs_any_arg_is_var(nm, xs) { false }
    else { pcs_all_args_consumers_linear(nm, xs) }
  }
  EField(x, _)        -> {
    # Field access reads the record raw and incref's the field.
    # If `nm == x` (bare ref), this is non-linear (borrow-only on nm).
    match x.kind {
      EVar(uname) -> uname != nm    # bare `nm.field` = borrow → false
      _           -> pcs_all_consumers_linear(nm, x)
    }
  }
  EIndex(a, b)        -> {
    # Same as EField: index borrows the array.
    let a_ok = match a.kind {
      EVar(uname) -> uname != nm
      _           -> pcs_all_consumers_linear(nm, a)
    }
    a_ok and pcs_all_consumers_linear(nm, b)
  }
  EBinop(_, a, b)     -> pcs_all_consumers_linear(nm, a) and
                          pcs_all_consumers_linear(nm, b)
  EUnop(_, x)         -> pcs_all_consumers_linear(nm, x)
  EIf(c, t, opt_e)    -> pcs_all_consumers_linear(nm, c) and
                          pcs_all_consumers_linear(nm, t) and
                          pcs_consumers_linear_opt(nm, opt_e)
  EMatch(s, arms)     -> {
    # The scrutinee is consumed by `match` (kai_decref at end of
    # the match block). A bare EVar(nm) as scrutinee is therefore
    # linear; but if `nm` appears INSIDE the scrutinee expression
    # (e.g. `match opts.path { ... }`), we recurse.
    let s_ok = match s.kind {
      EVar(_) -> true     # scrutinee linear by match semantics
      _       -> pcs_all_consumers_linear(nm, s)
    }
    s_ok and pcs_consumers_linear_arms(nm, arms)
  }
  ELambda(_, _)       -> true    # closure capture is handled separately
  ERecordLit(_, fis)  -> pcs_consumers_linear_fields(nm, fis)
  EList(els)          -> pcs_consumers_linear_elems(nm, els)
  ERange(a, b, opt)   -> pcs_all_consumers_linear(nm, a) and
                          pcs_all_consumers_linear(nm, b) and
                          pcs_consumers_linear_opt(nm, opt)
  EBlock(stmts, tail) -> pcs_consumers_linear_block(nm, stmts, tail)
  EPipe(a, b)         -> pcs_all_consumers_linear(nm, a) and
                          pcs_all_consumers_linear(nm, b)
  EMapPipe(a, b)      -> pcs_all_consumers_linear(nm, a) and
                          pcs_all_consumers_linear(nm, b)
  EFlatMapPipe(a, b)  -> pcs_all_consumers_linear(nm, a) and
                          pcs_all_consumers_linear(nm, b)
  EFilterPipe(a, b)   -> pcs_all_consumers_linear(nm, a) and
                          pcs_all_consumers_linear(nm, b)
  EHandle(body, _, _, init_opt, _, _, _) ->
    pcs_all_consumers_linear(nm, body) and
    pcs_consumers_linear_opt(nm, init_opt)
  EBang(inner)        -> pcs_all_consumers_linear(nm, inner)
  ELitUnit(inner, _)  -> pcs_all_consumers_linear(nm, inner)
  EModCall(_, _)      -> true    # mod calls go through user fns
                                  # post-resolve; treated as linear
  _                   -> true    # leaves (EInt, EBool, ELambda, ...)
                                  # don't reference nm
}

# Check whether a call expression `f(xs...)` with `nm` possibly
# appearing as an arg is linear-safe. Rules:
#   - If callee `f` is `EVar(fn_name)`:
#       - If fn_name starts with `__perceus_` → non-linear (these are
#         RC primitives that should never see a skipped read).
#       - Otherwise treat as user-defined linear fn.
#   - If callee is anything else (EField on capability, intrinsic,
#     apply on closure value), assume non-linear unless `nm` does
#     not appear in args.
fn pcs_call_consumers_linear(nm: String, f: Expr, xs: [Expr]) : Bool = {
  let nm_in_args = pcs_any_arg_is_var(nm, xs) or pcs_any_arg_mentions(nm, xs)
  if not nm_in_args {
    # `nm` only appears inside the callee expression (rare); recurse.
    pcs_all_consumers_linear(nm, f)
  } else {
    # Issue #680: when this predicate runs on a post-perceus body, the
    # callee may be wrapped in `__perceus_dup(...)` (e.g.
    # `step(initial, ev1)` becomes `(__perceus_dup(step))(initial,
    # ev1)`). Look through the dup wrap so the linearity analysis
    # matches the pre-perceus body. Without this, the same param
    # qualifies for skip_set when `pcs_pass` analyses the body but
    # NOT when `tcrec_rewrite_decl` re-analyses the post-perceus
    # `inner` — and the resulting misalignment plants a goto-block
    # drop without the matching `pcs_pass` dup, double-decrefing the
    # original ref.
    let effective_f = pcs_strip_dup_wrap(f)
    match effective_f.kind {
      EVar(fn_name) -> {
        # User-defined fn call — linear by pcs_pass construction —
        # UNLESS the fn name is a builtin synthetic.
        if pcs_is_runtime_primitive(fn_name) { false }
        # Even for user fns, check that `nm` does not also appear in
        # the callee (would mean f is computed from nm, unusual).
        else { pcs_all_consumers_linear(nm, effective_f) and
                pcs_all_args_consumers_linear(nm, xs) }
      }
      # The resolver qualifies a user CONSTRUCTOR to `EModCall(mod, Ctor)`
      # (uppercase head). A constructor takes ownership of its slots —
      # linear, exactly like the bare `EVar(C)` ctor shape. Without this
      # arm a resolved `RBNode(..., nm, ...)` ctor was misclassified
      # non-linear, blocking the branch-aware skip for `nm` (the rb-tree
      # insert_loop `l`/`r` ln=F bug). Restricted to ctors (uppercase):
      # a lowercase `EModCall` is a module FN call whose linearity we do
      # NOT assume here (capability ops, etc. internally incref) — those
      # stay conservative (non-linear → dup).
      EModCall(_mod, callee_name) ->
        if pcs_name_is_ctor(callee_name) {
          pcs_all_args_consumers_linear(nm, xs)
        } else { false }
      _ -> false   # call through capability/closure: assume non-linear
    }
  }
}

# Issue #680: strip an outer `__perceus_dup(x)` wrap to expose the
# underlying expression. Used by the linearity analysis so a post-
# perceus body whose call callee is `__perceus_dup(EVar(name))` is
# treated the same as the pre-perceus `EVar(name)` callee. Returns
# the original expression unchanged when no wrap is present.
fn pcs_strip_dup_wrap(e: Expr) : Expr = match e.kind {
  ECall(callee, args_) -> match callee.kind {
    EVar(nm) ->
      if nm == "__perceus_dup" {
        match args_ {
          [inner] -> inner
          _       -> e
        }
      } else { e }
    _ -> e
  }
  _ -> e
}

# Is `nm` directly an arg (as bare `EVar(nm)`)?
fn pcs_any_arg_is_var(nm: String, xs: [Expr]) : Bool = match xs {
  []           -> false
  [h, ...rest] -> match h.kind {
    EVar(uname) -> if uname == nm { true } else { pcs_any_arg_is_var(nm, rest) }
    _           -> pcs_any_arg_is_var(nm, rest)
  }
}

# Does `nm` appear anywhere within these args (recursively)?
fn pcs_any_arg_mentions(nm: String, xs: [Expr]) : Bool = match xs {
  []           -> false
  [h, ...rest] -> {
    if pcs_max_paths_in_expr(nm, h) > 0 { true }
    else { pcs_any_arg_mentions(nm, rest) }
  }
}

# Recurse into each arg.
fn pcs_all_args_consumers_linear(nm: String, xs: [Expr]) : Bool = match xs {
  []           -> true
  [h, ...rest] -> pcs_all_consumers_linear(nm, h) and
                   pcs_all_args_consumers_linear(nm, rest)
}

# Known runtime primitives / synthetic names that the compiler should
# treat as non-linear consumers. Builtin from the runtime's borrow
# discipline.
fn pcs_is_runtime_primitive(nm: String) : Bool = {
  nm == "__perceus_dup" or
  nm == "__perceus_drop" or
  nm == "__perceus_reuse_cons" or
  nm == "__perceus_reuse_record" or
  nm == "__perceus_reuse_variant"
}

fn pcs_consumers_linear_opt(nm: String, opt: Option[Expr]) : Bool = match opt {
  None    -> true
  Some(e) -> pcs_all_consumers_linear(nm, e)
}

fn pcs_consumers_linear_arms(nm: String, arms: [Arm]) : Bool = match arms {
  []           -> true
  [a, ...rest] -> match a {
    Arm(_, opt_g, body) -> {
      let gp = match opt_g {
        None    -> true
        Some(g) -> pcs_all_consumers_linear(nm, g)
      }
      gp and pcs_all_consumers_linear(nm, body) and
      pcs_consumers_linear_arms(nm, rest)
    }
  }
}

fn pcs_consumers_linear_fields(nm: String, fis: [FieldInit]) : Bool = match fis {
  []           -> true
  [h, ...rest] -> match h {
    # Record field init: the field consumes the value (record owns slot).
    # So a bare `EVar(nm)` as the field value IS linear.
    FI(_, e) -> pcs_all_consumers_linear(nm, e) and
                pcs_consumers_linear_fields(nm, rest)
  }
}

fn pcs_consumers_linear_elems(nm: String, els: [ListElem]) : Bool = match els {
  []           -> true
  [h, ...rest] -> {
    let h_ok = match h {
      ElPlain(e)  -> pcs_all_consumers_linear(nm, e)
      ElSpread(e) -> match e.kind {
        # `[x, ...nm]` lowers to `kai_cons(x, kai_incref(nm))`
        # (see `emit_list_tail` in the emitter): the spread tail is
        # increfed, not transferred. A bare `EVar(nm)` spread is
        # therefore a non-linear consumer of `nm` — the conservative
        # dup wrap MUST stay.
        EVar(uname) -> uname != nm
        _           -> pcs_all_consumers_linear(nm, e)
      }
    }
    h_ok and pcs_consumers_linear_elems(nm, rest)
  }
}

fn pcs_consumers_linear_block(nm: String, stmts: [Stmt], tail: Option[Expr]) : Bool = {
  pcs_consumers_linear_stmts(nm, stmts) and pcs_consumers_linear_opt(nm, tail)
}

fn pcs_consumers_linear_stmts(nm: String, stmts: [Stmt]) : Bool = match stmts {
  []           -> true
  [h, ...rest] -> pcs_consumers_linear_stmt(nm, h) and
                   pcs_consumers_linear_stmts(nm, rest)
}

fn pcs_consumers_linear_stmt(nm: String, s: Stmt) : Bool = match s {
  SLet(_, _, e)                  -> pcs_all_consumers_linear(nm, e)
  SVar(_, _, e, _, _)            -> pcs_all_consumers_linear(nm, e)
  SAssert(e, opt_m)              -> pcs_all_consumers_linear(nm, e) and
                                     pcs_consumers_linear_opt(nm, opt_m)
  SExprStmt(e)                   -> pcs_all_consumers_linear(nm, e)
  SIndexAssign(a, b, c, _, _)    -> pcs_all_consumers_linear(nm, a) and
                                     pcs_all_consumers_linear(nm, b) and
                                     pcs_all_consumers_linear(nm, c)
  SUse(_, _, _)                  -> true
}

# Returns `true` if every execution path through `body` consumes
# `nm` exactly once on a non-lambda read. Composition rules:
#   - leaf EVar(nm) → true
#   - sequential composition (Block/Call/Binop/...) → any sub-position
#     consumes
#   - EIf with both branches → both branches must consume
#   - EIf without else → cannot prove consume (the missing-else path
#     leaves the binding alive)
#   - EMatch → every arm body must consume (the scrutinee path is
#     a sequence: scrutinee evaluated, then arm body)
#   - ELambda → false (closure capture is RC'd separately)
#   - leaves (EInt, EBool, ...) → false
fn pcs_consumed_on_every_path(nm: String, e: Expr) : Bool =
  pcs_consumed_kind(nm, e.kind)

fn pcs_consumed_kind(nm: String, k: ExprKind) : Bool = match k {
  EVar(uname)         -> uname == nm
  EStr(_, _)          -> false  # interpolated reads go through §4b path
  ECall(f, xs)        -> pcs_consumed_on_every_path(nm, f) or
                          pcs_consumed_any(nm, xs)
  EIntrinsic(_, xs)   -> pcs_consumed_any(nm, xs)
  EField(x, _)        -> pcs_consumed_on_every_path(nm, x)
  EIndex(a, b)        -> pcs_consumed_on_every_path(nm, a) or
                          pcs_consumed_on_every_path(nm, b)
  EBinop(_, a, b)     -> pcs_consumed_on_every_path(nm, a) or
                          pcs_consumed_on_every_path(nm, b)
  EUnop(_, x)         -> pcs_consumed_on_every_path(nm, x)
  EIf(c, t, opt_e)    -> {
    # consumed if cond consumes, OR both branches consume.
    if pcs_consumed_on_every_path(nm, c) { true }
    else {
      match opt_e {
        None    -> false   # missing-else path leaves the binding alive
        Some(e2) -> pcs_consumed_on_every_path(nm, t) and
                    pcs_consumed_on_every_path(nm, e2)
      }
    }
  }
  EMatch(s, arms)     -> {
    if pcs_consumed_on_every_path(nm, s) { true }
    else { pcs_consumed_all_arms(nm, arms) }
  }
  ELambda(_, _)       -> false
  ERecordLit(_, fis)  -> pcs_consumed_any_field(nm, fis)
  EList(els)          -> pcs_consumed_any_elem(nm, els)
  ERange(a, b, opt)   -> pcs_consumed_on_every_path(nm, a) or
                          pcs_consumed_on_every_path(nm, b) or
                          pcs_consumed_opt(nm, opt)
  EBlock(stmts, tail) -> pcs_consumed_in_block(nm, stmts, tail)
  EPipe(a, b)         -> pcs_consumed_on_every_path(nm, a) or
                          pcs_consumed_on_every_path(nm, b)
  EMapPipe(a, b)      -> pcs_consumed_on_every_path(nm, a) or
                          pcs_consumed_on_every_path(nm, b)
  EFlatMapPipe(a, b)  -> pcs_consumed_on_every_path(nm, a) or
                          pcs_consumed_on_every_path(nm, b)
  EFilterPipe(a, b)   -> pcs_consumed_on_every_path(nm, a) or
                          pcs_consumed_on_every_path(nm, b)
  EHandle(body, _, _, init_opt, _, _, _) -> {
    # Conservative: only count the body and init expression. Handler
    # clause bodies execute on op invocation; we can't prove they
    # always fire.
    pcs_consumed_on_every_path(nm, body) or pcs_consumed_opt(nm, init_opt)
  }
  EBang(inner)        -> pcs_consumed_on_every_path(nm, inner)
  ELitUnit(inner, _)  -> pcs_consumed_on_every_path(nm, inner)
  _                   -> false
}

fn pcs_consumed_any(nm: String, es: [Expr]) : Bool = match es {
  []           -> false
  [h, ...rest] -> pcs_consumed_on_every_path(nm, h) or pcs_consumed_any(nm, rest)
}

fn pcs_consumed_all_arms(nm: String, arms: [Arm]) : Bool = match arms {
  []           -> true   # no arms = no paths = vacuously consumed
                          # (but EMatch with zero arms is invalid anyway)
  [a, ...rest] -> match a {
    Arm(_, _, body) ->
      pcs_consumed_on_every_path(nm, body) and pcs_consumed_all_arms(nm, rest)
  }
}

fn pcs_consumed_any_field(nm: String, fis: [FieldInit]) : Bool = match fis {
  []           -> false
  [h, ...rest] -> match h {
    FI(_, e) -> pcs_consumed_on_every_path(nm, e) or pcs_consumed_any_field(nm, rest)
  }
}

fn pcs_consumed_any_elem(nm: String, els: [ListElem]) : Bool = match els {
  []           -> false
  [h, ...rest] -> {
    let inner = match h { ElPlain(e) -> e ElSpread(e) -> e }
    pcs_consumed_on_every_path(nm, inner) or pcs_consumed_any_elem(nm, rest)
  }
}

fn pcs_consumed_opt(nm: String, opt: Option[Expr]) : Bool = match opt {
  None    -> false
  Some(e) -> pcs_consumed_on_every_path(nm, e)
}

fn pcs_consumed_in_block(nm: String, stmts: [Stmt], tail: Option[Expr]) : Bool = {
  if pcs_consumed_in_stmts(nm, stmts) { true }
  else { pcs_consumed_opt(nm, tail) }
}

fn pcs_consumed_in_stmts(nm: String, stmts: [Stmt]) : Bool = match stmts {
  []           -> false
  [h, ...rest] -> pcs_consumed_in_stmt(nm, h) or pcs_consumed_in_stmts(nm, rest)
}

fn pcs_consumed_in_stmt(nm: String, s: Stmt) : Bool = match s {
  SLet(_, _, e)                  -> pcs_consumed_on_every_path(nm, e)
  SVar(_, _, e, _, _)            -> pcs_consumed_on_every_path(nm, e)
  SAssert(e, opt_m)              -> pcs_consumed_on_every_path(nm, e) or
                                     pcs_consumed_opt(nm, opt_m)
  SExprStmt(e)                   -> pcs_consumed_on_every_path(nm, e)
  SIndexAssign(a, b, c, _, _)    -> pcs_consumed_on_every_path(nm, a) or
                                     pcs_consumed_on_every_path(nm, b) or
                                     pcs_consumed_on_every_path(nm, c)
  SUse(_, _, _)                  -> false
}

# ---- m5.x §4b: rewrite EVar reads inside EStr interpolation bodies ----
#
# `pcs_rewrite_kind` cannot reach EVar reads buried inside `#{...}`
# because the EStr span is opaque source text. The collector parses the
# bodies and counts uses correctly, but the rewriter has no transform
# hook into the span itself. Without this pass, `print("#{show(e)} =
# #{eval(e)}")` leaves both reads of `e` unwrapped — which is the bug
# behind R3.
#
# Strategy: walk each `#{esrc}` body. Tokenise + parse `esrc` into an
# Expr, feed it to the existing `pcs_rewrite_expr` (with the outer
# scope / uses / in_lam) to compute which inner EVar positions need a
# `__perceus_dup` wrap, then rebuild `esrc` by walking its tokens and
# replacing the wrapped idents with `__perceus_dup(NAME)`. The result
# is still valid kaikai source: when emit re-parses the interp body it
# sees the wrap as a regular ECall and routes through the normal
# `__perceus_dup` special case in `emit_call_expr`.

type DupMark = DM(Int, Int)   # line, col of an EVar that needs wrapping

fn pcs_rewrite_estr_span(span: String, is_triple: Bool, scope: [String],
                          uses: [Use], in_lam: Bool, skip_set: [String], force_set: [String], bmap: [BorrowEntry]) : String / Console {

  let n = string_length(span)
  let body_start = if is_triple { 3 } else { 1 }
  let body_end = if is_triple { n - 3 } else { n - 1 }
  if not has_interp(span, body_start, body_end) { span }
  else {
    let parts = iscan_collect(span, body_end,
                  IScan { parts: [], lit_start: body_start, i: body_start })
    let new_parts = pcs_rewrite_iparts(parts, scope, uses, in_lam, [], skip_set, force_set, bmap)
    let body = pcs_concat_iparts(new_parts, "")
    let prefix = if is_triple { "\"\"\"" } else { "\"" }
    concat_all([prefix, body, prefix])
  }
}

fn pcs_rewrite_iparts(parts: [IPart], scope: [String], uses: [Use],
                       in_lam: Bool, acc: [IPart], skip_set: [String], force_set: [String], bmap: [BorrowEntry]) : [IPart] / Console {

  match parts {
    [] -> list_reverse(acc)
    [p, ...rest] -> {
      let p1 = match p {
        IpLit(_, _) -> p
        IpExp(esrc) -> IpExp(pcs_rewrite_interp_src(esrc, scope, uses, in_lam, skip_set, force_set, bmap))
      }
      pcs_rewrite_iparts(rest, scope, uses, in_lam, [p1, ...acc], skip_set, force_set, bmap)
    }
  }
}

fn pcs_concat_iparts(parts: [IPart], acc: String) : String {
  match parts {
    [] -> acc
    [p, ...rest] -> match p {
      IpLit(piece, _) -> pcs_concat_iparts(rest, concat_all([acc, piece]))
      # `"#{"` would lex as an unterminated interpolation start because
      # kaikai has no escape for `#{` in string literals. Build the
      # opener from `"#"` + `"{"` so the source survives lex.
      IpExp(esrc) -> pcs_concat_iparts(rest, concat_all([acc, "#", "{", esrc, "}"]))
    }
  }
}

fn pcs_rewrite_interp_src(esrc: String, scope: [String], uses: [Use],
                           in_lam: Bool, skip_set: [String], force_set: [String], bmap: [BorrowEntry]) : String / Console {

  # Tokenise once for pcs_render_with_marks (it needs the token
  # stream to map AST positions back to source spans); parse_interp_expr
  # re-tokenises internally for the AST. The double tokenise keeps
  # parse.kai's public surface free of the Parser / PExpr workspace
  # types (issue #677 phase 1h H2).
  let toks = tokenize(esrc)
  match parse_interp_expr(esrc) {
    None -> esrc
    Some(parsed) -> {
      let rewritten = pcs_rewrite_expr(parsed, scope, uses, in_lam, skip_set, force_set, bmap)
      let marks = pcs_dup_marks_expr(rewritten, [])
      match marks {
        [] -> esrc
        _  -> pcs_render_with_marks(esrc, toks, marks, "", 0)
      }
    }
  }
}

# Walk a (rewritten) Expr collecting (line, col) of inner EVars wrapped
# in `__perceus_dup`. Pure structural recursion — no scope tracking,
# since pcs_rewrite_expr already encoded the wrap decisions in the AST.
fn pcs_dup_marks_expr(e: Expr, acc: [DupMark]) : [DupMark] {
  let acc1 = match e.kind {
    ECall(f, xs) -> match f.kind {
      EVar(nm) -> if nm == "__perceus_dup" {
        match xs {
          [arg] -> match arg.kind {
            EVar(_) -> [DM(arg.line, arg.col), ...acc]
            _ -> acc
          }
          _ -> acc
        }
      } else { acc }
      _ -> acc
    }
    _ -> acc
  }
  pcs_dup_marks_subs(e.kind, acc1)
}

fn pcs_dup_marks_subs(k: ExprKind, acc: [DupMark]) : [DupMark] {
  match k {
    EInt(_) -> acc
    EReal(_) -> acc
    EBool(_) -> acc
    EChar(_) -> acc
    EStr(_, _) -> acc
    EUnit -> acc
    EVar(_) -> acc
    EUnder -> acc
    EPlaceholder -> acc
    EHole(_) -> acc
    ETodo(_) -> acc
    EVariantsOf(_, _) -> acc
    EModCall(_, _) -> acc
    EIntrinsic(_, args_) -> pcs_dup_marks_exprs(args_, acc)
    ECall(callee, args_) -> pcs_dup_marks_exprs(args_, pcs_dup_marks_expr(callee, acc))
    EField(base, _) -> pcs_dup_marks_expr(base, acc)
    EIndex(a, b) -> pcs_dup_marks_expr(b, pcs_dup_marks_expr(a, acc))
    EBinop(_, a, b) -> pcs_dup_marks_expr(b, pcs_dup_marks_expr(a, acc))
    EUnop(_, x) -> pcs_dup_marks_expr(x, acc)
    EIf(c, t_, opt_e) -> {
      let a1 = pcs_dup_marks_expr(c, acc)
      let a2 = pcs_dup_marks_expr(t_, a1)
      match opt_e {
        None -> a2
        Some(e2) -> pcs_dup_marks_expr(e2, a2)
      }
    }
    EMatch(s, arms) -> pcs_dup_marks_arms(arms, pcs_dup_marks_expr(s, acc))
    ELambda(_, body) -> pcs_dup_marks_expr(body, acc)
    ERecordLit(_, fis) -> pcs_dup_marks_field_inits(fis, acc)
    EList(es) -> pcs_dup_marks_list_elems(es, acc)
    ERange(a, b, opt_step) -> {
      let a1 = pcs_dup_marks_expr(a, acc)
      let a2 = pcs_dup_marks_expr(b, a1)
      match opt_step {
        None -> a2
        Some(s) -> pcs_dup_marks_expr(s, a2)
      }
    }
    EBlock(stmts, opt_tail) -> {
      let a1 = pcs_dup_marks_stmts(stmts, acc)
      match opt_tail {
        None -> a1
        Some(t_) -> pcs_dup_marks_expr(t_, a1)
      }
    }
    EPipe(l, r) -> pcs_dup_marks_expr(r, pcs_dup_marks_expr(l, acc))
    EMapPipe(l, r) -> pcs_dup_marks_expr(r, pcs_dup_marks_expr(l, acc))
    EFlatMapPipe(l, r) -> pcs_dup_marks_expr(r, pcs_dup_marks_expr(l, acc))
    EFilterPipe(l, r) -> pcs_dup_marks_expr(r, pcs_dup_marks_expr(l, acc))
    EHandle(body, _, _, init_opt, _, clauses, ret_opt) -> {
      let a1 = pcs_dup_marks_expr(body, acc)
      let a2 = match init_opt {
        None -> a1
        Some(e2) -> pcs_dup_marks_expr(e2, a1)
      }
      let a3 = pcs_dup_marks_clauses(clauses, a2)
      match ret_opt {
        None -> a3
        Some(hr) -> match hr {
          HR(_, b, _, _) -> pcs_dup_marks_expr(b, a3)
        }
      }
    }
    ELitUnit(inner, _) -> pcs_dup_marks_expr(inner, acc)
    EBang(inner) -> pcs_dup_marks_expr(inner, acc)
  }
}

fn pcs_dup_marks_exprs(es: [Expr], acc: [DupMark]) : [DupMark] {
  match es {
    [] -> acc
    [h, ...rest] -> pcs_dup_marks_exprs(rest, pcs_dup_marks_expr(h, acc))
  }
}

fn pcs_dup_marks_arms(arms: [Arm], acc: [DupMark]) : [DupMark] {
  match arms {
    [] -> acc
    [a, ...rest] -> match a {
      Arm(_, opt_g, body) -> {
        let a1 = match opt_g {
          None -> acc
          Some(g) -> pcs_dup_marks_expr(g, acc)
        }
        let a2 = pcs_dup_marks_expr(body, a1)
        pcs_dup_marks_arms(rest, a2)
      }
    }
  }
}

fn pcs_dup_marks_field_inits(fis: [FieldInit], acc: [DupMark]) : [DupMark] {
  match fis {
    [] -> acc
    [h, ...rest] -> match h {
      FI(_, e) -> pcs_dup_marks_field_inits(rest, pcs_dup_marks_expr(e, acc))
    }
  }
}

fn pcs_dup_marks_list_elems(es: [ListElem], acc: [DupMark]) : [DupMark] {
  match es {
    [] -> acc
    [h, ...rest] -> {
      let inner = match h { ElPlain(e) -> e ElSpread(e) -> e }
      pcs_dup_marks_list_elems(rest, pcs_dup_marks_expr(inner, acc))
    }
  }
}

fn pcs_dup_marks_stmts(ss: [Stmt], acc: [DupMark]) : [DupMark] {
  match ss {
    [] -> acc
    [h, ...rest] -> {
      let acc1 = match h {
        SLet(_, _, rhs) -> pcs_dup_marks_expr(rhs, acc)
        SVar(_, _, rhs, _, _) -> pcs_dup_marks_expr(rhs, acc)
        SAssert(c, opt_m) -> {
          let a1 = pcs_dup_marks_expr(c, acc)
          match opt_m {
            None -> a1
            Some(m) -> pcs_dup_marks_expr(m, a1)
          }
        }
        SExprStmt(e) -> pcs_dup_marks_expr(e, acc)
        SIndexAssign(b, i, v, _, _) -> {
          let a1 = pcs_dup_marks_expr(b, acc)
          let a2 = pcs_dup_marks_expr(i, a1)
          pcs_dup_marks_expr(v, a2)
        }
        SUse(_, _, _) -> acc
      }
      pcs_dup_marks_stmts(rest, acc1)
    }
  }
}

fn pcs_dup_marks_clauses(cs: [HClause], acc: [DupMark]) : [DupMark] {
  match cs {
    [] -> acc
    [h, ...rest] -> match h {
      HC(_, _, body, _, _) ->
        pcs_dup_marks_clauses(rest, pcs_dup_marks_expr(body, acc))
    }
  }
}

fn pcs_dup_mark_has(marks: [DupMark], line: Int, col: Int) : Bool {
  match marks {
    [] -> false
    [h, ...rest] -> match h {
      DM(l, c) ->
        if l == line and c == col { true }
        else { pcs_dup_mark_has(rest, line, col) }
    }
  }
}

# Walk tokens of `esrc`, copying source verbatim except at TkIdent
# tokens whose (line, col) matches a `marks` entry — those get wrapped
# in `__perceus_dup(NAME)`. Token positions are relative to `esrc`
# (starting at line 1, col 1) because tokenize() runs on the slice.
fn pcs_render_with_marks(esrc: String, toks: [Token], marks: [DupMark],
                           acc: String, prev_end: Int) : String {
  match toks {
    [] -> concat_all([acc, string_slice(esrc, prev_end, string_length(esrc) - prev_end)])
    [t, ...rest] -> match t.kind {
      TkEof -> concat_all([acc, string_slice(esrc, prev_end, string_length(esrc) - prev_end)])
      TkIdent ->
        if pcs_dup_mark_has(marks, t.line, t.col) {
          let between = string_slice(esrc, prev_end, t.start - prev_end)
          let txt = string_slice(esrc, t.start, t.length)
          let chunk = concat_all([between, "__perceus_dup(", txt, ")"])
          pcs_render_with_marks(esrc, rest, marks,
                                  concat_all([acc, chunk]),
                                  t.start + t.length)
        } else {
          let chunk = string_slice(esrc, prev_end, (t.start + t.length) - prev_end)
          pcs_render_with_marks(esrc, rest, marks,
                                  concat_all([acc, chunk]),
                                  t.start + t.length)
        }
      _ -> {
        let chunk = string_slice(esrc, prev_end, (t.start + t.length) - prev_end)
        pcs_render_with_marks(esrc, rest, marks,
                                concat_all([acc, chunk]),
                                t.start + t.length)
      }
    }
  }
}

# ---- per-param drops: entry for unused, exit for multi-use / blocked ----
#
# Categorisation by `last_use_for`:
#   - LUUnused(p)         → drop at body entry (param never read; release
#                           immediately).
#   - LUBlocked(p)         → drop at body exit (a closure may keep the
#                           param alive past the fn body via capture; the
#                           closure-capture incref balances; the original
#                           param ref is released when the fn returns).
#   - LUAt + count >= 2    → drop at body exit (every read is dup-wrapped
#                           per Phase 1, so the original ref is unconsumed
#                           and must be released).
#   - LUAt + count == 1    → no drop (the single read transfers the
#                           original ref to its consumer).
#
# Wrap shape when both entry and exit drops are needed:
#   EBlock([entry_drops..., SLet(__pcs_ret, body), exit_drops...],
#          Some(EVar("__pcs_ret")))
# `__pcs_ret` is reserved (no kaikai user-source name starts with `__`).
# When neither set has drops, the body is returned unchanged so the
# fixed-point selfhost sees no extra wrap on inert fns.
#
# This pass is sound only because `emit_pat_binds` increfs every alias
# extraction (variant args, cons head/tail) — the shared-storage producer
# (caller's `e.kind` / list cell) keeps its own ref independent of the
# binding. The previous attempt's UAF in `synth_call` (and why
# incref-on-extract / Step A here is the prerequisite for this pass)
# is recoverable from `git log` on the m5.x runtime flip commits
# (atomic A+B+C+D, 2026-04-28).
fn pcs_prepend_unused_drops(body: Expr, params: [Param], uses: [Use], skip_set: [String]) : Expr {
  let entry = pcs_collect_entry_drops(params, uses, [])
  let exit_ = pcs_collect_exit_drops(params, uses, skip_set, [])
  match entry {
    [] -> match exit_ {
      [] -> body
      [_, ...__] -> pcs_wrap_with_exit(body, [], exit_)
    }
    [_, ...__] -> pcs_wrap_with_exit(body, entry, exit_)
  }
}

fn pcs_wrap_with_exit(body: Expr, entry: [Stmt], exit_: [Stmt]) : Expr {
  match exit_ {
    [] -> Expr { kind: EBlock(entry, Some(body)), line: body.line, col: body.col,
                 ty: body.ty, mode: body.mode }
    [_, ...__] -> {
      let ret_let = SLet(
        Pattern { pkind: PBind("__pcs_ret"), line: body.line, col: body.col },
        None,
        body
      )
      let stmts = list_append(entry, [ret_let, ...exit_])
      let tail = Expr { kind: EVar("__pcs_ret"), line: body.line, col: body.col,
                        ty: body.ty, mode: body.mode }
      Expr { kind: EBlock(stmts, Some(tail)), line: body.line, col: body.col,
             ty: body.ty, mode: body.mode }
    }
  }
}

fn pcs_collect_entry_drops(params: [Param], uses: [Use], acc: [Stmt]) : [Stmt] {
  match params {
    [] -> list_reverse(acc)
    [p, ...rest] -> {
      let acc1 = match last_use_for(p.pname, uses) {
        LUUnused(_) -> [pcs_make_drop_stmt(p.pname, p.pline, p.pcol), ...acc]
        _ -> acc
      }
      pcs_collect_entry_drops(rest, uses, acc1)
    }
  }
}

fn pcs_collect_exit_drops(params: [Param], uses: [Use], skip_set: [String], acc: [Stmt]) : [Stmt] {
  match params {
    [] -> list_reverse(acc)
    [p, ...rest] -> {
      let acc1 = match last_use_for(p.pname, uses) {
        LUBlocked(_) -> [pcs_make_drop_stmt(p.pname, p.pline, p.pcol), ...acc]
        LUAt(_, _, _) -> {
          # Issue #599 — branch-aware: if the param is in `skip_set`,
          # the rewriter did NOT wrap reads in `__perceus_dup`, so
          # the single read on the executed path transfers the ref
          # raw and the consumer must be linear. Emitting an exit
          # drop here would double-free.
          if list_has(skip_set, p.pname) { acc }
          else if pcs_count_non_lam_uses(p.pname, uses, 0) >= 2 {
            [pcs_make_drop_stmt(p.pname, p.pline, p.pcol), ...acc]
          } else { acc }
        }
        _ -> acc
      }
      pcs_collect_exit_drops(rest, uses, skip_set, acc1)
    }
  }
}

# Issue #297 (partial) — block-scope let-binding exit drops.
#
# For each `SLet(PBind(name), _, rhs)` introduced by this block,
# decide whether the binding needs a `__perceus_drop` at block exit.
# The rule mirrors `pcs_collect_exit_drops` for fn params:
#   - `LUBlocked` (closure capture) → drop.
#   - `LUAt` with ≥ 2 non-lam uses → drop.
#   - `LUAt` with exactly 1 non-lam use → no drop (the lexically-last
#     read transfers the ref raw to its consumer).
#   - `LUUnused` → no drop here. `block_unused_lets` in the emitter
#     attaches an inline `kai_decref` right after the SLet; emitting
#     a second `__perceus_drop` would double-free.
#
# Names already visible in `outer` (the scope at block entry) are
# skipped — those are owned by an enclosing scope's drop discipline.
#
# Destructuring SLet (PRecord, PVariant, PTuple, ...) is handled by
# `emit_let_stmt`'s destructuring arm (decrefs the composite temp),
# so we ignore non-PBind patterns here. `pat_bindings_skip_raw`
# excludes Tier 2.5 raw locals (`int64_t`, etc.) which have no rc.
fn pcs_collect_block_let_exit_drops(stmts: [Stmt], outer: [String],
                                     uses: [Use], opt_tail: Option[Expr],
                                     acc: [Stmt]) : [Stmt] / Console {

  match stmts {
    [] -> list_reverse(acc)
    [s, ...rest] -> {
      let acc1 = match s {
        SLet(pat, _, rhs) -> match pat.pkind {
          PBind(nm) -> {
            let names_in = prc_pat_bindings_skip_raw(pat, rhs, [])
            let in_block = list_has(names_in, nm) and not list_has(outer, nm)
            let in_tail = pcs_name_in_tail(nm, opt_tail)
            if in_block and not in_tail {
              match last_use_for(nm, uses) {
                LUBlocked(_) -> [pcs_make_drop_stmt(nm, pat.line, pat.col), ...acc]
                LUAt(_, _, _) ->
                  if pcs_count_non_lam_uses(nm, uses, 0) >= 2 {
                    [pcs_make_drop_stmt(nm, pat.line, pat.col), ...acc]
                  } else { acc }
                _ -> acc
              }
            } else { acc }
          }
          _ -> acc
        }
        _ -> acc
      }
      pcs_collect_block_let_exit_drops(rest, outer, uses, opt_tail, acc1)
    }
  }
}

# True iff `nm` appears in the block's tail expression. Re-runs
# `pcs_collect_uses_expr` with `[nm]` as scope so the result lists
# the EVar reads of `nm` and only those.
fn pcs_name_in_tail(nm: String, opt_tail: Option[Expr]) : Bool / Console {

  match opt_tail {
    None -> false
    Some(e) -> {
      let us = pcs_collect_uses_expr(e, [nm], false, [])
      pcs_uses_has_name(us, nm)
    }
  }
}

# Splice exit-drop SExprStmts into the block. Drops fire LIFO (last
# let entered → first dropped); the collector accumulates head-first
# then reverses, so we reverse again here. Drops sit *between* the
# trailing SLets and the tail, leaving the tail position untouched
# so `tcrec_rewrite_decls` can detect a self-tail-call.
fn pcs_append_drops(stmts: [Stmt], drops: [Stmt]) : [Stmt] {
  match drops {
    [] -> stmts
    [_, ...__] -> list_append(stmts, list_reverse(drops))
  }
}

fn pcs_uses_has_name(uses: [Use], nm: String) : Bool {
  match uses {
    [] -> false
    [h, ...rest] -> match h {
      U(uname, _, _, _) -> if uname == nm { true } else { pcs_uses_has_name(rest, nm) }
    }
  }
}

fn pcs_make_drop_stmt(nm: String, ln: Int, cl: Int) : Stmt =
  SExprStmt(Expr {
    kind: ECall(
      Expr { kind: EVar("__perceus_drop"), line: ln, col: cl,
             ty: None, mode: MUnknown },
      [Expr { kind: EVar(nm), line: ln, col: cl,
              ty: None, mode: MUnknown }]
    ),
    line: ln, col: cl, ty: None, mode: MUnknown
  })

# Issue #350 — Gap 3: emit `__perceus_drop` for multi-use pattern
# bindings introduced by match arms. Mirror of the SLet exit-drop
# pass landed in #342, but for the arm-binding shape that drives
# the RB tree leak (`balance` / `insert_loop` rotation arms).
#
# Each match arm extracts cells from the scrutinee with `kai_incref`
# at the binding site (`emit_pat_binds`). When a binding has ≥ 2
# non-lambda uses inside the arm, every read is wrapped in
# `__perceus_dup` (each consumer takes a fresh ref); the original
# extract ref is left dangling without an explicit drop, leaking
# the underlying child cell every time the arm fires.
#
# The pass walks the post-`pcs_rewrite_expr` AST, finds each EMatch
# arm whose pattern introduces multi-use bindings, and inserts a
# `__perceus_drop(nm)` between the body's statements and its tail.
# Conservative gates (preserve TCO + avoid use-after-free):
#   - Skip names already visible in the outer scope (owned upstream).
#   - Skip names whose `last_use_for` is `LUUnused` or single-use
#     `LUAt` (the lexically-last raw read transfers the ref).
#   - Skip names that appear in the body's tail-leaf positions —
#     a drop fires before the tail evaluates, so a tail-position
#     read would see a freed cell when the binding's last live ref
#     was the original.
#   - For non-EBlock bodies, skip drops when the body is a tail-call
#     to the enclosing fn (`fn_name`); wrapping such a body in an
#     EBlock with `__pcs_arm_ret` would hide the self-tail-call from
#     `tcrec_rewrite_decls` and break TCO (same risk #342 hit).
#
# The pass runs *after* `pcs_rewrite_expr` so it sees the
# `__perceus_dup`-wrapped reads and the canonicalised structure;
# it runs *before* `pcs_recognise_reuse_expr` so the reuse rewrite
# operates on the post-drop arm body.
fn pcs_arm_drop_pass(e: Expr, fn_name: String, outer_scope: [String],
                     uses: [Use]) : Expr / Console =

  Expr { kind: pcs_arm_drop_kind(e.kind, e.line, e.col, fn_name, outer_scope, uses),
         line: e.line, col: e.col, ty: e.ty, mode: e.mode }

fn pcs_arm_drop_kind(k: ExprKind, line: Int, col: Int, fn_name: String,
                     outer_scope: [String], uses: [Use]) : ExprKind / Console {

  match k {
    EMatch(scr, arms) -> {
      let scr1 = pcs_arm_drop_pass(scr, fn_name, outer_scope, uses)
      let arms1 = pcs_arm_drop_arms(arms, fn_name, outer_scope, uses)
      EMatch(scr1, arms1)
    }
    EBlock(stmts, opt_tail) -> {
      let stmts1 = pcs_arm_drop_stmts(stmts, fn_name, outer_scope, uses)
      let tail1 = match opt_tail {
        None -> None
        Some(e2) -> Some(pcs_arm_drop_pass(e2, fn_name, outer_scope, uses))
      }
      EBlock(stmts1, tail1)
    }
    ELambda(ps, body) -> {
      let pn = map(ps, (p) => p.pname)
      ELambda(ps, pcs_arm_drop_pass(body, fn_name, list_append(outer_scope, pn), uses))
    }
    EHandle(body, eff, eff_tas, init_opt, alias, clauses, ret_opt) -> {
      let body1 = pcs_arm_drop_pass(body, fn_name, outer_scope, uses)
      let init1 = match init_opt {
        None -> None
        Some(e2) -> Some(pcs_arm_drop_pass(e2, fn_name, outer_scope, uses))
      }
      let cls1 = pcs_arm_drop_clauses(clauses, fn_name, outer_scope, uses)
      let ret1 = match ret_opt {
        None -> None
        Some(hr) -> match hr {
          HR(pname, body2, hl, hc) ->
            Some(HR(pname,
                    pcs_arm_drop_pass(body2, fn_name, [pname, ...outer_scope], uses),
                    hl, hc))
        }
      }
      EHandle(body1, eff, eff_tas, init1, alias, cls1, ret1)
    }
    # Issue #528: inlined from `map_expr_kind` (stage 1 lacks row
    # polymorphism on function-param types).
    EInt(_)        -> k
    EReal(_)       -> k
    EBool(_)       -> k
    EChar(_)       -> k
    EStr(_, _)     -> k
    EUnit          -> k
    EVar(_)        -> k
    EUnder         -> k
    EPlaceholder   -> k
    EHole(_)       -> k
    ETodo(_)       -> k
    EVariantsOf(_, _) -> k
    EModCall(_, _) -> k
    EIntrinsic(name, args_) ->
      EIntrinsic(name, pcs_arm_drop_expr_list(args_, fn_name, outer_scope, uses))
    ECall(callee, args_) ->
      ECall(pcs_arm_drop_pass(callee, fn_name, outer_scope, uses),
            pcs_arm_drop_expr_list(args_, fn_name, outer_scope, uses))
    EField(base, nm)     -> EField(pcs_arm_drop_pass(base, fn_name, outer_scope, uses), nm)
    EIndex(a, b)         -> EIndex(pcs_arm_drop_pass(a, fn_name, outer_scope, uses),
                                    pcs_arm_drop_pass(b, fn_name, outer_scope, uses))
    EBinop(op, a, b)     -> EBinop(op, pcs_arm_drop_pass(a, fn_name, outer_scope, uses),
                                        pcs_arm_drop_pass(b, fn_name, outer_scope, uses))
    EUnop(op, x)         -> EUnop(op, pcs_arm_drop_pass(x, fn_name, outer_scope, uses))
    EIf(c, t_, eo)       -> EIf(pcs_arm_drop_pass(c, fn_name, outer_scope, uses),
                                  pcs_arm_drop_pass(t_, fn_name, outer_scope, uses),
                                  pcs_arm_drop_expr_opt(eo, fn_name, outer_scope, uses))
    ERecordLit(name, fs) -> ERecordLit(name, pcs_arm_drop_fields_init(fs, fn_name, outer_scope, uses))
    EList(els)           -> EList(pcs_arm_drop_list_elems(els, fn_name, outer_scope, uses))
    ERange(a, b, opt_step) -> ERange(pcs_arm_drop_pass(a, fn_name, outer_scope, uses),
                                       pcs_arm_drop_pass(b, fn_name, outer_scope, uses),
                                       pcs_arm_drop_expr_opt(opt_step, fn_name, outer_scope, uses))
    EPipe(a, b)          -> EPipe(pcs_arm_drop_pass(a, fn_name, outer_scope, uses),
                                    pcs_arm_drop_pass(b, fn_name, outer_scope, uses))
    EMapPipe(a, b)       -> EMapPipe(pcs_arm_drop_pass(a, fn_name, outer_scope, uses),
                                       pcs_arm_drop_pass(b, fn_name, outer_scope, uses))
    EFlatMapPipe(a, b)   -> EFlatMapPipe(pcs_arm_drop_pass(a, fn_name, outer_scope, uses),
                                            pcs_arm_drop_pass(b, fn_name, outer_scope, uses))
    EFilterPipe(a, b)    -> EFilterPipe(pcs_arm_drop_pass(a, fn_name, outer_scope, uses),
                                           pcs_arm_drop_pass(b, fn_name, outer_scope, uses))
    ELitUnit(inner, u)   -> ELitUnit(pcs_arm_drop_pass(inner, fn_name, outer_scope, uses), u)
    EBang(inner)         -> EBang(pcs_arm_drop_pass(inner, fn_name, outer_scope, uses))
  }
}

fn pcs_arm_drop_expr_opt(opt: Option[Expr], fn_name: String, outer_scope: [String], uses: [Use]) : Option[Expr] / Console = match opt {
  None    -> None
  Some(x) -> Some(pcs_arm_drop_pass(x, fn_name, outer_scope, uses))
}

fn pcs_arm_drop_expr_list(es: [Expr], fn_name: String, outer_scope: [String], uses: [Use]) : [Expr] / Console = match es {
  []           -> []
  [h, ...rest] -> [pcs_arm_drop_pass(h, fn_name, outer_scope, uses),
                   ...pcs_arm_drop_expr_list(rest, fn_name, outer_scope, uses)]
}

fn pcs_arm_drop_fields_init(fs: [FieldInit], fn_name: String, outer_scope: [String], uses: [Use]) : [FieldInit] / Console = match fs {
  []           -> []
  [h, ...rest] -> [pcs_arm_drop_field_init(h, fn_name, outer_scope, uses),
                   ...pcs_arm_drop_fields_init(rest, fn_name, outer_scope, uses)]
}

fn pcs_arm_drop_field_init(fi: FieldInit, fn_name: String, outer_scope: [String], uses: [Use]) : FieldInit / Console = match fi {
  FI(name, e) -> FI(name, pcs_arm_drop_pass(e, fn_name, outer_scope, uses))
}

fn pcs_arm_drop_list_elems(els: [ListElem], fn_name: String, outer_scope: [String], uses: [Use]) : [ListElem] / Console = match els {
  []           -> []
  [h, ...rest] -> [pcs_arm_drop_list_elem(h, fn_name, outer_scope, uses),
                   ...pcs_arm_drop_list_elems(rest, fn_name, outer_scope, uses)]
}

fn pcs_arm_drop_list_elem(el: ListElem, fn_name: String, outer_scope: [String], uses: [Use]) : ListElem / Console = match el {
  ElPlain(e)  -> ElPlain(pcs_arm_drop_pass(e, fn_name, outer_scope, uses))
  ElSpread(e) -> ElSpread(pcs_arm_drop_pass(e, fn_name, outer_scope, uses))
}

fn pcs_arm_drop_stmts(stmts: [Stmt], fn_name: String, outer_scope: [String],
                       uses: [Use]) : [Stmt] / Console {
  match stmts {
    [] -> []
    [s, ...rest] -> {
      let s1 = match s {
        SLet(pat, ty_opt, rhs) ->
          SLet(pat, ty_opt, pcs_arm_drop_pass(rhs, fn_name, outer_scope, uses))
        SVar(name, ty_opt, rhs, ln, cl) ->
          SVar(name, ty_opt, pcs_arm_drop_pass(rhs, fn_name, outer_scope, uses), ln, cl)
        SAssert(c, opt_m) -> {
          let c1 = pcs_arm_drop_pass(c, fn_name, outer_scope, uses)
          let m1 = match opt_m {
            None -> None
            Some(m) -> Some(pcs_arm_drop_pass(m, fn_name, outer_scope, uses))
          }
          SAssert(c1, m1)
        }
        SExprStmt(e) -> SExprStmt(pcs_arm_drop_pass(e, fn_name, outer_scope, uses))
        SIndexAssign(b, i, v, ln, cl) ->
          SIndexAssign(pcs_arm_drop_pass(b, fn_name, outer_scope, uses),
                       pcs_arm_drop_pass(i, fn_name, outer_scope, uses),
                       pcs_arm_drop_pass(v, fn_name, outer_scope, uses), ln, cl)
        SUse(n, ln, cl) -> SUse(n, ln, cl)
      }
      [s1, ...pcs_arm_drop_stmts(rest, fn_name, outer_scope, uses)]
    }
  }
}

fn pcs_arm_drop_clauses(cs: [HClause], fn_name: String, outer_scope: [String],
                         uses: [Use]) : [HClause] / Console {
  match cs {
    [] -> []
    [h, ...rest] -> match h {
      HC(op, params, body, ln, cl) -> {
        let pn = pcs_filter_non_resume(map(params, (p) => p.pname), [])
        let scope1 = list_append(outer_scope, ["state", "log", ...pn])
        let body1 = pcs_arm_drop_pass(body, fn_name, scope1, uses)
        [HC(op, params, body1, ln, cl),
         ...pcs_arm_drop_clauses(rest, fn_name, outer_scope, uses)]
      }
    }
  }
}

fn pcs_arm_drop_arms(arms: [Arm], fn_name: String, outer_scope: [String],
                      uses: [Use]) : [Arm] / Console {

  match arms {
    [] -> []
    [a, ...rest] -> match a {
      Arm(pat, opt_g, body) -> {
        let bound = prc_pat_binders(pat, [])
        let scope1 = list_append(outer_scope, bound)
        let body1 = pcs_arm_drop_pass(body, fn_name, scope1, uses)
        # For EBlock bodies the drop site sits between stmts and
        # tail (pre-tail), so a binding read in the tail would see
        # a freed cell — we must skip those names. For non-block
        # bodies the drop site sits AFTER the body via the
        # `__pcs_arm_ret` wrap, so any read inside body is safe
        # because body fully evaluates first; in that case the
        # only unsafe bindings are ones tied to a self-tail-call
        # (handled by `pcs_inject_arm_drops`).
        let pre_tail = pcs_body_is_block_with_tail(body1)
        let drops = pcs_collect_arm_drops(bound, pat.line, pat.col, body1,
                                            outer_scope, uses, pre_tail, [])
        let body2 = match drops {
          [] -> body1
          [_, ...__] -> pcs_inject_arm_drops(body1, drops, fn_name)
        }
        [Arm(pat, opt_g, body2),
         ...pcs_arm_drop_arms(rest, fn_name, outer_scope, uses)]
      }
    }
  }
}

# Build a `[Stmt]` list of `__perceus_drop(nm)` calls for the arm's
# pattern-introduced bindings that need a drop. Order is reverse-of-
# bound (head-first accumulation + `pcs_inject_arm_drops` appends).
fn pcs_collect_arm_drops(bound: [String], ln: Int, cl: Int, body: Expr,
                          outer_scope: [String], uses: [Use], pre_tail: Bool,
                          acc: [Stmt]) : [Stmt] / Console {

  match bound {
    [] -> list_reverse(acc)
    [nm, ...rest] -> {
      let acc1 =
        if list_has(outer_scope, nm) { acc }
        else if pre_tail and pcs_name_in_body_tail(nm, body) { acc }
        else {
          # Re-scan the arm body for `nm` to get arm-local uses.
          # The fn-wide `uses` table can over-count `nm` when sibling
          # arms or unrelated scopes also bind a name `nm`; mirroring
          # the rule against the global table would emit a drop on a
          # single-use binding (the lexically-last raw read transfers
          # the ref, so a drop here would over-decref). The local
          # rescan is bounded by the arm body's size and runs only
          # for arms that introduce bindings.
          let arm_uses = pcs_collect_uses_expr(body, [nm], false, [])
          let arm_count = pcs_count_non_lam_uses(nm, arm_uses, 0)
          let in_lam = pcs_uses_have_in_lam(arm_uses, nm)
          if in_lam {
            [pcs_make_drop_stmt(nm, ln, cl), ...acc]
          } else if arm_count >= 2 {
            [pcs_make_drop_stmt(nm, ln, cl), ...acc]
          } else { acc }
        }
      pcs_collect_arm_drops(rest, ln, cl, body, outer_scope, uses, pre_tail, acc1)
    }
  }
}

fn pcs_uses_have_in_lam(uses: [Use], nm: String) : Bool {
  match uses {
    [] -> false
    [h, ...rest] -> match h {
      U(uname, _, _, in_lam) ->
        if uname == nm and in_lam { true }
        else { pcs_uses_have_in_lam(rest, nm) }
    }
  }
}

fn pcs_body_is_block_with_tail(body: Expr) : Bool {
  match body.kind {
    EBlock(_, opt_tail) -> match opt_tail {
      None -> false
      Some(_) -> true
    }
    _ -> false
  }
}

# Insert drops into the arm body. Three shapes:
#   - body is `EBlock(stmts, opt_tail)`: append drops between stmts
#     and tail. The tail position is preserved so `tcrec_rewrite_decls`
#     can still detect a self-tail-call inside the tail expression.
#   - body is a non-block expression that itself is a self-tail-call
#     (`ECall(EVar(fn_name), args)`): leave alone. Wrapping it would
#     hide the call from the TCO rewrite and risk a stack overflow
#     (same regression #342 worked around). The drops are skipped —
#     bindings appearing in tail are filtered upstream, so this
#     only fires when the body has no draftable drops anyway.
#   - body is any other non-block expression: wrap as
#     `EBlock([SLet(__pcs_arm_ret, body), ...drops], Some(EVar(__pcs_arm_ret)))`.
#     The body executes first (with its bindings live), the drops run
#     before the wrapped block returns the saved value.
fn pcs_inject_arm_drops(body: Expr, drops: [Stmt], fn_name: String) : Expr {
  match body.kind {
    EBlock(stmts, opt_tail) ->
      Expr { kind: EBlock(list_append(stmts, drops), opt_tail),
             line: body.line, col: body.col, ty: body.ty, mode: body.mode }
    _ -> {
      if pcs_is_self_tail_call(body, fn_name) { body }
      else {
        let ret_name = "__pcs_arm_ret"
        let ret_let = SLet(
          Pattern { pkind: PBind(ret_name), line: body.line, col: body.col },
          None,
          body
        )
        let stmts = [ret_let, ...drops]
        let tail = Expr { kind: EVar(ret_name), line: body.line, col: body.col,
                          ty: body.ty, mode: body.mode }
        Expr { kind: EBlock(stmts, Some(tail)),
               line: body.line, col: body.col, ty: body.ty, mode: body.mode }
      }
    }
  }
}

fn pcs_is_self_tail_call(e: Expr, fn_name: String) : Bool {
  match e.kind {
    ECall(callee, _) -> match callee.kind {
      EVar(nm) -> nm == fn_name
      _ -> false
    }
    # A `match`, `if`, or `block` body may itself host a self-tail-call
    # in a tail-leaf position. Wrapping such a body in `__pcs_arm_ret`
    # would hide that call from `tcrec_rewrite_decls` and emit a real
    # recursive C call — same regression #342 worked around. Recurse
    # into tail-leaves and decline to wrap when any leaf is a
    # self-tail-call.
    EMatch(_, arms) -> pcs_arms_have_self_tail(arms, fn_name)
    EIf(_, t, opt_e) -> {
      if pcs_is_self_tail_call(t, fn_name) { true }
      else {
        match opt_e {
          None -> false
          Some(e2) -> pcs_is_self_tail_call(e2, fn_name)
        }
      }
    }
    EBlock(_, opt_tail) -> match opt_tail {
      None -> false
      Some(t) -> pcs_is_self_tail_call(t, fn_name)
    }
    _ -> false
  }
}

fn pcs_arms_have_self_tail(arms: [Arm], fn_name: String) : Bool {
  match arms {
    [] -> false
    [a, ...rest] -> match a {
      Arm(_, _, body) ->
        if pcs_is_self_tail_call(body, fn_name) { true }
        else { pcs_arms_have_self_tail(rest, fn_name) }
    }
  }
}

# True iff `nm` appears anywhere in the body's tail expression.
# For EBlock bodies the drop site sits between stmts and tail, so
# any read of `nm` in the tail expression (regardless of how deeply
# nested) would see a decremented binding. For non-block bodies
# the whole expression is treated as the tail. A scan over the
# expression with `[nm]` as the in-scope filter spots every read.
fn pcs_name_in_body_tail(nm: String, body: Expr) : Bool / Console {

  match body.kind {
    EBlock(_, opt_tail) -> match opt_tail {
      None -> false
      Some(t) -> {
        let us = pcs_collect_uses_expr(t, [nm], false, [])
        pcs_uses_has_name(us, nm)
      }
    }
    _ -> {
      let us = pcs_collect_uses_expr(body, [nm], false, [])
      pcs_uses_has_name(us, nm)
    }
  }
}

# ---- m5 #2 — last-use analysis (fn-param scope) ----
#
# For each `pub fn` parameter, find the lexical position of its last
# direct read in the body. Reads inside an `ELambda` body are
# conservatively treated as closure captures and BLOCK "last": the
# lambda may survive past its own evaluation point, so the captured
# binding is alive until the closure dies. m5 #2 stays at fn-param
# scope; let-bindings, match-pattern bindings, and closure-aware
# data-flow refinement land in m5 #2b / m5 #3.
#
# Output is diagnostic only — `--dump-last-use` prints one line per
# parameter:
#   fn add@10:
#     param x: last-use at 10:32
#     param y: last-use at 10:36
#     param z: blocked by closure capture
#     param u: never used
# m5 #3 will consume the same `last_use_for` result to drive drop
# emission.

#[doc("Last-use classification (LUUnused / LUBlocked / LUAt) for a name over a [Use] list. Pub because the tco pre-pass in main consults it to align goto-loop drops.")]
pub fn last_use_for(nm: String, uses: [Use]) : LU =
  last_use_for_loop(nm, uses, false, -1, -1)

fn last_use_for_loop(nm: String, uses: [Use], blocked: Bool,
                     mx_line: Int, mx_col: Int) : LU {
  match uses {
    [] -> {
      if blocked { LUBlocked(nm) }
      else if mx_line < 0 { LUUnused(nm) }
      else { LUAt(nm, mx_line, mx_col) }
    }
    [h, ...rest] -> match h {
      U(uname, ln, cl, in_lam) -> {
        if uname == nm {
          if in_lam {
            last_use_for_loop(nm, rest, true, mx_line, mx_col)
          } else if ln > mx_line or (ln == mx_line and cl > mx_col) {
            last_use_for_loop(nm, rest, blocked, ln, cl)
          } else {
            last_use_for_loop(nm, rest, blocked, mx_line, mx_col)
          }
        } else {
          last_use_for_loop(nm, rest, blocked, mx_line, mx_col)
        }
      }
    }
  }
}
