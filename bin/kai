#!/bin/sh
# kai — stage 2 compiler driver.
#
# Subcommands:
#   kai build <file.kai> [-o <out>]   compile to a native binary
#   kai run   <file.kai> [args...]    compile and execute; forward args
#   kai test  <file.kai>              compile with --test and run
#   kai bench <file.kai>              compile with --bench and run
#   kai check <file.kai>              compile with --prop-check and run
#                                      (property-based tests, issue #44)
#   kai help                          show this help
#   kai --version                     print version
#
# The driver wraps kaic2 + cc. It auto-builds stages 0/1/2 on first
# use if their binaries are missing. Paths resolve relative to this
# script's own location, so the script works from any working
# directory.
#
# Auto-loaded preludes (in order): stdlib/core/*.kai sorted
# alphabetically (char before string is required because
# string_trim_*_loop calls ch_is_space), stdlib/protocols.kai
# (Show/Eq/Ord/Hash/Serialize for primitives), stdlib/effects.kai
# (Stdin/Stdout/Stderr/File/Env declarations, created in m12.8.x
# phase 4), stdlib/random.kai (shuffle / choice / sample on top of
# the Random effect). Each is opt-out via env var KAI_NO_STDLIB=1
# (skips all) or by deleting the file.

set -eu

# kaic1/kaic2 lex their input recursively (lex_loop is not TCO'd in
# stage 0's C output). On ~10 k-line sources the default 8 MB thread
# stack overflows. Bump to 32 MB; ignore failure on shells/systems
# that reject it.
ulimit -s 32768 2>/dev/null || true

# Resolve script path portably (macOS lacks GNU readlink -f).
SCRIPT="$0"
case "$SCRIPT" in
  /*) ;;
  *)  SCRIPT="$(pwd)/$SCRIPT" ;;
esac
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# Layout detection — dev checkout vs installed tarball.
#
# Dev checkout: $ROOT contains stage0/, stage1/, stage2/ source dirs and
# stdlib/ at the top level. Used during development from a git clone.
#
# Installed: $ROOT contains libexec/kaikai/kaic2 (the binary), share/kaikai/
# stdlib (sources), and share/kaikai/include/runtime.h. Used after a release
# tarball is extracted to a prefix like /usr/local or ~/.local.
#
# KAI_STDLIB and KAI_INCLUDE env vars override the resolved paths if set
# (useful for running an installed kai against an experimental stdlib copy).
if [ -d "$ROOT/stage0" ] && [ -d "$ROOT/stdlib" ]; then
  KAIC0="$ROOT/stage0/kaic0"
  KAIC1="$ROOT/stage1/kaic1"
  KAIC2="$ROOT/stage2/kaic2"
  RUNTIME_INC="$ROOT/stage0"
  STDLIB_ROOT="$ROOT/stdlib"
  KAI_LAYOUT="dev"
elif [ -x "$ROOT/libexec/kaikai/kaic2" ] && [ -d "$ROOT/share/kaikai/stdlib" ]; then
  KAIC0=""   # not shipped — only needed for the bootstrap chain
  KAIC1=""   # not shipped — only needed for the bootstrap chain
  KAIC2="$ROOT/libexec/kaikai/kaic2"
  RUNTIME_INC="$ROOT/share/kaikai/include"
  STDLIB_ROOT="$ROOT/share/kaikai/stdlib"
  KAI_LAYOUT="installed"
else
  echo "kai: error: cannot find kaikai installation under $ROOT" >&2
  echo "  expected dev layout (stage0/, stdlib/) or installed layout (libexec/kaikai/, share/kaikai/)" >&2
  exit 2
fi

# Allow overriding the discovered locations.
STDLIB_ROOT="${KAI_STDLIB:-$STDLIB_ROOT}"
RUNTIME_INC="${KAI_INCLUDE:-$RUNTIME_INC}"

STDLIB_CORE_DIR="$STDLIB_ROOT/core"
STDLIB_PROTOCOLS="$STDLIB_ROOT/protocols.kai"
STDLIB_EFFECTS="$STDLIB_ROOT/effects.kai"
STDLIB_ARRAY="$STDLIB_ROOT/array.kai"
STDLIB_RANDOM="$STDLIB_ROOT/random.kai"
STDLIB_RANDOM_SECURE="$STDLIB_ROOT/random_secure.kai"
STDLIB_BASE64="$STDLIB_ROOT/encoding/base64.kai"
STDLIB_HEX="$STDLIB_ROOT/encoding/hex.kai"
STDLIB_MAP="$STDLIB_ROOT/collections/map.kai"
STDLIB_SET="$STDLIB_ROOT/collections/set.kai"
STDLIB_QUEUE="$STDLIB_ROOT/collections/queue.kai"
STDLIB_STACK="$STDLIB_ROOT/collections/stack.kai"
STDLIB_MATH_NUMERIC="$STDLIB_ROOT/math/numeric.kai"
STDLIB_MATH_INT="$STDLIB_ROOT/math/int.kai"
STDLIB_MATH_REAL="$STDLIB_ROOT/math/real.kai"
STDLIB_MATH_COMPLEX="$STDLIB_ROOT/math/complex.kai"
STDLIB_JSON="$STDLIB_ROOT/encoding/json.kai"
STDLIB_DECIMAL="$STDLIB_ROOT/decimal.kai"
STDLIB_MONEY="$STDLIB_ROOT/money.kai"
STDLIB_FX="$STDLIB_ROOT/fx.kai"
STDLIB_UUID="$STDLIB_ROOT/uuid.kai"
STDLIB_REGEXP="$STDLIB_ROOT/regexp.kai"
STDLIB_PATH="$STDLIB_ROOT/path.kai"
STDLIB_CRYPTO_HASH="$STDLIB_ROOT/crypto/hash.kai"
STDLIB_CRYPTO_MAC="$STDLIB_ROOT/crypto/mac.kai"

CC="${CC:-cc}"
CFLAGS="${CFLAGS:--std=c99 -Wno-unused-function -Wno-unused-variable -O2}"

die() {
  echo "kai: error: $*" >&2
  exit 2
}

# $1 = path that was not found; $2 = subcommand name (build/run/test)
die_file_not_found() {
  echo "kai: error: file '$1' not found." >&2
  echo "Try 'kai $2 --help' for usage." >&2
  exit 2
}

read_version() {
  if [ -f "$ROOT/VERSION" ]; then
    cat "$ROOT/VERSION"
  elif [ -f "$ROOT/share/kaikai/VERSION" ]; then
    cat "$ROOT/share/kaikai/VERSION"
  else
    echo "unknown"
  fi
}

read_baseline() {
  if [ -f "$ROOT/demos/baseline.txt" ]; then
    cat "$ROOT/demos/baseline.txt"
  elif [ -f "$ROOT/share/kaikai/demos/baseline.txt" ]; then
    cat "$ROOT/share/kaikai/demos/baseline.txt"
  else
    echo "?"
  fi
}

ensure_built() {
  # Installed layout ships a prebuilt kaic2 — bootstrap chain is not needed.
  if [ "$KAI_LAYOUT" = "installed" ]; then
    if [ ! -x "$KAIC2" ]; then
      die "kaic2 binary missing at $KAIC2 — installation is corrupt"
    fi
    return 0
  fi
  if [ ! -x "$KAIC0" ]; then
    (cd "$ROOT/stage0" && make kaic0) >&2
  fi
  if [ ! -x "$KAIC1" ]; then
    (cd "$ROOT/stage1" && make kaic1) >&2
  fi
  if [ ! -x "$KAIC2" ]; then
    (cd "$ROOT/stage2" && make kaic2) >&2
  fi
}

usage() {
  v="$(read_version)"
  cat <<EOF
 _      _ _      _
| |____(_) |____(_)    kaikai $v
| / / _\` | / / _\` |    a statically typed functional language
|_\\_\\__,_|_\\_\\__,_|    effects | fibers | protocols

usage: kai <command> [args...]

Commands:
  build <file.kai> [-o <out>]   Compile a kaikai file to a native binary.
  run   <file.kai> [args...]    Build and execute; forwards remaining args.
  test  <file.kai>              Compile with --test and run the test binary.
  bench <file.kai>              Compile with --bench and run the bench binary.
  check <file.kai>              Compile with --prop-check and run property
                                blocks (issue #44).
  fmt   <file.kai> [--check]    Pretty-print kaikai source canonically.
  watch <file.kai>              Recompile + run on every save (live demo).
  help                          Show this help.
  --version                     Print version and demo baseline.

Run 'kai <command> --help' for command-specific options.

Environment:
  CC               C compiler to invoke (default: cc).
  CFLAGS           Extra flags passed to CC.
  KAI_NO_STDLIB    If 1, skip auto-loading the stdlib preludes.
  KAI_STDLIB       Override the stdlib root directory (default: auto-detected
                   from the script's location — share/kaikai/stdlib if installed,
                   stdlib/ if running from a dev checkout).
  KAI_INCLUDE      Override the runtime.h include directory (default: auto-
                   detected — share/kaikai/include if installed, stage0/ if dev).

See README.md and docs/ for the language reference.
Project home: https://kaikai-lang.org
EOF
}

usage_build() {
  cat <<EOF
usage: kai build <file.kai> [-o <out>]

Compile a kaikai source file to a native binary using kaic2 + cc.

Options:
  -o <out>     Output binary path (default: basename of input without .kai).
  -h, --help   Show this help.

Examples:
  kai build hello.kai                    # produces ./hello
  kai build src/app.kai -o build/app     # produces ./build/app

The compiler auto-loads the stdlib preludes (stdlib/core, protocols,
effects, etc.). Set KAI_NO_STDLIB=1 to skip them.
EOF
}

usage_run() {
  cat <<EOF
usage: kai run <file.kai> [args...]

Compile and immediately execute a kaikai program. Any arguments after
the source file are forwarded to the compiled binary.

Options:
  -h, --help   Show this help.

Examples:
  kai run examples/minimal/hello.kai
  kai run demos/fizzbuzz/fizzbuzz.kai 30
  kai run app.kai --user alice --port 8080

The temporary binary is removed after the program exits.
EOF
}

usage_test() {
  cat <<EOF
usage: kai test [options] <file.kai>

Compile a kaikai source with --test enabled and run the test binary.
The compiler emits a main that runs every 'test "..." { ... }' block
defined in <file.kai> and reports the result.

Tests defined inside the auto-loaded stdlib preludes are dropped at
load time (issue #318) so the count reflects only the user's tests.

Options:
  -h, --help                Show this help.
  --include-prelude-tests   Also run test blocks defined inside the
                            stdlib preludes (legacy behaviour).

Examples:
  kai test stage2/tests/test_lex.kai
  kai test demos/poker/poker.kai
  kai test --include-prelude-tests demos/poker/poker.kai
EOF
}

usage_bench() {
  cat <<EOF
usage: kai bench <file.kai>

Compile a kaikai source with --bench enabled and run the bench binary.
The compiler emits a main that runs every 'bench "..." { ... }' block
under clock_gettime(CLOCK_MONOTONIC) and reports the mean ns/iter.

bench v1 (issue #40): N is fixed at 1000 iterations and only mean
ns/iter is reported. Median + MAD-based outlier stats, configurable
iteration counts, and selfhost-bench arrive in v1.x / v1.y.

Options:
  -h, --help   Show this help.

Examples:
  kai bench examples/stdlib/bench_basic.kai
EOF
}

usage_check() {
  cat <<EOF
usage: kai check <file.kai>

Compile a kaikai source with --prop-check enabled and run the
property-check binary. The compiler emits a main that runs every
'check "..." [with p: T, ...] { body }' block KAI_CHECK_ITERS times
(default 100), generating fresh random values for the with-clause
params on each iteration via the runtime arbitrary[T] helpers.

Per-block output:
  <desc>: 100 iter, OK
  <desc>: counterexample at iter <N>: p=<v>, q=<v>, ...

Followed by a 'P/T checks passed' summary; exit 1 if any block
recorded a counterexample.

check v1 (issue #44): supported with-clause types are Int, Bool,
Char, String, and lists of those primitives. Other types raise a
panic at runtime. Shrinking is deferred to v1.x; protocol-based
generators (impl Arbitrary for T) defer to v2 post-protocol
maturity.

Options:
  -h, --help   Show this help.

Examples:
  kai check examples/stdlib/check_basic.kai
EOF
}

usage_watch() {
  cat <<EOF
usage: kai watch <file.kai> [args...]

Watch a kaikai source file and recompile + run it on every save.
Useful for live demos: edit in one pane, see output in the other.

Behavior:
  - On entry, the file is compiled and run once.
  - On each save, the screen prints a timestamped header followed by
    the compile result. Build errors keep the watch loop alive.
  - Press Ctrl+C to exit.

Backend:
  - If fswatch is on PATH, kai uses it (one event per save).
  - Otherwise, kai falls back to a 500 ms mtime poll. Install
    fswatch (brew install fswatch) for lower latency.

Options:
  -h, --help   Show this help.

Examples:
  kai watch demo.kai
  kai watch examples/minimal/hello.kai
EOF
}

usage_fmt() {
  cat <<EOF
usage: kai fmt <file.kai>            # rewrite file in place
       kai fmt --check <file.kai>    # exit 0 if formatted, 1 if not
       kai fmt --stdin               # read stdin -> formatted to stdout

Pretty-print kaikai source canonically. The formatter is gofmt-style:
no options, single output, idempotent.

Tongariki MVP scope: imports, simple fns, type decls, tests, and the
base expression / pattern / type grammar (see CHANGELOG for the exact
list). Files using effects, handlers, protocols, impls, units, dim
types, refinements, axioms, generic fn / type parameters, var, or
parametric effect rows are refused with an explicit error.

Options:
  --check      Do not modify the file. Exit 0 if already formatted; 1
               otherwise. Print the formatted output to stdout when
               different.
  --stdin      Read kaikai source from stdin; write formatted source
               to stdout. The file form (kai fmt <file>) rewrites the
               file in place; this form is for editor integrations.
  -h, --help   Show this help.

Examples:
  kai fmt stage2/compiler.kai
  kai fmt --check src/foo.kai && echo OK
  cat src/foo.kai | kai fmt --stdin > /tmp/foo-fmt.kai
EOF
}

print_version() {
  v="$(read_version)"
  baseline="$(read_baseline)"
  cat <<EOF
kaikai $v (stage 2, self-hosted)
demos baseline: $baseline
home:           https://kaikai-lang.org
EOF
}

# $1 = source .kai path; $2 = tmpdir; $3 = output binary path;
# $4 = subcommand name (for help-pointer in errors); rest = extra kaic2 flags
compile_to_binary() {
  src="$1"; tmp="$2"; out="$3"; sub="$4"; shift 4
  [ -f "$src" ] || die_file_not_found "$src" "$sub"
  ensure_built
  prelude_flags=""
  if [ "${KAI_NO_STDLIB:-}" != "1" ]; then
    if [ -d "$STDLIB_CORE_DIR" ]; then
      for core_file in "$STDLIB_CORE_DIR"/*.kai; do
        [ -f "$core_file" ] && prelude_flags="$prelude_flags --prelude $core_file"
      done
    fi
    [ -f "$STDLIB_PROTOCOLS" ] && prelude_flags="$prelude_flags --prelude $STDLIB_PROTOCOLS"
    [ -f "$STDLIB_EFFECTS" ]   && prelude_flags="$prelude_flags --prelude $STDLIB_EFFECTS"
    [ -f "$STDLIB_ARRAY" ]     && prelude_flags="$prelude_flags --prelude $STDLIB_ARRAY"
    [ -f "$STDLIB_RANDOM" ]    && prelude_flags="$prelude_flags --prelude $STDLIB_RANDOM"
    [ -f "$STDLIB_RANDOM_SECURE" ] && prelude_flags="$prelude_flags --prelude $STDLIB_RANDOM_SECURE"
    [ -f "$STDLIB_BASE64" ]    && prelude_flags="$prelude_flags --prelude $STDLIB_BASE64"
    [ -f "$STDLIB_HEX" ]       && prelude_flags="$prelude_flags --prelude $STDLIB_HEX"
    [ -f "$STDLIB_MAP" ]       && prelude_flags="$prelude_flags --prelude $STDLIB_MAP"
    [ -f "$STDLIB_SET" ]       && prelude_flags="$prelude_flags --prelude $STDLIB_SET"
    [ -f "$STDLIB_QUEUE" ]     && prelude_flags="$prelude_flags --prelude $STDLIB_QUEUE"
    [ -f "$STDLIB_STACK" ]     && prelude_flags="$prelude_flags --prelude $STDLIB_STACK"
    [ -f "$STDLIB_MATH_NUMERIC" ] && prelude_flags="$prelude_flags --prelude $STDLIB_MATH_NUMERIC"
    [ -f "$STDLIB_MATH_INT" ]     && prelude_flags="$prelude_flags --prelude $STDLIB_MATH_INT"
    [ -f "$STDLIB_MATH_REAL" ]    && prelude_flags="$prelude_flags --prelude $STDLIB_MATH_REAL"
    [ -f "$STDLIB_MATH_COMPLEX" ] && prelude_flags="$prelude_flags --prelude $STDLIB_MATH_COMPLEX"
    [ -f "$STDLIB_JSON" ]      && prelude_flags="$prelude_flags --prelude $STDLIB_JSON"
    [ -f "$STDLIB_DECIMAL" ]   && prelude_flags="$prelude_flags --prelude $STDLIB_DECIMAL"
    [ -f "$STDLIB_MONEY" ]     && prelude_flags="$prelude_flags --prelude $STDLIB_MONEY"
    [ -f "$STDLIB_FX" ]        && prelude_flags="$prelude_flags --prelude $STDLIB_FX"
    [ -f "$STDLIB_UUID" ]      && prelude_flags="$prelude_flags --prelude $STDLIB_UUID"
    [ -f "$STDLIB_REGEXP" ]    && prelude_flags="$prelude_flags --prelude $STDLIB_REGEXP"
    [ -f "$STDLIB_PATH" ]      && prelude_flags="$prelude_flags --prelude $STDLIB_PATH"
    [ -f "$STDLIB_CRYPTO_HASH" ] && prelude_flags="$prelude_flags --prelude $STDLIB_CRYPTO_HASH"
    [ -f "$STDLIB_CRYPTO_MAC" ]  && prelude_flags="$prelude_flags --prelude $STDLIB_CRYPTO_MAC"
  fi
  # shellcheck disable=SC2086
  # KAI_TRACE_RC unset for the compiler invocation: we want the trace
  # to come from the user's compiled program, not from kaic2 itself.
  # Without this the wrapper's compile step and the child binary both
  # fire their RC reports, doubling the output. Note: a real `unset`
  # is required — `KAI_TRACE_RC= cmd` only sets the var to the empty
  # string, but the runtime gates the report on `getenv() != NULL`,
  # which is still true for an empty value (issue #81).
  # Auto-add the entry file's own directory to the module search path so
  # `kai run main.kai` finds sibling modules (issue #233). kaic2 already
  # tries `dir_of(root_path)` before the --path entries internally
  # (see stage2/compiler.kai expand_imports / find_module_file), so this
  # is defense-in-depth: it makes the contract explicit at the driver
  # level and survives any future change to that internal first-try.
  # `dirname` works for both absolute and relative `$src`. We then
  # `cd … && pwd` to resolve to absolute so the path passed to kaic2 is
  # unambiguous regardless of CWD — a relative `.` from a bare
  # `hello.kai` would otherwise alias the user's CWD and conflict with
  # the resolver's CWD-relative lookup (issue #237).
  src_dir="$(cd "$(dirname "$src")" && pwd)"
  (unset KAI_TRACE_RC; "$KAIC2" --path "$STDLIB_ROOT" --path "$src_dir" $prelude_flags "$@" "$src") > "$tmp/out.c"
  # shellcheck disable=SC2086
  # `-lm` (issue #343): math/real libm bindings (sqrt, sin, log, …)
  # are unresolved on Linux glibc without an explicit link line.
  # macOS libSystem already exposes them, so the flag is a no-op.
  $CC $CFLAGS -I "$RUNTIME_INC" "$tmp/out.c" -o "$out" -lm
}

cmd_build() {
  src=""; out=""
  while [ $# -gt 0 ]; do
    case "$1" in
      -o) shift; [ $# -gt 0 ] || die "-o needs an argument"; out="$1"; shift ;;
      -h|--help) usage_build; return 0 ;;
      -*) die "unknown flag: $1 (see 'kai build --help')" ;;
      *) [ -z "$src" ] || die "only one input file supported"; src="$1"; shift ;;
    esac
  done
  [ -n "$src" ] || die "missing input file (see 'kai build --help')"
  if [ -z "$out" ]; then
    out="$(basename "$src" .kai)"
  fi
  tmp="$(mktemp -d)"
  trap 'rm -rf "$tmp"' EXIT INT TERM
  compile_to_binary "$src" "$tmp" "$out" "build"
}

cmd_run() {
  case "${1:-}" in
    -h|--help) usage_run; return 0 ;;
    "") die "missing input file (see 'kai run --help')" ;;
  esac
  src="$1"; shift
  tmp="$(mktemp -d)"
  trap 'rm -rf "$tmp"' EXIT INT TERM
  bin="$tmp/$(basename "$src" .kai)"
  compile_to_binary "$src" "$tmp" "$bin" "run"
  "$bin" "$@"
}

cmd_test() {
  # Issue #318: parse `--include-prelude-tests` here so we can forward
  # it to kaic2 alongside the implicit `--test`. Any non-flag argument
  # is the source file; everything else gets passed straight through.
  extra_flags=""
  while [ $# -gt 0 ]; do
    case "$1" in
      -h|--help) usage_test; return 0 ;;
      --include-prelude-tests) extra_flags="$extra_flags --include-prelude-tests"; shift ;;
      --) shift; break ;;
      -*) extra_flags="$extra_flags $1"; shift ;;
      *) break ;;
    esac
  done
  case "${1:-}" in
    "") die "missing input file (see 'kai test --help')" ;;
  esac
  src="$1"; shift
  tmp="$(mktemp -d)"
  trap 'rm -rf "$tmp"' EXIT INT TERM
  bin="$tmp/$(basename "$src" .kai)-t"
  # shellcheck disable=SC2086
  compile_to_binary "$src" "$tmp" "$bin" "test" --test $extra_flags
  "$bin"
}

cmd_bench() {
  case "${1:-}" in
    -h|--help) usage_bench; return 0 ;;
    "") die "missing input file (see 'kai bench --help')" ;;
  esac
  src="$1"; shift
  tmp="$(mktemp -d)"
  trap 'rm -rf "$tmp"' EXIT INT TERM
  bin="$tmp/$(basename "$src" .kai)-b"
  compile_to_binary "$src" "$tmp" "$bin" "bench" --bench
  "$bin"
}

cmd_check() {
  case "${1:-}" in
    -h|--help) usage_check; return 0 ;;
    "") die "missing input file (see 'kai check --help')" ;;
  esac
  src="$1"; shift
  tmp="$(mktemp -d)"
  trap 'rm -rf "$tmp"' EXIT INT TERM
  bin="$tmp/$(basename "$src" .kai)-c"
  compile_to_binary "$src" "$tmp" "$bin" "check" --prop-check
  "$bin"
}

# kai fmt — pretty-print kaikai source canonically.
#
# Three input modes:
#   kai fmt <file>             -> rewrite <file> in place
#   kai fmt --check <file>     -> exit 1 if <file> would change, else 0;
#                                  print formatted text to stdout when
#                                  different (matches `gofmt -l` spirit
#                                  but with the diff in the body).
#   kai fmt --stdin            -> read stdin, write formatted to stdout.
#
# The formatter is implemented as a `kaic2 --fmt` (or `--fmt-check`)
# subcommand. The driver does NOT pass `--prelude` flags here — fmt
# runs at the source-text level and never resolves names; the prelude
# would only slow the parse and the unsupported-check.
cmd_fmt() {
  src=""; mode_check=""; stdin_mode=""
  while [ $# -gt 0 ]; do
    case "$1" in
      -h|--help) usage_fmt; return 0 ;;
      --check)   mode_check=1; shift ;;
      --stdin)   stdin_mode=1; shift ;;
      -*)        die "unknown flag: $1 (see 'kai fmt --help')" ;;
      *)         [ -z "$src" ] || die "only one input file supported"
                 src="$1"; shift ;;
    esac
  done
  ensure_built

  if [ -n "$stdin_mode" ]; then
    [ -z "$src" ] || die "--stdin takes no file argument"
    tmp="$(mktemp -d)"
    trap 'rm -rf "$tmp"' EXIT INT TERM
    cat > "$tmp/in.kai"
    "$KAIC2" --fmt "$tmp/in.kai"
    return $?
  fi

  [ -n "$src" ] || die "missing input file (see 'kai fmt --help')"
  [ -f "$src" ] || die_file_not_found "$src" "fmt"

  if [ -n "$mode_check" ]; then
    "$KAIC2" --fmt-check "$src"
    return $?
  fi

  tmp="$(mktemp -d)"
  trap 'rm -rf "$tmp"' EXIT INT TERM
  if "$KAIC2" --fmt "$src" > "$tmp/out.kai"; then
    # Only write back when the formatted text differs (avoids touching
    # the file mtime on a no-op).
    if ! cmp -s "$src" "$tmp/out.kai"; then
      cat "$tmp/out.kai" > "$src"
    fi
  else
    cat "$tmp/out.kai" >&2 2>/dev/null || true
    return 1
  fi
}

# kai watch — recompile + run on every save.
#
# Two backends:
#   1. fswatch -o "$src"   → one line per change event (lowest latency).
#   2. mtime poll (500 ms) → portable fallback when fswatch is absent.
#
# The compile/run cycle runs once immediately on entry so the audience
# sees output before they touch the file. Build failures do not exit
# the loop — the watcher keeps running so the next save retries.
file_mtime() {
  if stat -f %m "$1" 2>/dev/null; then
    return 0
  fi
  stat -c %Y "$1" 2>/dev/null || echo 0
}

watch_run_once() {
  src="$1"; tmp="$2"
  bin="$tmp/$(basename "$src" .kai)"
  ts="$(date '+%H:%M:%S')"
  if compile_to_binary "$src" "$tmp" "$bin" "watch" 2>"$tmp/err"; then
    printf '\n[%s] Build OK\n' "$ts"
    "$bin" || printf '\n[%s] Program exited with status %d\n' "$ts" "$?"
  else
    printf '\n[%s] Build FAILED\n' "$ts"
    cat "$tmp/err" >&2
  fi
}

cmd_watch() {
  case "${1:-}" in
    -h|--help) usage_watch; return 0 ;;
    "") die "missing input file (see 'kai watch --help')" ;;
  esac
  src="$1"; shift
  [ -f "$src" ] || die_file_not_found "$src" "watch"
  abs_src="$(cd "$(dirname "$src")" && pwd)/$(basename "$src")"
  tmp="$(mktemp -d)"
  trap 'rm -rf "$tmp"' EXIT INT TERM

  printf 'kaikai watch — recompiling on every save\n'
  printf 'Watching: %s\n' "$abs_src"
  if command -v fswatch >/dev/null 2>&1; then
    printf '(backend: fswatch)\n'
  else
    printf '(backend: mtime poll @ 500ms — install fswatch for lower latency)\n'
  fi

  watch_run_once "$abs_src" "$tmp"

  if command -v fswatch >/dev/null 2>&1; then
    fswatch -o "$abs_src" | while read -r _; do
      watch_run_once "$abs_src" "$tmp"
    done
  else
    last="$(file_mtime "$abs_src")"
    while :; do
      sleep 0.5 2>/dev/null || sleep 1
      cur="$(file_mtime "$abs_src")"
      if [ "$cur" != "$last" ]; then
        last="$cur"
        watch_run_once "$abs_src" "$tmp"
      fi
    done
  fi
}

case "${1:-}" in
  build)     shift; cmd_build "$@" ;;
  run)       shift; cmd_run   "$@" ;;
  test)      shift; cmd_test  "$@" ;;
  bench)     shift; cmd_bench "$@" ;;
  check)     shift; cmd_check "$@" ;;
  fmt)       shift; cmd_fmt   "$@" ;;
  watch)     shift; cmd_watch "$@" ;;
  help|-h|--help) usage ;;
  --version|-V) print_version ;;
  "")        usage >&2; exit 2 ;;
  *)         echo "kai: error: unknown command: $1" >&2; usage >&2; exit 2 ;;
esac
