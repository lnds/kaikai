#!/bin/sh
# kai — stage 2 compiler driver.
#
# Subcommands:
#   kai build <file.kai> [-o <out>]   compile to a native binary
#   kai run   <file.kai> [args...]    compile and execute; forward args
#   kai test  <file.kai>              compile with --test and run
#   kai bench [--iters N] <file.kai>  compile with --bench and run
#   kai check <file.kai>              compile with --prop-check and run
#                                      (property-based tests, issue #44)
#   kai help                          show this help
#   kai --version                     print version
#
# The driver wraps kaic2 + cc. It auto-builds stages 0/1/2 on first
# use if their binaries are missing. Paths resolve relative to this
# script's own location, so the script works from any working
# directory.
#
# Auto-loaded core modules — the Hanga Roa "core" set. Anything else
# under stdlib/ requires explicit `import` from user code.
#
#   stdlib/core/*.kai      sorted alphabetically (char before string
#                          because string_trim_*_loop calls
#                          ch_is_space). Includes complex.kai so the
#                          `2.5i` imaginary literal and Complex
#                          arithmetic work without an import.
#   stdlib/protocols.kai   Show/Eq/Ord/Hash/Serialize/BinSerialize.
#   stdlib/effects.kai     Stdin/Stdout/Stderr/File/Env/Console.
#   stdlib/array.kai       Array[T] helpers; Array itself is a runtime
#                          primitive.
#
# Everything else (decimal, money, math/int, math/real, regexp,
# collections/*, encoding/*, crypto/*, random*, fx, uuid, path) is
# opt-in via `import <name>` — see docs/stdlib-layout.md §*Core vs.
# opt-in*.

set -eu

# kaic1/kaic2 lex their input recursively (lex_loop is not TCO'd in
# stage 0's C output). On ~10 k-line sources the default 8 MB thread
# stack overflows. Bump to 32 MB; ignore failure on shells/systems
# that reject it.
ulimit -s 32768 2>/dev/null || true

# Resolve script path portably (macOS lacks GNU readlink -f).
SCRIPT="$0"
case "$SCRIPT" in
  /*) ;;
  *)  SCRIPT="$(pwd)/$SCRIPT" ;;
esac
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# Layout detection — dev checkout vs installed tarball.
#
# Dev checkout: $ROOT contains stage0/, stage1/, stage2/ source dirs and
# stdlib/ at the top level. Used during development from a git clone.
#
# Installed: $ROOT contains libexec/kaikai/kaic2 (the binary), share/kaikai/
# stdlib (sources), and share/kaikai/include/runtime.h. Used after a release
# tarball is extracted to a prefix like /usr/local or ~/.local.
#
# KAI_STDLIB and KAI_INCLUDE env vars override the resolved paths if set
# (useful for running an installed kai against an experimental stdlib copy).
if [ -d "$ROOT/stage0" ] && [ -d "$ROOT/stdlib" ]; then
  KAIC0="$ROOT/stage0/kaic0"
  KAIC1="$ROOT/stage1/kaic1"
  KAIC2="$ROOT/stage2/kaic2"
  RUNTIME_INC="$ROOT/stage0"
  # The C backend (kaic2-emitted C) requires stage 2's Koka-style
  # runtime.h (tagged Int, kai_intf, reuse-token). It must resolve
  # BEFORE stage0/runtime.h, which is the old heap-everything runtime
  # kept only for the stage0/stage1 bootstrap chain and the LLVM
  # backend's runtime_llvm.c. See the C-backend compile line below.
  RUNTIME_INC_C="$ROOT/stage2"
  STDLIB_ROOT="$ROOT/stdlib"
  KAI_LAYOUT="dev"
elif [ -x "$ROOT/libexec/kaikai/kaic2" ] && [ -d "$ROOT/share/kaikai/stdlib" ]; then
  KAIC0=""   # not shipped — only needed for the bootstrap chain
  KAIC1=""   # not shipped — only needed for the bootstrap chain
  KAIC2="$ROOT/libexec/kaikai/kaic2"
  RUNTIME_INC="$ROOT/share/kaikai/include"
  # Installed layout ships a single runtime.h (the stage 2 one) under
  # share/kaikai/include, so the C-backend include dir is the same.
  RUNTIME_INC_C="$ROOT/share/kaikai/include"
  STDLIB_ROOT="$ROOT/share/kaikai/stdlib"
  KAI_LAYOUT="installed"
else
  echo "kai: error: cannot find kaikai installation under $ROOT" >&2
  echo "  expected dev layout (stage0/, stdlib/) or installed layout (libexec/kaikai/, share/kaikai/)" >&2
  exit 2
fi

# Allow overriding the discovered locations. KAI_INCLUDE points at a
# directory holding the stage 2 runtime.h, so it drives the C-backend
# include dir too (and falls through to RUNTIME_INC for the LLVM path,
# which also needs runtime_llvm.c next to it).
STDLIB_ROOT="${KAI_STDLIB:-$STDLIB_ROOT}"
RUNTIME_INC="${KAI_INCLUDE:-$RUNTIME_INC}"
RUNTIME_INC_C="${KAI_INCLUDE:-$RUNTIME_INC_C}"

# `kai info` reference pages. Dev layout reads docs/info from the
# source checkout; installed layout reads share/kaikai/info from the
# release tarball. KAIKAI_INFO_PATH overrides both.
if [ "$KAI_LAYOUT" = "installed" ]; then
  INFO_DIR="$ROOT/share/kaikai/info"
else
  INFO_DIR="$ROOT/docs/info"
fi
INFO_DIR="${KAIKAI_INFO_PATH:-$INFO_DIR}"

# Export the resolved stdlib root so kaic1/kaic2 see the installed
# location at runtime. The compile-time `KAI_STDLIB_PATH` macro is
# set by stage{1,2}/Makefile to `$(abspath ../stdlib)` — an absolute
# path that points at the build host's checkout, not the install
# layout. After `brew install` or `tar -xf <release>` the macro path
# does not exist; kaic2 reads `KAIKAI_STDLIB_PATH` first and falls
# back to the macro only when the env is unset, so this export is
# what makes installed kaikai self-consistent.
export KAIKAI_STDLIB_PATH="$STDLIB_ROOT"

# Package manager helper (issue #405). The driver shells out to a
# kaikai-compiled CLI for kai.toml read/write, dependency
# resolution, and the user-facing init/install/show commands. Dev
# layout: source at tools/kai-pkg/main.kai, binary auto-built next
# to it. Installed layout: prebuilt at libexec/kaikai/kai-pkg.
if [ "$KAI_LAYOUT" = "installed" ]; then
  KAIPKG_SRC=""
  KAIPKG_BIN="$ROOT/libexec/kaikai/kai-pkg"
else
  KAIPKG_SRC="$ROOT/tools/kai-pkg/main.kai"
  KAIPKG_BIN="$ROOT/tools/kai-pkg/kai-pkg"
fi

# Language Server (issue #447). Same pattern as kai-pkg: source at
# tools/kai-lsp/main.kai, binary auto-built next to it for dev.
if [ "$KAI_LAYOUT" = "installed" ]; then
  KAILSP_SRC=""
  KAILSP_BIN="$ROOT/libexec/kaikai/kai-lsp"
else
  KAILSP_SRC="$ROOT/tools/kai-lsp/main.kai"
  KAILSP_BIN="$ROOT/tools/kai-lsp/kai-lsp"
fi

CC="${CC:-cc}"
CFLAGS="${CFLAGS:--std=c99 -Wno-unused-function -Wno-unused-variable -O2}"

# Resolve the runtime shim the in-process libLLVM `native` backend links
# against (stage0/runtime_llvm.c holds the `kaix_prelude_*` forwarders the
# native object calls). Dev checkout lives next to the C runtime under
# stage0/; installed layout would ship it next to runtime.h under
# share/kaikai/include/. Empty when neither exists — the build path errors
# out clearly.
if [ -f "$RUNTIME_INC/runtime_llvm.c" ]; then
  RUNTIME_LLVM_C="$RUNTIME_INC/runtime_llvm.c"
elif [ -f "$ROOT/stage0/runtime_llvm.c" ]; then
  RUNTIME_LLVM_C="$ROOT/stage0/runtime_llvm.c"
else
  RUNTIME_LLVM_C=""
fi

# P2 (docs/native-codegen-perf-plan.md §P2): the precompiled runtime
# BITCODE, sitting next to runtime_llvm.c. When present, kaic2 links it
# into the in-process module BEFORE default<O2> (via KAI_NATIVE_RUNTIME_BC),
# so O2 inlines the runtime ops (kaix_cons, the list spine, the arith
# helpers) into hot heap-bound loops. The resulting object is
# SELF-CONTAINED — it already defines main + every kaix_*, so the final
# `cc` link must NOT re-add runtime_llvm.c (that is a duplicate-symbol
# error). When the .bc is absent (a checkout/release that did not vendor
# it), this stays empty and the native link falls back to the legacy path:
# cc compiles+links runtime_llvm.c, identical behaviour, just without the
# P2 inlining. The bitcode is version-locked to the libLLVM kaic2 links
# (writer ≤ reader); a stale/incompatible .bc would fail to parse, which is
# why generation is pinned to the same clang-18 toolchain (see
# stage0/runtime_llvm.bc.mk / the lane retro).
if [ -f "$RUNTIME_INC/runtime_llvm.bc" ]; then
  RUNTIME_LLVM_BC="$RUNTIME_INC/runtime_llvm.bc"
elif [ -f "$ROOT/stage0/runtime_llvm.bc" ]; then
  RUNTIME_LLVM_BC="$ROOT/stage0/runtime_llvm.bc"
else
  RUNTIME_LLVM_BC=""
fi

die() {
  echo "kai: error: $*" >&2
  exit 2
}

# $1 = path that was not found; $2 = subcommand name (build/run/test)
die_file_not_found() {
  echo "kai: error: file '$1' not found." >&2
  echo "Try 'kai $2 --help' for usage." >&2
  exit 2
}

read_version() {
  if [ -f "$ROOT/VERSION" ]; then
    cat "$ROOT/VERSION"
  elif [ -f "$ROOT/share/kaikai/VERSION" ]; then
    cat "$ROOT/share/kaikai/VERSION"
  else
    echo "unknown"
  fi
}

read_baseline() {
  if [ -f "$ROOT/demos/baseline.txt" ]; then
    cat "$ROOT/demos/baseline.txt"
  elif [ -f "$ROOT/share/kaikai/demos/baseline.txt" ]; then
    cat "$ROOT/share/kaikai/demos/baseline.txt"
  else
    echo "?"
  fi
}

ensure_built() {
  # Installed layout ships a prebuilt kaic2 — bootstrap chain is not needed.
  if [ "$KAI_LAYOUT" = "installed" ]; then
    if [ ! -x "$KAIC2" ]; then
      die "kaic2 binary missing at $KAIC2 — installation is corrupt"
    fi
    return 0
  fi
  if [ ! -x "$KAIC0" ]; then
    (cd "$ROOT/stage0" && make kaic0) >&2
  fi
  if [ ! -x "$KAIC1" ]; then
    (cd "$ROOT/stage1" && make kaic1) >&2
  fi
  if [ ! -x "$KAIC2" ]; then
    (cd "$ROOT/stage2" && make kaic2) >&2
  fi
}

# Build a helper tool ($2 source -> $3 binary, $1 a human label)
# atomically and under a lock, so concurrent `kai` invocations sharing
# the same checkout (e.g. the parity harness fan-out, 16 workers) never
# observe a half-linked binary. Without this, worker B reaches the
# execute site while worker A is mid-`cc -o`, and the partial file
# fails with "Permission denied" / "Text file busy" (tier1-backend-parity
# flake). Two guards: (1) compile to a per-PID temp then `mv` (atomic
# rename on the same filesystem) so every reader sees a complete binary
# or none; (2) a `mkdir` lock (atomic create) serialises the build so
# losers wait for the winner instead of racing a second `cc` to the
# same path.
build_helper_tool() {
  label="$1"; src="$2"; bin="$3"
  if [ ! -x "$bin" ] || [ "$src" -nt "$bin" ]; then
    ensure_built
    lock="$bin.lock"
    # Spin briefly for the lock. The winner builds; losers re-check the
    # predicate after it clears (the build may have satisfied it).
    waited=0
    while ! mkdir "$lock" 2>/dev/null; do
      # If the lock is stale (>120s) reclaim it; otherwise wait.
      if [ "$waited" -ge 120 ]; then
        rm -rf "$lock" 2>/dev/null
        continue
      fi
      sleep 1
      waited=$((waited + 1))
      # Another worker may have finished the build while we waited.
      if [ -x "$bin" ] && [ ! "$src" -nt "$bin" ]; then
        return 0
      fi
    done
    # We hold the lock. Re-check under it (someone may have built between
    # our predicate test and acquiring the lock).
    if [ ! -x "$bin" ] || [ "$src" -nt "$bin" ]; then
      echo "kai: building $label ..." >&2
      tmp_bin="$bin.tmp.$$"
      if "$0" build "$src" -o "$tmp_bin" >&2; then
        mv -f "$tmp_bin" "$bin"
      else
        rm -f "$tmp_bin"
        rmdir "$lock" 2>/dev/null
        die "failed to build $label from $src"
      fi
    fi
    rmdir "$lock" 2>/dev/null
  fi
}

# Build tools/kai-pkg on first use; idempotent. Installed layout
# ships the binary, so we only re-check existence.
ensure_kaipkg() {
  if [ "$KAI_LAYOUT" = "installed" ]; then
    if [ ! -x "$KAIPKG_BIN" ]; then
      die "kai-pkg binary missing at $KAIPKG_BIN — installation is corrupt"
    fi
    return 0
  fi
  build_helper_tool "tools/kai-pkg" "$KAIPKG_SRC" "$KAIPKG_BIN"
}

# Build tools/kai-lsp on first use; idempotent. Same shape as
# ensure_kaipkg.
ensure_kailsp() {
  if [ "$KAI_LAYOUT" = "installed" ]; then
    if [ ! -x "$KAILSP_BIN" ]; then
      die "kai-lsp binary missing at $KAILSP_BIN — installation is corrupt"
    fi
    return 0
  fi
  build_helper_tool "tools/kai-lsp" "$KAILSP_SRC" "$KAILSP_BIN"
}

# Resolve the cache root for package downloads. Precedence:
#   1. $KAIKAI_CACHE     — explicit override (CI / sandboxes).
#   2. $XDG_CACHE_HOME   — Linux convention.
#   3. ~/Library/Caches  — macOS convention.
#   4. ~/.cache          — fallback.
# Sub-path is always `kai/pkg`. Issue #405.
resolve_cache_root() {
  if [ -n "${KAIKAI_CACHE:-}" ]; then
    printf '%s' "$KAIKAI_CACHE"
    return 0
  fi
  if [ -n "${XDG_CACHE_HOME:-}" ]; then
    printf '%s/kai/pkg' "$XDG_CACHE_HOME"
    return 0
  fi
  case "$(uname -s)" in
    Darwin) printf '%s/Library/Caches/kai/pkg' "$HOME" ;;
    *)      printf '%s/.cache/kai/pkg' "$HOME" ;;
  esac
}

# Walk up from $1 looking for a kai.toml. Echoes the directory
# containing the manifest, or empty if none found before /.
find_manifest_dir() {
  d="$1"
  while [ -n "$d" ] && [ "$d" != "/" ]; do
    if [ -f "$d/kai.toml" ]; then
      printf '%s' "$d"
      return 0
    fi
    d="$(dirname "$d")"
  done
}

# Read the package name from `name = "..."` in kai.toml. Empty on
# missing manifest, missing field, or unreadable file. Used by
# `kai build` to pick a sensible default output binary name when
# the user did not pass -o (Go-style: the package name, not the
# entry-point filename).
manifest_package_name() {
  manifest_dir="$1"
  if [ -z "$manifest_dir" ] || [ ! -f "$manifest_dir/kai.toml" ]; then
    return 0
  fi
  awk '
    /^[[:space:]]*\[/ { in_root = 0 }
    /^[[:space:]]*\[package\]/ { in_root = 1; next }
    NR == 1 || in_root || /^[^[]/ {
      if (in_root || NR <= 30) {
        if ($0 ~ /^[[:space:]]*name[[:space:]]*=[[:space:]]*"[^"]+"[[:space:]]*$/) {
          gsub(/^[^"]*"/, "", $0); gsub(/".*$/, "", $0); print; exit
        }
      }
    }
  ' "$manifest_dir/kai.toml"
}

# Issue #658: read the `entry = "..."` field from kai.toml as an
# explicit override of the conventional `main.kai` entry point.
# Empty manifest dir, missing manifest, or missing field all fall
# back to `main.kai`. Mirrors Cargo's `[[bin]] path =` shape: when
# a package wants to keep sources under `src/` (e.g. `src/main.kai`)
# the manifest declares it and the driver respects it from every
# entry-aware subcommand.
manifest_entry_field() {
  manifest_dir="$1"
  if [ -z "$manifest_dir" ] || [ ! -f "$manifest_dir/kai.toml" ]; then
    printf 'main.kai'
    return 0
  fi
  entry="$(awk '
    /^[[:space:]]*\[/ { in_root = 0 }
    /^[[:space:]]*\[package\]/ { in_root = 1; next }
    NR == 1 || in_root || /^[^[]/ {
      if (in_root || NR <= 30) {
        if ($0 ~ /^[[:space:]]*entry[[:space:]]*=[[:space:]]*"[^"]+"[[:space:]]*$/) {
          gsub(/^[^"]*"/, "", $0); gsub(/".*$/, "", $0); print; exit
        }
      }
    }
  ' "$manifest_dir/kai.toml")"
  if [ -z "$entry" ]; then
    printf 'main.kai'
  else
    printf '%s' "$entry"
  fi
}

# Emit `--path <abs>` flags for the manifest's own root plus each
# dep in $1/kai.toml. Resolves relative local-path deps against $1;
# git deps come from the lockfile's cache field. Silent if no
# manifest.
#
# The manifest dir itself comes first so that `import <pkgname>.X`
# from files in sibling dirs (examples/, tests/, …) resolves
# against the package's own root without requiring a self-dependency
# entry in kai.toml. kaic2 probes `dir_of(root_path)` before any
# `--path` (stage2/compiler.kai find_module_file), so this addition
# only affects lookups that the src_dir couldn't satisfy. Issue #567.
#
# Auto-installs on first compile when the manifest declares deps
# but kai.lock is missing or any pinned cache dir is gone.
manifest_path_flags() {
  manifest_dir="$1"
  if [ -z "$manifest_dir" ] || [ ! -f "$manifest_dir/kai.toml" ]; then
    return 0
  fi
  printf -- '--path %s ' "$manifest_dir"
  # Issue #658: also expose the manifest's parent directory so that
  # `import <pkgname>.<module>` resolves under it. kaic2's
  # `module_to_path` already turns dotted paths into directory
  # paths (`a.b -> a/b.kai`); we just need the parent visible as a
  # search root for the package's own short name. Bare `import
  # <module>` keeps working because the manifest dir itself is
  # still the first search path.
  parent_dir="$(dirname "$manifest_dir")"
  if [ -n "$parent_dir" ] && [ "$parent_dir" != "$manifest_dir" ] && [ -d "$parent_dir" ]; then
    printf -- '--path %s ' "$parent_dir"
  fi
  ensure_kaipkg
  cache_root="$(resolve_cache_root)"
  mkdir -p "$cache_root"
  # If the manifest references git deps and either kai.lock is
  # missing or any pinned cache dir vanished, auto-install before
  # emitting paths. This makes `kai run app.kai` work the first
  # time without an explicit `kai install` step.
  if needs_auto_install "$manifest_dir" "$cache_root"; then
    ( cd "$manifest_dir" && KAIKAI_CACHE_ROOT="$cache_root" "$KAIPKG_BIN" install ) >&2
  fi
  # `kai-pkg paths` emits one `<name>\t<path>` line per resolved dep.
  # Resolve each path relative to the manifest dir, absolute-ising it
  # so kaic2's --path resolver does not depend on the user's cwd.
  ( cd "$manifest_dir" && KAIKAI_CACHE_ROOT="$cache_root" "$KAIPKG_BIN" paths ) | while IFS="$(printf '\t')" read -r name dep_path; do
    [ -n "$dep_path" ] || continue
    case "$dep_path" in
      /*) abs="$dep_path" ;;
      *)  abs="$(cd "$manifest_dir" && cd "$dep_path" 2>/dev/null && pwd)" ;;
    esac
    [ -n "$abs" ] && printf -- '--path %s ' "$abs"
  done
}

# Issue #603: known editions accepted by the compiler. Kept in sync
# with stage2/compiler.kai's known_editions(). Adding an edition
# means flipping both lists.
KNOWN_EDITIONS="tongariki hanga-roa"

# Issue #637: validate an edition value against KNOWN_EDITIONS and
# die with a typed driver-level diagnostic when it is unknown.
# Failing early in the driver avoids the cascading linker error the
# user would otherwise see (ahu's `anga-roa` typo against the
# 0.67 enforcement turn-up was the motivator).
validate_edition() {
  candidate="$1"
  source="$2"   # human-readable source path (e.g. "kai.toml" or "EDITION")
  for e in $KNOWN_EDITIONS; do
    if [ "$candidate" = "$e" ]; then return 0; fi
  done
  printf 'kai: error: unknown edition %s in %s\n' "\"$candidate\"" "$source" >&2
  printf '  known editions: %s\n' "$KNOWN_EDITIONS" >&2
  printf '  hint: check the spelling, or update kaikai if you expect this edition to exist.\n' >&2
  exit 1
}

# Issue #603: emit `--edition <name>` based on the consumer's
# kai.toml `edition = "..."` field. Falls back to the repo-level
# EDITION file (read_edition) when no manifest exists or the field
# is absent. The compiler validates the value and gates feature
# branches (e.g. #594 pipe convention dispatch) on edition >=
# hanga-roa. Awk parsing mirrors manifest_unstable_flags — kaikai's
# TOML never quotes key/table names.
manifest_edition_flag() {
  manifest_dir="$1"
  default_ed="$(read_edition)"
  if [ -z "$manifest_dir" ] || [ ! -f "$manifest_dir/kai.toml" ]; then
    printf -- '--edition %s' "$default_ed"
    return 0
  fi
  ed="$(awk '
    /^\[/ { in_root = 0; next }
    NR == 1 { in_root = 1 }
    in_root && /^[[:space:]]*edition[[:space:]]*=/ {
      n = $0
      sub(/^[^=]*=[[:space:]]*"/, "", n)
      sub(/".*/, "", n)
      print n
      exit
    }
  ' "$manifest_dir/kai.toml")"
  if [ -z "$ed" ]; then
    ed="$default_ed"
  else
    validate_edition "$ed" "$manifest_dir/kai.toml"
  fi
  printf -- '--edition %s' "$ed"
}

# Read the edition for cache-partitioning purposes. Same resolution
# as manifest_edition_flag but emits only the bare value (no flag
# prefix), and silently falls back to the repo EDITION when the
# manifest is absent or lacks the field.
manifest_edition_value() {
  manifest_dir="$1"
  default_ed="$(read_edition)"
  if [ -z "$manifest_dir" ] || [ ! -f "$manifest_dir/kai.toml" ]; then
    printf '%s' "$default_ed"
    return 0
  fi
  ed="$(awk '
    /^\[/ { in_root = 0; next }
    NR == 1 { in_root = 1 }
    in_root && /^[[:space:]]*edition[[:space:]]*=/ {
      n = $0
      sub(/^[^=]*=[[:space:]]*"/, "", n)
      sub(/".*/, "", n)
      print n
      exit
    }
  ' "$manifest_dir/kai.toml")"
  if [ -z "$ed" ]; then ed="$default_ed"; fi
  printf '%s' "$ed"
}

# Issue #602: emit `--package-name <name>` if the manifest declares
# one, and `--unstable-optin <pkg>` for every `<pkg> = true` entry
# under `[unstable]`. The compiler uses these to suppress the
# `#unstable` warning for opted-in upstream packages and for the
# consumer's self-imports. Silent when no manifest exists. Parsing
# is intentionally simple — awk on raw TOML — because kaikai's
# manifest format never quotes table or key names. A leading `#`
# comment after the value is tolerated.
manifest_unstable_flags() {
  manifest_dir="$1"
  if [ -z "$manifest_dir" ] || [ ! -f "$manifest_dir/kai.toml" ]; then
    return 0
  fi
  # Consumer package name (top-level `name = "..."` outside any table).
  awk '
    /^\[/ { in_root = 0; next }
    NR == 1 { in_root = 1 }
    in_root && /^[[:space:]]*name[[:space:]]*=/ {
      n = $0
      sub(/^[^=]*=[[:space:]]*"/, "", n)
      sub(/".*/, "", n)
      print "--package-name " n
      exit
    }
  ' "$manifest_dir/kai.toml"
  # `[unstable]` table entries: `<pkg> = true` → `--unstable-optin <pkg>`.
  awk '
    /^\[unstable\][[:space:]]*$/ { in_section = 1; next }
    /^\[/                       { in_section = 0; next }
    in_section && /^[[:space:]]*[A-Za-z_][A-Za-z0-9_-]*[[:space:]]*=[[:space:]]*true/ {
      k = $1
      sub(/[[:space:]]*=.*/, "", k)
      print "--unstable-optin " k
    }
  ' "$manifest_dir/kai.toml"
}

# Returns 0 (true) if the manifest needs `kai install` to run
# before paths are usable. Heuristics:
#   - manifest mentions `[dependencies]` AND kai.lock is missing.
#   - kai.lock exists but at least one git dep's cache dir is gone.
needs_auto_install() {
  manifest_dir="$1"
  cache_root="$2"
  has_deps="$(grep -c '^\[dependencies\]' "$manifest_dir/kai.toml" 2>/dev/null || echo 0)"
  if [ "$has_deps" = "0" ]; then return 1; fi
  # Local-path-only manifests don't need a lock.
  if ! grep -q 'source[[:space:]]*=' "$manifest_dir/kai.toml" 2>/dev/null \
       && ! grep -qE '"[^"]*@[^"]*"' "$manifest_dir/kai.toml" 2>/dev/null; then
    return 1
  fi
  if [ ! -f "$manifest_dir/kai.lock" ]; then return 0; fi
  # Walk the lock for missing cache dirs (lock keeps source + sha;
  # cache dir derives from cache_root + slug + sha — issue #421).
  awk -v root="$cache_root" '
    /^source =/ { gsub(/"/, "", $3); s=$3 }
    /^sha =/    { gsub(/"/, "", $3); h=$3
                  # mirror slug logic: strip protocol prefix, leading /, replace bad chars with _
                  gsub(/^https?:\/\//, "", s); gsub(/^ssh:\/\//, "", s); gsub(/^file:\/\//, "", s)
                  gsub(/^\//, "", s)
                  gsub(/[^A-Za-z0-9_./-]/, "_", s)
                  gsub(/[^A-Za-z0-9_.-]/, "_", h)
                  print root "/" s "/" h
                  s=""; h="" }
  ' "$manifest_dir/kai.lock" | while read -r dir; do
    [ -d "$dir/.git" ] || { echo missing; break; }
  done | grep -q missing && return 0
  return 1
}

usage() {
  v="$(read_version)"
  cat <<EOF
 _      _ _      _
| |____(_) |____(_)    kaikai $v
| / / _\` | / / _\` |    a statically typed functional language
|_\\_\\__,_|_\\_\\__,_|    effects | fibers | protocols

usage: kai <command> [args...]

Commands:
  build [<spec>] [-o <out>]     Compile a kaikai package or file. With no
                                <spec> the cwd package's entry point is used.
  run   [<spec>] [args...]      Build and execute; forwards remaining args.
  test  [<spec>|./...]          Compile with --test and run. './...' walks
                                every kai.toml under cwd.
  bench [--iters N] [<spec>]    Compile with --bench and run.
  check [<spec>]                Compile with --prop-check and run property
                                blocks (issue #44).
  fmt   [<spec>] [--check]      Pretty-print kaikai source canonically.
  watch [<spec>]                Recompile + run on every save (live demo).
  init  <name>                  Create a kai.toml manifest in the cwd.
  add   <source>[@<ref>]        Fetch a dep and append it to kai.toml.
  install                       Resolve dependencies (git fetch + lock).
  update [<name>]               Re-fetch deps; refresh kai.lock.
  show                          Print the parsed kai.toml.
  lsp                           Language Server (JSON-RPC over stdio).
  info [<topic>] [--json]       Reference pages (man/info style). Run
                                'kai info' for the topic list, or
                                'kai info syntax' for the one-page
                                cheat sheet of forms kaikai has.
  doc  [<module>[.<symbol>]]    Read stdlib docs. 'kai doc' lists
                                modules; 'kai doc <module>' lists its
                                items; 'kai doc <module>.<symbol>'
                                shows a symbol's signature + doc.
  help                          Show this help.
  --version                     Print version and demo baseline.

A <spec> is one of: a path to a .kai file (legacy file mode), '.' or
omitted (the current directory's package, read from kai.toml), or
'./<sub>' where <sub> is a directory carrying its own kai.toml.

Run 'kai <command> --help' for command-specific options.

Environment:
  CC               C compiler to invoke (default: cc).
  CFLAGS           Extra flags passed to CC.
  KAI_BACKEND      Default backend (c|native) for \`kai build\` /
                   \`kai run\` when --backend is not passed. Overridden by
                   --backend; defaults to \`native\` (the in-process libLLVM
                   path — no clang, no .ll text — since the Lane 1.5 flip).
                   \`c\` is the portable C-text backend, the bootstrap path
                   and parity oracle. A kaic2 built without libLLVM cannot
                   run \`native\`: the implicit default degrades to \`c\` with
                   a note, but an explicit \`native\` here errors.
  KAI_NATIVE_OPT   Optimisation level for the native backend's in-process
                   LLVM pipeline: 0|1|2|3|s|z (default: 2). Set by
                   \`--debug\` (0) / \`--release\` (2); the C backend
                   ignores it.
  KAI_STDLIB       Override the stdlib root directory (default: auto-detected
                   from the script's location — share/kaikai/stdlib if installed,
                   stdlib/ if running from a dev checkout).
  KAI_INCLUDE      Override the runtime.h include directory (default: auto-
                   detected — share/kaikai/include if installed, stage0/ if dev).

See README.md and docs/ for the language reference.
Project home: https://kaikai-lang.org
EOF
}

usage_build() {
  cat <<EOF
usage: kai build [<spec>] [-o <out>] [--backend=<c|native>]
       kai build --holes [<spec>]
       kai build --holes-json [<spec>]
       kai build --diags-json [<spec>]
       kai build --effects-json [<spec>]
       kai build --effect-holes-json [<spec>]
       kai build --library-mode [<spec>]

Compile a kaikai package or file to a native binary. <spec> is one
of:
  <file>.kai       legacy file mode (unchanged from earlier versions).
  '.' or omitted   the package rooted at the cwd; kai.toml supplies
                   the package name (used as the binary name) and
                   optional 'entry = "..."' override of the default
                   main.kai entry point.
  './<sub>'        a sub-package — <sub> must carry its own kai.toml;
                   the binary lands inside that sub-directory.

The default backend is \`native\` (the in-process libLLVM path,
docs/kir-design.md §7.2): it lowers to KIR, builds the LLVM module via
the C API in one process, and emits a native object — no \`.ll\` text,
no \`clang\` subprocess. libLLVM is linked INTO kaic2 (statically in a
release), so a built binary runs the native backend with no system LLVM.

\`--backend=c\` selects the portable C-text backend (C linked with cc) —
the bootstrap path and the parity oracle, supported across the whole
corpus. A kaic2 bootstrapped without libLLVM cannot run \`native\`: the
implicit default degrades to \`c\` with a note (so a cc-only checkout keeps
building), but an explicit \`--backend=native\` errors. Build a
native-capable kaic2 with \`make -C stage2 KAI_LLVM=1\`.

Options:
  -o <out>             Output binary path (default: basename of input
                       without .kai).
  --backend=<c|native>
                       Codegen backend (default: native). \`c\` is the
                       portable C-text path (bootstrap + parity oracle).
                       KAI_BACKEND env var overrides the default; this
                       flag overrides both.
  --release            Optimise with -O2 (default). For the native
                       backend this runs the LLVM \`default<O2>\` pipeline
                       in-process — parity with the clang -O2 the C
                       path gets.
  --debug              Optimise with -O0: fast compile, no inlining,
                       symbols kept. Native runs \`default<O0>\`.
  --holes              Report every typed hole (\`?\` / \`?name\`) with
                       expected type, in-scope bindings, and candidate
                       fillers, then exit. No binary is produced. See
                       docs/typed-holes.md.
  --holes-json         Same as --holes, but emits the stable JSON
                       schema documented in docs/typed-holes.md (LLM
                       integration point).
  --diags-json         Emit collected structured diagnostics (errors +
                       notes) as a JSON object matching the LSP
                       Diagnostic shape. Only the m11 templates T1-T5
                       are migrated; older sites still print to stderr.
                       Used by \`kai lsp\` to drive
                       textDocument/publishDiagnostics.
  --effects-json       Emit per-function effect-row info as JSON:
                       declared row, inferred row, handlers in scope.
                       Used by tooling that wants effect coverage.
  --effect-holes-json  Emit row-variable hole resolutions (\`/ ?\` or
                       \`/ ?e\` in a row tail) as JSON, listing the
                       effects the typer inferred for each hole.
  --library-mode       Run lex / parse / resolve / infer and answer
                       \`# @probe <kind> L:C\` comments embedded in the
                       source. Probe kinds: type, def, enc, complete,
                       sig, symbols. Used by \`kai lsp\` to back hover /
                       goto-def / completion / signature help.
  -h, --help           Show this help.

Examples:
  kai build                                 # cwd package (reads kai.toml)
  kai build .                               # equivalent explicit form
  kai build ./sub                           # sibling sub-package
  kai build hello.kai                       # produces ./hello (native backend)
  kai build src/app.kai -o build/app        # produces ./build/app
  kai build --backend=c hello.kai           # produces ./hello via the C backend
  kai build --holes draft.kai               # human-readable hole report
  kai build --holes-json draft.kai          # machine-readable hole report
  kai build --diags-json draft.kai          # structured diagnostics (JSON)
  kai build --library-mode draft.kai        # answer @probe queries (JSON)

The compiler auto-loads the core stdlib modules (stdlib/core, protocols,
effects, array). Everything else under stdlib/ requires an explicit
`import`.
EOF
}

usage_run() {
  cat <<EOF
usage: kai run [--backend=<c|native>] [<spec>] [args...]

Compile and immediately execute a kaikai program. <spec> follows the
same rules as \`kai build\` (a .kai file, '.', '<sub>', or omitted for
the cwd package). Any arguments after the spec are forwarded to the
compiled binary. Backend selection follows the same rule as
\`kai build\`: --backend > KAI_BACKEND > default (\`native\`, the in-process
libLLVM path since the Lane 1.5 flip). On a kaic2 built without libLLVM
the implicit default degrades to \`c\` with a note; explicit \`native\`
errors.

Options:
  --backend=<c|native>
                       Codegen backend (default: native). \`c\` is the
                       portable C-text path. KAI_BACKEND env var overrides
                       the default; this flag overrides both.
  -h, --help           Show this help.

Examples:
  kai run                                   # cwd package
  kai run .                                 # equivalent explicit form
  kai run ./sub                             # sub-package binary
  kai run examples/minimal/hello.kai
  kai run demos/fizzbuzz/fizzbuzz.kai 30
  kai run app.kai --user alice --port 8080

The temporary binary is removed after the program exits.
EOF
}

usage_test() {
  cat <<EOF
usage: kai test [options] [<spec>|./...]

Compile a kaikai source with --test enabled and run the test binary.
<spec> follows the same rules as \`kai build\` (a .kai file, '.', a
'./<sub>' sub-package, or omitted for the cwd package). The special
spec './...' walks the cwd subtree and runs \`kai test\` for every
directory that carries its own kai.toml — exit code is the OR of
every sub-run, so CI fails the moment any package's tests do.

The compiler emits a main that runs every 'test "..." { ... }' block
defined in the entry point and reports the result. When the package
also has a sibling 'tests/' directory, every '*.kai' file under it
is compiled and run as its own test binary (in addition to the
entry). The aggregate exit code is the OR of every run.

Tests defined inside the auto-loaded core stdlib modules are dropped
at load time (issue #318) so the count reflects only the user's tests.

Options:
  -h, --help                Show this help.
  --include-prelude-tests   Also run test blocks defined inside the
                            auto-loaded core stdlib modules (legacy).

Examples:
  kai test                                   # cwd package (+ tests/)
  kai test ./...                             # every package under cwd
  kai test stage2/tests/test_lex.kai
  kai test demos/poker/poker.kai
  kai test --include-prelude-tests demos/poker/poker.kai
EOF
}

usage_bench() {
  cat <<EOF
usage: kai bench [--iters N] <file.kai>

Compile a kaikai source with --bench enabled and run the bench binary.
The compiler emits a main that runs every 'bench "..." { ... }' block
under clock_gettime(CLOCK_MONOTONIC). For each block the runner does
KAI_BENCH_WARMUP untimed iterations followed by KAI_BENCH_ITERS timed
iterations, then prints:

  <name>: <N> iter / median <X> ns / MAD <Y> ns / mean <Z> ns / range [<lo>, <hi>]

Iteration count precedence: --iters CLI flag > KAI_BENCH_ITERS env var
> compiled-in default (1000). Warmup is controlled by KAI_BENCH_WARMUP
(default 50).

Options:
  --iters N    Run N timed iterations per block (overrides
               KAI_BENCH_ITERS for this invocation).
  -h, --help   Show this help.

Examples:
  kai bench examples/stdlib/bench_basic.kai
  kai bench --iters 5000 examples/stdlib/bench_basic.kai
  KAI_BENCH_WARMUP=100 kai bench examples/stdlib/bench_basic.kai
EOF
}

usage_check() {
  cat <<EOF
usage: kai check <file.kai>

Compile a kaikai source with --prop-check enabled and run the
