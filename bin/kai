cmd_lsp() {
  case "${1:-}" in
    -h|--help)
      cat <<EOF
usage: kai lsp

Run the Language Server. Speaks LSP JSON-RPC over stdio (issue
#447). Editors should spawn this as their language server for
kaikai sources. v1 surface:

  initialize / initialized / shutdown / exit
  textDocument/didOpen, didChange, didClose (Full sync)
  textDocument/hover

Each hover spawns a kaic2 --library-mode subprocess; expect 5-15 ms
latency on macOS. See docs/lsp.md for editor configuration.

Environment:
  KAILSP_KAIC2     Override the kaic2 binary path used for probes.
EOF
      return 0 ;;
  esac
  ensure_built
  ensure_kailsp
  # Inform kai-lsp where the matching kaic2 lives, unless the user
  # overrode it. The library-mode subprocess must speak the same
  # AST the user authored against.
  if [ -z "${KAILSP_KAIC2:-}" ]; then
    export KAILSP_KAIC2="$KAIC2"
  fi
  exec "$KAILSP_BIN" "$@"
}

# ---- kai doc — human reader for the #[doc(...)] attributes ----
#
# `kai info builtins` exposes the auto-loaded core module set as JSON;
# `kai doc` is the human surface over ALL of stdlib. It builds on the
# existing extractor (`kaic2 --doc-json <file>`, issue #681) — no new
# parser. The doc bodies are CommonMark; we render a TTY-friendly
# subset (headers, fenced/indented code, bullet lists) with awk only,
# zero new dependencies.

# Map a user-facing module name (`string`, `stream`, `map`) to its
# stdlib-relative path. core/* and the collections/encoding/... trees
# are addressed by their basename; a top-level file wins over a nested
# one of the same name (`path` -> path.kai, not fs/path.kai).
doc_resolve_module() {
  name="$1"
  # Exact relative path (with or without .kai) takes precedence so
  # `kai doc core/string` and `kai doc fs/path` stay addressable.
  for cand in "$name" "$name.kai"; do
    if [ -f "$STDLIB_ROOT/$cand" ]; then
      printf '%s\n' "${cand%.kai}.kai"
      return 0
    fi
  done
  # Otherwise resolve by basename. Top-level match first, then nested.
  if [ -f "$STDLIB_ROOT/$name.kai" ]; then
    printf '%s\n' "$name.kai"
    return 0
  fi
  match="$(cd "$STDLIB_ROOT" && find . -name "$name.kai" 2>/dev/null \
            | sed 's|^\./||' | sort | head -1)"
  if [ -n "$match" ]; then
    printf '%s\n' "$match"
    return 0
  fi
  return 1
}

# Resolve a (possibly dotted) module name to a .kai FILE inside the
# current package's search roots — the manifest dir, its parent, and every
# dependency `manifest_path_flags` exposes. Mirrors kaic2's `module_to_path`
# (`a.b -> a/b.kai`) so `kai doc <m>` finds exactly the module an
# `import <m>` in the same package would. Echoes the absolute file path on
# success; returns 1 when there is no manifest or no matching file (the
# caller then reports a combined stdlib+package miss). This is what makes
# `kai doc` work for a module `m` declared in kai.toml, not just stdlib.
doc_resolve_pkg_module() {
  name="$1"
  manifest_dir="$(find_manifest_dir "$(pwd)")"
  [ -n "$manifest_dir" ] || return 1
  # `a.b.c` -> `a/b/c` (kaic2's dotted-path-to-dir convention).
  rel="$(printf '%s' "$name" | tr '.' '/')"
  # The search roots are exactly the `--path` dirs run/build would inject,
  # captured once (`manifest_path_flags` may auto-install, so avoid
  # re-running it). The flags interleave as `--path <dir> --path <dir> …`.
  flags="$(manifest_path_flags "$manifest_dir" 2>/dev/null)"
  for root in $flags; do
    case "$root" in --path) continue ;; esac
    for cand in "$root/$rel.kai" "$root/$name.kai"; do
      if [ -f "$cand" ]; then printf '%s\n' "$cand"; return 0; fi
    done
  done
  return 1
}

# The CommonMark -> TTY renderer, shared by the symbol view. Reads the
# raw doc body (with literal newlines already unescaped) on stdin and
# reflows it under a two-space margin: ATX headers drop their `#` and
# get a blank line above, fenced code keeps its shape under a deeper
# indent, `- `/`* ` bullets align. Deliberately small — full CommonMark
# (tables, nested lists, inline emphasis) is out of scope.
doc_render_body() {
  awk '
    BEGIN { in_fence = 0 }
    {
      line = $0
      # Fenced code blocks: the ``` marker becomes a blank separator;
      # the body passes through verbatim under a deeper indent.
      if (line ~ /^[[:space:]]*```/) { in_fence = !in_fence; print ""; next }
      if (in_fence) { print "      " line; next }
      # ATX headers (## Foo) drop the markers, gain a blank line above.
      if (line ~ /^#+[[:space:]]/) {
        sub(/^#+[[:space:]]+/, "", line)
        print ""; print "  " line; next
      }
      # Bullet list items keep a normalised marker, indented one level.
      if (line ~ /^[[:space:]]*[-*][[:space:]]/) {
        sub(/^[[:space:]]*[-*][[:space:]]/, "", line)
        print "    - " line; next
      }
      print "  " line
    }'
}

# Extract one field (sig/doc) of the item named $sym from a --doc-json
# stream on stdin, unescaping JSON string escapes. Prints the raw
# value (empty if the field is null or the symbol is absent). The JSON
# is a single line; objects are split on the stable `{"kind": ` prefix.
doc_field() {
  sym="$1"; field="$2"
  awk -v sym="$sym" -v field="$field" '
    function unescape(s,    out, i, c, n) {
      out = ""; n = length(s)
      for (i = 1; i <= n; i++) {
        c = substr(s, i, 1)
        if (c == "\\" && i < n) {
          i++; c = substr(s, i, 1)
          if      (c == "n") out = out "\n"
          else if (c == "t") out = out "\t"
          else if (c == "r") out = out "\r"
          else               out = out c
        } else out = out c
      }
      return out
    }
    # Scan one JSON string value starting just after the opening quote
    # at position p; honour \" escapes. Sets gval, returns the index
    # just past the closing quote.
    function scan_str(s, p,    out, c) {
      out = ""
      while (p <= length(s)) {
        c = substr(s, p, 1)
        if (c == "\\") { out = out substr(s, p, 2); p += 2; continue }
        if (c == "\"") { gval = out; return p + 1 }
        out = out c; p++
      }
      gval = out; return p
    }
    {
      s = $0; n = split(s, parts, /\{"kind": /)
      for (i = 2; i <= n; i++) {
        obj = parts[i]
        # name value
        np = index(obj, "\"name\": \"")
        if (np == 0) continue
        scan_str(obj, np + 9)
        nm = gval
        if (nm != sym) continue
        key = "\"" field "\": "
        kp = index(obj, key)
        if (kp == 0) { exit }
        rest = substr(obj, kp + length(key))
        if (substr(rest, 1, 4) == "null") { exit }
        # value is a quoted string
        scan_str(rest, 2)
        printf "%s", unescape(gval)
        exit
      }
    }'
}

# One-line synopsis = the first non-empty line of a doc body.
doc_synopsis() {
  awk 'NF { print; exit }'
}

# Extract the top-level `module_doc` value from a --doc-json stream,
# unescaping it. Empty when the module carries no module doc.
doc_module_doc() {
  awk '
    function unescape(s,    out, i, c, n) {
      out = ""; n = length(s)
      for (i = 1; i <= n; i++) {
        c = substr(s, i, 1)
        if (c == "\\" && i < n) {
          i++; c = substr(s, i, 1)
          if      (c == "n") out = out "\n"
          else if (c == "t") out = out "\t"
          else if (c == "r") out = out "\r"
          else               out = out c
        } else out = out c
      }
      return out
    }
    function scan_str(s, p,    out, c) {
      out = ""
      while (p <= length(s)) {
        c = substr(s, p, 1)
        if (c == "\\") { out = out substr(s, p, 2); p += 2; continue }
        if (c == "\"") { gval = out; return p + 1 }
        out = out c; p++
      }
      gval = out; return p
    }
    {
      kp = index($0, "\"module_doc\": ")
      if (kp == 0) exit
      rest = substr($0, kp + length("\"module_doc\": "))
      if (substr(rest, 1, 4) == "null") exit
      scan_str(rest, 2)
      printf "%s", unescape(gval)
      exit
    }'
}

cmd_doc() {
  case "${1:-}" in
    -h|--help)
      cat <<EOF
usage: kai doc                       List stdlib modules with a synopsis.
       kai doc <module>              List a module's pub items + synopses.
       kai doc <module>.<symbol>     Show a symbol's signature + full doc.

Examples:
  kai doc string.split
  kai doc stream.fold
  kai doc stream
  kai doc
  kai doc geo                        A package module (declared in kai.toml).
  kai doc geo.area

Docs come from the #[doc(...)] attributes in the source, extracted by the
compiler (kaic2 --doc-json). A <module> is resolved against the stdlib
first (string, stream, map, or a relative path like core/string, fs/path),
then — when a kai.toml is in scope — against the current package and its
dependencies, so a module you import via kai.toml is documentable the same
way. The bare-no-args list shows stdlib modules only.
EOF
      return 0 ;;
  esac

  ensure_built

  # No args: list every stdlib module with its one-line synopsis.
  if [ "${1:-}" = "" ]; then
    echo "kai doc — stdlib reference, by module."
    echo
    echo "Modules:"
    ( cd "$STDLIB_ROOT" && find . -name '*.kai' | sed 's|^\./||' | sort ) \
      | while read -r rel; do
          mod="${rel%.kai}"
          syn="$("$KAIC2" --doc-json "$STDLIB_ROOT/$rel" 2>/dev/null \
                  | doc_module_doc | doc_synopsis)"
          printf '  %-20s %s\n' "$mod" "$syn"
        done
    echo
    echo "Usage:"
    echo "  kai doc <module>            List a module's items"
    echo "  kai doc <module>.<symbol>   Show one symbol's doc"
    return 0
  fi

  arg="$1"
  # Split on the LAST dot: everything before is the module, after is
  # the symbol. `string.split` -> mod=string sym=split. A bare module
  # name (`stream`) has no dot and lists the module.
  case "$arg" in
    *.*) mod="${arg%.*}"; sym="${arg##*.}" ;;
    *)   mod="$arg";      sym="" ;;
  esac

  # Resolve `mod` against the stdlib first, then — when a kai.toml is in
  # scope — against the current package and its dependencies, so a module
  # `m` declared in kai.toml is documentable via `kai doc m` exactly like a
  # stdlib module. `doc_path_flags` carries the package's --path roots into
  # `--doc-json` so a package module that imports siblings/deps still
  # type-checks for doc extraction (empty for a stdlib hit).
  doc_path_flags=""
  if rel="$(doc_resolve_module "$mod" 2>/dev/null)"; then
    file="$STDLIB_ROOT/$rel"
  elif file="$(doc_resolve_pkg_module "$mod" 2>/dev/null)" && [ -n "$file" ]; then
    rel="$file"
    pkg_manifest_dir="$(find_manifest_dir "$(pwd)")"
    doc_path_flags="$(manifest_path_flags "$pkg_manifest_dir" 2>/dev/null)"
  else
    echo "kai: error: no module '$mod' in the stdlib or the current package" >&2
    echo "  run 'kai doc' to list stdlib modules; for a package module," >&2
    echo "  check it is declared in kai.toml and the name matches an import." >&2
    exit 1
  fi
  json="$("$KAIC2" $doc_path_flags --doc-json "$file" 2>/dev/null)"

  # Module view: list the pub items with their synopsis.
  if [ -z "$sym" ]; then
    echo "# $mod   ($rel)"
    mdoc="$(printf '%s' "$json" | doc_module_doc | doc_synopsis)"
    [ -n "$mdoc" ] && { echo; echo "  $mdoc"; }
    echo
    # Emit `name<TAB>kind<TAB>synopsis` per pub item, then format.
    printf '%s' "$json" | awk '
      function scan_str(s, p,    out, c) {
        out = ""
        while (p <= length(s)) {
          c = substr(s, p, 1)
          if (c == "\\") { out = out substr(s, p, 2); p += 2; continue }
          if (c == "\"") { gval = out; return p + 1 }
          out = out c; p++
        }
        gval = out; return p
      }
      function field_str(obj, key,    kp, rest) {
        kp = index(obj, "\"" key "\": ")
        if (kp == 0) return ""
        rest = substr(obj, kp + length("\"" key "\": "))
        if (substr(rest, 1, 4) == "null") return ""
        scan_str(rest, 2); return gval
      }
      function field_bool(obj, key,    kp, rest) {
        kp = index(obj, "\"" key "\": ")
        if (kp == 0) return ""
        rest = substr(obj, kp + length("\"" key "\": "))
        if (substr(rest, 1, 4) == "true") return "true"
        return ""
      }
      function synopsis(d,    p) {
        gsub(/\\n/, "\n", d); p = index(d, "\n")
        return (p > 0) ? substr(d, 1, p - 1) : d
      }
      {
        n = split($0, parts, /\{"kind": /)
        for (i = 2; i <= n; i++) {
          obj = parts[i]
          kp = index(obj, ", \"name\":"); kind = substr(obj, 2, kp - 3)
          name = field_str(obj, "name")
          if (field_bool(obj, "pub") == "") continue
          doc = field_str(obj, "doc")
          printf "%s\t%s\t%s\n", name, kind, synopsis(doc)
        }
      }' | sort | while IFS="$(printf '\t')" read -r name kind syn; do
        printf '  %-22s %s\n' "$name" "$syn"
      done
    echo
    echo "Run 'kai doc $mod.<symbol>' for a symbol's signature and full doc."
    return 0
  fi

  # Symbol view: signature + full doc body. Confirm the symbol exists
  # first so "no such symbol" is distinct from "documented but empty".
  if ! printf '%s' "$json" | doc_names | grep -qx -- "$sym"; then
    echo "kai: error: no symbol '$sym' in module '$mod'" >&2
    near="$(printf '%s' "$json" | doc_names | grep -i -- "$sym" | head -3 | paste -sd' ' -)"
    [ -n "$near" ] && echo "  did you mean: $near" >&2
    echo "  run 'kai doc $mod' to list the module's items." >&2
    exit 1
  fi
  sig="$(printf '%s' "$json" | doc_field "$sym" sig)"
  body="$(printf '%s' "$json" | doc_field "$sym" doc)"

  echo "# $mod.$sym   ($rel)"
  [ -n "$sig" ] && { echo; echo "  $sym$sig"; }
  if [ -n "$body" ]; then
    echo
    printf '%s\n' "$body" | doc_render_body
  fi
  return 0
}

# Print every item name in a --doc-json stream (for near-miss hints).
doc_names() {
  awk '
    function scan_str(s, p,    out, c) {
      out = ""
      while (p <= length(s)) {
        c = substr(s, p, 1)
        if (c == "\\") { out = out substr(s, p, 2); p += 2; continue }
        if (c == "\"") { gval = out; return p + 1 }
        out = out c; p++
      }
      gval = out; return p
    }
    {
      n = split($0, parts, /\{"kind": /)
      for (i = 2; i <= n; i++) {
        np = index(parts[i], "\"name\": \"")
        if (np == 0) continue
        scan_str(parts[i], np + 9)
        print gval
      }
    }'
}

cmd_info() {
  # kai info                    list topics
  # kai info <topic>            print topic page
  # kai info <topic> --json     same content as structured JSON
  # kai info --list             topic names only, one per line
  # kai info -k <keyword>       search topic names + NAME lines
  # kai info -h | --help        usage

  if [ ! -d "$INFO_DIR" ]; then
    echo "kai: error: info pages not found at $INFO_DIR" >&2
    echo "  set KAIKAI_INFO_PATH to override the lookup path." >&2
    exit 2
  fi

  case "${1:-}" in
    -h|--help)
      cat <<EOF
usage: kai info                    List available topics.
       kai info <topic>            Show the topic page (man/info style).
       kai info <topic> --json     Same content, structured JSON output.
       kai info --list             Topic names only, one per line.
       kai info -k <keyword>       Search topic names and NAME lines.

Topics live in $INFO_DIR (override with KAIKAI_INFO_PATH).

For language semantics and ecosystem, this is the entry point. The
quickref of every form kaikai actually has is at:

  kai info syntax
EOF
      return 0 ;;
    --list)
      ls "$INFO_DIR" 2>/dev/null | sed -n 's/\.md$//p' | sort
      return 0 ;;
    -k)
      shift
      kw="${1:-}"
      if [ -z "$kw" ]; then
        echo "kai: error: -k requires a keyword" >&2
        exit 2
      fi
      # Search topic names and the page's tagline (first non-empty,
      # non-heading line after the `# title` H1).
      found=0
      for f in "$INFO_DIR"/*.md; do
        [ -f "$f" ] || continue
        topic="$(basename "$f" .md)"
        name_line="$(awk '/^# /{h1=1; next} h1 && NF && !/^#/{print; exit}' "$f")"
        if echo "$topic $name_line" | grep -i -q -- "$kw"; then
          printf '%-12s %s\n' "$topic" "$name_line"
          found=1
        fi
      done
      [ "$found" = 1 ] || { echo "no topics matched '$kw'" >&2; exit 1; }
      return 0 ;;
    "")
      echo "kai info — language reference, organized by topic."
      echo
      echo "Topics:"
      ls "$INFO_DIR" 2>/dev/null | sed -n 's/\.md$//p' | sort | while read -r t; do
        name_line="$(awk '/^# /{h1=1; next} h1 && NF && !/^#/{print; exit}' "$INFO_DIR/$t.md")"
        printf '  %-12s %s\n' "$t" "$name_line"
      done
      echo
      echo "Usage:"
      echo "  kai info <topic>          Show topic page"
      echo "  kai info <topic> --json   Structured JSON"
      echo "  kai info --list           Topic names only"
      echo "  kai info -k <keyword>     Search"
      return 0 ;;
  esac

  topic="$1"
  shift

  # Issue #681: `builtins` is a dynamic topic — the doc tree comes from
  # the `#[doc(...)]` attributes in the auto-loaded core module set
  # (stdlib source), extracted by the compiler, not from a static .md
  # page. JSON is the canonical Phase 1 surface; the plain form prints
  # a per-module synopsis (module, item counts) derived from the same
  # dump.
  if [ "$topic" = "builtins" ]; then
    ensure_built
    case "${1:-}" in
      --json)
        exec "$KAIC2" --builtins-doc-json ;;
      *)
        echo "# builtins"
        echo
        echo "Doc attributes of the auto-loaded core module set"
        echo "(core/* + math/numeric + math/complex + effects + protocols + array)."
        echo
        "$KAIC2" --builtins-doc-json | awk '
          {
            n = split($0, parts, /"module": "/)
            for (i = 2; i <= n; i++) {
              mod = parts[i]; sub(/".*/, "", mod)
              items = parts[i]; cnt = gsub(/"kind": /, "", items)
              # count documented items in this module slice only
              docs = parts[i]; dcnt = gsub(/"doc": "/, "", docs)
              printf "  %-16s %3d items, %3d documented\n", mod, cnt, dcnt
            }
          }'
        echo
        echo "Full doc text: kai info builtins --json"
        exit 0 ;;
    esac
  fi

  page="$INFO_DIR/$topic.md"
  if [ ! -f "$page" ]; then
    echo "kai: error: no info page for '$topic'" >&2
    echo "  run 'kai info' to list available topics." >&2
    exit 1
  fi

  case "${1:-}" in
    --json)
      # Convert the page to JSON. Sections are H2 markdown headers
      # (`## Section name`). The H1 (`# topic`) is the page title and
      # is exposed as `"title"`; the first non-empty line after the H1
      # before any H2 is the tagline (exposed as `"tagline"`). Body of
      # each section is everything until the next H2 or EOF.
      awk -v topic="$topic" '
        function json_escape(s,    out, i, c, code) {
          out = ""
          for (i = 1; i <= length(s); i++) {
            c = substr(s, i, 1)
            code = ord[c]
            if (c == "\\")      out = out "\\\\"
            else if (c == "\"") out = out "\\\""
            else if (c == "\t") out = out "\\t"
            else if (c == "\n") out = out "\\n"
            else if (c == "\r") out = out "\\r"
            else if (code < 32) out = out sprintf("\\u%04x", code)
            else                out = out c
          }
          return out
        }
        BEGIN {
          for (i = 0; i < 128; i++) ord[sprintf("%c", i)] = i
          title = ""
          tagline = ""
          sec = ""
          buf = ""
          first = 1
          in_preamble = 0
          sections_started = 0
        }
        # H1: the page title.
        /^# / {
          title = substr($0, 3)
          in_preamble = 1
          next
        }
        # H2: a section header.
        /^## / {
          if (sec != "") {
            sub(/\n+$/, "", buf)
            if (!sections_started) {
              printf "{\n  \"topic\": \"%s\",\n  \"title\": \"%s\",\n  \"tagline\": \"%s\",\n  \"sections\": {", topic, json_escape(title), json_escape(tagline)
              sections_started = 1
            }
            if (!first) printf ","
            first = 0
            printf "\n    \"%s\": \"%s\"", json_escape(sec), json_escape(buf)
          }
          sec = substr($0, 4)
          buf = ""
          in_preamble = 0
          next
        }
        {
          if (in_preamble) {
            # Collect first non-empty line as tagline.
            if (tagline == "" && NF > 0) {
              tagline = $0
            }
          } else if (sec != "") {
            buf = buf $0 "\n"
          }
        }
        {
          if (sec != "") {
            buf = buf $0 "\n"
          }
        }
        END {
          if (sec != "") {
            sub(/\n+$/, "", buf)
            if (!sections_started) {
              printf "{\n  \"topic\": \"%s\",\n  \"title\": \"%s\",\n  \"tagline\": \"%s\",\n  \"sections\": {", topic, json_escape(title), json_escape(tagline)
              sections_started = 1
            }
            if (!first) printf ","
            first = 0
            printf "\n    \"%s\": \"%s\"", json_escape(sec), json_escape(buf)
          } else if (!sections_started) {
            printf "{\n  \"topic\": \"%s\",\n  \"title\": \"%s\",\n  \"tagline\": \"%s\",\n  \"sections\": {", topic, json_escape(title), json_escape(tagline)
            sections_started = 1
          }
          printf "\n  }\n}\n"
        }
      ' "$page"
      return 0 ;;
    "")
      cat "$page"
      return 0 ;;
    *)
      echo "kai: error: unknown flag for 'kai info $topic': $1" >&2
      echo "  try '--json' or no flag." >&2
      exit 2 ;;
  esac
}

case "${1:-}" in
  build)     shift; cmd_build "$@" ;;
  run)       shift; cmd_run   "$@" ;;
  test)      shift; cmd_test  "$@" ;;
  bench)     shift; cmd_bench "$@" ;;
  check)     shift; cmd_check "$@" ;;
  fmt)       shift; cmd_fmt   "$@" ;;
  watch)     shift; cmd_watch "$@" ;;
  init)      shift; cmd_init    "$@" ;;
  install)   shift; cmd_install "$@" ;;
  add)       shift; cmd_add     "$@" ;;
  update)    shift; cmd_update  "$@" ;;
  show)      shift; cmd_show_pkg "$@" ;;
  lsp)       shift; cmd_lsp     "$@" ;;
  info)      shift; cmd_info    "$@" ;;
  doc)       shift; cmd_doc     "$@" ;;
  help|-h|--help) usage ;;
  --version|-V) print_version ;;
  "")        usage >&2; exit 2 ;;
  *)         echo "kai: error: unknown command: $1" >&2; usage >&2; exit 2 ;;
esac
