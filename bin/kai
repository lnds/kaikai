#!/bin/sh
# kai — stage 2 compiler driver.
#
# Subcommands:
#   kai build <file.kai> [-o <out>]   compile to a native binary
#   kai run   <file.kai> [args...]    compile and execute; forward args
#   kai test  <file.kai>              compile with --test and run
#   kai bench <file.kai>              compile with --bench and run
#   kai help                          show this help
#   kai --version                     print version
#
# The driver wraps kaic2 + cc. It auto-builds stages 0/1/2 on first
# use if their binaries are missing. Paths resolve relative to this
# script's own location, so the script works from any working
# directory.
#
# Auto-loaded preludes (in order): stdlib/core/*.kai sorted
# alphabetically (char before string is required because
# string_trim_*_loop calls ch_is_space), stdlib/protocols.kai
# (Show/Eq/Ord/Hash/Serialize for primitives), stdlib/effects.kai
# (Stdin/Stdout/Stderr/File/Env declarations, created in m12.8.x
# phase 4), stdlib/random.kai (shuffle / choice / sample on top of
# the Random effect). Each is opt-out via env var KAI_NO_STDLIB=1
# (skips all) or by deleting the file.

set -eu

# kaic1/kaic2 lex their input recursively (lex_loop is not TCO'd in
# stage 0's C output). On ~10 k-line sources the default 8 MB thread
# stack overflows. Bump to 32 MB; ignore failure on shells/systems
# that reject it.
ulimit -s 32768 2>/dev/null || true

# Resolve script path portably (macOS lacks GNU readlink -f).
SCRIPT="$0"
case "$SCRIPT" in
  /*) ;;
  *)  SCRIPT="$(pwd)/$SCRIPT" ;;
esac
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

KAIC0="$ROOT/stage0/kaic0"
KAIC1="$ROOT/stage1/kaic1"
KAIC2="$ROOT/stage2/kaic2"
RUNTIME_INC="$ROOT/stage0"
STDLIB_CORE_DIR="$ROOT/stdlib/core"
STDLIB_PROTOCOLS="$ROOT/stdlib/protocols.kai"
STDLIB_EFFECTS="$ROOT/stdlib/effects.kai"
STDLIB_RANDOM="$ROOT/stdlib/random.kai"
STDLIB_BASE64="$ROOT/stdlib/encoding/base64.kai"
STDLIB_HEX="$ROOT/stdlib/encoding/hex.kai"
STDLIB_MAP="$ROOT/stdlib/collections/map.kai"
STDLIB_SET="$ROOT/stdlib/collections/set.kai"
STDLIB_QUEUE="$ROOT/stdlib/collections/queue.kai"
STDLIB_STACK="$ROOT/stdlib/collections/stack.kai"
STDLIB_MATH_NUMERIC="$ROOT/stdlib/math/numeric.kai"
STDLIB_MATH_INT="$ROOT/stdlib/math/int.kai"
STDLIB_MATH_REAL="$ROOT/stdlib/math/real.kai"
STDLIB_JSON="$ROOT/stdlib/encoding/json.kai"
STDLIB_DECIMAL="$ROOT/stdlib/decimal.kai"
STDLIB_MONEY="$ROOT/stdlib/money.kai"
STDLIB_UUID="$ROOT/stdlib/uuid.kai"
STDLIB_REGEXP="$ROOT/stdlib/regexp.kai"
STDLIB_PATH="$ROOT/stdlib/path.kai"

CC="${CC:-cc}"
CFLAGS="${CFLAGS:--std=c99 -Wno-unused-function -Wno-unused-variable -O2}"

die() {
  echo "kai: error: $*" >&2
  exit 2
}

# $1 = path that was not found; $2 = subcommand name (build/run/test)
die_file_not_found() {
  echo "kai: error: file '$1' not found." >&2
  echo "Try 'kai $2 --help' for usage." >&2
  exit 2
}

read_version() {
  if [ -f "$ROOT/VERSION" ]; then
    cat "$ROOT/VERSION"
  else
    echo "unknown"
  fi
}

read_baseline() {
  if [ -f "$ROOT/demos/baseline.txt" ]; then
    cat "$ROOT/demos/baseline.txt"
  else
    echo "?"
  fi
}

ensure_built() {
  if [ ! -x "$KAIC0" ]; then
    (cd "$ROOT/stage0" && make kaic0) >&2
  fi
  if [ ! -x "$KAIC1" ]; then
    (cd "$ROOT/stage1" && make kaic1) >&2
  fi
  if [ ! -x "$KAIC2" ]; then
    (cd "$ROOT/stage2" && make kaic2) >&2
  fi
}

usage() {
  v="$(read_version)"
  cat <<EOF
 _      _ _      _
| |____(_) |____(_)    kaikai $v
| / / _\` | / / _\` |    a statically typed functional language
|_\\_\\__,_|_\\_\\__,_|    effects | fibers | protocols

usage: kai <command> [args...]

Commands:
  build <file.kai> [-o <out>]   Compile a kaikai file to a native binary.
  run   <file.kai> [args...]    Build and execute; forwards remaining args.
  test  <file.kai>              Compile with --test and run the test binary.
  bench <file.kai>              Compile with --bench and run the bench binary.
  fmt   <file.kai> [--check]    Pretty-print kaikai source canonically.
  help                          Show this help.
  --version                     Print version and demo baseline.

Run 'kai <command> --help' for command-specific options.

Environment:
  CC               C compiler to invoke (default: cc).
  CFLAGS           Extra flags passed to CC.
  KAI_NO_STDLIB    If 1, skip auto-loading the stdlib preludes.

See README.md and docs/ for the language reference.
Project home: https://kaikai-lang.org
EOF
}

usage_build() {
  cat <<EOF
usage: kai build <file.kai> [-o <out>]

Compile a kaikai source file to a native binary using kaic2 + cc.

Options:
  -o <out>     Output binary path (default: basename of input without .kai).
  -h, --help   Show this help.

Examples:
  kai build hello.kai                    # produces ./hello
  kai build src/app.kai -o build/app     # produces ./build/app

The compiler auto-loads the stdlib preludes (stdlib/core, protocols,
effects, etc.). Set KAI_NO_STDLIB=1 to skip them.
EOF
}

usage_run() {
  cat <<EOF
usage: kai run <file.kai> [args...]

Compile and immediately execute a kaikai program. Any arguments after
the source file are forwarded to the compiled binary.

Options:
  -h, --help   Show this help.

Examples:
  kai run examples/minimal/hello.kai
  kai run demos/fizzbuzz/fizzbuzz.kai 30
  kai run app.kai --user alice --port 8080

The temporary binary is removed after the program exits.
EOF
}

usage_test() {
  cat <<EOF
usage: kai test <file.kai>

Compile a kaikai source with --test enabled and run the test binary.
The compiler emits a main that runs every 'test "..." { ... }' block
and reports the result.

Options:
  -h, --help   Show this help.

Examples:
  kai test stage2/tests/test_lex.kai
  kai test demos/poker/poker.kai
EOF
}

usage_bench() {
  cat <<EOF
usage: kai bench <file.kai>

Compile a kaikai source with --bench enabled and run the bench binary.
The compiler emits a main that runs every 'bench "..." { ... }' block
under clock_gettime(CLOCK_MONOTONIC) and reports the mean ns/iter.

bench v1 (issue #40): N is fixed at 1000 iterations and only mean
ns/iter is reported. Median + MAD-based outlier stats, configurable
iteration counts, and selfhost-bench arrive in v1.x / v1.y.

Options:
  -h, --help   Show this help.

Examples:
  kai bench examples/stdlib/bench_basic.kai
EOF
}

usage_fmt() {
  cat <<EOF
usage: kai fmt <file.kai>            # rewrite file in place
       kai fmt --check <file.kai>    # exit 0 if formatted, 1 if not
       kai fmt --stdin               # read stdin -> formatted to stdout

Pretty-print kaikai source canonically. The formatter is gofmt-style:
no options, single output, idempotent.

Tongariki MVP scope: imports, simple fns, type decls, tests, and the
base expression / pattern / type grammar (see CHANGELOG for the exact
list). Files using effects, handlers, protocols, impls, units, dim
types, refinements, axioms, generic fn / type parameters, var, or
parametric effect rows are refused with an explicit error.

Options:
  --check      Do not modify the file. Exit 0 if already formatted; 1
               otherwise. Print the formatted output to stdout when
               different.
  --stdin      Read kaikai source from stdin; write formatted source
               to stdout. The file form (kai fmt <file>) rewrites the
               file in place; this form is for editor integrations.
  -h, --help   Show this help.

Examples:
  kai fmt stage2/compiler.kai
  kai fmt --check src/foo.kai && echo OK
  cat src/foo.kai | kai fmt --stdin > /tmp/foo-fmt.kai
EOF
}

print_version() {
  v="$(read_version)"
  baseline="$(read_baseline)"
  cat <<EOF
kaikai $v (stage 2, self-hosted)
demos baseline: $baseline
home:           https://kaikai-lang.org
EOF
}

# $1 = source .kai path; $2 = tmpdir; $3 = output binary path;
# $4 = subcommand name (for help-pointer in errors); rest = extra kaic2 flags
compile_to_binary() {
  src="$1"; tmp="$2"; out="$3"; sub="$4"; shift 4
  [ -f "$src" ] || die_file_not_found "$src" "$sub"
  ensure_built
  prelude_flags=""
  if [ "${KAI_NO_STDLIB:-}" != "1" ]; then
    if [ -d "$STDLIB_CORE_DIR" ]; then
      for core_file in "$STDLIB_CORE_DIR"/*.kai; do
        [ -f "$core_file" ] && prelude_flags="$prelude_flags --prelude $core_file"
      done
    fi
    [ -f "$STDLIB_PROTOCOLS" ] && prelude_flags="$prelude_flags --prelude $STDLIB_PROTOCOLS"
    [ -f "$STDLIB_EFFECTS" ]   && prelude_flags="$prelude_flags --prelude $STDLIB_EFFECTS"
    [ -f "$STDLIB_RANDOM" ]    && prelude_flags="$prelude_flags --prelude $STDLIB_RANDOM"
    [ -f "$STDLIB_BASE64" ]    && prelude_flags="$prelude_flags --prelude $STDLIB_BASE64"
    [ -f "$STDLIB_HEX" ]       && prelude_flags="$prelude_flags --prelude $STDLIB_HEX"
    [ -f "$STDLIB_MAP" ]       && prelude_flags="$prelude_flags --prelude $STDLIB_MAP"
    [ -f "$STDLIB_SET" ]       && prelude_flags="$prelude_flags --prelude $STDLIB_SET"
    [ -f "$STDLIB_QUEUE" ]     && prelude_flags="$prelude_flags --prelude $STDLIB_QUEUE"
    [ -f "$STDLIB_STACK" ]     && prelude_flags="$prelude_flags --prelude $STDLIB_STACK"
    [ -f "$STDLIB_MATH_NUMERIC" ] && prelude_flags="$prelude_flags --prelude $STDLIB_MATH_NUMERIC"
    [ -f "$STDLIB_MATH_INT" ]     && prelude_flags="$prelude_flags --prelude $STDLIB_MATH_INT"
    [ -f "$STDLIB_MATH_REAL" ]    && prelude_flags="$prelude_flags --prelude $STDLIB_MATH_REAL"
    [ -f "$STDLIB_JSON" ]      && prelude_flags="$prelude_flags --prelude $STDLIB_JSON"
    [ -f "$STDLIB_DECIMAL" ]   && prelude_flags="$prelude_flags --prelude $STDLIB_DECIMAL"
    [ -f "$STDLIB_MONEY" ]     && prelude_flags="$prelude_flags --prelude $STDLIB_MONEY"
    [ -f "$STDLIB_UUID" ]      && prelude_flags="$prelude_flags --prelude $STDLIB_UUID"
    [ -f "$STDLIB_REGEXP" ]    && prelude_flags="$prelude_flags --prelude $STDLIB_REGEXP"
    [ -f "$STDLIB_PATH" ]      && prelude_flags="$prelude_flags --prelude $STDLIB_PATH"
  fi
  # shellcheck disable=SC2086
  # KAI_TRACE_RC unset for the compiler invocation: we want the trace
  # to come from the user's compiled program, not from kaic2 itself.
  # Without this the wrapper's compile step and the child binary both
  # fire their RC reports, doubling the output.
  KAI_TRACE_RC= "$KAIC2" --path "$ROOT/stdlib" $prelude_flags "$@" "$src" > "$tmp/out.c"
  # shellcheck disable=SC2086
  $CC $CFLAGS -I "$RUNTIME_INC" "$tmp/out.c" -o "$out"
}

cmd_build() {
  src=""; out=""
  while [ $# -gt 0 ]; do
    case "$1" in
      -o) shift; [ $# -gt 0 ] || die "-o needs an argument"; out="$1"; shift ;;
      -h|--help) usage_build; return 0 ;;
      -*) die "unknown flag: $1 (see 'kai build --help')" ;;
      *) [ -z "$src" ] || die "only one input file supported"; src="$1"; shift ;;
    esac
  done
  [ -n "$src" ] || die "missing input file (see 'kai build --help')"
  if [ -z "$out" ]; then
    out="$(basename "$src" .kai)"
  fi
  tmp="$(mktemp -d)"
  trap 'rm -rf "$tmp"' EXIT INT TERM
  compile_to_binary "$src" "$tmp" "$out" "build"
}

cmd_run() {
  case "${1:-}" in
    -h|--help) usage_run; return 0 ;;
    "") die "missing input file (see 'kai run --help')" ;;
  esac
  src="$1"; shift
  tmp="$(mktemp -d)"
  trap 'rm -rf "$tmp"' EXIT INT TERM
  bin="$tmp/$(basename "$src" .kai)"
  compile_to_binary "$src" "$tmp" "$bin" "run"
  "$bin" "$@"
}

cmd_test() {
  case "${1:-}" in
    -h|--help) usage_test; return 0 ;;
    "") die "missing input file (see 'kai test --help')" ;;
  esac
  src="$1"; shift
  tmp="$(mktemp -d)"
  trap 'rm -rf "$tmp"' EXIT INT TERM
  bin="$tmp/$(basename "$src" .kai)-t"
  compile_to_binary "$src" "$tmp" "$bin" "test" --test
  "$bin"
}

cmd_bench() {
  case "${1:-}" in
    -h|--help) usage_bench; return 0 ;;
    "") die "missing input file (see 'kai bench --help')" ;;
  esac
  src="$1"; shift
  tmp="$(mktemp -d)"
  trap 'rm -rf "$tmp"' EXIT INT TERM
  bin="$tmp/$(basename "$src" .kai)-b"
  compile_to_binary "$src" "$tmp" "$bin" "bench" --bench
  "$bin"
}

# kai fmt — pretty-print kaikai source canonically.
#
# Three input modes:
#   kai fmt <file>             -> rewrite <file> in place
#   kai fmt --check <file>     -> exit 1 if <file> would change, else 0;
#                                  print formatted text to stdout when
#                                  different (matches `gofmt -l` spirit
#                                  but with the diff in the body).
#   kai fmt --stdin            -> read stdin, write formatted to stdout.
#
# The formatter is implemented as a `kaic2 --fmt` (or `--fmt-check`)
# subcommand. The driver does NOT pass `--prelude` flags here — fmt
# runs at the source-text level and never resolves names; the prelude
# would only slow the parse and the unsupported-check.
cmd_fmt() {
  src=""; mode_check=""; stdin_mode=""
  while [ $# -gt 0 ]; do
    case "$1" in
      -h|--help) usage_fmt; return 0 ;;
      --check)   mode_check=1; shift ;;
      --stdin)   stdin_mode=1; shift ;;
      -*)        die "unknown flag: $1 (see 'kai fmt --help')" ;;
      *)         [ -z "$src" ] || die "only one input file supported"
                 src="$1"; shift ;;
    esac
  done
  ensure_built

  if [ -n "$stdin_mode" ]; then
    [ -z "$src" ] || die "--stdin takes no file argument"
    tmp="$(mktemp -d)"
    trap 'rm -rf "$tmp"' EXIT INT TERM
    cat > "$tmp/in.kai"
    "$KAIC2" --fmt "$tmp/in.kai"
    return $?
  fi

  [ -n "$src" ] || die "missing input file (see 'kai fmt --help')"
  [ -f "$src" ] || die_file_not_found "$src" "fmt"

  if [ -n "$mode_check" ]; then
    "$KAIC2" --fmt-check "$src"
    return $?
  fi

  tmp="$(mktemp -d)"
  trap 'rm -rf "$tmp"' EXIT INT TERM
  if "$KAIC2" --fmt "$src" > "$tmp/out.kai"; then
    # Only write back when the formatted text differs (avoids touching
    # the file mtime on a no-op).
    if ! cmp -s "$src" "$tmp/out.kai"; then
      cat "$tmp/out.kai" > "$src"
    fi
  else
    cat "$tmp/out.kai" >&2 2>/dev/null || true
    return 1
  fi
}

case "${1:-}" in
  build)     shift; cmd_build "$@" ;;
  run)       shift; cmd_run   "$@" ;;
  test)      shift; cmd_test  "$@" ;;
  bench)     shift; cmd_bench "$@" ;;
  fmt)       shift; cmd_fmt   "$@" ;;
  help|-h|--help) usage ;;
  --version|-V) print_version ;;
  "")        usage >&2; exit 2 ;;
  *)         echo "kai: error: unknown command: $1" >&2; usage >&2; exit 2 ;;
esac
