EOF
}

usage_watch() {
  cat <<EOF
usage: kai watch <file.kai> [args...]

Watch a kaikai source file and recompile + run it on every save.
Useful for live demos: edit in one pane, see output in the other.

Behavior:
  - On entry, the file is compiled and run once.
  - On each save, the screen prints a timestamped header followed by
    the compile result. Build errors keep the watch loop alive.
  - Press Ctrl+C to exit.

Backend:
  - If fswatch is on PATH, kai uses it (one event per save).
  - Otherwise, kai falls back to a 500 ms mtime poll. Install
    fswatch (brew install fswatch) for lower latency.

Options:
  -h, --help   Show this help.

Examples:
  kai watch demo.kai
  kai watch examples/minimal/hello.kai
EOF
}

usage_fmt() {
  cat <<EOF
usage: kai fmt <file.kai>            # rewrite file in place
       kai fmt --check <file.kai>    # exit 0 if formatted, 1 if not
       kai fmt --stdin               # read stdin -> formatted to stdout

Pretty-print kaikai source canonically. The formatter is gofmt-style:
no options, single output, idempotent.

Tongariki MVP scope: imports, simple fns, type decls, tests, and the
base expression / pattern / type grammar (see CHANGELOG for the exact
list). Files using effects, handlers, protocols, impls, units, dim
types, refinements, axioms, generic fn / type parameters, var, or
parametric effect rows are refused with an explicit error.

Options:
  --check      Do not modify the file. Exit 0 if already formatted; 1
               otherwise. Print the formatted output to stdout when
               different.
  --stdin      Read kaikai source from stdin; write formatted source
               to stdout. The file form (kai fmt <file>) rewrites the
               file in place; this form is for editor integrations.
  -h, --help   Show this help.

Examples:
  kai fmt stage2/compiler.kai
  kai fmt --check src/foo.kai && echo OK
  cat src/foo.kai | kai fmt --stdin > /tmp/foo-fmt.kai
EOF
}

read_edition() {
  if [ -f "$ROOT/EDITION" ]; then
    cat "$ROOT/EDITION"
  elif [ -f "$ROOT/share/kaikai/EDITION" ]; then
    cat "$ROOT/share/kaikai/EDITION"
  else
    echo "unknown"
  fi
}

print_version() {
  v="$(read_version)"
  edition="$(read_edition)"
  baseline="$(read_baseline)"
  cat <<EOF
kaikai $v - $edition (stage 2, self-hosted)
demos baseline: $baseline
home:           https://kaikai-lang.org
EOF
}

# Resolve the active backend. Precedence (highest first):
#   1. Caller-supplied value (the --backend CLI flag, already parsed).
#   2. $KAI_BACKEND environment variable (c|native).
#   3. Hard-coded default: `native`.
#
# `native` is the in-process libLLVM backend (docs/kir-design.md §7.2):
# it builds the LLVM module via the C API in one process and emits a
# native object — no `.ll` text, no `clang`. As of the Lane 1.5 flip
# (native-vs-C parity ratchet reached zero, llvm-text backend removed in
# #850) it is the DEFAULT destination of `kai build` / `kai run`.
#
# `c` is the portable C-text backend — the bootstrap path and the parity
# oracle, supported across the whole corpus. It stays reachable via
# `--backend=c` / `KAI_BACKEND=c` and remains the backend every dev-loop
# subcommand (test / bench / check / watch) uses.
#
# Graceful degradation (the load-bearing flip subtlety): a kaic2 built
# WITHOUT libLLVM (the cc-only bootstrap path — Tier 1: stage 0/1 build
# from any `cc`, no LLVM) cannot run the native backend. When `native`
# is the IMPLICIT default and this kaic2 is C-only, the build degrades
# to the C backend with a one-line notice rather than aborting — a dev
# who bootstrapped without LLVM must keep building. An EXPLICIT
# `--backend=native` / `KAI_BACKEND=native` on a C-only kaic2 still
# errors (compile_to_binary): the user asked for a backend this compiler
# does not carry, and silently downgrading would mask that. The
# distinction is carried by the second word this function prints:
# `explicit` when the choice came from a flag/env, `implicit` when it is
# the default.
#
# Stages 0/1 are bootstrapped with the system cc and never see this logic.
#
# Echoes `<backend> <origin>` where origin is `explicit` or `implicit`.
resolve_backend() {
  cli_choice="$1"
  if [ -n "$cli_choice" ]; then
    printf '%s explicit' "$cli_choice"
    return 0
  fi
  if [ -n "${KAI_BACKEND:-}" ]; then
    case "$KAI_BACKEND" in
      c|native) printf '%s explicit' "$KAI_BACKEND"; return 0 ;;
      *) die "KAI_BACKEND must be 'c' or 'native' (got: $KAI_BACKEND)" ;;
    esac
  fi
  # Lane 1.5 flip: the in-process libLLVM `native` backend is now the
  # default (parity ratchet at zero). It degrades to `c` on a C-only
  # kaic2 — see compile_to_binary, which keys off the `implicit` origin.
  printf 'native implicit'
}

compile_to_binary() {
  # Leading flags carry the backend across the wrapper boundary, none
  # forwarded to kaic2:
  #   `--backend <c|native>`        the resolved backend.
  #   `--backend-origin <explicit|implicit>`
  #                                 whether that choice came from a
  #                                 flag/env (explicit) or the default
  #                                 (implicit). Drives graceful
  #                                 degradation on a C-only kaic2.
  # `kai build` / `kai run` always pass both, resolved through
  # resolve_backend() (default since Lane 1.5: `native`). The dev-loop
  # subcommands (`kai test` / `bench` / `check` / watch) call without
  # either flag and so use the `c` fallback directly — they stay on the
  # C oracle, unaffected by the flip.
  backend="c"
  backend_origin="explicit"
  while :; do
    case "${1:-}" in
      --backend)        shift; backend="$1"; shift ;;
      --backend-origin) shift; backend_origin="$1"; shift ;;
      *) break ;;
    esac
  done
  src="$1"; tmp="$2"; out="$3"; sub="$4"; shift 4
  [ -f "$src" ] || die_file_not_found "$src" "$sub"
  ensure_built
  # shellcheck disable=SC2086
  # KAI_TRACE_RC unset for the compiler invocation: we want the trace
  # to come from the user's compiled program, not from kaic2 itself.
  # Without this the wrapper's compile step and the child binary both
  # fire their RC reports, doubling the output. Note: a real `unset`
  # is required — `KAI_TRACE_RC= cmd` only sets the var to the empty
  # string, but the runtime gates the report on `getenv() != NULL`,
  # which is still true for an empty value (issue #81).
  # Auto-add the entry file's own directory to the module search path so
  # `kai run main.kai` finds sibling modules (issue #233). kaic2 already
  # tries `dir_of(root_path)` before the --path entries internally
  # (see stage2/compiler.kai expand_imports / find_module_file), so this
  # is defense-in-depth: it makes the contract explicit at the driver
  # level and survives any future change to that internal first-try.
  # `dirname` works for both absolute and relative `$src`. We then
  # `cd … && pwd` to resolve to absolute so the path passed to kaic2 is
  # unambiguous regardless of CWD — a relative `.` from a bare
  # `hello.kai` would otherwise alias the user's CWD and conflict with
  # the resolver's CWD-relative lookup (issue #237).
  src_dir="$(cd "$(dirname "$src")" && pwd)"
  # Walk up from src_dir looking for kai.toml; if found, emit
  # `--path <abs>` flags for each local-path dependency. Silent and
  # zero-cost when no manifest exists (issue #405).
  manifest_dir="$(find_manifest_dir "$src_dir")"
  pkg_path_flags=""
  unstable_flags=""
  edition_flag="$(manifest_edition_flag "$manifest_dir")"
  if [ -n "$manifest_dir" ]; then
    pkg_path_flags="$(manifest_path_flags "$manifest_dir")"
    unstable_flags="$(manifest_unstable_flags "$manifest_dir")"
  fi
  # Issue #455 Phase B: opt-in user-file incremental cache. Off by
  # default — the build path is byte-for-byte unchanged unless the user
  # sets KAI_CACHE=1. When on, the cache lives at the project root (the
  # manifest dir, or the entry file's dir when there is no kai.toml);
  # we create it here because kaic2 only has read_file/write_file (no
  # mkdir among the bootstrap-stage1 prims), and pass --user-cache so
  # the driver consults compiler.user_cache before lexing each import.
  user_cache_flag=""
  if [ "${KAI_CACHE:-0}" = "1" ]; then
    cache_proj_dir="${manifest_dir:-$src_dir}"
    mkdir -p "$cache_proj_dir/.kai-cache" 2>/dev/null || true
    user_cache_flag="--user-cache"
  fi
  if [ "$backend" = "native" ]; then
    # KIR Lane 1.5: the in-process libLLVM native backend is the default.
    # `kaic2 --emit=native` lowers to KIR, builds the LLVM module via the
    # C API IN MEMORY, and writes a native OBJECT — no `.ll` text, no
    # `clang` subprocess. We then link that object against the effects
    # runtime shim (runtime_llvm.c) with `cc`. The native backend needs
    # no clang at runtime: libLLVM is linked INTO kaic2 (statically in a
    # release), so the user needs neither clang nor a system LLVM.
    if [ -z "$RUNTIME_LLVM_C" ]; then
      die "native backend: cannot locate runtime_llvm.c (looked under $RUNTIME_INC and $ROOT/stage0)"
    fi
    # kaic2 derives the object path from the SOURCE path (foo.kai ->
    # foo.o), so compiling the user's file in place would drop a `.o`
    # into their tree (and race the parity fan-out / break a read-only
    # checkout). Compile a copy under $tmp instead, and point the module
    # resolver back at the real source dir with --path so relative
    # imports still resolve. (bin/kai already passes --path "$src_dir"
    # on every backend; here it is load-bearing because the entry file
    # itself moved to $tmp.)
    src_base="$(basename "$src")"
    cp "$src" "$tmp/$src_base"
    obj="$tmp/${src_base%.kai}.o"
    nerr="$tmp/native.err"
    # P2: when the runtime bitcode is vendored, point kaic2 at it so it
    # links it into the module before O2 (the object then defines main +
    # every kaix_*, and the cc link below drops runtime_llvm.c). Absent →
    # the env var stays unset, kaic2's link step is a no-op, and the cc
    # link keeps runtime_llvm.c (legacy path). `--debug` (KAI_NATIVE_OPT=0)
    # is unaffected: the bitcode is still linked, just not O2-inlined.
    nbc_env=""
    if [ -n "$RUNTIME_LLVM_BC" ]; then
      nbc_env="$RUNTIME_LLVM_BC"
    fi
    # shellcheck disable=SC2086
    if ! (unset KAI_TRACE_RC; KAI_NATIVE_RUNTIME_BC="$nbc_env" "$KAIC2" --emit=native --path "$STDLIB_ROOT" --path "$src_dir" $pkg_path_flags $unstable_flags $edition_flag "$@" "$tmp/$src_base") >/dev/null 2>"$nerr"; then
      # Distinguish "this kaic2 has no native backend" (actionable: the
      # build was C-only) from a real compile error in the user program.
      # The C-only stub aborts with a known sentinel string; anything
      # else is the user's compile error and propagates verbatim. We
      # never silently fall back on a REAL native codegen failure — that
      # would mask it as success (the rejected hot-fallback). The
      # C-only-capability case is different: it is not a codegen failure,
      # it is a compiler that physically cannot run this backend.
      if grep -q "not built into this compiler" "$nerr" 2>/dev/null; then
        if [ "$backend_origin" = "implicit" ]; then
          # Lane 1.5 flip: `native` is the DEFAULT, but this kaic2 was
          # bootstrapped without libLLVM (cc-only — the Tier 1 bootstrap
          # path). Degrade to the C backend with a notice so the dev keeps
          # building; do not abort on a default the compiler cannot honour.
          # EVERY line is prefixed `kai:` — diagnostic tooling (and the
          # package harness, tools/test-packages.sh) strips `^kai:` lines
          # to isolate program output, so a bare indented hint line would
          # leak into compared stdout and break a golden (the tier1
          # test-packages break the first cut of this lane hit).
          echo "kai: note: native backend unavailable in this kaic2 (built without libLLVM); using the C backend." >&2
          echo "kai: note: rebuild with 'make -C stage2 KAI_LLVM=1 kaic2' for the native default, or pass --backend=c to silence this note." >&2
          compile_to_binary --backend c --backend-origin explicit "$src" "$tmp" "$out" "$sub" "$@"
          return $?
        fi
        # Explicit --backend=native / KAI_BACKEND=native on a C-only
        # kaic2: the user asked for a backend this compiler does not
        # carry. Error, do not downgrade. Same `kai:`-prefix discipline.
        echo "kai: error: the native backend is not built into this kaic2." >&2
        echo "kai: error: rebuild with 'make -C stage2 KAI_LLVM=1 kaic2', or pass --backend=c." >&2
        cat "$nerr" >&2
        exit 2
      fi
      cat "$nerr" >&2
      exit 1
    fi
    if [ ! -f "$obj" ]; then
      die "native backend: no object produced (expected $obj)"
    fi
    # shellcheck disable=SC2086
    # Same runtime-include precedence as the C path: the shim's
    # `#include "runtime.h"` must bind to stage2's Koka runtime
    # (tagged Int, slab, reuse-token), so $RUNTIME_INC_C leads.
    #
    # P2: if the bitcode was linked in-process, the object already defines
    # main + every kaix_* (the runtime is merged + internalised + DCE'd into
    # it), so the cc link is just the object + libm — adding runtime_llvm.c
    # would be a duplicate-symbol error. Without the bitcode (legacy /
    # fallback), cc compiles+links runtime_llvm.c as before. The -I flags are
    # only needed when runtime_llvm.c is compiled, but they are harmless on
    # the self-contained line so the two arms stay close.
    if [ -n "$RUNTIME_LLVM_BC" ]; then
      $CC $CFLAGS "$obj" -o "$out" -lm
    else
      $CC $CFLAGS -I "$RUNTIME_INC_C" -I "$RUNTIME_INC" "$obj" "$RUNTIME_LLVM_C" -o "$out" -lm
    fi
  elif [ "${KAI_MODULAR:-0}" = "1" ]; then
    # Issue #748: separate compilation. kaic2 emits a marker-delimited
    # stream of per-module `.c` files + two shared headers
    # (kai_types.h, kai_decls.h). We split the stream into files, compile
    # each `.c` to its own `.o`, and link the `.o` files. Each module is
    # its own translation unit with its own C symbol space; cross-module
    # calls resolve at link time through the shared kai_decls.h
    # prototypes. Opt-in via KAI_MODULAR=1 while the path is validated;
    # the default C path below stays single-TU (and selfhost-identical).
    # shellcheck disable=SC2086
    (unset KAI_TRACE_RC; "$KAIC2" --emit=c-modular --path "$STDLIB_ROOT" --path "$src_dir" $pkg_path_flags $unstable_flags $edition_flag "$@" "$src") > "$tmp/modular.stream"
    moddir="$tmp/mod"
    mkdir -p "$moddir"
    # Split the stream on the column-0 `//KAIFILE:<nonce>::<name>`
    # markers. Line 1 is `//KAIDELIM:<nonce>`; we read the nonce from it
    # so the awk match is exact and cannot fire on emitted C. Each marker
    # opens a new output file under $moddir.
    nonce="$(sed -n '1s/^\/\/KAIDELIM://p' "$tmp/modular.stream")"
    if [ -z "$nonce" ]; then
      die "internal: --emit=c-modular produced no //KAIDELIM marker"
    fi
    # While splitting, drop the leading `static ` from every emitted
    # top-level definition/prototype so cross-module symbols get EXTERNAL
    # linkage (separate compilation: a `static` symbol is invisible
    # across `.o` files). The strip is anchored to column 0 AND gated on
    # a closed whitelist of emitted return types (KaiValue *, int64_t,
    # double, int, uint32_t) so it never touches runtime.h's intentional
    # statics (those live in runtime.h, not this stream) nor a `static`
    # local variable inside a body (always indented). Names are uniquely
    # mangled, so external linkage cannot clash between two emitted
    # symbols (that was the #748 mangling fix).
    awk -v dir="$moddir" -v pfx="//KAIFILE:$nonce::" '
      index($0, pfx) == 1 { fn = substr($0, length(pfx) + 1); out = dir "/" fn; next }
      out {
        if ($0 ~ /^static (KaiValue \*|int64_t |double |int |uint32_t )/) {
          sub(/^static /, "", $0)
        }
        print > out
      }
    ' "$tmp/modular.stream"
    # Copy the runtime header next to the generated sources so the
    # emitted `#include "runtime.h"` resolves without an -I race against
    # a stale system copy. (kai_types.h includes runtime.h by name.)
    cp "$RUNTIME_INC_C/runtime.h" "$moddir/runtime.h" 2>/dev/null || true
    # Compile each generated .c to its own .o, then link.
    objs=""
    for cfile in "$moddir"/*.c; do
      ofile="${cfile%.c}.o"
      # shellcheck disable=SC2086
      $CC $CFLAGS -I "$moddir" -I "$RUNTIME_INC_C" -I "$RUNTIME_INC" -c "$cfile" -o "$ofile" \
        || die "modular compile failed for $(basename "$cfile")"
      objs="$objs $ofile"
    done
    # shellcheck disable=SC2086
    $CC $CFLAGS $objs -o "$out" -lm \
      || die "modular link failed"
  else
    # shellcheck disable=SC2086
    (unset KAI_TRACE_RC; "$KAIC2" --path "$STDLIB_ROOT" --path "$src_dir" $pkg_path_flags $unstable_flags $edition_flag $user_cache_flag "$@" "$src") > "$tmp/out.c"
    # struct-by-value FFI emits a marker stream (line 1 `//KAIDELIM:`)
    # carrying a shared `kai_ffi.h` + `out.c`. Split it INTO A SUBDIR (the
    # awk input is `$tmp/out.c`, so writing the split `out.c` back to
    # `$tmp` would truncate the file awk is still reading) so a hand-written
    # shim can `#include "kai_ffi.h"` and name the SAME struct type the
    # boundary uses. Plain programs (no extern struct) emit bare `out.c`
    # with no marker — the common path, byte-identical to before.
    cfile="$tmp/out.c"; cincl="$RUNTIME_INC_C"
    nonce="$(sed -n '1s/^\/\/KAIDELIM://p' "$tmp/out.c")"
    if [ -n "$nonce" ]; then
      ffidir="$tmp/ffi"
      mkdir -p "$ffidir"
      awk -v dir="$ffidir" -v pfx="//KAIFILE:$nonce::" '
        index($0, pfx) == 1 { out = dir "/" substr($0, length(pfx) + 1); next }
        out { print > out }
      ' "$tmp/out.c"
      cfile="$ffidir/out.c"; cincl="$ffidir"
    fi
    # shellcheck disable=SC2086
    # `-lm` (issue #343): math/real libm bindings (sqrt, sin, log, …)
    # are unresolved on Linux glibc without an explicit link line.
    # macOS libSystem already exposes them, so the flag is a no-op.
    #
    # `-I "$RUNTIME_INC_C"` comes FIRST so the emitted `#include
    # "runtime.h"` resolves to stage 2's Koka-style runtime (tagged Int,
    # kai_intf, reuse-token). `-I "$RUNTIME_INC"` (stage0) stays as a
    # fallback for the bootstrap-only header set; in dev layout these
    # differ, in installed layout they are the same dir. `-I "$cincl"`
    # (the split subdir, when present) lets the emitted `#include
    # "kai_ffi.h"` AND a shim in $CFLAGS resolve the shared FFI header.
    $CC $CFLAGS -I "$cincl" -I "$RUNTIME_INC_C" -I "$RUNTIME_INC" "$cfile" -o "$out" -lm
  fi
}

# If the user did not name an input file, try to infer one from the
# current directory:
#
#   1. If `./main.kai` exists, use it. This mirrors `go run .` —
#      the convention for package layouts is a single `main.kai`
#      entry-point next to `kai.toml`.
#   2. Otherwise, if the cwd has exactly one `.kai` file at the top
#      level, use it. Useful for tiny single-file scripts.
#
# Both branches print the inferred path to stderr so the user sees
# what got picked. Returns the path on stdout when found; empty
# string when no inference is possible (caller falls back to the
# old "missing input file" diagnostic).
# Issue #658: resolve a package spec — `.`, `./sub`, a relative
# `*.kai` file path, or empty (meaning the cwd) — into a concrete
# entry-point file path. Sub-package mode (`./sub`) requires the
# target directory to carry its own kai.toml; plain subdirectories
# of the current package are not separately buildable. `./...`
# (transitive test discovery) is handled by a dedicated walker in
# cmd_test, not here. File-path arguments (`foo.kai`) pass through
# unchanged so existing invocations keep working.
#
# Manifest-aware entry resolution: when the resolved directory has
# a kai.toml, the entry point is `manifest_entry_field` (default
# `main.kai`). The function dies with a clear diagnostic when an
# explicit `entry = "..."` points at a file that does not exist.
#
# Emits nothing (returning success) when the spec is empty AND no
# manifest exists AND the legacy single-`.kai`-file heuristic does
# not fire — callers detect this with `[ -n "$src" ]` and surface
# their own usage error.
resolve_package_spec() {
  spec="${1:-}"
  # The status verb is supplied by the caller so non-build subcommands
  # (e.g. `kai fmt`) do not announce "building". Defaults to "building"
  # for build/run/test/check/bench, which all compile.
  action="${2:-building}"
  case "$spec" in
    ""|".")
      target_dir="$(pwd)"
      manifest_dir_inf="$(find_manifest_dir "$target_dir")"
      if [ -n "$manifest_dir_inf" ] && [ "$manifest_dir_inf" = "$target_dir" ]; then
        entry_rel="$(manifest_entry_field "$manifest_dir_inf")"
        entry_path="$manifest_dir_inf/$entry_rel"
        if [ ! -f "$entry_path" ]; then
          die "kai.toml declares entry = '$entry_rel' but $entry_path does not exist"
        fi
        pkg_name_inf="$(manifest_package_name "$manifest_dir_inf")"
        if [ -n "$pkg_name_inf" ]; then
          echo "kai: $action package '$pkg_name_inf' (entry point: $entry_rel)" >&2
        else
          echo "kai: using $entry_rel as entry point" >&2
        fi
        printf '%s' "$entry_path"
        return 0
      fi
      infer_entry_point_legacy
      return $?
      ;;
    ./*)
      sub_path="${spec#./}"
      sub_path="${sub_path%/}"
      [ -d "$sub_path" ] || die "$spec is not a directory"
      if [ ! -f "$sub_path/kai.toml" ]; then
        die "$spec has no kai.toml — sub-packages must declare their own manifest"
      fi
      entry_rel="$(manifest_entry_field "$sub_path")"
      entry_path="$sub_path/$entry_rel"
      if [ ! -f "$entry_path" ]; then
        die "$sub_path/kai.toml declares entry = '$entry_rel' but $entry_path does not exist"
      fi
      pkg_name_inf="$(manifest_package_name "$sub_path")"
      if [ -n "$pkg_name_inf" ]; then
        echo "kai: $action package '$pkg_name_inf' (entry point: $entry_path)" >&2
      else
        echo "kai: using $entry_path as entry point" >&2
      fi
      printf '%s' "$entry_path"
      ;;
    *.kai)
      printf '%s' "$spec"
      ;;
    *)
      die "expected a .kai file, '.', or './<sub-package>' (got: $spec)"
      ;;
  esac
}

# Legacy entry-point heuristic preserved for cwds without a
# kai.toml. Picks ./main.kai if it exists, otherwise the lone .kai
# file at depth 1. Emits nothing when neither rule matches; the
# caller surfaces its own usage error so the message stays subcommand
# specific (`see 'kai build --help'`).
infer_entry_point_legacy() {
  if [ -f "./main.kai" ]; then
    echo "kai: using ./main.kai as entry point" >&2
    printf './main.kai'
    return 0
  fi
  candidate=""
  count=0
  for f in ./*.kai; do
    [ -f "$f" ] || continue
    candidate="$f"
    count=$((count + 1))
  done
  if [ "$count" = "1" ]; then
    echo "kai: using $candidate as entry point (only .kai file in cwd)" >&2
    printf '%s' "$candidate"
    return 0
  fi
  printf ''
}

# Backwards-compatible alias retained for any caller that still
# reaches for the old name. New code paths funnel through
# resolve_package_spec.
infer_entry_point() {
  resolve_package_spec ""
}

# Run kaic2 in a non-binary-producing reporting mode (`--holes`,
# `--holes-json`, `--diags-json`, `--effects-json`,
# `--effect-holes-json`, `--library-mode`). The compiler's report
# is the entire output of this invocation — no binary is produced.
# Uses the same `--path` flags as a normal build so the report's
# in-scope entries match what the user actually sees at compile
# time.
run_report_mode() {
  src="$1"; flag="$2"
  [ -f "$src" ] || die_file_not_found "$src" "build"
  ensure_built
  src_dir="$(cd "$(dirname "$src")" && pwd)"
  manifest_dir="$(find_manifest_dir "$src_dir")"
  edition_flag="$(manifest_edition_flag "$manifest_dir")"
  pkg_path_flags=""
  unstable_flags=""
  if [ -n "$manifest_dir" ]; then
    pkg_path_flags="$(manifest_path_flags "$manifest_dir")"
    unstable_flags="$(manifest_unstable_flags "$manifest_dir")"
  fi
  # shellcheck disable=SC2086
  (unset KAI_TRACE_RC; "$KAIC2" --path "$STDLIB_ROOT" --path "$src_dir" $pkg_path_flags $unstable_flags $edition_flag "$flag" "$src")
}

# Back-compat alias — older internal call sites referenced this name.
report_holes() { run_report_mode "$@"; }

cmd_build() {
  src=""; out=""; report_mode=""; backend_cli=""; opt_level=""
  while [ $# -gt 0 ]; do
    case "$1" in
      -o) shift; [ $# -gt 0 ] || die "-o needs an argument"; out="$1"; shift ;;
      -h|--help) usage_build; return 0 ;;
      # Reporting modes — mutually exclusive, no binary produced.
      # All of these run the compiler through lex / parse / resolve /
      # infer and emit a JSON or text report, then exit. They are
      # intended for tooling (LSP, agents, linters) that needs the
      # typed-AST view without paying for codegen.
      --holes)
        [ -z "$report_mode" ] || die "report-mode flags are mutually exclusive"
        report_mode="--holes"; shift ;;
      --holes-json)
        [ -z "$report_mode" ] || die "report-mode flags are mutually exclusive"
        report_mode="--holes-json"; shift ;;
      --diags-json)
        [ -z "$report_mode" ] || die "report-mode flags are mutually exclusive"
        report_mode="--diags-json"; shift ;;
      --effects-json)
        [ -z "$report_mode" ] || die "report-mode flags are mutually exclusive"
        report_mode="--effects-json"; shift ;;
      --effect-holes-json)
        [ -z "$report_mode" ] || die "report-mode flags are mutually exclusive"
        report_mode="--effect-holes-json"; shift ;;
      --library-mode)
        [ -z "$report_mode" ] || die "report-mode flags are mutually exclusive"
        report_mode="--library-mode"; shift ;;
      --backend=*)
        backend_cli="${1#--backend=}"; shift
        case "$backend_cli" in
          c|native) ;;
          *) die "--backend must be 'c' or 'native' (got: $backend_cli)" ;;
        esac ;;
      --backend)
        shift; [ $# -gt 0 ] || die "--backend needs an argument (c|native)"
        backend_cli="$1"; shift
        case "$backend_cli" in
          c|native) ;;
          *) die "--backend must be 'c' or 'native' (got: $backend_cli)" ;;
        esac ;;
      # L4 (issue #498): optimisation profile for the native backend.
      # Default (no flag) is `--release` = `-O2`, matching the `cc -O2`
      # the C path gets. `--debug` drops to `-O0` (fast compile, no
      # inlining, symbols kept). Threaded to the in-process libLLVM
      # pipeline via KAI_NATIVE_OPT (read by the emit prim); the C
      # backend ignores it (it already gets -O2 / -O0 from CFLAGS).
      --debug)   opt_level="0"; shift ;;
      --release) opt_level="2"; shift ;;
      -*) die "unknown flag: $1 (see 'kai build --help')" ;;
      *) [ -z "$src" ] || die "only one input supported"; src="$1"; shift ;;
    esac
  done
  src="$(resolve_package_spec "$src")"
  [ -n "$src" ] || die "missing input file (see 'kai build --help')"
  set -- $(resolve_backend "$backend_cli")
  backend="$1"; backend_origin="$2"
  export KAI_NATIVE_OPT="${opt_level:-2}"
  if [ -n "$report_mode" ]; then
    [ -z "$out" ] || die "$report_mode does not produce a binary; drop -o <out>"
    # Report modes run the typer only — backend selection is irrelevant.
    [ -z "$backend_cli" ] || die "$report_mode is independent of --backend; drop the flag"
    run_report_mode "$src" "$report_mode"
    return $?
  fi
  if [ -z "$out" ]; then
    # Default output name: prefer the package name from kai.toml
    # over the entry-point's basename, so a package laid out as
    # `notes/{kai.toml,main.kai,...}` builds to `./notes` not
    # `./main`. Mirrors `go build` which uses the module name.
    # Issue #658: when the src lives under a sub-package (its
    # manifest dir differs from cwd), the binary goes into that
    # sub-package dir rather than the cwd. This both matches
    # `go build ./sub` placement and avoids the path collision
    # where `./sub` is already a directory.
    src_dir_abs="$(cd "$(dirname "$src")" && pwd)"
    manifest_dir_for_out="$(find_manifest_dir "$src_dir_abs")"
    pkg_name="$(manifest_package_name "$manifest_dir_for_out")"
    if [ -n "$pkg_name" ]; then
      bin_name="$pkg_name"
    else
      bin_name="$(basename "$src" .kai)"
    fi
    cwd_abs="$(pwd)"
    if [ -n "$manifest_dir_for_out" ] && [ "$manifest_dir_for_out" != "$cwd_abs" ]; then
      out="$manifest_dir_for_out/$bin_name"
    else
      out="$bin_name"
    fi
  fi
  tmp="$(mktemp -d)"
  trap 'rm -rf "$tmp"' EXIT INT TERM
  compile_to_binary --backend "$backend" --backend-origin "$backend_origin" "$src" "$tmp" "$out" "build"
}

cmd_run() {
  backend_cli=""; opt_level=""
  while [ $# -gt 0 ]; do
    case "$1" in
      -h|--help) usage_run; return 0 ;;
      --backend=*)
        backend_cli="${1#--backend=}"; shift
        case "$backend_cli" in
          c|native) ;;
          *) die "--backend must be 'c' or 'native' (got: $backend_cli)" ;;
        esac ;;
      --backend)
        shift; [ $# -gt 0 ] || die "--backend needs an argument (c|native)"
        backend_cli="$1"; shift
        case "$backend_cli" in
          c|native) ;;
          *) die "--backend must be 'c' or 'native' (got: $backend_cli)" ;;
        esac ;;
      # L4 (issue #498): native optimisation profile (see cmd_build).
      --debug)   opt_level="0"; shift ;;
      --release) opt_level="2"; shift ;;
      --) shift; break ;;
      *) break ;;
    esac
  done
  case "${1:-}" in
    "") src="$(resolve_package_spec "")"
        [ -n "$src" ] || die "missing input file (see 'kai run --help')" ;;
    .|./*)
        src="$(resolve_package_spec "$1")"; shift
        [ -n "$src" ] || die "missing input file (see 'kai run --help')" ;;
    *)  src="$1"; shift ;;
  esac
  set -- $(resolve_backend "$backend_cli") "$@"
  backend="$1"; backend_origin="$2"; shift 2
  export KAI_NATIVE_OPT="${opt_level:-2}"
  tmp="$(mktemp -d)"
  trap 'rm -rf "$tmp"' EXIT INT TERM
  bin="$tmp/$(basename "$src" .kai)"
  compile_to_binary --backend "$backend" --backend-origin "$backend_origin" "$src" "$tmp" "$bin" "run"
  "$bin" "$@"
}

# Issue #658: `kai test ./...` walks the cwd subtree and runs
# `kai test` for every directory that carries its own kai.toml.
# Aggregate status is the OR of every sub-run's exit code, so CI
# fails the moment any package's tests do. Packages are visited in
# `find`'s default order (lexicographic per level), keeping output
# stable across runs. Directories without a kai.toml are skipped
# silently — they are not separately buildable.
run_tests_recursively() {
  extra_flags="$1"
  cwd_abs="$(pwd)"
  # `find -print` rather than `-print0` keeps the loop portable
  # across BSD/GNU `find`; package directory names cannot contain
  # newlines in practice (kai-pkg rejects them at init time).
  manifests="$(find . -name kai.toml -type f 2>/dev/null | sort)"
  if [ -z "$manifests" ]; then
    echo "kai: no kai.toml found under $cwd_abs" >&2
    return 1
  fi
  # The body loop runs in a subshell under POSIX sh (piped from
  # printf), so counter state must materialise on disk to survive
  # the loop boundary. Two tiny tally files do the job without
  # pulling in a temp dir lifecycle.
  fail_marker="$(mktemp -t kai-test-rec-fail.XXXXXX)"
  count_marker="$(mktemp -t kai-test-rec-count.XXXXXX)"
  trap 'rm -f "$fail_marker" "$count_marker"' RETURN 2>/dev/null || true
  : > "$fail_marker"
  printf '0' > "$count_marker"
  printf '%s\n' "$manifests" | while IFS= read -r manifest; do
    pkg_dir="$(dirname "$manifest")"
    pkg_name_inf="$(manifest_package_name "$pkg_dir")"
    if [ -n "$pkg_name_inf" ]; then
      label="$pkg_name_inf ($pkg_dir)"
    else
      label="$pkg_dir"
    fi
    entry_rel="$(manifest_entry_field "$pkg_dir")"
    entry_path="$pkg_dir/$entry_rel"
    if [ ! -f "$entry_path" ]; then
      printf '== kai test SKIP %s (no %s)\n' "$label" "$entry_rel" >&2
      continue
    fi
    printf '== kai test %s\n' "$label" >&2
    # shellcheck disable=SC2086
    if ( cd "$pkg_dir" && "$SCRIPT" test $extra_flags ); then
      :
    else
      printf 'fail' > "$fail_marker"
      printf '== FAIL %s\n' "$label" >&2
    fi
    cur="$(cat "$count_marker")"
    printf '%d' "$((cur + 1))" > "$count_marker"
  done
  count="$(cat "$count_marker" 2>/dev/null || echo 0)"
  failed=""
  [ -s "$fail_marker" ] && failed=1
  rm -f "$fail_marker" "$count_marker"
  if [ "$count" = 0 ]; then
    echo "kai: no buildable packages found under $cwd_abs" >&2
    return 1
  fi
  if [ -n "$failed" ]; then
    return 1
  fi
  printf 'kai: all package tests passed (%d package(s))\n' "$count" >&2
  return 0
}

cmd_test() {
  # Issue #318: parse `--include-prelude-tests` here so we can forward
  # it to kaic2 alongside the implicit `--test`. Any non-flag argument
  # is the source file; everything else gets passed straight through.
  extra_flags=""
  while [ $# -gt 0 ]; do
    case "$1" in
      -h|--help) usage_test; return 0 ;;
      --include-prelude-tests) extra_flags="$extra_flags --include-prelude-tests"; shift ;;
      --) shift; break ;;
      -*) extra_flags="$extra_flags $1"; shift ;;
      *) break ;;
    esac
  done
  case "${1:-}" in
    "./..."|"...") shift
        run_tests_recursively "$extra_flags"
        return $? ;;
    "") src="$(resolve_package_spec "")"
        [ -n "$src" ] || die "missing input file (see 'kai test --help')" ;;
    .|./*)
        src="$(resolve_package_spec "$1")"; shift
        [ -n "$src" ] || die "missing input file (see 'kai test --help')" ;;
    *)  src="$1"; shift ;;
  esac
  tmp="$(mktemp -d)"
  trap 'rm -rf "$tmp"' EXIT INT TERM
  bin="$tmp/$(basename "$src" .kai)-t"
  # shellcheck disable=SC2086
  compile_to_binary "$src" "$tmp" "$bin" "test" --test $extra_flags

  # Tests-dir auto-discovery: when the resolved entry sits next to a
  # `tests/` sibling directory containing `*.kai` files (the
  # convention introduced by issue #569 / `sibling_examples_tests`),
  # compile and run each test file in addition to the entry. Imports
  # in those files resolve to the package's own modules via sibling
  # resolution. The aggregate exit code is the OR of every run, so
  # any failing test file fails `kai test .` overall.
  entry_dir="$(dirname "$src")"
  tests_dir="$entry_dir/tests"
  entry_status=0
  "$bin" || entry_status=$?
  if [ ! -d "$tests_dir" ]; then
    return $entry_status
  fi
  test_files=""
  for tf in "$tests_dir"/*.kai; do
    [ -f "$tf" ] || continue
    test_files="$test_files $tf"
  done
  if [ -z "$test_files" ]; then
    return $entry_status
  fi
  agg_status=$entry_status
  # shellcheck disable=SC2086
  for tf in $test_files; do
    tbin="$tmp/$(basename "$tf" .kai)-t"
    printf '== kai test %s\n' "$tf" >&2
    # shellcheck disable=SC2086
    compile_to_binary "$tf" "$tmp" "$tbin" "test" --test $extra_flags
    "$tbin" || agg_status=$?
  done
  return $agg_status
}

cmd_bench() {
  iters_override=""
  while [ $# -gt 0 ]; do
    case "$1" in
      -h|--help) usage_bench; return 0 ;;
      --iters)
        [ $# -ge 2 ] || die "--iters requires a value (see 'kai bench --help')"
        iters_override="$2"; shift 2 ;;
      --iters=*) iters_override="${1#--iters=}"; shift ;;
      --) shift; break ;;
      -*) die "unknown option: $1 (see 'kai bench --help')" ;;
      *) break ;;
    esac
  done
  case "${1:-}" in
    "") src="$(resolve_package_spec "")"
        [ -n "$src" ] || die "missing input file (see 'kai bench --help')" ;;
    .|./*)
        src="$(resolve_package_spec "$1")"; shift
        [ -n "$src" ] || die "missing input file (see 'kai bench --help')" ;;
    *)  src="$1"; shift ;;
  esac
  if [ -n "$iters_override" ]; then
    case "$iters_override" in
      ''|*[!0-9]*) die "--iters value must be a positive integer (got: $iters_override)" ;;
    esac
    [ "$iters_override" -gt 0 ] || die "--iters value must be a positive integer (got: $iters_override)"
  fi
  tmp="$(mktemp -d)"
  trap 'rm -rf "$tmp"' EXIT INT TERM
  bin="$tmp/$(basename "$src" .kai)-b"
  compile_to_binary "$src" "$tmp" "$bin" "bench" --bench
  if [ -n "$iters_override" ]; then
    KAI_BENCH_ITERS="$iters_override" "$bin"
  else
    "$bin"
  fi
}

cmd_check() {
  case "${1:-}" in
    -h|--help) usage_check; return 0 ;;
    "") src="$(resolve_package_spec "")"
        [ -n "$src" ] || die "missing input file (see 'kai check --help')" ;;
    .|./*)
        src="$(resolve_package_spec "$1")"; shift
        [ -n "$src" ] || die "missing input file (see 'kai check --help')" ;;
    *)  src="$1"; shift ;;
  esac
  tmp="$(mktemp -d)"
  trap 'rm -rf "$tmp"' EXIT INT TERM
  bin="$tmp/$(basename "$src" .kai)-c"
  compile_to_binary "$src" "$tmp" "$bin" "check" --prop-check
  "$bin"
}

# kai fmt — pretty-print kaikai source canonically.
#
# Three input modes:
#   kai fmt <file>             -> rewrite <file> in place
#   kai fmt --check <file>     -> exit 1 if <file> would change, else 0;
#                                  print formatted text to stdout when
#                                  different (matches `gofmt -l` spirit
#                                  but with the diff in the body).
#   kai fmt --stdin            -> read stdin, write formatted to stdout.
#
# The formatter is implemented as a `kaic2 --fmt` (or `--fmt-check`)
# subcommand. fmt runs at the source-text level and never resolves
# names, so the core-stdlib auto-load is irrelevant here.
cmd_fmt() {
  src=""; mode_check=""; stdin_mode=""
  while [ $# -gt 0 ]; do
    case "$1" in
      -h|--help) usage_fmt; return 0 ;;
      --check)   mode_check=1; shift ;;
      --stdin)   stdin_mode=1; shift ;;
      -*)        die "unknown flag: $1 (see 'kai fmt --help')" ;;
      *)         [ -z "$src" ] || die "only one input file supported"
                 src="$1"; shift ;;
    esac
  done
  ensure_built

  if [ -n "$stdin_mode" ]; then
    [ -z "$src" ] || die "--stdin takes no file argument"
    tmp="$(mktemp -d)"
    trap 'rm -rf "$tmp"' EXIT INT TERM
    cat > "$tmp/in.kai"
    "$KAIC2" --fmt "$tmp/in.kai"
    return $?
  fi

  if [ -z "$src" ]; then
    src="$(resolve_package_spec "" "formatting")"
  else
    case "$src" in
      .|./*) src="$(resolve_package_spec "$src" "formatting")" ;;
    esac
  fi
  [ -n "$src" ] || die "missing input file (see 'kai fmt --help')"
  [ -f "$src" ] || die_file_not_found "$src" "fmt"

  if [ -n "$mode_check" ]; then
    "$KAIC2" --fmt-check "$src"
    return $?
  fi

  tmp="$(mktemp -d)"
  trap 'rm -rf "$tmp"' EXIT INT TERM
  if "$KAIC2" --fmt "$src" > "$tmp/out.kai"; then
    # Only write back when the formatted text differs (avoids touching
    # the file mtime on a no-op).
    if ! cmp -s "$src" "$tmp/out.kai"; then
      cat "$tmp/out.kai" > "$src"
    fi
  else
    cat "$tmp/out.kai" >&2 2>/dev/null || true
    return 1
  fi
}

# kai watch — recompile + run on every save.
#
# Two backends:
#   1. fswatch -o "$src"   → one line per change event (lowest latency).
#   2. mtime poll (500 ms) → portable fallback when fswatch is absent.
#
# The compile/run cycle runs once immediately on entry so the audience
# sees output before they touch the file. Build failures do not exit
# the loop — the watcher keeps running so the next save retries.
file_mtime() {
  if stat -f %m "$1" 2>/dev/null; then
    return 0
  fi
  stat -c %Y "$1" 2>/dev/null || echo 0
}

watch_run_once() {
  src="$1"; tmp="$2"
  bin="$tmp/$(basename "$src" .kai)"
  ts="$(date '+%H:%M:%S')"
  if compile_to_binary "$src" "$tmp" "$bin" "watch" 2>"$tmp/err"; then
    printf '\n[%s] Build OK\n' "$ts"
    "$bin" || printf '\n[%s] Program exited with status %d\n' "$ts" "$?"
  else
    printf '\n[%s] Build FAILED\n' "$ts"
    cat "$tmp/err" >&2
  fi
}

cmd_watch() {
  case "${1:-}" in
    -h|--help) usage_watch; return 0 ;;
    "") src="$(resolve_package_spec "")"
        [ -n "$src" ] || die "missing input file (see 'kai watch --help')" ;;
    .|./*)
        src="$(resolve_package_spec "$1")"; shift
        [ -n "$src" ] || die "missing input file (see 'kai watch --help')" ;;
    *)  src="$1"; shift ;;
  esac
  [ -f "$src" ] || die_file_not_found "$src" "watch"
  abs_src="$(cd "$(dirname "$src")" && pwd)/$(basename "$src")"
  tmp="$(mktemp -d)"
  trap 'rm -rf "$tmp"' EXIT INT TERM

  printf 'kaikai watch — recompiling on every save\n'
  printf 'Watching: %s\n' "$abs_src"
  if command -v fswatch >/dev/null 2>&1; then
    printf '(backend: fswatch)\n'
  else
    printf '(backend: mtime poll @ 500ms — install fswatch for lower latency)\n'
  fi

  watch_run_once "$abs_src" "$tmp"

  if command -v fswatch >/dev/null 2>&1; then
    fswatch -o "$abs_src" | while read -r _; do
      watch_run_once "$abs_src" "$tmp"
    done
  else
    last="$(file_mtime "$abs_src")"
    while :; do
      sleep 0.5 2>/dev/null || sleep 1
      cur="$(file_mtime "$abs_src")"
      if [ "$cur" != "$last" ]; then
        last="$cur"
        watch_run_once "$abs_src" "$tmp"
      fi
    done
  fi
}

# Package manager commands (issue #405). All shell out to
# tools/kai-pkg, which is auto-built on first use via ensure_kaipkg.
cmd_init() {
  case "${1:-}" in
    -h|--help)
      cat <<EOF
usage: kai init <name>

Write a stub kai.toml in the current directory with the given
package name and version 0.1.0. Errors out if kai.toml already
exists.
EOF
      return 0 ;;
    "") die "missing package name (see 'kai init --help')" ;;
  esac
  if [ -f kai.toml ]; then
    die "kai.toml already exists in $(pwd)"
  fi
  ensure_kaipkg
  "$KAIPKG_BIN" init "$@"
}

cmd_install() {
  case "${1:-}" in
    -h|--help)
      cat <<EOF
usage: kai install

Read kai.toml in the current directory (or the nearest ancestor)
and resolve dependencies. v1: local-path deps are reported as
resolved; git deps are deferred to a follow-up release.
EOF
      return 0 ;;
  esac
  manifest_dir="$(find_manifest_dir "$(pwd)")"
  if [ -z "$manifest_dir" ]; then
    die "no kai.toml found in $(pwd) or any parent directory"
  fi
  ensure_kaipkg
  cache_root="$(resolve_cache_root)"
  mkdir -p "$cache_root"
  ( cd "$manifest_dir" && KAIKAI_CACHE_ROOT="$cache_root" "$KAIPKG_BIN" install )
}

cmd_add() {
  case "${1:-}" in
    -h|--help)
      cat <<EOF
usage: kai add <source>[@<ref>]

Fetch a dependency, add it to kai.toml, and update kai.lock.

Source forms:
  github.com/owner/repo@v1.0      shorthand (string-form)
  github.com/owner/repo           ref defaults to HEAD/main
  ../local-thing                  local path override

Examples:
  kai add github.com/lnds/manutara@v0.1
  kai add github.com/lnds/kohau

Cache: \$KAIKAI_CACHE or ~/.cache/kai/pkg/.
EOF
      return 0 ;;
    "") die "missing source argument (see 'kai add --help')" ;;
  esac
  manifest_dir="$(find_manifest_dir "$(pwd)")"
  if [ -z "$manifest_dir" ]; then
    die "no kai.toml found in $(pwd) or any parent directory"
  fi
  ensure_kaipkg
  cache_root="$(resolve_cache_root)"
  mkdir -p "$cache_root"
  ( cd "$manifest_dir" && KAIKAI_CACHE_ROOT="$cache_root" "$KAIPKG_BIN" add "$@" )
}

cmd_update() {
  case "${1:-}" in
    -h|--help)
      cat <<EOF
usage: kai update [<name>]

Re-fetch the named dependency (or all of them if no name given)
and refresh kai.lock with the latest commit on the declared ref.
EOF
      return 0 ;;
  esac
  manifest_dir="$(find_manifest_dir "$(pwd)")"
  if [ -z "$manifest_dir" ]; then
    die "no kai.toml found in $(pwd) or any parent directory"
  fi
  ensure_kaipkg
  cache_root="$(resolve_cache_root)"
  mkdir -p "$cache_root"
  ( cd "$manifest_dir" && KAIKAI_CACHE_ROOT="$cache_root" "$KAIPKG_BIN" update "$@" )
}

